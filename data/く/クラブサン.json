        "examples": {
          "standard": [
            {
              "text": "彼の演奏するクラブサンは、まるでバロック時代にタイムスリップしたようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラブサンの音色は、ピアノとはまた違った魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は古いクラブサンを修理して、再び美しい音を奏でた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "乙女は頭傾け白き指先運ばせて深き思ひにくれつゝもクラブサン奏ではじめぬ。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜に細き指先運ばせてかなでし象牙のクラブサン。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいさん、出し巻の玉子、どうもなってえへんやろか」「それよりクラブサンドイッチが怪しいで。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルでクラブサンドウィッチ食って青山へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
