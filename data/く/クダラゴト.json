        "examples": {
          "standard": [
            {
              "text": "百済琴は、古代朝鮮半島で使われていた弦楽器である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、百済琴の復元品が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "百済琴の音色は、遠い昔の物語を奏でるようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さればこそ絶えず梭燃え、乱れうつ火の無花果の百済琴。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また光る白き兜の八幡座、火の無花果の百済琴。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
