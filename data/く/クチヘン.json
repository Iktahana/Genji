        "examples": {
          "standard": [
            {
              "text": "「語」「話」「言」など、多くの漢字で口偏が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "部首の口偏は、その漢字が言葉や発話に関連していることを示唆することが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "漢字の成り立ちを学ぶ際、口偏を持つ字の共通点に注目すると面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "呪とは口偏に兄という字ですが、普通にこの呪という字は「のろい」とか、「のろう」とかいうふうに読まれています。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
