        "examples": {
          "standard": [
            {
              "text": "着物の首上には、繊細な刺繍が施されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は風邪をひいて首上を冷やしてしまい、熱を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このセーターは首上がしっかりと作られていて、とても暖かい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……鷹揚に、然も手馴れて、迅速に結束し果てた紳士は、其の爲に空しく待構へて居たらしい兩手にづかりと左右、其の二人の女の、頸上と思ふあたりを無手と掴んで引立てる、と、呀？",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえにかの帝王宰相らが武備拡張に従事するものは、人を斬らんと欲してかえって短剣をば己れが頸上に擬するものにあらずや。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
