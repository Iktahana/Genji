        "examples": {
          "standard": [
            {
              "text": "誘拐犯は、人質が叫び声を上げないように布で口枷をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は真実を話そうとしたが、権力という見えない口枷をはめられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い拷問器具の展示の中に、鉄で作られた恐ろしい口枷があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "主題が緊張しているばかりでなく、云いたいことを云わせられず、書きたいようにかかされない、その手枷、口枷のなかで、もがいたり呻いたりしている作品である。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第四巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「血を恐れるというのは、最初血が流されたら、人の獣性が猛りたち、文明の仮面は落ち、獰猛な牙をそなえた獣面が現われて、それに口枷をはめることができるかどうかわからなくなるだろうという、ひそかな本能的な感情からなんだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
