        "examples": {
          "standard": [
            {
              "text": "幼い頃、母が読み聞かせてくれた「クマのプーさん」の物語が大好きだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "百町森（100エーカーの森）を舞台にした、クマのプーさんと仲間たちの日常には哲学的な教えが含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の誕生日プレゼントに、赤いシャツを着たクマのプーさんのぬいぐるみを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「クマのプーさん」原作者のＡ・Ａ・ミルンの日本における著作権保護期間が2017年5月末に満了したそうですが、そのとき先にパブリックドメインとなって公開されているカナダの電子テキストを底本にして、通勤の途中にスマホを使いつつ、twitter に挙げながら訳したものです。",
              "citation": {
                "source": "ぼくら　ふたり",
                "author": "US TWO",
                "note": "青空文庫"
              }
            }
          ]
        }
