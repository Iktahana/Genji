        "examples": {
          "standard": [
            {
              "text": "ドリアンは、その強烈な匂いから果物の王様と呼ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東南アジアでは、ドリアンは高級な果物の王様として珍重されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "果物の王様と呼ばれるドリアンを、初めて食べた時の衝撃は忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何処からとりよせたか、果物の王様といわれるマンゴーの生々したのを老人の枕頭に供えるものもあった。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "果物と言へば、秋に実る果物の王様はなんと言つても林檎でせうね、この林檎の木と言ふものは、平坦な土地ではうまくそだたないものなのです。",
              "citation": {
                "source": "果物の木の在所",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
