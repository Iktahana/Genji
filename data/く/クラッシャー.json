        "examples": {
          "standard": [
            {
              "text": "建設現場では、岩石を砕く大型のクラッシャーが稼働していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プラスチックごみを効率的に処理するため、高性能なクラッシャーが導入された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉱山で採掘された鉱石は、まずクラッシャーで細かく砕かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして十月の七日の朝、大きな石を入れる時に、その石と一緒に、クラッシャーの中へ嵌りました。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもいいけど、北尾の茶番のお相手なんかやっちまったクラッシャー・バンバン・ビガロよ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラッシャー・バンバン・ビガロの死を悼み、合掌。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロモーターたちがもっともおそれていたのは、ただで会場に入ってしまうゲイト・クラッシャーたちだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
