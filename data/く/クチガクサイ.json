        "examples": {
          "standard": [
            {
              "text": "ニンニクをたっぷり食べた翌日は、自分でも口が臭いのが分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お父さん、口が臭いよ！」と娘に言われ、彼はショックを隠せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "営業マンにとって、口が臭いことは致命的なマイナスポイントになりかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "傍へ寄るな、口が臭いや、こいつらも！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が子供の時分には、母は時々私を抱きあげて、「お前は虫歯がある位ひなんだから、そして寝る頃になつて何か食べたがつたりする癖があるんだから、どうかすると口が臭いことがあるぜ、口が臭い程みつともないことはないんだから余ツ程気をつけなければいけないよ。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もあの與三郎と來た日にや、ケチで、見得坊で、燒餅で、執こくて、鼻づまりで、口が臭い。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
