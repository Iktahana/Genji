        "examples": {
          "standard": [
            {
              "text": "夕暮れの田んぼから、昔ながらの組歌が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は日本の伝統的な組歌を研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "組歌の美しい旋律は、聴く人の心を和ませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "室町以後江戸の初期へかけて、中世以前、上流の専有であつた組歌が、民間に盛んに行はれる様になり、古い琴歌は、いつしか、新しい組唄を生じ、三味線にも組唄がかけられてゐた。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうしたかけ合ひを以て出発した歌が、かけ合ひに進むと同時に、一人の層畳的発想、即、組歌形式をも採つて行く様になる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
