        "examples": {
          "standard": [
            {
              "text": "昔の農家では、肥やしとして使うために糞桶で人糞を運んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、祖父が糞桶を抱えて畑に向かう姿をよく見たものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この時代の絵巻物には、庶民が糞桶を運ぶ様子が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "監督が上にあがって行くと、出しかけていた糞桶をまたもとの廃坑へ放りこんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫までは糞桶を担いでいた百姓が俄に紋付の羽織を着る地主様となって、お邸の旦那様が一朝にして下掃除人の地借或は店借となって了う。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
