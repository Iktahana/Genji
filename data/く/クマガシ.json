          "standard": [
            {
              "text": "古びた神社の境内にそびえ立つ見事な熊樫が、周囲に濃い緑の影を落としている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熊樫の非常に硬くて丈夫な木材は、昔から農具の柄や建築資材として重宝されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あの大きな熊樫の古木が、何百年もこの村の変遷をずっと見守ってきたんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "命あるものは、これからがいせんして、あの平群の山の、くまがしの葉を、髪に飾って祝い楽しめよ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
