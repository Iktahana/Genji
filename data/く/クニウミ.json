        "examples": {
          "standard": [
            {
              "text": "日本の神話では、イザナギとイザナミの二神が国生みを行ったとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国生みの物語は、古事記や日本書紀に詳しく記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アニメーション映画で、壮大な国生みの場面が描かれ、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "淡島を腹として国生みをする、といふ事も、昔から難解の句とせられてゐて、或学者は、此を「長男として」の義に解したが、誤りである。",
              "citation": {
                "source": "神道に現れた民族論理",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "安岡氏によると、三種の神器は知徳勇を表徴するものであって、日本国土はただの自然的地理的土壌ではなく、〔国生みの神〕の眼から生れた「大八州」なのだから、「〔天皇種族〕」と兄弟の関係に立つのだと云った種類の説明が与えられる。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
