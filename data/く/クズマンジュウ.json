        "examples": {
          "standard": [
            {
              "text": "夏になると、冷たい葛饅頭が食べたCくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "透明な葛の衣に包まれた葛饅頭は、見た目も涼しげだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "抹茶と一緒に葛饅頭をいただくと、心が安らぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "飴の湯、かんとう焼、白玉焼、葛饅頭、粟の餅。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其茶碗を倒にして持つた手を左の手の平へぽんと叩きつけると中から白い葛饅頭が出るのであつた。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は血相かへて（と少年の眼にはうつつた）、いきなりその葛饅頭を、流しの下の土間へ、紙ごと投げこんでしまつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
