        "examples": {
          "standard": [
            {
              "text": "江戸時代、幕府は全国の国絵図を作成させ、統治に役立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館で展示されている古い国絵図には、当時の地理情報が詳細に描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国絵図を紐解くと、街道や主要な城の位置がよく分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "備えつけの武器什器、民政の諸帳簿類から国絵図、すべて目録にして、きちんと、置くべき所へ置いて、公儀の使者を待っていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
