    "definitions": [
      {
        "index": 1,
        "gloss": "(in Onmyōdō) divination of a person's fate based on the nine celestial bodies's positions at birth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
