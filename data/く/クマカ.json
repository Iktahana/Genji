        "examples": {
          "standard": [
            {
              "text": "ジャイアントパンダや北極熊も、生物学的分類では同じクマ科の仲間に含まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クマ科の動物は非常に優れた嗅覚を持ち、餌を求めて一晩で数十キロ移動することもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、クマ科の中で最も体が大きくて力が強いのは、どの種類か知っているかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いちど、あまり大きな足あとがつづいているので、クマかと思っておどろいたら、「がんじき」というものをはいてあるいたあとだった。",
              "citation": {
                "source": "山の雪",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら、クマかなんかが、洞くつの中へまよいこんでいたのではないでしょうか。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたわのクマかしら。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
