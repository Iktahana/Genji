        "examples": {
          "standard": [
            {
              "text": "あの営業担当者は口数が多いけれど、肝心な説明が抜けていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊張するとつい口数が増えてしまうのは、私の悪い癖だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君は本当に口数が多いな」と、祖父に笑いながらたしなめられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の性質は、口数が多いというよりは寧ろしんねりむっつりの方で、常に教養を高めようという誠に殊勝な心掛けさえもっていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "サガ　　男の衆は、すこし、口数が多いよ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猿、往来調べの木戸へかかったら、おれの側を離れて通れよ」「はい」「てめえは一体、口達者で、口数が多いから、何を訊かれても、なるたけ黙っているんだぞ」「へい」「ボロを出すと、おれは知らん顔して、捨てて行ってしまうぞ」　街道の木戸は、次々にあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
