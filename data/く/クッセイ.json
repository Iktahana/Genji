          "standard": [
            {
              "text": "植物の屈性は、成長方向を環境に適応させる重要な性質だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヒマワリは太陽の光に反応して首を動かす、顕著な屈性を示す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重力に対する植物の屈性を研究することは、宇宙農業に応用できる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば、不屈性というものにしろ、行為の基準というものにしろ、その側からだけ称えられても、それをもち来す根本の一貫したものが、人間精髄としてその者の背骨を通っていなければ、安ぶしんの二階通りお神楽で、上にちょいとのっかっているだけで、すこしひどく吹きつけると忽ち木端微塵である。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "御辺は、退屈性よの」「なぜ」「高松退陣以後、まだ半年と遊んじゃおらぬではないか」「ていよく、毛利への番人じゃった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち叫ぶお代の声「ヤア大変だ、満さん来てくっせいよ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
