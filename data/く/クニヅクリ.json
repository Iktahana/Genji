        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいリーダーは、これからの国づくりについて熱く語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害からの復興は、まさに国づくりの一環だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若者たちが国づくりに参加意識を持つことが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヨーコとの二人の共和国づくり、いや生まれてくる子との三人の共和国づくりは充分に生きることの目的たりうるのではないか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学への進学を拒否し、退路を断ったところで、ヨーコとの、そしてヒカルとの共和国づくりを夢みた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーコとの二人の共和国づくりは、充分に手応えのある生きることの意味に思えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうところに水道システムのぜんたいを移植して、きちんと維持させて機能させ、それを国づくりの基礎のひとつにしていく、というような仕事ですよ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
