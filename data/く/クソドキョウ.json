        "examples": {
          "standard": [
            {
              "text": "あんな危険なことに挑戦するなんて、クソ度胸としか言いようがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のクソ度胸には、周りの誰もが呆れ返っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お前はクソ度胸があるな。俺には真似できない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "やぶれかぶれのクソ度胸！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう間も無く前線に出ると言うことで、召集された者はみんな不安なようなそれでいて變にクソ度胸をすえてしまつたと言いますか、ドロンとした氣持でいました。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
