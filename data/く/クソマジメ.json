                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "クソ真面目な色男気取りの議論が国をほろぼしたんです。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
