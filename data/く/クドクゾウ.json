        "examples": {
          "standard": [
            {
              "text": "祖母は、人に優しくすることで功徳蔵を積んでいると信じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の長年の慈善活動は、まさに功徳蔵の表れと言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "功徳蔵を積むことは、来世の幸福につながると教えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
