        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古代の医師は、高熱を鎮めるために苦蘇という薬草を処方した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アフリカ原産の苦蘇は、伝統医学で様々な病気の治療に用いられてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "苦蘇の成分を抽出したエキスは、抗炎症作用があると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そんなわけで　いまの　いまでも　きのうえに　のぼって　ナトキンに　なぞなぞを　だそうものなら、　えだを　なげつけてきて　じだんだ　ふんで、　ぷんすか　わめくでしょう　――「くそ　――　くそ　――　くそ　――　くっそ　――　くそおおお！",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
