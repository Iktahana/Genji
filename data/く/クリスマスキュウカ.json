        "examples": {
          "standard": [
            {
              "text": "クリスマス休暇は実家に帰省して家族と過ごす予定です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年はクリスマス休暇を利用して海外旅行に行くことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クリスマス休暇中も仕事のメールが来て、なかなか休まらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "クリスマス休暇でニューヨークに帰ったとき、ワラは、じぶんの好みでもないのに、慶一の好きそうな、ファースト・ロッカーをたくさん見つけてきてくれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、クリスマス休暇の間に、彼はひとしきり町の外に出る旅行を行い、その一つはとある記録についてセーレムのエセックス研究所で調査するためだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
