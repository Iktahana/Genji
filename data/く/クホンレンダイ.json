        "examples": {
          "standard": [
            {
              "text": "修行を積んで悟りを開いた者だけが、九品蓮台の最も高い席に座ることを許される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れの湖に浮かぶ大輪のハスが、まるで極楽の九品蓮台のように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おや、あんなに見事な九品蓮台の彫刻は、他の寺ではなかなか見られませんよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのあとで死ねば九品蓮台の最上位にだって生まれることができるでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は「九品蓮台の中には、下品といふとも」と同じく紙に書いて答える。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
