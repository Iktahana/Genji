        "examples": {
          "standard": [
            {
              "text": "道端にひっそりと咲く熊葛の紫色の花は、どこか懐かしい趣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヨーロッパでは古くから、熊葛は神聖なハーブとして儀式に用いられてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の片隅に植えた熊葛が、夏の訪れとともに小さな花を咲かせ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この尾張の女が、美濃狐のことを聞いて、一度試してやろうと云うので、蛤と熊葛で作ったねり皮とを船に積んで、小川の市へやって来た。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、美濃狐が怒って、尾張の女を打とうと手を出すと、尾張の女はその手を捕えて、熊葛のねり皮で打った。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つぶたせて二の手を待つて、待つてゐましたとばかりその手を捉へ、熊葛鞭でピシリとやつた。",
              "citation": {
                "source": "春宵戲語",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
