        "examples": {
          "standard": [
            {
              "text": "バスの中で席を譲らなかった糞爺に、周りの人が白い目を向けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの糞爺、また若い女に声をかけてるぜ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は糞爺と言われても、全く気にせず自分の趣味に没頭していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "松次郎は馬車のうしろに向って、ペラリと舌を出すと、「糞爺いの金聾」と節をつけていって、ぽんぽんと鼓をたたいた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、お前に対して何か思うところのある、陪審員のくそじじいの仕業だとでも言うのか？",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの　すきに　させてやるから　とっとと　うせろや　このくそじじい！",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
