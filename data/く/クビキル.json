        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "怒り狂った武士は、躊躇なく敵の首を切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝説の剣豪は、一刀のもとに大蛇の首を切ったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のワンシーンで、主人公が怪物たちの首を切って進んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ホウゴウ社の蕃人たちが内地人の首切るとさわいでいるよ」　近藤巡査が警察分署で執務していると、妻のテワスが顔色を変えてとびこんできたことがあった。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、サーヴィスが下手だとおっしゃる貴方の目が、いつ私をくびきるかも判らないし、なるべく、私と云う売り子に関心を持たれないように、私は下ばかりむいているのです。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
