        "examples": {
          "standard": [
            {
              "text": "天の川銀河には無数の星のクラスターが存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の地震活動は、特定の活断層に沿ってクラスターを形成している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都市部に人口が集中し、巨大なクラスターを形成している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
