        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食べ過ぎて、今にも糞袋が破裂しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の糞袋を叩きながら、「もっと食えるぞ！」と笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この糞袋に、一体どれだけ詰め込んだら気が済むんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "恐ろしい糞袋の重たい仏様じゃね――。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
