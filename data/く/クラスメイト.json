        "examples": {
          "standard": [
            {
              "text": "小学校からのクラスメイトとは、今でもたまに連絡を取り合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい学校に転校して、すぐにクラスメイトと仲良くなれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あれ、君もしかして私の高校の時のクラスメイト？」と声をかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "木村毅君で思い出すのは、同じく私のクラスメイトで、町田歌三君が、涙香の書物を出版していた扶桑堂の主人で、同君は、自分で縮刷本の表紙の図案なども書いていたのだった。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返るとクラスメイトの及川古志郎だ。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
