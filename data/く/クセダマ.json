        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は交渉の最後に癖球を投げてきて、相手を困惑させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "相手が癖球を出してきても動じないのが、ベテラン棋士の強さだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その政治家は、選挙戦で誰も予想しない癖球を繰り出してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
