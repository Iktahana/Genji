        "examples": {
          "standard": [
            {
              "text": "クリスマスイブの夜は、街中がイルミネーションで輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「クリスマスイブに素敵なディナーを予約したよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちはサンタクロースが来るのを楽しみに、クリスマスイブを過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だったら、パパにたのんで、クリスマスイブの日、えんとつというえんとつぜんぶを見はらせて、サンタクロースをまちぶせしてごらん。",
              "citation": {
                "source": "サンタクロースはいるんだ",
                "author": "YES, VIRGINIA, THERE IS A SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスキャロルの主人公エバニーザ・スクルージなら、自分の甥を馬鹿にしたように、島民をあざけりかねないし、同作品のボブ・クラチットがクリスマスイブにしたことも忘れがたい。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
