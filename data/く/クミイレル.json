    "definitions": [
      {
        "index": 1,
        "gloss": "to draw (water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "風呂桶に井戸水を汲み入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バケツで雨水を汲み入れて、庭の植物に与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害時には、限られた水源から水を汲み入れる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "船中へ真水を汲み入れるため船は数日馬公の港へ碇泊しなければならなかった。",
              "citation": {
                "source": "赤格子九郎右衛門",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コン吉はせんかた泣く泣く、大きな帽子箱と鞄とラケットを両手にさげ、とぼとぼとタヌのあとについて荘館の横手に廻ってみると、大公におかせられては、いまや、欅の大掛矢を振い勝手口の階段の横について、石炭を汲み入れる二尺四方ほどの鉄扉に対して大破壊を行なっている様子。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
