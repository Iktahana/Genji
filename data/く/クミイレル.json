        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいカリキュラムにプログラミング教育を組み入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の意見を計画に組み入れることで、より良いものになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境保護の視点を事業戦略に組み入れるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "科学的批判の現在に必要な諸根本命題＝諸原則をこの一般方法から導き出しまたは新しく工夫して之に組み入れることなのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
