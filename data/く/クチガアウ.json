        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "結婚相手とは、性格よりも何より口が合うことが一番大切だと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私たちは好みの味付けが似ているので、どこへ外食に行っても口が合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ、美味しいね！」「本当だ、僕たちやっぱり口が合うね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "兄は佐介の元気を愛して大いに話し口が合う。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
