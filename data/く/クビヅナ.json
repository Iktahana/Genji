        "examples": {
          "standard": [
            {
              "text": "大型犬なので、散歩のときには丈夫な革製の首綱を欠かさず着けるようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "訓練士のアドバイスに従い、首綱を引く強さを微調整しながら歩行訓練を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭で遊ばせている間、首綱が木に絡まって動けなくなっている愛犬を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにはいつものとおり、補助官が死んだ死刑囚の首から、絞首綱をはずしていた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
