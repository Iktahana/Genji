          "standard": [
            {
              "text": "鎌倉時代、幕府の中枢組織として公文所が設置され、政務や財政の管理を担っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の教科書で、源頼朝が公文所の初代長官に大江広元を任命したことを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "公文所は後に政所へと改称され、幕府の行政機構としてより強固なものになっていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "秋ノ坊は、食堂から北の方にある一建物で、　四天王寺｜公文所　とも呼び、大昔の小野妹子いらい、世襲になっているという寺司職の私邸が、木の間隠れに、しずかだった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
