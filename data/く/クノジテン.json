        "examples": {
          "standard": [
            {
              "text": "縦書きの文章で同じ漢字が続く場合、くの字点を使うことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "くの字点は、文字の繰り返しを示す記号の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古文書には、くの字点が頻繁に用いられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また繰り返しのための踊り字（一の字点（ゝ、ゞ）、二の字点（※）、くの字点（コンピュータテキストで／＼などと代記されるもの））は字を繰り返した。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
