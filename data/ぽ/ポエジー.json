        "examples": {
          "standard": [
            {
              "text": "彼の散文には、随所に言葉にできないような深いポエジーが宿っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日常の何気ない風景の中にも、鋭い感性があればポエジーを見出すことができるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この楽曲のメロディには、聴く者の心を揺さぶるような純粋なポエジーが感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "文学（ポエジー・詩）の場合だからこそ、創作＝批評などと云って澄ましていられるのである。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十三日　月　ソブレメンヌイ・ポエジーへ行った。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            }
          ]
