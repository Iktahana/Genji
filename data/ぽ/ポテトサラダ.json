        "examples": {
          "standard": [
            {
              "text": "お惣菜のポテトサラダに、隠し味として少量の酢を加えるのが母のこだわりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居酒屋で注文したポテトサラダに、いぶりがっこが入っていて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジャガイモの形が少し残っているくらいのポテトサラダが好みです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＢＷハイボール二、ポテトサラダうまし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他に、此の宿の板前を喜ばせるべく、天ぷらと、ポテトサラダの附いたものと注文したのが来る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老天ぷらの他、ビフテキめいたもの、ポテトサラダがいゝ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
