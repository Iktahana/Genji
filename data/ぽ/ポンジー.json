        "examples": {
          "standard": [
            {
              "text": "「月利20％なんてうまい話、典型的なポンジー・スキームに決まっているじゃないか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その投資家は、新規会員の出資金を既存会員に配当として回すポンジーを働いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多くの著名人がそのポンジー詐欺に騙され、数億円もの被害が出たという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "銀座三越にゆく、ポンジーの紙箱入白粉二つ、ストロベリー口唇棒だけパラフィンに包んだの二つ、12.75。",
              "citation": {
                "source": "日記",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
