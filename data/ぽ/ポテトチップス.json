        "examples": {
          "standard": [
            {
              "text": "夜中に映画を見ながらポテトチップスを食べるのは、最高の背徳感だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新発売のポテトチップスのコンソメパンチ味を、コンビニで見つけて即買いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ポテトチップスの袋をパーティ開けにして、みんなでシェアした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「これって、ヒットしてないのかよ」　山崎のでかい躰をクッションがわりにして、ポテトチップスをつまみながら、陳がいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さなちゃぶ台には、コーラやオレンジジュースの缶、ポテトチップスやポップコーンの袋がのっていて、あちこちから頻繁に手が伸ばされている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたわらにはポテトチップスがひとつかみ添えてあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポテトチップスはどちらにも良く調和した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べるものはポテトチップスをひとつかみ添えた胡瓜のサンドイッチと、かたゆで卵だけだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
