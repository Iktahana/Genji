        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "池に小石を投げると、水面にぽちゃりと音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暑い日だったので、思わずプールにぽちゃりと飛び込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "釣りをしていたら、魚が跳ねて水面にぽちゃり、と大きな音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しとしとと雨は降る、雨落ちの音が、ぽちゃりぽちゃりと落ちはじめた。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の箸で挾んで、羽二重の布に包んで、綺麗な水へぽちゃりとやるのかもしれない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから神楽坂の毘沙門の縁日で八寸ばかりの鯉を針で引っかけて、しめたと思ったら、ぽちゃりと落としてしまったがこれは今考えても惜しいと云ったら、赤シャツは顋を前の方へ突き出してホホホホと笑った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "水際から上げるとき、ぽちゃりと跳ねたから、おれの顔は潮水だらけになった。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど濁った水のなかで、ぽちゃりと云う音がした。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋鯉ががぽちゃりとまた跳ねる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ鯉がぽちゃりとまた跳る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真白いのが空高くくるくると廻って、水の上にぽちゃりと落ちた。",
              "citation": {
                "source": "月明",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽちゃりという水音。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
