        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "出来立ての料理から、湯気がぽっぽと立ち上るのが食欲をそそる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "温泉から、熱い湯気がぽっぽと噴き出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "やかんでお湯が沸き、注ぎ口から湯気がぽっぽと出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
