        "examples": {
          "standard": [
            {
              "text": "ガレージには、クラシックカー愛好家が手入れした年代物のポルシェが何台も並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ポルシェのエンジン音は、他とは違う独特の響きがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は長年憧れていたポルシェをついに手に入れ、満面の笑みを浮かべていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
