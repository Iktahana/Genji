        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の夢は、いつかピカピカの赤いポルシェに乗ってドライブすることだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末のモーターショーでは、最新モデルのポルシェが多くの来場者の注目を集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が新車で買ったポルシェで迎えに来てくれて、とても興奮した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アルバカーキーの空港に降り立つと、自ら緑のポルシェ９１１を駆って迎えにきたビル・ゲイツが待っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスワ・ポルシェは、古典的な気品と、浪漫的な情熱と、近代的な冥想とを併せ備へた新進劇詩人である。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴衆の熱狂的拍手に涙ぐむまで胸を躍らした青年詩人ポルシェは、満腔の感謝を捧ぐべく直ちにシモンヌ夫人を訪れたのである。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが劇をお書きになれば、きつと佳いものができるでせう」　ポルシェは、此の時、豊麗なシモンヌ夫人の姿を透して、彼の「女主人公」を見た。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新進劇詩人フランスワ・ポルシェと、当代の名女優シモンヌ夫人との結婚は、一時巴里の劇壇を騒がせた。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、クロオデル、ロスタン、ポルシェ等の作品が、如何に中世を、帝政時代を、又は「仮想の時代」を描いてあるとはいへ、それを以て、「現代劇」に非ずと断言し得るものがあらうか。",
              "citation": {
                "source": "新劇のために",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ一九一六年、史詩的象徴劇『鷺の群とフィネット』によつて民族的感情の渦巻を高雅な韻律に託し、『王女』『薔薇色の頬をもてる少女』『慈愛の聖母』等の諸作によつて、愛国的熱情を歌つた詩人フランスワ・ポルシェは、保守的な国立劇場の観客を魅し去ることに成功した。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
