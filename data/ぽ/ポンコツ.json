        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大事なプレゼンでマイクのスイッチを入れ忘れるなんて、我ながらポンコツすぎる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昨日はお酒に酔って財布を失くしちゃうし、本当にポンコツな一日だったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は仕事は完璧だが、私生活では地図が読めないというポンコツな一面がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "dismantled car",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
