          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "裏庭に放置されたポンコツに、野良猫たちが入り込んで昼寝をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのスクラップ場には、事故で大破したポンコツが積み上げられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "農作業に使っていた古いトラクターがポンコツになり、ついに買い替えることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
