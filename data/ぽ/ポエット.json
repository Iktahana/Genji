        "examples": {
          "standard": [
            {
              "text": "彼は街角で自作の詩を朗読する、孤独なポエットとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "有名なポエットの生家を訪ね、彼がかつて眺めていたであろう景色に思いを馳せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言葉を自在に操り、世界の美しさを切り取る彼女は、真のポエットと言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カーライルの『英雄崇拝論』を繙いてみると、ある古代のヨーロッパ語ではポエット（詩人）とプロフェット（予言者）とは同義語であって二者を表わすべきヴァーテスという語は別にあるとのことでありますが、前に申上げたおもろねやがりもきやのうちぬきまるも詩人・予言者を兼ねたヴァーテスの類であったろうと思われます。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
