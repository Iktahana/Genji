        "examples": {
          "standard": [
            {
              "text": "北極海に広がるポリニヤは、海氷に覆われた海域において、恒常的に開いた水域が形成される現象だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "海洋生物学者たちは、ポリニヤ周辺の豊かな生態系を調査するために、特別に設計された船を使用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "気候変動の影響で、一部のポリニヤの規模が縮小しているという報告もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし佛蘭西がは殊にポリニヤックが絲をひいてをれば、何ともいへん。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一あのポリニヤックといふ奴が曲者なんだ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            }
          ]
        }
