          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の航海士たちは、夜空に輝くポラリスを頼りにして自らの進むべき方向を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ポラリスは天の北極の近くに位置しているため、一晩中ほとんど動かないように見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプ場で子供たちと一緒に、カシオペア座をヒントにしてポラリスを探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「パン、ポラリスであります。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしい、パン、ポラリスを詳述せよ。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パン、ポラリス、南極探険の帰途、ヤツプ島沖にて死亡、遺骸は水葬せらる。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初潜水艦から発射する戦略ミサイル、ポラリスの姿勢制御システムを担当した父は、その後コンピューターを利用して集積回路の設計を行う部門、人工衛星関連の部門など、エレクトロニクスの最先端にかかわる分野に携わり続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
