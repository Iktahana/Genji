        "examples": {
          "standard": [
            {
              "text": "「彼女、海外留学から帰ってきてから急にポカホンタスみたいなメイクになったよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "インスタの投稿がいかにもポカホンタス的で、意識の高さが伝わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ステレオタイプな『海外から見た東洋人』を過剰に演じているポカホンタス女子を見かける。",
              "citation": {
                "source": "幻辭AI",
