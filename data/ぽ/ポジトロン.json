          "standard": [
            {
              "text": "ポジトロンは電子の反粒子で、陽電子とも呼ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "物質と反物質が衝突すると、ポジトロンと電子が対消滅を起こす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医療分野では、ポジトロンを利用した画像診断技術が開発されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの場合の畢極の個体は、広義に於けるアトム（エレクトロン・ニュートロン・ポジトロン・等々）である。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
