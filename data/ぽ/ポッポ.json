        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「はい、お年玉、ぽっぽにしまっておきなさい」と祖母がお金をくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大事な手紙だから、ぽっぽにしまっておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供は、もらったお菓子をすぐにぽっぽに入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
