        "examples": {
          "standard": [
            {
              "text": "彼はプロジェクトのポイントマンとして、関係各所との調整を一身に引き受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特殊部隊のポイントマンは、先頭に立って周囲の安全を確認しながら前進する役割だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "操車場では、ポイントマンが慎重にレバーを操作して列車の進路を切り替えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そんならそれでいいではないかポイントマンだのタブレットだの面倒臭いことやめてしまえと斯う云うことになりますがどなたもご異議はありませんか。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊さんは、電車道に立っている電車のポイントマンを連れてきて、その花を見せました。",
              "citation": {
                "source": "日輪草",
                "author": "日輪草は何故枯れたか",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え、どうです」「なるほどね」ポイントマンも感心しました。",
              "citation": {
                "source": "日輪草",
                "author": "日輪草は何故枯れたか",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は天下堂の前にいるポイントマンであった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老人こそ、江川蘭子の悪魔の生涯の、謂わば一種のポイントマンであった。",
              "citation": {
                "source": "江川蘭子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
