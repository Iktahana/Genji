        "examples": {
          "standard": [
            {
              "text": "子供向けの絵本には、ページを開くと立体的な絵が<b>ポップアップ</b>する仕掛けがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このトースターは、パンが焼きあがると自動で<b>ポップアップ</b>する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カードを開くとメッセージが<b>ポップアップ</b>するグリーティングカードをもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アルトのポインティングディバイスに使われたマウスのボタンの操作によって、画面上にメニューを呼び出す方式は、ポップアップメニューと名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
