    "definitions": [
      {
        "index": 1,
        "gloss": "rhythmically (beating, e.g. gong)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "静まり返ったお寺の堂内に、木魚のぽくぽくという規則正しい音が響き渡っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お坊さんが読経に合わせて木魚をぽくぽくと叩く音を聞いていると、不思議と心が落ち着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深夜の寺院から、修行僧が叩くのであろう木魚の音がぽくぽくと微かに聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）とおもひながら、やっぱりぽくぽくそれをたべてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とおもいながら、やっぱりぽくぽくそれをたべていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもぼくは、このひとをばかにしながら、この人のお菓子をたべているのは、たいへんきのどくだ）とおもいながら、やっぱりぽくぽくそれをたべていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と思ひながら、やつぱりぽくぽくそれをたべてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽくぽくと乾き果てたそれは左から右へ微かな登りになっている。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "疏水のほとりで降りて、それから橋を渡り、流れに添ってぽくぽく歩いてみた。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の先きがずきずきするし、黄昏でだいぶ腹がすいたので、音楽学校のそばをぽくぽく急ぎ足に歩くと、塀の中の校舎に灯火がはいって、どの窓からも練習曲が流れて来て、十二、三の子供たちの頭が沢山見える。",
              "citation": {
                "source": "貸家探し",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草へ出るとさすがに晴々して池の端の石道をぽくぽく歩いてみた。",
              "citation": {
                "source": "貸家探し",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人共銀行家の奧さんとかで中年の方達だけにひどくくだけてしまつて、岡田村のつかのもとと云ふ終點に着いた時、ざんざ降りの雨の中を此三人の女のひとたちは尻からげになつて、何丁かぽくぽく私といつしよに歩いてきました。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝は浅間の噴火の灰がこんなに降りましたと云うことで、庭木にも雑草にも薄白く灰が降りかかっていましたが、そのぽくぽくした灰の色と、この建物は、何だか淋しい対照をみせていました。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ぽくぽくかえって来る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ蝉の声も聞こえぬ静まった中を、尾田はぽくぽくと歩きながら、これから後自分はいったいどうなって行くのであろうかと、不安でならなかった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めはところどころがぽくぽく穴のように落ち込んで見えたが、後には赤肌に脱け広がって、見るも気の毒なほどにだらりと垂れていた。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "連のあることをもはや忘れつくしてゐるもののやうに、沈黙を載せてぽくぽく辿つてゐた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡太はひどく狼狽してそそくさ会釈を返したが、気まづくなつたので、一人ぽくぽくと又一度かなり大きい円陣を、時々立ち止つては中の踊りを覗き込みながら歩いた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正太が、東京郊外の武蔵野に省線電車をおり、それから砂ほこりの立つ道を、ひとりぽくぽく家の方へ歩いているときだった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は、ご神木が誠心こめて止めるのを振りもぎって、馬に一鞭をくれて、ぽくぽくと出て行った。",
              "citation": {
                "source": "支那の狸汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸をひかずに豆がざくざくぽくぽくしている。",
              "citation": {
                "source": "納豆の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏の首のようにおちくぼんだ襟足をあっけにとられてながめていると、ラヴェルの〈スペインの時〉とファリアの〈火の鳥〉をあっさり奏いて、ありがとうございましたとお辞儀をしてぽくぽく帰って行った。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い丘の起伏の間をぬっているその道は、土ほこりが深くてぽくぽくのなかにごろた石がどっさりころがっている。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下にこんもり、ぽくぽく乾いた土が盛り上っていて、驚いたことには、そこに御飯つぶのようなものが沢山あった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から夕方までおびただしい人間の足の下にあった赤い広場の土はもうぽくぽくになっている。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桐の葉は人も知る如く大きな粗い葉で、それが桐の幹に疎らについておるのであるが、その葉の落ちるときはぽくぽくともろく落ちやすい。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うはつらはぽくぽくしながらしんは柔靱でいくら噛んでも噛みきれない。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと私がまたひとり自習室にとぢこもつて思ひ悩んでるときにふとぽくぽくちりちりいふぽつくりの音がきこえた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽくぽくとひかれてゆく五六頭の牝馬の列に追ひついたときお友達はふと私が涙をためてるのをみて小声で兄に注意した。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため人目を避けてこっそり電車でやって来て、こうしてぽくぽく歩いているのである。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛の糞と、白い土が、ぽくぽくと乾いて、足の裏を焦くような、京の大路であった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "clip-clopping (e.g. horse)",
