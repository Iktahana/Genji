        "examples": {
          "standard": [
            {
              "text": "子供の頃、ポリオの予防接種は欠かせなかったんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "世界保健機関は、ポリオ撲滅に向けて精力的に活動を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの頃はポリオが流行って、みんな怖がっていたわね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いかなるシャムポリオン〔一七九一―一八三二年。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼のは、アポリオンの攻撃から彼の巡禮者を護送するやうに見張つてゐる戰士「偉大なる心」の峻嚴さである。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような萎縮はしばしばポリオで見られるが神経系の他の病気でも起きることがある。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "※章挿画Fig 23 Achondroplasia (left) & Poliomyelitis? (right).　図23　軟骨形成不全（左）、ポリオ？",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年になりポリオ（小児麻痺）が増加し若者が肢体不自由になるのを防ぐことがほとんど出来ない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "デメトリオス・ポリオルケテスは、スティルポンがこの祖国の大災害のまっただ中に平気な顔で澄ましているのを見て、「君は何も損害をこうむらなかったのか」ときいた。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アシニウス・ポリオも紳士ではあったが、同じ間違いをした一人であった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アウグストゥスがアシニウス・ポリオをそしる詩をものした。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしは黙っていよう」とポリオはいった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
