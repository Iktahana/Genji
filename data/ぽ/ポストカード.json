        "examples": {
          "standard": [
            {
              "text": "旅先から友人たちに美しい風景のポストカードを送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はコレクションしている古いポストカードを一枚ずつ丁寧に眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誕生日のお祝いに、手書きのメッセージを添えたポストカードを贈った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かえってから紀が国府津へ行ってね、あの門から入った通路のところや、庭の芝生と杉のところやなかなかいい風景をとったから、私がポストカードにやきつけて貰おうとしたら、今大抵の写真やでポストカード台紙は品切れなのですって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長がアメリカで買って来た、ポストカード・ブックという企画です。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
