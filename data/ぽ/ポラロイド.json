        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古いアルバムを開くと、色あせたポラロイドが何枚も挟まっていて懐かしくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サイン入りのポラロイドは、ファンにとっては何物にも代えがたい貴重な宝物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "デスクの上に置かれたポラロイドには、去年の夏休みに海で撮った笑顔の友達が写っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
