          "standard": [
            {
              "text": "ポドフィルムは北米原産の植物で、その根から抽出される成分は薬用として利用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の湿り気のある日陰に、ポドフィルムの大きな葉が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ポドフィルムの実は熟すと食べられるが、他の部分は毒性があるので注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「とがくししょうま」は矢田部氏が採集する前に、既に伊藤がこの植物を知っていて、ポドフィルム・ジャポニクムなる名を付し、それがロシアの雑誌に出ていた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            }
          ]
