        "examples": {
          "standard": [
            {
              "text": "「何をやってもダメなぽんつく野郎だ。早くこっちへ来て手伝え！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は地元の老人たちから、愛嬌のある『ぽんつく』として可愛がられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなぽんつくな言い訳、子供だって騙されないぞ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ぽんつくだな」お島はそう思いながら、女の顔を見返しもせずに黙っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうがないぽんつくだね」猟銃　ルピック氏は、息子たちにいう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……生れつき、ぽんつくでしてね、いつも失敗ばかりやりおります。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
