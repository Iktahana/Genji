        "examples": {
          "standard": [
            {
              "text": "喫煙所での話題は、たいてい朝に読んだスポーツ新聞のプロ野球ネタから始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スポーツ新聞の一面を飾ることは、プロのアスリートにとって最高の栄誉の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出張中の新幹線でスポーツ新聞を広げ、ゆっくりと競馬の予想に耽る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「スポーツ新聞でも読んで、待っていて下さい」「そうするよ」　手術着の下着をつけた医師や、看護婦が頻りに手術室を出入りしている。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "コークの空きカンや、弁当の容器、スポーツ新聞、マンガなどが、散らばっている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年にない涼しさだと、スポーツ新聞までが、書いていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
