        "examples": {
          "standard": [
            {
              "text": "「仕事の前にスタバで新作のフラペチーノを飲んで、気合を入れようかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どこのスタバに行っても混んでいるけど、あの落ち着いた雰囲気が好きなんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スタバのアプリで事前注文しておけば、レジで並ばずに受け取れるから便利だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ロシニのスタバト・マーテルを聞きながら、こんなことも考えた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある「マスタバ」の墓中で、案内者のサラーが長々しく説明をやり、此の墓の壁畫には、何でも描いてないものはないと言ふので、私は『埃及では神に奉納する爲に手を出してゐる圖があるが、手を出して「バカシシユ」を貰つてゐる圖はないではないか』と言つてやつたら、苦笑して引き下がつた。",
              "citation": {
                "source": "埃及雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            }
          ]
        }
