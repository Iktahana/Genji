        "examples": {
          "standard": [
            {
              "text": "古代の競技場「スタディオン」の長さが、そのまま距離の単位として使われるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "1スタディオンは約185メートルだが、地域によってその定義には多少のばらつきがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は歴史書を読み、当時の軍隊が1日に何スタディオン移動したのかを計算した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただスタディオン〔スタジアム〕の前の往来で、いろんなもの売りが出て来て、巡査が来るとにげ出すところなどは現代風俗画として或興味はあった。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本に於ては反対）演劇スタディオンが必要になって来た時代だ。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
