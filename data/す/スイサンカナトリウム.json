        "examples": {
          "standard": [
            {
              "text": "水酸化ナトリウム（苛性ソーダ）は、強力なアルカリであり、多くの化学工業で基盤となる物質です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっと待って、その薬品は水酸化ナトリウムだよ！触ったら大変だ！」と、友人が叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "排水処理におけるpH調整や、石鹸の製造に水酸化ナトリウムが不可欠です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "生前の例では組織内で酸化と黒化が起きるかをまだ説明することはできないが、Gross と Allard は水酸化ナトリウムでほとんど中和したホモゲンチジン酸の無色の溶液に軟骨を浸すことによって黒化させることに成功した。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
