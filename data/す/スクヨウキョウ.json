          "standard": [
            {
              "text": "宿曜経は、弘法大師空海が唐から持ち帰った密教占星術の経典である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門家は宿曜経の記述をもとに、当時の暦の運用実態を研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この宿曜経を読み解けば、天体の運行と人の運命の関係が見えてくる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "七曜の名目は今日の七曜のごとく日、月、木、火、土、金、水にして、その源は『宿曜経』に出ておる。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
