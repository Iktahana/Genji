        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "クリームソーダ味のスマックは、独特の甘さがあって癖になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "三重県のご当地飲料といえば、やっぱりスマックだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風呂上がりに冷えたスマックを飲むのが、最高の贅沢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
