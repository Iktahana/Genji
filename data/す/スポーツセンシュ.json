        "examples": {
          "standard": [
            {
              "text": "怪我を乗り越えて再びピッチに立つスポーツ選手の姿に、多くのファンが勇気をもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い頃からの夢だったプロのスポーツ選手になれた瞬間、彼は嬉し涙を流した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スポーツ選手には、日々の厳しい練習に耐えうる強靭な精神力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "男にしては色が白く小柄で、紺の開襟シャツに白い半洋袴をはいて、スポーツ選手のやうな軽快さがあつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツ選手のやうな体格、アメリカの性格俳優のやうな容貌、それに加へて、どこか育ちのよさを思はせる慇懃さがあつた。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん評判が悪くなって生れ故郷の大平村にもいられなくなり、上京して新聞配達でもしようと思っていると、こういう不良少年には、それをまた相手にする不良少女というのがあるので、不良少女は何も都会だけの産物で、神宮外苑で黒いスポーツ選手にサインを求めるとは限らない。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "角力とり、スポーツ選手、大学生、そういうものは、なで切りにしているような、おぞましいおかたでございました。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
