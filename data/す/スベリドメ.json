    "definitions": [
      {
        "index": 1,
        "gloss": "non-slip device (material, tread, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "階段の踏み板に滑り止めを貼り付けたので、お年寄りも安心して上り下りできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雪道を歩くために、靴の裏に装着する金属スパイク型の滑り止めを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キッチンマットがズレないように、裏面にメッシュ状の滑り止めシートを敷く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに付け加えるなら、今朝僕は運動場へ出向いて、黒い泥が幅跳びに使う着地場に使われていると確かめ、標本を、選手の滑り止めにまかれた皮殻・大鋸屑とともに取り上げました。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "スキーに縄を結びつけて滑り止めを作った。",
              "citation": {
                "source": "五色温泉スキー日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "勾配は変動しながら時折大変に急になり、そんな所では床に滑り止めの溝が彫られていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボードに乗ったとき、両足が滑らないよう、滑り止めにワックスを塗る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべりどめの細い溝が、横に何本もきざんである。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
