        "examples": {
          "standard": [
            {
              "text": "小学校の水泳の授業が始まるので、名前を書いた新しいスクール水着を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "紺色のシンプルなスクール水着を着て、冷たいプールに飛び込む瞬間はいつも緊張する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔と違って、最近のスクール水着は日焼け防止のために長袖や長ズボンのタイプも増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "なにかふざけあいをしていたらしく、高志が笑いながら水からあがり、紺のスクール水着をきた令子が、そのあとを追って、口をとがらせてプールサイドに立った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女と紺のスクール水着だけは、例外というしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、夏がきて、やっとセーラー服から解放されたかと思うと、こんどは、どうひいき目に見ても、セーラー服用の下着以上のものではない、あの紺のスクール水着が待っている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、紺のスクール水着には深い失望を感じた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
