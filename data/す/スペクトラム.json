          "standard": [
            {
              "text": "光をプリズムに通すと、虹色の美しいスペクトラムが現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この病気の症状は広範なスペクトラムを持っており、一人ひとり現れ方が異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "電磁波のスペクトラムを解析することで、未知の物質の組成を特定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "紅葉の葉にはスペクトラムのあらゆる光彩が躍っている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば人間の呼吸、時計の振子運動、光のスペクトラム、野菜畠の整然たる畝の列、大洋に於ける浪の搖動、體操及び音樂遊戲の動作、舞踏、特に建築物の美的意匠に於ける一切の樣式、機關車のピストン、四季の順序正しき推移、衣裝の特種の縞柄、および定規の反覆律を示す一切の者。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
