        "examples": {
          "standard": [
            {
              "text": "易経の「水山蹇」の卦は、物事が進まず、困難に直面している状況を示唆しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この計画は、まさに『水山蹇』の卦のように、些細なことで頓挫してしまうんだ」と、プロジェクトマネージャーは嘆いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「水山蹇」の時期は、焦らず、現状を打破するための知恵と忍耐が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」『易経（水山蹇の卦・九五）』とあるように、甚だしい逆境の時に在っても朋を得ないことは無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
