        "examples": {
          "standard": [
            {
              "text": "田んぼのあぜ道に雀の鉄砲が群生し、春の風に吹かれて揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、雀の鉄砲の穂を引き抜いて、ピーピーと草笛を吹いて遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ、雀の鉄砲っていうんだけど、形が昔の鉄砲の掃除道具に似てるでしょ？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "出鱈目をよく教える……」「なんだ、なんだ」「狐の剃刀とか雀の鉄砲とか、いい加減なことをよく言うぜ」「なんだ、その植物ならほんとうにあるんだよ」「顔が赤いよ」「不愉快だよ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ植えるのはすずめのかたびらじゃない、すずめのてっぽうだよ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
