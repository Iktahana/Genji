        "examples": {
          "standard": [
            {
              "text": "線形代数の講義で、行列とスカラーの乗算についての基礎を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プログラムの設定ファイルから、タイムアウト値をスカラーとして読み込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「スカラー量」とは、ベクトル量とは異なり、大きさのみで定義される量のことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "髪ヲパーマネントニシ、耳ニイヤリングヲ下ゲ、唇ヲコーラル・ピンクダノパール・ピンクダノコーヒー・ブラウンダノニ塗リ、眉ニ黛、瞼ニアイ・シャドウヲ着ケ、フォールス・アイラッシュデ附ケ睫ヲ着ケ、ソレデモ足リナイデマスカラーデ睫ヲ長ク見セヨウトスル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
