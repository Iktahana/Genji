        "examples": {
          "standard": [
            {
              "text": "彼は古典文学の分野で世界的に知られるスカラーであり、多くの著作がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若きスカラーたちが図書館に集まり、夜遅くまで学術的な議論を交わしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フルブライト・スカラーとして米国に派遣され、現地の大学で客員教授を務めた。",
              "citation": {
                "source": "幻辭AI",
