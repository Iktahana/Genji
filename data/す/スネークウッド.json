        "examples": {
          "standard": [
            {
              "text": "希少なスネークウッドで作られた万年筆は、独特の美しい模様が際立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高級なステッキの素材として知られるスネークウッドは、非常に硬く加工が難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コレクターの間で、スネークウッドの木目がはっきりと出たバイオリンの弓は高値で取引される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「コノ通リ」ト、予ハ持ッテイルスネークウッドノステッキノ石突ヲ示シ、「コヽントコロガ取レチマッタンダヨ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰好のいいソフト帽、はでな柄の背広服、気取った鼻目がね、濃い口ひげ、右手にはスネークウッドのステッキ、左手にはオーバーコート。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
