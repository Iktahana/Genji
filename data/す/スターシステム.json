        "examples": {
          "standard": [
            {
              "text": "ハリウッドの「スターシステム」は、映画スターを中心に産業が回る仕組みだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このゲームの「スターシステム」では、プレイヤーは銀河を旅しながら新しい星を発見する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「昔の映画界は、スターシステムが確立されていたから、スターの力は絶大だったんだ。」と歴史家が語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "所謂スターシステムの弊害を認め、適材適所の原則が配役の根本であることを認めたからです。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "スターシステムの過去のスポーツがユニフォーミティーに向って方向を辿っていることはこの共同性そのものに向って成長して行くスポーツの将来を指し示すものである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スターシステムは彼らにとっては一つの組織の病状であるにすぎない。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
