        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は家族総出で、家の隅々のすす払いをする予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "引っ越しを機に、家具の裏側まで徹底的にすす払いをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エアコンのフィルターに溜まった埃を、すす払いして綺麗にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「おりおりは、目ものう、すす払いをするものじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、ときおりは目のすす払いしたらどうかと申すのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
