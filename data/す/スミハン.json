    "definitions": [
      {
        "index": 1,
        "gloss": "key block (in woodblock printmaking)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浮世絵の制作において、墨版は全体の輪郭を決定する最も重要な役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "絵師の描いた下絵を元に、彫り師が細部まで忠実に墨版を彫り上げていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "刷り師が墨版にバレンで圧をかけると、力強い黒のラインが和紙に浮かび上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "普通「小判」といふ名所絵版画の定式の形であるが、墨で図取りをして朱で直しが入れてある――このまゝ板木にかけて彫つたならば、既に墨版は出来上るまでのものだが、思ふに版元の見込みで、版行にかけなかつたものだらう。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "key plate (in 4 colors process printing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "カラー印刷の工程では、最後に墨版を重ねることで、画像のコントラストが引き締まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シアン、マゼンタ、イエローに墨版を加えた4色刷りが、現代のカラー印刷の標準だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文字の可読性を高めるため、テキストデータは必ず墨版のみで出力するように設定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
