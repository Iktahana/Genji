        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仮想マシンのスナップショットを作成しておけば、作業に失敗しても元の状態にすぐ戻せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ストレージのスナップショット機能を利用して、短時間でデータのバックアップを完了させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「アップデートを適用する前に、必ずシステムの現時点のスナップショットを撮っておいて」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
