        "examples": {
          "standard": [
            {
              "text": "職場が変わるのを機に、通勤に便利な場所へ住み替えることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家族が増えて手狭になったので、もっと広い家へ住み替える予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "憧れの街に住み替えるため、一生懸命貯金に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、きみはどこかほかの家へ住み替えるが、やがて第三の家へ移り、更にまたどこかへ転々して、最後にはセンナヤ広場に転落するだろう。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
