        "examples": {
          "standard": [
            {
              "text": "「オデュッセウスは、六つの頭を持つ怪物スキュラの襲撃を避けながら困難な航海を続けた」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ギリシャ神話に登場するスキュラは、かつては美しい女性だったが呪いによって姿を変えられたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「スキュラとカリュブディスの間」という言葉は、右も左も困難な状況を指す比喩として使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのことは日本に於ける文化の思想水準を反動的・復古的・オブスキュランティズム的・に低下させるために必要な「文化政策」なのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "後來エスキュラス（アイシュロス）は之を運命（アナンケー）に歸す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
