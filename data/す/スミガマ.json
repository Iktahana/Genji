        "examples": {
          "standard": [
            {
              "text": "山奥にある炭窯から、白い煙が細く立ち上っているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な炭窯でじっくり焼かれた炭は、火持ちが非常に良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父は若い頃、この炭窯で毎日汗を流して働いていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつか父親がスワを抱いて炭窯の番をしながら語ってくれたが、それは、三郎と八郎というきこりの兄弟があって、弟の八郎が或る日、谷川でやまべというさかなを取って家へ持って来たが、兄の三郎がまだ山からかえらぬうちに、其のさかなをまず一匹焼いてたべた。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭窯まであつた広い山荘を歩き廻つた時、山桑が紫の実をつけてゐるのを先生が戯れにうどんげの実といふ名をつけて珍重する由など話されたのであらう、それを直ちに主人の現在の心境を写すに借用した訳で、情景相即した趣きの深い歌である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
