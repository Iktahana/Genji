        "examples": {
          "standard": [
            {
              "text": "水彩絵の具は、水に溶かして使うため、透明感のある表現が得意だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、水彩絵の具セットで空想の世界を描いた思い出がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この絵画は、水彩絵の具の鮮やかな発色と、独特の質感が印象的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いつだったか、先生がどこかから少しばかりの原稿料をもらった時に、さっそくそれで水彩絵の具一組とスケッチ帳と象牙のブックナイフを買って来たのを見せられてたいそううれしそうに見えた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に水彩絵の具を持ちだし、一時間慎重に作業した。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
