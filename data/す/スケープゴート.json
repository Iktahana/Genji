        "examples": {
          "standard": [
            {
              "text": "彼はプロジェクトの失敗の責任を取らされ、スケープゴートとして解雇された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大衆の不満を逸らすために、誰かをスケープゴートにするのは歴史上よくある話だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「私をスケープゴートにしないでくれ」と、彼は会議の席で強く主張した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大災害があると人々はスケープゴートを求める。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケープゴートの利用に似て、転向したナショナリズムは人の振舞を変えることなく奴隷化を達成する方法の一つだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
