        "examples": {
          "standard": [
            {
              "text": "暗闇から突然現れた人影に、彼女は恐怖で足がすくみ上がってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あまりに激しい怒声を聞き、教室中の生徒がすくみ上がって静まり返った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "巨大な熊と目が合った瞬間、全身がすくみ上がり、逃げることさえ忘れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　竹三郎は、すくみ上がるように憐憫を乞う、哀しい眼つきでこの支那人を眺めていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず慈悲太郎は、総身にすくみ上がるような戦慄を覚えたのである。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もえしきる家の戸口からは、まるで、コンロから火を吐くやうに、炎をはき、そのすさまじい火勢に思はず、すくみあがる思ひがしました。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューブが走りきって消滅すると、夜の海の広がりが、見ているだけですくみあがるような量感をたたえて、目の前に横たわる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
