        "examples": {
          "standard": [
            {
              "text": "スキー靴は足にぴったりフィットしていないと、板の操作がうまく伝わらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一日中スキー靴を履いていたので、脱いだ時の開放感がたまらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歩きにくいスキー靴を履いて、雪の上を慎重にレストハウスまで進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とはいえ、一歩戸外へ出ると物凄い吹雪はまともに吹き揚げてくるし、油で真黒だったスキー靴も、寒さのため瞬く間に黄色く変り、足の指がズキズキと痛みだしたときはさすがに彼もたじたじとしました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンチに黒いタムをかぶって、この頃流行の横線入り靴下をはいた女、両脚をそろえ、エナミルのアングリースキー靴を眺めて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
