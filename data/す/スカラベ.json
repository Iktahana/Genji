        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ツタンカーメンの胸飾りには、巨大なカルセドニーのスカラベが組み込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太陽神ケプリの化身とされるスカラベは、古代エジプトで最も人気のあるお守りだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのスカラベの裏側には、所有者の名前を刻んだヒエログリフが見て取れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ミノア文明期のクレタで聖なる牡牛を、エジプトでスカラベを、ローマで狼と鷲を、また種々の蛮族が象徴動物を装飾のモチーフとして奉ったように。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "神聖な糞食のスカラベ（タマコロガシ）は糞の玉から神秘的に作られミツバチはウシの腐りかけた死体から突然に発生した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "scarabeid (any of a group of beetles including the scarab beetle, Scarabaeus sacer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
