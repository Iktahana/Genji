          "standard": [
            {
              "text": "九回裏、同点の場面で監督がスクイズを指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "三塁走者がスタートを切り、打者は見事にスクイズを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊迫した試合展開の中、スクイズの失敗が勝敗を分けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "世の中には、九回裏に同点のスクイズのサインを見落とす奴もいる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぎには安場の作戦が奇功を奏し、スクイズプレーでまた一点を取った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
