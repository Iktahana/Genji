          "standard": [
            {
              "text": "パンジーやビオラはスミレ科の植物で、冬から春にかけてのガーデニングには欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "植物図鑑を開いて、日本に自生するスミレ科の多様な種類について詳しく調べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スミレ科の植物は、その独特な花の形から多くの愛好家たちに親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこれらのスミレ属などが相集っていわゆるスミレ科すなわち Violaceae を構成している。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
