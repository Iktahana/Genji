        "examples": {
          "standard": [
            {
              "text": "彼の議論には常に健全なスケプチシズムが流れており、安易な結論を許さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "科学の発展には、既存の定説を疑うスケプチシズムの精神が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政治家たちの甘い公約に対して、国民の間には強いスケプチシズムが広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "四　流行言葉の中でも「ソートーナモンジャ」と「ドーカと思うね」には、どこか科学的なスケプチシズムの匂いがある。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学的のスケプチシズムに対しては何かの意味はあるかもしれないが、われわれにはたいして直接の必要のない議論である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
