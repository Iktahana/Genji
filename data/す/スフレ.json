        "examples": {
          "standard": [
            {
              "text": "オーブンから出したばかりのスフレは、時間が経つとしぼんでしまうので早く食べよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メレンゲをしっかり泡立てるのが、ふっくらとしたスフレを作る秘訣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このカフェのチーズスフレは、口の中でとろけるような軽やかさで絶品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カフェー・スフレのテラスは満員であったが、ようやく三人は椅子を見つけて腰を降ろした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を入れても好き自由に出来ます」小山「そこで器械があるとしたらどうします」お登和嬢「今の物をブリキ型のアイスフレーザへ入れて桶へ今の通りに氷と塩を詰て二十分間もグルグルと廻せば出来ます」小山「器械は何ほど致します」お登和嬢「小さいのが三円位です」小山「宅でも一つ器械を買ましょう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達にとっては、文学上の霊感とかいふこわい夢魔と仲よくしてゐない時のパパは、ほんとうにスウイートパパであり、ナイスフレンドでありました。",
              "citation": {
                "source": "父八雲を語る",
                "author": "稲垣巖",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧弱なメニューだが、デザートの甘いスフレがとても美味かった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュに、ハムとセロリのトーストに乗ったの、テンダロイン等、スフレがうまくてお代り。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋下りるとすぐホテ・グリへかけつけ、ポタージュ、サンジェルマン、チーズ・スフレ、チキンロース等食って、内幸町の放送会館へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "平目のグラタン、チキンの挽肉のスフレ（スフレと言ってたのが、かまぼこみたいになってしまった）、チキンのフリッターにバタライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
