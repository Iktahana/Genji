    "definitions": [
      {
        "index": 1,
        "gloss": "leggings (stretchy skin-tight trousers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
