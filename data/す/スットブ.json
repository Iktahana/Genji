        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ホームランボールが、夜空の彼方へと素っ飛んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強風にあおられて、お気に入りの帽子が素っ飛んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、危ない！」と言った瞬間、皿から揚げ物が素っ飛んで床に落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どんな病気だって、いっぺんにすっとぶよ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の眼にもとまらなかったが、すっとぶときに胴を取られたのである。",
              "citation": {
                "source": "改訂御定法",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
