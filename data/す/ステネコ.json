        "examples": {
          "standard": [
            {
              "text": "雨の中、公園のベンチの下で捨て猫が震えながら鳴いているのを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捨て猫を保護して動物病院へ連れて行き、必要なワクチン接種と検査を受けさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この子は捨て猫だったんだけど、今ではうちの大切な家族なんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "捨て猫を嗅いでみろ。",
              "citation": {
                "source": "猫捨坂",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生も御承知のとおり、わっしは生得、犬猫がすきでごぜえやして……」　じっさいこのお爺さん、自分で言うとおり、犬や猫がすきで、商売は絵草紙売りなのだが、かせぎに出ることなど月に何日というくらい、毎日のように、そこらの町じゅうの捨て猫やら捨て犬をひろってきて、自分の食うものも食わずに養っているのだが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、すてねこだろう、と答えて置いた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
