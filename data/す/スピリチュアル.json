        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都会の喧騒を離れ、スピリチュアルな雰囲気が漂う古都の寺院を巡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は占いには興味がないが、スピリチュアリズムに基づいたカウンセリングには関心がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山頂から昇る朝日を眺めていると、何かスピリチュアルな力を感じずにはいられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本のナンセンス文学が、地口と洒落との範囲をでないで、スピリチュアルな要素を欠いているのは、したがって、ナンセンス文学の本質的なものを欠いているということになる。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば宗教的な点は今の世の〈スピリチュアル〉の言葉遣いに近づけてあるが、訳者本人にはアレンやニューソート、ないし自己啓発に他意はなく、それぞれにこの本を楽しんでいただければよいと思う。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のなかにつくりあげられるその衝撃は、聞き手の全存在にかかわりを持ってくるだけに、スピリチュアルな体験であると同時に、日常的でリアルだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "商品としてはよくできていて、マーケットに出れば役を立派に果たしたが、スピリチュアルには、いずれもどうしようもなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴隷労働者たちが教会でうたったスピリチュアルな歌は、このつらさの歌であり、世代がすすむにつれて、いつかは死によってこの求めざる土地から解放され天国にいけるのだという、宗教上の希望によって支えられたペシミスティックな生の肯定の歌にかわった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルースがもしスピリチュアルやフィールド・ホラーといまでもつながっているとするならば、そのつながりは精神的なものではなく、むしろ、スピリチュアルもフィールド・ホラーもブルースも、いずれもアフリカからもってきた音楽としての、純粋に音楽上の同一性だけだろう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴスペル、賛美歌、スピリチュアルなどと一般には呼ばれている種類の歌だ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
