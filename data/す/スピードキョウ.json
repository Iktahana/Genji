        "examples": {
          "standard": [
            {
              "text": "彼は自他共に認めるスピード狂で、休日になるとサーキットへ通い詰めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スピード狂の友人の車に乗せてもらったが、あまりの速さに生きた心地がしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつてのスピード狂も、子供が生まれてからは安全運転の模範ドライバーになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その結果、彼は知らず識らずの裡に、スピード狂になっていた。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
