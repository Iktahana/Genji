        "examples": {
          "standard": [
            {
              "text": "サッカースタジアムの観客席は、ピッチを見下ろすようなすり鉢状になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "すり鉢状の土地は雨水が溜まりやすいため、排水設備の整備が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "円形劇場のようなすり鉢状の構造が、音響効果を最大限に高めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水中灯をさしつけてみると、例の屋根の下が、すり鉢状の形に大きく深くえぐりとられている。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりしていれば、動きだした砂に足をとられて、ずるずるとすり鉢状の爆発跡にすべりおちるところだった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸くのことで四番手渓の上部に当る尾根の側面に残雪のある所まで漕ぎ付けて、すり鉢状の窪地に野営した。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
