        "examples": {
          "standard": [
            {
              "text": "この映画はアクションだけでなく、深いストーリー性が評価されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャラクターの過去にストーリー性を持たせることで、共感を得やすくした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ただの風景写真だが、どこかストーリー性を感じさせる一枚だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このように何かしらストーリー性を持つ句では、人世や人生の側面を描くため、ドラマストーリーへの共感性とか意外性によっていかに読者を引き込むことができるか、読者に自己投影させえるかが眼目となろう。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
