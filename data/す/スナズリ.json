        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "錆びついた鉄板に砂ずりを施して、表面を滑らかに整える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人が砂ずりの工程を繰り返すことで、金属特有の鈍い光沢が戻ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "手作業での砂ずりは時間がかかるが、仕上がりの精密さが全く違う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
