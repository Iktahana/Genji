      {
        "index": 1,
        "gloss": "chicken gizzard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "焼き鳥屋に行くと、コリコリした食感の砂ずりを必ず注文する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂ずりの銀皮を丁寧に取り除いてから、ニンニクの芽と一緒に炒めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「砂ずりって、実は鶏の胃袋の一部なんだよ」と友人が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "左官のほうじゃあ、大阪｜土の砂ずりなアンてことを言ってネ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "海は青鮫の砂ずりのいろに拡がり、空にちかい波と波のすき間から、聖らかな船唄が流れてくる。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う側はそこだけ横に黒い砂ずりになっているから、こちらで燈でもつけない限りまったくわからない。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天床は網代というのだろう、壁は砂ずりだし、なにかの消息の残欠で裾張りがしてあるが、これも彼の眼には、書き損じの反故にしか見えなかった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
