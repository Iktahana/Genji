        "examples": {
          "standard": [
            {
              "text": "鋼材の接合部分に綺麗なすみ肉溶接が施されており、構造体の強度が保たれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "すみ肉のサイズが設計図通りであることを、ノギスを使って入念に確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "溶接工の資格試験では、すみ肉溶接のビードの均一さが厳しくチェックされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "分担金の必要はないのだが、菱苅と同様、停年近くの黄昏の状態で、みな、くすみにくすんでいる。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の呪いがかかっているような、くすみにくすんだ大玄関の式台と、欅の大引扉は、眼もさめるような青林檎色のペンキを塗られ、ディッケンスの古いアメリカの絵にある、清教徒の郷土の館邸のようなロマンチックな見かけになっていた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともだちに　なった　サンタさんが　かえっていくのは　ちょっと　さみしいけれど、　うれしいことに　まいとし　ぞうの　くにへ　おやすみにくると　やくそくしてくれましたとさ。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから、洋服をぬいで、透明人間となって、あれをぬすみにくるかもしれない。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、気候がだんだん寒くなるとか、なにか、すみにくい変化がおこったのかもしれない。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
