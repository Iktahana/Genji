        "examples": {
          "standard": [
            {
              "text": "工事の進み具合を確認するために、現場を定期的に巡回する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "原稿の進み具合はどうですか？締め切りまであと三日ですよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "料理の進み具合を見ながら、次の材料を準備し始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ペンネン技師からはひっきりなしに、向こうの仕事の進み具合も知らせてよこし、ガスの圧力や山の形の変わりようも尋ねて来ました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『では明日の夕方七時に来て、進み具合を見せていただければ。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「捜査の進み具合はどうですか」　スパロウ警部補が力なく言った。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この船は、京・大阪などを見物にでかける人々をのせた船でしたから、そのとちゅうでも、あちらこちらのみなとによって、見物をしたり、船の中では、ごちそうをひろげて酒もりをしてさわいだり、まことに船のすすみぐあいがおそいのです。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
