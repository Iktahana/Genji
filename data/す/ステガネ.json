        "examples": {
          "standard": [
            {
              "text": "せっかく買ったジムの会員権も、一度も行かずに会費だけ払い続けるのでは捨て金も同然だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな怪しい投資話に乗るなんて、わざわざ捨て金をするようなもんじゃないか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "安物買いの銭失いとはよく言ったもので、すぐに壊れる靴を買うのは結局捨て金になってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの研究には捨て金が大分要ることは知っておく必要がある。",
              "citation": {
                "source": "弓と鉄砲",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの研究には捨て金が大分｜要ることは知って置く必要がある。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの金は捨て金になっちゃう。",
              "citation": {
                "source": "あるドライブ",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしわしに何かあったら、捨て金になるぞ」　グラントがまた笑った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
