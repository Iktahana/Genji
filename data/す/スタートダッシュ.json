      {
        "index": 1,
        "gloss": "dash at the beginning of a short-distance race",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
