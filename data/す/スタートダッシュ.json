        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "短距離走では、スタートダッシュが勝負を分けることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のスタートダッシュは目を見張るほど速かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「よーい、ドン！」の合図で、選手たちは一斉にスタートダッシュを切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それゆえに、８０８６とＧＤＣ、そして互換ベーシックによって「速いＰＣ―８８０１」として生まれたＰＣ―９８０１は、スタートダッシュを決めることができたのだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "charging ahead at full strength from the beginning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
