        "examples": {
          "standard": [
            {
              "text": "「ここのメロディはスタッカートを意識して、もっと音を短く切るように弾いてください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のピアノ演奏は、軽やかなスタッカートが非常に印象的で聴く人を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヴァイオリンの弓を跳ねさせるようにして、歯切れの良いスタッカートを奏でた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それに合わせ、慶一は〈サブスティテュート〉をスタッカートで歌いながら、三階のヴェランダにむかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スタッカート練習曲」「ワルツ・キャプリス」等のピアノ・レコードもある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタッカートじゃなくてさ、ホーンの感じで。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
