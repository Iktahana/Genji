        "examples": {
          "standard": [
            {
              "text": "印刷工場では、刷り上がった大量のチラシをスタッカーが自動で積み上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "倉庫内でパレットを高く積み上げるために、電動のスタッカーを操作する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スタッカーが詰まってしまい、一時的にラインを止めて点検を行うことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それに合わせ、慶一は〈サブスティテュート〉をスタッカートで歌いながら、三階のヴェランダにむかう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スタッカート練習曲」「ワルツ・キャプリス」等のピアノ・レコードもある。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタッカートじゃなくてさ、ホーンの感じで。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
