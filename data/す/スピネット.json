        "examples": {
          "standard": [
            {
              "text": "貴族の邸宅の片隅に、繊細な装飾が施された小型のスピネットが置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "グランドピアノとは異なる、スピネット特有の軽やかで可憐な音色が響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スペースの限られた室内でも、スピネットなら圧迫感なく設置できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここにはまたその頃のがたがたするような小さいスピネット（楽器）もある。",
              "citation": {
                "source": "痴人と死と",
                "author": "ホフマンスタアル　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食を一人で摂ることが多かったベアトリスは食後これまた自然に古いスピネットの前に陣どると、暗く幽鬼じみた和音をいくつか弾いた。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時間もスピネットを弾き続けたり、赤ん坊のそばにいたりして――」「その男の子はジョナサン中佐に違いない。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊＊　一五八〇年版には、「私はそのためのエスピネットの奏者をもっていた」と書いている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスピネットとは旧式のピアノのことである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
