        "examples": {
          "standard": [
            {
              "text": "インテリアの配置については、個人の好き好みがあるから一概には言えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は特に好き好みなく、どんなジャンルの本でも面白がって読む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相手の好き好みを把握しておくことは、プレゼントを選ぶ際に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "王　　さてさてすきこのみの多い人じゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肇のすきこのみなどを千世子は話すまで千世子は聞くまいと思ったし、千世子のすきこのみ、毎日仕て居る事、などは同様肇は何も知らなかった。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
