        "examples": {
          "standard": [
            {
              "text": "テレビの放送が終了し、画面はザラザラとした砂嵐に変わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古いビデオテープを再生したが、砂嵐ばかりで映像が映らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真夜中の部屋に、砂嵐のシャーという不気味な音が響いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
