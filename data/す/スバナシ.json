    "definitions": [
      {
        "index": 1,
        "gloss": "chat without food or drink",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お茶も出せませんが」と断ってから、縁側で老友としばらく素話に興じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特別なもてなしは何もない素話だけの時間だったが、それが何よりの贅沢に感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨宿りのために立ち寄った軒先で、見知らぬ旅人と短い素話を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "佐野さんが来るのを傍輩がかれこれ云っても、これも生帳面に素話をして帰るに極まっている。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの方は素話で、浜町の太夫さんの粋な喉を聴かせるなんていうわけには行かないんですから、お話に艶はありませんがね」　慶応元年の正月の末であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "名所なつかしさに、某の君を見たてて一夜うかれ遊び酒一盃呑むにもあらねば、素話身にしみて、かた様のお国はと問はるるに、東京と答ふれば、吉原といふ処面白いさうな、吉原で遊び給ふ身のここらでは遊ばれまじ、といふ。",
              "citation": {
                "source": "旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより素話になりましてからは沢の紫（粟田口）に次では此の業平文治でございます。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其天地開闢説に就ては、次節に譲り、茲には専ら天然物素話神、即ち火水風、土諸神に就て述ぶ可し。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍妙な当り芸列伝ヘラヘラ坊や名代の円太郎　素話で持ち切れず、苦しまぎれの珍芸で、明治中期の落語界に当りを取った顔触れを一々ここに首実検。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも円朝の素話が芝居以上に面白かったのと同じ程度。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
