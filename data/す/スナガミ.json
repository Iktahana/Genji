          "standard": [
            {
              "text": "木材の表面を滑らかにするため、目の粗い砂紙から順にかけていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サビを落とすために、金属専用の砂紙を使って力強くこすった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工作の時間、砂紙で角を丸く削って手触りを良くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この関係を調べる為に、硯の面を細かい砂紙で大体一定の条件の下で磨いて、各系の実験の始めに於て、硯の面を同じような粗さにしておく。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には硯の面をまた砂紙でこすって新しくし旧くらいの粗さにして、別の墨で全く同様な実験を繰り返すという具合にして実験を進めた。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
