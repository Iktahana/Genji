        "examples": {
          "standard": [
            {
              "text": "1957年、世界初の人工衛星スプートニク1号の打ち上げ成功は、世界中に衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スプートニクの信号を受信したアマチュア無線家たちは、宇宙時代の到来を実感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ソ連のスプートニクショックを受けて、アメリカは宇宙開発への投資を劇的に増やした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あんた達はあたしを自分たちのスプートニクに閉じ込めるべきだったとか抜かしてる。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「スプートニクの中。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシア人たちがスプートニク二号を打ち上げたときに始めたんです。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は自分の犬をスプートニクには乗せなかった、これからも月で迷うなんてさせないわ……」聖歌が雷鳴のように轟いた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリジナルの出版は1959年で、スプートニク・ショック冷めやらぬころ、ソ連のルナ2号が人類の宇宙船として初めて月面に到達した年です。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
