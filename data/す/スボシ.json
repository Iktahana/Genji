        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漁港の近くに行くと、網の上でイカや魚が素干しにされている光景をよく目にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "素干しにすることで素材の旨味が凝縮され、保存性も格段に向上する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このスルメ、素干しだから噛めば噛むほど味が出てくるね」とお酒の席で喜ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
