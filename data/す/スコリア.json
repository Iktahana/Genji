        "examples": {
          "standard": [
            {
              "text": "火山の噴火口周辺には、マグマが急激に冷えて固まった黒いスコリアが散乱している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スコリアは多孔質で水はけが良いため、園芸愛好家の間で土壌改良材として重宝されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "富士山の登山道を歩いていると、ザクザクとしたスコリアの層が足元を滑りやすくさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "スコリアからなる頂が東の空を背景に三八〇〇メートルの高さに聳え、聖なる富士山を描く日本の版画のようだった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
