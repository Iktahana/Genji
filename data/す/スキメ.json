        "examples": {
          "standard": [
            {
              "text": "「障子の隙目から入り込む冷気が、冬の夜の寒さをいっそう厳しく感じさせる」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "板塀の隙目から隣家の庭を覗くと、真っ赤な椿の花が綺麗に咲き誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古くなったタンスの引き出しに隙目ができていることに気づき、修理に出すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "八郎太は、箱の隙目へ小柄を挿し込んで、静かに力を入れた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "香の木の実が生るでなし、はなたちばなが咲くでなし、蜜柑の木より榊とも、樒の木とも云ふ方が、かなつたやうな若い木で、穂すすきめいた弓なりの、四尺ばかりの五六本。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
