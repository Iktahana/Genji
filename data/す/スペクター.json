        "examples": {
          "standard": [
            {
              "text": "古城の窓辺に、青白いスペクターが立っているのを見たという噂が絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての戦争のスペクターが、平和な街に暗い影を落としているように感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自らの過去というスペクターに追い回され、夜も眠れない日々を過ごしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たのしいみもの（スペクタークル）を！",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィル・スペクターとザ・ビーチボーイズが、その代表例だろう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィル・スペクターは、二一歳のとき、ロサンゼルスでザ・テディベアーズというグループをつくり、一九五八年、『トゥ・ノウ・ヒム・イズ・トゥ・ラヴ・ヒム』をヒットにした。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
