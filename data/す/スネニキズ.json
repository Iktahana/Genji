        "examples": {
          "standard": [
            {
              "text": "彼が警察官の姿を見た瞬間に逃げ出したのは、やはりすねに傷があるからだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「私にはすねに傷があるから、表舞台に出るわけにはいかない」と彼は寂しげに笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "清廉潔白に見えるあの政治家も、実は隠されたすねに傷を持っているという噂だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "なれども、首尾よく主家横領はいたしましたものの、すねに傷もつだけに江戸錦様のいられることは目の上のこぶでござりましたゆえ、これをもついでにあやめようと思いたたれてごくふうなさりましたのが、今日ご不審のもととなった秀の浦とのあの一番でござりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの悪党もすねに傷持つ身、私の気迫に押されたのか、しばらく無言で私の顔をねめつけていたが、やがて『よろしい。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに、すねにきずをもっていることとて、仏官憲の臨検を、極度に気にした。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
