        "examples": {
          "standard": [
            {
              "text": "「飛び込み競技の選手が、スプリングボードの反動を利用して高く舞い上がった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このプロジェクトを、海外進出へのスプリングボードにしたいと考えている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『失敗を恐れず、次のステージへ進むためのスプリングボードにしよう。』」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「見ること」の機みをもって、自分自身を脱けだし、自分自身を対象化すること、「見ること」を機みとして、自分自身を自分自身に矛盾せしめ、自分自身をスプリングボードとして時の中に跳ねかえり、突きすすむ。",
              "citation": {
                "source": "「見ること」の意味",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈こいつは賭け金を、飛び込むスプリングボードにするつもりだな〉　おめおめと一周して戻れば、丹尾の五万円は彼のものになる。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
