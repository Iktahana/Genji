        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "引退した先輩から、大切に使っていた野球のスポーツ用品をいくつか譲り受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "近所のショッピングモールに、世界中のブランドを扱うスポーツ用品店がオープンした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部活動の予算で、テニスボールやネットなどの古くなったスポーツ用品を買い換えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しばらくたってから立ちあがり、スポーツ用品をしまってある部屋へあがって、海釣用の糸と針を何本か選びだし、また階段をそっと忍び足で降りた。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車で都心へ出て、スポーツ用品のディスカウント・ストアへいった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スーパー・マーケットの二階にスポーツ用品の店をみつけ、そこで競泳用のショーツを買った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツ用品店とか、妙な書店のヴィデオのコーナーへいくと、置いてある。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "書店、文房具店、スポーツ用品店、時計店、それにパンや飲み物を売る店などだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　報道規制　ピカデリ九九九番地には世界的に有名なスポーツ用品店があり、経営者はグラスゴウ殿下。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
