        "examples": {
          "standard": [
            {
              "text": "スコットランドヤードが捜査に乗り出したことで、事件は一気に解決へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ロンドン警視庁の通称であるスコットランドヤードは、数多くの推理小説に登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スコットランドヤードの精鋭捜査官たちが、現場の証拠品を徹底的に調べ上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……こんな時にスコットランドヤードの探偵犬が居るといいんだがなあ」　この時に杉川医師も階下から上って来た。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二年後に出たフリーマンの「赤い拇指紋」には、さすがに科学的に指紋の偽造が描かれているが、このころになって、スコットランドヤードの指紋課というものがようやく充実し、その効用が一般に認められてきたためではないかと思われる。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとスコットランドヤードの警視庁に着いたのは時計が午前一時半を告げたときだった。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
