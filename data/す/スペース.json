[
  {
    "uuid": "376436a9-7c0c-5785-8d9c-9efbb649a512",
    "entry": "スペース",
    "reading": {
      "primary": "スペース",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
