        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の滑り台は、夏の日差しを浴びて火傷しそうなほど熱くなっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼い娘が何度も階段を上っては、満面の笑みで滑り台を降りてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "放課後の校庭で、小学生たちが滑り台の順番待ちをして長い列を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "砂場、ブランコ、滑り台。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その板看板も夜は土間の荷物の脇に放ってあったので、静三たちにとっては滑り台となったり、橋梁となるのであった。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、さらばさらば」　と、金博士は事務長に挨拶すると、舷をまたいで、傾斜した船側の上を滑り台のように滑って、どさりと百花咲き乱れる花壇の真中に、トランク諸共尻餅をついたのであった。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、甲板が、いやにお滑り台におあつらえ向きになってきましたねえ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い運動場では、子供たちが、ボールを投げたり、なわ飛びをしたり、また滑り台に乗ったりして遊んでいました。",
              "citation": {
                "source": "汽車は走る",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "十フィートの台からは、プールのなかにむけて滑り台があった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上にあるレヴァーを押すと、鉄の滑り台の滑りをよくするために、水が出てくるしかけになっていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このプールのことを思い出すたびに、滑り台の感触がよみがえる。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園には、ぶらんこがあり、すべりだいがありました。",
              "citation": {
                "source": "朝の公園",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、お嬢さんはすべりだいからどうしておちたものか、泣いているのです。",
              "citation": {
                "source": "朝の公園",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "正ちゃんは　あおぎりの　木の　下で、すべりだいに　のって　あそんで　いました。",
              "citation": {
                "source": "しゃしんやさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しゃしんやさんは、正ちゃんを　すべりだいの　上へ　かけさせ、おねえさんに　ランドセルを　しょわせて、下へ　たたせました。",
              "citation": {
                "source": "しゃしんやさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、正ちゃんは　するすると　すべりだいを　すべりました。",
              "citation": {
                "source": "しゃしんやさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、あなの下に、すべりだいのようないたが、ずっとつづいています。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四かくいふたのようなものが、下の方へひらいて、そのふたが、すべりだいのように、ゆかにとどいたのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中カブトムシは、ゆかにたれたふたのすべりだいをはいおりて、そのへんをぐるぐると歩きまわりました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
