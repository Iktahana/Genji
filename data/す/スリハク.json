        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "能の舞台で、女性の役を演じる演者が摺箔の着物を身に纏っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その摺箔は、精緻な鱗模様が銀色に輝いていて非常に美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "役柄によって摺箔の文様が異なり、演目の雰囲気を大きく左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
