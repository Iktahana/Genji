    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be worn down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年使い込んだ愛用のペンの先が磨り減って、インクの出が悪くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "登下校で毎日歩くため、半年も経たないうちにスニーカーの踵が磨り減る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "階段の石段が磨り減っているのを見ると、歴史の長さを実感する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "普通に摩擦係数というと、堅い固体の表面間のものしか研究がして無いので、墨と硯のように一方が磨り減る場合には、問題がずっと難しくなる。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｋが大きいと速く磨り減るのである。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五図の結果で著しいことは、雨端石の硯は、非常に速く磨り減るということである。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このｑ／ｓの値がちょうど墨が一｜糎動いた時に磨り減る層の厚さｈになる。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨が磨り減る厚さと同程度の大きさの粒子になることから考えて、これは墨の磨り口の表面に、顕微鏡でも見えぬくらいの細かい罅が沢山出来る為であろうという考察がされてある。",
              "citation": {
                "source": "墨並びに硯の物理学的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "摩擦係数の測定は、物理学の極めて初歩な実験であるが、それは普通の堅い物体間の摩擦の場合であって、墨と硯との場合のように一方が磨り減る場合は、今まで殆んど手がつけられていない。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわかると、墨の比重は知れているので、墨が一センチ動いた時に磨り減る層の厚さが計算出来る。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、市日や祭日にはいてるばかりでは、木ぐつもなかなか、すりへるものではありません。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡だと思われるほどすりへることのない一つの真実がある。",
              "citation": {
                "source": "新しい文学の誕生",
                "author": "――若い人に贈る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もののすりへることについて、どの面がどうすりへらされるかということについて、少くとも自分だけははっきりして科学的観測の能力をもっていなければならないのねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to dwindle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
