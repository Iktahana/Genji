        "examples": {
          "standard": [
            {
              "text": "選挙後の交渉の末、保守党と自由党による連立内閣が誕生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新しい連立内閣の顔ぶれを見ると、各党への配慮が色濃く反映されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大臣の不祥事が発覚し、発足したばかりの連立内閣は早くも危機に陥った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "資本主義経済の必然の行きづまりで、労働党内閣は、今度保守党自由党の連立内閣をつくった。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山哲を首班とする三党連立内閣はこのような悲喜劇のうちに成立した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤内閣が辞職した時、せめて連立内閣でもと思っていた処、思いも及ばなかった岡田海軍大将が内閣の首班として乗り出して来て、政友会には平大臣として入閣を交渉するような始末になった。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
