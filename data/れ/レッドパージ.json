        "examples": {
          "standard": [
            {
              "text": "あの歴史の授業で、戦後のレッドパージが社会に与えた影響について深く考えさせられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父の古い日記には、職場でレッドパージの嵐が吹き荒れていた当時の緊迫した様子が書き残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "公職追放とそれに続くレッドパージの歴史的背景を調査するため、図書館で昔の新聞記事を何時間も読み漁った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "レッドパージで全国の学生がたたかっていた十月　一万九百人の戦争協力者が解除された。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            }
