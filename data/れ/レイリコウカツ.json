        "examples": {
          "standard": [
            {
              "text": "物語の悪役は、目的のためなら手段を選ばない怜悧狡猾な人物として描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は怜悧狡猾な交渉術で、次々と競合他社を打ち負かしていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一見、人の良さそうな彼だが、実は怜悧狡猾な一面も持っていると噂されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、自分のように人間をおそれ、避け、ごまかしているのは、れいの俗諺の「さわらぬ神にたたりなし」とかいう怜悧狡猾の処生訓を遵奉しているのと、同じ形だ、という事になるのでしょうか。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
