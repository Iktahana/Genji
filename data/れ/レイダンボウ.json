        "examples": {
          "standard": [
            {
              "text": "このマンションは各部屋に冷暖房が完備されているので、一年中快適に過ごせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "電気代を節約するため、使っていない部屋の冷暖房はこまめに消すようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古いアパートなので冷暖房の効きが悪く、真冬は隙間風が身にこたえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "洋館は階上階下とも冷暖房装置にし、日本間のほうは数寄屋造り。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "築地に、夕ぎりという、これも冷暖房完備の、女中美人多しの、スキヤキ屋が出来た。",
              "citation": {
                "source": "牛鍋からすき焼へ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
