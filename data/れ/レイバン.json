        "examples": {
          "standard": [
            {
              "text": "旧約聖書に登場するラケルとレアの父の名は、レイバン（ラバン）である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "レイバンは、二人の娘をヤコブに嫁がせる際に、彼を欺いたことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "振付家のレイバンは、その革新的なダンス記譜法で舞踊界に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "いつも、レイバンのサングラスをかけている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
