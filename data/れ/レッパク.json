        "examples": {
          "standard": [
            {
              "text": "静まり返った部屋に、仕立て屋が厚い布を裁ち鋏で切る裂ぱくの音が響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は古いシーツをウエスにするため、勢いよく布を裂き、鋭い裂ぱくの音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "剣の修行中、振り下ろした木刀が風を切る音が、まるで裂ぱくの音のように鋭く道場に響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
