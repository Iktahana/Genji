        "examples": {
          "standard": [
            {
              "text": "大容量のファイルをダウンロードする際は、レジューム機能があるダウンローダーを使うと安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ノートパソコンを閉じても、開けばすぐに作業を再開できるのはレジューム機能のおかげだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "突然停電したが、レジューム機能があったので印刷は途中から再開できた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "レジューム機能も無し。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプリケーションなどごそごそ動かしているとき、このデスクトップのマシンにもレジューム機能がついていればなあと思う局面は多々ある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
