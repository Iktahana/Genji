        "examples": {
          "standard": [
            {
              "text": "初夏の川辺には、週末のレガッタ大会に向けて練習に励む大学生のボートがいくつも浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "川沿いの土手にレジャーシートを広げて、家族で白熱したレガッタのレースを観戦した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は名門大学のボート部に所属し、年に一度開催される伝統的なレガッタで舵手を務めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十七　オリムピックのなかでも、青リボンと呼ばれる、壮麗なレガッタのなかで、ぼくには、負けて仰いだ、南カルホルニアの無為にして青い空ほど、象徴的に思われたものはありません。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
