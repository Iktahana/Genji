        "examples": {
          "standard": [
            {
              "text": "無線LANのアクセスポイントはレスポンダとして働き、周囲の端末からのプローブ要求に対してネットワーク情報を返す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "チャレンジ＆レスポンス認証において、サーバーから送られた乱数を元に計算を行うクライアント側をレスポンダと呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "航空機のトランスポンダ（応答機）は、地上のレーダーからの質問信号を受信するレスポンダの役割を果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "茶山と江戸にあつた井上四明との応酬に徴するに、茶山の東命は期せずして至つたらしいから、必ずや茶山は相見る日を待たずして屡報復を促し、蘭軒は遂に一たび断えたコレスポンダンスの緒を継いだことであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは筆不精ではないが、手紙不精で、親戚故舊に不沙汰ばかりしてゐるので、讀んで此に到つた時壽阿彌のコルレスポンダンスの範圍に驚かされた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
