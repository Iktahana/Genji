        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣家との境界に、蔦の絡まる古いレンガ塀が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "台風で庭のレンガ塀が一部崩れてしまい、修理が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "猫が夕暮れのレンガ塀の上を、器用に歩いていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "その向こうは、やぶれたレンガ塀をへだてて、すぐ八幡神社の森につづいています。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッと思うまに、黄金の豹は、そのレンガ塀に飛びつきました。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンガべいがつづいて、門には、すかしもようの鉄の扉が、しまっています。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくいきますと、ふるいレンガべいの門に、からくさもようの鉄のとびらのしまった、大きなうちの前に出ました。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはレンガべいでかこまれた、木造三階だての洋館でした。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
