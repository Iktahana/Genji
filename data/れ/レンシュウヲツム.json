        "examples": {
          "standard": [
            {
              "text": "彼は毎日厳しい練習を積むことで、ついに全国大会への切符を手に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "どんな分野でも、一流になるためには地道な練習を積むことが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼女は来る日も来る日も練習を積み、誰もが認めるピアニストになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「老後にそなえて、事務所の重役にでもなる練習を積むには、いまが最適だ」　笑いながら僕が言った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これは声帯模写だから、日本ならば腹話術師よりも声色屋に弟子入りすることになる）　第二回を受持ったアダムスは、これにつづいて表情、手の動かし方、歩き癖その他いっさいの身振りを別人のものにするために、やはり俳優の弟子となり、数カ月の練習を積むという筋にしている。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
