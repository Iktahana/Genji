        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "美容師の卵である彼女は、カットモデルが見つからない時、マネキンの頭を練習台にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "夜中にドラムの練習はできないので、消音パッドのついた練習台でリズムトレーニングに励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新人研修では、本物のレジを模した練習台を使って接客のロールプレイングを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "何を練習台にしたか。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽室のなかでは、五人のスネア・ドラマーが、音楽学校の女打楽器奏者の大声に合わせて、ほんもののスネア・ドラムではなく、板にゴムシートを貼りつけた練習台を相手に、「フラ打ち」の練習をえんえん一時間もつづけていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "練習台を叩く音もまじっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "デジタル技術を経験してこなかった松本にとって、ＩＣ電卓のジャンクは格好の練習台だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
