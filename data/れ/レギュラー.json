        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "レンタカーを返す前に、最寄りのスタンドでレギュラーを満タンにしておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「お支払いは現金ですか？レギュラー30リットル入りました」と店員さんが元気よく声をかけてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "昨今の原油高の影響で、うちの近所のスタンドでもレギュラーの価格が1リットル170円を超えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
