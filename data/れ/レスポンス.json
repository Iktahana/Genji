        "examples": {
          "standard": [
            {
              "text": "ユーザーがボタンをクリックしたときのレスポンスが遅いと、アプリの離脱率が跳ね上がってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "採用面接のメールを送ったが、一週間経っても候補者からのレスポンスがなく困惑している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の良いところは、仕事の依頼に対して常に的確かつ迅速なレスポンスを返してくれることだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "余り情熱の激しさに打まけ、打まけるのが苦々しいために良人に対して、それにレスポンスしないことを怒る――、　此は如何に考えられるべきことか。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
