        "examples": {
          "standard": [
            {
              "text": "初代のレーザーライターは、DTPの歴史を語る上で欠かせない画期的な製品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "博物館には、初期のパーソナルコンピュータと共に、Apple社のレーザーライターが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は古いマニュアルを読みながら、なんとかヴィンテージのレーザーライターを修理しようと試みていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "一九八五年二月にレーザーライターの名称で発表されたこの製品は、アルダスが開発中のページメーカと名付けられたソフトウエアの足下を固める役割を演じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
