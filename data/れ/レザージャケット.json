        "examples": {
          "standard": [
            {
              "text": "彼は黒いレザージャケットを羽織り、愛用のバイクにまたがった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ライブに行くために、クローゼットから何年も着ているレザージャケットを引っ張り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "このレザージャケット、少しサイズが大きいけど、中にパーカーを着ればちょうどいいかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それに目を通そうと、レザージャケットの男が足を止めた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便屋とレザージャケットの男が歩道に立ち止まって様子を眺めた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とレザージャケットの男が近づいてきた。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            }
          ]
