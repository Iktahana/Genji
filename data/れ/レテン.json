        "examples": {
          "standard": [
            {
              "text": "漢文の授業で、先生が黒板に返り点の一種であるレ点を書き加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この漢詩を訓読するには、いくつかあるレ点の意味を正確に理解する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は白文を読むとき、鉛筆で薄くレ点や一二点を書き込みながら読み進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ヘゲタレてんなあ、人権じゃなくて人間の方だろ！",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
