          "standard": [
            {
              "text": "その歴史書は、歴代の皇帝の出来事を正確な年代の列次に従って詳細に記述している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祭りのパレードでは、各町内の神輿が古くからの取り決めに基づく列次で街を練り歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "文書のファイリング作業で、資料を発生した日付の列次に正しく並べ替えるよう上司に指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "其後天明八年戊申と寛政十一年己未とに列次を進め俸禄を加へられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小嶋君はこのたび全集の印刷校正に際し、先生が用語の大略を列次して其便覽を作り、之を編纂同人竝に印刷所に送り、以て全集校正の完璧を期すべしといふ。",
              "citation": {
                "source": "鴎外全集刊行の記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
