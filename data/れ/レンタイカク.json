          "standard": [
            {
              "text": "ラテン語の学習で、名詞の格変化、特に連体格の用法を覚えるのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "先生は、所有を表す「の」が日本語における連体格の役割を担っていると説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ドイツ語では、連体格の名詞が後ろに続く名詞を修飾することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "熊本県では「り」をもって終る連体格の動詞を、ライと昔風に延べて言う風があると記憶するが果して誤りはないだろうか。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
