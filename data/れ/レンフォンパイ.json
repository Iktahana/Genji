    "definitions": [
      {
        "index": 1,
        "gloss": "tiles matching both the round wind and one's seat wind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "東場（トンバ）で東（トン）を刻子（コーツ）にすると、連風牌となり二翻（リャンハン）つく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は自分の席風と場風が同じであることに気づき、連風牌を狙って手を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "初心者の頃は、連風牌の存在を知らずに、みすみす役を逃してしまったことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "頭を掻くと、白板があるという信号だったり、鼻の頭をこすると連風牌があるということだったりする簡単な信号から、もっと秩序だったものでは、持牌十三枚の間、適当なところをすこしすかしてみたり、又一枚ぐらい列から前へ出したり、後へ下げたりして、入用な牌を相手に求める方法もある。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "pung (or kong) of these tiles (meld)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は配牌で連風牌の対子（トイツ）があったため、積極的にポンして役を確定させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「ポン！」という声と共に、彼は連風牌をさらし、高得点を予感させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "リーチをかけていたところに、対面から連風牌が出て、思わずロンと声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
