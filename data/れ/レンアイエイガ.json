        "examples": {
          "standard": [
            {
              "text": "雨の日は、家でゆっくり恋愛映画を観て過ごすのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あの俳優が出演している恋愛映画は、いつも結末が切なくて泣いてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "最近の恋愛映画は、単純に甘いだけでなく、登場人物の成長や葛藤も描かれていて見応えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "（それが女性の快楽であるかもしれないが）今まで、涙ながして何度もみた恋愛映画に於いても、私は思いかえしてみて、そこにあらわれたいろいろの女性は悉くそう云った自己満足のように思われた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
