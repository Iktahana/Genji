[
  {
    "uuid": "ce7be095-e2ee-552e-ad9b-84af516737a2",
    "entry": "練炭",
    "reading": {
      "primary": "れんたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "briquette (charcoal or coal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い冬の朝、祖母は火鉢に練炭の火をおこして部屋を暖めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "昔ながらの焼き肉屋では、今でも七輪に練炭を使って肉を焼いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "換気の悪い室内で練炭を燃やすと、一酸化炭素中毒の危険があるので絶対にやめてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "多少の寒さでは、大切にためてきた練炭に火を付けることを許しません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが焼け跡に燃え盛る練炭の山を見つけた途端、冷水でも浴びせられたように失ったものの大きさにうたれ、突き上げる悔しさに胸を焼かれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこで、子｜猫のようにかがみ込み、背をピアノの方に向け、一塊の練炭が音もなく燃えつきてゆく炉の赤い輝きに眼をすえながら、過去の事柄をうっとりと思い浮かべていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "スープ煮で他にすゐ鍋、七輪持って来て練炭で焚くといふ「殺風景で済みません」と全くだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
