        "examples": {
          "standard": [
            {
              "text": "春の柔らかな日差しが、風に揺れるレースカーテンを通して部屋の中に差し込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新しい部屋に合わせて、外からの視線を遮りつつも明るさを保てるレースカーテンを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "猫がレースカーテンにじゃれついて、爪を引っ掛けてほつれさせてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "小規模なそのホテルの食堂も、白と金とレースカーテンのほのかなクリーム色に飾られて、喪服の年とった婦人がひとり、むこうのはじの小食卓についている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南に向って平たく浅い六畳ですし、縁側がないからその日よけと、すだれと、レースカーテンとで光りを調節しているわけですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
