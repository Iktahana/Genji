        "examples": {
          "standard": [
            {
              "text": "真夏に外回りをして帰ってきた後、冷蔵庫でキンキンに冷えた冷茶を飲むのが一番の幸せだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "麦茶パックを水出しにして、常にピッチャーに冷茶を作り置きしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "来客があったので、氷をたっぷり入れたグラスに冷茶を注いで急いでお出しした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かう云ふ挨拶に慣れた先生は、折から小間使の持つて来た冷茶を、客の前に直させながら、直に話頭を相手の方へ転換した。",
              "citation": {
                "source": "手巾",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭先生に、よろしくね」　青木は思わずホッとして、のぼせた頭に、血がクラクラと離合集散、彼は冷汗をふいて、冷茶をグッと一パイのみほした。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、主人の手が自分の口を割って冷茶のような水物を流し込んでくれたまでは、ぼんやりながら薄眼で見ていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "即時に同氏の宅に至り、冷茶を喫す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "白身の刺身、冷茶わんむし（これは洒落れてゐる）、メンチボール。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
