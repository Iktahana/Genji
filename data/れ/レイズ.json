        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「すみません、その棚の上にある箱をレイズして取ってもらえますか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "フォークリフトを使って、重い荷物をトラックの荷台にレイズした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "クレーンが巨大な鉄骨をゆっくりとレイズしていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "raising (topic)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
