        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゲームで仲間が倒れたが、ヒーラーが魔法でレイズしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「誰かレイズの呪文を使える人はいないか！」",
              "citation": {
