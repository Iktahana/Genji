        "examples": {
          "standard": [
            {
              "text": "この新薬は、特定のウイルスの表面にあるレセプターに結合し、体内細胞への侵入を防ぐ効果がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ホルモンは血流に乗って全身を巡り、標的となる細胞のレセプターと結合することで情報を伝達する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "研究チームは、がん細胞に特有のレセプターを標的とする新しい治療法の開発を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
