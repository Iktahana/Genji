        "examples": {
          "standard": [
            {
              "text": "履歴書に貼る証明写真を撮った後、写真館で肌の写りを少しだけレタッチしてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "プロのフォトグラファーは、撮影した写真を一枚一枚丁寧にレタッチし、光や色を調整して作品を仕上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この画像編集ソフトを使えば、専門家でなくても、写真の赤目補正やシミ消しなどの簡単なレタッチができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
