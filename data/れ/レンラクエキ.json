        "examples": {
          "standard": [
            {
              "text": "新宿駅は多くの路線が乗り入れる、都内でも有数の巨大な連絡駅だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "地下鉄と私鉄の連絡駅で乗り換える際、少し迷ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "次の連絡駅で快速電車に乗り換えた方が、目的地に早く着くはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この連絡駅は、いつも刺々しく緊張していた。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "青森に着いても何事も知らされず、いつものように乗客は先を争って汽車に乗ろうとし、それを制止する駅員の声がとぎれとぎれに雑沓の中に響く、普段通りの連絡駅風景であった。",
              "citation": {
                "source": "Ｉ駅の一夜",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
