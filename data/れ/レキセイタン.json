        "examples": {
          "standard": [
            {
              "text": "蒸気機関車の燃料として、火力が安定している瀝青炭が山積みになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "冬の暖炉にくべるため、おじいさんは地下室に瀝青炭をたくさん蓄えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "製鉄所の高炉を稼働させるため、海外から大量の良質な瀝青炭を輸入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "棺中の清潔な白布に安置されてゐる死體は初め急いで瞥見した目には形の崩れた燃えさしの瀝青炭の大きな塊に似てゐたが、これを更に接近してその恐るべき代物を探知するのは餘程の健胃者によつて初めて成し得る觀察であつたに相違ない。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
