        "examples": {
          "standard": [
            {
              "text": "その歴史学者は、編年体ではなく、あえて人物に焦点を当てた列伝体で新しい歴史書を執筆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "中国の正史は伝統的に紀伝体という形式をとっており、本紀と列伝体で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "一つの出来事を様々な人物の視点から描く列伝体の手法を用いることで、物語に深みが増していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「美人伝は、こちらがお書きになってらっしゃるから、いけないけれど――」と、画伯夫人は、列伝体のものを、欣々女史の名で集めて残したらよかろうということを、しきりに勧めた。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
