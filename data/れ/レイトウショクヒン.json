        "examples": {
          "standard": [
            {
              "text": "最近の冷凍食品はクオリティが高く、特にチャーハンやパスタはレンジで温めるだけで本格的な味が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お弁当の隙間を埋めるのに、自然解凍で食べられる冷凍食品のおかずが毎日大活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "共働きの我が家では、忙しい平日の夕食は冷凍食品やレトルトに頼ることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "罐詰と冷凍食品ばかり食べている連中には、磯の香りは生臭いのであろう。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方工業を興して電気冷蔵庫をたくさん作り、冷凍食品で生活出来るように、食生活を改善する。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷凍食品が普及しているお蔭である。",
              "citation": {
                "source": "北国の春",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
