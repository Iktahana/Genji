        "examples": {
          "standard": [
            {
              "text": "プログラミング中に関数の引数が分からなくなったので、公式ドキュメントのレファレンスを参照して正しい使い方を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "図書館のカウンターで司書さんにレファレンスをお願いし、郷土史のレポート作成に必要な古い新聞記事のマイクロフィルムを探してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "英語の技術書を読む際、手元に専門用語のレファレンスブックを置いて、分からない単語をこまめに引きながら読み進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "研究調査業務のスピード化の一つとして、図書館がレファレンス業務を営むこともあげらるべきだろう。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実用主義の国アメリカでは、図書館が単に文献の格納庫ではなく、この眠れる宝庫を活かすためにレファレンス業務が活発におこなわれている。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この書物は一般向きの読物の形をとってはいるが、この学殖深く視野の広い医学史学者がそこに揃えている話題は、他に求めにくいものも多く、正確なレファレンスも挙げられていて、学問的な用意にも欠けていない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
