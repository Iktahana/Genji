        "examples": {
          "standard": [
            {
              "text": "前回のオリンピックが残した最大のレガシーは、市民が自由に使える広大なスポーツ施設群だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先代の社長が築き上げた顧客との強い信頼関係が、我が社のかけがえのないレガシーとなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父の古い日記を読み返し、そこに綴られた戦争の記憶を家族のレガシーとして後世に伝えたいと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
