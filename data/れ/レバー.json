    "definitions": [
      {
        "index": 1,
        "gloss": "liver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鉄分不足を解消するために、昨日の夕食は鶏のレバーを甘辛く煮付けた惣菜をスーパーで買ってきて食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "焼き肉屋に行くと、彼女はいつも最初に新鮮な牛レバーを頼んで、両面を軽く炙ってからごま油と塩で味わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "豚レバーの下処理を丁寧に行い、血抜きをしてから牛乳に浸しておくことで、特有の臭みをかなり抑えることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わら色、レモン色、オレンジ色、レンガ色、アイリッシュ・セッターみたいな色、レバー色、粘土色、ありとあらゆる色合いの赤毛がおりました。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちに高い「エレバートル」が見える！",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（エレバートルは麦袋を貨車につみ込むための自動的運搬である。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そびえるエレバートルの下へ機関車にひかれて行く。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も新しいエレバートルを見た。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は日やけした小手をかざして、眩しい耕地の果、麦輸送の「エレバートル」の高塔が白く燦いている方を眺めた。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メメックスは一見すれば、傾いたディスプレイとキーボード、ボタンやレバーの付いた机である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてレバーをうごかしたり、操縦｜桿をひねったりした。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、それでは極微の世界にお別れして、逆の方向へとびますよ」　博士がそういって、レバーを切りかえると、東助とヒトミのからだは、ほんのすこしの間だけだったが、大きな力でおしつぶされるような感じをうけた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "故障の扇風機をしらべてみると、故障のところは、レバーの接触がよくないのだと分った。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手も、マリ子と名のる女スパイとともに、毒瓦斯にやられてしまい、レバーやハンドルから、手を放してしまったのである。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり歩行の自由を奪はれた父親を、車のついた箱に載せ、その力の強い犬に曳かせて、この九つになつたばかりのミス・レバースは物乞ひして歩いたのである。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○或るところの高い「エレバートル」〔起重機〕、馬車が積んで□かけて□る。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷滴の下った貨車、聳えるエレバートルの下へ、貨車がキカン車にひかれてゆく。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も新しいいくつかのエレバートル、まだこしらえかけで頂上に赤旗の翻ってるのなどを見た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二人は助けあって、スイッチをひねったり、レバーを引っぱったり、ペダルをふんだりして、ありとあらゆる応急処置をこころみた。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "レバーをたおすと、地底戦車は、ごとんごとんと、前進をはじめたのであった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピート一等兵は、あわてて、レバーをひいて、ギアをはずした。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンズ・カバーをとって、焦点硝子の上に落ちる映像にしきりにレバーを動かせていると、誰か僕のうしろにソッと忍びよった者のあるのを意識した。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人の前にひろげたいろいろの手製の料理、レバー焼きだの肉のカンヅメだの、イモやカボチャの煮つけなどを交換し合いながら「病院の配給料理はまずいね」　などとこぼしてはいるが、その配給料理の味のないようなカボチャの煮たのまで一ツ残さず食いあげてしまう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギスレバータス・クリスピナス僧院長、一一一四年。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を釣りあげた上の姉の常子が、毛布地仕立の大外套の重ね着をして、鼻の下までマフラをひきあげた山川に蝙蝠傘をさしかけながら、なになには、どうとかしなくてはとか、ネオ・レバーを飲むことを忘れないでとか、子供にでもいうようにクドクドと注意していた。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに卵の黄身、牛乳は欠かさず、ビフテキ、レバーなども時々やる。",
              "citation": {
                "source": "猫料理",
                "author": "村松梢風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間を逃さず女は裁断機のレバーを一気に押し下げた。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校はすでに片足を伸ばして、『製図屋』の電源を入れるために、レバーを倒そうとしていた。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると当然、将校の足はレバーに届かなくなる。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "理研レバーも、私のように肝臓をひどく患ったものには必要だそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしレバーは薬でのまず、私はいきなり肝ゾーをたべることで補います、薬多種は趣味でないから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "理研のレバー、それから御持薬、こんなにきくのでしょうか、ともかくこれは結構です、どうか御よろこび下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "理研レバーでもふせぎきれませんから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
