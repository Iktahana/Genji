        "examples": {
          "standard": [
            {
              "text": "「この会社に送る履歴書、英語ではレジュメって言うんだっけ？」「そうそう、職務経歴が中心のやつね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "外資系企業への転職を目指して、彼は英文のレジュメの書き方を学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "リクルーターは、毎日何百通ものレジュメに目を通している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "レジューム機能も無し。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アプリケーションなどごそごそ動かしているとき、このデスクトップのマシンにもレジューム機能がついていればなあと思う局面は多々ある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
