        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "転倒した際、割れた瓶で腕に深い裂創を負ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "医師は傷口を丁寧に洗浄し、裂創を数針縫合する処置を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "事故現場では、救急隊員が負傷者の裂創から流れ出る血を懸命に止めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "創は裂創にして、熊の爪にかけられたるも逃げ出して無事なりと。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の眼は裂創の縫合のために恐ろしいまでに吊りあがり、右の耳殻が無くなって、そこに干貝のような恰好をしたものが申訳のように喰ッついている。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗り二　これっそういいながら、やや滑稽に先の船乗りを引きずり下ろす。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
