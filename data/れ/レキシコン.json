        "examples": {
          "standard": [
            {
              "text": "あの作家の独自のレキシコンには、一般には使われない古風な表現が数多く含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "専門家同士の会議では、その分野特有のレキシコンが頻繁に飛び交っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "子供のレキシコンが急速に発達する時期には、周囲の大人の言葉遣いが大きく影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "更にマイエルのレキシコンによれば、大アララットが五一六五米で、小アララットが四〇三〇米。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
