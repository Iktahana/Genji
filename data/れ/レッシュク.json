        "examples": {
          "standard": [
            {
              "text": "古代中国の天文学では、天球を二十八の列宿に分けて星の位置を記録していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "夜空に輝く列宿の動きを観察することで、昔の人々は季節の移り変わりや農作業の時期を知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "陰陽師は、列宿の配置を読み解くことで国家の吉凶を占ったと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わたくしは当時の社会にどういう人物がいたかと問うて、ここに学問芸術界の列宿を数えて見たい。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
