          "standard": [
            {
              "text": "広大な敷地を持つそのレジャーランドには、一日では遊びきれないほどのアトラクションがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "子供の頃、親にレジャーランドへ連れて行ってもらったのが楽しい思い出だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "バスツアーの行程には、地元の有名なレジャーランドでの自由時間が含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "灯台のある丘の下に、子供の国レジャーランド、と看板にうたった施設が、暑い陽ざしのなかに横たわっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
