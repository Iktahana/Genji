          "literary": [
            {
              "text": "学円　私に礼には及ばない。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お礼には及ばないよ。",
              "citation": {
