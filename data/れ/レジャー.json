        "examples": {
          "standard": [
            {
              "text": "仕事が忙しくて、最近はゆっくりレジャーを楽しむ時間がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "次の連休は、家族でキャンプにでも行って、アウトドアレジャーを満喫したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "高齢化社会の進展に伴い、シニア向けのレジャー市場が拡大している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "p. 247　また、モスク※大学生のとき、社会諷刺詩「サーシカ」をかいたためにニコライから兵士にされてカフカスへ送られ一番しまいには「安酒に」という詩をかき兵卒病院の地下室で死骸になった片脚を鼠にかじりちらされて生涯を終ったポレジャーエフについて。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ、レジャーブームという言葉があるが、自分一人楽しんで家族を困らせるのは、娯楽の本質でない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ、よくレジャーブームというが、自分一人で遊んでいたのでは意味がない。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、自然な性質、教育、研究のために有利な地位、初期教育、労働愛、レジャー、である。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯台のある丘の下に、子供の国レジャーランド、と看板にうたった施設が、暑い陽ざしのなかに横たわっていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
