        "examples": {
          "standard": [
            {
              "text": "週末はレイクサイドのキャンプ場で、静かな湖面を眺めながらのんびり過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "湖畔に建つレイクサイドホテルからは、四季折々の美しい自然の景色を満喫できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女はレイクサイド沿いの遊歩道を、愛犬と一緒に毎朝ジョギングしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小中高と持ち上がりの名門校、レイクサイドスクールに学んだゲイツは、中学二年のときコンピューターと出会うことになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七三年六月、レイクサイドスクールを卒業したゲイツは、その年の九月、ハーバード大学に進む。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・アレンとビル・ゲイツを結びつけたのは、二人が通ったシアトルのレイクサイドスクールで始まったコンピューターの授業だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立の名門男子校のレイクサイドスクールは、一九六八年春、いち早くコンピューター教育に取り組むことを決めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとはテレックス用の通信端末として開発されたテレタイプが購入され、レイクサイドスクールに設けられたコンピュータールームに置かれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイクサイドスクールでは、テレタイプは電話回線を通してゼネラルエレクトリックのＰＤＰ―10に接続され、タイム・シェアリング・システム★によって割り振られたマシンの処理能力を同校から利用できるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイクサイドスクールがタイムシェアリングのサービスを買っていることを聞きつけたＣＣＣは、この学校への売り込みに成功した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイクサイドスクールの最終学年に達していたゲイツは、二学期を休学する許可を得てアレンの誘いに乗った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
