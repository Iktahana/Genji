        "examples": {
          "standard": [
            {
              "text": "捻挫した足首の腫れを素早く抑えるために、救急箱からスプレー式の冷却剤を取り出して吹きかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "発熱した子供の額に、冷凍庫で冷やしておいたゲル状の冷却剤を当ててあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "生鮮食品を宅配便で送る際には、箱の中にドライアイスや保冷剤などの冷却剤を多めに入れる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "パレは呼ばれ薬屋に行ってふつうの冷却剤を求めた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
