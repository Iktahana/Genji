        "examples": {
          "standard": [
            {
              "text": "安定した議会運営を目指し、与党は新たな連立政権を発足させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ヨーロッパの多くの国では、複数の政党による連立政権が一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その法案は、連立政権内の意見の不一致により採決が見送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのための強国間の協力、原子爆弾の禁止、人種的差別の撤廃、マーシャル・プランの廃止、植民地住民の自治原則確立、日独に対する講和促進と占領軍の撤退、中国における民主的連立政権の樹立、タフト・ハートレー法の撤廃、非米委員会活動の廃止、基本産業の国有化と時給一ドル最低賃銀制の確立。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
