        "examples": {
          "standard": [
            {
              "text": "祖父は若かりし頃、黎明会に参加し、新しい時代の思想を学んだそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "その博物館には、黎明会が発行した貴重な機関誌が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は黎明会の中心メンバーとして、数多くの文化活動を主導した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "」福田博士の衣替へ５・13（夕）　先日中央公会堂で開いた黎明会の講演会に聴きに往つた人は、いつも黒木綿の紋附羽織に小倉の袴ときまつた福田徳三博士が、皺くちやではあつたが、背広の洋服を被てゐたのを見て一寸変な気持がしたに相違ない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明会的な啓蒙運動としての批判主義哲学や文化哲学が、その地ならしをした。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
