        "examples": {
          "standard": [
            {
              "text": "本館と新館は、ガラス張りの明るい連絡通路で繋がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "地下鉄の駅からデパートの地下売り場まで、濡れずに行ける連絡通路があって便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "火災報知器が鳴り、従業員は慌てて非常用の連絡通路を通って外へ避難した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これらのうちに７つの“外部”脈（陽の基本原理）、８つの”内部”脈（陰の原理を示す）、９つの”道”（大きな連絡通路に相当する）、および致死的な証拠となる27の脈、がある。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＪＲの駅まで連絡通路を歩き、新横浜までの切符を買ってＪＲの駅に入った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
