        "examples": {
          "standard": [
            {
              "text": "病院の地下にある霊安室は、ひんやりとしていて重苦しい静寂に包まれていた",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "身元不明の遺体は、家族が迎えに来るまで警察署の霊安室で一時的に安置されます",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "葬儀会社の手配が済むまでの間、父は病院の霊安室で静かに眠っていた",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "地下室までエレベーターで降りると、私は霊安室の前まで行き、霊安室というからには何処かいんさんな景情であろうと思ったが、締った扉の中は見えないが普通の病室と変りがなかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "その霊安室と背中合せに洗濯物にアイロンを当てる工場の大きさくらいある、洗濯屋さんの仕事場があった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはお隣の霊安室の死の気はいさえない、死もアイロンで白く清められている感じであった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
