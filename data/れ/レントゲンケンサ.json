        "examples": {
          "standard": [
            {
              "text": "歯の痛みの原因を特定するために、歯科医院で顔全体のレントゲン検査を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "バリウムを飲んでから行う胃のレントゲン検査は、何度経験しても慣れないものですね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "骨の成長具合を確認するため、小児科医は定期的な手首のレントゲン検査を勧めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「やっ」　と言いながら木村さんは、つかむように受け取って、「ど、どうしてこれが……」「レントゲン検査に行ったのは、これを取りかえすためだったのです」　と、俊夫君は説明しました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "タビ／＼申シ上ゲル通リ、コノオ痛ミハ脳中枢カラノ原因ガ二三分、他ノ六七分ハ頸椎ノ生理的変化ニ依ル神経痛ト云ウコトニ、レントゲン検査ノ結果診断ガツイテオリマス。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
