        "examples": {
          "standard": [
            {
              "text": "新しい国王の戴冠式で、王権の象徴である豪華なレガリアが厳かにお披露目された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "博物館の厳重なセキュリティシステムに守られたガラスケースの中に、古代帝国のレガリアが展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "王室の宝物庫から盗み出されたレガリアを取り戻すため、秘密裏に捜査班が結成された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "四五日前、図書館で読んだ哲人の書物のなかに、結婚とは人間のグレガリアスハビット（群居性）の一形式に過ぎない、とあったのを、ふと思い出したのです。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
