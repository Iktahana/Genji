        "examples": {
          "standard": [
            {
              "text": "競馬初心者の友人に、連勝式の馬券の買い方を教えてあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は直感を信じて連勝式で万馬券を当て、大喜びしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "どの馬が勝つか分からない混戦模様なので、とりあえず連勝式で何通りか買っておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "以上のレース経過をたどって、山際さんの犬とデンスケの犬で連勝式一二着と相なったが、本命の魚屋と対抗の八百屋と、その他の入賞候補の注意犬がみんなダシぬかれて負けてしまい、一番名もない駄犬が一二着。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
