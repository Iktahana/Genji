        "examples": {
          "standard": [
            {
              "text": "彼女は大学の在外研究員として、ヨーロッパで最新の学術動向を追っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "在外研究員からの報告書は、研究室にとって貴重な情報源だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は在外研究員制度を利用して、海外の研究機関で経験を積んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "名義こそ從來の留學生は在外研究員と改良されたが、實際の待遇は、到底陸海軍等の在外研究員と比較出來ぬ程愍然たるものである。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、当時の「還学生」の名より「留学生」の名を好んだごとく、「在外研究員」の名を厭うて、自ら「留学生」と謂っていたのであった。",
              "citation": {
                "source": "ドナウ源流行",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同教授はロシア人で一九二九年在外研究員としてケンブリッジへ派遣され、ラザフォード卿の下で強力磁場の作成にその非凡の能力を発揮するや、英学界は彼のために新研究所を作りその所長に任じたのである。",
              "citation": {
                "source": "カピッツア争い",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
