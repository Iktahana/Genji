        "examples": {
          "standard": [
            {
              "text": "ガソリンの残量が心もとないので、次のサービスエリアで給油しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スマホのバッテリー残量が10％を切ると、自動的に節電モードに切り替わる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "在庫の残量を正確に把握するために、月末の棚卸しを徹底している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "経路探索用の紙の残量にしても無限にはほど遠く、かといって追加用に予備のノートやスケッチ用紙を犠牲にするのは忍びなかったが、結局大判のノート一冊をそれに充てることにした。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くにある二つのトンネルが両方とも塞がっているならば、次に近い更に北側のトンネルを当ってみるだけの電池残量があるか疑わしかった――第二の選択肢より更に二キロメートル近く離れているからだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
