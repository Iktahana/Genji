        "examples": {
          "standard": [
            {
              "text": "こたつで本を読んでいると腰が痛くなるので、通販で座椅子を注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "和室に新しく購入した高級な座椅子を置くと、部屋の雰囲気が一段と良くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "おじいちゃんは、テレビを見る時にいつも使い込んだお気に入りの座椅子に座る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お父様は障子のそばへ床をうつし、今は座椅子によって上半身起き上っていらっしゃいます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは午後一寸（二時間ほど）横になってあと茶の間にいた、座椅子にもたれて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いんね川のでございす。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは貧しいみなし児でございすが、贅沢などをしたいとは存じません。",
              "citation": {
                "source": "三つの指環",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
