        "examples": {
          "standard": [
            {
              "text": "彼はチームの監督として優れているだけでなく、経営などの財政面でも手腕を発揮している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外移住を検討しているが、言語の問題よりも財政面での不安の方が大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンサートの開催にあたって、地元の企業が財政面での全面的なバックアップを約束してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに財政面での支援を続けてきたベネディクティン・カレッジが、今後、資金の提供を行えない見通しとなったこと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただでさえ、新政府の財政面は火の車なのである。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
