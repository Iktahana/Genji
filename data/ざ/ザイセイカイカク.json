        "examples": {
          "standard": [
            {
              "text": "財政改革の一環として、公務員の給与削減と組織の統廃合が検討されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "痛みを伴う財政改革を行わなければ、この国の経済は数年以内に破綻するだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "知事は財政改革を公約に掲げ、選挙で圧倒的な支持を得て当選した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり財政改革の下拵らえで、必要なばあいには準備した調書をかれらに示し、拒否できないように抑えるという計画だった。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、財政改革ということが、いつかは避けられないという現実もわかっていた。",
              "citation": {
                "source": "いしが奢る",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
