        "examples": {
          "standard": [
            {
              "text": "彼は昔からお酒が好きで、鼻の頭が赤く膨らんだ「ざくろ鼻」になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ざくろ鼻の治療について相談するため、信頼できる皮膚科の専門医を訪ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鏡を見るたび、自分のざくろ鼻が目立ってきたようで気にかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鼻は所謂ざくろ鼻といふやつだが、たゞ赤いばかりでなく脂光にぬらついて吹出物が目立ち、口をあく毎に双つの小鼻が拳骨のやうに怒り鼻腔が正面を向いた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻はいわゆるざくろ鼻というやつだが、ただ赤いばかりでなく脂光にぬらついて吹出物が目立ち、口をあくごとに二つの小鼻が拳骨のように怒り鼻腔が正面を向いた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
