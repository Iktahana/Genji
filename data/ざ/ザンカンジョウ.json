    "definitions": [
      {
        "index": 1,
        "gloss": "letter explaining the reasons for cutting down an alleged villain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "刺客の懐には、標的とした人物の罪状を列挙した斬奸状が隠されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "乱闘の跡に残された斬奸状の文字は、怒りに震えたのか乱暴に書き殴られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「我ら、大義のためにこれを斬奸せり」と記された斬奸状が門前に貼り出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "切り取り強盗、闇討ち放火、至る所に行なわれ巷の辻々には切り仆された武士の屍が横たわっていたりまた武家屋敷の窓や塀には斬奸状が張られてあったり、二百万人を包容していた幕府所在地の大きな都には平和の影さえも見られなくなった。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田沼主殿頭その人を、さながらに作った人形であって、しかもその胸には短刀が刺してあり、手には斬奸状が持たされてあった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "等々と云ったような条目が、斬奸状には連らねてあった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と慶喜を説き、「薩藩奸党ノ者罪状之事」という斬奸状をたずさえ、慶喜を護衛して上京することになった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮士は、斬奸状を懐にしていたが、それを官内省に持っていって、さし出した。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "」九　（一二八ページ）大久保利通への斬奸状「石川県士族島田一郎等、叩頭死昧、仰いで天皇陛下に奏し、俯して三千有万の人衆に普告す。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
