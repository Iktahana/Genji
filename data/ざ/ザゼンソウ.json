        "examples": {
          "standard": [
            {
              "text": "湿地帯に自生する座禅草は、達磨大師が座禅を組む姿に似ていると言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春先に雪の中から顔を出す座禅草の姿は、生命力を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て、あそこに座禅草が咲いているよ！」と彼は指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "元来｜沮洳の地で、水芭蕉や座禅草など生えていたが、今は道が少し上の方へつけ替えられた。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
