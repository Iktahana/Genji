        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "在日韓国人のコミュニティは、独自の文化を形成している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は在日韓国人として、日本と韓国の架け橋となることを目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "在日韓国人の歴史は、日本の近代史と深く関わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "県下有数の受験校の教師たちは強く休学を進めたが、孫は在日韓国人の両親の承諾を取りつけてさっさと退学届けを出し、一九七四（昭和四十九）年二月、アメリカに渡った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
