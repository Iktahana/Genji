        "index": 1,
        "gloss": "South Korean national residing in Japan (esp. one who came to Japan before 1945 or a descendant of such a person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
