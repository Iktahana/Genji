        "examples": {
          "standard": [
            {
              "text": "深刻な少子高齢化は、もはや単なる社会現象ではなく、国家を揺るがす財政問題である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は長年、地方自治体が抱える複雑な財政問題の解決に向けて取り組んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家族会議の議題は、いつも最終的には家のリフォームにかかる財政問題に行き着く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その後もこの研究所の財政問題などで心を煩わすことが多かったようである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して今や財政問題に於て党議と相反するものあり、遂に已むを得ずして党籍を脱す。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "財政問題が多いが、これも主婦のやる任務が、これでおしまいになるからであろう。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対してベエコンは、上院議員たちに財政問題に容喙させる機会を与えることの危険を説いて、上院の企てを挫折せしめた。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
