        "examples": {
          "standard": [
            {
              "text": "人気アーティストのコンサートチケットは、発売開始から数分で残席わずかとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛行機の残席を確認したが、希望の便はすべて満席で予約できなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「残席一名様となっております、お急ぎください」と受付係が呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この時、炉辺閑談の席は、鐙小屋の神主の退却した時を以て一次会が終り、あとは閑散のやからが残席を守り、或いは長々と炉辺に寝そべって、頬杖をつきながらだまり込んでいるのもある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
