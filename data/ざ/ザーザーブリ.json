        "examples": {
          "standard": [
            {
              "text": "突然のザーザー降りになり、駅の雨宿り客で改札口が溢れかえった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バケツをひっくり返したようなザーザー降りの中、泥まみれで帰宅した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このザーザー降りじゃ、今日の運動会は延期だろうね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのあいだも、雨はザーザー降り、窓という窓は、風のためにガタガタ鳴っています。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザーザー降りの中を養生館という昔からある旅館へ行って、そこでお昼をたべて、寿江子が稽古に行って、かえって六時の汽車で戻りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
