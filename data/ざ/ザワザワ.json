[
  {
    "uuid": "82bd0254-12b8-58f1-9e83-1c9be9595a57",
    "entry": "ざわざわ",
    "reading": {
      "primary": "ざわざわ",
      "alternatives": [
        "ザワザワ"
      ],
      "is_heteronym": false
    },
    "grammar": {
