        "examples": {
          "standard": [
            {
              "text": "彼は長期休暇を利用して、故郷に在居している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は不審人物の在居を確認するため、聞き込み調査を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の間は別荘に在居し、涼しい場所で過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」七「うむ、それでは神崎、現在居る、ここは一体どこだと思うか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この遊女の姿態ばかりは現在居る一番の錦絵描きでも描けないので、私の家の芸の中でも一番むずかしい秘密の伝授になっているものを……あの奥さんは不思議な人だ」　と云って舌を捲かれたという事で、今でも博多の人の噂に残っているそうで御座います。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、とど心靈は諦めの境地に達し、生前の好意を感謝したり、現在居る世界の樣子をぼつぼつと語り出す。",
              "citation": {
                "source": "心靈研究會の怪",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
