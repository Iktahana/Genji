        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このハンバーグは、牛肉の雑肉をうまく配合してジューシーな食感に仕上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精肉店で安く売られていた雑肉を買い込み、今夜は自宅で餃子を手作りする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カレーに使うなら、高級な部位よりも雑肉の方が適度な脂身があって美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "meat other than beef, pork or poultry (e.g. horse meat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
