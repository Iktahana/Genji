        "examples": {
          "standard": [
            {
              "text": "森の落ち葉をどかすと、長い脚を器用に動かして逃げていく座頭虫を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "座頭虫はクモの仲間だが、糸を出して網を張ることはなく、地表を歩き回って餌を探す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その独特なフォルムから、海外では「あしながおじさん」という愛称で親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鼠が毎晩｜座頭虫の身だけをくって足をそこらへちらけておく。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭虫はくわれてもくわれても別の奴が相変らず長い脚をもてあましてよいよいみたいに歩き廻る。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
