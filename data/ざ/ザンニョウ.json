        "examples": {
          "standard": [
            {
              "text": "検査の結果、膀胱にかなりの量の残尿が確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高齢の父が、最近は残尿による尿漏れに悩んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前立腺肥大症の影響で、排尿後も残尿が残りやすくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さっぱりと快い気分になってあるだけの重い残尿を放出して、あなたの処からかるがると出てゆこうとしている。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "残尿が描く尿意のはたらきは残酷に私をあやつり、殆ど何分も経たないあいだに同じ所作を反芻しなければならなかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前カラ予ニハ前立腺（青年時代花柳病ヲ患ッタ頃ニハ摂護腺ト呼ンダモノダガ）肥大症ガアリ、トキ／″＼残尿ガ溜ッタリ、尿ガ出ナクナッテカテーテルデ導尿シタリシタコトガ二三回アル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前立腺肥大及び残尿のための細菌感染が見られ、前立腺のマッサージと抗生物質の投与で様子を見るようにと云われる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
