        "examples": {
          "standard": [
            {
              "text": "この地域は、商業施設と住宅が混在する雑居地として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "開発が進むにつれて、昔ながらの雑居地も姿を変えつつある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雑居地ならではの活気ある雰囲気が、この町の魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日鮮雑居地で、かなり多くの鮮人とわずか四十家族ばかりの日人とが住んでいた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの今日のわれわれの口語というものが発生以来なお日が浅く、且つ発祥地たる東京が不幸にしてあらゆる方言の奇怪な雑居地帯であったため、謂わばまだ白湯がねれていず、散文という結構なお茶を立てるには適せぬだけの話かも知れぬ。",
              "citation": {
                "source": "飜訳遅疑の説",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
