        "examples": {
          "standard": [
            {
              "text": "由緒ある寺院の本堂で、姿勢を正して座拝を行い、心穏やかに先祖の供養をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は毎日仏壇の前で座拝を欠かさず、今日一日の平穏を祈るのが日課となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳かな空気の中、参拝客たちが一斉に座拝をする姿は、見ていて清々しいものがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上等の客種ならぬことは、一見たゞちにわかれど、いざはいり給へと、にはかに猫撫聲出すもをかしや。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠し立てさえしなけァいざこざはいわねえといってるんじゃねえか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
