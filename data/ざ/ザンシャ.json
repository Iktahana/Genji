    "definitions": [
      {
        "index": 1,
        "gloss": "leaving a car (e.g. at a parking lot overnight)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
