        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのパーティーには、多くの著名な財界人が出席していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は若いながらも、すでに将来を期待される財界人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "財界人の発言は、しばしば市場に大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今日の軍部に対しては言論機関も、云いたいことをいえないし、財界人も『これは困った事態だ』と思いながらも何もいい得ない。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて、死者に対するあらゆる敬意をはらいながらも、わしはかならずしもあの二人の財界人の知性の前には頭を下げません。",
              "citation": {
                "source": "共産主義者の犯罪",
                "author": "THE CRIME OF THE COMMUNIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "（笑聲）そのくせ欲望は財界人にも劣らない、一ぱし計數に長けたやうなことはみないふのです。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょろはしばしば日本の財界と財界人、経済組織などに非難をあびせ、嘲弄し軽侮した。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはだね、日本がまだ資本主義国ではなく、かろうじて自由経済にまでたどりつき、そこでうろうろしているにすぎない、ということを証拠だてているんだ」　日本には欧米流の財界人などはいない、みんなけちくさい商人、十円百円の利を奪いあう夜店あきんどに毛の生えたような連中だ、と春彦はきめつけた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
