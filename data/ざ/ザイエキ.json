        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の祖父は第二次世界大戦中、軍に在役していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "兵役義務のある国では、多くの若者が一定期間在役する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "在役中の兵士たちは、遠い国で故郷を思っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
