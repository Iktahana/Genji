        "examples": {
          "standard": [
            {
              "text": "新しいプロジェクトチームへの座入りが決まり、身が引き締まる思いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議が始まる前に、全員が席に着いて座入りを待っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は途中でその輪に座入りし、議論に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
