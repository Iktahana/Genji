        "examples": {
          "standard": [
            {
              "text": "彼の提案は、会議でボロクソにけなされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近の成績はボロクソで、このままでは進級が危ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この作品は評論家からボロクソに評価されたが、一部のファンには熱狂的に支持されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これは、内地で、早足行進に、どうしてもすねが伸びない初年兵が、教官にボロクソにこづきまわされて、古いお城の松の枝で頸を吊って死んだ、その晩にうなされたのと同じ現象だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見とくなはれ、ボロクソに焼けてしまいました。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "その返事はボロクソだったのだ。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟弱外交の賛成者としては、どうかね」「それは昔のことですよ」と砂馬が取りなすように、「今の猪沢さんは対支強硬論者だ」　黙って口をつぐんでいる猪沢に、客は追い討ちをかけるみたいに、「商売上からそうなったのか」「矢萩さんにかかると、ボロクソだね」と猪沢は笑った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚勢を張っているとも見られ、ボロクソにやられて笑っている猪沢のほうが一枚うわ手のようだった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくれて来た土屋・一木をボロクソにとっちめてやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
