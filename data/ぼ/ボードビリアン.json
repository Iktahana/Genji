          "standard": [
            {
              "text": "彼の軽妙なトークとダンスは、まさにボードビリアンの真骨頂だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の映画には、才能あふれるボードビリアンたちがたくさん出演していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボードビリアンの時代は過ぎ去ったが、その芸は今も多くの人々に語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「やあ、朝野さん」　それは「愉快な四人」という四人組のボードビリアンの一人の瓶口黒須兵衛であった。",
              "citation": {
                "source": "如何なる星の下に",
