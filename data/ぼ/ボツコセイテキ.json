        "examples": {
          "standard": [
            {
              "text": "彼の描く絵は、色彩豊かだが、どこか没個性的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "没個性的なデザインの家具は、部屋に温かみを与えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今の時代、没個性的な製品は消費者の関心を引きにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "寧ろこちらから云へば、都の人が没個性的であるのでもあるのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がこの個々の事象は、たといリッケルトの云うような文化価値への直接な関係づけが一応無意味であったにしても、そうだからと云って決して全く没個性的なものではない。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
