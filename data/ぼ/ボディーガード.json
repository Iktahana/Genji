        "examples": {
          "standard": [
            {
              "text": "有名な俳優は、常に数人のボディーガードに守られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "緊迫した状況で、ボディーガードが冷静に状況を判断し、指示を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "重要な人物の警護のために、プロのボディーガードが派遣された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "こんな小さいからだをしているが、じつは、わたしのボディーガードなんですよ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかたがボディーガードですか。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉村さんは、ボディーガードにかぎをわたしておくのはあたりまえだとおもい、べつにうたがいもせず、ポケットからかぎを出してわたしました。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんどたのんだ先生のボディーガードです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人目は白ジャケットのネアンデルタール人で、ヴァーナー医師お付きのボディーガードだ。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
