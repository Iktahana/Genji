        "examples": {
          "standard": [
            {
              "text": "彼は梵学を修め、インド哲学の専門家となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この大学では、梵学の研究が盛んに行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "梵学は、古代インドの言語や思想を深く探求する学問だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "グ伯は梵学者また神誌学者としてすこぶる大家だが、ややもすれば得意の言語学に僻して、何でも陰具に引き付け説く癖がある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
