      {
        "index": 2,
        "gloss": "sound of quiet walking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "静まり返った夜の廊下を、誰かがぼくぼくと歩く音が聞こえてきて、思わず身構えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は新雪の上をぼくぼくと踏みしめながら、山の頂上を目指して一歩ずつ進んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砂浜をぼくぼくと歩く足音が、寄せては返す波の音にかき消されていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
