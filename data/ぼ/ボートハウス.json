        "examples": {
          "standard": [
            {
              "text": "湖畔には、カヌーやボートを保管するための小さなボートハウスがいくつか並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末はボートハウスで友人とバーベキューを楽しみ、ゆったりとした時間を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風光明媚な川沿いに建てられたボートハウスは、観光客に人気のカフェになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鐘が淵紡績の煙突草後に聳え、右に白きは大学のボートハウスなるべし、端艇を乗り出す者二、三。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
