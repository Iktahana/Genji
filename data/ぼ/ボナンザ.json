        "examples": {
          "standard": [
            {
              "text": "19世紀のゴールドラッシュ時代、多くの採掘者が一攫千金を狙ってボナンザを夢見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新製品の大ヒットにより、その企業はかつてないほどの利益のボナンザに沸き立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この海域は魚影が濃く、釣り人にとってはまさに大漁のボナンザだと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "四人乗り単発のボナンザ機は、離陸後まもなく墜落した。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は東線会社が通信に使う封筒を一、二枚持っているから、くだんの電文を中に入れて、宛名を俺の登録名ボナンからボナンザに変える。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボナンザはメッセンジャー新聞社の登録電信宛名だ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "電信は弊社登録のボナンザ宛てに来ます。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告によれば元の電報あて先はボナンでありボナンザではないとのことです。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
