        "examples": {
          "standard": [
            {
              "text": "観光客を乗せたボートマンが、ゆっくりとゴンドラを漕いで運河を進む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "嵐の日、経験豊富なボートマンは、荒れる海でも冷静に船を操った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちは、川辺で魚を獲るボートマンの姿を興味津々で眺めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "よく「水ごころ」とか「ゲフュール」などと、ボートマンがその恍惚とした我を忘れるこころもちを呼んで楽しむのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のフォームが気にかかっているボートの選手を「岸が気にかかる」といってボートマンは嫌う。",
              "citation": {
                "source": "実践について",
                "author": "――馬になった話――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
