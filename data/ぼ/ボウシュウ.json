        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このTシャツは防臭効果が高く、スポーツウェアとして最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "クローゼットに防臭剤を置いたら、嫌な匂いが気にならなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新のトレーニングウェアは、強力な防臭性能を備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "見れば病舎の便所に備えつけた防臭剤のガラス瓶だ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この翁屋の主人は、紅葉さんなんかと友人で、文墨の交がある位で、ちょっと変った面白い人で、第三回の博覧会の時でしたかに、会場内の厠の下掃除を引受けて、御手前の防臭剤かなんかを撒かしていましたが、終には防臭剤を博覧会へ出かけちゃ、自分で撒いていたので可笑しかった。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "▽　ドーナツツに穴のある様に、もつと現実的にいつて、便所の防臭剤に穴のある様に、丸ビルの内側にも、通風と採光の穴があいてゐる。",
              "citation": {
                "source": "丸之内点景",
                "author": "‥‥東京の盛り場を巡る‥‥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
