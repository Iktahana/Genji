        "examples": {
          "standard": [
            {
              "text": "教会の牧師は、信徒への牧会を通して心の支えとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な状況にある人々に対し、丁寧な牧会が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "牧会は、精神的なケアだけでなく、日常生活の相談にも応じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "真似だと思えばこそ小倉地の詰襟なんかで、汗の放散を妨げてふうふうと苦しがらせたり、または寒くて乾燥した大陸でもないのに、あんな窮屈な靴を穿かせたり脱がせたり、泥ぼっかいの中をあるかせたり、手も洗わずに餅菓子を食べさせたりするのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
