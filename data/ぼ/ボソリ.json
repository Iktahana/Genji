    "definitions": [
      {
        "index": 1,
        "gloss": "in a subdued voice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は何か思いついたように、ぼそりと言葉を漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "周囲の喧騒の中で、彼女はぼそりと本音を語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議の終わりに、彼はぼそりと「異議なし」と言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」やはり半分は口の中で、ぼそりと言ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心配しないでもいい」　正勝は初めてそれだけをぼそりと言った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでお蚕に追はれとるうちゃァ何んと云ってもいいが……」宇平は心細さうにぼそりと云った。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラングボムの研究所にも行つて、加野君にも逢つてやりたいと思つてゐます……」　富岡はぼそりと、そんな事を云つて、さつさと先に応接間へ戻つて行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、古新聞の記事をぼそりぼそり読みあげる校長のヴァン・バンメル先生をさがしても無駄だった。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
