        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒いから、ちゃんとコートのボタンを掛けて出かけなさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が自分でシャツのボタンを掛けられるようになって、成長を感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この服はデザインが複雑で、ボタンを掛けるのが少し難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "見ないで後のボタンを掛けるのがむずかしく、出来ないで始めはよわりましたが、いつの間にか慣れて来ました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――よく町人の家で、窓かけや、家具のおおいに使われるような、大きな花もようのサラサでぬってあって、わきの下で、ボタンをかけるようになっている。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹物らしい筒袖の着物と羽織、袖からは、明治時代に流行した、手首のところでボタンをかける白いネルのシャツが覗いている。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
