        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨の日に和傘を差して歩く着物姿の女性は、とても風情がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "金沢の土産物屋で、美しい模様の和傘を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この和傘は、職人が一本一本手作りで仕上げた逸品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ヨシオはきれいな模様の和傘をさしていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨の雨が降る雑木林の丘を、夏子は良く似合う和傘をさして歩いた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "媼はわがさし伸ばす手に縋りて下りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがさし伸ばす手に、童の接吻せんとするを遮りつゝ、われ、無面目くも忘られしよとおもへるならん、忘れたるにはあらずとことわりつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "運が悪いと、ゆうべは夜ふけまで隣りの杵の音にさわがされ、今朝は暗いうちから向うの杵の音に又おどろかされると云うようなこともあるが、これも一年一度の歳の暮れだから仕方がないと覚悟していたらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文学精神が欧化したと云われる日本の純文学は一つのＮ・Ｒ・Ｆによってどれ程さわがされなければならなかったろう。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、わが新しき感激は拝日教徒の信の如し、わがさしのぶる諸手を受けよ、日よ、曙の女王よ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母をはふりて　家いでしよりわがさかり　さびしきことの多きにも　かくあらたまる御代の　はげしさわが母の新盆すぎて、かへり来し家に　すべなく　人とあひつゝ大きなる父の墓石に　並びたる母のみ墓の新しき、あはれはふりどに　我がふむ砂のくづれつゝ、秋澄みにけり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、わがさわぐ心を以て、その罪を水に向って被せている――それのみではない――「湖水の水が、かくもあわただしく騒ぐのは……つまり、湖岸が穏かでないからです」と、今度はその責めを岸へ向ってなすりつけにかかりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
