        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "実験台にこぼれた薬品は、放置せずにすぐ専用のワイプで拭き取って安全な場所に廃棄してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "カメラのレンズに付いた指紋を落とすため、鞄からアルコールを含ませたクリーニングワイプを取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "赤ちゃんの口周りの汚れをサッと拭くのに、この低刺激のウェットワイプが非常に重宝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
