        "examples": {
          "standard": [
            {
              "text": "デスク周りのケーブルがごちゃごちゃするのが嫌で、マウスもキーボードもすべてワイヤレスの製品に統一した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "最近のプリンターはワイヤレス接続が標準機能なので、スマホから直接写真を印刷できてとても便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ライブステージでギタリストがワイヤレスシステムを使っているため、コードを気にせず激しく動き回れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ワイヤレスマイクが咳も拡大するので、大変な音がするらしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
