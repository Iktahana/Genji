          "standard": [
            {
              "text": "「若い時は二度ない」のだから、今しかできないことを全力で楽しみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "卒業式の祝辞で、校長先生が「若い時は二度ない。一日一日を大切に」と話された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "悩んでいる時間ももったいないよ。若い時は二度ないんだから、前を向いて進もう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "宿の娘さん、親類の娘さん、若い行商人さん、近所の若衆さんが集つて、歌かるたをやつてゐる、すつかりお正月気分だ、フレーフレー青春、下世話でいへば若い時は二度ない、出来るだけ若さをエンヂヨイしたまへ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
