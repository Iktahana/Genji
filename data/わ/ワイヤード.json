        "examples": {
          "standard": [
            {
              "text": "セキュリティ上の理由から、社内のデスクトップパソコンはすべて無線接続を禁止し、ワイヤードのLANケーブルでネットワークに繋いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "音の遅延や接続の途切れを嫌うプロのゲーマーたちは、今でもマウスやキーボードはワイヤードのものを好んで使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ワイヤレスイヤホンが普及した現代でも、充電を気にせず使えるワイヤードのイヤホンの需要は依然として高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すべての機能を回路に作り付けてしまうワイヤードロジックに代え、シンプルなＣＰＵとプログラムの組み合わせで機能を組み立てるという発想をより徹底させれば、はじめから一つにまとまったマイクロコンピューターを使うというアイディアが当然浮上してきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラントの各所のデータを集めて表示、分析するシステムを、これまで横河電気はワイヤードロジックで作っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人界を遠く離れたこの世界の中でも、とくにワイヤード（weird）な景色である。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
