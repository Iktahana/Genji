        "examples": {
          "standard": [
            {
              "text": "ウェブサイトの制作プロセスにおいて、まずはデザインの骨組みとなるワイヤーフレームを作成してクライアントとレイアウトのすり合わせを行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "アプリの開発チームは、手書きのワイヤーフレームをホワイトボードに貼り出しながらUIの改善点について激しく議論を交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "グラフィックを適用する前のワイヤーフレームの状態で見ると、このキャラクターモデルがどれだけ精巧に作られているかがよく分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ほっそりとやせ、ワイヤーフレームの眼鏡をかけたゲイツは、青年というよりも少年といった方が似つかわしい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
