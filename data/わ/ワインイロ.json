        "examples": {
          "standard": [
            {
              "text": "彼女は、秋らしい深みのあるワイン色のドレスを着てパーティーに現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "部屋のカーテンを落ち着いたワイン色に変えたら、ぐっと大人っぽい雰囲気になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼の新しいネクタイは、上品な光沢のあるワイン色だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "「お茶」「ほんとかよ」　ワイン色のラッカー仕上げをしたシグのボトルを、彼女は、さし出してくれた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隅には番号の付いた仕切りのある箱が置かれ、そこには各下宿人のしみが付いたり、あるいはワイン色に染まったりしたナプキンを保管するようになっていた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
