        "examples": {
          "standard": [
            {
              "text": "週末は少し遠出して、山の麓にある歴史あるワイナリーの見学ツアーに参加する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "そのワイナリーでは、地元のブドウだけを使い、昔ながらの製法でこだわりのワインを醸造している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "試飲コーナーで気に入った白ワインを、ワイナリーの直売所で友人へのお土産として3本購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ハレアカラのスロープにあるテデシ・ワイナリーにとっての、最初の赤ワインだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイベルに描いてあるのは、そのワイナリーのテイスティング・ルームのある建物だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
