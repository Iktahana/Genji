        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この漢字の和音は「ワ」だが、一般的には漢音の「カ」と読むことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "歴史的仮名遣いを学ぶ中で、漢字の呉音、漢音、そして和音の違いを知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「和」という漢字を和音で読む例は、現代の日本語では限られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "Wu reading (of a kanji; as opposed to a Han reading)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仏教用語には、古い時代に伝わった和音（呉音）で読まれる漢字が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「行灯」の「アン」は、和音（呉音）に由来する読み方だと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "音読みの歴史を調べると、和音（呉音）が日本に与えた影響の大きさがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": []
        }
      }
