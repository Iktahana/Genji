    "definitions": [
      {
        "index": 1,
        "gloss": "chord",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ギターを始めたばかりで、まだ綺麗な和音を出すのが難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "この曲の切ない雰囲気は、巧みな和音の進行によって作り出されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "教会のパイプオルガンが奏でる荘厳な和音が、聖堂内に響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "完全和絃ばかりから構成されたものは音楽とはなり得ないように絵画でも幾多の不協和音や雑音に相当する要素がなければ深い面白味は生じ得ないではあるまいか。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、めんどうな積分的計算をわれわれの無意識の間に安々と仕上げて、音の成分を認識すると同時に、またそれを総合した和弦や不協和音を一つの全体として認識する。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一つの曲に修熟してその和音や旋律を記憶して後にそのレコードの音を専心に追跡しあるいは先導して行く場合にはかなりの程度までこの選択ができるように思われる。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあまりに美しい完全な和弦が連行すると単調になり退屈になるので適当な不協和音を適当に插入することによって、曲の変化と活気が生じる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし古人のすぐれた連句と思うのをよく解剖してみると、どうもこの不協和音のようなものが巧みに插入されているように思われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん定座には必ず同季の句が別に二句以上結合して三協和音のごとき一群をなすのであって、結局は春秋季題の插入位置を規定する、その代表者として花と月とが選ばれているとも言われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つの音が協和して一つの和弦を構成するということは、三つの音がそれぞれ互いに著しく異なる特徴をもっている、それをいっしょに相戦わせることによってそこに協和音のシンセシスが生ずる。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "各句にすでに旋律があり和音があり二句のそれらの中に含まれる心像相互間の対位法的関係がある。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方で和音「すまふ」はこれは相撲の音から転じたものであるに相違ない。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもよ、和音なんだから、コードネイムがあるだろう？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　長田は、じぶんのことばに合わせて、三つの和音を弾いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈イエス・アイ・ウィル〉だ」「おしまいの和音を教えてくださる？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロスビーと、グレース・スリックと、あとひとりはだれだっけ、ポール・カントナーだったかな」　tri- は三を示す接頭辞で、triad というのは、たとえば「三和音」のように、なんであれ、三つでひと組のものをいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダグラスの信用経済と新文学とを有機的にむすびつけようとする久野豊彦の不協和音にも一つの席が与えられる。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "各頂草圏樹枝、有乗騎者有徒‐行者、入王宮中以遊戯一唱百和音声凄‐惨、倏忽往来莫可踪跡。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代工業のおどろくべき進歩は、二十世紀に西洋音楽に深く影響して、オネガやストラヴィンスキーその他の音楽家たちが不協和音を摂取するようになったし、文学でも即物的な要素を加えられた。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不潔な燈火の下を飛び交ふこれらの新奇な鼻音と、交流する世界の諸潮流の海鳴りとが、私の頭蓋中で互の協和音を発見し合ひ、響かせ合つた。",
              "citation": {
                "source": "断片",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和音を弾くようにキーを組み合わせて押すことで、アルファベットが入力できるように装置は仕立てられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを通奏低音期と呼んだのは通奏低音（一名数字附低音）と云う略譜を見て即席に和音的伴奏をつける事が行われた時代だからで、この命名はリーマンに従ったものである。",
              "citation": {
                "source": "総説　西洋音楽史の時代",
                "author": "乙骨三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "リリューリやコラ・ブルーニョンのように、律動や音色や和音のまったく別な演技と結合とを要求する実質をもってる作品については、言うまでもないことである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人の中で和音をして顫動してゐるものは、先づ、生きんとする劇的な悦びであらう。",
              "citation": {
                "source": "Ombra di Venezia",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "百を以て数える枚数の彼女の作った切紙絵は、まったく彼女のゆたかな詩であり、生活記録であり、たのしい造型であり、色階和音であり、ユウモアであり、また微妙な愛憐の情の訴でもある。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百を以て数へる枚数の彼女の作つた切紙絵は、まつたく彼女のゆたかな詩であり、生活記録であり、たのしい造型であり、色階和音であり、ユウモアであり、また微妙な愛憐の情の訴でもある。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろの感覚がまざりあって、一つのハーモニー、和音を形づくるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの波が、光の世界、音の世界、言葉の世界にと、次から次へ響きあって、無限のハーモニー、和音をかなでているともいえるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと厳かな、すさまじい協和音であろう。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会で、聖歌隊の全員が鳴りひびくオルガンに合わせて、クリスマスの聖歌を歌い、その勝ち誇った調和音が大伽藍の隅々まで満たしてしまうのを聞くときほど、音楽が荘厳に人の道徳的感情に迫ってくるのを知らない。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人がそれを終るとすぐ、今度は若者が、老人の楽器の和音にも小鳥の歌にも似ない単調な音を、弾かずに出しはじめた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに時間的の変化は、緩急さまざまであって、リズム的な移り変りをすることもあろうし、モダン音楽のように、不協和音的な変化をする場合もあろう。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、もし何者か悪魔よりももつと怖ろしい、人智の想像を絶したものがあつて、それを仮に虚無と名づけるとすれば、それは正しくこの虚無の発する名状すべからざる不協和音であつた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "customary \"on\" reading (of a kanji) used in Japanese (as opposed to those derived from Chinese)",
