        "examples": {
          "standard": [
            {
              "text": "来年打ち上げられる新しい探査機は、火星の地下に液体の水が存在するかを調べる惑星探査を行う予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "惑星探査は、地球外生命の可能性を探る上で非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "我々は、人類がいつか太陽系外の惑星を探査できるようになることを夢見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "代表者となったボブ・スタインは、妻だったアリーン・スタインとボイジャー・プレスを作った人物で、ここから引き継いだ社名は、ＮＡＳＡの惑星探査機から取ったそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
