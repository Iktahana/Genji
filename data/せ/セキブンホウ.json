          "standard": [
            {
              "text": "積分法を用いて、複雑な曲面に囲まれた容器の容積を正確に算出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「積分法には置換積分や部分積分など、状況に応じた様々な解法があります」と参考書に書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史的に見れば、積分法は古代ギリシャの求積法にその起源を求めることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "算術的方法は代数的方法に、そして代数は微積分法にまで進歩したのだ。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
