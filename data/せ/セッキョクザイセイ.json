        "examples": {
          "standard": [
            {
              "text": "景気後退の兆しが見える中、専門家の間では積極財政による経済の下支えが必要だとの意見が強まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "積極財政を続ければ需要は喚起されるが、将来的な財政赤字の拡大を懸念する声も根強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「積極財政によってインフラ整備を加速させ、長期的な経済成長の基盤を築くべきだ」と政治家が訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば一方が国体明徴（尤も之はもっと他のファシスト層からの借りものだが）・積極財政（之も実は虎の威を借る狐だ）と行けば、他方は国防・財政・産業の三全主義と行くだけの差だ（一九三六年二月中旬の事情）。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本家政治家が健全財政とか内政重視とかいう退嬰政策を取れば、軍部は積極財政とか大陸政策とか南方政策とかいう積極方針に出ようとする。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
