          "standard": [
            {
              "text": "震災の記憶が精神的外傷となり、今でも大きな音を聞くと体が震えてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "専門のカウンセラーが、事件に巻き込まれた子供たちの精神的外傷を和らげるために尽力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "過去の精神的外傷が原因で、人間関係を築くことに極度の不安を感じる場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それを他の言葉で云うと、兇行によってうけた犯人の精神的外傷――つまり、その際に与えられた表象や観念の、感覚的情緒的経験の再現にあったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
