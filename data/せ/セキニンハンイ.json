        "examples": {
          "standard": [
            {
              "text": "各部署の責任範囲を明確にすることで、業務効率が向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の責任範囲は広く、複数のプロジェクトを同時に担当している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "契約書には、サービスの責任範囲が詳細に記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "本来君の責任範囲の仕事だよ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思う識者はいないのか、識者がいても自分の責任範囲外のときは言わないのか。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "各職の下には、下請があり、小頭があり、現場頭があって統率されていたが、要するに、それらの組々の名は、責任範囲の名称だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
