        "examples": {
          "standard": [
            {
              "text": "多くのSF小説では、全人類が一つの政府の下に統合された世界国家の姿が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際連盟の理念をさらに推し進めた究極の平和の形として、世界国家の樹立を夢見る思想家もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界国家が誕生すれば、国家間の紛争は消滅するかもしれないが、新たな統治の難しさも生じるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "火山学界はこれをほぼ予報し得たのであるが、その程度についての的中を欠き、ために世界国家の用意は十分ではなく、惨禍を前にして呆然自失の態たらく。",
              "citation": {
                "source": "予報省告示",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○先ずもってわれわれヨーロッパの世界は、この新しい神の国、ロシアという世界国家の中で崩壊しなければならず、然るのち初めて救われるのである。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界国家というようなこともいわれています。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに将来世界が一つになるような場合を想像してみても、それは個々の国家が国家でなくなり、その代りに世界国家が成立するということにほかならない。",
              "citation": {
                "source": "政治学入門",
                "author": "矢部貞治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
