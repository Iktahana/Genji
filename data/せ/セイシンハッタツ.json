        "examples": {
          "standard": [
            {
              "text": "乳幼児期の遊びは、身体だけでなく精神発達にも大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "思春期における特有の葛藤は、正常な精神発達の過程で避けては通れない道だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精神発達が遅れている可能性がある場合、早めに専門機関に相談することが推奨される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おそらく僕の精神発達のいまだ幼稚なるを証するのではあるまいかと、自ら疑うことが多いと告白したところが、かの文士は、それは君は心配するにおよばない、ドイツ人のうちにも、今日なおシラーを推して、思想においてははるかにゲーテに優るものなりと称嘆する者はけっして少なくない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンドルセエ氏の『人類精神発達史論梗概』〔Esquisse d'un Tableau Historique des Progre`s de l'Esprit Humain.〕 は、ついに彼を死にまで至らせた残酷な迫害の圧迫の下に書かれたものと云われている。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは全くそういう野心なしに、ただもうあの女に反抗の意識を呼び起こそうと努力し、彼女の精神発達を志したきりです……わたしにはただ反抗が必要だったんです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
