        "examples": {
          "standard": [
            {
              "text": "思春期には、性ホルモンの分泌が活発になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "性ホルモンは、体の様々な機能に影響を与える重要な物質だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は、ホルモンバランスの乱れが性ホルモンに関係している可能性を指摘した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その他ヴィタミンの研究（理研の鈴木梅太郎博士その他）や、性ホルモンの研究（東大の緒方章氏その他）が、漸次盛んになっている。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ上僕ハ精力ノ補給ヲスルタメニ相馬博士ニ相談シ、大体月ニ一回男性ホルモンノデポヲ用イテイルノダガ、ソレダケデハマダ不足ナ気ガシ、脳下垂体前葉ホルモンノ五百単位ヲ三日カ四日オキニ注射シテイル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "注射は阪大の皮膚科の意見に従って、女性ホルモン剤とヴィタミンＣ剤とを、櫛田医師の所へ行ってして貰うのであったが、そんなことと、週に二回悦子のピアノの稽古がある日に、あとでおさらいをしてやることとが、近頃の雪子の仕事であった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            }
          ]
        }
