        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "人々は、戦国乱世を生き抜くために必死だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦国乱世の世では、平和な暮らしは望むべくもなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ああ、あの戦国乱世はもうこりごりだよ。」と老人はしみじみと語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かういふ御両人であるから信長以前の戦国乱世では大人物どころか三流四流の小者であり、大馬鹿野郎の律義者で笑はれてもほめられることはない筈だが、天下の気風が変つてきたから、自然に諸侯の許す大人物となつた。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国乱世の風潮である。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国乱世には、皇居の塀や国宝の仏像で煖をとります。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう御両人であるから信長以前の戦国乱世では大人物どころか三流四流の小者であり、大馬鹿野郎の律義者で笑われてもほめられることはない筈だが、天下の気風が変ってきたから、自然に諸侯の許す大人物となった。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国乱世の習わしで、浮沈定めがたき運命に遭逢した徳川一家は四分五裂の窮境に陥ち、やっと十歳になったばかりの広忠は、時の東条城主吉良持広をたよって落ちのびてきた。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
