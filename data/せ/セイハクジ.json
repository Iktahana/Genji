          "standard": [
            {
              "text": "昭和初期の記録には、精薄児のための特殊学級が設立された旨が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「精薄児」という言葉が持つ偏見を払拭するため、名称の変更が議論された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母親は、精薄児と診断された我が子の将来を案じて夜も眠れない日々を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "書きつくせるだけを書き残して貧しい精薄児か死刑囚でも教育によって人の情か誠によって歌を得て、更生してゆく上に、役に立てられるようなものとなるようにと書いています。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "精薄児教育の方、家族に。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
