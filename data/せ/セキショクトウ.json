        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠くからサイレンの音と共に赤色灯の光が見え、パトカーが猛スピードで通り過ぎた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「救急車が近づいています。赤色灯が見えたら道を譲ってください」と放送が流れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工事現場の入り口で、注意を促すために赤色灯がくるくると回転している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いくぶん不安な気を起させるものといえば、この部屋の照明が、相当明るいには相違ないが、淡い赤色灯で照明されていることであった。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の様子は、前と同じで室内には例の赤色灯が点いていた。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤色灯のついているときは、安全なんです。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人たちは、赤色灯点る局舎のあちらこちらに、射斃され、非戦闘員である機械係りや、アナウンサーは、不抵抗を表明した。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をあげると、大きな赤色灯が生物のように激しい息をしていた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根の赤色灯を回転させ、サイレンを鳴らしていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
