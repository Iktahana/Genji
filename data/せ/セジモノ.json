        "examples": {
          "standard": [
            {
              "text": "彼は典型的な世辞者で、上司が何を発言しても「さすがです」と機嫌を取ることに余念がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周りから世辞者だと思われている彼だが、実は計算高い戦略家の一面も持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "王の周りには甘い言葉をささやく世辞者ばかりが集まり、真実を告げる忠臣はいなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "うなぎ屋は筋向うで、時々行ったこともあるし、またそこのかみさんがお世辞者だから、僕は遠慮しなかった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "理髪店の親爺が非常に饒舌なお世辞者であることも思つた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはお世辞者の娘は作らなかつた。",
              "citation": {
                "source": "愚かな父",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "（仕事座に就き鋸の目を立てる支度をする）政吉　　お前なかなかお世辞者だなあ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、へたな御機嫌取りの取持ちや、見え透いたお世辞者よりも、この大女にしてお酌と監視役とを兼ねた山出しが、時にとっての愛嬌となったためでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
