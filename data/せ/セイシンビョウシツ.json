        "examples": {
          "standard": [
            {
              "text": "彼は精神病質特有の冷徹さを持ち合わせ、自分の利益のためなら他人を犠牲にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精神病質は性格の問題ではなく、脳の構造的な特徴に起因するという説もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一見すると非常に魅力的で人当たりが良いのも、精神病質者の特徴の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ドストエフスキーは精神医学者ではなかったが精神病質者、てんかん患者、犯罪人、を巧みに記述した。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身が精神病質者であり、てんかん患者であった事実は彼の感覚を鋭くしたかも知れない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
