        "examples": {
          "standard": [
            {
              "text": "突然の性的衝動に駆られても、公共の場では理性的な行動が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "思春期には、性的衝動の扱いに戸惑うことも少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画の登場人物は、自身の強い性的衝動と戦いながら生きていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「性的衝動に基づく男女間の愛情。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちは道学者流に考えているのでもないし、性的経験に対して臆病であるとも思わないが、性的衝動を感じて、その解決をねがっても売笑婦のところへはどうしても行けない。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔った岸本が記憶しています限りでは、彼女は殆んど性的衝動を示さず、何等の積極的態度にも出ませんでした。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女自身にとつては全く性的衝動なしに為し遂げられたこの偶発事件は、彼女を肉体的にではなしに、精神的にのみ刺戟したかの様であつた。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
