    "definitions": [
      {
        "index": 1,
        "gloss": "person of lofty virtue and great wisdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
