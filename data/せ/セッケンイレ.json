        "examples": {
          "standard": [
            {
              "text": "お風呂場の石鹸入れが古くなったので、陶器製の新しいものに買い替えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅行に持ち運べるよう、蓋がしっかり閉まるプラスチックの石鹸入れを用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗面台の横に置かれた石鹸入れには、小さくなった石鹸が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その内におかみさんが石鹸入れを手拭に包んで、下のお子さんをつれてお湯から帰つて入らつした。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻君が奥から大きな西洋手拭と洋銀の石鹸入れを持つてきてくれた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも昼間は、広告画を始めとして、かれが蒐集したところの総ゆる婦人雑誌や活動写真の絵葉書、ことに忌わしげな桃色をした紙の種類、それからタオルや石鹸や石鹸入れなどが、みんな押入れのなかに収われてあった。",
              "citation": {
                "source": "幻影の都市",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
