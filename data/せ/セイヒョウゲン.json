        "examples": {
          "standard": [
            {
              "text": "個人のアイデンティティに基づいた性表現は、他者から尊重されるべき基本的な権利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職場においても、その人らしい性表現が認められる多様な環境作りが進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ファッションを通じた性表現の自由は、若者たちの間で新しい文化として定着している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
