        "examples": {
          "standard": [
            {
              "text": "主要な輸出先が経済危機に陥り、日本も世界的不況の煽りを受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界的不況の影響で、多くの製造業が大規模なリストラを余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若者の就職難が深刻化している背景には、長引く世界的不況がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "世界的不況時代にせめてロンドンでの鉄の贅沢だった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の宝沢はこの世界的不況にすっかり商売をしくじって、本店も支店も閉鎖して、無理な借金の中に苦闘しているとか伊東は聞いていた。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪は、世界的不況にあるのでもなく、「問屋の種切れ」にあるのでもない。",
              "citation": {
                "source": "純粋演劇の問題",
                "author": "――わが新劇壇に寄す――",
                "note": "青空文庫"
              }
            }
          ]
        }
