        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その広告は扇情的すぎると判断され、テレビ放送が禁止された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女のパフォーマンスは、観客を魅了する微妙に扇情的な質を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その小説の描写は、しばしば扇情的すぎると批判された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
