        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜は整髪料をたっぷりつけたまま寝てしまったので、髪がゴワゴワだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近は、頭皮に優しいオーガニック成分の整髪料が人気を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "整髪料の香りがきつすぎると、周囲の人に迷惑をかけてしまうこともある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "慶一は、この整髪料のにおいが嫌いだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷たい奴だな」「もう、明後日から期末だしね」　といって、頭に整髪料をふりかける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
