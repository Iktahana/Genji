        "examples": {
          "standard": [
            {
              "text": "子供たちは聖誕祭のプレゼントを楽しみにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "聖誕祭の夜は、家族で特別なディナーを楽しむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "街は聖誕祭の飾り付けで、華やかな雰囲気に包まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さる程に嬉しき聖誕祭は近づきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "船が一日遅れたのでマルセエユの聖誕祭を観ることの出来ないのを洋人の乗客は残念がつた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
