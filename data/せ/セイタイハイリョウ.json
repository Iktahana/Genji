        "examples": {
          "standard": [
            {
              "text": "キリスト教のミサでは、信者たちが聖体拝領によって神との一体感を深める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての聖体拝領は、彼女にとって非常に神聖な体験だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "聖体拝領の儀式は、キリスト教徒にとって信仰の中心的な行為である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これは主のテーブルと呼ばれ、カトリックでは聖体拝領と言っています。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最初の聖体拝領の時のような無関心さがまた戻ってきた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
