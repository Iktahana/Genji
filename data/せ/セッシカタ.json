        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新人社員の教育係を任されたが、彼との適切な接し方が分からず毎日頭を悩ませている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "接し方ひとつで、気難しい顧客との関係も劇的に改善することがあるから面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「子供への接し方に正解なんてないよ」というベテラン保育士の言葉に、肩の荷が下りた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "袴をはき付けぬ人が、袴をはいて袴腰を前にしたといふ笑話がある、袴の事は誰でも心得てゐて、誰でも当を得た接し方をするものであるが、さてその他の物に接すると、仲々さうは不可ぬもので、どうも帽子を逆さに冠つたり、袴を逆にはいたりするやうな過失に陥り勝ちなものである。",
              "citation": {
                "source": "些細なやうで重大な事",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子や袴の事は誰でも知つてゐて、そんな事をするものもないが、一段進んで見るとそれに似た事で色々の接し方がある。",
              "citation": {
                "source": "些細なやうで重大な事",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長のその気持が少しでもわかったら、自分がもっと真面目になるのはむろんのこと、下級生にだってもう少しは人間らしい接し方がありそうなものだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うのは、あの時の前後の事情や、あの家の樣子や、あの女の僕への接し方などから、あれが普通の商賣女――つまり、そういう事に馴れ切つている女では無かつたような氣がしたのです。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、姉は私達にとって神様のような、あの可哀想な父に向かって、間違った接し方をしています。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙のないように見える頼朝にも、相手の接し方に依っては、あれほど惜しんでいた名馬でも、つい与えてしまうぐらいな甘さもあった。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
