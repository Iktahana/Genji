        "examples": {
          "standard": [
            {
              "text": "石炭液化の技術は、石油代替エネルギーとしての活用が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大規模な石炭液化プラントの建設には、莫大な初期投資が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "研究所では、より効率的で環境負荷の低い石炭液化プロセスの開発が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "石炭液化も今日まで困難な路を歩んで来たが、そろそろ純日本式の簡単で優秀な世界無比の能率よい方式が成功しつつある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "……同じ論法で行けば、プロエスチの油田から一思ひに送油管をひくことも可能だし、またこの方が石炭液化なんかよりずつと手つとり早い。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭液化とか人絹工業のように。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
