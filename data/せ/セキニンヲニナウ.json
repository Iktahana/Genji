        "examples": {
          "standard": [
            {
              "text": "若くして大きなプロジェクトの責任を担うことになり、彼はプレッシャーで眠れない日々を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次世代の教育という、国の未来を左右する重大な責任を担っているという自覚を持つべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は一家の大黒柱として、三人の子供を育てる重い責任を一人で担ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "船客に対して最も重き責任を担うべき事務長にかかる不埒の挙動ありしは、事務長一個の失態のみならず、その汽船会社の体面にも影響する由々しき大事なり。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は従って、自己の思想を所有してその理論を構成することによって、常に、連帯者たる他の諸思想への歴史社会的責任を担う。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
