        "examples": {
          "standard": [
            {
              "text": "彼は出家を機に、世事一切との関わりを断ち切って修行の道に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「世事一切を忘れて、たまには温泉でゆっくりしたいよ」と父がこぼした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遺言書には、彼の死後、世事一切の処理を長年の友人に託すと記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "元々、世の外にいて、戦乱はもちろん世事一切にも関わらぬとしている者が、自分に生じた災難だけを、その世間の中で生きている者へむかって「助けてくれ」と、救いを乞うのも、虫のいい料簡だった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
