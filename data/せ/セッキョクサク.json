        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不況を脱却するため、政府は公共投資を大幅に増やす積極策を打ち出す方針を固めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「現状維持は衰退と同じだ。常に積極策を講じて、新たなビジネスモデルを模索すべきだ」と経営陣は主張した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "監督が試合終盤に攻撃的な選手を投入するという積極策に出たことで、チームは逆転勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "荊州方面への積極策は、一時見合わせとなって、ただ夏侯惇、満寵の二将が抑えに下った。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ、孔明なき後の三十年も、年々、進攻的な気概を外敵にしめし、「攻むるは守るなり」の積極策を持ちつづけて来た気力にはむしろ愕かれるものがある。",
              "citation": {
                "source": "三国志",
                "author": "篇外余録",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
