        "examples": {
          "standard": [
            {
              "text": "摂関政治の全盛期には、天皇は儀式的な存在となり、実質的な政治権力は藤原氏が握っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で、摂関政治がどのようにして武士の台頭を招いたのかについて議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "藤原氏による摂関政治は、外戚関係を利用して権力を維持する独自の支配体制であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "摂関政治、院政、武家政治時代、というものは、なべて選定相続だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "目企むところは、革命にはちがいないが、摂関政治への私怨であり、その改革であった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
