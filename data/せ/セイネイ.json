[
  {
    "uuid": "a9a7c63f-2fe3-5190-90de-e9842f923f4b",
    "entry": "静寧",
    "reading": {
      "primary": "せいねい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "peace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "騒がしい都会を離れ、湖畔の別荘で静寧な時間を過ごすのが私の理想だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦乱が終わり、ようやくこの国にも静寧な日々が戻ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "修道院の内部は、外の喧騒が嘘のように静寧な空気に包まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "＊幾度と無く繰返したる大智識の教話によりて、悲哀は分類結晶して、頗る静寧の姿を得たるも、なほ、をりふしは憤怒の激発に迅雷の轟然たるを聞く。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは玄妙の、静寧の「死」の大神が、わがまなこ、閉ぢ給ふ国、黄金の、浦安の妙なる封に。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "静寧な南欧の自然と、そこに伝はつた古芸術とが、ゲエテを救つて新生命を点じたやうに、それ程深く奈良や京都の自然と古芸術とが、氏を感化したとは思はれなかつたが、少くとも氏の鑑賞力を養つた事だけは明かだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒廃のいとも気高き眺めの中には、美しき昔のさまの影もあはれや、遊楽｜後を絶ちて唯だ変りなきその池水のみ、昔の秩序と静寧の中に息ひたるこそ嬉しけれ。",
              "citation": {
                "source": "霊廟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今その山の前面はこと／″＼く月の光をうけて、静寧の懐に横はり、殊更一ところ黝ずんでゐるのは、山頂から麓まで走つた馬の背のやうな崖とその凹所の谷を表はす襞である。",
              "citation": {
                "source": "修道院の月",
                "author": "三木露風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
