        "examples": {
          "standard": [
            {
              "text": "セントバーナードは、その穏やかな性格と賢さで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "巨大なセントバーナードが、子供たちに優しく撫でられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このセントバーナード、すごく大きいね！」「ええ、体重は80キロを超えることもあるそうですよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "滝本にとても深くなついてゐたセントバーナードの「ジヤツキ」が大きな花瓶の傍らに立つてゐた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界で一番巨大な犬は、セントバーナードとグレートデーンだといわれています。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "セントバーナードは見たことがありませんが、この牛犬はまず、グレートデーンをもう一回り大きくして、逞しくしたと思えば間違いありません。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
