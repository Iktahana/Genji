        "examples": {
          "standard": [
            {
              "text": "世界人権宣言は、全ての人が生まれながらにして持つ権利を明記している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界人権宣言の精神は、現代社会においても非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私たちは世界人権宣言に基づいて、差別撤廃を訴えるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "去年もおしつまった十二月四日から一週間日本でも世界人権宣言第二周年の記念週間がもたれた。",
              "citation": {
                "source": "世界は求めている、平和を！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しかし、「戦術的には従来の共産党諸氏のやりかたには、与し得ない」として、左右両翼の反作用の時を、袖手傍観しないで促進するためにもと、世界人権宣言に改めて深い関心をよせている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
