        "examples": {
          "standard": [
            {
              "text": "彼はまるで石油王のように、莫大な富を築き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中東には、多くの伝説的な石油王が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貧しい生まれだった彼が、一代で石油王になるとは誰も想像しなかっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "油が足りない７・29（夕）　石油王ロツクフエラアが、ある時自動車に乗つて出掛けようとすると、直ぐ側に何家の児とも知れない六歳ばかりの小娘が立つてゐて、この富豪の顔をしげしげと見てゐるのに気がついた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓語　米国の石油王ロツクフエラアは、滅多に公の宴会へ出ない。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人が石油王に対つて、「何故貴君はそんなに公の宴席をお嫌ひになるのです。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油王のウォルター・クレードルストンさんでしょう、一億ドル長者の。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "クライソリン薬の調合を、はした金で買い取った本当の目的は、クレードルストン石油王の眼をそらし、隣地で盗掘するためだった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "グライドが話したら石油王のクレードルストンはせせら笑った。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
