          "standard": [
            {
              "text": "植物には、様々な染色素（せんしきそ）が含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この天然染料は、植物由来の染色素（せんしきそ）から作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "染色素（せんしきそ）の抽出と分析は、化学の分野で行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "園は右手の食指に染みついているアニリン染色素をじっと見やった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、妻を解剖する可否を兄と論じながら、彼れが自信と興味とに心ををどらして、殘りもなく準備したミクロトーム、染色素、その外のものゝきちんと一つの机の上に列べてあるのが、積み重ねられた枯枝のやうに今の彼れには見えた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
