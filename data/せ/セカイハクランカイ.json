        "examples": {
          "standard": [
            {
              "text": "世界博覧会は、各国の文化や技術を紹介する国際的な平和の祭典だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次回の世界博覧会のテーマは「持続可能な開発目標と未来の知恵」に決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界博覧会の会場には、多種多様なパビリオンが立ち並び多くの人で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は生れつきのむつつりやで、何時だつたか大統領に在職当時、世界博覧会が米国に開かれたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、これらの説を発表してから二十年も過ぎて後ち、明治三十七年に、アメリカのセント・ルイ世界博覧会の万国学芸大会から比較法学の講演者として招待せられた時、同会の比較法学部において、我輩は比較法学の新研究法として法系別比較法を採用すべきことを提議した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "日東コーナーハウスで四時、大辻司郎と会ふ、大辻はアメリカの世界博覧会へ行くので、帰朝六月、うちでそのレポレヴィウをやりたいといふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
