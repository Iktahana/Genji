          "standard": [
            {
              "text": "投票日前に、候補者の政策を比較するために選挙公報を読み比べる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "選挙公報は、候補者が自身の主張を記載できる限られたスペースで作成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "選挙公報は、有権者が公平な情報に基づいて判断できるよう、広く配布されるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一般投票で五五〇万票、選挙人団投票では三五三票の差をスティーヴンスンにつけて、アイクは、ランドスライドをおこなった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
