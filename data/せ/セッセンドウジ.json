        "examples": {
          "standard": [
            {
              "text": "仏教説話に登場する雪山童子は、悟りを求める修行者の象徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雪山童子の物語は、苦行の末に真理を得る姿を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雪山童子は、厳しい修行を通して仏法を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "恋ひわびて死ぬる薬のゆかしきに雪の山には跡を消なまし　死を求める雪山童子が鬼に教えられた偈の文も得たい、それを唱えてこの川へ身を投げ、亡き人に逢おうと薫が思ったというのは、あまりに未練な求道者というべきである。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛本生傳に從へば、釋迦は、その前生に於いて雪山童子であつたとき、半偈を聽かむがために身を投げ、薩食を求めて自己の肉體に供養することを憚らなかつた。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
