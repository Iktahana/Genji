        "examples": {
          "standard": [
            {
              "text": "早朝の駅のホームでは、清掃員の方々が手際よくゴミを回収している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "清掃員として働いている彼は、街の美化に貢献していることに誇りを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オフィスビルの清掃員に挨拶をしたら、笑顔で返してくれて温かい気持ちになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "当時の常識では、競馬界の公爵に元々道徳が無いのは清掃員以上だった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
