          "standard": [
            {
              "text": "彼の生誕百年を記念して、特別展が開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "生誕百年を迎えた詩人の作品が、再び注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "町は、生誕百年祭の準備で賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "福沢諭吉生誕百年祭を祝うきょうび、日本の出版屋にとって涎の垂れる記録である。",
              "citation": {
                "source": "福沢諭吉",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　「福沢諭吉」　今日その生誕百年祭が祝われている「福沢諭吉」は、明治四年以後の福沢諭吉である。",
              "citation": {
                "source": "福沢諭吉",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年（一九二八年）はどういう廻り合せか、世界的な劇作家の生誕何年という数字が、しきりとかち合いまして、たとえばロシアのトルストイがイプセンとおない年の生誕百年、マクシム・ゴリキイが六十年記念、ドイツ劇壇ではシュテルンハイムとカイザアが、そろって生誕五十年を迎えます。",
              "citation": {
                "source": "イプセン百年祭講演",
                "author": "久保栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこの間、生誕百年祭が行われた坪内逍遙博士とは、翻訳についてしばしば話し合ったことを思い出す。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
