        "examples": {
          "standard": [
            {
              "text": "テレビのニュース番組では、著名な政治評論家が解説を行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は辛口の政治評論家として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治評論家の意見は世論形成に大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この抱琴が、骨を折ってくれた新聞社を、私は結局敬遠したが、そこは、政治色の強い社だったから、もしもそこへ行っていたら、銭形平次を書く代りに、政治評論家になっていたかも知れない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治評論家たちは、わたしのしていることを低俗なつまらないことだと、いくらでもくさすがよろしい。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治評論家といい軍事評論家といい、どんな間違いをしでかそうと平気の平左なことたるや占星術師並みだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
