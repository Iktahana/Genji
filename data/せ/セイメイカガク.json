        "examples": {
          "standard": [
            {
              "text": "生命科学の分野では、iPS細胞を用いた再生医療の研究が急速な進展を見せている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は生命科学を学ぶために渡米し、最先端の遺伝子工学のラボで博士号を取得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生命科学の知見を応用することで、アルツハイマー病の新たな治療薬の開発が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "早い話が、なるほど今日の科学は、電気や磁気といった物質科学の方面の研究は相当の域にまで進んではおりますが、生命科学の方面では如何でございましょうか、御承知のように、まだアメーバ一匹人工では作られてはおりません。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質科学にしたところで、実は生命科学や精神科学の方面が進歩しなければ、とうてい十分の説明のできる筈のものではございません。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カエルの脳髄を切りとって、それを他の動物にうつしうえることですか」　検事は、一世一代の生命科学の質問をこころみる。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
