        "examples": {
          "standard": [
            {
              "text": "帆船は赤道無風帯に入り、しばらく航行が困難になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤道無風帯では、気流が弱く、積乱雲が発生しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人生の赤道無風帯を抜け出し、新たな目標を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それでも面白かったねえ、ギルバート群島の中の何と云う島かしら小さいけれども白壁の教会もあった、その島の近くに僕は行ったねえ、行くたって仲々容易じゃないや、あすこらは赤道無風帯ってお前たちが云うんだろう。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、赤道無風帯のなかでいちばん湿熱がひどいという、いわゆる「｜熱霧の環」のなかにある。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、北東貿易風がいつとはなしに絶え、船は、聴くだに厭な赤道無風帯に入っていった。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつあどうも赤道無風帯みたいに退屈だな。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
