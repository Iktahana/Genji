          "standard": [
            {
              "text": "カナダの１９８２年憲法は、権利と自由の憲章を包含している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "１９８２年憲法制定は、カナダの国家としてのアイデンティティを確立する上で重要な出来事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その法律専門家は、１９８２年憲法の一条項について、新たな解釈を提唱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "とは云ふものの、千九百年代の初頭に此の作を示した戯曲家ブウエリエは、やはり、一個の先駆的芸術家であつたことは争へない。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
