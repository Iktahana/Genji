    "definitions": [
      {
        "index": 1,
        "gloss": "Kshatriya (member of India's military caste)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
