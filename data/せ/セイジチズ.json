        "examples": {
          "standard": [
            {
              "text": "近年の国境紛争により、この地域の政治地図はわずか数年のうちに大きく書き換えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勢力争いの変遷を理解するために、過去100年間のヨーロッパの政治地図を比較してみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しいエネルギー資源の発見は、世界の政治地図を塗り替えるほどの影響力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "試みに三百年前の政治地図と三百年後の政治地図とを採って比較せよ。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界万邦の思想は、相接引するの時となれり、東西南北の区劃は政治地図の上にこそ見れ、内部文明には斯かる地図なからんとす、この好時代に生れて、思想界に足を投ずるの栄を得たるもの、誰か徒為に旧思想を墨守し、狭隘なる国家主義を金城鉄壁と崇め、己れと己れの天地を蠖屈の窄きに甘んぜんとするものぞ。",
              "citation": {
                "source": "一種の攘夷思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            }
          ]
        }
