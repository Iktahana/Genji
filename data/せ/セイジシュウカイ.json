          "standard": [
            {
              "text": "広場で行われた大規模な政治集会には、現政権に不満を持つ数万人の市民が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "候補者は政治集会の壇上で、格差社会の是正と教育費の無償化を熱く訴えかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨の中での政治集会となったが、参加者の熱気は最後まで衰えることがなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "松本自身は政治集会やデモに直接参加することはなかったが、友人たちとの話題にはベトナムや成田や、何よりだめな日本のあり方が紛れ込んできた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
