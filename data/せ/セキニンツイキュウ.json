        "examples": {
          "standard": [
            {
              "text": "事故の原因究明と、関係者の責任追及が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不正が発覚した場合、徹底的な責任追及が行われるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "株主は、経営陣に対し、経営不振の責任追及を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "戦争責任追及の公判で、却って東條に人気が出たなどということは、ヨーロッパのどの国にもない例である。",
              "citation": {
                "source": "砂糖・健忘症",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち文化上の戦争責任追及もうやむやになったし、日本の保守傾向の存在できる幅のひろさも見えはじめたことから、頼んでいる人自身が尊敬もしていない、けれどなにしろ読む人がいるのだから、と書かせる。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞関係の戦争責任追及も彼等が心配したほど徹底的には行われなかった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
