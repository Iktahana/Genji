          "standard": [
            {
              "text": "日本は成文憲法を持つ国であり、憲法典が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "成文憲法は、国家の基本的な統治の仕組みを明確に定める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イギリスのように成文憲法を持たない国もあるが、多くは成文憲法を採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "國體の問題は成文憲法の基礎に横たはる問題であつて、憲法の條項に直接關係のある事柄ではなく、各人の判斷、各個の學説に委されて然るべきものであるが、こゝでは政府の説明の趣旨を紹介して、各人の自由な批判に委せようとするのである。",
              "citation": {
                "source": "新憲法の解説",
                "author": "解説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
