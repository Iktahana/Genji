          "standard": [
            {
              "text": "世界労連は、イデオロギーを超えた労働者の国際的な連帯を呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "発展途上国の労働組合を支援するため、世界労連が教育プログラムを実施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界労連の加盟組織として、ストライキへの支持を表明する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "世界労連の会議にも出席させられなかった。",
              "citation": {
                "source": "再武装するのはなにか",
                "author": "――ＭＲＡについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界労連の代表が日本へ来たことは、日本の教育の実状が側面から具体的に観察される機会となった。",
              "citation": {
