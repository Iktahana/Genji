        "examples": {
          "standard": [
            {
              "text": "軍部は、綿密な戦争計画を立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その戦争計画は、あまりにも大胆すぎると批判された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "敵国の戦争計画を傍受することに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "２　日露戦争に於ける日本の戦争計画は「モルトケ」戦略の直訳にて勝利は天運によりしもの多し。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和六年「満蒙問題解決のための戦争計画大綱」を起案している。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国の戦争計画は先ず第一に外交に重きを置き、戦役計画の立案も政治上の顧慮を重視して作戦目標および作戦路を決定し、その作戦実施を将軍に命令する。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は対米戦争計画の必要を唱えていたからであろう。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
