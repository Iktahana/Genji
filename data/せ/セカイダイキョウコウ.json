          "standard": [
            {
              "text": "世界大恐慌は、世界経済に深刻な影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経済学の授業で、世界大恐慌の原因と影響について詳しく学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界大恐慌の後、各国は経済政策を見直す必要に迫られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一九二九年の世界大恐慌から後一九三三年ナチス独裁が樹立するころ、ケーテの生活はどんなふうであったのだろう。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
