        "examples": {
          "standard": [
            {
              "text": "幽霊屋敷に入った瞬間、背筋が凍るような冷たい空気が漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然、背後から聞こえた足音に、思わず背筋が凍ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あのホラー映画のラストシーンは、観ているこちらの背筋も凍るほど恐ろしかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "背筋が凍るような電気的効果を発揮する写真機様兵器で武装した大規模な常備軍があり、その目的はほとんど語られることがなかったものの、黒く窓のない古い廃墟及び地下最下層の封鎖された大きな落し戸へのとどまることのない恐怖と明らかに結びついていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
