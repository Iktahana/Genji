          "standard": [
            {
              "text": "戦時内閣は、国家の存亡をかけた重要な決定を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その国は、危機的状況に対応するため、戦時内閣を組織した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "戦時内閣のメンバーには、軍事専門家も多く含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "戦時内閣の総理大臣も現れますが、東条でも近衛でもありません。",
              "citation": {
                "source": "作者附記〔「火」『群像』連載第一回〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中の人物は一切架空であり、戦時内閣の総理大臣は、東条でも近衛でもない。",
              "citation": {
