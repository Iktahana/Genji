        "examples": {
          "standard": [
            {
              "text": "北欧神話には、世界樹ユグドラシルが登場する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのゲームには、世界樹の伝説が深く関わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界樹は、天と地を結ぶ聖なる存在として多くの文化で語られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ケリーは此説話をば、「世界樹」の説話と名づけ、北欧日耳曼神話の「イグドラシル」樹等と比較して、樹木信仰の形跡を求めんと試みたり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　せかいじゅうのくにぐにから、旅行者が皇帝のみやこにやってきました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "せかいじゅうをちょっととびまわった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
