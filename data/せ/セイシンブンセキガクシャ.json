        "examples": {
          "standard": [
            {
              "text": "精神分析学者は、人間の行動の多くが本人の自覚できない無意識によって支配されていると説く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は著名な精神分析学者として、現代人の孤独に関する新著を出版した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国際会議には世界中から精神分析学者が集まり、新しい臨床手法について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "専門の心理学者ことに精神分析学者の目で連句の世界を見渡せばまだまだおもしろい問題や材料は数限りもなく得られるであろうと想像される。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、特に縊死を醜いとも思わぬが、縊死する瞬間に起こるであろう苦しい感じ、いわば生き埋めの時に起こるであろうところの恐ろしさ、かの精神分析学者のいわゆる、子宮内にとじこめられて居たときに得た恐怖その恐怖感の起こるのが、如何にも忍び得ないのだ。",
              "citation": {
                "source": "ある自殺者の手記",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "痴人に対して夢を説いても何にもならないが、精神分析学者の前で夢を説けば、自分にも解らない自分の真相を実に明白に開示してもらえるからである。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそういう精神分析学者の解釈を信用しないことはその人の自由である。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神分析学者は神のお告げを神様の方から生理心理的な個体の方へ移してしまって、リビドの表現ということにしてしまったのであるから、そういう学説をエセ学説として排斥しても、リビドが復讐するなどということはなかろう。",
              "citation": {
                "source": "夢",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また精神分析学者ジョオンスの実験談にこういうのがある。",
              "citation": {
                "source": "疑惑",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
