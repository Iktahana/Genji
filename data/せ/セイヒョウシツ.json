        "examples": {
          "standard": [
            {
              "text": "昔の大きな屋敷には、冬場に採取した氷を夏まで保存しておくための製氷室があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地下の製氷室に案内されると、外の暑さが嘘のようにひんやりとした空気に包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "製氷室の奥深くには、断熱のために敷き詰められた大量のおがくずが残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "冷蔵庫の中のように冷々とした製氷室であったにも拘わらず、玉の汗が、彼の青ざめたこめかみをツルツルと流れ落ちた。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智と、恒川氏と、文代と、倭文子母子の五人は、まんまと製氷室にとじこめられてしまった。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "製氷室にとじこめられた五人のものは、思わず顔を見合わせた。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が製氷室で、ほんの少し躊躇していたら、無事に逃げ出すことは出来なかったに相違ない。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
