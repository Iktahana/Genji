        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "運搬用の石炭袋が破れて、中の粉末が足元にバラバラとこぼれ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "炭屋の主人は、手際よく石炭をスコップですくい、石炭袋に詰め込んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重い石炭袋を背負って階段を上るのは、かなりの重労働だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
