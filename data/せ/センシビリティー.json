        "examples": {
          "standard": [
            {
              "text": "その詩は、読者の繊細なセンシビリティーに訴えかけ、深い感動を呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の突然の涙に、母親は母親ならではのセンシビリティーで優しく寄り添った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この作家は、人間の心理描写におけるセンシビリティーの高さで評価されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "或ものをよみ青鞜前期が、性的の、人間の持つ特殊な潔癖と云うようなものに対し、強いて、平気に、センシビリティーを失おうとした形跡のあるのを知った、あわれ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――処が私は不幸にしてあまりこうした浮気な同情や道徳やセンシビリティーを信用出来ないのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "同情や道徳やセンシビリティーが、婦人団体のように貞淑で浮気だからばかりではない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
