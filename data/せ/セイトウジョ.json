          "standard": [
            {
              "text": "地元の人々は、製糖所の煙突から立ち上る白い煙を見慣れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この製糖所は、最先端の技術を導入して効率的な砂糖生産を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観光客向けに、製糖所の見学ツアーが開催されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "家の裏手に小さな庭があって、夏の間みんなは、たいてい一日中そこですごすことになっていた――近所の製糖所から、ほとんどたえ間なく、甘たるい匂いが流れて来たのだけれども。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            }
          ]
