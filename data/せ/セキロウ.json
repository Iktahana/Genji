[
  {
    "uuid": "fce3c57a-43bf-5cc6-a204-0e991349918e",
    "entry": "石蝋",
    "reading": {
      "primary": "せきろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "paraffin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "石蝋でコーティングされた紙袋は、水濡れに強く、生鮮食品の持ち運びに適している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "実験室でスライドガラスに固定した組織片を、石蝋の中に浸してパラフィンブロックを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このジャムの瓶、蓋を石蝋で密封しておけば長持ちするわよ」と祖母が知恵を授けてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――石蝋に彫り浮かべたような白い指だった。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある石蝋の会社にも雇われた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は　常春藤の籠にもり或時は　石蝋の壺に納め心　はるばると、祈りを捧げる　神よ、四時の　ささやかな人間の寄進を　納め給え、と。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石蝋の製造職工ともなったし、針商ともなったしそれから横浜へ行きました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
