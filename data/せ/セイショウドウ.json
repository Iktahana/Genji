        "examples": {
          "standard": [
            {
              "text": "「思春期になると、湧き上がる性衝動にどう向き合うべきか悩むことも多い。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「性衝動を抑えることができず、彼は衝動的な行動に走ってしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「生物としての本能である性衝動は、適切にコントロールされなければならない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――人生は生産機構から解明される代りに、性衝動から説明されたり、人間性の展開とされたり、身辺心理の短篇集になったりする。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、精神分析の理論に従えば、一般に文化は、衝動――広義に於ける性衝動・又は権力への意志――を終局の原因とする。",
              "citation": {
                "source": "イデオロギー概論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "性衝動もまた刺激される。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "効果としてはむしろ逆で、性衝動は押えられる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
