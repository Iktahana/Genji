        "examples": {
          "standard": [
            {
              "text": "現代社会における性風俗のあり方について、様々な議論が交わされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "性風俗は社会の多様な側面を映し出す鏡のようなものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "都市部では、性風俗に関わる文化やビジネスが独自の発展を遂げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "風俗にぞくする規定の代表的なものは、前にも云ったように社会に於ける性関係だが、事実はこの性風俗が最も端的な通常道徳の内容をなしていることを、注目しなければならぬ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "風俗壊乱という一種の反社会的現象は、主に性風俗の破壊を指すことは云うまでもないので、これが社会風教上の大問題だと政治的道学者や風紀警察当局は考える。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "性風俗が可なりに衣服服飾と密接な関係のあるのは興味ある点だ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて風俗の最も著しい内容は性風俗だが、そこから恋愛論というモラル問題に行く道も開けると思う。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
