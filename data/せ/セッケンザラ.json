          "standard": [
            {
              "text": "ホテルのアメニティとして、小さな石鹸が上品な石鹸皿に載せられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水が溜まらないように、傾斜がついたタイプの石鹸皿を使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "割れにくい素材の石鹸皿を探していたら、シリコン製のものを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　セエラは夢の中の人のように、幸福そうな微笑をたたえながら、石鹸皿を雪花石膏の水盤に見たてて、薔薇の花を盛りました。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
