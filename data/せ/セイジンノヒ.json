        "examples": {
          "standard": [
            {
              "text": "成人の日になると、街の至る所で華やかな着物姿の新成人を見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "1月の第2月曜日は成人の日で、多くの自治体で式典が開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「成人の日おめでとう！今日から大人の仲間入りだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その孫が大八島しらす天皇、現御神たる成人の日を夢みてゐた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その孫が大八島しらす天皇、現御神たる成人の日を夢みていた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、はるばる東国下総から来たことだの、これから大叔父の添え書を持って、藤原忠平公のお館をたずね、成人の日まで留まって、学問修養に専念し、一かどになって帰国するつもりであるなどと、遠い未来夢までを話し話し、道づれになって、いつか、京都の街なかを歩いていた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、鞍馬寺にある亡主義朝の遺子牛若を、よそながら護り、よそながら教育し、やがての事は、その牛若の成人の日として待っているのである。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、不知哉丸の身は、そこの生家において、ひそかに養育するつもりとみゆる」「そこなれば、もう、御成人の日までも、安心なもの。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
