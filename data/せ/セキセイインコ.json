        "examples": {
          "standard": [
            {
              "text": "友達の家で飼っている背黄青鸚哥は、とてもよく人間の言葉を真似する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鮮やかな緑色の背黄青鸚哥が、籠の中で元気いっぱいにさえずっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ペットショップには、様々な色の背黄青鸚哥が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最初せきせいいんこがはやり出しそれが下火になると兎が、それから食用蛙がはやつた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り口にぶらさげてあった金網のかごの中に、せきせいいんこが飼ってあって、急にそうぞうしくなったので、鳥はびっくりしたのか、目をまるくしながら、甲高な声でキイー、キイーといって、奥の方へ取り次ぎをするごとく鳴きつづけました。",
              "citation": {
                "source": "僕はこれからだ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
