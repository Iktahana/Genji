        "examples": {
          "standard": [
            {
              "text": "精神分裂病という呼称が差別を助長するという声を受け、学会が名称変更を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は若くして精神分裂病を発症し、長年の闘病生活を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精神分裂病のメカニズム解明のため、世界中で遺伝子レベルの研究が進められてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "継母の精神分裂病に何処か似通うた戦争の被害だと、直吉はいまこそはつきりと思ひ知らされたのだ。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "発熱や疼痛を伴う疾患にも何の苦悩をも示さない」　精神分裂病者の病棟を描写した後に、中山はこのような説明をつけていた。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナショナリストのいくたりかは精神分裂病から然程遠くない所にいる。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「精神分裂病」は現在では「統合失調症」と呼ばれています。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは精神分裂病の傾向ですね。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
