          "standard": [
            {
              "text": "革命後の混乱期において、反革命勢力を根絶やしにするための赤色テロが吹き荒れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「歴史の教科書で読んだ赤色テロの凄惨さは、想像を絶するものだ」と学生が感想を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "独裁体制を維持するために行われた赤色テロにより、多くの知識人が犠牲となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上海に於けるガロン、チルキンス、陳独秀等の赤色テロリズムの敢行によって二十世紀の支那の赤い花が散り落ちた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤色テロルを生んだのは白色テロルにほかならないのだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
