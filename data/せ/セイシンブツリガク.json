        "examples": {
          "standard": [
            {
              "text": "精神物理学は、物理的な刺激の強さと心理的な感覚の関係を定量的に扱う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フェヒナーの法則は精神物理学における基礎的な理論として有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "音響機器の開発において、精神物理学のデータは音質の微調整に欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも今から百年二百年後の精神物理学者が今の私のような立場でこの巻を読めばあるいは、この巻において最も興味ある発見に出会うかもわからないという事は想像し得られる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神物理学的乃至心理学的な概念としての個人の意識は、物理学的物質の極めて高次の質的飛躍として之を理解する外はない。",
              "citation": {
                "source": "辞典",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
