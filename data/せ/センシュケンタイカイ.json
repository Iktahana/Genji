        "examples": {
          "standard": [
            {
              "text": "今年の全国選手権大会は、来週から大阪で開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "フィギュアスケートの選手権大会には、多くの若手選手が出場するだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの若いアスリートが、選手権大会への出場を夢見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ヴィクトル・アリ氏は来月中旬の鳩撃ち選手権大会に出場のため滞在しているのだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "全米水上選手権大会へ、これらの日本の若い精鋭が出場するようになったことは全日本の明るい関心をあつめている。",
              "citation": {
                "source": "ボン・ボヤージ！",
                "author": "――渡米水泳選手におくる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、体育派とスポーツ派　問題は四月九日から上海で開かれた日支比三国の第十回極東選手権大会円卓会議に始まる。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
