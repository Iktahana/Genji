        "examples": {
          "standard": [
            {
              "text": "整理ダンスの引き出しが重くて開かないので、シリコンスプレーを吹きかけて滑りを良くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "模様替えのために整理ダンスを動かしたら、裏側にホコリがびっしり溜まっていて驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「その整理ダンスの一番下に予備のシーツが入っているよ」と母が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "窓と向かい合ってローズ材の古びた整理ダンスがあった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それはあそこだ、私の整理ダンスの上だ』そして彼はハンカチで覆っていた宝石箱を私に見せたの。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
