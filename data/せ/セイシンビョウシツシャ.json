          "standard": [
            {
              "text": "凶悪事件の犯人が精神病質者であると鑑定され、裁判の行方に注目が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精神病質者は、他人の痛みに対して共感することが極めて困難だとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "フィクションの世界では、知的な精神病質者がしばしば魅力的な悪役として描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ドストエフスキーは精神医学者ではなかったが精神病質者、てんかん患者、犯罪人、を巧みに記述した。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身が精神病質者であり、てんかん患者であった事実は彼の感覚を鋭くしたかも知れない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
