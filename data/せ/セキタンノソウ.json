          "standard": [
            {
              "text": "崖の断面を観察すると、何層もの土砂の間に薄い石炭の層が挟まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太古の森林が地中に埋もれ、長い年月を経て石炭の層へと変化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉱夫たちは暗い坑道の中で、わずかな石炭の層を頼りに掘り進めていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが磐城の国の川の上流には、石炭の層が幾重にも断続していて、そこから流れ出る炭粉のために、鮎は香味の気品を備えぬのである。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
