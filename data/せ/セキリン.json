        "examples": {
          "standard": [
            {
              "text": "マッチの箱の横にある茶色い部分は、赤リンを主成分とする摩擦剤が塗られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "白リンと違って赤リンは毒性が低く安定しているため、工業的に幅広く利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「理科の実験で赤リンを加熱する時は、絶対に直接触らないように！」と先生が注意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
