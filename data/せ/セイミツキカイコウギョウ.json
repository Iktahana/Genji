          "standard": [
            {
              "text": "高度経済成長期を経て、日本の産業構造は軽工業から精密機械工業へとシフトしていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精密機械工業の発展には、熟練した技術者の育成と最新の設備投資が不可欠である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その都市は精密機械工業を中心とした企業城下町として、長年地域経済を支えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日台紡績の社長で、東洋綿業の社長で、中込精密機械工業の社長として日本中に鳴り響いている財界屈指の富豪だということは、こんな山の中の刑事の頭にまでも、沁み込んでいる。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
