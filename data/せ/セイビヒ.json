        "examples": {
          "standard": [
            {
              "text": "新しい道路の建設には莫大な整備費がかかる見込みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "学校施設の老朽化に伴い、耐震補強の整備費が緊急の課題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の遊具の入れ替えには、多額の整備費が計上された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば港湾であるが、漁港の整備費に二十三億円を使っているが、手がけている漁港の数は、何と七十七港に及ぶというのである。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
