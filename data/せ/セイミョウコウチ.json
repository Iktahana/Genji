          "standard": [
            {
              "text": "アンティークの時計内部には、精妙巧緻な仕掛けが施されており、見る者を圧倒する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この工芸品に見られる精妙巧緻な透かし彫りは、熟練の職人にしかできない神業だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最先端のマイクロマシンは、精妙巧緻な構造を持ちながら自動で体内の患部へ移動する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ツイ此頃の新着だから、尚だ尽く目を通していなかったが、デュポン・トーベルヴ等、其製版摺刷の精妙巧緻は今猶お眼底に残って忘れられない。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
