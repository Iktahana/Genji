        "examples": {
          "standard": [
            {
              "text": "小学生の頃、社会科見学で町外れにある石鹸工場へ行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "石鹸工場から漂ってくる独特の清潔な香りが、この通りの特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父はこの石鹸工場で40年以上、職人として働き続けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この町のずッと奥の方に、近ごろ出来た石鹸工場の職工らしい酔漢が、呂律の怪しい咽喉で、唄を謳って通った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、父は先ず、曳舟通りなんぞにある護謨会社や石鹸工場のなかへ私を連れてはいり、しばらく用談をしている間、私を事務所の入口に一人で待たせておいた。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
