        "examples": {
          "standard": [
            {
              "text": "スポーツウェアの製品ラインを拡充し、プロからアマチュアまで幅広い層をターゲットにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "売れ行きが芳しくない旧来の製品ラインを廃止し、リソースを新分野へ集中させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "各製品ラインの売上動向を月次でチェックし、在庫調整の判断材料にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＴＲＯＮチップのＧ　ＭＩＣＲＯ１００、２００、３００をそれぞれ搭載した複数の製品ラインが用意されるとのことで、低価格攻勢をかけるサンのマシン並のお値段となるだろうと、オレの責任において勝手に予測しておく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターからメインフレームまで、全製品ラインの統合を目指したエイカーズのもとで、ＩＢＭはＰＣ／ＡＴを切り捨て、ＰＳ／２への移行を目指した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
