        "examples": {
          "standard": [
            {
              "text": "その問題については、彼がこの分野の精通者なので尋ねてみるのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は茶道の精通者として、多くの弟子を指導している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この複雑なシステムを理解するには、精通者の助けが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それで我々は次のようなことを歌ったかの偉大なる自然と人間の精通者ゲーテとともに、未来は更に一層より善くなるばかりであろうという堅い希望を抱いても差支えはないであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "○彼の情熱的意力におけるわれわれの意志喪失　p.234○ドストイェフスキーよりもシェイクスピアは人間の精通者である。",
              "citation": {
                "source": "ツワイク「三人の巨匠」",
                "author": "――ドストイェフスキーの部（偉大な統一の破壊者、永遠の分裂者としての）――",
                "note": "青空文庫"
              }
            }
          ]
