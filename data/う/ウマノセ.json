        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "振り上げられた銃が馬の背に力いっぱいに落ちて行った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴は馬の背から取りはずされていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までポケットで休んでいた鈴は、さわやかに、馬の背でリンリン鳴った。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者たちは、それぞれ馬の背に乗ってやって来る。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食料品はもとよりすべての物資は東｜倶知安から馬の背で運んで来ねばならぬ交通不便のところでした。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおおお、竜の口の清水より、馬の背の酒は格別じゃ、甘露甘露。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが馬を降りれない、もう将軍の両足は、しつかり馬の鞍につき、鞍はこんどは、がつしりと馬の背中にくつついて、もうどうしてもはなれない。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の背のやうに乘上つた俥の上の目の前に、角柱の大門に、銅板の額を打つて、若葉町旭の廓と鑄てかゝげた、寂然とした、明るい場所を見たからである。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の背に立つ巌、狭く鋭く、踵から、爪先から、ずかり中窪に削った断崖の、見下ろす麓の白浪に、揺落さるる思がある。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿の背骨が千年持つならば、馬の背骨は五百年持つ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとからヒョロ子が豚吉を背負って馬の背中に這い上りますと、無茶先生が手綱を取って、「ハイヨーッ」　と云うと、広い往来を一目散に逃げ出した。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由之さんも馬の背にゆられて、国上山をおりながら思つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私の身体は足を空に、（馬の背に裳を掻緊む）倒に落ちて落ちて、波に沈んでいるのでしょうか。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　千仭の崕を累ねた、漆のような波の間を、幽に蒼い灯に照らされて、白馬の背に手綱したは、この度迎え取るおもいものなんです。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのを、馬の背中に狐が乗ってるみたいと言うのではなかろうか。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の背たけよりも高い蕗の林もありました。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "馭者は心得ているので、どこからか荒むしろのようなものを貰って来て、馬の背中に着せてやる。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺は伐仆した木を薪にして、隔日の午前に、白毛の盲目馬の背につけては、麓の町に賣りにゆく。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミランダは馬の背に乱舞しつつ火の輪を潜る。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七章　　　　　　　１　砂煙を蹴上げながら、毬のように駆け飛んで吾助茶屋の前まで来ると、正勝は馬の背にしがみつくようにしながらぐっと手綱を引いた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん凹地に降りて馬の背後に回ってマッチを擦る。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "真先に黄色い旗を捧げた道案内者が、二人か三人馬に乗って行くと、その後から二三匹｜宛、馬の背中に結び付けられた猿が合計二三十匹、乃至、四五十匹ぐらい行くのです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "店先に込合っている大勢の弥次馬の背後へ廻って、トねらいをつけて、天窓ともいわず、肩ともいわず、羽織ともいわず、ざぶり、滝の水。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気は馬の背以上にも立って、人も馬も湯気にぼかされてほとんどそのまま昼のようだ。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩方が溪谷で一條の林道は馬の背を行く樣なものだ。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝馬の背には、白い砂山の続きの間から、松と屋根とが延び上がってのぞいていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の村から三哩、馬の背で踏み入る山奥の材木工場で、フロラと私はその年のクリスマスを迎へようとしてゐた。",
              "citation": {
                "source": "寄生木と縄梯子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏ならば村里の家々にランプが点り、そのまはりに集つた蛾や甲虫類の数々を、わたしは思はず軒下から覗き込んで、あちこちで迂散な奴と怪まれたりしながら、冬ならば馬の背で琴座の星をかぞえながら――だから長くとも短かくとも日はもうとつぷりと暮れた刻限に、森蔭の水車小屋に到着した。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い馬を酒場の窓際にたゝせてをいてから酒の瓶をもちだしてちびりちびりと飲みだした馬を窓際につないでをいたのは、もし街の兵隊が捕まへにきたなら、ひらりと得意の馬術で窓から馬の背にとびのつて雲を霞と逃げ失せるつもりであつたのです。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はワーナー調査団について大西洋まで行くには行ったが、そのまま引返して来たんだからね、或る婦人の策謀にうまうまのせられて……」「まあ、ドレゴさん」「要するに、僕はケノフスキーを満足させるほどの物を持っていないのだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
