    "definitions": [
      {
        "index": 1,
        "gloss": "Bon festival (Buddhist ceremony held around July 15)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
