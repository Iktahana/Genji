        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのうちに七月が来て、盂蘭盆会の前夜となったので、※の家では燈籠をかけて紙銭を供えた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌十三日は盂蘭盆会で、親戚のものが墓参に来る日である。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の盂蘭盆会には毎歳大燈籠を貼らせ、榛軒が自ら達磨を画いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、この盂蘭盆会に水辺の家々にともされた切角灯籠の火が樒のにおいにみちたたそがれの川へ静かな影を落すのを見た人々はたやすくこの自分のことばに首肯することができるだろうと思う。",
              "citation": {
                "source": "松江印象記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "観世音四萬三千日、草市、盂蘭盆会も瞬間に過ぎ土用の丑の日にも近くなった。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五度行うた精霊会が、南北朝の頃には、社会的の勢力を失うて、唯一回の盂蘭盆会に帰趨した痕を示したのであるが、七月の盂蘭盆と十二月の魂祭りとは、必古の大祓への遺風であると信じる。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "念仏者の行ふすべての行儀・芸能を籠めて、念仏と称へ、盂蘭盆会から初つて、初春の祝言にまで、用ゐられる様になつたのを、多少、劇的の進行を備へたものであつた。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時期は、仏家でも、盂蘭盆会を修する時である。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此水神祭りは、元々、夏祓へと同じものであつて、村や家に迎へる方は、盂蘭盆会に任せて了うて、水神迎へと禊ぎとの痕跡だけを、七夕の乞巧奠に止めた。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "盂蘭盆会も、仏法種よりも、寧、古代信仰が多く残つてゐる様だ。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水月寺の尼僧達が盂蘭盆会を行ったので、その日はそれに参詣する女が四方から集まって来た。",
              "citation": {
                "source": "封三娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、“薬王寺案内”といふ小冊子をみると、この外に、二月の涅槃会、三月は正御影供、四月は釈尊花祭、五月は大般若会、六月は弘法大師降誕会、七月は盂蘭盆会、といつた工合に、毎月、欠さず何かしら、催しものをする運びをつけてゐる。",
              "citation": {
                "source": "にはかへんろ記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新盆　盂蘭盆会　近づきにけり―。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭礼では祇園祭・盂蘭盆会・端午の節句、仏教では時宗・真言宗・一向宗・日蓮宗など。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "また丁度その頃に盂蘭盆会の廃棄を考えていた彼は、大村の先代の像（位牌か）の前に香をたく代りに、その像を焼却するということをやったらしい。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗麟受洗の前後にはこの態度はますます顕著になり、盂蘭盆会の禁止、八幡宮祭礼の無視などを敢行するに至ったのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "草深い山峡の部落では、盂蘭盆会は、若い男女が思いきり羽をのばす唯一の祭である。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "盂蘭盆会の名残りの提灯や、お供え物が、方々の墓に、いくつも残っている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "盂蘭盆会のための提灯なので、どれにも、戒名が書いてあり、紋章が入っている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "大牢の城門外にある獄神｜廟と地蔵寺では、例年｜盂蘭盆会の当夜、さかんなる燈籠流しの魂祭がおこなわれる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――のみか、いつのまにやら日はたそがれ、盂蘭盆会の熱鬧のちまたも遠く夕闇の楊柳原まで来てしまった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢営長官の愛児が、盂蘭盆会の夜、地蔵寺の池で溺れ死んだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の盂蘭盆会をすぎるとすぐ聞えてきた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
