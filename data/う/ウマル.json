    "definitions": [
      {
        "index": 1,
        "gloss": "to be buried",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "うしろを振りかえると、そそり立つ山――森林で埋まる山にふさがれて、川は、全く、両山迫れる間の、凹流になってしまう。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな柏の木は枝も埋まるくらい立派な透きとおった氷柱を下げて重そうに身体を曲げて居りました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所なんぞ入場料十圓也と觸れ出せば、紳士淑女は雜鬧し、雜誌は動物園の詩で埋まるに違ひない。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何しろ深い谷の底のことではあるし、堅雪にはなっていたが、上部の解けた所に踏みこむと胸まで埋まるくらい積もっているのだから、先生にはどうしていいか分らなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを三つも、やすんだら、もう頭まで埋まるんぢや。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな柏の木は枝も埋まるくらゐ立派な透きとほった氷柱を下げて重さうに身体を曲げて居りました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものさ、甘干の柿見たやうに、軒へぶら下げて売りましつけ、……水損、山抜け、御維新以来、城趾へ草が生へる、濠が埋まる、村も里も無くなりました処へ、路が変つて、旅人も通らぬけえに、根つから家業に成らんでの、私ら、木挽木樵も遣る。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下に眼をやると樹の下は狼の眼の光で埋まるように見えた。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時一明人、四郎の風貌を観て此子は市井に埋まる者でない。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮の前にはさすがに草は生えていないが、落葉で埋まるばかりになってる。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢の上から私は歌を空に漂はす、　紆り動く浪を越えて――無数の圃園と荒涼たる大草原とを越えて、　建てこんだ凡ての市街と、群衆に埋まる繋船場と道路とを越えて、　私はこの歌を喜び勇んで空に漂はす、オヽ死よ」　（一九一八、九月十七日）",
              "citation": {
                "source": "運命と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六　青年の面が、火のような激憤で、埋まるのを見ると、紳士はそれを宥めるように云った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "全都国旗をもって埋まるという記事があった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六　青年の面が、火のやうな激憤で、埋まるのを見ると、紳士はそれを宥めるやうに云つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻からこんな問答に業を煮やしてゐた森村市左衛門氏は、「大森さん」と言つて衝立ち上りながら、「一寸伺ひますが、往時一｜夜のうちに琵琶湖とか富士山とか出来たと言ひますが、富士山を取崩したら、見事琵琶湖が埋まるでせうかな。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "中核の圧力をこめてつたえて岸を撃ち、河の力がこわした堤の土の下に埋まることもあるこの岸沿いの河水の意味を、「女の一生」の中で作者は何故認め得ないのであろう。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹の取れる頃には、其邊は人で埋まるとか、其日は闃寂としたもので、蝦網などが干してあつて、二三の隱居が暢氣に網を補綴つて居た。",
              "citation": {
                "source": "伊豆の旅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱さえも埋まるかと思う埃の中で、細い燐燧に何うして探り当てる事が出来よう。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れはハタと室の戸を閉めて、ツカ／＼と床の間の上へあがると、清少納言の繪姿の頸筋のあたりを舌の尖端で輕く※めてから、丸行燈の燈心を一筋にして、郡内の厚蒲團の上へ、埋まるやうになつて轉がつた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "」雪よドンドン降ってくれ、私が埋まる程、私はえこじに傘をクルクルまわして歩いた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ドンドン降ってくれ、私が埋まる程、私はえこじに、傘をクルクルまわして歩いた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でないと、全く球場に埋まる老いたる玉が気の毒であり、芸術の完成を萎びさせていけないと思う。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私達は絵葉書と画集を買って、待たせておいた自動車へ埋まるかも知れない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、糸芯の周囲の蝋が全部熔け落ちてしまうと、芯が鉄芯にくっついて直立して、下端のわずかな部分だけが、熔けた蝋に埋まると云う形になるだろう。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この墓場に埋まる最初の人間として……悪魔の尿溜にいり込んだはじめての男として……また、ゴリラと親和した唯一の人として……ことに、あなたへの献身をいちばん誇りとする……。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは、英蘭銀行がお前の紙幣で埋まるだろう……ここだ、一生の運を掴むか掴まないか※　するとその時、おなじ思いはセルカークにも、こいつを、釈放したら、どんな事になる※　うまくいい当てて覗き穴を発見し、俺を地下採油の超富豪にしてくれるか。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に彼は埋まるようにして、種々雑多なものを読みあさっていた。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "江は七八月の流筏で埋まる季節には早いが、それでも既に上流から来た筏が諸所に浮んで居た。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンジキは往々持ちあげ兼ねるほど深く、その雪に埋まるのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そっちを見ますと、青白く光る銀河の岸に、銀いろの空のすゝきが、もうまるでいちめん、風にさらさらさらさら、ゆられてうごいて、波を立ててゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
