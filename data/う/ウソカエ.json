    "definitions": [
      {
        "index": 1,
        "gloss": "annual religious ceremony that occurs in Tenmangu where worshippers come to exchange their wooden bullfinch birds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
