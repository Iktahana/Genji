    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cloud formation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い安西洋紙で張りつめた天井には鼠の尿ででもあるのか、雲形の汚染がところどころにできている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎角するうちに半紙八つ切りの料の紙、小さく折られたるが雲形塗のお盆の上に堆たかくなりぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小袖と言ふのは、此れこそ見よがしで、嘗て将軍家より拝領の、黄なる地の綾に、雲形を萌葱で織出し、白糸を以て葵の紋着。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの彫刻は掛かりの方から下絵が出ているので、そうむずかしく意匠することも入らず、得手々々に彫刻して雲形の透かしに配置したものです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲形定木の面白さも何となく物足りぬ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの下界は整然とした方形の群団だが、イギリスの下界は雲形だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔が始終目について気になっていけないので、今度は右向きに横に寐ると、襖にある雲形の模様が天狗の顔に見える。",
              "citation": {
                "source": "ランプの影",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄紫に白で流行の雲形ぼかし模様に染た縮緬の単衣をぞろりと着、紅がちの更紗の帯を大きく背中一杯に結んでいる。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其顔が始終目について気になつていけないので、今度は右向に横に寐ると、襖にある雲形の模様が天狗の顔に見える。",
              "citation": {
                "source": "ラムプの影",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のどこから落ちて来るのか知ることの出来ぬ光が、安硝子の雲形の歪みの上にたゆたひ、半ばは窓の内側に滲み入る。",
              "citation": {
                "source": "鳥獣剥製所",
                "author": "一報告書",
                "note": "青空文庫"
              }
            },
            {
              "text": "繍帳原形は中央に浄土変相をあらわし、瑞雲、霊鳥、霊樹、雲形、花鳥、人物、鬼形、仏像などを、周りに大銭のような亀甲が一百ばかりつらなり、一甲に四字あて、すべてで四百字、この繍文によって繍帳製作の由来をあらわしたと言われる。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛ば立った皮からむき出た牛蒡の種の表面には、蒔絵に似た模様が巧緻な雲形の線を入れ、蝋燭豆のとろりと白い肌の傍に、隠元が黒黒とした光沢で並んでいる。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字架は雲形｛の彫刻｝に圍まれ、その下層には三行に、各行三個の大漢字が刻まれてある。",
              "citation": {
                "source": "大秦景教流行中國碑に就いて",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光赫々と輝き渡りて、深碧なる一天はさながら淨玻璃を張りたる如く、山脈の蜿蜒と連互するさま、雲形の飄蓬と往來するさま、極めて分明に見え渡れり。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　広庭には粗らな木の植込の中に、※牙な太湖石がさまざまに積み重ねられていまして、奇体な雲形を至る所に現出し、或は仙人を、或は昇竜を、或は怪獣を、彷彿せしむるものがありました。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは竹で拵えたもので、先端の雲形の代りに、小さな宝珠の群彫があった。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、藍色の鱗に不規則に雲形の斑点を浮かせ、翡翠の羽に見るあの清麗な光沢をだしたものが、至味とされている。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い雲形の模様が薄く泛びでてゐて、このごろ流行のオイルシルクで作つたレーンコートに彷彿としてゐる。",
              "citation": {
                "source": "河童酒宴",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスキンが雲を三層に分けた頃から思うと、九層の分類にまで及んだ近時の雲形の研究は進んだものだ。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲形や気温の表を製作しつつ日を送る人々の生活なぞも、私の心を引いた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "上段の間という部屋が一段高く造りつけてあって、本格な床の間、障子から、白地に黒く雲形を織り出したような高麗縁の畳まで、この木曾路を通る諸大名諸公役の客間にあててあるところも似ていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地に黒く雲形を織り出した高麗縁の畳の上には、雨の日の薄暗い光線がさし入っている。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは北向きで、広い床の間から白地に雲形を織り出した高麗縁の畳の上まで、茶室のような静かさ厳粛さがある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日の薄暗い光線は、その白地に黒く雲形を織り出した高麗縁の畳の上にさして来ている。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地に黒く雲形を織り出した高麗縁の畳の上までが湿けて見える。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはずっと以前に彼の手に入れた古鏡で、裏面には雲形の彫刻などがしてあり、携帯用の紐の付いたものである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "其日々々の勤務――気圧を調べるとか、風力を計るとか、雲形を観察するとか、または東京の気象台へ宛てて報告を作るとか、そんな仕事に追われて、月日を送るという境涯でも、あの蛙が旅情をそそるように鳴出す頃になると、妙に寂しい思想を起す。",
              "citation": {
                "source": "朝飯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲形、層、層積、巻層、巻積。",
              "citation": {
                "source": "朝飯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
