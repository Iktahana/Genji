[
  {
    "uuid": "aa793b6a-f71c-5120-b340-4c18c3656013",
    "entry": "雲形",
    "reading": {
      "primary": "うんけい",
      "alternatives": [
        "くもがた"
      ],
      "is_heteronym": false
    },
    "grammar": {
