          "literary": [
            {
              "text": "嘘字か、どうか不安なのである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘字だらけじゃないか、と思っているに違いない。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘字盡を作ることになりはせぬかと思ひます。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京へ行つてゐた間、母に手紙の返事を彼は、時々書いたが、よく母は彼の手紙の文章中の嘘字や仮名使ひの誤りの傍に線を引いて、返送して寄したものだつた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは好いが嘘字が沢山書いてあった」「こゝの悪い男かい？",
              "citation": {
                "source": "合縁奇縁",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校三年を中途でやめた兄の手紙は、片仮名で、ところどころに入っている漢字は、全部、嘘字である。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "専売局のも片仮名文であったが、嘘字はなく、これはいかめしく印刷してあった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "片仮名文に、嘘字だらけの漢字、人が見たら、支離滅裂であるかも知れないが、他人に示すものではなく、それで充分だった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや、うそじゃない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うそじゃありません。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母　　　うそじゃありませんよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそじゃねえだろう。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそじゃと思うたら、おじさんも字が読めるはず、お地蔵さまたちのお背中をようごろうじませ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそじゃあるめえな」「いまさらなんのうそ偽りを申しましょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃほんとうかッ」「正真正銘のこの目の玉で見たんだから、うそじゃねえんですよ」　きくや同時！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに今いったことはうそじゃあるめえな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ、さっきもいっそ駕籠かきどもを締めあげたほうが早くわかるだろうと、そちらのだんなにも思ったとおり申しあげたんですよ」「そのことば、うそじゃあるめえな」「いまさらうそなんぞいってなりますものか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手の用意をしろといったな、うそなんですかい」「うそじゃねえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、駿三の云うことはうそじやないんだね」「そうさ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、みんなうそじゃ。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばばが昔なじみじゃというのも、うそなら、沙金がおばばに似ているというのもうそじゃ。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……わしの言ったことはうそじゃなかろうがな。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘーイさんはお茶目さんだからなあ」「うそじゃないよ。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそじゃありません。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うそじゃないよ」「うそだったら。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあ何かえ、お前の言うこと、うそじゃあないんだね？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "土一升に金一升……うそじゃ無い、本間の話じゃ。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここは法廷じゃないから、真実などという、むずかしい言葉をつかわなくとも、結構ですよ」「きょう、偶然、あの人たちに会って、誘われてここへ来たというのは、絶対にうそじゃないの……それで、あたし、どうなるのかしら？",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……そんな」「うそじゃない。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうです、やつぱり、うそじやありませんでしたね。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
