    "definitions": [
      {
        "index": 1,
        "gloss": "tying a person's limbs to two or four bulls and making them run in different directions (Warring States-era death penalty)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「爪責めは愚か、八つ裂き、牛裂きに逢おうとも、一旦口外すまいと誓ったことを、破るような――あははは、ここらの方々には、爪責めで、ぺらぺら喋る人もござるのじゃろ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が罪人を牛裂きにしたり釜ゆでにしたりするのに比べると、それほど積極的に戦争を好んでいるようにも見えなかった。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際は天下に悪名が高いほど牛裂きや釜ゆでに入れあげていたわけでもなかった。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "微罪の罪人を牛裂きにしたり、釜で煮殺したり、おまけに、その釜を、煮られる者の女房や親兄弟に火をたかせた。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たとえ牛裂きにされようとも」「まして炮烙の刑なんど……」「釜煎りさえも恐れぬ身じゃ！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち逃げ遅れた者を兵が拉して来ると、「牛裂きにしろ」　と、相国は威猛高に命じた。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
