[
  {
    "uuid": "3d76f197-f6a7-5d05-ad6d-bfcec45c994a",
    "entry": "云々",
    "reading": {
      "primary": "うんぬん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
