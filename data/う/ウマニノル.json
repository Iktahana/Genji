        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だからちったア馬に乗ることも心懸けておくこッた、女にかかり合っているばかりが芸じゃあねえぜ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "匈奴にして昭君を愛するも、昭君｜豈馬に乗るの怨あらむや。",
              "citation": {
                "source": "愛と婚姻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松公、汝は放生の亀の話を知っておるか」　獅子鼻の右横になった松の浮根に竹馬に乗るようにしていた小供が、獅子鼻に向って云った。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬に乗ることも、散歩することも、その他いっさいの家から離れなければならないような運動にふけることもためらった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上馬に乗るも今度がはじめてじゃ。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにつないであるんだが」三上は、これを昨夜伝馬に乗る前から計画していたのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "天文中書いたてふ『奇異雑談』に出た話で大略は、一婦人従者と旅するに駄賃馬に乗る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "懸賞小説を書いたり政治家の尻馬に乗るより余程気楽に儲けることが出来る。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は馬に乗ることはすこぶる不得手なので、さっきから一行にしばしば乗り遅れている。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "落馬のときのことなど心配すると、今の人はおかしがって笑い出すかも知れないが、むかし池大雅は、旅行のとき、宿場宿場でよく馬に乗ることがある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子とローラと八重は、シヤツの腕まくりをして馬に乗ると、戯れらしくそろつてスタートを切つた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、ひと通り以上に馬術を稽古するのは、馬に乗ることが好きだという人で、云わば本人の道楽です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "神原は三千石の大身で、馬に乗るのが大好きでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やつてみたいと思ふのは馬に乗ることだ。",
              "citation": {
                "source": "自慢山ほど",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の嫌ひな上西氏は、馬に乗る事を稽古した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、もう貴方様の馬に乗る事だけは御免を蒙りやす。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしのヒンヅウ人は、今の人たちが馬に乗る折りのやうに象の背にまたがつて、長い足をぶらりと両わきにぶらさげてゐたといふから、身のたけは随分あつたものと思はれる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬に乗るのにそれぞれ流儀があるやうに、妻を取り扱ふにも各自の勝手があるものです。",
              "citation": {
                "source": "恋妻であり敵であつた",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして現今でもこの遺風は田舎に遺っていて祭礼の時にのろくもいが馬に乗るところが稀にあるようであります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が父の馬に乗るのを覚えたのも、やはりその頃のことだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓を引くことも馬に乗ることも、太刀を抜くことも、兵法も、何一つ手掛けていなかったからだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の足で走る代わりに馬に乗ることを覚え、馬車で人を運ぶ術を身につけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて初めて馬に乗るものの為に乗馬の心得が浴場の壁に掛けてあつたとしても必ずしもあり得べからざる事でもない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦長木村は江戸の旗本だから、馬に乗ることは上手だ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れからその馬に乗てどん／＼駆けて来ると、亜米利加人が驚いて、日本人が馬に乗ることを知て居ると云うて不思議の顔をして居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で明治三年｜酷い腸窒扶斯を煩い、病後の運動には馬に乗るのが最も宜しいと、医者も勧め朋友も勧めたので、その歳の冬から馬に乗て諸方を乗廻り、向島と云う処も始めて見れば、玉川辺にも遊び、市中内外、行かれる処だけは何処でも乗廻わして、東京の方角も大抵分りました。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "役前の外、馬に乗る者とては一人もなく、内職の傍に少しく武芸を勉め、文学は四書五経歟、なお進て蒙求、左伝の一、二巻に終る者多し。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無事とお伝え下さりませ」　三人は、池上の馬に乗るのを見送った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の月給が百円より多いらしく思われて来た事は、やがて自分も白い馬に乗ることが出来そうな気持を起こさせた。",
              "citation": {
                "source": "大人の眼と子供の眼",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、自分は馬に乗るどころでなく、一家を構える力もなく、下宿屋の二階にくすぶって、常に懐中の乏しさに難渋し、朝夕満員の電車に鰯の鑵詰の姿をして乗らねばならぬ身の上だった。",
              "citation": {
                "source": "大人の眼と子供の眼",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
