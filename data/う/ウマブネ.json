[
  {
    "uuid": "a2345e51-1c9b-5ed0-afeb-6f1640fb745b",
    "entry": "馬槽",
    "reading": {
      "primary": "うまぶね",
      "alternatives": [
        "まぶね"
      ],
      "is_heteronym": false
    },
    "grammar": {
