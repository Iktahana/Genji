        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし統計ほど確かなものはないが、また「統計ほど嘘をつくものはない」という事は争われないパラドックスである。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に私は「道」とか「嘘をつく日」とか「輝ける朝」などに感心してしまつた。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「輝ける朝」「嘘をつく日」これらは作者の性格のまがう方なき美しさをはつきりと、而かも何等の矯飾なく暴露してゐる。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重苦しくてならぬ現実を少しでも涼しくしようとして嘘をつくのだけれども、嘘は酒とおなじようにだんだんと適量がふえて来る。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、嘘をつくと死んでから、閻魔さんに舌をぬかれるといつたり、辻で銭をひろふと、厄病が家へやつて来る、といつたりするのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、もう嘘をつく必要は無くなりました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんは、どうしてそんな不必要な嘘をつくのだろう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のひとって、なぜそんな見え透いた嘘をつくんだろう。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は嘘をつく事をやめて、女は慾を捨てたら、それでもう日本の新しい建設が出来ると思う。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が慾を捨て、女が嘘をつく事をやめる、とこう来なくてはいけません。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が、あんなに平気で嘘をつく間は、日本はだめだと思いますが、どうでしょうか。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どだい女房に、まことしやかの嘘をつくのが、けちくさいじゃないか。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その写真帖を、そのまま、日本へ持って帰り、日本の人に見せるのは、少し、そらぞらしい嘘をつくようなうしろめたさを覚えた。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は坂口安吾が実生活では嘘をつくが、小説を書く時には、案外真面目な顔をして嘘をつくまいとこれ努力しているとは、到底思えない。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘をつく快楽が同時に真実への愛であることを、彼は大いに自得すべきである。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかの曲亭馬琴の筆記に拠ったもので、その話をして聴かせた人は決して嘘をつくような人物でないと、馬琴は保証している。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘をつくと承知しないぞ言はれたので、今までしたこと、あることないことを洒唖洒唖と言つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――嘘つき佐平、で有名な佐平爺は、嘘をつくときには、いつも口尻を曲げるのが癖だった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し佐平は、依然として嘘をつくことをやめなかった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえはまた嘘をつくつもりか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私、今ままでにここへ来たことなんかありませんわ」「どうしてお前は私に嘘をつくんだ？",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘をつくと飛んだことになる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嘘をつく訳じゃねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠は嘘をつくような人物ではない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、嘘をつく時には、必ず、まじめな顔をしているものである。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえの兄の、一ばんきらいなものは、人を疑う事と、それから、嘘をつく事だ。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ露見する事なのに、一日でも一刻でも永く平和を持続させたくて、人を驚愕させるのが何としても恐しくて、私は懸命に其の場かぎりの嘘をつくのである。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く飛んでゐる飛行機を映画化すために、飛行機を固定さしてをいて、背後の雲を早く移動させるといふ映画のトリックを想ひ出したらいゝ、自然の真を衝くためには、嘘をつくことをゆるされるといふ場合はさうした場合を言ふのであらう、そこにも桂月氏の曲者的なところがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄之丞がなぜそんな嘘をつくのか、二人にも判らなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジャーナリズムの一相と見らるる「事実の類型化」はある意味では確かにうそをつくことであるが、しかしまたよく考えてみると、これは具体的個別から抽象され一般化された規準的事実の記述だと解釈されないこともない。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
