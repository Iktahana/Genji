        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "猫や、孔雀や、鶯や、はつか鼠や、豹や、駱駝や、獅子やを乘せ、さうして私の航海の日和がつづいた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とばかり、海の日を玻璃に透かしつ、やうやうに形ととのふ恋の珠磨きつ、吹きつ、をりをりに車まはせば、美しく薔薇いろの靄さとけぶる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君の大好きな海の日が来たのである。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂は海中に突出した位置のため、船の食堂に出た航海の日の思い出を湧き立たせ、暫くの間も矢代は、もう忘れていた風景を限りなく思い出すのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "卵色の地に、とろりと溶け流れるような濡羽色の壺肌の前で、真紀子は久慈に、平尾男爵と帰って来た航海の日の様子を話したりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もんはそれから暫く上海の日本人の店で働いた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　上海の日本婦人倶楽部に、招待を受けた事がある。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたづみの戀、海の日や、照らせあふれよ、　　　　夢ふかかれ、濃ゆかれこの酒、このあやしみ。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の日の沈むを見れば、たぎり落つ。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "安永のそれから天保のそれまで約六十年、天保のそれから慶應のそれまで約三十年、通じて約一世紀の、長崎港の沖合にかかる外國渡來の船の姿のうつりかはりは、誰にしろ海の日本の歴史を知りたい慾望をおこさせられるだらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私らの遠い祖先と、當時の海の日本の、自分らの位置を知る氣がした。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代が三百年の鎖國にゐるうち、海の日本の四周は、刻々にヒタしてくる「戰爭」と「文化」の波であつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶長、元和以前の昔は知らず、家光以來の二百數十年、海の日本に船らしい船が造られなかつたといふことは記憶さるべきであつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢なる船乘高田屋嘉兵衞が國後、擇捉間の航路を拓いた苦心は、海の日本の誇るべき語り草であるが、吃水の深い波の入らない異國の船は、嘉兵衞のやうに勇敢老練でなくともその一世紀もまへから赤道を横切り、太平洋を横斷し、北氷洋から千島列島を南下することも出來た。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし周囲が海の日本のことだから、どうしても舟というものを考えてみなければならない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心な唐次長が、軍部の意向を聴取するために、南京へ帰京する予定を延ばして、在上海の日本武官を訪問して歩いた。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "肝心な唐次長が、軍部の意向を聴取するために、南京へ帰京する予定を延ばして在上海の日本武官を訪問して歩いている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の日に少し焦げたる冬椿一月二十三日　鎌倉俳句会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川の云ふ所では支那商人が上海の日本領事館の薦めで輸出したものださうだが、商人は一向に売れないと滾してゐるとのことであつた。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の日本宿で、朝食を食った時、ああ、こんなに、日本食ってものは、うまいものか！",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
