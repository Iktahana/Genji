        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "全く三千六百五十三回、則ち閏年も入れて十年という間、日曜も夏休みもなしに落第ばかりしていては、これが泣かないでいられましょうか。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に洪武三十一年｜閏五月なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其歳閏九月、たま／＼天文の変ありて、詔を下し直言を求められにければ、山西の葉居升というもの、上書して第一には分封の太だ侈れること、第二には刑を用いる太だ繁きこと、第三には治を求むる太だ速やかなることの三条を言えり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の病は洪武三十一年五月に起りて、同閏五月｜西宮に崩ず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の崩ぜるは閏五月なり、諸王の入京を遏められて悦ばずして帰れるの後、六月に至って戸部侍郎卓敬というもの、密疏を上る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "閏のあった年で、旧暦の月が後れたせいか、陽気が不順か、梅雨の上りが長引いて、七月の末だというのに、畳も壁もじめじめする。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶長に入るとその元年閏七月になって、二回の大地震が起った。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同五年閏一月には胆振にあって、それには有珠嶽が噴火した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同四年閏五月に駿河、相模、武蔵、同年七月に伊予、同五年二月に越中、越前、同年三月に信濃、松代、同六年に武蔵の槻にあって、それが江戸時代のしんがりをしている。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先、余り御無体、お待ちや、などと、慌しい婦まじりの声の中に、丸官の形、猛然と躍上って、廊下を鳴らして魔のごとく、二人の閏へ押寄せた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七段頃しも弘安四年、閏七月の朔日、ああら不思議や、京にては晴れに晴れたる夏空に一朶の黒雲｜神立ち現れ、白羽はいだる鏑矢の見る見る輝き鳴動して、たちまち西へと飛び去りける。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十七日京都を発せさせ給ひ、閏十月二日東京なる東伏見宮第に着かせ給ひ、尋いで有栖川宮第に徙らせ給ふ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年は八月に閏があったそうで、ここにいう八月は閏の方であるから、平年ならばもう九月という時節で、朝晩はめっきりと冷えて来た。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "周の昭王の四十年｜閏十二月｜某日。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "周の敬王の四十年、閏十二月某日は良夫に迎えられて長駆都に入った。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "周の敬王の四十年、閏十二月某日｜は良夫に迎へられて長驅都に入つた。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此上は死を以って諫めるほかに道はないと決意して、天文二十二年｜閏正月十三日、六十幾歳かの皺腹｜割いて果てた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤の刑死は、慶応四年四月二十五日であるが、此の年六月六日発行の「中外新聞」には――閏四月八日、元新撰組の隊長、近藤勇といふ者の首級、関東より来つて三條河原に梟せられたり。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘安四年、七月｜晦より、閏七月一日の夜にかけての大暴風に、敵十五万の大軍は覆滅して、還り得たるもの、わづか五分の一だと云はれてゐるが、十五万の大軍を石築地に依つて、よく防禦した将士の奮戦が、やがてこの天佑を待ち得たのであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今年は閏がねえ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、閏があろうとあるまいと、今日は全く十九日だろうな。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "使は閏四月二十四日に江戸の本誓寺に着いた。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年には閏があって、七月がふた月つづくことになる。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしは残暑が長く、殊に閏の七月は残暑が例外に強い。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "閏七月二日の朝五つ時（午前八時）に金助の葬儀は小梅の菩提寺で営まれた。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　閏七月は誰かの予言どおり、かなり強い残暑に苦しめられたが、二十九日の牡丹餅が効を奏したのか、江戸にはさまでの病人もなく、まず目出たいといううちに、八月にはいって陽気もめっきりと涼しくなった。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の秀康卿が慶長十二年閏四月に薨ぜられた時、わずか十三歳で、六十七万石の大封を継がれて以来、今までこの世の中に、自分の意志よりも、もっと強力な意志が存在していることを、まったく知らない大将であった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが二月二十九日は閏年にあるんで……だからこの人の誕生日は四年に一度しか来ないわけで。",
              "citation": {
                "source": "白妖",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎六年目に閏月が一つあてはさまることにしたので一年は平均するとやはり三六五日ということになったのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲のわだつみ洞なして、　　青野うるうる川湧けば、あなや春日のおん帯と、　　もろびと立ちてをろがみぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
