        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それはた小野の朝じめり、薔薇の香ふ途ならず、汐ざゐどよむ海境を海豚の列の見えがくる大わだつみの彼方にて。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は、海境――水平線――で、海はどかつと落ち込んでゐて、其処を越すと、常世国があると思うてゐた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海境は、行けば行くほど遠のくので、とても行きゝれない。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又この海境で、天と海と一つになつてゐるので、空と海とは同じだ、と思うてゐた。",
              "citation": {
                "source": "古代人の思考の基礎",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『万葉集』の浦島子の歌にも有るように、海境を過ぎて漕ぎ行くという作業が普通であって、是には帆を用意せぬ小舟も多かったから、次第に大胆に遠く出る者があったとはいうものの、いつでも地方にアテすなわち目標を見定めていて、よほど確かな船頭をもたぬかぎり、山ナシという水域までは出ないようにしていた。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃えあがるやうなさかんな熱情。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、それはどんな王さまもついみたこともないようなさかんなお祝の行列が、お城にむかって練っていきました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この社会ファシストの代表は、満鉄が不明の活動を援助しているというようなさかさまごとを臆面なく披瀝して軍事活動を合理化している。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、いさき・えび・たい・さわら・すずきのようなさかなである。",
              "citation": {
                "source": "琥珀揚げ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "材料の良否は人の賢愚善悪にも等しいもので、腐ったようなさかな、あるいは季節はずれの脂っ気を失ったさかななどは、魂の腐った人間に比すこともできれば、低能あるいは不良に比すべきもので、優れた教育家の苦心が払われたとしても、その成果はおぼつかないものであると同様である。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
