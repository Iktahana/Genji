    "definitions": [
      {
        "index": 1,
        "gloss": "boundary between the world of men and the world of the sea god",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
