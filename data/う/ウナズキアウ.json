        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なべて人の世に相逢うということ、頷き合うということ、それ等は、結局、この形に於てのみ真の可能なのではあるまいか。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と人間とが、高い天の上から瞰下したら、さぞさぞ小さく、然しながら一生懸命に生きてゆく間に、馴れた賢い本能が睦しく互に頷き合う。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女らは貌を見合わせて頷き合う風であった。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の使女は途方に暮れ、場内を二度ばかり歩き廻りし後、寝台の女子をいたわらんとし、立ちよりしが、思い返して、たちまち窓口に行きて葬式の列を眺め、頷き合うて正面の出口より浜に向かって馳せ行く。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くは白髪頭と断髪と、テラスの葡萄の葉蔭に、頷き合うように揺れていたのです。",
              "citation": {
                "source": "水中の宮殿",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "土方歳三は一人の黒と頷き合うと、スーッと左の方から進み寄って太刀を取り直す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには思いあたる者もあるとみえ、うす笑をうかべながら頷き合う者もいた。",
              "citation": {
                "source": "青竹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、聞く方でも、それが世に隠れもない名器と、みな知っているだけに、「まことに、三河どのにも、よく思い切って、これをば……」　と、その懇厚な信問には、誰もが、事実どおり、家康の秀吉に対する礼のなみなみならぬことに、頷き合うのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝々、まだ生きていることを知らせるために、眼でうなずきあうのが精一杯のところである。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき彼の顔のほうへ耳をよせ、彼の呼吸がすこしでも安まり、彼の顔から苦痛の色がうすらぐと夫婦は涙ぐんだ眼でうれしそうにうなずきあうのだった。",
              "citation": {
                "source": "黒い手帳",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、あすこのことだから、古くさいものばっかり読まされて来たんだろうから」「じゃあね」とうなずきあうようにして、蕗子とその友達とは帰って行った。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いるな」「いる」「では……」　目と目が険しくうなずきあう。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　何か目と目でうなずきあうと、苫をはねたそのふたり、手と膝とで、松兵衛の部屋のほうへ這いだした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うなずきあうと、「今のおことばはご本心ですか」　と、左右からすり寄った。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
