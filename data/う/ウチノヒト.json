        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "うちの人は毎日仕事で忙しい。",
              "source": "幻辞"
            },
            {
              "text": "うちの人が帰ってくるまで待っている。",
              "source": "幻辞"
            },
            {
              "text": "うちの人と一緒に買い物に行った。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は料理が得意だ。",
              "source": "幻辞"
            },
            {
              "text": "うちの人に今日のニュースを聞かせた。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は新しい仕事に挑戦している。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は営業部で働いている。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は月曜日から金曜日まで出張に行く。",
              "source": "幻辞"
            },
            {
              "text": "うちの人が昇進したので家族で祝った。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は同僚と良い関係を築いている。",
              "source": "幻辞"
            },
            {
              "text": "うちの人と教育について意見が合う。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は子どもの成績向上を応援している。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は読書を習慣にしている。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は映画鑑賞が趣味だ。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は音楽を聴きながら仕事をする。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は健康管理に気をつけている。",
              "source": "幻辞"
            },
            {
              "text": "うちの人は毎朝ジョギングをしている。",
              "source": "幻辞"
            },
            {
              "text": "うちの人はテニスクラブに参加している。",
              "source": "幻辞"
            },
            {
              "text": "うちの人と春の旅行を計画している。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "主人がうちの人をこんなめにあわしてしまったんです！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "純哉さんのうちの人だ。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虔十のうちの人たちはほんたうによろこんで泣きました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虔十のうちの人たちはほんとうによろこんで泣きました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬はいよいよ勘弁ならぬと思いましたが、このうちの人に可愛がられているのでジッと辛抱して出て行きました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆうべも九つ（午後十二時）を合図におせきの寝床へ忍んで行って、寝ぼけてぼんやりしているのを抱き起して、うちの人が蝋燭をかざしてみると……壁には骸骨の影が映って……。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしばかりでなく、うちの人の眼にも見えたというのですから、嘘じゃありません。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの人は下谷へ行って、その話をしましたところが、行者さまはただ黙って考えていて、わたしにもよく判らないと言ったそうです。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平は銀子が松の家へ住み込むちょうど一年前に起こった、この哀話を断片的に二三の人から聴き、自分で勝手な辻褄を合わせてみたりしたものだったが、土地うちの人は、この事件に誰も深く触れようとはしなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人たちも、寝床にはいりました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人たちは、「この子は、がつがつ食うなあ」と、言っていました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこんなに面白く遊んでいるが、うちの人はどうしているだろうと思いながら、眼鏡を眼に当ててみますと……大変なことが見えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小學二年か三年の雛祭りのとき學校の先生に、うちの人が今日は雛さまを飾るのだから早く歸れと言つてゐる、と嘘を吐いて授業を一時間も受けずに歸宅し、家の人には、けふは桃の節句だから學校は休みです、と言つて雛を箱から出すのに要らぬ手傳ひをしたことがある。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人は私が本さへ讀んで居れば、それを勉強だと思つてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人たちは私の容貌を兄弟中で一番わるいわるい、と言つてゐたし、そのやうな惡いをとこが、こんなおしやれをすると知られたら皆に笑はれるだらう、と考へたからである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢る前に砂糖をなめればいいとか、時計のかちかちを數へろとか、水で兩足を冷せとか、ねむのきの葉を枕のしたに敷いて寢るといいとか、さまざまの眠る工夫をうちの人たちから教へられたが、あまり效目がなかつたやうである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分になると、うちの人は皆寢てしまつてゐて、祖母だけが起きてゐるのだ。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次兄も亦うちの人たちに冷く取扱はれてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の姉も亦きりやうがわるいとうちの人たちからいはれいはれしてゐたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は程なく小學校を卒業したが、からだが弱いからと言ふので、うちの人たちは私を高等小學校に一年間だけ通はせることにした。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、私のうちの人たちは父の寢棺の置かれてある佛間に集つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の顏に就いてのうちの人たちの不評判も絶頂に達してゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私の友がうちの人たちに不評判でないやうに祈つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人たちと並んで玄關先へ、みよも見送りに立つてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄關のほの暗い軒燈の下でうちの人たちがうようよ出迎へてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその夜、みよと結婚するに就いて、必ずさけられないうちの人たちとの論爭を思ひ、寒いほどの勇氣を得た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの人たちは馬車で行け、と言つたのだが、定紋のついて黒くてかてか光つたうちの箱馬車は、殿樣くさくて私にはいやだつたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の顔に就いてのうちの人たちの不評判も絶頂に達してゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、私のうちの人たちは父の寝棺の置かれてある仏間に集つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しナフタリン臭くなっているかも知れませんけど、ね、」と私のほうに向き直って言って、「うちのひとには、もう、なんにも要らないのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
