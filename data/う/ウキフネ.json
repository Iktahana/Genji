        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "浮舟のようにネオンサインにブルウスの曲目があらわれると、ジャズ・バンドが演奏を始めた。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き花鳥図水禽さながらや、一片の蓮華、浮舟。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮舟さんが燗部屋に下っていて、七日ばかり腰が立たねえでさ、夏のこッた、湯へ入っちゃあ不可えと固く留められていたのを、悪汗が酷いといって、中引過ぎに密ッと這出して行って湯殿口でざっくり膝を切って、それが許で亡くなったのも、お前、剃刀がそこに落ッこちていたんだそうさ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も一挺紛失さ、しかしそりゃ浮舟さんの楼のじゃあねえ、確か喜怒川の緑さんのだ、どこへどう間違って行くのだか知れねえけれども、厭じゃあねえか、恐しい。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は親しい源氏物語の光君は持っているが、彼とても、彼と交渉を持った数多い女性達の優婉さ、賢さ、風情、絵巻物風な滑稽等の生彩ある活躍にまぎれると、結局末摘花や浮舟その他の人物の立派な紹介者というだけの場合さえあるようだ。",
              "citation": {
                "source": "わからないこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女も珍しい楽しい路のような気がして、橘の小嶋は色も変はらじをこの浮舟ぞ行くへ知られぬ　こんなお返辞をした。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸に着いた時、船からお上がりになるのに、浮舟の姫君を人に抱かせることは心苦しくて、宮が御自身でおかかえになり、そしてまた人が横から宮のお身体をささえて行くのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮舟の姫君の着ていた上着は抱いておいでになる時お脱がせになったので、繊細な身体つきが見えて美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は繕いようもないこんな姿で、高雅なまぶしいほどの人と向かい合っているのではないかと浮舟は思うのであるが、隠れようもなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "右近だけでなくこの人にまで自分の秘密を残りなく見られることになったのを浮舟は苦しく思った。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれも来ぬ所で宮はお気楽に浮舟と時をお過ごしになった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮舟の姫君は雪の深く積もった中から自身の住居のほうを望むと、霧の絶え間絶え間から木立ちのほうばかりが見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "降り乱れ汀に凍る雪よりも中空にてぞわれは消ぬべき　とその上へ浮舟は書いた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日は乱れた髪を少し解かさせて、深い紅の上に紅梅色の厚織物などの取り合わせのよい服装を浮舟はしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍従も平常用の裳を締めたまま来ていたのが、あとから送ってこられたきれいなものにすべて脱ぎ変えたので、脱いだほうの裳を宮は浮舟にお掛けさせになり手水を使わせておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかりましたか」　とお言いになると、そうであったというように思って、浮舟がうなずいているのが可憐であった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い見識があるのでもない若い浮舟はこれにさえ多く動かされ、その人と同じ恋しさも覚えたのであるが、初めに永久の愛の告げられた大将の言葉にはさすがに奥深いものがあり、他に優越した人格の備わっていることなども思われ、異性として親しんだ最初の人であるためか、今も一方へ没頭しきれぬ感情はあった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわるがわるに二人の男の消息を読むことは気恥ずかしくて、浮舟はまださっきの宮のほうの長い手紙ばかりを寝ながら見ていると、それと知って侍従と右近は顔を見合わせて、姫君の心はのちの情人に移ったと言わないようで言っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さきのほうのお返事を、だれも見ませんうちにお書きなさいまし」　と右近は言ったが、「宮様へ今日は何も申し上げる気はしない」　と恥じたふうで浮舟は言い、無駄書きに、里の名をわが身に知れば山城の宇治のわたりぞいとど住みうき　と書いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮舟は宮の描いてお置きになった絵をときどき出して見ては泣かれるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "かきくらし晴れせぬ峰のあま雲に浮きて世をふる身ともなさばや　こう浮舟が書いてきたのを御覧になり、兵部卿の宮は声をたててお泣きになった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ばかりが熱愛しているのでなく、彼女も自分を恋しく思うことがあるのであろうと想像をあそばすと、浮舟の姫君が物思わしそうにしていた面影がお目の前に立って悲しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫は余裕のある気持ちで浮舟から来た返事を読み、かわいそうにどんなに物思いをしているであろうと恋しく思った。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "新築させた邸へ浮舟を入れようと思っていたが、そのために家までも作ったと派手な取り沙汰などをされるのは苦しいことであると薫は思い、ひそかに襖子を張らせなどすることを、人もあろうに内記の妻の親である大蔵の五位へ心安いままに命じたのであったから、時方から話は皆兵部卿の宮のほうへ聞こえてしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮舟の姫君は逃亡というような意外なことを自分が起こして問題になれば、この人たちはどんなにかなしむことであろう。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてそんなに平生と違って顔色が悪く、痩せておしまいになったのだろう」　と母は浮舟を見て驚いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の上の有明月夜のことがまた思い出されて、とめどなく涙の流れるのもけしからぬ自分の心であると浮舟は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのことはごりっぱな方なのですがね、そんなことで奥様が無礼だとお思いになることがないかと御心配が絶えないなどと大輔の娘が話していましたよ」　こう言うのを、女房ですらその遠慮はするのである、まして自分は夫人の妹でないかと思いながら、横たわった浮舟は聞いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "二条の院の奥様に苦労をおかけ申すようなことをこの方がなさいましたら、私はどんなにこの方がかわいそうでも二度と逢うことはいたしますまい、他人になりますよ」　母が尼に話すこの言葉で肝も砕かれたように浮舟の姫君は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の愛情から出る言葉を寝たようにして聞きながら浮舟は思い乱れていた。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
