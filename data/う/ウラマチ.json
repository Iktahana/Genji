              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "とある裏町に濁った溝川が流れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町によく見る風物で、何の奇もない市中風景の一角だが、そこを捉えて春夜の生ぬるく霞んだ空気を、市中の空一体に感触させる技巧は、さすがに妙手と言うべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の句には、こうした裏町の風物を叙したものが特に多く、かつ概ね秀れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは多分、蕪村自身が窮乏しており、終年裏町の侘住いをしていたためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光の下、ひとり深夜の裏町を通る人は、だれしも皆こうした詩情に浸るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち冬の寒い日に、葱などの流れている裏町の小川を表象して、そこに人生の沁々とした侘びを感じているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の長屋｜住いをしていた蕪村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の溝を流れる湯の匂ひや、朧ろにかすむ紅色の軒灯や、枕に近い湯滝の音やが、何とも言へぬ春らしい感じを起させる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄汚い裏町のようなところの雑貨店の軒にロシア文字の看板が掛かっていたりした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は時々サン・ドニの門の裏町のキャフェに寄る。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日、例のサン・ドニの門の裏町のキャフェで彼等の集りがあった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、家、ジョバンニが勢よく帰って来たのは、ある裏町の小さな家でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから私は彼女を連れて、白首女の蝟集する裏町へ行って、チョップ・ハウスのサルーンで、一夜そこの踊子たちの仲間入を彼女にさせました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ヶ月の支那旅行を終つて、いよいよ明日は日本へ歸ると云ふ前夜、向うで知り合つた二三の友人と別宴を交し可成り醉つてゐた處を例の黄苞車でぐるぐる引きまはされたあとなのでどこのどう云ふ處にあつたのか覺えてゐないが、とにかく法租界の暗い裏町にある二流どこの阿片窟だ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通り抜けて停車場の方へと裏町を歩いていると家々からラジオが聞こえ、それが今聞いた市役所の庭の合唱そのままである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫婆が死んだという噂が長屋じゅうから裏町まで伝わって、家主もおどろいて駈け付けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、家　ジョバンニが勢よく帰って来たのは、ある裏町の小さな家でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十四年二月、東京朝日新聞）　　　　　パリから（一）　私の宿はオペラの近くでちょっと引っ込んだ裏町にあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　家　ジョバンニが勢いよく帰って来たのは、ある裏町の小さな家でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　家　ジヨバンニが勢よく歸つて來たのは、ある裏町の小さな家でした。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の下水に落ちている犬を子供が助けてやった事実でも、自転車が衝突して両方であやまっていた実例でも適当に描かれれば有意義である。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドック近くの裏町の門々にたたずむ無気味な浮浪人らの前をいばって通り抜けて川岸へくると護岸に突っ立ったシルクハットのだぶだぶルンペンが下手な掛け図を棒でたたきながら Die Moriat von Mackie Messer を歌っている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の中に現われている限りの出来事と達引とはおそらくパリという都ができて以来今日に至るまでほとんど毎日のようにどこかの裏町どこかの路地で行なわれている尋常｜茶飯のバナールな出来事に過ぎないであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また始めにはカメラが、従って観客が、あたかも鳥にでもなったように高い空からだんだんに裏町の舗道におりて行って歌う人と聞く人の群れの中に溶け込むのであるが、最後の大団円には、そのコースを逆の方向に取って観客はだんだん空中にせり上がって行って、とうとう天上の人か鳥かになってしまう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで「パリの屋根の下」の観客は、この東京の電車や四つ辻におけると同じような態度で、フランスの都の裏町を漫歩しつつその町の屋根の下に起こりつつあるであろうところの尋常｜茶飯事を見物してあるくのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舗道をあるくルンペンの靴音によって深更のパリの裏町のさびしさが描かれたり、林間の沼のみぎわに鳴く蛙や虫の声が悲劇のあとのしじまを記載するような例がそれである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠りのまださめぬ裏町へだれか一人自転車を乗り込んで来て、舗道の上になんだか棒のようなものを投げ出す。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりそれらに眺め入っているとここはどこかの裏町で橋の上であるのを忘れさえする。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋に手の届く、通一つの裏町ながら、撒水の跡も夢のように白く乾いて、薄い陽炎の立つ長閑さに、彩色した貝は一枚々々、甘い蜂、香しき蝶になって舞いそうなのに、ブンブンと唸るは虻よ、口々に喧しい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、穴のやうな眞暗な場末の裏町を拔けて、大川に架けた、近道の、ぐら／＼と搖れる一錢橋と云ふのを渡つて、土塀ばかりで家の疎な、畠も池も所々、侍町を幾曲り、で、突當りの松の樹の中の其の邸に行く、……常さんの家を思ふにも、恰も此の時、二更の鐘の音、幽。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
