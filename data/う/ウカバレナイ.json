        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これでは犠牲者は全く浮かばれない。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んでいくのに、祝賀なんかされたら、ヘッケルとジャッケルが浮かばれない」　慶一は気持ちを引き立てるために、まうしろの令子に目をやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その犯人を突止めて八裂にでもしなければ、浮かばれない人間がイクラでもいるじゃないですか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の写真を母のお棺に入れたが、これは死んだ人が浮かばれないとて取り出された。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、浮かばれないと見えるな」と、貝谷は叫んだ。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十万円で浮かばれないというワケだ。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシはお経をケンヤクするから、奴め、なかなか浮かばれないな」　ソノ子は歯をとりあげて、見ていたが、怖れる様子は一向になかった。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教会は人里はなれているので、浮かばれない死人の霊魂がいつも好んであらわれたようである。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のほうはそれで都合がよかろうが、おれのほうは浮かばれない。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ではあのお部屋にはあのお方の、いまだに浮かばれない修羅の妄執が、黴と湿気と闇とに包まれ、残っておることでございましょうよ。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大威張りをした手前、なんとか恰好をつけないと浮かばれない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつが晴れないと浮かばれないんだ。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラコさんは、いよいよ浮かばれない気持になって、みっともなく舌をもつらせながら、「ねえ、タフさん、悦二郎氏、……このごろ、また、忙しいのでしょう？",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時、「お通、その先を言うのだ、――隠してはお照が浮かばれないぞ」　縁側へ来たのは、主人の石井依右衛門でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっ母さんなんて、言って貰い度かァありませんよ、先刻掴み合いをしたばかりのお前さんを通しちゃ、娘だって浮かばれないにきまって居る」「でも」「さァ、帰って下さい、大夕立が来なきゃ、舞台の上で、お前さんが掴み殺したかも知れないじゃないか」　母親のお槇は、頑として関所を据えるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "夕立の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "その堂というのは浮かばれない堂という意味で、そこへ首を入れられるともう一遍生れて来ることが出来ないという、チベット人の信仰からこういう残酷な事をするのです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしなければ、お父さまお母さまの魂は決して浮かばれないのです。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、後深草に出家されては、生涯浮かばれない側臣がたくさんある。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれどもだけは浮かばれないよ　今日だけとは限らない。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "高倉の宮の御謀議むなしく、うかばれない武士たちの亡魂が、秋のかぜの暗い空を、啾々と駈けているかと、性善坊は背を寒くした。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
