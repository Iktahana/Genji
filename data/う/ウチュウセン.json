[
  {
    "uuid": "8a1e5d1a-a3ad-5079-80ee-f15c9f1d961a",
    "entry": "宇宙線",
    "reading": {
      "primary": "うちゅうせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
