        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "汝を贔屓に目が眩んで、今までは知らなかったが、海に千年、川に千年、劫を経た古狸、攫出してお汁の実にする、さあ失せろ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁夫二　（俊寛を突きやり）失せろ、流人め。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐しかったら、一刻も早く出て失せろ」　坊主はまるで青鬼のように、半分死にかかった人間の前でたけり立った。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人攫い奴、失せろ、失せろ！",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと出て失せろつちふに！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「出て失せろ、出て失せろ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた旗よ、失せろ！",
              "citation": {
                "source": "組合旗を折る",
                "author": "永崎貢",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴さまゆえ、このわしの迷惑――気違い、失せろ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げたければ、車掌に謝った上で逃げ失せろ。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今起きるよ」「邪魔だから、消えて失せろい」　馬吉は渋々起き上ったが、熊さんはツマミだしかねまじき殺気立った見幕であるから、馬吉は益々物欲しくなるばかりである。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えて失せろといったら、分らねえのか」　馬吉はあきらめて歩きだした。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっさとこの家から出て失せろ……」　女房の権幕に作造はやおら起ち上った。",
              "citation": {
                "source": "おびとき",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "270　　　１．とつとと出て失せろ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．荷ごしらへをして、出て失せろ。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "良心の幽霊なんか過去の忘却の中へ消え失せろ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと消えて失せろッてんなら、あんまり畳のあったまらねえうちに、いい加減で引揚げやしょう。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゝ、百の仔羊よ、牧歌の中の金髪兵士達よ、水路橋よ、痩衰へた灌木林よ、失せろ！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢餓の祭り　　俺の飢餓よ、アンヌ、アンヌ、　　　驢馬に乗つて失せろ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の飢餓よ、アンヌ、アンヌ、　　　驢馬に乗つて失せろ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミルノーフ　出て失せろ！",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "木華里　さあ、出て失せろ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっさと失せろっ」　荷物あらための出役と、上り下りの旅人のむれが、黒い影にもつれさせて、わいわいいう騒ぎだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おめえこそ早く失せろ。",
              "citation": {
                "source": "命",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "往く所があつたら何處にでも失せろと言ひ、先きに立つて足早に歩いていつたが、あん子は、わあ、と聲を擧げて唏き出してミツのあとに尾いていつた。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤八　　やいやい、しつッこ過ぎるから突き出したんだ、さっさと失せろ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だ失せろだと、失せてやるから失せるようにしろ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、さっさと出て失せろ！",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、何物かが胸のなかの堰を切りでもしたように、まるで別人のような上ずった聲で、ヴェリチャーニノフは急に喚きだした、「ええ出て失せろ、その人の腹を探るような小きたない話と一緒に、とっとと出て失せろ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたにお願いと云うのはね、妾の同業の厚化粧ぐみをね、彼奴たちはどうせろくなことはやらないのさ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを嫌いなくらいなら、どうせろくなやつじゃないぜ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
