        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "見ているうちに小舟が一｜艘、磯を離れたと思うと、舟から一発打ち出す銃音に、游いでいた者が見えなくなった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しもう大時計が打ち出すので、市民はその方に気を取られて外道奴が何をするやら、見てゐることが出来なかつた。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "専用の装置を使えば、文章を点字にして打ち出すことも可能だ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "守備範囲としては、レーザーライタで打ち出すところまでを念頭に置き、すぐにも写植に取って代わるものとは考えていませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "受け取った側は、手許のプリンターで打ち出すこともできます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "校正を経て完成したデータを、点字プリンターにかけて打ち出す。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが時計の歯車をもっと速く回そうとするのなら、かつてオレを苦しめた編集にまつわるあれこれを解消する手立てを早く打ち出す必要がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "城から打ち出す鉄砲が烈しいので、島が数馬の着ていた猩々緋の陣羽織の裾をつかんであとへ引いた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀鎗弓矢の盛んに用いられた世に刀鎗を神威ありとしたごとく、石器時代には斧や槌が武威を示す第一の物だった遺風で、神威を斧や槌で表わす事となり、厨神大黒天もなかなか武備も抜かっておらぬという標しに槌を持たせたのが、後には財宝を打ち出す槌とのみ心得らるるに及んだと見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川台場沖あたりで打ち出す祝砲がかすかに腹にこたえるように響いて、子供らは往来でそのころしきりにはやった南京花火をぱちぱちと鳴らしていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はやり出した吾妻拳を打ち出すものがある。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭が朦朧として來て胸が激しく波打ち出すと仰向きになつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし地球上の一点から弾丸を打ち出すとすれば、それが閉鎖した曲線軌道を描く場合ならば再び元の出発点に帰ってくるであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの足が壕底に着くや否や穹窖より覘を定めて打ち出す機関砲は、杖を引いて竹垣の側面を走らす時の音がして瞬く間に彼らを射殺した。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷花のついた窓硝子にまっ青な月の光が一面にさし、夜中十二時になると打ち出すクレムリ時計台のインタナショナルの音が厳寒をふるわして室内にまで響いて来た。",
              "citation": {
                "source": "坂",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしセントー・ハヤオのことが一層気にかかるので大急ぎで短波長の送受信機の前に座って受話器を耳に当てたり、送信機の電鍵を叩いたりしましたが、機械はたしかによく作働しているのにも拘らず、何時まで経ってもセントー・ハヤオの打ち出す無線電信の応答は聞こえませんでした。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "プログラムやデータを保存しようとすれば、これまではアルテアにテレタイプをつなぎ、紙テープに打ち出すしかなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした機能を強化して、いったんキーボードから入れた文章を後から編集、修正し、これをきれいに打ち出すことのできるワードプロセッサーに需要があることは、すでに明らかになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙テープを打ち出すタイプライターとブラウン管ディスプレイを備えたＰＤＰ―１の本体は、キャビネット三台分ときわめて小さく仕上がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらたに用意されたプリンターの側にもＲＯＭを組み込めば、漢字仮名交じりの文書を打ち出すこともできるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―９８０１の強化のポイントは、日本語が使えるビジネス機という性格を鮮明に打ち出すことに置いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "折りしもあれ、この教室を包む一棟の中の、遥かに遠くの小使室で打ち出す時計の音が、陰に籠って……一ツ……二ツ……三ツ……ボ――ン……ボ――ン……ボ――ン……ボ――ン……ボ――ンボ――ンボ――ンボ――ン…………ボオ――オオ――ンン……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉行の手から、鉄砲を打ち出す頃になると、暴民は、退却しかけて、浮浪の徒は、侍屋敷の人々と、町方の人足のために、食い止められてしまった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具止ると、筆を墨斗にをさめ、札を肩にかけ、立上り、右に柄杓を持ち、左に笠を持ち、斜に下手に向ひて、柱に記しし歌を読み「順礼に」にて五右衛門が打ち出す手裏剣を右手の柄杓に受け止め、さてその柄杓を左手に取り直してさし上げ、右手を腰の番ひにあて「御報捨」と云ひての見え、これも立派なり。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは平和、次ぎに小口径の猟銃を用いて軽々に散弾を撒き、ついに攻城砲の恐ろしきを打ち出す。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折しもあれやバロン山で打ち出す三発の号砲は、午後二時より催される謝肉祭仮装大行進発程の合図。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、これだ」　富士男のうちだすつるはしとともに、ぞろぞろと大きな岩がくずれて、そこに洞然たる一道の穴があらわれた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこか天じょう穴があるとか、壁の下の方に穴があるとかして、そこからぴゅーッと刃物のついた矢をうちだすのじゃないですかな。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人工細胞破壊銃というのは、その名のとおり、人工細胞にあてると、それをたちまちばらばらに破壊しさる装置で、強力に加速された中性子の群れを、うちだすものだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちだす砲声も銃声も、いよいよさかんになり、そのはげしい砲火のため、耳もきこえなくなりそうだ。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
