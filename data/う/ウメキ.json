[
  {
    "uuid": "21b1d02e-ea2c-5b74-a255-511db86bab7c",
    "entry": "呻き",
    "reading": {
      "primary": "うめき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "moan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しばらく經つて、とんと輕く足踏みして、おもむろに呻き出すは、「是は阿波の鳴門に一夏を送る僧にて候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピークは、病人の入る処じゃねえや」「ピークにゃ、船長だけが住めるんだ」　彼等は、足下から湧いて来る、泥のような呻き声に苛まれた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一とき聞くに堪えないような失望の呻き声が聞える。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二箇月位もぶつ通しに苦しんでゐたが、その呻き聲と云つたら、ずつと離れた農場にまで聽えたくらゐであつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、私達は、花子の絶望的な呻きが彼女の唇から洩れるのを聞いた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その母も、流石に兄も、私も、そして附添ふ若い一人の看護婦も、高い熱でさらさらに乾いた灰のやうなお前の顏色を見、夢中の口から洩れる呻き聲を聞いた時、お前の上に嚴かに死が迫らうとしてあるやうな豫感に打たれて、堅く口を噤んでしまつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、消毒藥の何處となく漂ふ病室の中はお前の呻き聲に靜寂が破られるだけだつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術前の體の消毒の爲めに運搬車が來て、一先づお前を消毒室へ運び去つて行つた時、急に呻き聲の消えた靜かな病室の中に、私は兄とお前の母と顏を見合せてぢつと押し默つてしまつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さま／″＼の溜息、呻き、訴える声、堪え難いしかめッ面などが、うつしこまれたように、一瞬に、病室に瀰漫した。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の病室でも、やかましく呻きわめく騒音が上りだした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呻きはつゞいて出てきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、それと一緒に、又哀れげな呻きが出てきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どいつも、こいつも弱みその露助みたいに呻きやがって！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、鈍感なセメント樽のような動物は割れるような呻きを発して、そこらにある水桶を倒して馳せ出た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の大きい牝豚は仲間の呻きに鼻を動かしながら起き上って、出口までやって来た。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹が跳ね、騒ぎだしたのにつれて、小屋中の豚が悉く、それぞれ呻き騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その時には、丘にも谷間にも豚群が呻き騒いで、剛い鼻さきで土を掘りかえしたり、無鉄砲に馳せまわったりしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚が野に放たれて呻き騒いでいる理由が分ったのであった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚は呻き騒ぎながら、彼等が追いかえそうと努めているのとは反対に、小屋から遠い野良の方へ猛獣の行軍のようになだれよった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　二週間ほどたって、或る日、健二が残飯桶をかついで丘の坂路を登っていると、彼の足音を聞きつけて、封印を附けられた宇一の小屋から二十匹ばかりが急に揃って、割れるような呻きを発して、騒ぎだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "饉え渇して一時に餌を求めている呻きだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "露西亜語を話す者のでない呻きが倒れたところから聞えてきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　助けを求める切れ／″＼の呻きが井村の耳に這入ってきた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は巨大な鉱石に耳をつけて息子の呻きがしやしないか神経を集中した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは、呻きも、虫の息も、何等聞えなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこからは呻きも叫びも何等聞えなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞ましい雄獅子が自分と妻の致命的な傷口を嘗め労わりつつ呻く、絶体絶命の呻きです。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身肉寒さに噛まれて鉢特摩の華の如く折裂し、呻きの声はただ※嘶叱、虎虎婆の二音が発せられるだけじゃ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦女等は船の動くと与に船暈を発して、かつ嘔き、かつ呻き、正体無く領伏したる髪の乱に汚穢を塗らして、半死半生の間に苦悶せり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "交番も程遠く近隣に人無ければ、誰ありて介抱するもの無く、一杯の水を恵むもあらず、屑屋は人心地も無く呻きおりぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
