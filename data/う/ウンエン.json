        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すべての物体は雲煙のごとくまた妖怪｜変化と類を同じうするだろう。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その末はいつとなく模糊たる雲煙の中に没しているのが誘惑的である。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある場合には紙面の上下に二つの場面の終わりと始めとが雲煙を隔ててオーバーラップの形で現われることもあるであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺から西方｜雲煙の表に夕陽の残光を受けて立つ日本アルプスの重畳は実に雄麗壮大の眺めであった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡す限り雲煙渺茫たる大空に漂蕩して、西も、東も定めなき今、何時大陸に達して、何時橄欖島に赴き得べしといふ目的もなければ、其内に豫定の廿五｜日も去つたならば、櫻木大佐も終には覺悟を定めて、稀世の海底戰鬪艇と共に、海の藻屑と消えてしまう事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの雲煙｜模糊の大陸が佐渡だとすると、到着までには、まだ相当の間がある。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいほうの山脈地帯は、れいの雲煙模糊の大陸なのである。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ人の偶然事のみとして雲煙看過するの事件も、仔細に観来れば奥底必ず不動の磐坐のあるありて、未だかの長汀波上の蜃気楼台の如からず。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も怒りに顫へてその面を睨みつけると不思議や忽ち眼前に一切は雲煙と化して、恐ろしい二つの眼が星の如くに光るかと思ふ間に、全然意識は消え失せてしまつた。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈善は人のためならず、妾は近頃になく心の清々しさを感ぜしものから、譬えば眼を過ぐる雲煙の、再び思いも浮べざりしに、図らずも他日この女乞食と、思い儲けぬ処に邂逅いて、小説らしき一場の物語とは成りたるよ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "混沌の大気の中に、雲煙が凝つてアミーバが形成される概であつた。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿島灘は雲煙に見えざれど、近く濤聲の甚しくなりたれば、興盡きて歩をかへせり。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "近山は濃く、遠山は淡く、雲煙浮動して景致を添ふ。",
              "citation": {
                "source": "白河の七日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "満足にポストの中へはいっており、宛名も正確に書いてあるとしても、それが雲煙万里を隔てた目的地へ間違いなく行きつく可能性は甚だ乏しいような気がする。",
              "citation": {
                "source": "雑文一束",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち一方なる肉慾的慾望は不手際なる蔓を以てこの世に執着し、他は雲煙模糊たる霞をとほして遥かなる清浄の空へ翼を伸さんものと悶掻いてゐるのだ。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲煙の多いので聞えてゐる。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨降りだと、雲煙が深く山を封してゐるから、折角山へ入つても山を見ることはできず、よほど厳重な雨支度をしてゐない限り、からだはびしよ濡れになつて、大概の人は風邪をひいてしまふ。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和の時こそ、供花燒香に經を飜して、利益平等の世とも感ぜめ、祖先十代と己が半生の歴史とを刻みたる主家の運命｜日に非なるを見ては、眼を過ぐる雲煙とは瀧口いかで看過するを得ん。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その梢には石英のやうに、角張つた雲煙が横はつてゐる。",
              "citation": {
                "source": "支那の画",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "百里の距離を作るには日本画では、先ず近景を描き、中景を描き、而して百里の先きを同じ大きさにおいて一幅の中に収めてしまい、その間には雲煙、あるいは霞を棚引かせて、その中間の幾十里の直接不必要な風景を抹殺してしまう。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "観者はその雲煙のうちに幾十里を自ら忍びて、そこに地球の大きさを知るのである。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い楓葉につつまれたる白布の滝が静かに落ち、その周囲は雲煙を以てぼかされた。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、西洋人が日本画家の一本の筆先きから生れる竹石、雲煙の妙に驚くのと同じ種類の驚きで私は眺めていた。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "四条派の絵画も近代の展覧会場では全くうすぼけた存在に過ぎないけれども、一たび、うす暗い床の間に懸ると、忽ち滝は雲煙の間を落ちて行く。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、万里の雲煙をへだてたヨーロッパにいて知るとは、なんという化物のような男だろうか。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雲煙邱壑は、紛れもない黄一峯です、癡翁を除いては何人も、これほど皴点を加えながら、しかも墨を活かすことは――これほど設色を重くしながら、しかも筆が隠れないことは、できないのに違いありません。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この雲煙の濃淡をご覧なさい。",
              "citation": {
                "source": "秋山図",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖も立ち罩めた雲煙の中に、ややともすると紛れそうであった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
