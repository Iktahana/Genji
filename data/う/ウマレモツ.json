          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "人皆それぞれに欠点・混濁・偏歪・昏暗のあるもので、一切の悪・一切の愚・一切の過・一切の苦は、各自が生まれ持つ形質気質の欠処・濁処・偏処・昏処が縁となって、世に出て来て幸いに持つところの善も知も功も楽をも、滅茶苦茶にしてしまうのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の生まれ持つ人の人である根本のもの、即ち禽獣と異なる根本のものを湛えて、之を損傷しないで、本性に率い工夫純熟する「忠」が存在し、発して皆妥当する（節に中る）。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
