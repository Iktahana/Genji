        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それでスイスなどで兵隊商売、即ち戦争の請負業ができて、国家が戦争をしようとしますと、その請負業者から兵隊を傭って来るようになりました。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "市原は、神戸で相当な請負業を営んでいる彼女の実弟であった。",
              "citation": {
                "source": "墓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしよし面白い面白い、ひとつこいつの手に従いて、殺人請負業を開店いてやろう。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に建築請負業もやっているし、漁船も持っている。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は建築請負業としては別荘造りが専門で、推古から現代に至る木造建築に秘密というものはない、自分はそのあらゆる様式を再現する能力があると宣伝している。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏ君は当時は、私立の一小請負業者に過ぎなくて、坪三十円か四十円の借家普請まで引き受けたという程度の建築家であった。",
              "citation": {
                "source": "防寒戸",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に彼はあれ程多数の固定読者を持つことが出来たので、恐らく彼は、自分の読者に対して、社会的な教師として、常識的な総合教育の請負業をやったのだと見ていい。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も喜ぶものは農民ではなくて、土木請負業者やセメント会社の重役などだろう。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見して土木請負業と思える万端と、少しかわって特色のある眼つきとそのとりなしとは、ひろ子の興味をひいた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の請負業みたいなもんです。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人請負業よりはおだやかでもあり、いろっぽくもございますね」　ちょびひげ社長は短い足を組み、腕を組んで、その右手でパイプを口にささえながら、ニヤニヤと笑った。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この際、殺人請負業者にご用がおありだと思いましてね」　相手もすましている。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「人殺し請負業さ。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殺人請負業」ほどではないにしても、けっして刑罰をのがれられるものではない。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局は汲取請負業が少額であるためであるが、時折、市役所に行く度に、衛生課長の杉山氏に愚痴を述べ立ててみるのだが、気の毒だが予算がないので何ともならない、出来なければやめて貰う外はない、の一点張りで、埒が開かない。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "新仲町玉井組明治三十九年四月二日求之本品ハ請負業開業記念トシテ愛智時計店ヨリ買収セリ　一金四円七拾銭也営業開始ハ二月十九日　金五郎は、微笑した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これを荷主に取り次ぐのは、請負業者である。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「狡猾にも、請負業者中のスキャップ、吸血鬼ともいうべき暴力団長と結託して、哀れなる沖仲仕の膏血をしぼる」などと書き、暗に、友田喜造を諷した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負業者、小頭、仲仕の多くの人々が、苦心して、協力した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時計は『花と龍』の中に出て来るもので、裏には、父の字で、新仲町　玉井組明治三十九年四月二日求之本品ハ請負業開業紀念トシテ愛智時計店ヨリ買収セリ一金四円七拾銭也営業開始ハ二月十九日　と書いてあるが、まだ、かすかながら読みとれる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "又世間では哲学者を抽象的概念の請負業者と見て居るものもあるやうだが、なるほど或る哲学者はさうだとも云へるであらうが、中には全くさうでないのもある。",
              "citation": {
                "source": "時の流れ",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手の請負業者がいることは知っている。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
