    },
    "definitions": [
      {
        "index": 1,
        "gloss": "upasika (devout female lay follower of Buddhism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "優婆塞優婆夷の合唱にかくれて、ひそかに始末する魂胆であつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "化石もすらむ秋の木は骨立ち強に呼吸つまり、天つ御法のおん宣告に、拗ねては、櫨も葉こそ縒れ、孕婦ながら茴香は優婆夷か、悩む色もなし伴にはぐれし赤蟻の飢ゑて足悩ゆむ湿り地に、憐み顔のおとどひは茎も軟らに額づきて、手弱腕にそと乗せつ、弘誓もさこそ、あゝ茴香。",
              "citation": {
                "source": "茴香",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "」仏弟子の位は第一比丘、第二比丘尼、第三｜優婆塞、第四｜優婆夷である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "優婆塞優婆夷の合唱にかくれて、ひそかに始末する魂胆であった。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "絢爛な色彩の古画の諸仏、羅漢、比丘、比丘尼、優婆塞、優婆夷、象、獅子、麒麟などが四壁の紙幅の内から、ゆたかな光の中に泳ぎ出す。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、蟹は、「とこやというしょうばいは、たいへんひまなものだな。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鳥右ヱ門にぴつたりあふやうなしやうばいは一つもありませんでした。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、しやうばい女などはそれとはまるで違ふ種だが、やつぱりかならず持つて居る。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの村の子どもたちは、夏休みになってから毎日大池にきて、こちらの村の子どもたちと水あび場をうばいあうのでした。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じぶんのしょうばいは盗人だということをしっかり肚にいれておらんから、そんなことだ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれじゃ、こっちのしょうばいにゃなりません。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こっちのしょうばいというのは何だ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そういう村こそ、こっちのしょうばいになるじゃないかッ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉があって、子供でもねじきれそうな錠しかついておらんというほど、こっちのしょうばいに都合のよいことがあるか。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう村こそしょうばいになるのですね。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「盗人のかしらというのもあんがい楽なしょうばいではないて。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳一君がすばやく、音次郎君の手からかきをうばいとって、ひと口かぶりついた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりしっかりしょうばいをやれよ。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明開化に遅れた自分の暗い村に、このすばらしい文明の利器を売りこんで、村人たちの生活を明かるくしてやろうという希望のランプが――　巳之助の新しいしょうばいは、はじめのうちまるではやらなかった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから巳之助のしょうばいははやって来た。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今はもう、よその家の走り使いや子守をすることはやめて、ただランプを売るしょうばいだけにうちこんだ。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "巳之助はお金も儲かったが、それとは別に、このしょうばいがたのしかった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは嘘をいってしょうばいをしたことにはならない」と巳之助はひとりごとをいった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプ屋のしょうばいはいらなくなるだろう。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「電気というものは、長い線で山の奥からひっぱって来るもんだでのイ、その線をば夜中に狐や狸がつたって来て、この近ぺんの田畠を荒らすことはうけあいだね」　こういうばかばかしいことを巳之助は、自分の馴れたしょうばいを守るためにいうのであった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "へいぜいは頭のよい人でも、しょうばいを失うかどうかというようなせとぎわでは、正しい判断をうしなうものである。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い自分のしょうばいが失われるからとて、世の中の進むのにじゃましようとしたり、何の怨みもない人を怨んで火をつけようとしたのは、男として何という見苦しいざまであったことか。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中が進んで、古いしょうばいがいらなくなれば、男らしく、すっぱりそのしょうばいは棄てて、世の中のためになる新しいしょうばいにかわろうじゃないか。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの、しょうばいのやめ方はこれだ」と巳之助は一人でいった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの、しょうばいのやめ方はこれだ」　それから巳之助は池のこちら側の往還に来た。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
