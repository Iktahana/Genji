        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ちきしやうめ、こんどあいつが、おれと逢つた時、うつとりおれの顏に見とれて、うふふ、おれはもう、あいつが、戀わづらひしたつて知らないぞ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言われて私もまんざらでなく、うふふと笑ってやにさがり、いもの天ぷらを頬張ったら、私の女が、お前、百姓の子だね、と冷く言います。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うふふふふ、と、おたがいに顔を見合わせてわらいました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、何とも言わずに朝子と女の子とを見較べて、うふふふふふと笑った。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この女の子、この間言ったあんたのお嫁さんじゃないの」　島吉は矢張り、うふふふふふと笑って、「奥さんにおじぎしないかよ」と、女の子に命令するように言った。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のさのさのさ、頭で廊下をすって来て、夫人の枕に近づいて、ト仰いで雨戸の顔を見た、額に二つ金の瞳、真赤な口を横ざまに開けて、「ふァはははは、」「う、うふふ、うふふ、」と傾がって、戸を揺って笑うと、バチャリと柄杓を水に投げて、赤目の嫗は、「おほほほほほ、」と尋常な笑い声。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洲の股もめでたいな、うふふ、」　と北叟笑みつつ、坂下の嫗は腰を捻った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸声に、「ふァふァふァ、」「うふふ、」「あはははは。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うふふふ、我を如燕になさる。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うふふ、うふふ、うふふふふふ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と片手に猪口を取りながら、黒天鵝絨の蒲団の上に、萩、菖蒲、桜、牡丹の合戦を、どろんとした目で見据えていた、大島揃、大胡坐の熊沢が、ぎょろりと平四郎を見向いて言うと、笑いの虫は蕃椒を食ったように、赤くなるまで赫と競勢って、「うはははは、うふふ、うふふ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "えッ、いや、あ、あ、チ、あははははは、はッはッはッはッ、テ、ウ、えッ、えッ、えッ、えへへ、うふふ、あはあはあは、あは、あはははははは、あはははは。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お伴しましょうかね」「うふふ……」　君勇は肩で笑って、「――どこまで……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふふ……」　女は笑いながら、電話を切った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふふ……」　宮子は意味ありげな笑いを、蓮ッ葉に笑いながら、鶴雄を誘って曲り角を折れて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふふ……」　と、からかうような洒落を言って、溜飲を下げた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　弓子はそんな小田を見て、うふふ……と笑った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食べさせるったら、喜んでついで来よった」　針助はうふふ……と、下卑た笑い声を立てた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり沢山持ち出すと、おふくろに叱られちゃうけど……うふふ……」　信吉も何となく空虚に笑い、それで約束が出来たのも同様だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄男の方を、恐いと思った事なんか一度もないわ」「それが間違いだったという事、やがて気がつくかも知れない」「うふふ……」　冴子は、信吉には意味の判らぬ笑いを笑って、「――あたし今迄人を好きになった事がないのよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘノモチン、という」　と言いかけて、うふふふと笑ってしまいました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちきしやうめ、こんどあいつが、おれと逢つた時、うつとりおれの顔に見とれて、うふふ、おれはもう、あいつが、恋わづらひしたつて知らないぞ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うふふふふ、とおたがひに顔を見合はせて笑ひました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私のあわてて騒ぐ様子が、よっぽど滑稽なものだったと見えて、嫁は、膝の上の縫い物をわきにのけ、顔を膝に押しつけるようにして、うふふふと笑い咽んでしまいました。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふふ、死骸じゃよ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君も同じ思ひと見えて、顔を赤くし、うふふと笑ひ、「僕もね、ひとりぢや我慢も出来るんだが、君の顔を見ると、飲まずには居られないんだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
