        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "空には今日も浮雲が四抹、五抹。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く澄み透った空では浮雲が次から次へ美しく燃えていった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑まだ私などが文筆の事にたずさわらなかった程の古い昔に、彼の「浮雲」でもって同君の名を知り伎倆を知り其執筆の苦心の話をも聞知ったのでありました。",
              "citation": {
                "source": "言語体の文章と浮雲",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治の言語体文章に就ての美妙齋君の功績は十二分に之を認めなければならぬのでありますが、二葉亭主人の「浮雲」が与えた左様いう感じも必ずしも小さい働ではないと思います。",
              "citation": {
                "source": "言語体の文章と浮雲",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまあただ文章の上だけの話でありますが、其から「浮雲」其物が有した性質が当時に作用した事も中々少くはなかったように覚えています。",
              "citation": {
                "source": "言語体の文章と浮雲",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日置いて九日の日記にも「風強く秋声｜野にみつ、浮雲変幻たり」とある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い町を辿つて人家を離れると、渓を隔てゝ屏風の如く黒く前面に横はる杣山の上に月現はれ、山を掠めて飛ぶ浮雲は折り／＼其前面を拭ふて居る。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は昨夜海に浸つて、全濡になつた儘、黎明の風に寒相に慄へて居る、日出雄少年をば膝に抱上げ、今しも、太陽が暫時浮雲に隱れて、何となく薄淋しくなつた浪の面を眺めながら、胸の鏡に手を措くと、今度の航海は初から、不運の神が我等の身に跟尾つて居つた樣だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠅の唱歌春はどこまできたか春はそこまできて櫻の匂ひをかぐはせた子供たちのさけびは野に山にはるやま見れば白い浮雲がながれてゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色、黄色、意気で高尚で、しとやかな、茴香のいろ、卵いろ、「思ひ出」のいろ、好きな児猫の眼の黄いろ、浮雲のいろ、ほんにゆかしい三味線の、ゆめの、夕日の、音の黄色。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が山上の浮雲よりも早く消え、汝が山腹の電影よりも速に滅する浮世の英雄、何の戯れぞ。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮雲には私も驚かされた。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し「浮雲、二葉亭四迷作」といふ八字は珍らしい矛盾、稀なるアナクロニスムとして、永遠に文藝史上に殘して置くべきものであらう。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮雲に心理状態がゑがかれてゐるやうな、貧血な、神經質な男ではない。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮雲ひとつ無い空だ、めらめらと燃える樣にとも、または、死にゆく靜けさを持つたとも、いづれとも云へる眞夏の空だ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "夏の寂寥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで少時立留って、浮雲のただよう形、熟と此方を視めたが、思切った状して去った。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また鄒陽の書に、〈蛟竜首を驤げ、翼を奮えばすなわち浮雲出流し、雲霧｜咸集まる〉とあれば、漢の世まで、常の竜も往々有翼としたので、『山海経』に、〈泰華山蛇あり肥遺と名づく、六足四翼あり〉など、竜属翼ある記事も若干ある。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』は明治の文学の中で、いろ／＼な意味に於てすぐれた作だが、これがロシア文学の影響を受けた作であるといふことは、今では誰も知らぬ人はない。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』だの、『いちご姫』だのゝ言文一致に満足せずに、『二人女房』を書いた。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭の『浮雲』は、其頃、文壇的に評判があつたといふほどでもなかつたが、それが一種の深い印象を当時の文学書生の群に与へたといふことは争はれなかつた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』――心理描写――ロシヤ文学、とてもあの細かい彫刻のやうな筆致は真似が出来ないと思はれてゐた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　二葉亭が書いた『浮雲』の言文一致はかれを促がして『二｜人女房』を書かしめた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』にも満足が出来なかつたらしかつた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これを『浮雲』と比べて見る。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮雲』のやうな内容ある作品が其時代に出たといふことが不思議で、作者の考一つで人物を生かしたり殺したりすることの出来る時代には『二人女房』でもすぐれた立派な作品であつたに相違なかつた。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処が『浮雲』の作者の真面目と違つてゐる処で、かれは『芸術は人を娯ましめざるべからず』といふ古いセオリーに全く捉へられて居たのである。",
              "citation": {
                "source": "尾崎紅葉とその作品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            }
          ]
        }
