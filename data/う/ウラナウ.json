    "definitions": [
      {
        "index": 1,
        "gloss": "to tell someone's fortune",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大路ゆく辻占うりのこゑ、汽車の笛の遠くひゞきたるも、何とはなしに魂あくがるゝ心地す。",
              "citation": {
                "source": "月の夜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　神戸――Ａオリエンタル・ハウスの踊子が私を占う。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一例は第一部でグレエトヘンが恋の成否を占う花はステルンブルウメと原本にある。",
              "citation": {
                "source": "訳本ファウストについて",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからして虎は人を襲うに今度は誰を食うとちゃんと目算が立ちおり、その者現に家にありやと考えもし疑わしくば木枝を空中に擲て、その向う処を見て占うという。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンボジア人言うは虎｜栖より出る時、何気なく尾が廻る、その尖を見て向う所を占う（アイモニエー『柬埔寨人風俗迷信記』）。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎はなかなか占いが好きで自ら占うのみならず、人にも聞いた例、『捜神後記』に曰く、丹陽の沈宗卜を業とす、たちまち一人｜皮袴を著乗馬し従者一人添い来って卜を請う、西に去って食を覓めんか東に求めんかと問うたんで、宗｜卦を作し東に向えと告げた。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "占う者は常にその墓の上に、黄いろい気が数丈の高さにのぼっているのを見た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に望気の法だけで鉱山の有望無望を考定するのは愚かであるが、既に何等かの物があれば又自然と何等かの気が有る理屈であるから、気を望んで山を占うのも一理無いことではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の占星の術は星の位置と他星との交渉と、光威とその付近にたちこめる霞気の類との状態に照らして人事や運勢の吉凶を判断するのであって、星を占うという語と共にしばしば支那の書に於いて遭遇するところである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂の陣（冬の陣、夏の陣）の起こる前に当たって気が騰ったことは余程著しかったと見えて、望気の術を知る人が指摘したのではなかったが大いに驚異して、そして占うのに焦氏の『易林』を以ってしたという記事が我が史上に見えている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルコ・ポロの紀行に、宋帝占うて百の眼ある敵将にあらずんば、宋を亡ぼし得ずと知ったところ、元将｜伯顔の名が、百眼と同音で、宋を亡ぼしたとある。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "その妻が後世子孫の栄枯を占い言えと勧めたので、占うと十代めの孫はきわめて貧乏と判った。",
              "citation": {
                "source": "易の占いして金取り出だしたること",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻がそれを救う法ありやと問うたから、また占うて、某の年月日に本府の太守が梁が落つる厄にあうべしと知った。",
              "citation": {
                "source": "易の占いして金取り出だしたること",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇で占う事、『淵鑑類函』四三九に、『詩経類考』を引いて、江西の人、菜花蛇てふ緑色の蛇を捕え、その蟠る形を種々の卦と名づけ、禍福を判断し俚俗これを信ずと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "古ケルト人もっともこれを信じ、特別の白馬を公費もて神林中に蓄い、大事あるに臨みこれを神車の直あとに随わしめ、その動作｜嘶声を察して神意を占うた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『郷土研究』一巻八号斎藤真氏説に、陸前の駒ヶ嶽、毎年消え残りの雪が白い奔馬形を現わす、これを見て年の豊凶を占う農夫もある由。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にはシセロ説に寝牀の下に鶏卵一つ匿されあると夢みた人が、判じに往くと、占うて、卵が匿され居ると見た所に財貨あるべしと告げた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "利口な人ならば、ここらでもう見切りをつけて、二度と大門をくぐらない筈であると、八橋は彼の未来を占うように言った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入などは勿論ここらの一角とは没交渉で、新宿行の電車が満員の札をかけて忙がしそうに走るのを見て、太宗寺の御閻魔様の御繁昌を窃かに占うに過ぎません。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女はいわゆる狐使いのように、自分の狐を放して他人に憑かせるなどということはしないらしく、唯その狐の教えに依って、他人の吉凶禍福や失せ物、または尋ね人のありかを占うに過ぎないのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は初め当時全盛のワルレンスタインのためにその運勢を占う占星図を作製したのであるが（第十四図）、後にはついに占星学上の計算をすることを謝絶するに至ったということはケプラーのために特筆すべき事実である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十四図　ケプラーの作ったワルレンスタインの運勢を占う占星図。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫覡を時とりや（時を取る人）または、えかとりや（日を取る人）というところから見るときは日や時の吉凶を占うところから来たようでもあるが、日本語に夢解きという言葉のあるのを見るとまた解くという動詞の名詞形「解き」から出たようでもある。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもろねやがりぎや時とたるまさしやおふれ　よそわてちよわれせるむ　ねやがりぎやきやのうち　ぬきまるが時とたるまさしやぐすく二ぐすく時とたるおどん二おどの時とたる　おもろねやがりは尚真王時代の人で日の吉凶を占うに妙を得た人であった。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには蝋燭の灯の炎の靡く方嚮によって人の運命を占うという老婆が、じめじめした薄暗い部屋に坐りこんでいて、さっそく葉子の身の上を占いにかかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、それでその日の運命を自ら占うのだという御幣をかついでいる。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――や、除夜の鐘や、そやそや、……うちの商売もんで、来る年の運勢を占うたげまひよ、それを途々考へて来たんや」　彼は立ち上つて、はい、はい、お狐さまと云ひながら、狐の檻を部屋に運び入れた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭占判断といって、六文銭で吉凶禍福を占うその次第書を、駿河半紙二切り六枚綴の小本に刷って、それを町の盛場で一冊三銭に売るのだ。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくあれは占うまでもなく、水晶さまにお伺いしないでも口からつるつると出て来たことなんだ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、お父さんは笑いながら、「なに、とんまの六兵衛がうらなうって？",
              "citation": {
                "source": "とんまの六兵衛",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            }
          ]
        }
