    "definitions": [
      {
        "index": 1,
        "gloss": "restlessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅前でうろうろしている。",
              "source": "幻辞"
            },
            {
              "text": "うろうろするよりさっさと決めてください。",
              "source": "幻辞"
            },
            {
              "text": "彼はそわそわしながらうろうろしていた。",
              "source": "幻辞"
            },
            {
              "text": "部屋の中をうろうろ歩き回った。",
              "source": "幻辞"
            },
            {
              "text": "スーパーでうろうろ探し物をしている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "きょうこの部屋で海賊の打ち合せをしようと思ってね」　私は馬場の興奮に釣られてうろうろしはじめ、蒲団を蹴って起きあがり、馬場とふたりで腐りかけた雨戸をがたぴしこじあけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下を出たら、大隅君がズボンに両手を突込んで仏頂面してうろうろしていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は爺さんに捕へられ、もう少しのところで狸汁にされるところであつたが、あの兎の少女にひとめまた逢ひたくて、大いにあがいて、やつと逃れて山へ歸り、ぶつぶつ何か言ひながら、うろうろ兎を搜し歩き、やつと見つけて、「よろこんでくれ！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」となほもその邊を、うろうろ搜し廻りながら、「まつたく、いまのおれのこの心苦しさが、お前にわかつてもらへたらなあ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の火事ならば大勢の人が集まっているであろうに、あたりには人影もなくただ野良犬が一匹そこいらにうろうろしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うろうろ木の高いところを見ていましたしそれに林の前でぴたっと立ちどまったらしいのでした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が牛舎の流しを出て台所へあがり奥へ通ったうちに梅子とお手伝いは夕食のしたくにせわしく、雪子もお児もうろうろ遊んでいた、民子も秋子もぶらんこに遊んでいた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうする詮も知らずに着物をあたためてはあてがい、あたためてはあてがってるのみ、家じゅう皆立って手にすることがなくうろうろしてる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君が帽子と外套を取って来てくれる間を出口でうろうろして、寒い空気に逆上した頭を冷やしていた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険線のすぐ近くまで来てうろうろしているものが存外その境界線を越えずに済む、ということは病気ばかりとは限らないようである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありとあらゆる罪悪の淵の崖の傍をうろうろして落込みはしないかとびくびくしている人間が存外生涯を無事に過ごすことがある一方で、そういう罪悪とおよそ懸けはなれたと思われる清浄｜無垢の人間が、自分も他人も誰知らぬ間に駆足で飛んで来てそうした淵の中に一目散に飛込んでしまうこともあるようである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友はその故郷の停車場でいきなり私のうろうろしてゐるのをつかまへた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳、近侍を呼び止めて、Ｔ「門前にふんぞり七兵衛と申す御用聞がうろうろ致して居る」　と言ってなりひらの方をジロリと睨んで、Ｔ「その七兵衛に斯う申せ」　と言って、Ｔ「お尋ね者のなりひら小僧が拙宅に忍び込んだ」　えッ、となりひら油断なく大刀を掴む。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその中にうろうろしながら、思案に暮れた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、どうぞこちらへ」　入口へ出たお亀がうろうろしながら、新しい女客を奥へ招じ入れようとすると、案内を頼んだ女は少しためらっているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫じゃ猫じゃでも踊りゃあしめえし、手拭をかぶって、浴衣を着て、跣足でそこらをうろうろしているところは、どうしても正気の人間の所作じゃありませんぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がうろうろしてゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして落日を見ようとする切なさに駆られながら、見透しのつかない街を慌てふためいてうろうろしたのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、何やら深刻な顔をして、うろうろして、突然となりの女の局員に、きょうはいいお天気だ、なんて曇っている日なのに、大声で言って、相手がおどろくと、ぎょろりと睨んでやって、立ち上って便所へ行ったり、まるで阿呆みたいになっていたのでしょう。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の日は私も、朝から何となく落ちつかず、さればといって、あの若者達と一緒に山車を引張り廻して遊ぶことも出来ず、仕事をちょっと仕掛けては、また立ち上り、二階の部屋をただうろうろ歩き廻って居ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてペンを握ったまま、目を閉じると、からだがぐいぐい地獄へ吸い込まれるような気がして、これではならぬと、うろうろうろうろ走り書きしたるものを左に。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっして噛まないということは、科学的に証明できるはずはないのである）その猛獣を、放し飼いにして、往来をうろうろ徘徊させておくとは、どんなものであろうか。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "やけくそで、いっそ林銑十郎閣下のような大鬚を生やしてみようかとさえ思う事もあるのだが、けれども、いまの此の、六畳四畳半三畳きりの小さい家の中で、鬚ばかり立派な大男が、うろうろしているのは、いかにも奇怪なものらしいから、それも断念せざるを得ない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中まで檻の中をうろうろうろうろしてゐた狐さへ、をかしな顔をしてねむってゐるやうでした。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐も沢山くしゃみをして起きあがってうろうろうろうろ檻の中を歩きながら向ふの獅子の檻の中に居るまっくろな大きなけものを暗をすかしてちょっと見ました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
