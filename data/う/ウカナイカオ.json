        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "主人は水の中から葉を一枚とってしきりにしらべていましたが、やっぱり浮かない顔でした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房や娘の浮かない顔色をみて、由兵衛は叱るように言い聞かせた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "李は顔色を変えて、「あなたは、どっちも佳い女だとおっしゃるのですが、それは私に言うからでしょ、蓮香さんは月宮殿の仙女だわ、私なんかが、どうしてよりつけるものですか」　と言って浮かない顔をした。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよさんの浮かない顔するのもそれゆえと思えばかわいそうになってくる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作も何となし気が咎めてか、浮かない顔をして、わが家の門をくぐったのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすこしぽかぽか暖かくなってきますと、どうも家にばかりおられませんから」　老人は糟谷の浮かない顔などにはいっこう気もつかず、かってに自分のいいたいことをいっている。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六三郎はやっぱり浮かない顔をして聴いていた。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて三郎さんが、店で遊ぶにも飽きたやうに、浮かない顔をしてこちらへ上つて来られた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきも青木さんが坊ちやんを外の湯へつれて行かれて、もうとつぷりと日もくれかけた、雨もよひらしい夕方を、浮かない顔をしてとぼ／＼手を引いて帰つて来られたときにでも、青木さんがどんなことを考へてゐられた続きかといふ事が、おくみにはちやんと解るやうな気がして、自分までがさびしいやうな心持がした。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊ちやんは、もう絵の本にも疾くにお飽きになつて、足を投げ出して、紙箱の蓋を裂り／＼してゐられたが、やがてもう眠くなつたと見えて、せいのない、浮かない顔をしてお出でになる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木さんは、何か厭な事でもおありになつた続きのやうに、浮かない顔をしてお出でになる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上出来」　と、浮かない顔のワラを高志がもちあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、浮かない顔してんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慶一、なに浮かない顔してんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディジタル・テクノロジーってのは、人間に対する侮辱ですよ」　ワラは浮かない顔つきだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じパッキングにいる温しい女工が、浮かない顔をしていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮かない顔をしていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠原は蒼い、浮かない顔をして室の中に横坐りに坐っていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと学校に樹明君を訪ねる、昨夜また脱線したとかで浮かない顔をしてゐる、話したいことも話さないで帰る、畜舎で新聞を読ませて貰つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけ放した観音開きの扉から、浮かない顔付の娘達がぞろぞろ出て来る。",
              "citation": {
                "source": "七階の住人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俊和尚が浮かない顔をしてゐると思つたら、夫婦喧嘩して奥さんが実家へ走つたといふ、いろ／＼宥めて電話をかけさせる、私と俊和尚とは性情に於て共通なものを持つてゐる、それだけ一しほ人事とは思へない、彼も憂欝、私も憂欝になる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪結いの帰り、今日は寅の日なのを思い出して毘沙門へお詣りに廻ったお初が戻ってくると妙に浮かない顔で何か思案事に心を奪われているという様子である。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りに坐っている姉を突ついてそっと訊くと、「どうもねえ、お父様はおきえさんの籍をいれたいらしいのよ」　と、姉も浮かない顔である。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父は浮かない顔をしながら、その癖｜冗談のようにこんな事を云った。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　一時間の後店の二階には、谷村博士を中心に、賢造、慎太郎、お絹の夫の三人が浮かない顔を揃えていた。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　金花は頬杖をついた儘、浮かない顔色を改めなかつた。",
              "citation": {
                "source": "南京の基督",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は一寸厭な気がして浮かない顔つきだつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　保吉は浮かない顔をしたまま、マソヒズムの意味を説明した。",
              "citation": {
                "source": "文章",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏七月第一審が終結した翌朝、彼の妻は不安とも安心ともつかない浮かない顔をして彼に云った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支倉はとうとう死刑になりましたね」「うん」　牧師も浮かない顔をして答えた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
