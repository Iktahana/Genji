        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「lying face down」である。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「lying face down」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「lying face down」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "lying face down」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "其の順礼のお盥髪さへ、此方に背き、早やうしろを見せて、びしや／＼と行く処を――（見なくとも可いのに）気にすると、恰も油さしがうつ伏せに鉄の底を覗く、かんてらの火の上へ、ぼやりと影を沈めて、大な鼠のやうに乗つて消えた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また老人の義理の妹にあたるクリスチナ・ヘドストロムはうつ伏せになり、兩手をだらりと垂れたまま料理臺の上に横たはつてゐた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、うつ伏せに倒れて、片足が寢臺に殘つた‥‥」「うん、たしかにさうだね。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの床にはうしろの頭蓋骨を打ち碎かれた老婆がうつ伏せに倒れてゐた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、犯人の一撃を受けると、一溜りもなくうつ伏せに倒れてしまつて、小間使のやうに抵抗する隙は全然なかつたものと考へますが‥‥」「君、兇器は見つからんかね？",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の机の上の一輪挿しには椿の枝と葉ばかりが挿さっていて、花はしおれ返ったままうつ伏せに落ちておりました。",
              "citation": {
                "source": "白椿",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の女たちの主人は、うつ伏せになって室の中央に斃れて、もう全く息は絶えており、夫人の方は窓近くに這い寄って、壁に頭を寄せかけていたが大変な負傷で、顔の半面は血まみれになっていて、もう何も云うことが出来ず、ただ呻吟ていたそうである。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつ伏せになって、周囲に噴き上がる飛沫を浴びながら私はのぞき込んだ。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝室へ帰って、暗がりの中を手で探ると夕顔はもとのままの姿で寝ていて、右近がそのそばでうつ伏せになっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつ伏せに倒れているむくろの頭に、見たような五分｜月代がつやつやと光っているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその端にうつ伏せに寝ころんでいるのは、瘠せこけて青ざめた、眼ばかり光る顔に、黒い髪毛をバラバラと垂らした女で、手には一冊の字も絵も何も書いて無い、白紙の書物を拡げて読んでいる。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして全く呼吸が絶えて、うつ伏せに倒れたのを見澄まして引き返して来て、助けて行く風をして馬の上に抱え乗せて、只或る森の中へ這入りました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸子は寢床に走り入ると、うつ伏せになつて、そのまゝ枕に顏をあてゝ泣き出した。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はようやく階段を上がり、そのまゝ畳のうえにうつ伏せになった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "極度の疲労から身体の何処かを悪くしているらしく、弱い子供のように直ぐうつ伏せになって寝ていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は想い出すのだが、父が秋田で百姓をしていた頃、田から上がってくると、泥まみれの草鞋のまゝ、ヨクうつ伏せになって上り端で昼寝していた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はどうしてもうつ伏せにならないと眠れないとき、自分がだん／＼父と似てくるように思われた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか大きい貝だと思いながら、彼は立ち寄ってその一つ二つを手に把ってみると、貝はいずれも殻ばかりで、その中の最も大きい蠑螺はうつ伏せになっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草｜田町の袖摺稲荷のそばにある黒沼孫八という旗本屋敷の大屋根のうえに、当年三、四歳ぐらいの女の子の死骸がうつ伏せに横たわっていたが、屋根のうえであるから屋敷の者もすぐには発見しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに彼女は、『立像』をやって見せることになったが――すると彼女は自分の台座に、醜男のニルマーツキイを選び出して、うつ伏せに寝るように命じたばかりか、顔を胸へたくし込ませさえしたものである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はとうとう卒倒した、幸か不幸か、雨がふつてゐたので雨にうたれて、自然的に意識を回復したが、縁から転がり落ちて雑草の中へうつ伏せになつてゐた、顔も手も足も擦り剥いだ、さすが不死身に近い私も数日間動けなかつた、水ばかり飲んで、自業自得を痛感しつつ生死の境を彷徨した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めはからだを横にして寝て見たが、肩や腕が痛くて堪らんので、こんどはうつ伏せになった。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は一つの行事として男の子供らを裸にし、台所のベンチへうつ伏せに臥かせ、樺の鞭でその背中をひっぱたくのであった。",
              "citation": {
                "source": "逝けるマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い緑色の目をした祖父は一つの行事として男の子達を裸にし、台所のベンチの上へうつ伏せに臥かせ、樺の鞭でその背中をひっぱたくのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝にうつ伏せになつている死骸を調べ了へた巡査が、モンペ姿の婦人の方へ近づいて来た。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつ伏せに溝に墜ちたものや、横むきにあおのけに、焼け爛れた奈落の底に、墜ちて来た奈落の深みに、それらは悲しげにみんな天を眺めているのだった。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝にうつ伏せになっている死骸を調べ了えた巡査が、モンペ姿の婦人の方へ近づいて来た。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつ伏せに溝に墜ちたものや、横むきにあふのけに、焼け爛れた奈落の底に、墜ちて来た奈落の深みに、それらは悲しげにみんな天を眺めてゐるのだつた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は人気に押されておしまいになり、小さいお美しい姿をうつ伏せにしておいでになる。",
              "citation": {
                "source": "源氏物語",
                "author": "鈴虫",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹がハシつて来ました……」　山口はぢつと腹を片手で押へながら、うつ伏せになつてゐた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
