        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "烏木の光ある髮は、美しく凸なる額を圍めり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はもうぼくどうしても探そうとおもって羊飼のミーロと二人で出て来たんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この女は、死ぬんじゃありませんか、というぼくの言葉を純粋に彼女の自殺を心配した上での真実の疑問だと思うだろうか。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうぼくは思ったのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼女はもうぼくの直ぐ眼の前まで来ていて、ぼくが頭を下げると、彼女の方から、「もうお身体は大丈夫ですか」と声をかけた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が友達になってくれとか、尊敬するとか言ったのはそれをきくためだったのだ、そう言えば、昨日彼がぼくに親切にしたり媚びる様な態度を見せたりしたのもこのことの予備行動ではなかろうか、そうぼくは思ったのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうぼくの態度を明日子はどう思ったのであろうか、あるいはそういう態度を見て、自分が嫌われていると思い、そのために一層ぼくに心を惹かれたのであろうか、ぼくが照れてしまうほどいそいそとぼくの機嫌をとり、ぼくに意味あり気な秋波を送っている様に見えた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、このいやな気持は明日子を嫌悪するというよりも、その時明日子をそういう風に思わねばならぬことが又もやぼくが轡川の言を正しいとしなければならぬことになるので、そういうぼくの計算の間違いを認めることがいやだったのである。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうぼくを明日子は何と見たのだろうか。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうぼくだって、こんなに大きくなって、去年連れて行かれた木ぐらいになっているんだもの！",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうぼくたちの別れをつげようあひびきの日の木小屋のほとりでおまへは恐れにちぢまり　猫の子のやうにふるへてゐた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男　　きのうぼくに、竹馬にのりたいって、いってたよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『曾呂利物語』四には伊予の出石の山寺で足利の僧が妖怪を鎮めたとし、主怪をえんひょう坊、客怪をこんかのこねん、けんやのばとう、そんけいが三足、ごんざんのきゅうぼくとす。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "交戦中の捕虜は荷厄介として全て殺してしまうぼくたちも、彼の若い美しさを惜しみ、荷物を持たせる雑役に使うことにした。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっ、とうとうぼくを担いだね」「怒るな怒るな、話はまだあるのだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうぼくにはどうすることもできない。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその若い男は、話に夢中になっていたので、文句も云わず何遍でもやり直して、とうとうぼくを穴の中に圧し込んでしまったのである。",
              "citation": {
                "source": "もくねじ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはきのうぼくに、これはできものだと言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの家の近いところに、花園荘というぼくの友達のやっているアパートがある。",
              "citation": {
                "source": "魯迅さん",
                "author": "内山完造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たか／″＼とあはれは三の酉の月　というぼくの句に、おさわへのぼくの思慕のかげがさしているという人があっても、ぼくは、決して、それを否まないだろう……（「中央公論」一九五六年一月）",
              "citation": {
                "source": "三の酉",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうぼくにとって、出来ることはただ一つ、詩を読んでもらいたいと、答えの代りにおすすめするより外にはないのである。",
              "citation": {
                "source": "詩とはなにか",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでぼくはしかつめらしい顔をして孵卵器の前に立つのだが、腹の空いているときなぞはもうぼくは食いしん坊の大罪を犯しはじめているのだ。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これ以上、かれらに影響されたくなかったし、とにかくかれらとは違うぼくを守り、育てようと考えたのだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぼくらが最初のその出逢いの場所をはなれなかったのは、しかし、たんなる習慣というより、その下界を見下ろし、自分と同じ高さにはただ空漠たる冬空しか見えない位置の感覚に、地上の現実をきらうぼくと彼との趣味が一致したことのせいではないだろうか？",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、そんな二人の少年｜乞食のような姿でわずかな食事をわけあうぼくと山口とに、まるで人目をしのぶ泥棒ネズミのような、ある隠微な、みすぼらしい友情がつながっているのをかんじる。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……突拍子もなく、鋭くそうぼくは思ったりした。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ、どこ行っちゃったのかな」　疲れたので交替してもらうつもりでそうぼくがいうと、ローラーを押していた最年長の一人が、皮肉な顔でいった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口と学校の前で別れ、一人で品川行の都電を待っていると、もうぼくの想うのは夕食のことぐらいしかなかった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
