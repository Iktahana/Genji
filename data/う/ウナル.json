[
  {
    "uuid": "1570875a-e6f0-5ce0-8fa5-c8b50e808154",
    "entry": "唸る",
    "reading": {
      "primary": "うなる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
