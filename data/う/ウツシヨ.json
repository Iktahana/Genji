          "literary": [
            {
              "text": "うつし世の人の母なるわれにして手に触る子の無きが悲しき。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつし世のうつしごとの上では満足出来ず、さればとて死を越えては、いよいよ便りを得さうも無い欲情――わづかにそれを紙筆の上に夢にのみ描いて、そのあとを形にとどめて来た。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの世か、うつし世にてか、かかる人ありしを見ずや、われひとり涙ながれぬ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつし世の命を耻の　　めぐらせど、こぼれいづる神のゑまひか、　　君がおも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつし世の命を耻の　めぐらせど、こぼれいづる神のゑまひか、　君がおも。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしや、わざくれ、身はうつし世の　榮にまぎるゝとがめびと、　有爲の奧山、路嶮し。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は谷の百合、峰のさくら、　　　うつし世にたぐひもなし。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は谷の百合、峰のさくら、　　　　　うつし世にたぐひもなし。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "○うつし世の渦巻の中、と云ふにあらねども、なけれども、する息のむづかし。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その喜びに私はひそかに浸り得たのであつたが、いくばくもなくして君のうつし世は閉ぢられたのである。",
              "citation": {
                "source": "不器男句集",
                "author": "芝不器男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　その夜駅長は茶を啜りながら、この間プラットホームで蘆工学士を突き倒した小林浩平の身の上話をしてくれた、私がただ学問とか栄誉とかいうはかないうつし世の虚栄を慕うて、現実の身を愧じ、世をかねる若い心をあわれと思ったからであろう。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともし灯低く、白みわたる部屋にこんこんと再び眠りに沈んだ大膳亮――畢竟これはうつし世の夢魔、生きながらに化した剣魅物愛の鬼であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とお艶、この驚愕の真っただなかにあって、うつし世のはかなさといったようなものがしみじみと胸を侵すのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろきにやまぬ　ひそか心はうつし世に　君の心のまことなる。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "合唱げにうつし世は　夢ならむげにうつし世は　夢ならむ何事もみな　思い出の伝えは遠き　竹の里のいつの名残りをとどめてやいつの名残りをとどめてやこれやこの　遥けくも古りにし伝え跡や残るらむ　跡や残るらむ聞えは朽ちぬ世語りのなよ竹山に翁ありけりなよ竹取の翁ありけり竹取翁　聞いて下されますか？",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は、もうそこらにうきただよう気息のなかまらしく、人間の音楽にうつしようのない、たましいのひびきのようになっていました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            }
          ]
        }
