          ],
          "literary": [
            {
              "text": "ガタンコガタンコ、シュウフッフッ、　　凍えた砂利に　湯げを吐き、　　火花を闇に　まきながら、　　蛇紋岩の　崖に来て、　　やっと東が　燃えだした。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタンコガタンコ、シュウフッフッ、　　鳥がなきだし　木は光り、　　青々川は　ながれたが、　　丘もはざまも　いちめんに、　　まぶしい霜を　載せていた。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタンコガタンコ、シュウフッフッ、　　やっぱりかけると　あったかだ、　　僕はほうほう　汗が出る。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフッ、ウウ、どうもうまいもんだ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クックックッ」とか、「ウフッフッフッ」とかいって。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフッ、まさしく両性だな」　金弥ガタガタふるえ出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウフッ、ウフッ」　笑いとも恐怖とも、何とも判断のつきかねる声を発したかと思うと、見る見るうちに彼は顔色を土のようにして、その場に蹲ってしまいました。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでアンポンタン、大成した彼の舞台を見、舞台の悪党ぶりを見、息をひいて、白い眼をむいて、顎でしゃくった太々しさを見ると、ウフッという笑いが、表面へ出ずお腹の底の方で笑う。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾が偶然に行き合わせた時に、周章てて隠しちゃったんですけど、そのハンカチにあの人の口紅のアトが残ってベタベタ附いているのが見えたわ」「ウフッ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、貴殿へは渡されぬよ」「ウフッ、なるほど、恋敵だからで」「その恋敵で思い出した。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウフッ」　さすがにお八重はおかしくなった。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフッ、その手にはのらねえよ」　主水正は図星をさされて、苦笑の顔をツルリとなでながら、「イヤ、どうも、辛辣なものですナ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やら多勢で、ワイワイ論じておりましたが」「ウフッ、今ごろは丹波のやつめ、さぞ青くなっておることであろう」　そう言って源三郎は、ゴロッと腹ばいになりました。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフッ、東海道を与吉といっしょに、流しているうちに、柳生の殿様につかまって、おもしろい女というんで、おそばに仕えることになったんだが、今その殿様は、日光御造営のお奉行になって、日光へ行ってしまうし、あたしゃ百いくつとかのお化けのようなお爺さんの世話をしながら、しんき臭い日を送っていたのさ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようで」「ウフッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺とてめえはどこまでもかたき同士だが、ウフッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は、スス、水難の相があるとか申したな」　おんなは、ウフッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞどうぞ、お返しなされてくだされませ」「ウフッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらあ、お姫さまのお墨つきの包みをいただいただけで、満足だ、ウフッ」　なんかと、若いやつらは、儚い期待に胸をときめかしております。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この方は探偵だ相じゃ、笑っちゃ失礼だよ……、尤もこの御人体を見せて、若い娘に笑っちゃいけないという方が無理かも知れないが……ウフッ」　娘もたまらなくなって、ハンケチで顔を隠してしまいました。",
              "citation": {
                "source": "古銭の謎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
