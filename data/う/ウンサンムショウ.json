[
  {
    "uuid": "df2d571c-761a-5250-b6d0-9ab2d6ba194b",
    "entry": "雲散霧消",
    "reading": {
      "primary": "うんさんむしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
