  {
    "uuid": "4ad00472-4ea8-589c-9f21-cc0ab89978c4",
    "entry": "善知鳥",
    "reading": {
      "primary": "ウトウ",
      "alternatives": [
        "うとう",
        "ぜんちちょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rhinoceros auklet (Cerorhinca monocerata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "むかいに来た親は、善知鳥、うとうと、なきながら子をくわえて皈って行く。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "安方町に善知鳥のむかしを忍び、外の浜に南兵衛のおもかげを思う。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々男の小さきは生まれ付きなり、能の上手下手に係らずやと問うと、太夫、善知鳥の曲舞に鹿を追う猟師は山を見ずという古語を引き居る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "画を善くして、「外浜画巻」及「善知鳥画軸」がある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二では謠の「善知鳥」など、三では「阿漕」、「鵜飼」など其適例である。",
              "citation": {
                "source": "妖怪研究",
                "author": "伊東忠太",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も急く旅でもなしいっそ人力で五十三次も面白かろうと、トウトウそれと極ってからかれこれ一月の果を車の上、両親の膝の上にかわるがわる載せられて面白いやら可笑しいやらの旅をした事がある。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウトウトこんな事を考えていたが、気がついてみると垣の外ではさっきの子供等がまだ大きな声で歌ったりわめいたりしている。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　實に、氣の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔らかい毛布にくるまって上には志んの持って来た着物をかけられ、脚部には湯婆が温かくていい気持になってほとんど何も考えないでウトウトしていたが眠られはしなかった。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな幻像を夢うつつの界に繰り返しながらいつのまにかウトウト眠ってしまう。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でも貴方にはトウトウわかったのね……ホホホ……モウ随分前からの事ですからかなりの人数になるでしょう……御存じの家政婦も入れてね……ホホホホホ……」　私は見る見る血の気を喪って行く自分自身を自覚した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し最後にトウトウその手袋を脱がされた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "理屈のわかる時節が来たなら二度ビックリするような話が、底の方に隠れておろうやら知れん」「そこでトウトウ思案に詰まった揚句がアンタの事じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年も前から一緒の下宿にいる気持になりながら、私はウトウ卜する。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はウトウトする片手間に、モセイ君のホッソリした身体を黒ビロードずくめの服で包んでみた。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トウトウ悲鳴をあげて「誰か背後から突き飛ばしてくれ」と叫んだりする。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の迷いかしら、それとも揺椅子でぬくもりながらついウトウトとしてしまって夢をみたのかしら――酒と阿片とでいい加減狂いかけている俺の頭だもの、その位の気の迷いや夢がないとも云えない――が、併しそんな風に簡単に思いなしてしまうには、どうもすべてがあんまりまざまざとし過ぎている。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ているうちにあくびがいくつも出て来たので、私は窓に倚りかかったままウトウトと居眠りをはじめた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその日は仕事の始末をソコソコにして潜り込んでみるとその暖かくて気持ちのいい事、身体中の血のめぐりがズンズンとよくなるのがわかる位で、私はツイ何もかも忘れてウトウト眠り初めたのであったが、間もなく階下でけたたましく電話のベルが鳴り出したようなので、私は又渋々起き上った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてヤットの思いでウトウトしかけたと思う間もなく、長距離らしい烈しい電話のベルに呼び立てられたので、私は寝床に敷いていた毛布を俥屋のように身体に纏いながら、半分夢心地で階段を馳け降りると電話口に突立った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」オニハ　コナヒダ　アヅカツタコブヲ　ツケマス　ミギノ　ホホオヤオヤ　トウトウ　コブ　フタツブランブラント　オモタイナハヅカシサウニ　オヂイサンムラヘ　カヘツテ　ユキマシタ　実に、気の毒な結果になつたものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコデ　タウトウ　イチバン　イタダキニ　ヰタ　ツボミガ　オメメヲ　ヒライテ　花ニ　ナリマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデモ、オモヒダセナイノデ、トウトウ　オコツテ、カタツムリヲ　ツブシテ　シマハウト　シタ　トキ、フツト　オウサマノ　ココロニ、「デンデン　ムシムシ　ツノ　フレヨ、夜アケニ、ヌストガ　ヤツテ　クル」ト　イフ　ウタガ、ウカビマシタ。",
              "citation": {
                "source": "カタツムリノ　ウタ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トウトウ　コノ　タケノコハ　ホカノ　タケノコタチト　ワカレテ、カキネノ　ソトニ　アタマヲ　ダシテ　シマヒマシタ。",
              "citation": {
                "source": "タケノコ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "トウトウ　ハジメノ　デンデンムシハ　キガ　ツキマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヂイサンハ、ソノ　ラツパヲ　ヨロコンデ　ツカツテ　ヰマシタガ、ミミハ　ドンドン　トホク　ナツテ、トウトウ　ツンボニ　ナリマシタ。",
              "citation": {
                "source": "ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "タウトウ　チヤウサンハ　ハラヲ　タテテ　シマヒマシタ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤレヤレ」ト　チヤウサンハ、タウトウ　クルマノ　ナカニ　ヘタバツテ　シマヒマシタ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ、トウトウ、タイヘンナ　コトガ　オコリマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グツグツグツ、カアチヤン」　コドモダヌキハ　タマラズ　トウトウ　オホキナ　コヱヲ　ダシテ　ナキダシマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
