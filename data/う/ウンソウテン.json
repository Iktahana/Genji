          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どちらも茣蓙で包んで上箱に入れて、貴重品扱いにして門司の山九運送店宛に出して下さいな。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運送店に捜すよう詰責したが、絶えて返事が無かった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと淺間御社の境内なりしが、原鐵運送店の主人買收して公開せるなりとは、殊勝なる事也。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "運送店の前にはもう二台の馬力があって、脚をつまだてるようにしょんぼりと立つ輓馬の鬣は、幾本かの鞭を下げたように雨によれて、その先きから水滴が絶えず落ちていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの気分にふさわない重苦しさが漲って、運送店の店先に較べては何から何まで便所のように穢かった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山梨県の百姓の子で、青年の頃出京して長い間運送店の丁稚を務め、後に無頼漢の群に投じたのである。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒乱の酷い頃は連夜、吾家に帰つて乱暴を働き、その頃小さな運送店を経営してゐたのであるが、店の者などは蒼くなつて逃げ出したさうだ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いくら程あれば、以前の運送店を取り戻して、あんな働きのない夫などは頼まずに――云々といふ、彼女は、癖になつてゐる愚痴を滾して、夫を批難しはじめてゐた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて頼んでおいた駒平の知合ひの、町の運送店の若ものが、白レグの雌を三羽持つて來てくれたのである。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　工藤は百姓の伜だが、運送店で働いてゐるのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は晝のうち運送店にゐる間は、仕事の合間には聞くことが出來るのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅で手荷物、宿で行乞道具、運送店で荷物、酒屋で酒、米屋で米。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒物屋の向っ角――あたしの家の筋向いに横っぱらを見せている、三立社という運送店の店蔵は、元禄四年の地震にも残った蔵だときいていた。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、何故かというと、三誠社という馬車を扱う大きな運送店があって、その前身が、伝馬町の大牢の、咎人の引廻しの馬舎だったというのだ。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "船着場のトラックの運送店で、バスを交渉して貰つた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い運轉手と、運送店の主人が乘り込んでくれた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造の役所らしいのや、運送店や、三階建てのかしがつたやうな古びた旅館や、飲み屋なんかが、岩壁添ひにごちやごちや見えた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、兎に角運送店の名前をしっかり見といて貰うように云って呉れ給え」　電話を聞いた刑事にそう云うと、根岸は石子の方を向いて云った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に運送店を突留めるのだ」　分り切った事まで指図がましく云う根岸の言葉は決して愉快ではなかったが、今の石子刑事にはそんな事を考えている余裕がなかった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家について聞いて見ると、出した荷物は支那鞄に柳行李合せて四、五個らしく、手荷車で引出したのだが、さて運送店の事になると少しも手懸りがない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は別れ／＼に運送店を物色し始めた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大崎駅附近を受持った石子刑事は、取り敢ず一軒の大きな運送店に這入った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この辺の運送店で背の低い、ずんぐり肥えた人のいる所はありませんか」「知りませんね」　対手は相変らず素気なく答えた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子刑事の御馳走と世間馴れた話振に、すっかり打解けた運送店の人夫は知っているだけの事は残らず話し、背の低い運送人についても考えて呉れたが、結局誰も知らない事になって、石子刑事は何一つ得る所なくその運送店を出ねばならなかった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石子刑事はそれから丹念に運送店を一軒々々訪ね歩いたが、正午近くまで何の効果もなかった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が落胆しながら重い足を引摺って五反田の方から引返して来ると、或る狭苦しい横丁に、うっかりしていると見落すような一軒の小さい運送店があった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "運送店を突留めてそこの若い者からどうやら荷物の届先を聞き出して渡辺刑事は、喜び勇んで支倉の家の附近に引返した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "布疋雑貨商、穀物商、焼鍋（酒製造業）、獣皮毛商、運送店、旅館、飯館（料理屋）等の大きな商家が目に附く。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はさるすべりの木がホテルのものとも、前の運送店のものとも、又その筋向うの煙草屋のものともつかず、三方でそれを自分のところのものだと主張してゐる擧句の果、いまだにそんなところに打ち棄てられたままにされてゐるのだと云ふ話を聞いたのは、夏ももう末近くなつてからだつた。",
              "citation": {
                "source": "生者と死者",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
