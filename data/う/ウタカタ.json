  {
    "uuid": "e7ccfee9-923e-5e82-877d-e0978d07318c",
    "entry": "唄方",
    "reading": {
      "primary": "うたかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "singer in a nagauta performance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "足下は唄方であったものを。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "置舞台の正面に、屋形舟が一隻、その右に、しだれ柳、黒幕の背景、右掛りに赤毛氈の床がしつらわれて、黒紋付姿の地方姐さん連が五人、見台に唄方が三人、三味線が二挺。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "[川しろじろとまじはりて]川しろじろとまじはりて、　　　うたかたしげきこのほとり、病きつかれわが行けば、　　　　そらのひかりぞ身を責むる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔川しろじろとまじはりて〕川しろじろとまじはりて、　　　うたかたしげきこのほとり、病きつかれわが行けば、　　　　そらのひかりぞ身を責むる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにして集へる川の、　　はてしなみ萌ゆるうたかた。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れはうたかたのはかないものと思って居ります。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず休んで、」　と三足ばかり、路を横へ、茶店の前の、一間ばかり蘆が左右へ分れていた、根が白く濡地が透いて見えて、ぶくぶくと蟹の穴、うたかたのあわれを吹いて、茜がさして、日は未だ高いが虫の声、艪を漕ぐように、ギイ、ギッチョッ、チョ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋は夜とも分かず晝とも知らず朧夜に迷出でて、あはれ十九を一期として、同國浦崎と云ふ所の入江の闇に身を沈めて、蘆の刈根のうたかたに、其の黒髮を散らしたのである。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時、最も頭に印象されて、僕の文學崇拜の念を益々深くしたものは、森鴎外氏の水沫集一卷、其中でも「埋木」と「うたかたの記」と、内田不知庵氏の「罪と罸」とである。",
              "citation": {
                "source": "自傳",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんたくるす　さんたくるす　遊樂至上のうみのうへ、岬をめぐる浪のうたかた、浪とほれば鳥禽の眼にも見えず、況んや白日の幽靈は、いと遙かなる地平にかげをけちゆくごとし。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれ等は元来正体のないもので、雲は霧の集り、結んだ水がうたかた、なに、心を苦しめ、身を辛がることがございましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨勢は老女と屍の傍に夜をとほして、消えて迹なきうたかたのうたてき世を喞ちあかしつ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人の為に酒を佐るに嫻ひし手も、などや今宵の恋の命も、儚き夢か、うたかたの水盃のみづからに、酌取らんとは想の外の外なりしを、唄にも似たる身の上｜哉と、漫に逼る胸の内、何に譬へん方もあらず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "身はひとつ心はふたつ三股の流れによどむうたかたの、とけてむすぶの假枕、あかつきがたの雲の帶、なくか中洲のほとゝぎす。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎ても亡びんうたかたの身にしあれば、息ある内に、最愛しき者を見もし見られもせんと辛くも思ひ決め、重景一人｜伴ひ、夜に紛れて屋島を逃れ、數々の憂き目を見て、阿波の結城の浦より名も恐ろしき鳴門の沖を漕ぎ過ぎて、辛く此地までは來つるぞや。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながめする軒の雫に袖ぬれてうたかた人を忍ばざらめやそれが長い時間でございますから、憂鬱的退屈と申すようなものもつのってまいります。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "よどみに浮ぶうたかたは、かつ消えかつ結びて久しくとゞまることなし。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに固く信じあっていたのに、お養父さんもお母さんも忘れてこんなに働いていたのに、私は浅い若い恋の日なんて、うたかたの泡よりはかないものだと思った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古新聞を焚いて茶をわかしていると、暗澹とした気持ちになってきて、一切合切が、うたかたの泡より儚なく、めんどくさく思えて来る。",
