        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大目付様にも何にも生まれて初めて見る御状箱で御座いましたけに、よくわかりませなんだが、お先方様のお名前は渋川様と御座いましたが……渋川ナニ吾様とか……」「エッ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座尾張町から上野の展覧会へ行く積りで、生まれて初めての地下鉄へ降りてみる。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれて初めて会う文壇人に対する期待が皆外れてしまったので……けれども、それと同時にこの青年がタマラなくなつかしい人物に見えて来たのは不思議であった。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は日本の文字がそうであり、短歌｜俳諧がそうであり、浮世絵がそうであると言い、また彼の生まれて初めて見たカブキで左団次や松蔦のする芝居を見て、その演技のモンタージュ的なのに驚いたという話である。",
              "citation": {
                "source": "ラジオ・モンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれて初めて自分が教わったと思われる書物は、昔の小学読本であって、その最初の文句が「神は天地の主宰にして人は万物の霊なり」というのであった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも生まれて初めて飛行機に乗って珍しく感じたことを談り合ってそれを全国の聴取者に聞かせるのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな屑記事、生まれて初めてだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に為吉らは生まれて初めて江戸へ出たと云うのであるから、何が何やら殆ど夢中で、この不意の出来事についてはただ茫然としているばかりであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、いよいよ本当に製作に取り掛かることになったのですが、何しろ、私も、生まれて初めての大作のことで、かなり苦心をしました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして思いもかけない切ない愛の言葉を、生まれて初めて囁かれたのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しいトレイニングの後で嘔きたくなる時のような疲れを感じて、窓の外の太陽の光が妙に黄臭くて、起き上ろうとすると眼がクラクラして堪りませんので、生まれて初めて終日、床に就いておりましたが、あれは多分、烈しい神経の打撃からだったのでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生まれて初めて親の命令に背いたのです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して先生のお心にそむくような事は致しませんから……」　これは私が生まれて初めて吐いた嘘言でした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の待合室になっている裁縫室に入って行きました私は、卒業生仲間のお話の中に交って一緒に笑ったり、お菓子を頂いたり何かして一時間余りを過しましたが、私があんなに打ち解けて皆様と一緒に愉快そうに燥いだ事は生まれて初めてだったでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現代の文明は男性のための文明」と仰言った校長先生の演説のお言葉を思い出しながら、こうした妖怪じみた人間と美人たちの乱舞を生まれて初めて眼の前に見て、気が遠くなるほど呆れ返っておりましたが、やがて吾に帰りました私は、屋根の端に身を逆様にしながら、落ち着いてコダックの焦点を合わせました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ余ほどの老人でない限りは、生まれて初めてこんな目に出逢ったのであるから、狼狽混乱、どうにも仕様のないのが当りまえであるかも知れないが、罹災以来そのあと始末に四ヵ月を費して、まだほんとうに落着かないのは、まったく困ったことである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのとき、変な鳴き声を出して、こんな気味のわるい分泌液をたらしながら、幽霊が侵入する……だが、それから先は、さっぱりわからん…………」「わたしは、こんな目に出合ったのは、生まれて初めてだ！",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろよほどの老人でない限りは、生まれて初めてこんな目に出逢ったのであるから、狼狽混乱、どうにもしようのないのが当りまえであるかも知れないが、罹災以来そのあと始末に四ヵ月を費して、まだほんとうに落付かないのは、まったく困ったことである。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらあたしのような女でも、あんな恥かしい事をしたのは生まれて初めてだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "（刑吏一、甚兵衛の前腕だけを自由にする）甚兵衛　ほほう、わしゃ、こなな白い飯生まれて初めてじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かも瓜　……　こほろぎ　私は生まれて初めてこんな物を見るのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは夢の中のことを思い、この不思議な現象を見て、生まれて初めての大きな驚きを感じました。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生まれて初めてエックス光線にかけられましたよ」「あんなものを度々かけてもらうのはよくありません」　と俊夫君は皮肉を言いました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれて初めて辞令を手にした私にはよく分らない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の今度の奈良京都見物は、生まれて初めての事で、かねてから見たい希望もあったことで、大変ためになり、また熱心に見たことでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "奈良見物に行ったことのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな早業を見たのは生まれて初めてでした。",
              "citation": {
                "source": "橋の上で",
                "author": "ON A BRIDGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母さんもなく、母さんもなく、誰も言って聞かせるもののないような家庭で、生まれて初めて袖子の経験するようなことが、思いがけない時にやって来た。",
              "citation": {
                "source": "伸び支度",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "染井の森で僕は野枝さんと生まれて初めての恋愛生活をやったのだ。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "自給するようになって、生まれて初めて月給を懐中にした時は、嬉しい気持ちよりも、顧みて一ヶ月の自分の労力が余りに安価に購われ、余りに又小さなる自らの力である事を心細く思いました。",
              "citation": {
                "source": "職業の苦痛",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお空には、私うまれてはじめて頭を下げたいのです。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
