        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これだけの事実はいかなる疑い深い人でも認めないわけにはいかないだろうと思う。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がっしとまた胸を絞って、「でありますが、余りお疑い深いのも罪なものでございます。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でああ疑い深いでしょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐ろしい疑い深い人間やなあお前は……」　又野はイヨイヨ不愉快そうに顔を撫でた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして様子を探ってみたんだ」「疑い深いなあ……お前は……」「まだあるんだ。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑い深い沢山の眼に取りかこまれて、私は又頼り所のない淋しさと憤怒とを感ぜずにはいられませんでした。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊さんのお内儀さんは、馬鹿正直なかわりに疑い深いたちでした。",
              "citation": {
                "source": "日輪草",
                "author": "日輪草は何故枯れたか",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、疑い深い俊寛の瞳にも、遥かかなたの水平線に、波に浮んでいる白千鳥のように、白い帆をいっぱいに張りながら、折柄の微風に、動くともなく近づいて来る船の姿が映らずにはいなかった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも貴方なんか生活の苦労を知ったり下らない苦痛をたえなければならない様で育って来たらきっとごく疑い深いいやな人になったでしょうねえ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに母がこの世に生きながらえていて、一回の震災の打撃に小竹の店の再興も覚束ないと聞いたなら、あの疑い深い人はまた何を言い出したかも知れない。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋は合衆国高等法院のように出来ていて、ポウル・ボウの税関吏のような疑い深い、そしていつも突発事を待っている眼をした役員たちがとまり木の上に止まっていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "「にわかにとあなたが思うようなことが私のどこにあるのですか、あなたは疑い深いのですね。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ナアニ……ヨタじゃないったら……恐ろしく疑い深い読者だね君は……虚構だと思うならイツ何時でも本人に紹介してやるよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して広い平ったい額は疑い深い、もしくは底意地の強い才智の働きを表明し、耳は又、女性的で温順しい恰好をしているなぞ、随分矛盾した特徴を持った顔で、全体を綜合した印象から云っても、ちょっとどんな性格か要領の得難い表情と云わねばならぬ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一旦交際を初めても、暫くの間はその人間を疑問の圏内に保留しておいて、さり気なく様子を見ているので、この点から云えば私は思い切って卑怯な、疑い深い人間であった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑い深い眼付きをショボショボさして、モウ一度私を見上げ見下した。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナカナカ君は疑い深いなあ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑い深いとでも思ったことはないか？",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「疑い深い気質とは思いませぬ。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "かさかさ草の中を潜っていた子供の顔は人馴れぬ獣のように疑い深い眼つきで一様に私を仰ぎ見た。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ人間は疑い深いのであろう。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手繰出されたわたしの考えは疑い深い考えかも知れない。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は疑い深い目で、行き交う全ての女を見た。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "夢の総量は空気であった",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分の子が産まれてからというものは、さらに深刻な疑い深いと思えるほどの眼光を、家内の挙措に注いだのである。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、家内は長い年月私の疑い深い注意など、全く知らぬ風であった。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "平山中尉の疑い深い招請に応じたおかげで、悩める人間がどのような発作を起すかということをツブサに見学することができたのである。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、黒んぼは疑い深い目つきで、娘をながめながらいいました。",
              "citation": {
                "source": "港に着いた黒んぼ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは話さんでもないがね、弁償のことが気になってならんのだ」　と事務長はうたがいぶかい目で大佐を見すえてから、「この現場へきたが、わたしたちは『宇宙の女王』号の姿を発見することができなかったし、そのほか、その遺留品らしい何物をも見つけることができなかったのです。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こういって、猫は、うたがいぶかいような目をしました。",
              "citation": {
                "source": "猫吉親方",
                "author": "またの名　長ぐつをはいた猫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
