        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それでも、都会離れたこの浦里などでは、暗いさびしい貴船神社の森影で、この何百年前の祖先から土の底まで根をおろした年中行事がひそやかに行なわれていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして熱いのを口で吹いて、嬉しそうな宗吉に、浦里の話をした。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八畳一杯｜赫と陽気で、ちょうどその時分に、中びけの鉄棒が、近くから遠くへ、次第に幽かになって廻ったが、その音の身に染みたは、浦里時代の事であろう。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえにも云う通り、おなじ歌いものでも弁慶や熊坂とちがって、権八や浦里ではどうも困る。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺には何でも司馬江漢や小林平八郎の墓の外に名高い浦里時次郎の比翼塚も残つてゐたものである。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから浦里時次郎も、――僕はあらゆる東京人のやうに芝居には悪縁の深いものである。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて矢張り小学時代から浦里時次郎を尊敬してゐた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（けれども正直に白状すれば、はじめて浦里時次郎を舞台の上に見物した時、僕の恋愛を感じたものは浦里よりも寧ろ禿だつた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺には何でも司馬江漢や小林平八郎の墓の外に名高い浦里時次郎の比翼塚も建っていたものである。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから浦里時次郎も、――僕はあらゆる東京人のように芝居には悪縁の深いものである。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って矢張り小学時代から浦里時次郎を尊敬していた。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（けれども正直に白状すれば、はじめて浦里時次郎を舞台の上に見物した時、僕の恋愛を感じたものは浦里よりもむしろ禿だった。",
              "citation": {
                "source": "本所両国",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "新町にかくれなき、加賀屋の名とりの浦里の君さまを、初めてこれを身請けする。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川にかくれなき黒江町に殿を建て、目算御殿となぞらえて、附き添う幇間は誰々ぞ、一蝶民部に角蝶や（下略）ハアホ、大尽舞いを見さいナ」　で、その奈良屋茂左衛門がまだ浦里を身請けしない前の、ある春の日のことであったが、取り巻を連れて吉原の新町の揚屋で飲んでいた。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ身請けという段になって、にわかに浦里が冠を振り、彼の望みに応じようともしない。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほどまでに心を許し慣れ馴染んで来た浦里が、これという特別の理由もないのに、彼の心に従わないのが、彼には不満でならなかった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し望みがありますゆえ」と、いくら尋ねてもただこういって浦里は他には何もいわない。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに近頃若い男が、彼に楯突いて浦里のもとへ、しげしげ通って来るという、厭な噂も耳にしたので彼は益※｜焦心した。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は一度も浦里は座敷へ顔さえ出さなかった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前髪立ての美男であって、浦里のもとへ通って来た嫖客の一人だということであったが、それかあらぬか浦里は、自分親しく施主に立って立派な葬式を営んだため、噂がパッと拡がった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなくその浦里も奈良茂のために根引きされて、吉原から姿を隠したので、廓の名物を失ったといって、嘆息しない者はなかったが、名物といえば江戸名物の紅白縮緬組もそれ以来パッタリ市中へ出ないようになって、次第に噂も消えて行った。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦里のお千代は、兄と共々、深夜に廓を抜け出して、市中を横行した当時の覇気を、兄の死と一緒に封じ込み、ただ貞節の妻として奈良茂に仕えたということであった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、田之助が浦里で出てゐた。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、田之助が浦里で出ていた。",
              "citation": {
                "source": "役者の一生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その極端な例は、日本の歌舞伎劇の長つたらしい標題「浦里時次郎明烏花濡衣」の如き類だ。",
              "citation": {
                "source": "標題のつけ方",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦里時次郎の艶事を伝うるに最適したものは江戸の浄瑠璃である。",
              "citation": {
                "source": "十日の菊",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日浦里上の段をけいこす。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
