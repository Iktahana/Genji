        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その美しい眼を心持泣き脹して、雪のような喪服を纏うて、俯きがちに、しおたれて歩む姉妹の姿は、悲しくも亦美しかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう云われて、今迄俯きがちに歩いて来た美奈子も、立ち止って空を振り仰いだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美しい眼を心持泣き脹して、雪のやうな喪服を纏うて、俯きがちに、しほたれて歩む姉妹の姿は、悲しくも亦美しかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう云はれて、今迄俯きがちに歩いて来た美奈子も、立ち止つて空を振り仰いだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者らしくない風采をした彼は、俯きがちに私たちのそばを通りすぎようとしましたが、そのとき私たち一行のうちの巡査は、「市さん、ご苦労だね」　と声をかけました。",
              "citation": {
                "source": "白痴の知恵",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "不注意でした』『………………』　俯きがちに眼を外らせて、忍耐力と戦つてゐるといふ様子で陶が僕に云ふのだ。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "四｜人はうつむきがちに、歩いていきました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子が、どこかへ外出するのだと思っていると、すぐ後から、鳩色羽織を着たおとなしい姿の倭文子が、うつむきがちに、玄関を降りて来た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子は帽子をまぶかにかぶってうつむきがちで、大船辺までほとんど黙っていた。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉は赤い顔をして、うつむきがちであった。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　座蒲団の隅を折りながら、うつむきがちに、それでも、ハッキリと言った。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしは気咎めがするようで、幕間にはうつむきがちにしていたが、見物が「鎌子だ」といって視線をむけても格別恥らいもしなかった。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "白光はうつむきがちな彼女の頸のきめの粗いざら／＼した白粉膚に紫光を放って反映した。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "にげる様に門の外に出てホッとした様にたいらに白く光って居る広い道をうつむきがちにあるいた。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややうつむきがちに、ただ黙々としていた。",
              "citation": {
                "source": "犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物もたしなみのある着附で、品がよく、うつむきがちに沈黙していると、いかにも、ゆかしく、つゝしみ深く見えるのである。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、末子は兄のそばに静かにいて、例のうつむきがちに私たちの話に耳を傾けたが、自分の証書を開いて見ようとはしなかった。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "泳ぐというよりは、前の方へうつむきがちに、しゃがみこむように見えましたな」　と一人が答えた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "木枯しが夕暮れの街をはしり、胡麻粒のように見える人も、みんな外套の襟を立てて、うつむきがちな速足で歩いていた。",
              "citation": {
                "source": "メリイ・クリスマス",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二里あまりの道を、彼はうつむきがちに歩いた。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎は、その半丁ほど手まえに来たとき、今までうつむきがちになっていた顔をあげて、ふと向こうを見た。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "原爆の残虐さが、そのことばとしての意味だけで伝えられてはいたが、まだほんとうの惨状を知らされていなかったあの年の八月十五日、ラジオの放送を聞くために学校へ召集された国民学校五年生の大吉は、敗戦の責任を小さなじぶんの肩にしょわされでもしたように、しょげかえって、うつむきがちに帰ってきた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖る怖る、庄司七郎の孤雲は、そこへ来て、うつむきがちに坐った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で――うつむきがちに先へ行くと紐の宅助もしばらくは無言のまま犬のようについて歩く。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ理解しがたい人の世の相剋ぶりが彼には悲しくて恨めしくて、つい尊氏へも、多くをいわず、うつむきがちな姿になっているものだった。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "――目のまえの勾当の内侍は、ともすればただうつむきがちだった。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
