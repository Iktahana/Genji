[
  {
    "uuid": "46ed5480-c0fa-5ad5-862e-4677d34b884b",
    "entry": "打ち勝つ",
    "reading": {
      "primary": "うちかつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
