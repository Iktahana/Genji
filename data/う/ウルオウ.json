    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to become moist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これが売られる縁によって、多少｜生計が潤うとか、蝗がわいたので都会の子供が蝗取りに来るとか、本年米作の成績表の一部に数え入れられて、農林大臣の考えの資料になるとか――とても数え切れません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はしんしんと更けて、いよいよ深みまさり、粘り濃く潤う闇。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "延長でもっとも潤うのは、著作物の商品化と著作権の管理にあたる者である。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "御墓のある所は高い雑草がはえていて、分けてはいる人は露に全身が潤うのである。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠つ祖どもの苦心があればこそ、二千年この方、幾百億の人々が、その余沢に潤うてござるのじゃ。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは一時潤うていた深山の生活状態がまた寂しくなっていたので、家主のＫ―へやるべきものも一時そのまま残して行くことになった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からは、夏の夕らしい涼しい風が吹き込んで、萎えたような皮膚がしっとり潤うようであった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は昔のように細面な、敏感な、眼の潤うた青年で居られた。",
              "citation": {
                "source": "追慕",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感じは祈りとか望みとかいうような、すべての潤うた感じを殺してしまうようないやなものでした。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして涙と訴えとをもって、心から心へと語るような、博い、潤うたものを書きたいと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたのお書きになるものでは、やはり、あの短篇集などが最近のものだけに、最も潤うているのではないかと思われます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心が貧しく潤うているならば、私の日々新しい興味で生きてゆく途は残っていると思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたった今｜嚥んだばかりの毒液に潤うた唇は、血のようにぶるぶるとふるえつつ、次第次第に傾いて行く漆黒の頭髪の蔭になって、見えなくなって行った。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十四日（金曜）曇　夜の中に少雨があったと見えて、庭が美しく潤うて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言ふ悲痛な信仰に似たものに、心が潤うて来るのをおさへることが出来ませんでした。",
              "citation": {
                "source": "延若礼讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうずいぶん長い間あなたが潤うた、和らかな心でいらしたことはありませんわ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のようなあなたの情けに潤うて、私の胸につぼみのままで圧しつけられていた、娘のねがい、よろこび、いのち、おゝ、私の恋が一時にほころびました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨に濡るる若草のごとくに甘い、懐かしい、潤うた悲哀である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて氏の認識は科学者の分析的理解力よりも、詩人の直観的創作力に著しく接近してきて、われらをして科学的真理の価値の過重からきたる器械的見方の迷妄より免れしめ、新しくて、不思議の光に潤うたる瞳をもって自然と人生とを眺めしめるのである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽き接触の表面が潤うて少しじとじとすれば、それに美しき友情の名を被らせるのであるか。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして安らかに、潤うた交わりをいつまで続けようではありませんか。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "純な、潤うた、細々とした心を作者は観客に要求する。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに彼は、妹の頬に浮んでいる美しい赤い血の色や、よく潤うている口の中や、その奥で見え隠れしている宝玉のような光沢を持った純白な歯やに我れにもなくじっと見入っているのであった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張草葺だが、さすがに家内何処となく潤うて、屋根裏には一ぱい玉蜀黍をつり、土間には寒中｜蔬菜を囲う窖を設け、農具漁具雪中用具それ／″＼掛け列べて、横手の馬小屋には馬が高く嘶いて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日終日終夜の雨で、畑も土も真黒に潤うた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "概念的に明確な漢詩は叙情的に潤うた律動の細かい唐詩に変わった。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神とキリストの御霊の愛に潤うて、愛の生涯を送る者が基督者である。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "工藝に潤うこの世を、幸あるこの世と云えないであろうか。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が特に農村の副業としてかかる品の発展を熱望する所以は、これによってただに北国の貧村が潤うのみでなく、真に地方的な産物として栄えると思えるからである。",
              "citation": {
                "source": "蓑のこと",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大工のかんなやかなづちの音もいいかげんにうるおうて響く。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
