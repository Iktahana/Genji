          ],
          "literary": [
            {
              "text": "されば隣国の軍勢は、一たまりもなく浮き足立つて、武具馬具のたぐひをなげ捨てながら、四分五裂に落ち失せてしまうた。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると地廻りが浮き足立つ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さなきだに、大将を失って浮き足立つ残軍、なんでひと支えもできよう。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
