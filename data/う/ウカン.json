              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "羽子はソープベリイ〔米国産無患子の一種〕の種子（ムクロジ）で出来ていて、その一端では五本の羽毛が羽冠を形成する。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその星はみな、乳のなかにまるで細かにうかんでゐる脂油の球にもあたるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラの眼にはきれいな涙がうかんでゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎの蒲焼（鑵詰）ライスカレー（同上）あずきようかん（同）栗のきんとん（同）ほーじ茶、ココア、角砂糖（斯うたくさんは食えんわい）小包は厳重にして置いて呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりその星はみな、乳のなかにまるで細かにうかんでいる脂油の球にもあたるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラの眼にはきれいな涙がうかんでいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚鉢のメダカが、鉢の底から二寸くらいの個所にうかんで、じっと静止して、そうしておのずから身ごもっているように、私も、ぼんやり暮しながら、いつとはなしに、どうやら、羞ずかしい恋をはじめていたのでした。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝永五年の夏のおわりごろ、大隅の国の屋久島から三里ばかり距てた海の上に、目なれぬ船の大きいのが一隻うかんでいるのを、漁夫たちが見つけた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の中にはひよめが五六っぱ、黒くうかんでおりました。",
              "citation": {
                "source": "一年生たちとひよめ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕だってそうだ」カムパネルラの眼にはきれいな涙がうかんでいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には所々雲もうかんでゐるやうでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたも、もうかんむりをかぶってるではありませんか。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には所々雲もうかんでいるようでした。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが病氣に惡いんだといふこともよく知つてゐますから、讀むこと又書くことは勿論、どんなにいゝ言葉や場面がうかんで來ても、それを拭き消し拭き消ししてゐます。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木綿の布子、襟が黄色にヤケたのに、單衣らしい、同じ白の襦袢を襲ね、石持で、やうかん色の黒木綿の羽織を幅廣に、ぶわりと被つて、胸へ頭陀袋を掛けた、鼻の隆い、赭ら顏で、目を半眼にした、眉には黒も交つたけれど、泡を塗つた體に、口許から頤へ、短い髯は皆白い。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その野原のはずれのまっ黒な地平線の上では、そらがだんだんにぶい鋼のいろに変って、いくつかの小さな星もうかんできましたし、そこらの空気もいよいよ甘くなりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、君勇のことがうかんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　冴子は微笑しかけたが、青ざめた顔にうかんだ信吉のキッとした表情を感ずると、あわてて視線を外らし、みるみる固い姿勢になって行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の流通をよくしなければいけないんです」　すると、女の顔に思いがけぬ生気がうかんだ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりのざわめきが、まるで遠くの空にきこえているようで、眼の前がぼうっと霞み、白い視野の中で、母親の赤い唇がうかんでいた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にもひょいと戯作一句うかんだ。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌が、心の中までしみとおるようにひびきましたので、ヨハンネスの目には、涙がうかんできました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "白晝のかなしい思慕からなにをあだむが追憶したか原始の情緒は雲のやうでむげんにいとしい愛のやうではるかな記憶の彼岸にうかんでとらへどころもありはしない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」顏ねぼけた櫻の咲くころ白いぼんやりした顏がうかんで窓で見てゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとめは戀戀の羞をふくんであけぼののやうに爽快な　別製の皿を運んでくる仕組私はゆつたりとふほくを取つておむれつ　ふらいの類を喰べた空には白い雲がうかんでたいそう閑雅な食慾である。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
