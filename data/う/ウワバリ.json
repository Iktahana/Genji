        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "其時春さんは能く市中の女に見るやうな紺飛白の筒袖を上張りにして居た。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっしょで、果然上張りの一枚下からにょっきりと正体を現わしたものは、画面だけを切り抜いた名画雪舟の一幅でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "上張りの鉄板なんざあ、おれがポルタワへ出仕事に行つたをり、百人長の二輪馬車に張つたのより、ずつと上物なんだぜ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くしてから、黒い上張りを着た中年の女が出て来た。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼろぼろにほつれた毛糸の上張りの前がはだけて、玉葱のやうに光つた膝小僧が出てゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○夜、上張りに着かえたところへ、ノックして、女の人が入って来た。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と書いて居る上張りの袖を引っぱった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目に呼鈴を押したら、漸っと白い上張りを引っかけた若い男が出て来たので、部屋をかけあうと、まだ二三日滞在している筈の前からの客があるのでそれまでならお泊めします、と云う事だった。",
              "citation": {
                "source": "晩夏",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内側の壁にはジョンの先祖たちの記念碑が飾られ、やわらかい座蒲団や、立派な上張りの椅子が心地よくしつらえてある。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰度十二時十分過ぎになると、樋口さんは紺の筒袖の上張りをつけたまゝ十三の弥生ちやん、十五六の梶さん、梶さんより一つ上だと云ふ富海さんを連れて、いつも子供が首を出す硝子障子の処に顔を出すのであつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
