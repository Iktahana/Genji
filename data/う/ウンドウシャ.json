[
  {
    "uuid": "328040a5-f321-57f3-a784-3b59be90f32a",
    "entry": "運動者",
    "reading": {
      "primary": "うんどうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
