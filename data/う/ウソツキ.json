        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「世の中の人は皆、嘘つきだから、話を交すのがいやになつたのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　夜、丸の内の淋しい町を歩いていたとき、子供を負ぶった見窄らしい中年の男に亀井戸｜玉の井までの道を聞かれ、それが電車でなく徒歩で行くのだと聞いて不審をいだき、同情してみたり、また嘘つきのかたりではないかと疑ぐってみたりしたことがあった。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「濫費日」や「嘘つき日」や「怠け日」はあまり聞えはよくないかもしれないが、実はこれらの特定日の存在は平日の節約勤勉真面目を表白するとすれば目出度い事である。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでもわれわれは「言葉」という嘘つきに欺されていたのではないか。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもう一歩進めば――「勇さんは嘘つきだ。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と顔を合せて、お変りありませんか、寒くなりました、などと言いたくもない挨拶を、いい加減に言っていると、なんだか、自分ほどの嘘つきが世界中にいないような苦しい気持になって、死にたくなります。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五唱　嘘つきと言われるほどの律儀者　まちを歩けば、あれ嘘つきが来た。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ああ、言へば言ふほどおのれが嘘つきで不正直な氣がして來るこの大きな不幸！",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、孝行な他の賢い子より、そのやくざで嘘つきな息子の方が可愛ゆくて憎もうとしても憎めない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大がたりの大嘘つきめが……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）嘘つきなればこそ嘘つきと云うたがなぜ惡い。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は約束にそむく大嘘つき、まはりの奴儕はへつらひ武士や臆病者、右を見ても左をみても、癇に障ることばかりが疊まつて來るわ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつや　嘘つき……。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女子は嘘つきですよってな。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実感織田作之助　文子は十七の歳から温泉小町といわれたが、「日本の男はみんな嘘つきで無節操だ。",
              "citation": {
                "source": "実感",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐の襟巻をすると、急に嘘つきになるマダムがいた。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは、実に謙遜なつつましい奥さんであるのだが、一旦、狐の襟巻を用い、外出すると、たちまち狡猾きわまる嘘つきに変化している。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマダムもまた、狐は人をだますものだと単純に盲信しているらしく、誰もたのみもせぬのに、襟巻を用いる度毎に、わざわざ嘘つきになって見せてくれる。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐がマダムを嘘つきにしているのでは無く、マダムのほうから、そのマダムの空想の狐にすすんで同化して見せているのである。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、嘘つきだ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘つき」　と、小さい顎を出し、老婢がこれに対し何かあらがう様子を尻眼にかけながら、「あがってもいいでしょう。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、とても嘘つきです。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿か利巧か、嘘つきか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（数枝）（全然それを聞いていない様子で、膝の上で袖の端をいじりながら）いつから日本の人が、こんなにあさましくて、嘘つきになったのでしょう。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は、私を、なんと言っているか、嘘つきの、なまけものの、自惚れやの、ぜいたくやの、女たらしの、そのほか、まだまだ、おそろしくたくさんの悪い名前をもらっている。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち上って吉野山の冬景色を見渡しても、都の人たちが、花と見るまで雪ぞ降りけるだの、春に知られぬ花ぞ咲きけるだの、いい気持ちで歌っているのとは事違い、雪はやっぱり雪、ただ寒いばかりで、あの嘘つきの歌人めが、とむらむら腹が立って来ます。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人はうそつきでしたね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、ふたりのうそつきがやってきました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、さっそく、その織物を織らせるとしよう」　そこで、ふたりのうそつきにたっぷりお金をやって、仕事にかかるように言いつけました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、年とった正直者の大臣は、ふたりのうそつきが、からっぽの機にむかって働いている広間へはいっていきました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
