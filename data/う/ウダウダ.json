        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "電車を降りて車にのった時、私はその男に勝った様にあの男の時々したうだうだな様子を思ってうす笑いをしました。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛のほうは、昔はだいぶ凝ったおぼえのある老人だから、屋敷を出る時はうだうだいっていたが、いざ釣りはじめると面白いように喰いつく。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかに何でも、これは無作法過ぎる」と、お角さんはムッとしながら、そのならず者を見つめていると、「いいってことよ」を連発する江戸まがいの三下奴があるかと見れば、「うだうだ言やはるな、ちゃア」と上方なまりをむき出したよた者もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに、「あんたはん、うだうだ言やはるな、ちゃア」に至っては、上方弁というものが本来、啖呵を切るには適していないので、お角さんが、うずうずして、どうにもこうにもならない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばかばかしい、女の腐ったように、いつまでみれんがましくうだうだしているんだ」　自分を嘲弄するようにせせら笑う。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "進展に大満足し、うだうだ考えて夜の大半を費やさなくていい。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
