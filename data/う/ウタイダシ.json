    "definitions": [
      {
        "index": 1,
        "gloss": "first line (of a poem)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　柏の木大王も白いひげをひねって、しばらくうむうむと云いながら、じっとお月さまを眺めてから、しずかに歌いだしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が動きだすと一団の生徒らは唱歌を歌いだした。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして驚くような大きな声で「ターカイヤーマーカーラアヽ」と歌いだした。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミーロは歌いだしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫博士は案外うまく歌いだしました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小さなきれいな声で、誰か歌いだしたものがあります。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそのころ、臣下の中でおそろしく幅をきかせていた志毘臣というものが、その大魚の手を取りながら、袁祁王にあてつけて、「ああ、おかしやおかしや、お宮の屋根がゆがんでしまった」と歌いだし、そのあとの歌のむすびを王にさし向けました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛卿の霊は趙の方を見て拝をしたが、それが終ると悲しそうな声を出して歌いだした。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、徳利を叩き、卓を叩いて歌いだした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウェ、シェキナ・ベイビー・ナウ」　と高志が歌いだしたので、慶一も即座に乗って、「シェキナッベイビー」　とバックコーラスをつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「も、サイコー」　外へ出たところで、柾生が「ユ・ゴナ・ルー・ザッ・ガル」と歌いだしたので、慶一もつきあって、「ヨー・ゴーナ・ルーズ・ザット・ガール」とバックをつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ダッシン・スルー・ザ・スノウ、イナ・ワン-ホース・オープン・スレイ」　ワラが歌いだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョンが、素早くチューニングして、マイクに近づき、無造作にコードをストロークして、歌いだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」羽団扇で膝をたたきながら、僧正天狗、頼宣卿、さも豪壮に歌いだした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また将右衛門歌いだした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「未熟者で、何も覚えて居りませぬが、折角のお言葉ゆえ――」　と、そう答えて、一人の芸者から、三味線を借りると、かすめた調子で、爪弾きで、低く粋な加賀節を歌いだした。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、海ゆかばを歌いだした者がある。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると車座の連中が何やら静かな声で歌いだした。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という唄を、頭を上下に振りながら歌いだしたのであります。",
              "citation": {
                "source": "からすの唄うたい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌ってね、そうして自分で踊るよ」　ギラリ、大ランプの灯に大刀をかざしたかとおもうと、筒いっぱいのキンキン声を張り上げて歌いだしたねこの、御隠居。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "危うく「坊主に簪さし場がない、畑に蛤掘ってもない」と傍らの小木魚叩いて歌いだしてしまうところだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい太陽の光が、心の隅々まで射しかけ、歌いだしたいような快活な気持になった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "纒いつくように、夫に寄りそって、中野の、二人のアパートまで帰りながら、葵は、歌いだしたいほど幸福だった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、では『王子さまの雌牛』もいばって乗りこめるわけだね」　かれはうれしがっておどりをおどったり、歌を歌いだした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐山の声　……（しばらくだまっていてから）吉富といって、やっぱり、はじめての召集で、甲州の山ん中から来た男だ……そいつが歌いだして――盆踊りの歌だっていってた……みんな、それから、ここを掘りながら歌った。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松浦が口ずさみから段々本気になって、声量はとぼしいが正確で地味なバリトーンで歌いだした。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と突然暗い中で、ゴットフリートが歌いだした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども「南ドイツ人」の一団が現われて、恋に落ちた若い娘の気恥ずかしい告白を、堂々と歌いだした時には、もう堪えられなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女はまた歌いだした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、水の静明な瞳に惑わされてのぞき込んだ時、ごく小さな一匹の小鳥が、そばの木の上で歌いだした――やたらに歌いだした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
