[
  {
    "uuid": "19d38d36-3e20-5bad-9246-c238aaee4050",
    "entry": "浮く",
    "reading": {
      "primary": "うく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to float",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何だか、ご自分のからだが、ふはふは浮くやうな氣がするでせう？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、汗は出たが、いい考えが浮く筈がなかった。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景なり人物なり、これで撮って適当な薬液で現像すれば蒼い空に浮く雲も、森の緑、野の花の黄紅白紫、ないしは美人の頬の桜色でもすぐに種板に現われるというのは愉快である。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は下態はそのままで、上態は七分通り水の方へ捩じ向け、ふくふく水溜りの底から浮く、泡の湧玉を眺めている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、不思議な人情を潜った老女の顔に影のように浮く薄白いような希望のいろを、しみじみと眺めた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "環境には何ら科学的の刺戟はなかったが、塩水に卵の浮く話を聞いて喜んで実験したり、機関車二台つけた汽車を見てその効能を考えたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところをわが青海流では、死屍水かかずしてよく浮くといって、平泳ぎのこころだ」「それは、よくおとうさんがおっしゃる、あの渾沌未分の兄弟か何かなの」　小初は食後の小楊枝を使いながら父親を弥次った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども陸羽一三二｜号のほうは三｜割ぐらいしか浮く分がなかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　卯の花の色うつくしく、中肉で、中脊で、なよ／＼として、ふつと浮くと、黒髪の音がさつと鳴つた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍは毎年学校の水泳部に行っていたので、とにかくあたり前に泳ぐことを知っていましたが、私は横のし泳ぎを少しと、水の上に仰向けに浮くことを覚えたばかりですし、妹はようやく板を離れて二、三｜間泳ぐことが出来るだけなのです。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "快い朗らかさで身も浮く様に覚える時さえある。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を押付けがましいにおいを立て、脂がぎろぎろ光って浮く精力なんというものほど下品なものはない。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黒髪の船に垂れたのが、逆に上へ、ひょろひょろと頬を掠めると思うと――（今もおくれ毛が枕に乱れて）――身体が宙に浮くのであった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "口中に熱あり、歯の浮く御仁、歯齦の弛んだお人、お立合の中に、もしや万一です。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……橋詰から打向ふ眞直な前途は、土塀の續いた場末の屋敷町で、門の軒もまばらだけれども、其でも兩側は家續き……　で、町は便なく、すうと月夜に空へ浮く。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　敷居からすぐに潜ったが、唯、見る目も涼しく、桔梗の藍が露に浮く、女郎花に影がさす、秋草模様の絽縮緬をふわりと掛けて、白のシイツを柔に敷いた。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二筋、三筋、流れを合せて、濤々たる水面を、幾艘、幾流、左右から寄せ合うて、五十傳馬船、百傳馬船、達磨、高瀬、埃船、泥船、釣船も遠く浮く。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には山椿の花片が、此のあたり水中の岩を飛び岩を飛び、胸毛の黄色な鶺鴒の雌鳥が含みこぼした口紅のやうに浮く。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、其の一名、弘法の湯の露呈なことは、白膏の群像とまでは行かないが、順禮、道者、村の娘、嬰兒を抱いた乳も浮く……在の女房も入交りで、下積の西洋畫を川で洗濯する風情がある。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空へ、すらすらと雁のように浮く、緋縮緬の女の眉よ！",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "細腰はふっと消えて、すぼめた肩が、くらがりの柳に浮く。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは首だけ浮いたのですが、礫を避けるはずみに飛んで浮くのが見えた時は可恐い兀斑の大鼠で。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆府の湯へ箱形の波を打って、皮が伸びて浮く処をすくい上げる。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず続いて、音色は替っても、囃子は留まらず、行交う船脚は水に流れ、蜘蛛手に、角ぐむ蘆の根を潜って、消えるかとすれば、ふわふわと浮く。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし逃げ出したくなるわ」　と、信吉が書きもしなかった歯の浮くような甘い科白を言っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯の浮くような、甘ったるいラヴシーンで、凡そくだらない一幕だった上に、現代劇だというのに、新内流しの下座がはいっていて、いつもの信吉なら、そのチグハグさに腹を立てるか、噴き出した筈だ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてぼくらは学生らしい所謂感激に満ちた、歯の浮く様な儀礼を暫くかわしていたが、轡川は突然、真剣な顔付きになったかと思うと、「実は、明日子のことだけど、明日子はあなたにどんなこと話したんですか。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼の眩むような大光熱は、山々の青葉を渡る朝風をピッタリと窒息させ、田の中に浮く数万の蛙の鼻の頭を一つ一つに乾燥させ、地隙を這い出る数億の蟻の行列の一匹一匹に青空一面の光りを焦点作らせつつジリジリと真夏の白昼の憂鬱を高潮させて行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、ご自分のからだが、ふはふは浮くやうな気がするでせう？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、めんどうくさくなくていい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
