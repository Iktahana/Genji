        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "銀子は撫で肩の肩が少し厚ぼったく、上背もなかったが顔は彼女の型なりに完成美に近く、目も美しく、鼻も覗き気味で尋常であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「う、」　と唸って、足をばたばたと※く状を、苦笑いで、睨めつけながら、手繰って手元へドン、と引くと、凧かと見えて面くらう、自分よりは上背も幅もあるのを、糸目を取って絞った形。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背丈なら凡そ五尺六寸、上背のあるその長身に、蝋色鞘の長い奴をずっと落して差して、身分を包むためからか、面は宗十郎頭巾に深々とかくしながら、黒羽二重を着流しの、素足に意気な雪駄ばきというりりしい姿です。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の博士論文から引出された論によると、女学生の体格は統計上背が高くすらりとしたタイプであり、女工たちの体はずんぐりで低く、四肢が短い。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、中腰になって上背をよじるようにして手早く縒り合わせていく。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇を借りるとき、世話を焼いてくれた、親切な南加大学の補欠漕手の上背も、六尺八寸はあり、驚かされたことでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "「荒木だ」　少し、蒼白めた顔をして、上背のある荒木が、長い、厚い刀を構えていた。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "やさしくて、ほがらかな聲だつたが、濡雜巾を手にして立上つた姿は、たつぷり上背もある肥大なものだつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上背は高かった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "経験という語と形而上学という語とは哲学史上背を合わしてきているにもかかわらず、氏の体系においては経験はただちに形而上学の拠って立つ根底である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "可なり上背のある婦人で、クッションのように軟くて弾力のある肉付の所有者だった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして必らず上背のある相手の顎を狙ふ。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも五尺二寸以上の上背があって最も高いのは五尺三寸あるという。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、上背が五尺あるかなしかの、幅広の体格から想像すると、もし兄さんに似ている妹さんであったなら、女として美しい出来ではないかも知れないと思った。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上背は四尺六、七寸、肩幅が広くてずんぐりしている。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼の友人たちは、彼が醜男にも拘わらず上背の高い美しい妻君を持っているのを、日ごろ羨ましがった。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "半身像であるから、上背のところは分からない。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが七兵衛には皮肉に響かないで、「全く、相撲にもあのくらいのは、たんとありません、まず横綱の陣幕と比べて、上背はホンの少し足りないかも知れないが、横幅は、たしかにあれ以上ですね」「えー」　神尾主膳が眼を円くしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏君は上背が低い上に、小肥りに肥って色白であるから、豚の子のようにからだの恰好がころころとしている。",
              "citation": {
                "source": "弟子自慢",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の頃は四十五六、頬髯の濃い赤ら顔、上背があって立派である。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉附きがよくて上背があって、とても清浄で別嬪だ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のびのびと、上背があるようだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの騙児め、上背といい、お面といい、男っぷりといい、――ちょいと水際だっておりますからねえ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年には、その頃ぼつぼつ「洋物」が売れた、と云っても、一番よく出たものは、服装の上ッ張りに着られる廻し合羽、やがてトンビと云われたもの、あれだったそうで、両羽も上背丈も短かかった。",
              "citation": {
                "source": "ハイカラ考",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "上背のあるスラリとした影法師が、春の夜の靄のなかでジットリ朧に濡れていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
