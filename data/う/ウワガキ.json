        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこには明らかに「室生犀星樣」と上書きされてる、二三の手紙が這入つてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は手紙をそれ以上書き續ける氣がしなくなつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして桃いろの封筒へ入れて、岩手｜郡西根山、山男｜殿と上書きをして、三｜銭の切手をはって、スポンと郵便函へ投げ込みました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏頃までぼんやりして暮してゐましたが、手紙は來ず、ひどい面倒を見て、横文字の上書きをして貰つて、手紙を遣つても、返事も來ないうちに、お金は段々なくなりますの。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "油紙に包んで革文庫に蔵められて、文庫の上書きには「妖馬の毛」と記されてある。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度印刷が出来て来た答礼の葉書の上書きを五人の店員が精々と書いていた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのはその手紙の上書きが、あの男の自筆であることをたしかめたのです。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに居あわせた手代どもがその封書の上書きをみると、和泉屋市兵衛様、弥左衛門としるしてあった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアザーが、書いたお供物の上書きを見ると、君はまた何うして自分の名前までを代筆なんてして貰ふんだい！",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ來てからも、隨分出したのは分つてゐるが、東京の「本郷區｜千駄木」云々と、上書きに書いてゐるのをちよツと見て、あれは寫眞學校の先生のところだ、な、と思つたほか、別にどれにも追窮はしなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上書き畢つた時、弟潤三郎が説郛を抄して寄示した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上書き畢つた後、徳さんの言を聞けば、蘭軒夫妻と常三郎とは同一の熱病に罹つたらしく、柏軒も亦これに侵されて頭髪が皆脱したさうである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論封筒の上書きが男の字だったから、こんなことになったのでした。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上書きは男の子が自分の名前で自分で書いてよこしたんだが、中身は女房なんだ。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｊ・Ｇ・アッタスンの手にのみ開封さるべし、彼が先立ちて死する場合は読まれずして破棄さるべきこと、」とそれにはそうはっきりと上書きしてあった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、興奮していらいらしながら自分あての手紙を待ち、それが遅れるとみじめになって、どこまでも危惧の念に駆られるのだったが、さてその手紙が来て、エリザベートか父の上書きを見ると、思いきって読んで自分の運命を確かめる気にはなかなかなれなかった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し苦しめられただけに自分は封筒の上書きだけ日本字で書かれた令孃の返書に接した瞬間の喜びは、全く言葉に現せない位であつた。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを受取りながら私に向かって、先生（彼は私を小学校の先生と判断したのだ）は字が書けるかと聞く、字位は書けるよと答える、それなら帳面の上書きを頼むと言われて、今更断る訳にも行かず、金銭出納帳、物品貸付帳、仕切帳、何帳、何帳と、先方のいうがままに十五、六冊書いてやった。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神経をずたずたにされたような叫びはヒステリックな谺を返しつつ、邪悪な上書き彫刻のある太古のアーチ状通路を通り抜けて行った。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "一層信じ難く名状し難い悪夢――粘液にまみれ悪臭芬々たる、一目たりと見ることのできない原形質の山であり、その種族は深淵を征服し地上へと先遣隊を送り出し彫刻を上書きし丘じゅうを穴だらけにしてのたくりまくっているのだ――の居所については推測さえできなかった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々には嬉しかった、病的な上書き彫刻を――ほとんど見えなくても存在が感じられるのだ――後にしていくことが。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、上書きを書こうとして、何かにはっと気がついたように、ペンをにぎったまま、その封筒を見つめた。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "上書きがそうで、彼の希望に関する個所がそうだった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ユリ　そんなによくばらず　上書きだけは　明日のたのしみに　とってお置き　疲れた証拠に　息が　こちらへ　触れる程だよ」と。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒にはこういう上書きがしてあるのさ、『わが天使なるグルーシェンカへ――もしわがもとに来たりなば』これはしんと寝静まった時こっそり自分で書きつけたのだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテルブルグへ舞い戻ってからは、なるほど手紙を二通出すには出したが、それはかねての申しあわせにしたがって上書きを夫妻連名にして置いたのである。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかでもない何かの品、たとえば鎖かカフスボタンか、あるいはそれを包んだ紙きれで老婆が手ずから上書きしたものが、あの時どうかしたはずみですべりぬけ、どこかの隙間へ落ち込んだかもしれない。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包のうわがきに、「さよなきどり。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
