        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "Ｔ「さすれば源兵衛貴様は打ち首」　と言われて源兵衛愈々困り果てる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「運よく召しとって、奉行所へ突き出せば、奉行はじめ狼狽し、やがてその狼狽をかくすために、やい、首のなき者よ、汝盗賊を働かんとせし罪科軽からず、速刻打ち首に致すとあわてて申し渡すに相違ない。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありようしだいはかくのとおり、もうじたばたはいたしませぬ……すっぱりと、あすにでもすっぱりと打ち首にしてくだせえまし。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、その子ゆえに、そちの命の長かるべきよう慈悲をたれて、縛り首打ち首にもすべきところを遠島に上申すると申すのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "行列｜紊す浪藉者は、打ち首勝手たること存じおろう！",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「打ち首……」「へえ」「というところを、片耳を剃いで、抛りだしたそうで」「ひどいことをしやがる。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九十郎をとらえて打ち首にせい」　伝聞した九十郎はお吉を連れ、その夜のうちに逐電した。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉いお弟子たちはあるいは打ち首、あるいは流罪になられました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁裡御賄頭田村肥後、御勘使津田能登、服部左門、御買物役西池主鈴などという武士は捕われて打ち首となった。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓一揆の処罰と言えば、軽いものは笞、入墨、追い払い、重いものは永牢、打ち首のような厳刑はありながら、進んでその苦痛を受けようとするほどの要求から動く百姓の誠実と、その犠牲的な精神とは、他の社会に見られないものである。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪士らのうち、百三十四人は十五日に、百三人は十六日に打ち首になった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月十七日以後のこともすこしは存じておりますが、十九日にも七十六人、二十三日も十六人が打ち首になりました。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾路行軍の途中、東山道軍の軍規を犯した同藩の侍が野尻宿で打ち首になり、さらに馬籠の宿はずれで三日間｜梟首の刑に処せらるるというものの首級なのだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、番太のむすめに戯れたぐらいで、打ち首とは、おれもたまげたよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と勝重がそれを引き取って、「番太の娘に戯れたぐらいで打ち首になった因州の武士は東山道軍が通過の時にもありますよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は時も艱い上に、軽いものは笞、入墨、追い払い、重いものは永牢、打ち首、獄門、あるいは家族非人入りの厳刑をさえ覚悟してかかった旧時代の百姓｜一揆のように、それほどの苦痛を受けなければ訴えるに道のない武家専横の世の中ではなくなって来たはずだからである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打ち首に会うか火あぶりにされるか、海の中にほうりこまれるか、いずれにしても、固く神の教えを信じて動かなかったならば、必ず天国の栄冠を賜わるのだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよいよ白状いたさぬとあれば、明日｜其方を打ち首にせよとの、お館様よりのお沙汰なのだぞよ！",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たとえ打ち首になろうとも、逆磔刑にされようとも、汝ごときにこの体を、女の操を許そうや！",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……八重めはお館の命により、明朝打ち首に致すはずじゃ。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、その後は二人して夫婦になろうとそれは自由じゃ」　ここで頼母は言葉を切り、また二人をじろり見て、「それともあくまで強情を張って、淀屋の独楽を渡さぬとなら、この場において其方を殺し、明朝八重を打ち首にする。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切腹かそれとも打ち首にされよう。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ここにちゃアんと鎮座ましましている）「旗あげせぬうちに捕えられ、打ち首じゃ！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋十郎は弾正太夫の手で、その後打ち首の刑に逢い、忠義の右衛門と島君とは夫婦になったということである。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃアお手当てになりゃア、切腹か打ち首か、あんたのお命は無えものだが、あっしも、黒門町と言われる男だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいこと、地球は自転するのに二四時間ちょっきり――公爵夫人　ちょっきりとな、こやつを打ち首にせい！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　打ち首なんかさせなくってよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子屋　よろしければお茶の方を済ませても……キング　構わん、行け――　帽子屋は走り出ていくクイーン　外でやつを打ち首にせい！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのヤマネは打ち首じゃ！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
