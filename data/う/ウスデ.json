    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thin (paper, cloth, porcelain, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "難を云えば造りが薄手に出来ていて湿気などに敏感なことです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "身をかわして薄手だけで遁れた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "きわめて薄手な色白の皮膚が斑らに紅くなった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "油気も無く擦切るばかりの夜嵐にばさついたが、艶のある薄手な丸髷がッくりと、焦茶色の絹のふらしてんの襟巻。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そして、肩越しに此方を見向いた、薄手の、中だかに、すつと鼻筋の通つた横顏。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも來る時は、縞もののそろひで、おとなしづくりの若い男で、女の方が年下の癖に、薄手の圓髷でじみづくりの下町好みでをさまつてゐるから、姉女房に見えるほどなのだが、「嬰兒が乳を呑みますから、私は何うでも、彼女には實に成るものの一口も食はせたうござんすから。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、さきに、伊達の停車場を出て間もなく踏切を越して、しばらくして、一二軒、村の小家の前に、細い流に一際茂つて丈ののびたのがあつて、すつと露を上げて薄手ながら、ふつくりとした眞新しい蕾を一つ見た。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、鬼神の瞳に引寄せられて、社の境内なる足許に、切立の石段は、疾くその舷に昇る梯子かとばかり、遠近の法規が乱れて、赤沼の三郎が、角の室という八畳の縁近に、鬢の房りした束髪と、薄手な年増の円髷と、男の貸広袖を着た棒縞さえ、靄を分けて、はっきりと描かれた。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "総てが薄手で、あり余る髪の厚ぼったく見えないのは、癖がなく、細く、なよなよとしているのである。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄手のお太鼓だけれども、今時珍らしい黒繻子豆絞りの帯が弛んで、一枚小袖もずるりとした、はだかった胸もとを、きちりと紫の結目で、西行法師――いや、大宅光国という背負方をして、樫であろう、手馴れて研ぎのかかった白木の細い……所作、稽古の棒をついている。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文金の高髷ふっくりした前髪で、白茶地に秋の野を織出した繻珍の丸帯、薄手にしめた帯腰｜柔に、膝を入口に支いて会釈した。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをしも通夜の席の笑いばなしの種子にされるというのは何という果敢なくも薄手で安直な老女のいのちでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに想念に浮ぶ厚手の花の形と薄手の花の形と、輪違いに紙の中での狂い咲き。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半身から上が裸体で筋肉を自慢に見せて居る壮漢が薄手の斧を提げて来た。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に黒く剛い、しかし外に灰銀の柔かな、平滑な光の面、面は縦に大きく円く、極めて薄手の幅を持って、その両面が、一方は紫の陰影をしかもまた旋転光の数かぎりなき細かな輪の線を辷らしながら、目にも留らぬ速さで廻っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とまた、あの幅の広い広い、そうして薄手の薄手の白紙が、ローラーからローラーへ、一｜間の余の空間を辷って巻き附くその全く目にも留らぬ廻転と移動とを以てして、些の裂けも破けも、傷つきも飜りもしないことだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、場長さんが、若い技手に白い陶器のミルク入れと、白い西洋皿と、透きとおった薄手のカップとを運ばせて来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もせぬ幽かな姿、　黒い頭巾をかむって、黒い服をつけて、それはまことに白皙の、髪も眉も※毛も、その太い鼻も、頬の額の深皺も雪のような、何か品のよい老婆が、壁際の白いベッドに白いクッションを高く、下半身に白い薄手の毛布を引きあげて、そうして白い両手をその上に組み合せて、じっと此方を見入っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄手で寂しい、眉の凜とした瓜核顔の……佳い標致。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子分ふたりは薄手を負って、あやうく彼を取り逃がそうとしたが、とうとう半七と幸次郎に追いつめられて、泥田のなかで組み伏せられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "深田久弥氏のものは今年になつてからは出会はず、それ以前折々読み、いつも薄手でないところの風格的なる長閑さに満々たる夢を湛えてゐるおもむきに好感を誘はれてゐた。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄手のコップに泡を立てて盛られた黄金色の酒は葉子の手の中で細かいさざ波を立てた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄あかりのなかに凝視むる小さな銀側時計の怪しい數字に苦蓬の香沁みわたり、右に持つた薄手の和蘭皿にはまだ眞赤な幼兒の生膽がヒクヒクと息をつく。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肩に三ヵ所胸に二ヵ所、みんな薄手だ、大丈夫。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勢い込んで斬りつけた吉川の長刀が、その鴨居に斬り込んだので、あわてながら刀を抜こうとする隙を、老人は身を躍らして、吉川の左肩へ、薄手ながら一太刀見舞った。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは、その時には、女と思って油断をしたために、つい薄手を負ったのが、この二の腕の傷じゃ」　彼は、自分の腕をまくって、二の腕の傷を見せた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶道具と鉄瓶とを持って部屋へかえって来たら、もうすでに馬場と太宰が争っていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はしばらく困ったやうすでしたが、眼をカムパネルラの方へ向けて、「ではカムパネルラさん。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラのとなりの女の子はそはそは立って支度をはじめましたけれどもやっぱりジョバンニたちとわかれたくないやうなやうすでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は奈々子が一昼寝してからであった、雪子もお児もぶらんこに飽き、寝覚めた奈々子を連れて、表のほうにいるようすであったが、格子戸をからりあけてかけ上がりざまに三児はわれ勝ちと父に何か告げんとするのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
