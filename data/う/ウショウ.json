  {
    "uuid": "5033e82d-e22e-5746-86c4-c5913ddb31a8",
    "entry": "有生",
    "reading": {
      "primary": "うしょう",
      "alternatives": [
        "ゆうせい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "living thing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（未完）（八）　権威は勝利者の手にあり　（続）　而して今茲に有生十五億を眩目せしむるの巨光、而して又、世界第二の文明を経営すべき参天の巨柱は建設せられたる也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天地無始終、人生有生死」であります。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩は諸君もご承知のとおり山陽の詩の一番初めに載っている詩でございます、「十有三春秋、逝者已如水、天地無始終、人生有生死、安得類古人、千載列青史」。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "不図渠は、諸有生徒の目が、諄々と何やら話し続けてゐる校長を見てゐるのでなく、渠自身に注がれてゐるのに気が付いた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "不圖渠は、總有生徒の目が、諄々と何やら話を續けてゐる校長を見てゐるのでなく、渠自身に注がれてゐるのに氣が附いた。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の存在は万有生命の惰性の表現である。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごときあらゆる対象から、有生たると無生たるとを問わず、人間たると物たるとに論なく、一切のいわゆる偶性を抽象することによって、これを究極まで抽象してゆけば、ただ論理的範疇のみがそこに実体として残る、といい得るわけである。",
              "citation": {
                "source": "科学批判の課題",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "七、國有工場の増大、國有生産機關の増大、共同的設計による土地の開墾および改善。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『楞伽経』に曰く、「かの生滅するは、これ識、不生不滅は、これ智」と）勝鬘経曰、世間言説故有死有生、死者諸根壊、生者新諸根起、非如来蔵有生有死、如来蔵離有為相、如来蔵常住不変。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "又曰、有生死生是相続法、如何間絶言無中有、乃至猶如種果、是続生、種果無間絶、死生是続生、死生無間絶、云云。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "また曰く、「有生じ死生ずるはこれ相続の法、いかにか間絶して中有なしという。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『秘蔵宝鑰』に曰く、「生まれ生まれ生まれ生まれて生のはじめに暗く、死に死に死に死んで死の終わりに冥し」と）永覚禅師曰、夫人身一天地也、天地有成壊、而為天地之主宰者未嘗滅也、故壊而復成、人身有生死、而為人身之主者、未嘗滅也、故死而復生。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "お放しなすって、え、どうしょうねえ」　とおぼえず、声を放ちたり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、蟹は、「とこやというしょうばいは、たいへんひまなものだな。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一とうしょう、白金メタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第二とうしょう、きんいろメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第三とうしょう、水銀メタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第｜四とうしょう、ニッケルメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第五とうしょう、とたんのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「第六とうしょう、にせがねメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第｜七とうしょう、なまりのメタル。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第｜九とうしょう。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀はただほっとして「あら、嫌否、私はもうどうしょうねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仁右衛門が見た御新姐のように、この手が触って血を吐きながら、莞爾としたらどうしょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、これからどうしょうかと思案しているらしかったが、やがて馭者にむかってきいた。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、しょうしょう、伺います」「どなた」　中から声がして顔を出した者があった。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょうしょう物を尋ねたいが、ここはどこであろう」　提燈を持った男が足を停め提燈をあげて武士の顔を透すようにした。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、しょうしょうおたずねします」　彼は女を驚かさないようにと思ってつとめてやわらかに云った。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、しょうしょうお願いいたします」　中から年とった男の声がした。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょうしょう伺います、海岸の方へ往くには、どう往ったら宜いでしょう」　三人｜伴の道具箱を肩にした大工の一人を見つけて訊いてみた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
