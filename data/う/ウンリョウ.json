          ],
          "literary": [
            {
              "text": "翌日は雲量零の大快晴であったが、かえって怠れて、マチガ沢でトカゲして午後の汽車で帰京した。",
              "citation": {
                "source": "一ノ倉沢南稜",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この考えをさらに確かめるものは、日照時数および雲量の比較である。",
              "citation": {
                "source": "雪三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平均雲量も札幌の四月は六・五であって、東京の四月の六・九に比して明らかに少ない。",
              "citation": {
                "source": "雪三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
