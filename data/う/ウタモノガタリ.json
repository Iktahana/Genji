        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "常に宇宙の深遠なる悲愁、神秘なる歓楽を覚ゆるものから、当代の愚かしき歌物語が、野卑陳套の曲を反復して、譬へば情痴の涙に重き百葉の軽舟、今、芸苑の河流を閉塞するを敬せざるのみ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に宇宙の深遠なる悲愁、神祕なる歡樂を覺ゆるものから、當代の愚かしき歌物語が、野卑陳套の曲を反復して、譬へば情痴の涙に重き百葉の輕舟、今、藝苑の河流を閉塞するを敬せざるのみ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歌物語など致しておりました」「恋歌の講釈か」と、彼はまたあざ笑うような眼をした。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方はいつもの歌物語であろうと気を許して、信西入道はゆるゆると支度して伺候すると、忠通は待ちかねたように彼を呼び入れて出逢った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらが今宵、大納言｜師道卿の屋形へ歌物語を聴きにまいろうと存じて、四条のほとりへ来かかると、兼輔めが人待ち顔にたたずんでいる。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらが今宵、大納言師道卿の屋形へ歌物語を聴きにまいろうと存じて、四条のほとりへ来かかると、兼輔めが人待ち顔にたたずんでいる。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七　歌物語に何の癡言と聞き流せし戀てふ魔に、さては吾れ疾より魅せられしかと、初めて悟りし今の刹那に、瀧口が心は如何なりしぞ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　実生活を詠んだ歌物語の主人公は勿論、もでるを思はせる様な書きぶりで表されてゐる。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "其例の物に伊勢物語系統の歌物語の型をとり容れて来たのがあつて、自分の贈答や述懐の短歌の製作動機を、あはれに書く風が出来た。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑歌が歴史的の意義を持つてゐる事は明らかであつて、謂はゞ、歌物語を簡明に、集成したものであつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、平安朝中期以後の歌、及び其に基いて出來た歌物語は、虚構といつてよい。",
              "citation": {
                "source": "文學に於ける虚構",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ風にして、虚構の多い歌を作り、歌物語を作つてゐた、其傳統を承け繼いだ連歌師・誹諧師が、虚構の文學を作るのは、當然のことゝ言へよう。",
              "citation": {
                "source": "文學に於ける虚構",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「烏羽玉のわが黒髪は白川の、みつはくむまで老いにけるかな」（大和物語）という檜垣嫗の歌物語も、瑞歯含むだけはわかっても、水は汲むの方が「老いにけるかな」にしっくりせぬ。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣通媛の藤原｜郎女であり、禊ぎに関聯した海岸に居り、物忌みの海藻の歌物語を持ち、また因縁もなさそうな和歌浦の女神となった理由も、やや明るくなる。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安の女房日記や、其歌物語が、宮廷貴族の子女教育に用ゐられたり、男子の手に書かれたものでも、倭名鈔や、口遊などが、修養書に使はれた例の古いものではあるまいか。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の日記が、旧事・歌物語の外に、私事を多く交へる様になつて、段々、女房文学が栄えたのである。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "前代の風俗・歌を中心に綴つた説話記録が、歌物語となり、自分の身辺の応酬を記した部分が日記歌として行はれるやうになり、其が更に単独な物語や、家集・日記・世代歴史を生む様になつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、先代の語部の意義において仕へてゐた女房の仮名文によつて、歌物語の描写が、段々新作を導く様になつた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから歌物語は逸話の形をとつてゐた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏物語は、歌物語と中篇小説とを併せた形である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが平安朝に持ち越されて、平安朝の物語、所謂歌物語と言ふものが出来てをります。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌物語における滑稽は、歌諺類を、すべての人をして、信じ難い方法で以て、而も強ひて巧みに説明する技巧から出て来るのである。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌の本辞（もとつごと）言ひ換へれば、歌物語の古形であつて、また必しも歌の為のみに有するものと考へられて居なかつた時代の形なのだ。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
