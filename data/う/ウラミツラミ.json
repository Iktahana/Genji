        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "実はきのうも八橋から呼び出しの手紙が来て、いろいろの恨みつらみや愚痴が長々と書いてあった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は胸に抑えあまる恨みつらみをいい出すには、心があまりに震えて喉がかわききっているので、下くちびるをかみしめたまま黙っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母の手紙はいつでも恨みつらみで満たされていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみを云うような、ケチな野郎は一人だってありゃしねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみをいうようなけちな野郎は一人だってありゃしねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよいことだと弁信さん、あなたも賛成なさいますから、あなたを信じて、ここへこうして三日目になりますけれど……」　ここでも、お雪ちゃんが、弁信の株を奪って、一息にこれだけの恨みつらみを述べたててしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれア伊賀の源三郎に、なんの恨みつらみもねえ痩せ浪人。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみを無言のうちに思い知らせようとしているとしか思えない。",
              "citation": {
                "source": "鈴木主水",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみは、ともかく少し逃げてから。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの身を破らせておいて、女は、後じゃ恨みつらみ……。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし今の年でしたら、何の構うことがあるものですか、いきなり、戸を叩き破ってでも、二人のそばへ駈込んで、恨みつらみのありたけを、並べもしたでしょうけれど、何を申すにも、まだ小娘の当時では、とてもその様な勇気が出るものではございません。",
              "citation": {
                "source": "人でなしの恋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから専務支配人宛に、恨みつらみをつらねた手紙を書く、悪い月ばかり呉れて僕一座を殺す気か、四月は有楽座がいけないなら、日劇を本興行で開けさせろ、さもなきゃクビにしろと言ってやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みつらみは、親の十太夫にもない、家族たちにもない、甚三郎にもない。",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうなったら、妾たち妻子は、またいつの日、あなたに会うことができましょう」　綿々と、恨みつらみを並べた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の誤解をなだめて、その不びんな恨みつらみに、ことばを尽して、よく得心を与えてやろう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "会って、ただの子として父として、一度いろんなことを、恨みつらみをも、言ってみたい」「めっそうもない。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨折り損のくたびれもうけです」　四馬剣尺が、どっかと腰をかけた頭目台の前へいって、この山塞の番頭格の木戸が、うらみつらみをのべたてた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜太郎は、あの娘に逢ったら、いきなり胸の囲みの中へとりこみ、今迄の、うらみつらみ、うれしさも悲しさも、何もかもいっしょくたに叩きつけ、人形のような、あの脆そうなからだを腕の中で押しつぶしてやるつもりだった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはなんでしょう」「手紙らしいわ……ながいあいだ書きためた、うらみつらみの恋文、てなもんでしょう」　愛一郎は、うたれたように、はっと顔を伏せた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、もし船の中へ走り込む元気があったならば、いきなり、竜之助の膝にしがみついて、うらみつらみを並べたかも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
