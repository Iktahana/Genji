    "definitions": [
      {
        "index": 1,
        "gloss": "to incur someone's enmity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
