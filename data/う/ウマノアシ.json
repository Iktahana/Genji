    "definitions": [
      {
        "index": 1,
        "gloss": "minor or untalented actor (relegated to roles such as the legs of a stage horse)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "馬の足なみがかげろうのようにちらちらちらちら光りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最後に、漸く人馬の足跡のはっきりついた、一つの細い山道を発見した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の足なみがかげろふのやうにちらちらちらちら光りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが戸外が急ににぎやかになって、町の中を狂気のように馳せちがう人馬の足音が聞こえだしたと思うと、寺々のかねが勢いよく鳴りはじめました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりの中から、チラチラ馬の足が光った。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御者はやがて馬の足掻きを緩め、渠に先を越させぬまでに徐々として進行しつ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "與一　　まして河の底には亂杭を打つて、大綱小綱を張りわたし、馬の足をさゝへんと巧んである。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ幸ひとよび止めて馬を借受け、むかうの岸までは渡りしが……これより遠き旅をゆくに、馬の足を假らでは不便なり、ぬすみて逃げんと馬をはやめて、二三町ばかり駈けぬくれば、馬士はおどろき追ひ來りて馬盜人よと罵りさわぐ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "驢馬は驢馬の足を曳きずって、驢馬の鳴声を鳴くより外はない。",
              "citation": {
                "source": "砕けた瓦",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ猫の歯をのがれたにしても、道を通る馬の足か、車の輪でぺしやんこに轢かれてしまふだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "才之助は、菊の良種を得た事で有頂天なのだから、そんな馬の足音なぞは気にしない。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁慶の足あとだとか、義経の馬の足あとだとか、何だとかいふ話だ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の足跡の多い畝路を歩き尽して、其の部落に足を踏み入れた時、多吉も松子もそれと聞かずにもう学校の程近い事を知つた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝に旅籠屋を立つてから七八哩の間は潦に馬の足痕の新しい路を、森から野、野から森、二三度人にも邂逅した。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今はどうも……飛んだ失礼を……真平、御免下されまして……」　五十ばかりの亭主と見える男が、走って来て平馬の足元に額を擦り付けた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉川の沿岸は、水田多く、人馬の足立たず、殊に越前勢は、所の案内を知らざる故、水田沼沢の地に人馬陥り、撃たるる者が多かった。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑山修理亮の足軽共が、馬の足を冷そうと、湖の磯に出て居るのを見付けた盛政は、馬上から、討取って軍神の血祭にせよと命じたので、忽ち数名が斬られた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、真先に飛込んで、間もなく馬の足を鎖に捲きたおされ、ドウと許り、真倒まに河中に落ちた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面はいたるところ馬の足跡だらけ、どうやら追っ手は大規模の騎馬隊、跡の通る方向からすると、そのあとソルト・レイク・シティへと引き返したようだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "童の足二つにて、馬の足の用をなせるなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の足掻の早きときは、窓より首を出すべからず。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我はこゝに至りて、復たこれを避けんと欲することなく、却りて二馬の足掻の猶太だ遲きを恨みき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっどっと馬の足音がすると思うと、ふッふッと強い馬の鼻息が聞え、やがて舌金を噛む音が聞えて、馬は庭まで這入ったけはい。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩の者はいよいよ驚いたが、すぐには人には洩らさないで猶も様子をうかがっていると、その後のある夜にも黒犬は馬に乗って出て、やはり暁け方になって戻って来たので、厩の者はひそかに馬の足跡をたずねて行くと、あたかも雨あがりの泥がやわらかいので、その足跡ははっきりと判った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが後の二人の白い騎士と、青い騎士とは、明るいうちは、それは強さうなことを言つてをりましたが、とつぷりと日がくれてしまつては、急に怖気がついて一歩も馬の足をすゝめることができなくなりました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面へ水を灑いでやっと蘇り、何と悔いても跡の祭と諦め、これというもわれ尊公を智馬と知らず悪み虐げた報いですと、馬の足を捧げ申謝して去った。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者馬の祖先の足に三、四趾あった当時の旧態に復って、かくのごとしと説くが通例だが、篤と調べるとそうでなく、かかる多趾の馬の足は、ヒッパリオンやアンキテリウムなど、過去世の馬の多趾な足に似ず、全く手足が一本多過ぎたり指が六本あったりの人と同じく、畸形不具者に過ぎずと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "圉人驚異したが敢えて洩らさず、その後また事あったので、雨後のこと故圉人が馬の足跡をつけ行くと、南方十余里の一古墓の前まで足跡あり。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ざまに倒れたところを、かの馬の足で脇腹を強く踏まれたらしい。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
