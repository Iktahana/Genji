        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中で一番威張れる者が、その赤らんだ薄い皮膚の眼蓋の上にロイド眼鏡を掛けて、彼女が襖を開くや愛相よく「今晩は」と言つた時、彼女は漸く何だか嬉しくなつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "向合て立つたのは細目の痩形、鼻下に薄い八字を蓄へて金縁の眼鏡が光る、華奢のステツキに地を突いて、インバネスの袖を氣にしながら對手が惡いと見て、怯氣た體、折折無氣味｜相に、眼を轉じて前後を竊視する。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の夕まぐれの茶の間の板縁で古新聞を引破ってのホヤ掃除をした経験をもたない現代青年が、明治文学に興味の薄いのは当然かもしれない。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ども平生自分で歌を作っていないものにとっては、ただ一本立の歌に対する興味はどうしても薄いようであります。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその地図の所々に薄い血痕のやうなものが付いて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに何せ薄い板切れでいい加減に作つた舟だから、水がしみ込んで來て危いのよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉間には狐疑の深い皺がきざみ込まれ、小さい灰色の眼には淺間しい殺意が燃え、眞蒼な頬は威嚇の怒りに震へて、黒ずんだ薄い唇は嫌惡と侮蔑にひきつつたやうにゆがんでゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が美味しい美味しいと、そのお魚フライを食べてゐると、やがてツカツカと、白い大きい※ーレをかぶり、青い洋服に薄い焦茶のストッキングをはいた、大きなアメリカの小母さんが這入つて来ました。",
              "citation": {
                "source": "夜汽車の食堂",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の四合目から以上を輪切りにすれば、木山に対するいわゆる石山で、イワツメグサ、オンタデなど、薄い髪の毛のような草はあっても、眼にいらず、ただ見上げるばかりの岩石の堆積である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし猿橋の方では、熔岩の延長八里ぐらいで、厚さも今日見らるるところでは、四、五｜米突ばかりの薄い皮であるが、サクラメントへ流れるシャスタ熔岩の厚さは、五十｜呎から二、三百呎に達している。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの、パンだとか、魚の切身だとか、巴焼だとかの包み紙の、古新聞が、風に捲かれて、人気の薄い街を駆け抜けた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中村だがね、ちょっと署まで来て貰いたいんだ」――誰だい――と呼ぶ吉田の声が、鋭く耳を衝いたので、子供が薄い紙のような眠りを破られた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年九月廿九日の早朝新宿駅中央線プラットフォームへ行つて汽車を待つてゐると、湿つぽい朝風が薄い霧を含んでうそ寒く、行先の天気が気遣はれたが、塩尻まで来るととうとう小雨になつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば作者の影の濃いと薄いとがある。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年九月二十九日の早朝新宿駅中央線プラットフォームへ行って汽車を待っていると、湿っぽい朝風が薄い霧を含んでうそ寒く、行先の天気が気遣われたが、塩尻まで来るととうとう小雨になった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は天体の星は扁平な薄い長方形の中に散布していて、その中ほどに我が太陽系が居るものと想像した。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち送ろうと思うものが写真ならば、これを薄い金属板に焼付けこれを前のコルン式同様に円筒に巻く。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受信機の方ではこれを電話の受話器のごときものに接続する、受話器の薄い鉄の円板の真中に固着した針が一本あってこれが原板の写しを画くペンの役目をするのである。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方法は、一種特別な種板の裏を水銀で蔽い、これで普通写真のように撮影した後現像すれば、種板を通って水銀に当る光線と、それから反射する光とが互いに干渉して種板の薄い膜の中に微細な縞が出来る、この縞の精粗は光の色によってちがう。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さほど醜くもなく、これだけ物事ができる自分が、せめて、どうして男の縁が薄いのだろうか。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの方はレンズが薄いのでわづかの光る粒即ち星しか見えないのでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」黒服のほうが薄いひげをひねりながら答えました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がまっ白に光って、ぐるぐる廻り、そのこちらを薄い鼠色の雲が、速く速く走っています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大都市の冬に特有な薄い夜霧のどん底に溢れ漲る五彩の照明の交錯の中をただ夢のような心持で走っていると、これが自分の現在住んでいる東京の中とは思えなくなって、どこかまるで知らぬ異郷の夜の街をただ一人こうして行方も知らず走っているような気がして来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから古典教育に関する著者の長い議論があるが、日本人たる吾々には興味が薄いから略する事にして、次に女子教育問題に移る。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時頃の薄い日影が庭半分にさしていて、梅の下には蕗の薹が丈高くのびて白い花が見えた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの乳牛に消化不良なのがあって、今井獣医の来たのは井戸ばたに夕日の影の薄いころであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁淀川と塩魚は縁が薄いが材木とは縁が深い。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、この地方の人は男女ともに黄金の薄い板を歯にかぶせて飾りにするとある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "切り離すと、もうそれは自分の活きた経験でなくなって、まるで影の薄い抽象的な「誰でも」の知識になってしまう。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
