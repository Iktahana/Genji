        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "此処は銀座の裏通りのカフェー、卓子の上で扇風器は、哀しげな唸りをつづけてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の感傷性がまたもや唸り出した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄々として唸りながら、無限に高く、穹窿の上で悲しみながら、いつも一つの遠い追憶が漂っている！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悶え苦しさに覚えず唸り声を出すと、妻は驚いてさし覗いたが急いで勝手の方へ行って氷を取りかえて来た。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ、ううむ、と大袈裟に唸りながら、めちや苦茶に鎌を振りまはして、時々、あいたたたた、などと聞えよがしの悲鳴を擧げ、ただもう自分がこのやうに苦心慘憺してゐるといふところを兎に見てもらひたげの樣子で、縱横無盡に荒れ狂ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その翌る日、狸は自分の穴の奧にこもつて唸り、「ああ、くるしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海抜二千尺、山峡を流るる川は、吹雪の唸りと声を合せて、泡を噛んでいた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず現代の応用科学の産み出した文化は天地間のエネルギーを駆使して多くの唸り声や吼声を製造するに忙しい。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唸り独楽の音なども同じような例である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしても風が烈しく唸りながら吹き過ぎて、屋根の上へ木の枯枝のようなものが落ちる音がした。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あるとも、一昨日なんか骨膜炎の手術を受けた老人がね、義太夫を唸り出す騷ぎだつたよ‥‥‥』と、水島は相變らず冷靜な顏附で云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まるで酒場の醉ひどれのやうな兵士の集團は濕つた路上に重い靴を引き摺りながら、革具をぎゆつぎゆつ軋らせながら劍鞘を互にかち合せながら、折折寢言のやうな唸り聲を立てながら、まだ五六｜里先のＮ原まで歩かなければならなかつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の蓙の上で絶え間なく笑ひを交へながら何か話し合つてゐる船客達の聲が、蜂の唸りのやうに耳を掠めて行つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉清輝と田川とは、傷の痛さに唸りながら、半ば、うつらうつらしつつ寝台に横たわっていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一発、弾丸が、彼の頭をかすめて、ヒウと唸り去った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるえる手で当もなく手掛りのない扉の面を撫で廻しながら動物のような唸り声をつづけていた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かゞ持って来て欲求を満してやらなけりゃ、中毒した支那人が唸り死んじまうだろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一ツのトラックの負傷者が、それぞれベッドに運ばれて、一時担架卒のがたがた出入する靴音が消えたかと思うと、まだ、軍医の傷の手あてが、みんなの三分の一にも行き渡らないうちに、次のトラックが病庭へ唸りこんできた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士の銃口からは、つづけて弾丸が唸り出た。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸が唸り去ったあとで頸をすくめるように、そのたび彼等は、頸をすくめた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ほどから露路をあちらへ行ったりこりこちらへ来たり、二匹の白猫が盛んに追っかけあいをしていたのであるが、この時ちょうど私の眼の下で、不意に彼らは小さな唸り声をあげて組打ちをはじめたのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし速力が緩み、風の唸りが消え、なだらかに橇が止まる頃には、それが空耳だったという疑惑が立｜罩める。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰さんは小声で義太夫を唸りながら、あらの始末をしている。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原に花をたずねて迷う蜂の唸りが聞える。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはあのゆるやかな抑揚ある四拍子の「子守り歌」の代わりに、機械的に調律された恒同な雑音と唸り音の交響楽が奏せられていた。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は高くあがっていて、凧の唸りがいくつも聞えた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百萬の羽ばたきの音は、眞晝のあぶの唸りに似てゐた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万の羽ばたきの音は、真昼のあぶの唸りに似ていた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ『玉三』でも唸りながら書こう。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか『太陽』の口絵にて見たるようなりと考うれば、さなり三条｜君美の君よと振返れば早や見えざりける。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
