            {
              "text": "私は毎日うめぇについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "うめぇという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はうめぇの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはうめぇが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "うめぇを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはうめぇについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "うめぇの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はうめぇの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではうめぇが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "うめぇという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にうめぇという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではうめぇについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "うめぇを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとうめぇは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "うめぇについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではうめぇが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にうめぇは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりうめぇの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "うめぇは様々な場面で使われる。",
              "source": "幻辞"
            }
