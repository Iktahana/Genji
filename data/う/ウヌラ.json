          ],
          "literary": [
            {
              "text": "汝等祝福されてあるべきなり、其の他はすべて分解しければ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ星に甘え、われ太陽に傲岸ならん時、汝等ぞ、讃ふべきわが従者！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等ともに闇くして、且はひめやか。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が底を探りたる、者とてはなく、汝がゆたけき内奥を、知るものとてなかりけり、さまで汝等秘密をば、守らんこと敏なりき！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等おのれを愛するが如く、汝の隣人を愛せよ。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉「よーしＴ「汝等、よう開けぬ　のなら、俺が　斬って落すぞ」　と叫んで太刀大上段に振り上げ、Ｔ「此村大吉が　柳島の妙見に　一大乱闘の幕　切って落すぞ」　と叫んで一同の中へ斬り込む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち説いて曰く、　汝等審に諸の悪業を作る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等飛躍して之を握む。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等之を※食するに、又｜懺悔の念あることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等｜審に諸の悪業を作ると。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等といふは、元来はわれわれ梟や鵄などに対して申さるゝのぢゃが、ご本意は梟にあるのぢゃ、あとのご文の罪相を拝するに、みなわれわれのことぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち説いて曰く、　汝等｜審に諸の悪業を作る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に小禽｜既に終日日光に浴し、歌唄跳躍して疲労をなし、唯唯甘美の睡眠中にあり、汝等飛躍して之を握む。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等飛躍してこれを握む。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等これを※食するに、又｜懺悔の念あることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に小禽｜既に終日日光に浴し、歌唄跳躍して疲労をなし、唯唯甘美の睡眠中にあり、汝等飛躍してこれを握む。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、我々がうぬらをそばに置くとしたらば、それはただ我々の教義を信じる者としてのみである。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この荒野で白い骨となった方が最善なのだ、うぬらが、やがて果実すべてを腐らせてしまう腐敗の一粒になるのが必然であるのならな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はうぬらが荒野で餓え、死に瀕していたとき、うぬらを拾い上げた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "なめこというぬらぬらした豆きのこは大変ねだんがよかった。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あそこばかりは二度ともう――」「うぬらもかッ」「でも、気味がわるくて近よれませぬ」「死骸か！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな古手でうぬらばかりうまいしるが吸われると思うとあてが違うぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬらに捕まる百化けのお兄さんかい。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬらごとき不浄役人の詮議うける覚えはねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三とせ前からこうして矢場を開き、うぬら初め家中の者共の弓の対手となっていたは、みな御老中の命によって当藩の秘密嗅ぎ出すための計りごとじゃ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――者共ッ、一歩たりともそこ動かば、江戸で少しは人に知られた早矢の英膳が仕止め矢、ひとり残らずうぬらが咽喉輪に飛んで参るぞッ」　言いつつ、射て放ったはまことに早矢の達人らしく一｜箭！",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬらがつけた因縁じゃ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "事ここに至っては命にかけてもうぬら二匹、追ッ払わねばならぬ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬらがまま子根性でやったにちがいない！",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんばこの小娘が子ぬすっとの下手人であろうと、うぬらにかってな吟味｜折檻させてたまるけえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            }
          ]
        }
