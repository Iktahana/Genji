        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "能楽の内兜を見透かして、能楽師を恐れ入らして遣ろう……ぐらいの了簡で、初めからわかったような高慢な顔をして楽屋を覗きに来る馬鹿が多い。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふと金がどうかなっていはしないかと思ったが、そこで検べることも出来ないので、それを上衣の内兜に入れ、時計を手首に着けた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙作は廊下へ出ると内兜に手をやって紙入を出してみた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分から進んで内兜を見透かされたようなもどかしさはいっそう葉子の心を憤らした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行け、行け」　もうこっちの内兜を見透しているので、平作は素直に立去らない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "伜には内兜を見透かされる、女将には冷やかされる……」「アラ、冷やかしなんかしませんわ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトヨリ内兜を見せる吾輩ではなかったので、引つぎ引つぎ傾けているうちに、忘れるともなく友吉親子の事を忘れていた。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも乗馬水田に陥りて再立たず、時に飛矢あり、颯然として流星の如く彼が内兜を射て鏃深く面に入る。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "なか／＼他人の中へ突出されて、内兜を見透かされねえやうに遂行げるのは容易ぢやねえ。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代を笑ふ近代マニヤ連中の内兜は、すつかり見透しなのだからね。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢は、景経の内兜につき刺さった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすきをねらっていた入善は、あっと思う間に判官の内兜に刀を突きさした。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "取って押えて、首をかこうと、内兜を押しひろげてみると、思いもかけぬ花のような美少年であった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いすがる武者を斬り伏せたところへ、上総太郎判官のひょうと射る矢が兼綱の内兜を射当てた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お学問とは関係なきを、万々御承知の筈の旦那が、かうして見ればつゆいささか、伎倆なき奥様の、内兜見透したまひてや。",
              "citation": {
                "source": "今様夫婦気質",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらがながめるより先に、先方は敵の提灯で、敵の内兜を見定めたと覚しく、「こいつは少し当が外れた！",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、言葉はまさにこの秋草を描いた襖のあなたから迸り出たのに違いないのですから、一旦は狼狽したが、もとより相当な奴ですから、ここらで内兜を見せるようなことはない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "実家の奴等に笑われようと、彼女に内兜を見透かされようと、出かけて行って平詫りに詫まって、姉や兄貴にも口添えを頼んで、「後生一生のお願いだから帰っておくれ」と、百万遍も繰り返す。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
