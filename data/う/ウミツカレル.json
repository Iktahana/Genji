          ],
          "literary": [
            {
              "text": "太陽が中天に一休みして暑さと砂ほこりにみんなが倦み疲れる頃を見はからい彼は唄をうたった。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日同じ事の繰り返しにすぎませんが、決して倦み疲れることを知りません！",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像に倦み疲れると、凡てを頭の外へ抛り出そうとした。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の役割に倦み疲れるせいか、子供心にとらわれて他のことを考えるせいかだったろう。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
