        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おまけに犬が、それを胡乱な武器と感ちがいして、さかんに吠えたてるかも知れぬのだから、一つとして、いいところが無い。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ、そんなら貴下は、その新聞包みを棄つるに際して、きょろきょろ四辺を※したり、胡乱々々往来をしたんじゃね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」「木賃泊りの天井裏に、昼は内に潜って、夜になると、雨でも、風でも、稲葉屋の周囲を、胡乱つき廻って、稲荷さんの空地に蹲んでもいりゃ、突当りの黒塀に附着いて立明す……そうして声を聞く、もの音を考えるですだい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「挙動が奇怪じゃ、胡乱な奴等、来い！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姉さんは貴方、こないだから、昼間参りましたり、晩方来ましたりいたしましては、この辺を胡乱々々して、行ったり来たりしていたのでございますがね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と道は落着かず胡乱々々する。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "米は鍵屋あって以来の上客を得た上に、当の敵の蔵屋の分二名まで取込んだ得意想うべく、わざと後を圧えて、周章てて胡乱々々する蔵屋の女に、上下四人をこれ見よがし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の真似やら、おなじような、あたまから羽織を引かぶった若い衆が、溝を伝うて、二人、三人、胡乱々々する。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更本郷くんだりの俺の縄張内を胡乱ついて、三世相の盗人覗きをするにゃ当るまい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾疋となく、やがて五六十、夕焼がそこいらを胡乱つくように……皆猿だ。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋室｜擬いに窓を狭め、畳が敷いてある様子までが、胡乱に感じられる部屋つきです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブダブの印度服に、無恰好なゴム長靴を穿いて一瞬間私を胡乱臭そうな眼付で見たが、やがて頭をピョコリと下げて見せた。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に経歴を偽っても、又は柔和な人相をしていても、「此奴油断のならぬ奴」　と思わせるのは、その胡乱な経歴から来た性格が鼻に現われているからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、此の屑屋が興がつた男で、鉄砲笊を担いだまゝ、落ちた処を俯向いて、篦鷺のやうに、竹の箸で其処等を突つきながら、胡乱々々する。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯を入れて、更めて、町奉行が、余の事に、櫓下を胡乱ついた時と、同じやうな状をして見せろ、とな、それも吟味の手段とあつて、屑屋を立たせて、笊を背負はせて、煮しめたやうな手拭まで被らせた。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図らざりきこの船遊びを胡乱に思い、恐るべき警官が、水に潜みてその挙動を伺い居たらんとは。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お浪は仔細ないと認められて一と先ず釈されたが、お照は申し口に少し胡乱の廉があるというので、これも番屋に止められた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だしぬけに出ましてこんなことを申すのですから、定めて胡乱な奴とおぼしめすかも知れませんが、いよいよお使いくださると決まりますれば、身許もくわしく申し上げます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋作は自分の叔母だと云っているが、それがどうも胡乱である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女がどうも胡乱だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間でも彼の目には胡乱なものは屹度吠えられた。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼を胡乱と見とがめて、采女は一応の詮議をすると、彼は明瞭の返答を与えない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こやつ、胡乱と見ましたで引っ捕え申した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "京を立ち退く時には心のみ急がれて、ろくろくに前後の分別もなく、彼を路しるべとして此処まではまいったれど、何やら性の知れぬ胡乱な奴、いつまでも道連れにするは不安のようにも思われまする。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、あの決して胡乱な旅籠ではござりませぬ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その慌てた口ぶりがどうやら胡乱に思われたので、五、六間も行き過ぎて又見返ると、彼はまだ行きもやらじに立ち明かしている。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍は胡乱らしく玉藻をじろじろ眺めているので、玉藻は丁寧に会釈して、主人の入道に取次ぎを頼むと、侍は更に彼女の顔を睨むように見て、すぐに内へ引っ返して行った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、一たん太っちょの患者と一緒に行き過ぎた老看護婦が戻って来て、加奈子をうろんな眼で見ながら訊ねた。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの犬たちが出て来て、店の中へもぐりこもうとでもしますと、やせ犬はうゝうときばをむいておいまくり、うろんくさい乞食が店先に立つと、わんわんほえておいのけてしまいます。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ物そうなので、町々では青年団なぞがそれぞれ自警団を作り、うろんくさいものがいりこむのをふせいだり、火の番をしたりして警戒しました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
