        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もう大概で打ち切りにしてもよさそうに思われるのに、そうしないのは、やはりジグスとマギーのような「定型」の永久性を要求する大衆の嘱望によるものであろう。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減に切り上げようかと渡瀬の思ったのもたびたびだったが、そうするとこの方の研究は早速打ち切りになって、他の研究がはじまるのを覚悟せねばならない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情上のはなしと聞いて、よく世間にある老人のように、うるさいものと思い取り、こういう態度で、暗に、打ち切りを宣告したのかも知れない。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長くなりますので、今日の手紙は、これだけで打ち切ります。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガルスワーシーが突如此の額を卸ろして来て景子達に差出した仕打ちは一つは宗教問題打ち切りの宣告でもあり、一つは印度女への無言の叱責でもあった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、貴女に洗いざらい打ち明けて、美和子さんとの話は、打ち切りたいと思ってやって来たんですよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の日記には、「今回は打ち切り、また道を探ろうと自分を説得する」と書いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九八六年三月、アスキーとマイクロソフトが独占代理店契約を打ち切り、新たにマイクロソフトの日本法人が設立される中で、アスキーの開発本部担当取締役を務めていた古川は、新会社の社長へと一大転身をはかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな題をつけて照れ臭かつたといふのは、そんな気勢も知らずに、たゞ弱々しく題してゐたといふのが、ぼんくらだつたと後悔され、これは（一―三）これで今回で打ち切り、いつかまた改めて出直さうと思つた。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この類の事まだ夥しくあるが、今度はこれで打ち切りとして、もし私人がこの文を読むに起因して大儲けをしたら、お富も三十七まで仲居奉公に飽きてこの上娘が承知せぬというから、なるべく大金を餽って片付けやってくれ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、象牙のことは今日限り打ち切りまして、やっぱり従前通り、木彫りの方をお願い致しましょう」と、よく要領を得た答えに私もよろこび、その後相変らず沢田氏の注文で二、三回も木彫りの仕事をしたことがありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のごとき推理に基づいて、私は田端事件の犯人は既にこの世にいないことを主張し、したがって当局者が、この上、この事件の捜査に貴重な時間と労力とを費やすは無益であることを信じて、捜査の打ち切りを切に当局に勧告するものである。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また出したねえ、粂仙を」「執念深うございます」「妾もそうさ、袴さんにはね」「面白くないというところで、打ち切りやしょうや、この話はね、ほんとにあっしは袴様では痩せるほどあねごにコキ使われていまさあ」どうやら忠三不平らしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人の方から契約の打ち切りを云はれたのなど、彼としても決して有難いことではないのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "社大党支持者の多い総同盟や、日本無産党支持者の少なくない東京交通労働などの諸労働組合は、争議打ち切りと労資協調へと転向した。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど濃厚なるビステキにてひたと打ち切りてはかへつて物足らぬ故更に附物として趣味の変りたるサラダか珈琲菓物の類を出す。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一昨夜電車でお目にかかった時、今日のように名乗って下されば、うちででもお話が出来たのですが残念でしたね」　私は論議打ち切りの印のつもりでこう云いながら、傍の雑誌を手にとった。",
              "citation": {
                "source": "途上の犯人",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察や本庁の人達の調べは約二時間余にもわたつて漸く一先ず打ち切りと云うことになつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーとの提携解消後、一〇〇パーセント子会社として設立されたマイクロソフト株式会社は、ＭＳ―ＤＯＳの勝利が確定した段階で、アプリケーションへのバンドル打ち切りに向けて動きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気は一九八七（昭和六二）年一月から、主要なソフトハウスを集めてＭＳ―ＤＯＳのバンドル打ち切りに関する検討会を開始し、約半年の準備期間を経て、アプリケーションのバージョンアップを機会にバンドルを取りやめるよう働きかけていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "引捕えて白状さして、今度はこっちから鼻を落してやると、源八郎はそういう決心をして、酒は一升で打ち切り、勘定済まして立場茶屋を出た。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いる」　その朝の新聞に、市電争議打ち切りが出た。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話だけは、まず打ち切りに願いますよ」　長崎屋の、噛みしめた下唇からは、血がにじんで来るかと思われた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶釜から足がはえないぞ」「タヌキの首もはえないや」「さきに説明を打ち切りましたが……」　と雨谷が、ここぞと声をはりあげての口上だ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて皆は調査を打ち切り、再び兄の屍骸のある室へ、集まって来たのでございます。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その問題はこの辺で打ち切り、拙者再度ハッキリと申す、五十嵐右内殿や萩丸様、決して貴殿方にはお渡しいたさぬ！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがあまりはっきり感ぜられましたので、直吉は、思いが自分の火傷のことに戻ってきて、もうその話を打ち切りたくなりました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "セラダの車は翌日発見されて、セラダの経歴が分ってのちに一応自殺として事件は打ち切りとなったのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "可児君　　もう、その話は打ち切りにしませう。",
              "citation": {
                "source": "可児君の面会日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……天つ宮事もちて、大中臣、天つ金木を本うちきり、末うち断ちて、千座の置座におき充はして、天つ菅曾を本刈り断ち、末刈り切りて、八針にとり辟きて、天津祝詞の太祝詞事を宣れ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
