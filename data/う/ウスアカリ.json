        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　炬火の薄明かりの中へ地主の藤沢が事務所から出て来た。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ランプの放つ薄明かりのなか、私はホームズがそこに座っているのを見た。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧深い十一月の日の薄明かりだ、病室は陰気な所となり、さらに寝台から私へ向けられた憔悴の顔が、私の肝を冷やす。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに部屋の窓の位置を確認して、翌朝早く、ホテルの裏通りに立てかけてあった梯子を使って薄明かりのなか、やつの部屋に乗り込みました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝銀座の玩具屋で十銭で買ってきたのです」　男はちょっと言葉をきって薄明かりにすかして腕時計を見た。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を擡げて、薄明かりで時々小首をかたむけながら相手の顔を見ていた。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁の薄明かりと共に再び室内へ帰らうと思つたのだ。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が歇つて薄明かりのさしてる中を長い雲が走つてゆく。",
              "citation": {
                "source": "静物",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、街灯の射し込む薄明かりの中に黒い人影があったことには、敏感な彼女も気づかなかった。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄明かりの坂路から怪物のように現われて来る逞しい牛の姿、前景に群がれる小さき雑草、頂上を黄橙色に照らされた土坡、――それらの形象を描くために用いた荒々しい筆使いと暗紫の強い色調とは、果たして「力強い」と呼ばるべきものだろうか。",
              "citation": {
                "source": "院展遠望",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁の薄明かりの中にこの様子を見られたイエス様は、急いで丘を馳せ下り、浪の穂を踏んで弟子たちの舟に近づき、勢い余って往き過ぎようとせられました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄明かりの下でちらっと顔を見た限りでは、見知らぬ男は五十絡みだったと思う。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄明かりの居間でコーラが出迎えた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "直後、夜明けの薄明かりにこっそり忍び出て、崖に消えた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭上のかすかな眼光で、何かが燕のように薄明かりを突進している。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はその重々しい温みを好み、その薄明かりを好み、重苦しい頭の中に積もってる夢を好む。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け方の薄明かりの中で、ロープはまっすぐ水中へと走っている。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "二匹の犬を連れた異様の人物は、樹蔭を出て常夜燈の薄明かりの下を右から左へと横ぎっていた。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベラ・ギャロウェイの服を着て、薄明かりの下に居れば、同嬢として振舞っても全く申し分ない。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "目には邪悪な光があり、音もなく歩くので裸足だと、ろうそくの薄明かりで分かった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "マッチの薄明かりで分かったのは、ジェナがスイッチに手を伸ばして部屋をぱっと照らす寸前だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとランプの薄明かりでも本官が分かる。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薄明かりでも明白でしょう」「当然だよ、フフフ」　フィールデンがすぐ臨時の決勝点へ急ぎ、双眼鏡を当てて、遠くの物体をじっと見つめた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏はざらざら雲の波、早くも黄びかりうすあかり、その丘のいかりはわれも知りたれどさあらぬさまに草むしり行く、もう夕方だ、はて、この沼はまさか地図にもある筈だ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く別の世界だぞ、　気を落ちつけて（黄のひかり）あるある、あるには有るがあの泥炭をつくったやつの甥か孫だぞ、黄のひかりうすあかり鳴れ鳴れかしは。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすあかりが青くけむり東のそらには日本の春の夕方のやうに鼠色の重い雲が一杯に重なってゐた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、うすあかりの国　けれどもけれどもそんなことはまるでまるで夢のやうでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青白い苹果の匂のするうすあかりの中で、赤いダァリヤが云ひました。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がその広い河原の、向ふ岸近くをごうと流れ、空の桔梗のうすあかりには、山どもがのっきのっきと黒く立つ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
