[
  {
    "uuid": "5d34e629-932d-5574-90da-917594e1bc8b",
    "entry": "恨む",
    "reading": {
      "primary": "うらむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bear a grudge against",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "造花作りは花屋を恨む、さて、花は造花程口がきけない。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵が、Ｔ「娘さん　俺の所為じゃ無えぜ」　「馬鹿な事しちゃ困る」と云って、Ｔ「恨むんなら　先生を恨みな　此村大吉をな」　と言い残して仲蔵の方へ行かんとした時、　児分連、典六に追われて逃げて来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お道は夫の冷淡な態度を恨むやうにもなつて來た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生籬などに籠めらるれど恨む顔もせず、日の光りも疎きあたりに心静けく咲きたる、物のあはれ知る人には、身を潜め世に隠れたるもなか／＼にあはれ深しと見らるべし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうなひどい目にあうて、何悪いことしたむくいぢゃと、恨むやうなことがあってはならぬ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども他人は恨むものではないぞよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけても他人は恨むでない。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようなひどい目におうて、何悪いことしたむくいじゃと、恨むようなことがあってはならぬ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母恨むというとも貴嬢怒るに及ばじ、恨む心は女の心にして、恨む女は愛ずる女なり、ただこの叔母を哀れとおぼさずや。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ俺らこと死ぬまで恨むのだべさ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ほとばしる嗚咽と共に男の胸に顔を埋めた女――男に謝する女の心、男を恨む女の心。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、恨むらくは節遲きこと一月なり、時既に冬にして我が思ふがまゝならずと。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と笑うがごとく泣くがごとく恨むがごとく嘲けるごとく、様々声の調子を変じて遠くよりまた近くより、透間もあらせず呼立てられ、得三は赤くなり、蒼くなり、行きつ戻りつ、うろ、うろ、うろ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "石崇曰く、恨むることなかれと即ち侍僮に命じて、おなじほどの珊瑚六七株を出して償ひ遷しき。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その誰もが皆揃うて、親兄弟を恨む、家眷親属を恨む、人を恨む、世を恨む、人間五常の道乱れて、黒白も分かず、日を蔽い、月を塗る……魔道の呪詛じゃ、何と！",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）恨むが無理か、積つてもみやれ。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之介　むかしの罪を後悔して、毎月二日を命日に、佛事供養をかゝさず營んでくださる殿樣を、いまさら執念く恨むのは……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじひのお慈悲でわが子を召されなければ、こんなことにもならなかつたであらうと、娘の親たちは今更に上を恨むやうにもなつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "外にも恨む理由はある。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで苦労して、なんでこんな苦しい娑婆に頼みもせんのに生み付けたのだと親を恨むかも知れん。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "没くなった父の老僧は、もし子供が不如意を託って「なぜ、こんな世の中に自分を生んだか」と、父を恨むような場合があったら、「こっちが頼みもしないのに、なぜ生れた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八、他をも恨めども、自らを恨むこと我より甚しきはあるまじ。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔たゞかたくなのみをわぶる〕宮沢賢治　　……たゞかたくなのみをわぶる　　　　なにをかひとにうらむべき……ましろきそらにはゞたきてましろきそらにたゆたひて百舌はいこひをおもふらし",
              "citation": {
                "source": "〔たゞかたくなのみをわぶる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは結局、あなた自身に創意と工夫が無いからだ、いまさら誰をうらむわけにはいかない、東京が空襲で焼かれるだろうという事は、ずいぶん前からわかっていたのだから、焼かれる前に何かしらうまい工夫があって然るべきであった。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫百合、白百合こそなつかしけれ、鬼と呼ぶさえ、分けてこの凄じきを、雄々しきは打笑い、さらぬは袖几帳したまうらむ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの親切をさかさまにうらむとは。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらむなら、先生を恨め、と。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が悪いことをしておいて、天をうらむといふことがあるものかい。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　菊次さんは、かうわかつて見ると、もう天をうらむ気はなくなりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、君を、うらむよ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
