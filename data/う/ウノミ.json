[
  {
    "uuid": "cb3b8819-91ac-56ec-8e89-21349048ff53",
    "entry": "鵜呑み",
    "reading": {
      "primary": "うのみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
