[
  {
    "uuid": "689278e3-6573-5bb2-8088-011d6f1c2162",
    "entry": "腕利き",
    "reading": {
      "primary": "うできき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
