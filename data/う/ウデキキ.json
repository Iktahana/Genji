    "definitions": [
      {
        "index": 1,
        "gloss": "highly skilled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それならわたしは、畢竟党から撰ばれて、若手検事の腕利きといふ　この青年を対｜告に、社会一般教育のため、こゝへ来たとも云ひ得やう。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "商賣人の中でも、腕利きと云はれてゐる半七がこの事件をどんな風に扱ふかと、をぢさんは多大の興味を持つて明日を待つことにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "子分にもあまり腕利きがなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "この六でなしの六蔵は、元来腕利きの仕立屋で、女房と世帯を持ち、弟子小僧も使った奴。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴富組の主人は腕利きの潜水夫が無くて弱っていたところだったので、次郎と君枝が現場へ現われると、「よく気が変ってくれたもんだね」　と、喜んだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の木の葉がほんとうに落ちはじめて、鷲がいよいよその巣を離れて遠征をこころみる十月の頃になると、古参の腕利きが初めて出張るのである。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴富組の主人は腕利きの潜水夫が無くて困っていたところだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名刺を持たない新聞記者ってものは余っ程怠け者か、――この僕の如き――それとも余っ程腕利きのどちらかで、まあ、とにかく聞屋には名刺が要るもんだね。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会部長はちゃんと腕利きの記者を「オリンピア」へ派遣したのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "場末ではあるが、若い時から腕利きで知られた男です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売人の中でも、腕利きといわれている半七がこの事件をどんなふうに扱うかと、おじさんは多大の興味を持って明日を待つことにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかな朝の単調にわづかな胡椒を振りかけたばかりの食膳私の味覚はそんなぐらゐの甘つたるい料理は喰ひあきた舌なのですもつと　もつと腕利きのコックを雇つて下さいこの現代の味覚はもるひね愛好者のたゞれた舌ですねばりこく脂こい情感にふるへるやうなわたしは料理をのぞむのです。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等も何やかやと材料を豊富にもつてゐる、だが鍋は完全に奴等から奪つたコックが腕利きなら材料は生きるんだ。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　手先の藤次郎は初めからこの事件に係り合っている上に、平生から相当の腕利きとして役人たちの信用もあるので、秋山も彼にあずけて置けば大丈夫であろうと思った。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り分けて剣術に趣味をもって毎日精出して習ったために、後には立派な腕利きとなった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩州浪士取締り早瀬助三郎組下の五名に厶ります」「早瀬が組下とあらば腕利きの者共よな。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その俳優は旅役者の果てもあれば、小芝居｜根生いの者もあったが、またそのうちには何かの事情で大芝居から小芝居へ流れ落ちた者もまじっていて、そこに侮るべからざる腕利きを見出だすこともあった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかも切られたのが、手先の中でも一っぱし腕利きの者ばかり……」「ふうーん」と虎松は呻った。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡っ引仲間でもなかなかの腕利きだそうだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の代から出入りの子分は相当にあるのですが、その子分にも余り腕利きがいない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕利きの子分二、三人は若い親分を見捨ててほかの親分の手に移ってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……伊豆山から君の電話がかかるなり、すぐ数人の腕利きの刑事をつれて逮捕に向かったよ。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田刑事は、数名の腕利きの刑事を先へ送って手配りをさせ、私たち三人は小田刑事とともに、自動車に乗って後から出かけました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腕利きの警官を四人連れてゆくことにした。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分腕利きらしいが、あんな男がＫ署に居たかしら？",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、われわれの居合わせたことが偶然であるにせよないにせよ腕利きと云われた高橋警部、鬼と云われる藤枝、それと並んで竜にたとえられる林田、この三人の目前で二人の人間が惨殺されたという事実はたしかに都人士をして戦慄させるに十分だつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……非常な腕利き、ただ一刀に、項を斬るそうでございます。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひるすぎになって、お年よりの奥さまは、カレンのはいていたくつが赤かった話を、ほうぼうでききました。",
              "citation": {
                "source": "赤いくつ",
                "author": "DE RODE SKO",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備庁長官アンドレ大佐は、うでききのモロ警部に命じて、自称フランス氏のポーニン氏と会見させることとなった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらあら　ええ　ごめんなさい、　あたしゃ　うでききの　クリーニングやなのよ！",
              "citation": {
                "source": "チギウィンクルおばさんのはなし",
                "author": "THE TALE OF MRS. TIGGY-WINKLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
