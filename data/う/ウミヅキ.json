          ],
          "literary": [
            {
              "text": "もう産み月で痛み出して居るかも知れませんがなあ。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い羽根蒲団の上に、産み月の黄金の闇は悩みをふくんでゐる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "産み月近くには、二人ばかり貰い手の口もあったのだけれど、いざ生れて、猿っこのような赤ん坊を見せられると、二人の貰い手は、もっと器量のいい子供をと云うことになったのであろう。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "産み月のポテレンで、裳を高々とまくりあげ、アユのころがしをやっている図などは、想像しただけで愉快である。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "産み月の近くなったころ、特別製の大きなオーバーをきて、そっくりかえるような堂々さで歩いていた姿は実に立派だった。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん現在も吉野屋にいるし、懐妊ちゅうで、来月が産み月だ、ということであった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の歴史の本には、「たまたま産み月にあたる。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
