          ],
          "literary": [
            {
              "text": "噂をすれば影とやらで、ひょっくり自分が現われたなら、升屋の老人｜喫驚りして開いた口がふさがらぬかも知れない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂をすれば影とやらで、ひょっくり自分が現われたなら、升屋の老人喫驚りして開いた口がふさがらぬかも知れない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂をすれば影とやらです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『十口坊は誘ふか、誘ふまいか、どうしたものにや』と云ふ折しも、噂をすれば影とやら、旅運強き十口坊、偶然來り會す。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい／＼、声が高いぞ――噂をすれば影とやら――とは、まつたくだよ。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりそんな、噂をすれば影、お見えになるだろうと存じていました」臼井金弥の挨拶には、なんとなく毒気が含まれている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、ま、噂をすれば影とやらだよ」とお政が顔を見るより饒舌り付けた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「噂をすれば影、だツせ。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂をすれば影……」　と七代が頬をパッと染て起き上りながら、障子を引き明けた。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂をすれば影どころじゃない。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気配に、露月はそちらをながめやって――「おお、呉羽之介どの――噂をすれば影とやら、只今もそなたの話をしていたところだ」　呉羽之介は縁端にて、しとやかに会釈しました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山川の霊気自然に凝って英雄豪傑を産むということは、まことに千古の名言じゃ」「なるほどさようでござりますか――噂をすれば影とやら、お三婆が見えました」「なに婆が見えたというか」老人は四方を見廻わしたがそれらしい女の姿もない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石川どのは、まだだったかな」　この主水正の声と同時に、障子のそとの小縁に、前髪立ちの取次ぎの影がさして、「御家老さまに申しあげます」「なんじゃ」「ただいま、石川左近将監様より御使者が見えまして――」「来た、来た」　主水正は笑って、「噂をすれば影じゃ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると王様は俺を肘で突ついて、「噂をすれば影だ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は、――錢形の兄哥は居なさるかい、あつしは」　噂をすれば影で、戸口へ來たのは眞砂町の賣出し、喜三郎が立つて居たのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　さう言ふ伊三郎は、噂をすれば影のやうに、ヒヨツコリ戻つて來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "秋祭の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は、――銭形の兄哥は居なさるかい、あっしは」　噂をすれば影で、戸口へ来たのは真砂町の売出し、喜三郎が立っていたのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人形の誘惑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何を笑っているんだ」「噂をすれば影です。",
              "citation": {
                "source": "善根鈍根",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――噂をすれば影――その禿鳶が、大股に、ここの窓へ向って、空地を斜めに来るのが見える。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
