          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それでも、海老などは気合ものの方に属し、形の大小、本場のよしあしなどで時々の相場があって、品ふっていになると、熊手の売り方と同じように買い手の慾しがる大きさのを一つ位ほん俵の上などにとまらせて、客を引いたりして、これにもなかなか掛引があるのだということです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "歳の市のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは死体写真の売り方と同一で、慣れると相手に品物を渡す。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この売り方は最新式で、二十円云々は只相手の好奇心をそそるに過ぎぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店には「一パイ」という酒の売り方がないのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "売り方では牡丹屋に泊まっている安兵衛も嘉吉も共に列席して、書類の調製は寛斎が引き受けた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新生」はこんど出る全集の中にあるでしょうからもしかしたら買えるが、ひどい売り方をするのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩の売り方は言うまでもなく、さいぜんの生酔いの二人の若ざむらいで、それを買ったのは、町人風であるらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具の売り方も、父のは一風変っていた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんな売り方をしているのは一人でもよけいに安く買って貰いたいからである、又売りをされるためではないのだから、はっきりそう云った。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなの　へんな　うりかたじゃない？",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
