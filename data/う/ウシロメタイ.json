          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "芳子は取りつく島のない想いの底に、何か後ろめたい気持を、ひやりと覗きながら、「銀ちゃんのことよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者の側にも、後ろめたい気持ちなしで本に向き合いたいという思いがあるはずです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉は舅にこう言われると、時々彼の不人情に後ろめたい思いもしない訣ではなかった。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の話の工合もあつたのだが、また今更、私がそんなにもお信さんに関心してゐたのを知られるのを、何か後ろめたい気がしたりしたのだつた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前なんざ、奈落で、廻り舞台を担いでろっ」　富士春は、益満と、いつの間にか、後ろめたい関係になっていたので、庄吉の意気込みに、気圧されていたが、お嬢さん、と聞くと、自分が、着物を曲げてまで、苦労して来たことが、思い出されて（五分と、五分だ）　と、思った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "広子は勿論｜後ろめたい気がした。",
              "citation": {
                "source": "春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作品集は決して仲間褒めや後ろめたい提灯持ちをする必要のないものである。",
              "citation": {
                "source": "『開拓地帯』の序",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い、後ろめたい思想が自分を悩まし、ある大きな圧力が自分の心を一杯にした。",
              "citation": {
                "source": "涸沢の岩小屋のある夜のこと",
                "author": "大島亮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で振切ったものを待っているというようになっては、後ろめたい話だが――そうかといって、約束は約束だ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで何か後ろめたいことでもあるように、道庵先生が急に巻を閉じてしまい、すっくと立ち上って、羽織をぬいで投げ捨て、帯を解いて抛り出し、めちゃくちゃにねまきに着かえると、夜具の中へもぐり込んで、「つまらねえなあ」と嘆息しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などとお母さまが仰しやると、なんだか後ろめたい興ざめな気持がしたほどでした。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の説得は面白いがそれは藝術論の一種類であつて、われわれ白日の下に何の後ろめたい氣持もなく堂々と歩く人間の、口にするにはあまりに恥かしい事がらなんだ。",
              "citation": {
                "source": "帆の世界",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うなると反って後ろめたいような気がして、今更帰ることも脱けることも出来ません。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく後ろめたい良心だったのだろうが、俺がずっと気にしていたのは、教授が鋭い碧眼でけげんな疑惑を一晩中俺に向けていたことだ。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "どか／＼と家へ入つた七人、主人に顏を合せるのが、さすがに後ろめたいと思つたか、默つてそれ／″＼の部屋に引取りましたが、下女のお作は、居候の吉太郎と共に、一應戸閉りを見て廻つて、さて、お孃さんのお島が、氣分が惡くて寢て居るのへ、外から聲を掛けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "寳掘りの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、どうせ死ぬのならばうつむきのたれ死ぬこともないと腹を決め、それならばむしろ躍動的な最期を迎えてやろうと、後ろめたい活力で満たされた私は、古い塔とその秘密の探検を始めたのです。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは言いながら、決してこの話、人に漏らすなとの主君の戒め、今ここでそれを破った罪で、我はもう既に一歩、世に後ろめたい。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "予審判事はこの三人を長い事取調べたが、そしてまた彼等の私的生活についても詳細に探られたが、三人が三人、その行為は最も正しく、いささかも後ろめたいような点はなかった。",
              "citation": {
                "source": "探偵小説アルセーヌ・ルパン",
                "author": "EDITH AU COU DE CYGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、自分たちとしては、誰に逢っても、誰と話をしても、さらに後ろめたいことは無いけれども、自分たちの連れには、人に知られていいか、悪いかわからない人がいる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰るに如かず」の心が、白雲の逸る心を乗越え乗越えして、堪え難いものとするとともにここまで来て……引返すということの意気地のなさを、自分ながら後ろめたいものにもする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭下駄を突っかけて、その駕籠の傍へ寄って来たおかみさんは、何か後ろめたいように見返しました時、前の駕籠の垂が細目にあいて、「おかみさん――」　極めて忍びやかな女の声。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、もしあなたに何か後ろめたいことがあれば、あなたはどうしたって『たしかに夢中だった！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろめたい忌わしい秘密があるけど」　それから道化役者のウェブスターは口をつぐんだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那樣は、遲くなるかも知れないから、小袖を一枚用意に持たせるやうにとのことでした」　妾のお小夜は、さすがに本妻のお顏を差し措いた取りさばきが後ろめたいか、辯解らしいことを言ふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "三つの菓子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこやら後ろめたいものに襲われまする」「何の、意気地のない」　年老った方の一文字笠は、多少自分の心にも、そうした怯えがあるらしく、忌々しげに、自分へいうとも連れの者へいうともなくつぶやいて、漆桶のくくり付けてある荷鞍へ乗り移った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが不安そうで後ろめたい様子だ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺をまともに見て、兄さんが過去に後ろめたいことをしてないと言えるか、いま阿漕なことをしてないと言えるか」　女の顔がますます青ざめて、目を伏せた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬喋れなかったが、後ろめたい表情は微塵もない。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろめたいエレンは疑心暗鬼だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをいうとき何かうしろめたい気がしたけれども。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
