    },
    "definitions": [
      {
        "index": 1,
        "gloss": "after rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "露の玉は、そういう葉や、霜枯れ前の皺びた雑草を雨後のようにぬらしていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯倉の通りは雨後の美しさで輝いていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の空気のなかに窓を明け放ち、乗客も程よい電車の内部は、暗い路を通って来た私達の前を、あたかも幸福そのものが運ばれて其処にあるのだと思わせるような光で照されていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の雲　雨後の雲の美しさは山にてこそ見るべけれ。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ、雨後の青空にかかっていたひとすじのほのかな虹を覚えているだけである。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると水上がまばゆく煌いてきて、両側の林、堤上の桜、あたかも雨後の春草のように鮮かに緑の光を放ってくる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後らしく思ひ出は一塊となつて風と肩を組み、波を打つた。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度洋中雨後の光線はまた格別で、私は炒り殺されるかと思つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田や芋畑のあいだを縫いながら、雨後のぬかるみを右へ幾曲りして登ってゆくと、その間には紅い彼岸花がおびただしく咲いていた。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　頬を吹く雨後の寒い朝風は、無数の針を含んでいる様にも感じられたので、市郎は思わず襟を縮めながら、充血した眼に大空を仰ぐと、東は漸く明るくなったが、北の山々は夜の衣をまだ脱がぬと見えて、頽れかかった砲塁のような黒雲が堆く拡がっていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階へ上がると部屋もざっと掃除がすんでおり、均平は縁側のぼろ椅子に腰かけて、目睫の間に迫る雨後の山の翠微を眺めていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後すぐに真白に冴えて、夕陽に瑩光を放っている椰子林の砂浜に出た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "透き通る様な青い若葉が門扉の上から雨後の新滝のやうに流れ降り、その萌黄いろから出る石竹色の蔓尖の茎や芽は、われ勝ちに門扉の板の空所を匍ひ取らうとする。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年夏の半、驟雨後の月影｜冴かに照して、北向の庭なる竹藪に名残の雫、白玉のそよ吹く風に溢るゝ風情、またあるまじき観なりければ、旗野は村に酌を取らして、夜更るを覚えざりき。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の華厳の滝のところは、ただもう、にこにこしてしまいました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の暁に見出すその艶美で無垢で而かも知性的なしどけなさ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとふればマラリヤの病室にふりそそがれし香水と消毒剤と、……※の外なる蜜蜂の巣と、……そのなかに絶えず恐るる弊私的里の看護婦の眼と、霖雨後の黄なる光を浴びて蒸す四時過ぎの歎に似たり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと叢の樟のわか葉の黄金いろ梢も高く、濡れ濡るる雨後の夕のひとあかり、入日に燃えて潤やかに、華やかに、調べあはするかなしみの、よろこびの、くるしみの香も狂ほしき生の曲……夢の合奏……そのかげに、赤き煉瓦の変圧所、心盲ひし高圧の電気の叫喚音もなく、斜に走る銅線のかきむしりゆく火の苦悩。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっとりとした雨後であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後には海岸だけが紅になつた。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汪洋たる木曾川の水、雨後の、濁って凄まじく増水した日本ライン、噴き騰る乱雲の層は南から西へ、重畳して、何か底光のする、むしむしと紫に曇った奇怪な一脈の連峰をさえ現出している、その白金の覆輪がまた何よりも強く眼を射ったのである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日に比して少からず減じた水量のために河中の巌石という巌石は、ことごとく高く高くせり上って、重積した横の、斜の斧劈も露わに千状｜万態の奇景を眼前に聳立せしめて、しかも雨後の雫は燦々と所在の岩角、洞門にうち響きうち響き、降るかとばかりに滾れしきる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の吹く城の向うで化猫草の穗のゆらゆらとうごいてゐてなにものかかなしい追憶の敵が笑つてゐる。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な歌みたいなものまで書いて、恥ずかしゅうございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、――年とって、もろもろの物慾が出て来て、お恥かしゅうございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の恋の相手はまばたきもせず小さい下唇だけをきゅっと左へうごかして見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹は太宰のすぐ傍にながながと寝そべり、いかにも、つまらなそうに眼玉をきょろきょろうごかしながら煙草をふかしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらん下さい、私はいまこうしています、ああしていますと、いちいち説明をつけなければ指一本うごかせず咳ばらい一つできない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとうございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしゅうございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
