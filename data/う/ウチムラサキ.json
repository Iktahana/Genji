          ],
          "literary": [
            {
              "text": "白牡丹白牡丹、大き籠に満ち、照り層む内紫、豊かなり、芬華の奥、とどろきぬ、閑けき春に。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "口びるは上下ともからからになって内紫という柑類の実をむいて天日に干したようにかわいていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザボンはたあちやんの宅になるので奇麗な内紫だ。",
              "citation": {
                "source": "日記より",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　冬の果樹園で、同じ柑橘の仲間に、図体の偉大なうちむらさき。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "台湾では文旦という形の尖ったうちむらさきや普通の丸いざぼんや、ぽんかん、すいかん（ネーブル）等を籠に入れて毎日の様土人が売りにきた。",
              "citation": {
                "source": "朱欒の花のさく頃",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            }
          ]
        }
