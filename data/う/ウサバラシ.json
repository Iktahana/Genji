    "definitions": [
      {
        "index": 1,
        "gloss": "diversion (from one's worries, troubles, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "旦那さまだとて金滿家の息子株が藝人たちに煽動られて、無我夢中に浮かれ立つとは事が違ふて心底おもしろく遊んだのではありますまい、いはゞ疳癪抑へ、憂さ晴らしといふやうな譯で、御酒をめし上つたからとて快くお醉ひになるのではなく、いつも蒼ざめた顏を遊ばして、何時も額際に青い筋が顯はれて居りました。",
              "citation": {
                "source": "この子",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、近頃はまだ噂の行き亘らぬ吉原方面に場所を変え、そこを取引先との交際場にも、自分の憂さ晴らしにも使うようになった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもねえさんにはあなた方の考えてもみられないような心配な事や困る事があるものだから、つい憂さ晴らしにこんな事も覚えてしまったの。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者は「外套」の幽霊と肩を抱きあつて慰めあひ、憂さ晴らしに腕を組んで居酒屋へ行きたくなる。",
              "citation": {
                "source": "幽霊と文学",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人旅の憂さ晴らしに、ていのいい幇間代りの道具にされるだけなのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「議論に負けた憂さ晴らしよ！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……水戸様石置き場の空屋敷などへ、たとい私たちが出入りをしたにしても、それはほんの憂さ晴らしでもあり、いい換えれば息抜きでもあるのだよ。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪の深い男で、ただ憂さ晴らしのために飲んだんでございますよ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、人は憂さ晴らしに酒を飲むだろう。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、だからぼくも憂さ晴らしに、こうしてここに来ているのだ、ねえ、ひとつ聞かしてもらおう。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も奥畑のお茶屋遊びは前からのことではあったが、当人は、これも君との結婚を許して貰えない憂さ晴らしだから、大目に見てくれ、但し僕のは女達を集めて無邪気に酒を飲むだけだ、決して節操を汚すようなことはしないから、それは信じてくれと云っていたので、その程度のことは諒解してやっていたのであった。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも同じくむしゃくしゃしている子分連中と、山笠をおさめてから、自宅で、憂さ晴らしの饗宴を張った。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに独りで映画でも観て、うさばらしでもしたかつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤羽夫人は、パートナーを連れて早々に競技場をひきあげると、うさばらしに飲みにゆき、キャバレーへ踊りに行った。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、メルゲルの心を苦しめたのは、後悔であったか、それとも羞恥心であったかはともかくとして、彼はますます＊４うさばらしを必要とするように思われた。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊４　うさばらし――うさばらしをするためのブランデーをさす。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
