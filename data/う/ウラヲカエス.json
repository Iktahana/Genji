    "definitions": [
      {
        "index": 1,
        "gloss": "to turn inside out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "羽織の袂の裏を返すと隅に白糸三筋縫い込んである。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀姫　（鉢金の輝く裏を返す）ほんに、討死をした兜ではありませんね。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと弁慶が大長刀を持って威張っている。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮田からだと思って、裏を返すと村川生とかいてある字が、鋭い短剣のように、京子の眼を突き刺した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと、見覚えのある川上万吉と云う金貸業者の名前だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと、見覚えのある川上万吉と云ふ金貸業者の名前だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にじゃれついてきて、わたしを興奮させたり、うっとりさせたかと思うと、こんどは手の裏を返すように、わたしを突っぱなして、彼女に近寄ることも、その顔を眺めることも、できないような羽目に落してしまう。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠井春子と別れた鉱山班の瀬谷は、手の裏を返すやうに、ゆき子へにこにこした顔をむけた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美津江は、終戰になると、何時までも、かうした田舍にゐたくはなかつたけれども、急に行末の繁昌をみこして、手の裏を返すやうに、大切にしはじめたお神さんの口車に乘せられて、仲々東京に歸つてはゆけなかつた。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと差出人は松本であった。",
              "citation": {
                "source": "琥珀のパイプ",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "配達夫の近づく足音にもう次の間まで出て待構えていた渡辺刑事は素早く飛出して拾い上げたが、そのうちに上封に見覚えのある太い字がいきなり眼についたので、ハッと思いながら裏を返すと、松下一郎と云う四字が電光のように彼の眼を打った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「例の文字だ」「いかにも、執拗な奴だ」　二人は暫く襟の所を眺めていたが、やがて一人が裏を返すと驚いた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八　雪之丞が、手の裏を返すように、折れて出たのを見ると、三郎兵衛は、ニヤリと猫族に似た白い歯を現して、「そうじゃ、そうじゃ、そのように物わかりがよう無うては、芸人はなかなか出世がなりませぬ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんも今に封筒の裏を返すに違ない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと昭和四年発行、大浦天主堂とあり、一部五銭であつた。",
              "citation": {
                "source": "島原の乱雑記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも今夜、こうしてここへ、女の名を覚えていてやって来たのも、裏を返すというような遊蕩気分に駆られて、やって来たわけではあるまい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが裏を返すと、すなわち、仙台の仏兵助と、青梅の裏宿七兵衛との取組みとなるのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "常ひごろ、あんなに尊重してらしたことを、なんだっていきなり手の裏を返すようなことを仰しゃるの？",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと彼の心は一瞬の間緊縮された。",
              "citation": {
                "source": "恩人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまも、陣々として、頭の上を吹く風の中に、たんぼの野菜の葉が白い裏を返すのである、そして、やつれた母の涙ぐんだ顔が浮かぶのでありました。",
              "citation": {
                "source": "僕はこれからだ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちがねる前に『本日終業』の方をだしておきますから、その裏を返すと『十一時開店』がでるのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "静枝に送る手紙をひきかえに、女中に渡した彼は、その封書の裏を返すと、そこには明かに清川純という三字がよまれた。",
              "citation": {
                "source": "正義",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "客あつかひの名人で、一度逢つたものはきつと裏を返す、此家へ入つてからも、何んかの遊藝や用事にことよせて、狼共が寄つて來た相ですが、だん／＼華魁の學や藝は大したもので無いとわかつて、次第に足が遠退いた上、主人の貫三郎が浮氣を始めたので、内儀の方でも身を愼んで、近頃は神妙に暮して居た相です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "華魁崩れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとにお見せ申したいくらいでござんす、今日のこのお月様を」　お徳は砧の手を休めて、竜之助の方を向いて絹物の裏を返す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏を返すと、渋谷・陳根頑と記してある。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとその宛名が『不破数馬』で、裏を返すと発信人は野呂旅人です。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "細った横顔にも、弾力のない頬の肉にも、懊悩のかげはにじみ出ているのだが、美妙は、手のうらをかえすように別のことを冷たく言った。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、よくよく気をつけて嵐の前の樫をみると、風につれてリズミカルに葉うらをかえす合間に、時々急にむせるように、瞬くように、全身を小波立たせることがあるでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
