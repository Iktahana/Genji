        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ホヤの中にほうっと呼気を吹き込んでおいて棒きれの先に丸めた新聞紙できゅうきゅうと音をさせて拭くのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも黒紋付に、歩くときゅうきゅう音のする仙台平の袴姿であったが、この人は人の家の玄関を案内を乞わずに黙っていきなりつかつか這入って来るというちょっと変った習慣の持主であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばかいえ貴様、そうきゅうにわかってたまるものか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、姉ちゃんのお見舞いに呉れたのね、自分で買って来たの」「ああ」「それを買うおあし、お母さんにいくら貰ったの」「二円だい」　女中がきゅうきゅう笑った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと、みんな、あんたのに取っちゃうの」　室子はわざと驚いた風をすると、女中がまたきゅうきゅうと笑う。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だい、鳴るじゃあないか、きゅうきゅういってやがら、おや、可訝いな。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士や教授や勅任官｜抔の事を念頭にかけて、うんうん、きゅうきゅう云っていられるものじゃない。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、自分たちの談話室では庄亮が湯上りの浴衣の胸をはだけて、濡れ手拭で、きゅうきゅうと、まだ紅みの残ったその首筋を拭き出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとかんしゃくが起こってくやしがってきゅうきゅういっているような奇妙な声を出す。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じたばたすりゃ、もっといてえめに会わしてやるぞ」　きゅうきゅうしめあげておくと、伝六のきょうの働きというものはおどろくくらいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が人民生活を再建出来ないでインフレーションの波のまにまに、当選したかと思うと、たちまち選挙違反で検挙されるような代議士の頭数ばかりあつめて、大臣病にきゅうきゅうとしているとき、もし私たち婦人が、心から自分の運命を守ってたち上らないならば、だれが明日の生命を保障してくれるでしょう。",
              "citation": {
                "source": "求め得られる幸福",
                "author": "――今こそ婦人の統一を――",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究会の末席に加えてもらうようになった僕が、学費と生活費にきゅうきゅうとしてアルバイトに飛び回るのを見て、雑誌を起こしていたリーダーが「うちで働くか」と声をかけてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きゅうきゅうとして雑誌に原稿を書き、Just making rubbish に何の価値があるか？",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの男を、どこかへしょびき出すか、それとも、途中で生け捕るかして、きゅうきゅうむごい目を見せてやりたいのです」「それ真剣か？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも大石自身は、後を清くして立つためには何かと用事もあって、そうきゅうに京師を引払うわけにも行かない。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆をきゅうきゅう追いつめながら、一方には会社や資本家にはどっと新円を下ろさせる銀行の不徳と政府の反民主政策は呆れる外ない。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生きものは、きゅうきゅう鳴いて、くちびるにかみつこうともがく。",
              "citation": {
                "source": "かき",
                "author": "УСТРИЦЫ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その責任の一半は地方の側にもあるので、東京の模倣にきゅうきゅうとして、自ら地方文化の基盤をくずしてきた傾向がある。",
              "citation": {
                "source": "根強い北陸文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子ときたら、ひっぱたいたって、もうきゅうとも泣きゃしませんよ」二十一　なお、彼女はこういうのである――　――空に汚点ができたり、道の上に糞でも落ちてると、あの子は、こりゃ自分のものだと思ってるんです。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいものみつけた、ござんなれ、ござんなれ、めがものお上※に、かえるどのぱくとのまれてきゅうきゅうきゅう。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、まるでグレゴールのこんな問いに乱暴に答えるかのように、隣室の支配人は今度は一、二歩しっかりした足取りで歩いて、彼のエナメル靴をきゅうきゅう鳴らした。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のうしろでなに鳥かきゅうきゅうと鳴く。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会そのものはとうの昔に、教会という下級の形から、国家という上級の形へ移るのにきゅうきゅうたるありさまで、やがては国家というものの中へ、すっかり姿を没してしまおうとしておるのじゃ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがおまえに言っておるとおり、人間という哀れな生き物は、生まれ落ちるとより授けられている自由の賜物を、いちはやく誰かに譲り渡そうとして、その相手を捜し出すことにきゅうきゅうとしていて、この苦しみほど人間にとって切実なものはないのだ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分、社では参考書も見ていられないので、途中からは帰宅後、家で夜半に書いて行ったが、それでも思わぬ誤謬や不備を指摘されてきゅうきゅういわせられたことが幾度あったことかしれない。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右馬めを、きゅうきゅういわせるぞ」「腕をさすって、晩の勝負をお待ちしましょう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
