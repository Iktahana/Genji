        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして何もかも打ち壊して見てえなあ」と怒鳴った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをあなたは、見事に打ち壊してしまった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はこの鼓を手に入れて打ち壊してしまいたいと思っているのでしょう」　青天の霹靂……私は全身の血が頭にのぼった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ばん、よさそうなのは、この鏡のどれか一面を打ち壊して脱出を計ることなのだが、しかし、この三面の鏡のどの一面を壊し去っても、もう、そこには、形造られている自分というものは無くなってしまう気がする。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓司がふと見ると、足下の象の鼻の途中から下、瀞の渚近くまで岩層が露出していて、学者乞食の花田が頁岩のあると言って頻りに研究の材料にしている地点へ、運転手風の男が試掘用のハンマーで岩石を打ち壊しては堤の上の自動車の中へ運び入れています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、嫌いだというのは打ち壊しだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根を打ち抜いて、天井を打ち抜いて、菓子の陳列棚を打ち壊して、商品をメチャメチャにするってな事になると、背に腹は代えられませんからね。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸川貞雄の『遠雷』は後半がちよつと好いが、あの妾の出し方なども旨いとは思つたが、それよりももつと大切なことは、この作者がもう少し自由に、もう少し大胆に、その持つた型を打ち壊してしまふことではないかと思つた。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、貴方は此頃荒んで来ましたね、どうかすると目茶苦茶に自分を打ち壊して行くやうなことをする。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間幾人の人間を轢きたおし、いくらの品物を打ち壊したかわかりませぬ。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の土煙と火煙は、彼女等の頭の中のこうした城廓を、かなり烈しく打ち壊した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今はもうその方が何方にとっても得策であるに拘らず、強いてそれを打ち壊してまでも自分は自分の博愛を秋三に示さねばならないか？",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この幽霊のごときは極端の極端の例であるから、積極的に真を含んでおらんとも云えましょうが、むやみに真を打ち壊しているものでないと云う事だけは、さきの説明で明らかでありましょう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其代り、此窮窟な主義だとか、主張だとか、人生観だとかいふものを積極的に打ち壊して懸つた試もない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔、怒った群衆が略奪して、町の米問屋の住家や米蔵を打ち壊した。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが望んだのは打ち壊しであって、盗むことではなかった。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を苛め、さいなみ、あらゆる自由と独立とを私から奪い、私のよいところを片っ端から打ち壊し、私の成長を阻み、私を撓じ曲げ、歪め、ひねくれさせ、そしてしまいにはとうとう、盗みをするような女にまでも私をしたところの私の祖母たちの手からも遁れられる時が……。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは違うんだってば」　勝負の間、彼等は、朝子が二人に何をしても平気の癖に、大平が幸子の駒を飛びすぎたり、幸子が彼の計画を打ち壊したりすると、「こいつめ」「生意気なことをするな、さ、どうだ」「ほら、朝っぺ！",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その障壁を、いまここにいられる方々が打ち壊してくれたのでした」「私は、装飾灯が消えるとすぐに、竪琴の方から人の近づいて来る気配を感じました」とそう云いながら、たぶん評論家の鹿常充と思われる――その額の抜け上った四十男は、左右を振り向いて周囲の同意を求めた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の形象を打ち壊したり組み立てたりすることが、私には楽しいのである。",
              "citation": {
                "source": "私の信条",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかしふと指に触れたズボンの底の六十何銭かはたちまちその夢を打ち壊した。",
              "citation": {
                "source": "十円札",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その贅沢心を、或る日白木豹二が、一撃のもとに打ち壊してしまった。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り、この窮屈な主義だとか、主張だとか、人生観だとかいうものを積極的に打ち壊して懸った試もない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち物の関係を味わい得んがためには、その物がどこまでも具体的でなくてはならぬ、知意の働きで、具体的のものを打ち壊してしまうや否や、文芸家はこの関係を味わう事ができなくなる。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の理想を打ち壊しています。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこにしがみついて喘いでいる時に、鈍い物音がして、スクーナー船が革舟にぶっつかってそれを打ち壊して、私が戻る処もなしにヒスパニオーラ号に残されたのだということがわかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "錠を下した箇処はどこも皆、海図を捜すのに打ち壊して開けてあった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師は鶴嘴でその中の一艘を打ち壊し、それから私たちみんなはもう一艘の方に乗り込んで、北浦をさして海路で※って行こうと出発した。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "無一文で正月を迎えることも……金がいるというなら、盗み取ってくることも……笹木に内通していくらか搾り取ってやることも……場合によっては、妻や子供を捨てて一人身になることも……あの神棚を打ち壊してやることも……何だって出来ないとは限らない。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長州屋敷の打ち壊しが始まったのだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
