    "definitions": [
      {
        "index": 1,
        "gloss": "owner of a horse (esp. racehorse)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
