          ],
          "literary": [
            {
              "text": "先「中々旨いな、旨くやるねえ。",
              "citation": {
                "source": "西洋の丁稚",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うまくやる奴もあるもんだね。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく、きっとうまくやるから、まあ置いとけよ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これなら、宮中でも、きっとうまくやるだろう」「もう一度、皇帝さまに、うたってさしあげましょうか？",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンネスが、いままでの人たちよりも、うまくやるだろうとは、だれにも考えられませんでしたからね。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくやるもので、浮世絵好みの意気な姿です。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙ってはいってきゃええだ」　それからは木之助はうまくやることが出来た。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、僕の前で、どれだけうまくやるか、試みにやる分には構わん。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意深く観察するということは明瞭に記憶することであって、そこまでなら集中力の優れたチェスの棋客もホイストを十分うまくやるだろうし、またホイル（３）の法則だって（それがゲームの単なるメカニズムに基づいたものである以上）誰にでも十分に理解できるものなのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の防禦陣地はすばらしいものだそうだ」　「大きな戦争になりそうだナ」　「一日砲声がしたからナ」　「勝てるかしらん」　「負けちゃ大変だ」　「第一軍も出たんだろうナ」　「もちろんさ」　「ひとつうまく背後を断ってやりたい」　「今度はきっとうまくやるよ」　と言って耳を傾けた。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様商売もうまくやると、お賽銭のあがりが大きいからなあ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒に貰いたいと思ってね」「へえ、うまくやるね。",
              "citation": {
                "source": "ソヴェト労働者の夏休み",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等がうまくやるから??」　こんなことを話してから、鶴次郎は再び最初のことを云つて誘つたが、義雄は應じなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等がうまくやるから――」　こんなことを話してから、鶴次郎は再び最初のことを云つて誘つたが、義雄は應じなかつた。",
              "citation": {
                "source": "――泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さァ、しかし、そこは句会ですから、何とかうまくやるでしょう。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の人々には、それをうまくやる事によつて名誉と考へたのである。",
              "citation": {
                "source": "巫女と遊女と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今夜はたとえどんなことが起ろうと僕が引受けてうまくやるから、君は安心して睡れといって呉れた。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女なら、きっとうまくやるだろう」と、帆村はもとの冷い顔になって、しきりにひとりで肯いて、「――さて、貴女に頼みたい仕事のことなんですがね。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとのことは僕がうまくやるから、貴女はなにも愕かないで筋書どおりやってください。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方うまくやるだろう。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「おれに演らせればもつとうまくやる」。",
              "citation": {
                "source": "「悲劇喜劇」の編輯者として",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕が加担してたら、もっとうまくやるよ。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "最上先生の思想が如何に地べたに密着して地平すれすれに這ひ廻るにしても、人間が国持大名を望む夢を失ふといふことはない」　と倉田が慨嘆してみても、彼はアクビひとつせず、俺は貧乏な大学生が下宿の娘とうまくやるのが羨しいのだ、とうそぶくのだから手がつけられない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのところはうまくやるつもりだ。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはわしがうまくやるから」　と、治明博士は近づいて、それをいおうとしたのだ。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はきっとうまくやるでしょう」「どういう方法か」「要するに彼らを説き伏せ、まっすぐな道を歩かせるのです。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、なんとかいった大きな男が出ていって、うしろから知れないように、うまくやるだろう」「ああ、あれは巨人ハルクです。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
