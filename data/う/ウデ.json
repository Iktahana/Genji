        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なれは喜ぶなが影の、すがたの海に跳び入りて、眼に腕にかい抱き、それな固有のざはめきに、なれがこゝろはなごむなり、抑へがたなきはた荒き、浪の歎きのかの響き　もはや眺めてはゐられなくなつた、跳び込んで、眼に腕にかい抱き、それな固有のざわめきに、なれがこころはなごむのだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大学を出たのに職がない」といふと、尠くも近親は周章てるが、「腕はあるのに職がない」なぞと云はうものなら、「威張つてやがらァ」ではないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのがつしりした鉄のやうな腕は、すべての不健全なもの、非人倫的なもの、神秘的なもの、病感的なもの（もちろんその中には私の詩にみるやうな哲学も含んで居る）及び人生の幸福に有害なる一切の感情を弾きとばすことに熱して居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「われは横綱らしく強いところを見せようとして左の腕を大きくぶるんと振って相手を片手で投げ飛ばそうとしたが、相手は小さすぎて、われの腕はむなしく相手の頭の上を通過し、われはわが力によろめき自ら腰がくだけて敗れたのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いだすと果しがないけれども、いったい、彼にはどのような音楽理論があるのか、ヴァイオリニストとしてどれくらいの腕前があるのか、作曲家としてはどんなものか、そんなことさえ私には一切わかって居らぬのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はときたま、てかてか黒く光るヴァイオリンケエスを左腕にかかえて持って歩いていることがあるけれども、ケエスの中にはつねに一物もはいっていないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場も立ちどまり、両腕をだらりとさげたまま首を前へ突きだして、私の女をつくづくと凝視しはじめたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、僕は失敬するよ」佐竹は小声でそう呟き、金側の腕時計を余程ながいこと見つめて何か思案しているふうであったが、「日比谷へ新響を聞きに行くんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹はしずかに腕を伸ばして吸いかけの煙草の火を山猫の鼻にぴたっとおしつけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか返辞をしろ、といきり立ち腕力に訴えようとしても、相手は、双葉山である。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕はその儘、頭だけを屈めてサラリと禿げかゝりのそれを撫でた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服の袖はまるで中に腕がないかのやうにポウとなつて胴より心持前に振ら下つてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、達沢が教頭席に腰を下した儘、前方のゴタゴタした一群れ――それは何か分らぬ――に向つて、その太い腕を得意気に振廻してゐる光景のみが、彼の目に見えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯然と二の腕を捲ると、生白い肌が現出れて酒氣を帶びた頬が薄赤い。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『間拔奴、見損やがつたか、汝、記憶えとけ、深川の芳兄いてで鳴らしたもんだい、手前達の樣な、女たらしに、一文たりとも貰ふ覺えはないぞ、ヘツ、どうだい、その面は、いやにキヨロツキやがつて、憚乍ら口惜しけりや腕ツコキで來い、白痴ツ』『女たらし』の一言に力を罩めて憤怒の焔燃ゆるが如し、果然彼には一物あり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『斯う成つちやあ一番腕ツコキだ、さあ野郎、文句は言はずと、出ろ』男は片脚はづして下駄を脱いだ。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『では、どうすれば好いんだ、ど、どうすれば……腕力なんて、野蠻な……僕は』紳士は對手の權幕に、震へ聲を出して、殆ど、全く、實際、困つた樣子。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芳ちやん、お待ちツてば、アレ、そんな手荒なことを』纖弱い腕を延べて、男の右手に搦み付く。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも背広の片腕に黒い喪章を巻いていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理教室の図書の管理をしていた、オットー・バシンという人も同じ仲間であったがこの人は聴講に身が入って来ると引切りなしに肩から腕を妙に大業に痙攣させるので、隣席に坐るとそれが気になって困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機今｜音羽屋の弁天小僧にして向いの壮士腕をまくって耶蘇教を攻撃するあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、もう三十余年前にただ一度実見したきりなので記憶がはなはだたしかでないが、網を張った叉手の二等辺三角形の両辺の長さが少なくも九尺くらいあり、柄竿の長さもほぼそのくらいあるかと思われ、とにかくずいぶん大きなものであるので、それを自由に操作するには相当の腕力を要するものであったように思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝馬に乗って櫂を動かしている女の腕に西日がさして白く見える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく腕は立派でも、衣食に追われて画くようでは、よい絵は出来ず、第一絵に気品がなくなる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのこと、ありのままに山岸へ告げたところ、山岸しさいらしく腕組み、「君、それが惡い。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と何の事やら、わけのわからんやうな事を悟り澄ましたみたいな口調で言ひ、兩腕をうしろに組み、ひとり家を出て、あちらこちら海岸を逍遙し、苅薦の亂れ出づ見ゆ海人の釣船　などと、れいの風流めいた詩句の斷片を口ずさみ、「人は、なぜお互ひ批評し合はなければ、生きて行けないのだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして兩腕をひろげて一歩足を踏み出すと、ゆらゆらと氣持よく落下します。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島も氣をとり直して、兩腕をひろげ、魚の掛橋の外に一歩、足を踏み出すと、すつと下に氣持よく吸ひ込まれ、頬が微風に吹かれてゐるやうに涼しく、やがてあたりが、緑の樹蔭のやうな色合ひになり、琴の音もいよいよ近くに聞えて來たと思ふうちに、龜と並んで正殿の階段の前に立つてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷君がこれから出掛けて飲みませんかといふと、出たさうだし出たくなささうであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も帰つて欲しさうでもなかつたので、何か話し出さうと思つたが、私は疲れてもゐたので黙つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
