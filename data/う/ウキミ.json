[
  {
    "uuid": "5f0eab4f-bf5c-519e-957b-156bbe80a433",
    "entry": "浮き身",
    "reading": {
      "primary": "うきみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
