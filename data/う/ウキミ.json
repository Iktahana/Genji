      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "floating on one's back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今から思えば、ばかばかしいほどに浮き身をやつしたものであったが、これもやはり降りつづく梅雨にぬれながら木場へ手長蝦を釣りに行ったときに、土地の人から聞かされた話の一つで、江戸末期から明治の初年にかけての世界であると思ってもらいたい。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそのおかげで、私は汚ない二階に寝ころんだまま、煙草と、弁当と、書物の三道楽に浮き身をやつし得るありがたい身分になったわけであるが、同時にその道楽の結果として、自分の頭と、胃袋と、肉体とが日に日に頽廃して行く有様を自分でジッと凝視めていなければならなくなったのには少々悲観させられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れもあえず元の岸へも戻さず、自分を浮き身の宙に漂わして、辛い水を飲ませる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺　苦惨の海に漂ふて、よるべなぎさの浮き身となる時は、人は自然に自殺を企つるものなり。",
              "citation": {
                "source": "復讐・戦争・自殺",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから西洋中世の有名な学者達はいずれも「哲学者の石」の発見に浮き身を窶し、中にはそれを捜し当てたといい、パラセルズスはルビー色をしたものだと告げ、ワン・ヘルモントは硝子のような光沢をしたサフランのようなものだと記述した。",
              "citation": {
                "source": "錬金詐欺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の旗太郎は、平常なら身ごなしに浮き身をやつす彼には珍しく、天鵞絨の短衣のみを着ていて、絶えず伏眼になったまま、その薄気味悪いほどの光のある、白い手を弄んでいた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく浮き身がついて、身体がすううっとよっていった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の大ブルジョアは貿易とか海運とか、手ッとり早くサヤのとれる事業には浮き身をやつすが、大資本を投下して設備をほどこし、技術の精華をあつめた上で長年月の研究を重ねなければならないような大工業には見向きもしないのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その一　舞踏会殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、どうしてあのとき、あんなに衣裳に浮き身をやつしたのか、自分でもわからないのでございます。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、便所の中や、往来のまんなかで、眼をむき出したり、首を振ったり、一生懸命声色の稽古に浮き身を窶して居ることもありますが、手持無沙汰の時は、始終口の先で小唄を歌うとか、物真似をやるとか、何かしら一人で浮かれて居なければ、気が済まないのです。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくももうきみらの仲間にはいろうかなあ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういう嘘を言うきみのことだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集にあるめづらしと吾が思うきみは秋山の初もみぢ葉に似てこそありつれ　こう言ったような気もちであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうきみにやられた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが海蛇どもは失望せずに進んだ、そしてとうとうきみらを発見した」「どこで？",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしき笑い声「もうきみの力は借りない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうきみと口をきく必要はない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきみには答えてもらう必要はない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきみには用はない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もうきみはかんづいているだろう」「なんですって」「きみのからだをもらいたいのだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄の島では、穀物の漂著と共に、「うきみぞ・はひみぞ」の由来を説いてゐる。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いっそうきみの安否を心配していたんだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもうきみょうな物の形と、大きな樹木が、いまにもわたしをつかもうとするようにうでを延ばしているだけであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげん水びたしにされたり、焼かれたりしたずうたいを、なんぼなんでも、このまんまで色男の前へ出されもすまいじゃないか――そこでおばさんは焼跡の土をせせくって、何やら相当の身じまいにうきみをやつしているものだろうか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屑買ののろま清次は、今晩それに眼をつけて、イヤなおばさんの焼灰の跡をせせりに来たものに相違なく、決して最初想像したように、おばさんの亡霊が、心やみ難き未練があって、うきみをやつして化けて出たものではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもうきみの心もちなんか問題にしやしない、ただきみを自分の意に従わせるばかりだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもうきみを憎んでいた。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠に沿って五六丁ゆくと、北の庄村の地端れに近く、首切地蔵というきみの悪い地蔵尊へゆく道があり、その脇に野井戸が一つある、どういうわけか「つんぼ井戸」と呼ばれているが、その井戸の向こうを右へだらだらと下り、松林の中へはいるとすぐに一軒の家がみえる。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごつんというきみの悪い音が、かなり高く聞え、三島はそこへどさりと尻もちをついた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飲もうきみ、こんな汚ならしい金は一銭も残らず遣い捨ててやるんだ」「飲みましょう、仲井さんの新しい出発を祝いましょう」　おれたちは飲みまわった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
