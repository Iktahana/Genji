              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ぼくももうきみらの仲間にはいろうかなあ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういう嘘を言うきみのことだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉集にあるめづらしと吾が思うきみは秋山の初もみぢ葉に似てこそありつれ　こう言ったような気もちであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうきみにやられた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが海蛇どもは失望せずに進んだ、そしてとうとうきみらを発見した」「どこで？",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしき笑い声「もうきみの力は借りない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうきみと口をきく必要はない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきみには答えてもらう必要はない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきみには用はない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もうきみはかんづいているだろう」「なんですって」「きみのからだをもらいたいのだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄の島では、穀物の漂著と共に、「うきみぞ・はひみぞ」の由来を説いてゐる。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、いっそうきみの安否を心配していたんだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもうきみょうな物の形と、大きな樹木が、いまにもわたしをつかもうとするようにうでを延ばしているだけであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげん水びたしにされたり、焼かれたりしたずうたいを、なんぼなんでも、このまんまで色男の前へ出されもすまいじゃないか――そこでおばさんは焼跡の土をせせくって、何やら相当の身じまいにうきみをやつしているものだろうか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙屑買ののろま清次は、今晩それに眼をつけて、イヤなおばさんの焼灰の跡をせせりに来たものに相違なく、決して最初想像したように、おばさんの亡霊が、心やみ難き未練があって、うきみをやつして化けて出たものではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもうきみの心もちなんか問題にしやしない、ただきみを自分の意に従わせるばかりだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもうきみを憎んでいた。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "濠に沿って五六丁ゆくと、北の庄村の地端れに近く、首切地蔵というきみの悪い地蔵尊へゆく道があり、その脇に野井戸が一つある、どういうわけか「つんぼ井戸」と呼ばれているが、その井戸の向こうを右へだらだらと下り、松林の中へはいるとすぐに一軒の家がみえる。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごつんというきみの悪い音が、かなり高く聞え、三島はそこへどさりと尻もちをついた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飲もうきみ、こんな汚ならしい金は一銭も残らず遣い捨ててやるんだ」「飲みましょう、仲井さんの新しい出発を祝いましょう」　おれたちは飲みまわった。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ピッポちゃん、とうとうきみが手がらをたてるときがきたよ。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウン、もうきみから話があるころだと思っていた。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そう言うきみこそ、だれだ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが透明怪人の首領にさらわれたことは、もうきみの耳にもはいっているでしょう。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、なんというきみの悪い、大きな顔でしょう。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳に向かうきみを、いまから撮り始める。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "叡山に苦行し、南都に学び、あらゆる研鑽にうきみを窶していたところで、それが単なる自分の栄達だけにすぎないならば、なんの意義があるのであろう。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レックミア侍従というきみの考えは素晴らしい、実にすばらしい。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴はもうきみを妨害しないよ、ビートリス。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なんというきみの悪いやつでしょう。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
