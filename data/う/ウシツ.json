          ],
          "literary": [
            {
              "text": "山口はわたしの左室、大杉は右室に入れられました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何というしつこい氏の神経だ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは飽くまで読者の想像力を屈服せしめて作者が凱歌をあげてはやまぬというしつこさ、用心深さのためではないかと私は思う。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どうしつぺなあ、私の病氣の爲にみんなが……』　ほろほろと病人の顏から涙が落ちた。",
              "citation": {
                "source": "四十餘日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもう一羽雌鷄を置くといゝんですがなあ、さうしつと大抵卵をかはりばんこに生しやすからなあ。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「舊正月うまれだとか言ひやすから、さうしつと新の二月でごすな。",
              "citation": {
                "source": "嘘をつく日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その引つこ拔くのがまたえらいぜえ、八月の末にもなりや、もうしつかと根を張つてゐるけんのう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "・つく／＼ぼうしつく／＼ぼうしと鳴いて去る・咲いてこぼれて萩である・秋ふかう水音がきこえてくる　　農学校即事　鵞鳥よ首のべて何を考へてる　九月廿四日晴れて独りだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "○きつね火　まへうた本てうしつきはつれなや。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はさつぱり樣子のわからない神戸驛に下りると、東京では見かけたことのない眞つ白なタクシイを呼び止め、氣輕に運賃をかけ合ひ、そこからさうしつけてゐる者のやうに、元町通りの方へそれを走らせた。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い意味もなかろうが、実は彼女の給仕を受けて飯を食う間に、今しがたゲダンケを読んだ自分と、今黒塗の盆を持って畏まっている彼女とを比較して、自分の腹はなぜこうしつこい油絵のように複雑なのだろうと呆れたからである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はさっぱり様子のわからない神戸駅に下りると、東京では見かけたことのない真っ白なタクシイを呼び止め、気軽に運賃をかけ合い、そこからそうしつけている者のように、元町通りの方へそれを走らせた。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いの繰り言　私はいろいろの方面から「アーニイ・パイル」の感激に刺戟されつつ、それからそれへと、連想を逞しうしつつ、日比谷の交叉点に出たのである。",
              "citation": {
                "source": "アーニイ・パイルの前に立ちて",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、多くの職業婦人の出現は、たしかに与えられつゝあることを証するにはちがいないが、果して、女子は、これによって経済上の独立を全うしつゝあるであろうか？",
              "citation": {
                "source": "婦人の過去と将来の予期",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊お洗濯知つてるの……』『ぼうしつてる、おべべばつちくなつたとき、じやく／″＼してきれいにすることでせう』『あゝさうです／＼、坊よく知つてゐるわね。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、こういうしつけをする本当のねらいは、学問に対する身だしなみを、身につけさせるところにあるのです。",
              "citation": {
                "source": "鉛筆のしん",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あゝいうこと、もうしつこなしよ」「うちの好き勝手にしたんやないもの。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそうしつこく手を退け手を退けというんだい」「あまり仕事が大き過ぎるからさ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは斯うしつこくないのだが、主人公、今日は特に気を廻す理由がある。",
              "citation": {
                "source": "或良人の惨敗",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭木の奥の洞穴のような離れで営まれていた生活も、細君が、そうしつらえたというより、はじめは確かに竹村が自分の趣味で、あの座敷も選び、渋いという風なあの雰囲気をつくって行ったのだろうのに、と思えた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子のそういうしつけがなかったら、伸子はモスク※へついて、たった二週間めに、鉄工労働者のクラブで、たとえ十ことばかりにしろ、ものを云うことなどは出来なかったろう。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして妃には、わたしが背中に子どもをしばりつけて、遠くへいくようにもうしつけました。",
              "citation": {
                "source": "手なしむすめ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、しかともうしつけたぞ。",
              "citation": {
                "source": "三つのことば",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの功名ずい一である、よって五百貫の加増をもうしつけるぞ」　伝九郎は無言のまま平伏した。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前はこの少女らを罰しようとして、そうしつつあった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会生活を全うしつつ、人間本来の欲望を発散する安全弁として、この秘密クラブを組織したのです。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、―――」「さあ、僕は孰方でもいいんだが、………」要の方は要の方で、例のあいまいな返辞をしながら、今日に限ってそうしつッこく「帰る帰らない」を問題にする妻の態度に、淡い不満を蔽い隠すことが出来なかった。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしつこく言うと、私はほんとにそうなるぞ。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしつけられているのはこの膝だけである」というのは、決して単なるオネトムの言葉ではない。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしつけられているのはこの膝だけである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
