        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "西郷像の方へ行きたれども書生の群多くてうるさければ引きかえしパノラマ館裏手の坂を下る。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆に墓表とは見えずまた墓地でもないのを見るとなんでもこれは其処で情夫に殺された女か何かの供養に立てたのではあるまいかなど凄涼な感に打たれて其処を去り、館の裏手へ廻ると坂の上に三十くらいの女と十歳くらいの女の子とが枯枝を拾うていたからこれに上根岸までの道を聞いたら丁寧に教えてくれた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食ひながら女中の話を聞くと、先達つて何とかいふ博士が此の公園を見に來て、此れは大變にいゝ處だから此の形勝を保存しなければいけないといふ事になり、更に裏手の丘迄も公園の地域を擴張する事になつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出口へ出るとそこでは下足番の婆さんがただ一人落ち散らばった履物の整理をしているのを見付けて、預けた蝙蝠傘を出してもらって館の裏手の集団の中からＴ画伯を捜しあてた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日堂の裏手より裏見の滝へとこころざす。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから丘を登つて修道院の裏手に行くと牛酪の製造場があつた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく邸宅にいよいよ買手がついたといふ話が傳はつて、ラアネフスカヤが悲しみに打たれて卒倒する塲面となつてくるのであるがその間裏手からカチン、カチインと絶てくる球突の球の響きはさういふ塲面の空氣と對應して、いかにも感じの美しい、何ともいへない舞｜台効果をなしてゐる。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり同じ町内の酒屋の下女で、今年二十一になるお伝というのが、裏手の物置へ何か取り出しにゆくと、やがてきゃっという声をあげて倒れた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども家の前を通るときは犬は裏手の方へ逃げて微かにうなってゐるのだ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎は寺の裏手へ廻ります。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "３７＝裏手　坊主が縁側に控えて居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "37＝裏手　坊主が縁側に控えて居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに今｜雛鳥を二羽、宿の裏手の鶏小屋の片すみの檻に養っている。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから新張家の外郭を包む煉瓦塀にヘバリついてグルリと半まわりすると、裏手の小山のコンモリした杉木立の中に辷り込んだ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから炭坑のトロ道が作る黒い投影の中を一散に走って、直方駅構内の貨物車の間を影のようにスリ抜けて、ほど近い日吉町の日吉旅館の裏手に来た青年は、素早く前後を見まわして、警戒のないのを見定めてから蔦蔓の一パイに茂り絡んだ煉瓦塀をヒラリと飛越えた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それでもヤット決心をしたらしく、和尚は脱けかけた腰を引っ立てて、婆さんに手を引かれ引かれ、真暗い木立に囲まれた裏手の墓地に来た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "欝蒼とした欅、榎、杉、松の巨木に囲まれた万延寺裏手の墓地外れに一際目立つ「蔵元｜家先祖代々之墓」と彫った巨石が立っているのが、木の間隠れに往来から見える。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお島どんがなあ……御存じかも知れんが、当寺の本堂の……ホラ……あすこの裏手に住んでおりまする非人の処へイツモ立寄って行きましたそうで……これは寺男の話で御座いまするが……」「ハハア。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "名をジュセッポ・ルッサナとかいって、黒田の宿の裏手に小さな家を借りて何処かの語学校とかへ通っていた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を食いながら女中の話を聞くと、せんだってなんとかいう博士がこの公園を見に来て、これはたいへんにいい所だからこの形勝を保存しなければいけないという事になり、さらに裏手の丘までも公園の地域を拡張する事になった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の日に白山御殿町のケーベルさんの家を捜して植物園の裏手をうろついて歩いた。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、きっと蝉時雨の降る植物園の森の裏手の古びたペンキ塗りの洋館がほんとうに夢のように記憶に浮かんで来る。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "準備が整って予定の時刻が迫ると、見物人らは一定の距離に画した非常線の外まで退去を命ぜられたので、自分らも花屋敷の鉄檻の裏手の焼け跡へ行って、合図のラッパの鳴るのを待っていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと気がついて、私は急いでその音の方教会の裏手へ出て行って見ました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日はもう裏手の山へかくれて居た。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもせぬ其奴こそ、得三に使わるる八蔵という悪僕なれば、害心もあらんかと、用心に用心して、この病院の裏手まで来りしに、思えば運の尽なりけん。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊などと動揺きしがようやくに静まりて、彼方へ連れ行き介抱せんと、誘い行きしを聞澄まし、縁の下よりぬっと出で蚊を払いつつ渋面つくり、下枝ならむには一大事、とくと見届けてせむ様あり、と裏手の方の墓原へ潜に忍び行きたりける。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　破廂　泰助は昼来て要害を見知りたれば、その足にて直ぐと赤城家の裏手に行き、垣の破目を潜りて庭に入りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉、杉作の家のうらてには、ふたかかえもあるニッケイの大木がありました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のうらてへむかって一直線に走っている細い道に出たとき、五十メートルほど前を、薬屋の音次郎君が、なにかつまらないことでも考えているように、拍手をしては右手を外の方へうっちゃりながら歩いていくのを見た。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
