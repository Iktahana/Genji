        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "眼の玉が濡れたように薄茶色を帯びて、眉毛の生尻が青々と毛深く、いかにも西洋人めいた生々しい逞しさは、五年前と変っていない。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは眼の前に重なり合った草の茎の隙間から見るテニスコートの白い一直線の上を、ソロソロと後しざりして来る薄茶色のセイラアパンツであった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは人間の子供位なのから、小さいのは雀位のものに至るまで、白いもの、灰色のもの、薄茶色のもの、淡青のもの、何萬とも數へ切れぬ數十種の海鳥共が群れてゐるのだが、殘念ながら、私には（同行の船員にも）一つも名前が判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは人間の子供位なのから、小さいのは雀位のものに至るまで、白いもの、灰色のもの、薄茶色のもの、淡青のもの、何万とも数え切れぬ数十種の海鳥どもが群れているのだが、残念ながら、私には（同行の船員にも）一つも名前が判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ控え室の反対側で、母親と姉さんと思われるふたりの手で、薄茶色のスーツと、燕脂をきかせたレジメンタル・タイをととのえてもらっている柾生を見て、慶一はおどろいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄茶色の芽を全体に吹いて、柔らかい梢の端が天に接く所は、糠雨で暈されたかの如くに霞んでゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二羽ながら巣にこもり、白と薄茶色のまだらの頭をのぞかせて、おだやかに引立つこともなく暮して行く。",
              "citation": {
                "source": "小鳥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持の好い空想を破られ、それでムッとして見ると、薄茶色の粟が一粒いる。",
              "citation": {
                "source": "一粒の粟",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手には薄茶色の崖があり、左手には海と空間とが広がっている。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮屈な階段を昇り切ったシャラフシャーの暗い眼にぱっと漲る日光とともに、彼の薄茶色の寛衣を纏った肩つきが、くっきり、遠景の大空を画って写った。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子は、外側から一面薄茶色の粉を吹きつけたように曇っていた。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の多い、白く光る地面には、粗毛のような薄茶色の草が一杯に生えて、晩秋の日を吸いながら輝く色々の樹木の間には、Sandstorm をふせぐための、腰の高い木造のバラックが、ポツリポツリ並んで居る。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い寒気の間幾冬もつづけて重吉の体をまもって来た毛布は、晴天の下で快く熱をふくみ、薄茶色にふくらんでいる。",
              "citation": {
                "source": "日々の映り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ははでな仕立の背広服をつけ、チョコレート色の短靴、薄茶色のソフト帽、籐のステッキという、すきのない身装をしていた。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の偉人が此馬車に乗つて毎日停車場や船乗場へ行かれるのであると思ふ時、右の肱掛の薄茶色の切がほつれかかつたのも尊く思はれた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行方を見ていると、そこに、薄茶色のしなやかな革の手袋があって、それに酒が少し触れた。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄茶色の芽を全体に吹いて、柔らかい梢の端が天に接く所は、糠雨で暈されたかの如くに霞んでいる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫地に花の押模様の繻子のコート姿が、皺も襞もなくすらりと伸びて、細そりした肩に薄茶色の毛皮の襟巻が軽くふくらみ、顔の輪廓が蝋細工のようにきっぱりしていた。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのその、薄茶色の帽子がま新らしく、へんにしゃちこばってるのに対して、大島の着物も羽織も、折目がくずれてだらりとしてる、それだからといって、あなた自身、ちぐはぐじゃいけませんよ。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子と外套の襟及び袖の折返しに、薄茶色の絨毛がもりあがっている。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の偉人が此馬車に乘つて毎日停車場や船乘場へ行かれるのであると思ふ時、右の肱掛の薄茶色の切がほつれかかつたのも尊く思はれた。",
              "citation": {
                "source": "巴里の旅窓より",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄茶色のクロース表紙の本である。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、その雪のやうなもんが、地べたへ積ると、白くなる筈だのに、それが、かう、薄茶色に、紫がかつたやうな、さうかと思ふと、ところどころ、黒いぽつぽつが見えたりして、どうも可笑しいんですの。",
              "citation": {
                "source": "雅俗貧困譜",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集の中から、パナマ帽を目深に被り、仕立下しの薄茶色の洋服をつけ、握り太のステッキを手にした、可なりの年配の男が、つかつかと出て来て、二人の前に立止った。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌の色はだぼ沙魚に似て黝黒のものもあれば、薄茶色の肌に瑤珞の艶をだしたのもある。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌の色はダボ沙魚に似て黝黒のものもあれば、薄茶色の肌に瓔珞のような光沢を出したのもあるが、藍色の肌に不規則な雲型の斑点を浮かせて翡翠の羽に見るあの清麗な光沢を出しているのが一番上等とされている。",
              "citation": {
                "source": "冬の鰍",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無紋の黒の羽織を着して、薄茶色の衣裳をまとっている。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の色は緑がかった土黄色に見え、海藻は薄茶色になる。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩の色は緑がかつた土黄色に見え、海藻は薄茶色になる。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに洋袴は薄茶色に竪溝の通った調馬師でなければ穿かないものであった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
