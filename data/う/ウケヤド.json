    "definitions": [
      {
        "index": 1,
        "gloss": "agency that dispatches lodged servants",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その一人は知行所の村から奉公に出て來るのが例で、ほかの一人は江戸の請宿から隨意に雇つてゐることが判つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "請宿は音羽の堺屋といふのが代々の出入りであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お筆はさらに近所の雇人｜請宿へ頼みに行ったが、右から左には思わしい奉公口も見いだせないらしく、二月の末まで溝口家にとどまっていた。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの習いで、幾らかの食雑用を払えば請宿の二階に泊めてくれる。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一人は知行所の村から奉公に出て来るのが例で、ほかの一人は江戸の請宿から随意に雇っていることが判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "請宿は音羽の堺屋というのが代々の出入りであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月末になると請宿の主人が来て、まことに相済まないがおたけに暇をくれといった。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下請宿は若狭屋亀吉である。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "人相書だけをたよりにするのは、いかにも心細いので、口入宿の富士屋や、請宿の若狭屋へ往って、色々問い質したが、これと云う事実も聞き出されない。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に呼び出されていた、亀蔵の口入人神田久右衛門町代地富士屋治三郎、同五人組、亀蔵の下請宿若狭屋亀吉が口書を取られた。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其次の日に仲間の請宿の主人が礼を言ひに来た。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手廻りのお世話をさせるために、江戸でお召抱えになったのがそのお藤さんで、当時はそんな邸向の奉公人ばかりを口入する請宿があったのだそうです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな家の生れか知りませんが、年も若く、美しくて利発な人で、請宿では隠れた処にも痣や黒子のないように、裸体にして調べたとかいいました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃のことですから雇人に不足はなくて、請宿へいって遣りますと、すぐに人をよこしてくれます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は曙町に住んでいましたので、請宿は白山坂の中途にありました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
