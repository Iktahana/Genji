        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "兄さんったらそんな事ちっとも言って寄こさないのね」　「親の儂に一言の挨拶もしねえで、何処の馬の骨か分らねえ様な女と一緒になりやがって………」　「兄さん帰って来たら、うんと叱言を言ってやるといいわ」　「おや？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごつげな、いい金モール服を着てやがって、どこの馬の骨だい！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董を買う以上は贋物を買うまいなんぞというそんなケチな事でどうなるものか、古人も死馬の骨を千金で買うとさえいってあるではないか。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、このアルバムを見ただけでは、人は私を、どこの馬の骨だか見当も何もつかぬ筈です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――牛馬の骨皮を、じとじと踏むような奈落の床を。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、三亀雄の妻は良家の娘ではあるが、実は養女であって、本当は誰の、どこの馬の骨の子か分らぬ私生児なのだ、という噂を耳にした時、だから政江は喜びの余りひどくそわ／＼したものである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董を買ふ以上は贋物を買ふまいなんぞといふ其様なケチな事で何様なるものか、古人も死馬の骨を千金で買ふとさへ云つてあるでは無いか。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おん箸入）の内容が馬の骨なら、言い得て特に妙である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎さんかて喜びはったのに……」「次郎さんてどこの馬の骨や？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨か知らねえが、ひでえ男だ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨か分らんようなでん公の種を宿して、認知もしてもらえんで、子供に肩身の狭い想いをさせるより、表具屋の息子が一寸間アが抜けてるのを倖い、しつこく持ちかけて逐電し、表具屋の子やと否応はいわせず、晴れて夫婦になれば、お腹の子もなんぼう幸せや分らへん。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様の口のはたも、どこの馬の骨か分りもしない奴の毒を受けた結果だぞ」　言っておかなかったが、かの女の口のはたの爛れが直ったり、出来たりするのは、僕の初めから気にしていたところであった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨か分らんようなでん公の種を宿して、認知もしてもらえんで、子供に肩身の狭い想いをさせるより、表具屋の息子が一寸間ァが抜けてるのを倖い、しつこくもちかけて逐電し、表具屋の子やと否応はいわせず、晴れて夫婦になれば、お腹の子もなんぼう倖せや分らへん。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに我々の間に入って来た英国人などは、全くどこの馬の骨でしょう？",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ひとつ気のすむまで、何処の馬の骨ともわからぬこの男と議論をしてやれ―』　と思ひましたので『私が何か間違つてゐるやうな、貴方のお話しですが、それはどういふ理由からでせうか―』　すると彼はつとめて冷静にしやべらうとして、嫌らしい程の特別に丁寧な言葉を選んで、話しかけてくるのでした。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地はどこの馬の骨かと思うような調子で、自分の名を名乗る事はもとよりせずに、軽く帽子を取って見せただけだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨だかわからない者に、頭の上がらないくらいどやされたような気がした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの珠数屋の大尽とか申すは、どこの馬の骨じゃ」「何だと！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の骨、鹿の角、人の骨、おシャリコウベ、それから蛇のぬけがら、いずれも不気味な品が雑然と所嫌わずに置いてあるのです。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ越しソバを配るだけの義理が済めば、あとはどこの馬の骨か牛の糞かといった風である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の骨に馬鹿にされたツ！",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前えなんぞは何処の馬の骨だか解つたものぢやないぞ！",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて加えて、どこの馬の骨だか知れないような相手と、わけのわからない場所をうろつくのは、だい嫌いだよと言い足した。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "死馬の骨を五百金に買いたる喩も思い出されておかしかりき。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの馬の骨だか……という侮蔑や反抗心も起って来た。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
