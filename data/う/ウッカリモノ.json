        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "彼はうっかり者で、いつも何か忘れている。",
              "source": "幻辞"
            },
            {
              "text": "私はうっかり者なので気をつけている。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者の彼女は物を落とすことが多い。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者では運転免許を取得できない。",
              "source": "幻辞"
            },
            {
              "text": "彼の弟はうっかり者で時々約束を忘れる。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者の同僚にはメモを書かせる。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者でも努力すれば改善できる。",
              "source": "幻辞"
            },
            {
              "text": "その先生はうっかり者で授業に遅刻することがある。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者の傾向がある人は細心の注意が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者であることを自覚して対策を講じた。",
              "source": "幻辞"
            },
            {
              "text": "医師がうっかり者では患者が困る。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者の欠点は個人の注意力の問題だ。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者の家族は互いに注意し合う。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者でも信頼できる人はいる。",
              "source": "幻辞"
            },
            {
              "text": "彼のうっかり者ぶりは有名だ。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者が責任ある立場にいるのは問題だ。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者は自分の弱点を理解している。",
              "source": "幻辞"
            },
            {
              "text": "そのうっかり者ぶりはコミカルでもある。",
              "source": "幻辞"
            },
            {
              "text": "うっかり者の性格は生まれつきではなく改善可能だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "また、少し感の悪いうっかり者が、とんでもない失策を演じながら当人はそれと気がつかずに太平楽な顔をしているのも、やはり涼しい顔の一種に数えられるようである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん、うっかり者のようでございますが、けれども、それは私だけでなく、世間のひと皆、新聞の美しい広告を見ても、その図案工を思い尋ねることなど無いでしょう。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれもぼんやりだが、おめえもよっぽどうっかり者だぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の如きうっかり者は招待されるとついその手に乗りたがる傾向があるので大いに用心している次第である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "操舵手がうっかり者か、無視したのか。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、私はうっかり者です。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は若しやあの暗い中で乳色の糸のような芽生がそのまま朽ちてるんじゃあないかとも、だれかうっかりものが掃除の時にするどいくわのさきでスッパリと思いきりよく殺してしまったんじゃないかとも思いまわして不安心な日を垣根の黒土を見ては送って居た。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叔父さんはね、あたしのようなうっかりものには解らないが、お延にならきっと解る。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
