    "definitions": [
      {
        "index": 1,
        "gloss": "guardian deity of one's birthplace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
