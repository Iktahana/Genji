    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wet nurse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんなときにこの行燈が忠義な乳母のように自分の枕元を護っていてくれたものである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ぐれ、めっきり水の細った秋の公園の噴水が霧のように淡い水量を吐き出している傍を子守達は子を乗せた乳母車を押しながら家路に帰って行く。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　襖の処で乳母や番頭がオロオロ顔である。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "停つてゐる乳母車の中に一人の子供を私は見た。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さうね、あたしの今一番｜欲しいのは上｜等の乳母｜車よ。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、乳母｜車なんてお安い御用さ。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のお類さん乳母をつれて今御出掛けです。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が履物をそろえてる間に彼女帳場の方をちらと見ます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母に「お前見といで」と言ってます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が戻って来ると伊吉が得意先でも廻る恰好で出て来る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が「早く」と目顔で……伊吉急ぎ足に近づく。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が「待ってらっしゃいますよ」と言って置いて日傘を取りに店へ戻る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母が日傘持って帰って来た。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お類が、Ｔ「妹さんと相談しといてね」　と乳母と共に去る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母車なんとかと白くペンキで書いた屋根が見える。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "借りて来たのは乳母車だった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と娘と姪が、夏の朝の明け方を三人で、一人は乳母車をおし、一人はいでたちをした一人に手を曳かれ、停車場へ向かってゆく、その出発を彼は心に浮かべてみた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスンの詩「プリンセス」に「戦士の亡骸が運び込まれたのを見ても彼女は気絶もせず泣きもしなかったので、侍女たちは、これでは公主の命が危ういと言った、その時九十歳の老乳母が戦士の子を連れて来てそっと彼女のひざに抱きのせた、すると、夏の夕立のように涙が降って来た」というくだりがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなることか、私は幼いときからこの婆様が大好きで、乳母から離れるとすぐ婆様の御懐に飛び込んでしまったのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母車を押していますね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、私の小さい女の子を乳母車に乗せて、ちかくの井の頭、自然文化園の孔雀を見せに連れて行くところです。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の小咄にある、あの、「誰でもよい」と乳母に打ち明ける恋いわずらいの令嬢も、この数個のほうの部類にいれて差し支えなかろう。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああこのばうばうたる白日の野邊を訪ねて行つてもむかしの失はれた幸福に出逢ひはしない。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その亭の庭にも草木茂み風ふき渡りてばうばうたれどもかのふるき待たれびとありやなしや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそうばかりでもないかもしれない。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白剥山の入口などは、解らなくて、森の中を一行が、離れ離れに迷うばかり、滝上りまでもやった、一時は絶望に近かった、しかし山腹に辿りついてからは、去年の路が、微かに見分けが出来た、頂は存外変りがなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "琵琶湖の水が高い河になって流れる下を隧道に掘って通っている道を過ぎて私たちは草津のうばが餅屋に駆け込んだ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思ってしまえば誠に簡単であるが、自分にはどうもそうばかりとは思われない。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、またそのおかげで科学が栄え文学が賑わうばかりでなく、批評家といったような世にも不思議な職業が成り立つわけであろう。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう生まれ合わせだと皆はいうけれど、そうばかりは思われない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
