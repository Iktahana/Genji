        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのうえ光と影の移り変わりは溪間にいる人に始終｜慌しい感情を与えていた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊コンピューターの世界は日進月歩で目まぐるしく物事が移り変わり、ちょっと目を離しているとすぐに時代に置いていかれてしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この項で触れているＡＣＥにしてから、その後の移り変わりは実に目まぐるしい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポッケットに両手をさし入れて、頭を縮め気味に、波止場の石畳を歩き回る人々の姿にも、不安と焦躁とのうかがわれるせわしい自然の移り変わりの中に、絵島丸はあわただしい発航の準備をし始めた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣がえ、移り変わり、季節の変わりめ、年季奉公の変わりめ、中間下男下女小女の出入りどきであるから、小前かせぎの者にはなくてかなわぬ質屋が繁盛したとて、なんの不思議もない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "物静かな山科郷の陶器師の家には、月日の移り変わりというものがないようにも思われた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季の移り変わりと月の盈虧がなかったら、どうして月日さえ数えることができたろう。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　自分は考えると頭が混沌として来るので、いつでもそれを有耶無耶に葬ってしまう――そして所定めず目的なしにフラフラと歩き出す――歩いている間、動いている間はいつの間にか甚だ呑気になって、目前の周囲の移り変わりに心を惹きつけられ、気をとられて一切を忘却してしまうのである。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎めの置き台の上に載せられてあるのを見て、山ではこうした植物の新鮮な色を見ることで時の移り変わりのわかるのがおもしろいと女房たちが言っているのを、姫君たちは何がおもしろいのかわからぬと聞いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "電子計算機の開発主体が、大学から企業に移り変わりつつある世界の流れに注目した大泉らは、「ぜひ我々にやらせてほしい」との日本電気からの働きかけに乗った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして長生きして世界の移り変わりをよく見極めたいものである。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "世情は滔々と移り変わりつつあり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや世の中の移り変わりはひどいもンじゃ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "相生町のかみさんのように、婦人としての教養もろくろく受ける機会のなかった名もない町人の妻ですら、世の移り変わりを舞台の上にながめ、ふとした場面から時の感じを誘われると、人の泣かないようなことに泣けてしかたがないとさえ言っている。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "半蔵はそれを都会の人たちの風俗の好みにも、衣裳の色の移り変わりにもみて取ることができた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい移り変わりの時を告げ顔なものは、ひとりこんな俗謡にのみかぎらない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ればそこにも流行というものがあって、石蹴り、めんこ、剣玉、べい独楽というふうに、あるものははやりあるものはすたれ、子供の喜ぶおもちゃの類までが時につれて移り変わりつつある。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、しまいには、季節の移り変わりを、牛女について人々はいうようになったのでした。",
              "citation": {
                "source": "牛女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "暦も、新暦よりは、旧暦のほうが季節の移り変わりによく合っているといっていました。",
              "citation": {
                "source": "さかずきの輪廻",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸はその源が土地表面からあるていど深いところにあって外気の影響よりも下にあるので、それらの温度は一般に季節の移り変わりのあいだに均一であり、大気の温度よりも常に数度低い。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "……弁当の包みを膝にのせながら、微妙な季節の移り変わりに驚歎している赤子のような無心な表情。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、見よ、私がこう言っている間に、それを火に近づけると、残っていた味は除き去られ、香りは散り失せ、色は移り変わり、形体は毀され、大きさは増し、流動的となり、熱くなり、ほとんど掴まれることができず、またいまは、打っても音を発しない。",
              "citation": {
                "source": "省察",
                "author": "MEDITATIONES",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二つの音楽の移り変わりがあまりに粗暴だったので、クリストフは憤って、歯をきしらせ足を踏み鳴らして、壁に拳固をつきつけた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、彼はその精神の最も空漠たる一｜隅において、移り変わりゆく眼界と人間の一生とを比べてみたであろう。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "その精神の成熟ぶりがはっきりしている――「愛、喜び、落ち着き、忍従、思いやり、善、誠実、温和、節度、自制」――境遇が、世の移り変わりがどうあろうとも。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "20日　夜　社交・娯楽といった目に見える快楽は気持ちいいものであるが、移り変わり消えるものだ。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節のうつりかわりに敏感なのは、植物では草、動物では虫、人間では独り者、旅人、貧乏人である（この点も、私は草や虫みたいな存在だ！",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出ると、急にむずかしき顔して衣紋をつくろい、そり身になってそろりそろりと歩いて、物持の大旦那がしもじもの景気、世のうつりかわりなど見て廻っているみたいな余裕ありげな様子である。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二章　大正　　　　　１　そこは貧乏たらしくごみごみとして、しかも不思議にうつりかわりの尠ない、古手拭のように無気力な町であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "弐、大正　そこは貧乏たらしくごみごみとして、しかも不思議にうつりかわりの尠い、古手拭のように無気力な町であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
