        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "・晴れきつて青さ防空のサイレンうなる　しきりに撃ちまくる星がぴかぴか・燈火管制の、風が出て虫が鳴きつのる　　　燈火管制・まつくらやみで煮えてる音は佃煮・ぴつたりけさも明星がそこに　九月十九日　快晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯昼間、敵機の爆撃音がすごくなり、味方の高射砲もどんどん撃ちまくるとなれば、恐怖心もどこかへ吹っとんでしまって「おのれ、敵の奴め、味方よ、撃て撃て！",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、そこにいる火星先生にも一発……」　と、博士は楽しそうにピストルを音もなく撃ちまくる。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗組員は皆一挺ずつ小銃と青龍刀を持っている外に、船の底に機関銃が二挺も隠してあって、いざという時には、それを甲板に持出して、相手の船をうちまくるのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
