    "definitions": [
      {
        "index": 1,
        "gloss": "to hit repeatedly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は、まるで、誰か頑丈な人間が、自分の体内を歩きまはりながら、掛矢で心臓や脈管を打ちまくるやうに感じた……それほど怖ろしく、この笑ひ声が彼の内心に響いたのだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "また患者が注射といふものを気味わるがり、医者仲間もそれに迎合して滅多に使はなかつたころから、彼はどしどし打ちまくるのだつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金太郎のセリフの尻にかぶせて、下の県道の奥から、急速に近づいてくるトラクターの、ガラガラという、ちょうど機関銃を打ちまくるような激しい音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗組員は皆一挺ずつ小銃と青龍刀を持っている外に、船の底に機関銃が二挺も隠してあって、いざという時には、それを甲板に持出して、相手の船をうちまくるのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
