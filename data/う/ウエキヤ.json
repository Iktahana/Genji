        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば菓子屋、植木屋、吹屋、射的場の前には、今一客を止めず。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人に聞いてみると、せんだって四つ目垣の朽ちたのを取り換えたとき、植木屋だか、その助手だかが無造作に根こそぎ引きむしってしまったらしい。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物を扱う商売でありながら植物をかわいがらない植木屋もあると見える。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な植木屋が良い木を枯らす。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の門、植木屋の庭、花屋の店など、坂下を挟みて町の入口にはあたれど、のぼるに従いて、ただ畑ばかりとなれり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の檜葉の手入れをしていた植木屋たちはしかし平気で何事も起こっていないような顔をして仕事を続けていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にお庭の立木にも植木屋の手が這入らなくなったらしい。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに植木屋夫婦が暮している。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め植木屋夫婦が引越して来た時、井戸がないので何卒か水を汲ましてくれと大庭家に依頼みに来た。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方で木戸を丈夫に造り、開閉を厳重にするという条件であったが、植木屋は其処らの籔から青竹を切って来て、これに杉の葉など交ぜ加えて無細工の木戸を造くって了った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋の女房のお源は、これを聞きつけ「それで沢山だ、どうせ私共の力で大工さんの作るような立派な木戸が出来るものか」　と井戸辺で釜の底を洗いながら言った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃア大工さんを頼めば可い」とお徳はお源の言葉が癪に触り、植木屋の貧乏なことを知りながら言った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで結極のべつ貧乏の仕飽をして、働き盛りでありながら世帯らしい世帯も持たず、何時も物置か古倉の隅のような所ばかりに住んでいる、従ってお源も何時しか植木屋の女房連から解らん女だ、つまり馬鹿だとせられていたのだ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらにしてもお徳が言った通り、彼処へ竹の木戸を植木屋に作らしたのは策の得たるものでなかったと思った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋さんも何時まであんな物置小屋みたような所にも居られんで移転なりどうなりするだろう。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷は軽そうなが前屈みに、てくてく帰る……お千世が爺の植木屋｜甚平、名と顱巻は娑婆気がある。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　植木屋の布子の肩に、手を柔かに掛けた、弱腰も撓むと見える帯腰に、もの優しい羽織の紋の、藤の細いは清葉であった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花咲爺の画にあるような、ああ、」　と横を向いて卓子台を幽に拊って、「前刻、西河岸で逢った植木屋……ね、ちょっと肖ていたよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、小腰を屈めて差覗き、頭を揺って呼掛けたのは、顱巻もまだ除らないままの植木屋の甚平爺さん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、植木屋さん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五「それからの、山田下の植木屋の娘がある、美人じゃ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にその時もあれじゃ、植木屋の庭へこの藁草履を入れて掻廻わすと、果せるかな、、蟷螂。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まさか、」「うむ、植木屋の娘と其奴と、貴様、植込の暗い中に何か知らん歎いておるわい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御出入の商人、職人、盆栽のお見出しに預りたる植木屋までが、驚破鎌倉と馳参じ、玄関狭しと詰懸け詰懸け、夜一夜眠らで明くる頃、門内へ引込みたる母衣懸の人力車、彼はと見れば、こりゃどうじゃ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しい以前だけれど、大塚の火藥庫わき、いまの電車の車庫のあたりに住んで居た時、恰も春の末の頃、少々待人があつて、其の遠くから來る俥の音を、廣い植木屋の庭に面した、汚い四疊半の肱掛窓に、肱どころか、腰を掛けて、伸し上るやうにして、來るのを待つて、俥の音に耳を澄ました事がある。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こゝで分つた――植木屋の親方だ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　萩も芙蓉も、此の住居には頷かれるが、縁日の鉢植を移したり、植木屋の手に掛けたものとは思はれない。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとへ引返して、すぐ宮前の通から、小橋を一つ、そこも水が走っている、門ばかり、家は形もない――潜門を押して入ると――植木屋らしいのが三四人、土をほって、運んでいました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお御隠居様、大旦那、と植木屋は一斉に礼をする。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
