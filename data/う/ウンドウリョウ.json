[
  {
    "uuid": "a3350232-d09a-5e86-a2e5-1c697faa90d0",
    "entry": "運動量",
    "reading": {
      "primary": "うんどうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
