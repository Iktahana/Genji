        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（明治四十年十月十九日『東京朝日新聞』）　　　　　　　　　二十三　　　　　　章魚と烏賊との研究　（一）章魚の生殖作用　今年の英国科学会の総会でホイルという動物学者が講演した章魚や烏賊の類に関する研究の結果中で吾々｜素人にも面白く思われる二、三の事実を夜長の話柄にもと受け売りをしてみよう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得の知識を繰り返して受け売りするだけでは不十分である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけのことは郵船会社の案内記にも書いてあるので、僕はその受け売りをして聞かせると、早瀬君はうなずいた。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに「鼻の表現」の一篇はそれ等の受け売りであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも註釈をそっくりそのまま受け売りにして説明致しました方が早わかりであると信ぜられるからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは今云った悲劇喜劇のなかでは余ほど毛色の変った方ですから、自分のことじゃありませんけれど、受け売りの昔話を一席弁じましょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "琉球の永良部鰻など、食用さるる海蛇あるは人も知るが、南アフリカのズーガ河に棲む水蛇も、バエイエ人が賞翫する由（リヴィングストンの『宣教紀行』三章）このついでに受け売りす。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に愍然な次第故、自分も知らぬながら、学者の説を受け売りしよう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし既に述べ置いた通り、美術としては絵嘘事も決して排すべきにあらねど、ここにはただかかる行動を為す蛇は実際ないてふ小説を受け売りし置く。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鑑識に驚いて予が小沢という人に話し、小沢また岡崎氏に向って受け売りすると、恋愛の実境はそんな言では悉し得ない、すべて少年は縹緻を重んじ中年は意気を尚ぶ、その半老以後に及んではその事疎にして情｜転た熾んに、日暮れ道遠しの事多し、ただ身分の健否を問うのみと言われた由。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "騾の牝が他の馬種と合いて、子を産んだ事は時に聞くも、少なくともこの数千年間、無数の騾を畜うた内、牝牡の騾の間に子生んだ例あるやは極めて疑わし、故に馬属の諸種は現時｜相雑わって子あれども、その子同士で繁殖し行き得ぬ世態にあると、『大英百科全書』から受け売りかくのごとし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今大要を受け売りと出掛ける。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代の探偵物語を読む人々の便宜のために、わたしも少しばかりここにその受け売りをして置きたい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その説明をするために植木さんの受け売りをするのだが、どうも誰も承知しません。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏のモデルを探したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこれこれと例の受け売りをやって見ましても、後藤氏は腑に落ちた様子がない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏のモデルを探したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑っくるしいから、やじうまはどぶへへえれよッ」　すぐともう名人のせりふを受け売りしながら、肩で風を切り、ありったけの蘊蓄を傾けて、いらざることをべらべらとしゃべりつづけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は新智識を衒って雑誌や新聞の受け売りを吹く。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは受け売りですよ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の話が果たして受け売りか、あるいは他人に托して自己を語っているのか、おそらく後者であるらしく想像されたが、彼はあくまでも受け売りを主張していた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも云う通り、かの老人の話が果たして受け売りであれば、半七のモデルは他にある筈である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを当代の大原君がかつて話してくれたので、僕は今その受け売りをするわけであるから、多少の聞き違いがあるかも知れない。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕はすぐそばにいた荒畑に、きのう雑役の囚人から聞いたそのままを受け売りした。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア・ジャーナリズムのあれこれの作品について受け売り批評をすることでもなければ、口の先だけで民主主義文学創作方法あれこれをしゃべることでもないでしょう。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが東洋の哲学を咀嚼しないで単に西洋の哲学の受け売りをして、翻訳的、紹介的に煩瑣なる羅列を試み、鸚鵡的にくり返すというような状態で、真に活躍したる哲学的精神の甚しく欠乏したことに驚かざるを得ないのである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから最前から饒舌り続けた経験談なんかは、ミンナ受け売りのゴッタ雑炊だ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の話は大部分新聞記事の受け売りらしかった。",
              "citation": {
                "source": "湖南の扇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは、すこし、受け売りだがね」「わかるやうな気もするわ」「そこまで行つてない証拠だ」　二人の話声が夫の耳にはいりました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその子供が根作の自慢をそっくり受け売りに綴り方を書いた。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般的にいえば、彼らの著書の内容は、辞書の受け売りや他人の書物のつぎはぎで、著者自身の舌から生み出された文章はまったく稀である。",
              "citation": {
                "source": "弦斎の鮎",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ私生子を生むような女は、と悪態をつかれることなどを聞いていた花村が、主人公の私生子であるということについて大人からうけうりの偏見を持ったわけであり、その動機は、主人公の少年の卑屈から出たうそでした。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            }
          ]
        }
