[
  {
    "uuid": "e630343b-d7e6-5149-8b46-b34c6becfec4",
    "entry": "得る",
    "reading": {
      "primary": "うる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-二段-ウ行-古典",
