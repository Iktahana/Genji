        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、明日の糧にも気心を配る女房の顔を見れば、釜貞も人間、只暗澹として首を俯する他はなかつた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは日ごとに公苑に往き戲園に入り、又心安からぬまゝに寺院を尋ねて、聖母の足の下に俯することあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（足手を硬直し、突伸べ、ぐにゃぐにゃと真俯向けに草に俯す。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大洗祠前、海水浴旅館、波に俯す。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "玩具のくゝり猿の如き樣して、水に俯する母の背に負はれたる赤兒、泣いてやまざるも、母は之を懷くひまなし。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉氏代々の城址にして、千葉第一の遊覽地、老松參差として、千葉の市街に俯す。",
              "citation": {
                "source": "千葉夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏山は風邪の心地なりとて、一隅に身をちゞめ、羽衣は船暈の氣味なりとて、座に俯す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "男二人横臥せる間のしりへに、わづかに膝を容るゝばかりの餘地を求めて、顏を袖に埋めて俯す。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺は、山を負ひ、山門怒濤に俯す。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "伽藍堂々、山に據り、海に俯す。",
              "citation": {
                "source": "北條より一ノ宮へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女は青畳の上に俯すように身をかがめたり、また仰向きに反り身になったりして、鈴と扇とを品よくあしらった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄に倚って俯すとき広き両岸の青を極めつくして、始めて石垣に至る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊ヂュウカリオーンは次の牲、肱の筋肉合ふところ、其腕をうつ青銅のアキルリュウスの槍凄し、彼は空しく腕を垂れ死の運命を覺悟して、　480敵の迫るを迎へ待つ、敵は利劍を打ち揮ひ、兜のまゝに其頭、打つて落せば背骨より、脊髓溢れほとばしり、屍は大地に倒れ俯す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "うち俯すぎて、兜の頂辺を射られるな。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯をかはした櫻内が、疊にうつぶすのと、瓶が床の間の壁へづしりと響いたのと同時だつた。",
              "citation": {
                "source": "就職",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空はしる雲の白き額うつぶすと言ひては、下の邦なる争ひの急なるを愁ひ、大樹も梢あらはに黄葉落尽のさまを譬へて素足真白き女の神の引照比喩頗る精彩あり。",
              "citation": {
                "source": "泣菫氏が近業一篇を読みて",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
