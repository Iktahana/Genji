        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一に好色、二に酒の味、三にさんげの歌枕。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心は安く、気はかろし、揺れ揺れ、帆綱よ、空高く……　私の今度の航海は必ずしも物の哀れの歌枕でも世の寂栞を追い求むる風狂子のそれでもなかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一に好色、二に酒の味、三にさんげの歌枕、わが思ふ人ありやなしやと問ふまでもなし都鳥、忘れな草の忘れられたるなほいとし。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀の国屋十二　御待合歌枕。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえてものの三角形が秘密を守るものだという数学の原理はないけれども、歌枕の女房は目の形が三角である。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月ばかり前の夜、同じこの歌枕で会った時、蝶吉はそれとはなく、頻に子が一人欲しくはないかといったのを、気にも留めないで聞棄にしたが、松の鮨の毒口を、ここで聞正せば実際で、梓は思い懸けず、且つ驚き且つ呆れ、あわれにも情なくも思ったのである。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ蝶吉と歌枕で逢曳の重なる時分、神月は玉司子爵の婿君であったから、一擲千金はその難しとせざる処、蝶吉が身を苦界から救うのはあえて困難な事ではなかった。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梓は丸腰の着流し、あたかもお館の法度を犯して裏庭から御台のお情で落ちて行くように、腕車で歌枕に送られたが、後を知らず、顔色も悪く未明に起きると、帯を取って、小取廻に尖を渡して、本式に畳んで置いた袴の腰板を取ってあてがい、着たまま枕頭に坐って介抱していた蝶吉が件の羽織を惜そうに脱いで被せた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし千賀の浦と云へば、陸奧の歌枕の一つなりき。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故あの時無理にでもそのあとについて歌枕を見に行かなかつたかと思つた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この多賀の府からは歌枕の千松島はもはやさして遠くない。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちのくへ歌枕見にまゐると世間へは立派に披露して、實はこの春から我家の奧に隱れてゐました。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらや歌人の歌枕なるべきとて　　　関守のまねくやそれと来て見れば　　　　　　尾花が末に風わたるなり　薄の句を得たり。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれその内に、御眼にかけようとは思っているんですが――安田さんは絵本歌枕と云うものを御覧になった事がありますか。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌の主題と言へば、彼等の経験を超越して居る事を条件とする歌枕に、僅かに驚異の心を寄せるばかりだつたからである。",
              "citation": {
                "source": "鶏鳴と神楽と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝中頃の歌の主題になつて居た歌枕の中に、特に、非常な興味を持たれたものは、東国の歌枕である。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又「入間言葉」なども、大分後になつて、歌枕に這入つて来た。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は、平安朝の末頃、陸奥の結婚にはかう言ふ話があつた、と言ふ諸国噺の一つとして、語り伝へられて、歌枕になつたのであるが、よく考へて見ると、さう言ふ事でないのかも知れぬ。",
              "citation": {
                "source": "花の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が「歌枕」と称せられるものだが、歌の全内容となる題材としてゞなく、修辞上の刺戟の為ばかりに使はれた様である。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌枕も、修辞の上ばかりでなく、全体としてとりこまれてゐる。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌学の始りとしては、まづ、古今を中心にした故事の詮索から、古くは万葉、新しくは後撰以後の出典・歌枕などまでに手が及んで、日本学としての姿を具へ出して来た。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　歌枕及び幽玄態の意義変化宮廷の日常交際の古歌引用は、流行に影響せられて行つた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌枕の存在を明らかにした。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌枕の採集地として、万葉を扱うたまでゞあつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕詞・歌枕といふ語も、常に動いて居たので、第一義は既に述べたが、而も疑ふべきは新撰髄脳で、果して公任作かどうかと思はれる程だ。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "わりに古い歌枕は、初めは、古書に出た地名・行事の称呼・日常語の雅訳したものなどを言うて居た様である。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌の上の文学用語であると共に、歌枕は、本来の用として、歌の風韻を作るものであつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌枕其他、故事・格式を知らねば作れぬものと考へたからである。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "俊頼のたゞごと主義は、歌に従来の歌枕以外の語を入れ、優美と考へられて居ない事象をも優美にすることで、其結果は却つて、奇歌を作つた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            }
          ]
        }
