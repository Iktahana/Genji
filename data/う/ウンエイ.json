          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まもなくヤングは、指導的役割を果たしただけでなく、都市の運営にも手腕を発揮した。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を乗りこなすのはお手のものでしたので、辻馬車の運営事務所に自分を売り込むと、すぐ採用に。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表的なパソコン通信の運営会社であるニフティーサーブには、エキスパンドブックに関する意見交換の場として、ボイジャーのサロンが設けられています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピースボートには、運営にあたる会社や恒常的な組織はありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空文庫の運営には、費用がかかる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ファイルの商業利用に対価を求める余地を残しておけば、ここから運営費を得ることも可能になる」とする主張がなされた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "…　青空文庫を、テキスト・アーカイブ構築のある種の文化事業としてとらえるなら、ファイル利用に対価を求めて、運営体制を強化するという考え方が出てくる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃこのオレも、大組織の運営効率を高めるＭＩＳ部門のエリートにでも収まっているのなら、システム本位で物事を考えるかも知れない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもう私は引退ればいゝのでしたが、その後をいゝ結果のでるやうに組織運営されそこを共同的精神が支配出来るやうにといふ願ひから私はこの農場の組織と施設とを北海道大学農業経済の教室で作製して貰つたのであります。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの一八一二年の軍編制や運営につき深刻な研究をしていた独軍参謀本部は、一九一四年同じ失敗をしたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、日本の教育方針が改められて、軍国主義の教育をすて、国民の一人一人が社会を運営してゆく能力をもつために民主的な教育が要求されてから、母も父と並んで、子供の未来に重大な関係をもつものであることがはっきりして来ました。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がたたかわなければならなかった、社会の現実と、彼の理性と真実の観念的な運営法との間に、ギャップがあったのでした。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人民の社会生活が戦争犯罪的権力によって破壊された今日、それを癒す道は犯罪的な権力を根本的に人民の生活機構から追放して、健全な精神と能力の人民が自分ら人民のために社会を運営してゆく方法しかない。",
              "citation": {
                "source": "女の手帖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本全国のすべての婦人が、その苦痛の解決のために、希望の具体化のために、よろこばしい諸成果をともどもに愉しむために、生々と運営してゆくべき組織の一つです。",
              "citation": {
                "source": "婦人民主クラブ趣意書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、各種の現存の機構、組合にしろ、購買組合にしろ、それはどのように運営される可能があるか。",
              "citation": {
                "source": "合図の旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家事の運営のために婦人が費す労力は世界最大のものである。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして最も不幸な加害者の形で現れている被害者の一部をもこめて、私達全人民は、女も男もこの破局から自分達の前途を救い、民族を高めるのはただひとつ自分達の結集した力の合理的な運営があるのみであるということを自覚することは、もう決して早すぎない。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "公民権は、市、町、村等自治体の運営に参加する権利である。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの「政治」は、私たち人民の眼にも届かないどこかで、見たこともない一握りの人々によって運営されて来た。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私たちがまだ未熟で、クラブとしての運営の形も十分ととのいきれないうちに、日本の社会の事情は目まぐるしく前進した。",
              "citation": {
                "source": "三つの民主主義",
                "author": "――婦人民主クラブの立場に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ごろ来朝していた作家シーモノフが、日本の出版界にもそれを衷心から希望したとおり、ソヴェト同盟の出版事業は直接に人民文化の仕事として企画され運営されている。",
              "citation": {
                "source": "政治と作家の現実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部の運営が民主的でないこと、プログラム編成が低俗であり昨今は労働、農民、報道、子供のための放送にはっきり民主化からの後退が示されてきていることが世論にのぼっている。",
              "citation": {
                "source": "三年たった今日",
                "author": "――日本の文化のまもり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたち日本の人民は、人民の合議の上で決定される社会の運営法があるのだ、ということを、もっと現実的に知るべきである。",
              "citation": {
                "source": "目をあいて見る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会の運営は民主的な会議制を原則とすると明記していることも、旧い文壇の先輩、後輩のしきたりにとらわれたり、ひきにたよったりする文学的卑屈さを排そうとする性格をあらわしているように見える。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学習院の運営は宮内省からきりはなされ、自主的にされなければならなくなっていること。",
              "citation": {
                "source": "日本の青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織の内のことは、組織の内で解決するべきものだ、ということが、組織の運営についての論議と、文学問題一般についての発言とのけじめなく、プロレタリア作家たる立場として、求められたのだった。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソ同盟の社会主義社会の運営方法や建設の現実を、捕虜という条件にいながらも公平に評価しようとした若い学徒兵たちの記録。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学校は働いている若い女性達が、全く自分で計画して、運営して、経済的にも充分次期計画を実行できるだけの余力を持って第一回を終りました。",
              "citation": {
                "source": "若人の要求",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義は文字通り人民の幸福を主として考え、運営される社会を意味する。",
              "citation": {
                "source": "明瞭で誠実な情熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らしむべからず、よらしむべしという徳川幕府の政治的金言は、天皇制運営者たちによって、人民にあてはめられて来たばかりでなく天皇そのひとの生涯に適用された。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
