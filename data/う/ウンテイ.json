    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cloud base",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "見る／＼、樹を裂き、枝をくだき、すさまじき音して下りゆきて、他の巖と鬪ひて、雲底に火花を散らすなど、壯觀云はむ方なし。",
              "citation": {
                "source": "春の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどもまた「自由の郷は雲底に沒せんとす」るのである。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "創始期の新詩界はさきに言つた如く、獨歩の雲底に沒する自由と共に過ぎ去つて、こゝにまた新たなる感情がえならぬ薫香を帶びて立ちのぼるのを見るのである。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "観測陣の人たちは、こんな呑気な話ではなかろうと思っているうちに、いよいよ日の出直前になると、急に薄い雲がいくつもの層になって東の空に現れ、その雲底が真赤に照り出した。",
              "citation": {
                "source": "日食記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は京都からこつちへ廻つて来た口なんだが、どうも君以外にうんていふ奴はゐさうもないんだよ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
