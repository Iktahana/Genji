          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すると家中の者がぞろぞろ出て来る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしヘルンが仕事をしている時は、家人が皆神経質に注意しているので、家中がひッそりとして閑寂に静まり返っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時の夜などに、ヘルンの書斎から法螺貝の音が聞えて来ると、それが広い家中に響き渡って、ボオボオと余韻の浪をうって伝って来る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今日の洋画家中唯一の浅井｜忠氏を除けばいずれも根性の卑劣な※の声を打消していった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まづお婆さんが目を覚まし、家中のお掃除を始めます。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお父さんが目を覚まして、咳払ひや煙草盆の音を立て始めると、急に家中活気を呈して来ます。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中に二十銭しかない。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "華々しいもの、潔いもの、勇壮なるもの、さう云つたものから、子供の家へ帰ると、ひつそりと沈んだ冷え冷えとしたものが、両親の体臭のやうに、家中を靄のやうに立ちこめてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくすると、急に家中がしんとして、大風の後のやうな靜穩が此の山腹全體を支配するやうに感ぜられた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいつでも家中まだしぃんとしてゐるからな。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと通されると応接間というのがまた大概きまって家中で一番日当りの悪い一番寒い部屋になっているようである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は三度も四度も裏坂の上まで出て渡しの方を見ていたそうで、いつでも家中のものに冷かされる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日がこの村の祭で明日は宵祭という訣故、野の仕事も今日一渡り極りをつけねばならぬ所から、家中手分けをして野へ出ることになった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵祭ではあり十三夜ではあるので、家中表座敷へ揃うた時、母も奥から起きてきた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにこの時は戸村の家でも家中で僕を悪く言ったそうだけれど、民子一人はただにこにこ笑って居て、決して政夫さん悪いとは言わなかったそうだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所で家中夕飯時であったが、ただそこに母が見えない許り、何の変った様子もない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯は勿論茶もほしくないです、このままお暇願います、明日はまた早く上りますからといって帰ろうとすると、家中で引留める。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがお出でになったら、お話し申すつもりで、今日はお出でか明日はお出でかと、実は家中がお待ち申したのですからどうぞ……」　そう言われては僕も帰る訣にゆかず、母もそう言ったのに気がついて座敷へ上った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る通り家中がもう、悲しみの闇に鎖されて居るのです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで家中の人が皆集って、それをどうしようかと相談しましたが、可哀相なような気持もするけれど、見ずに置くのも気にかかる、とにかく開いて見るがよいと、あれの父が言い出しまして、皆の居る中であけました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考えるほどあの児が可哀相で可哀相で居ても起っても居られない……せめてあなたに来て頂いて、皆が悪かったことを十分あなたにお詫びをし、またあれの墓にも香花をあなたの手から手向けて頂いたら、少しは家中の心持も休まるかと思いまして……今日のことをなんぼう待ちましたろ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに現今幾百を数える知名の画家｜殊に日本画家中で少なくも真剣にこういう努力をしている人が何人あるかという事は、考えてみると甚だ心細いような気がする。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして既成文壇の大家中で、所謂プロレタリヤ文學に理解と同情を有したところの、眞の唯一の人であつた。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中で、おかしな子供と云われていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に腦症を起しかけて醫師が絶望を宣告した事、そして、家中の者が枕元に集まつて豫期された私の死に涙ぐんだ事――そんな事は回復期にはいつてから初めて看護婦の武井さんに聞かされた事だつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人に聞いてみると、どこからともなく入り込んで来て、そうして、すっかりわがもの顔に家中を歩き廻っているそうである。",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中が珍しくしんとして表庭の方で虫の音が高く聞えていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の眷族はゆうべのうちに皆帰って来たらしく、さながら人間の無智を嘲るように家中いっぱいに啼いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは固より記憶していなかったが、唯さえ静かな家中がしんとして、夜ももう余ほど更けているらしいと思う頃に、次の間の畳を滑るような足音が微かに響いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか修学旅行の話が出てから家中へんになってしまった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
