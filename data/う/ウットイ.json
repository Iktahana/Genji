[
  {
    "uuid": "051b0f5a-8408-5edf-95f6-849f7df57076",
    "entry": "うっとい",
    "reading": {
      "primary": "うっとい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "irritating",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "そのうっとい態度はやめてほしい。",
              "source": "幻辞"
            },
            {
              "text": "彼のうっとい発言は周囲を不快にさせた。",
              "source": "幻辞"
            },
            {
              "text": "うっとい会話が続いていて疲れた。",
              "source": "幻辞"
            },
            {
              "text": "このうっとい関係から解放されたい。",
              "source": "幻辞"
            },
            {
              "text": "上司のうっとい質問に答えるのが嫌だ。",
              "source": "幻辞"
            },
            {
              "text": "毎日のうっとい通勤が苦痛だ。",
              "source": "幻辞"
            },
            {
              "text": "そのうっとい気分をどうにか改善したい。",
              "source": "幻辞"
            },
            {
              "text": "うっとい感覚を覚えて深呼吸をした。",
              "source": "幻辞"
            },
            {
              "text": "弟のうっとい行動に我慢できない。",
              "source": "幻辞"
            },
            {
              "text": "このうっとい業務は誰かに任せたい。",
              "source": "幻辞"
            },
            {
              "text": "久しぶりのうっとい感情が戻ってきた。",
              "source": "幻辞"
            },
            {
              "text": "そのうっとい環境を避けるために引っ越した。",
              "source": "幻辞"
            },
            {
              "text": "うっとい人間関係は精神的にきつい。",
              "source": "幻辞"
            },
            {
              "text": "何かうっとい雰囲気が漂っている。",
              "source": "幻辞"
            },
            {
              "text": "その人のうっとい性格は治らない。",
              "source": "幻辞"
            },
            {
              "text": "朝のうっとい気分を払拭したい。",
              "source": "幻辞"
            },
            {
              "text": "うっとい話題を避けるようにしている。",
              "source": "幻辞"
            },
            {
              "text": "このうっとい状況から脱出したい。",
              "source": "幻辞"
            },
            {
              "text": "親戚のうっとい訪問を避けられない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と思うと地面ははげしくぐらぐらゆれ、百合の花もいちめんゆれ、それからごうっというような大きな音が、みんなを倒すくらい強くやってきました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうよほど年はとっていましたが、やはり非常な元気で、こんどは毛の長いうさぎを千匹以上飼ったり、赤い甘藍ばかり畑に作ったり、相変わらずの山師はやっていましたが、暮らしはずうっといいようでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉君は、いつも水藻のような石太郎が、こんなにはっきり、ちくしょうっという日本語を使ったこともふしぎだったし、こんなにすばしこい動作ができるということも不可解な気がした。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうっといって御覧なさい。",
              "citation": {
                "source": "勝川花菊の一生",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眠ったらしいから、もう大丈夫だ、ね」　そして、わざと心持にはふれずに、「ともかく電報うっといたから」と云った。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ水面には触れずとおく上空をゆくのか、ごうっという颶風のような音がする。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間、どうっという小音が一同の鼓膜をうった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、思うと、遥かの底の、正面の一部分が四角に切り抜かれて、闇の中から浮き出したように、ぼうっといつの間にやら薄明るくなって来た。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑巾がけは、すうっといちどきに長く早くふいてしまわずに、じゅうぶん両手に力を入れて、こまかく手を動かし、一つのところに、二度三度ずつ雑巾の当るようにふくこと。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンドンはだまって、すうっといってしまいます。",
              "citation": {
                "source": "もののいえないもの",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のことは、ほうっといてくれ」ブルタスのごとくルピック氏――おい、にんじん、お前は前学年には、わしの望みどおり勉強しなかった。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓で、自分の牛をほうっといて気楽に眠ってるような奴はいませんでした。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田　事に托して、あいつを蹴倒してやった時には、春以来のこの胸が、どうやらすうっといたしたよ、あはははは。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらがら鳴り続ける雷鳴の中に、ふと、ごうっというひどいひびきがした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ずうっといるんです。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ありがとう」「ともかく電報をうっといたから……」　伸子の感情を刺戟しまいとして素子は事務的な方面からばかり話した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぶこちゃんは帰らないということと、お悔みをうっといた」「それでいいわ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっという声が喉を塞ぎ、全身の筋肉が痙攣して、刺しとおした短刀を烈しくくい緊めるように思えた。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた、おなかすいたでしょ」「そうでもない」「いま起きるから待っててね」「そうすいてもいないよ」「もうお午ごろだわね」　そうっといって（夜具の中で）伸びをし、大きな声で欠伸をするのが聞えた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　万三郎はうっといって息をのんだ。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにみごとな技で、女はうっといったまま気絶した。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万三郎は思わずうっといった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "躰勢もよかったし、満身の怒りをこめた力で、注文したように当て身がきまり、蔵人はうっといって前のめりに倒れた。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眼で見たものも間違い、口で云うこともできない、――そう致しますと、万三郎さまの真実と仰しゃるのは、どうして理解したらいいのでございますか」　万三郎はうっといった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "休之助はうっといい、弟のほうへ振返った。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三之助のあっという声で、ふり向こうとした男の頭の上へ、……鈍いいやな音と共に、男はうっといって横へのめった。",
              "citation": {
                "source": "暴風雨の中",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか聞き違えたかと思ったらしいが、すぐにその意味がわかり、うっといって坐り直した。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほど意外だったらしい、眼をみはってからうっといった。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
