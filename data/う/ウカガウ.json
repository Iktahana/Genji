[
  {
    "uuid": "2750793f-d592-54d7-98f3-efbc1e7fc4d7",
    "entry": "窺う",
    "reading": {
      "primary": "うかがう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
