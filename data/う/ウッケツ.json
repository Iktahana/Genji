  {
    "uuid": "49ab90df-4386-534a-ac8f-88693f7d20d0",
    "entry": "うっ血",
    "reading": {
      "primary": "うっけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
