        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そういう晩によく遠い沖の海鳴りを聞いた。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の島宮沢賢治海鳴りのとゞろく日は船もより来ぬを火の山の燃え熾りて雲のながるゝ海鳴り寄せ来る椿の林にひねもす百合掘り今日もはてぬ",
              "citation": {
                "source": "火の島",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "韃靼海の深い、遠い、冥い響きが、海鳴りが、波の音が、潮騒が、　あ、きこえる、きこえる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかそこからオルガンがひびいてくるような気がしましたが、でもそれは海鳴りの音をききちがえたものでした。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚はまい日まい日丘の上で、海鳴りを聴く苦しい生活をしました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "天も海も真黒に塗りつぶされた闇のなかに、カンテラの光りがかすかに明滅し、海鳴りと風の咆哮とが、その音を競い合った。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "津輕海峽を渡る船の上、雨のそぼ降る海鳴りを闇のなかに聞いたとき、かつて遠い他人のものであるに過ぎなかつた一つの誘惑を自分自身に感じた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不潔な燈火の下を飛び交ふこれらの新奇な鼻音と、交流する世界の諸潮流の海鳴りとが、私の頭蓋中で互の協和音を発見し合ひ、響かせ合つた。",
              "citation": {
                "source": "断片",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、その響きに、彼は夷岐戸島の海鳴りを聯想したのである。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳴りの聞える草葺き小屋のなかで、身を寄せあうようにした彼らの家族たちは、ひたすらにのぞみをかけて待っている――その姿もありありと見えるようであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふなばたに砕ける波と、はるかなる海鳴りと、浜でたたく浪の音が別々に聞き分けられた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、この広間の声々は海鳴りの音に似て来る。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今われが柱に倚りて見るものに、青青たらぬ木草なし、満潮どきの海鳴りのごと蝉の鳴く、八月に怪しく見ゆれ、みちのくの、板柳町岩木川流るるあたり、古りにたる某でらの境内の片隅にして、上向きに枝を皆上げ、葉のいまだ厚き銀杏の黄に変り、冬を示せる立姿、かの町びとの目よりまた、除きがたかる、寂しさの備る銀杏。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽はやがて急湍のように迫り、二つの音調は急流のように争いつつ、いつしか渾一に融合するうちに、いつともしれず大鼓の海鳴りの音が新しい根拠をもって轟いて来た。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸もできなくなるし、だいいち凄い海鳴りが耳もとに唸りまはつてゐるくせに、てんで海なんて見えやしないよ」　宿へ帰つて湯槽からあがると、当太郎は別人のやうに活気づいた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が落ちると、北風の悲鳴と海鳴りが、急にいちぢるしく唸りはじめてくるのだつた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳴りのとどろきわたる停車場で、茫然と汽車を待つことが苦しかつた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏も終りに近い荒天の日で、町にゐても海鳴りのなりつづく暗澹たる黄昏時のことであつたが、突然母が私を呼んで、貝が食べたいから海へ行つてとつてきてくれと命じた、あるひはからかつたのだ。",
              "citation": {
                "source": "をみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏も終りに近い荒天の日で、町にいても海鳴りのなり続く暗澹たる黄昏時のことであったが、突然母が私を呼んで、貝が食べたいから海へ行ってとって来てくれと命じた、或いはからかったのだ。",
              "citation": {
                "source": "おみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が傾くにつれて海鳴りが強くなる。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの土地で育ったころは一冬中海鳴りが町まできこえていたものだ。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の凋落が深かまると、海鳴りのひろい唸りが、日毎に由子の住居へも訪れはじめてくるのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝々の目覚めに、そして深夜の物思ひに、むしろ数々の愁ひよりも、由子の心を占めることが多かつた遥かな海鳴り。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠つた深夜の森林に蔓草の無数の繁みが這ひのぼり、乾草の香気がみなぎり、そして海鳴りの響のなかに牧歌に明ける平原があり、燃えるやうな雑沓の街と夜宴があつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳴りがこの坂上の小径にも遥かな響をつたえてゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、海岸が暫く静まったが、やがて、すさまじい海鳴りがすると共に、果して大鯨が奮迅の勢いで、波をきってやって来た。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた暫く海が平和であったが、やがて海鳴りがする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝風呂にはいって、あっさりと隠し化粧をすると、軽く朝げをすまして、例の町女房にしては、少し小意気だというみなり、お高祖頭巾に、顔をかくして、出かけてゆく先きは山ノ宿の方角だ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
