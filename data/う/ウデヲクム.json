    "definitions": [
      {
        "index": 1,
        "gloss": "to fold one's arms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "羽織の袖口両方が、胸にぐいと上るように両腕を組むと、身体に勢を入れて、つかつかと足を運んだ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してぶツつり下を向いて腕を組むと遂に彼れの心の底の蓋が口を開いた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何じゃな、汝は一体、」と大人は正面に腕を組む。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、思はず唇を噛んで腕を組むことがあつた。",
              "citation": {
                "source": "昔の歌留多",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅王には今浪花座で多見蔵のやつてゐるやうに車曳の条で、両臂を張り手先を肩に預けないやうに腕を組むで、「喰ひふとつた時平どんの尻こぶら、二つ三つ……」と左手の拳で右の二の腕を打つところがある。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宗先生、試みに、御自分の体を触ってごらんなさい」　女史は、自分の胸のあたりに両腕を組むようにしてそこらを撫でるのだった。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と思ふか思はない内に、妻は竹の落葉の上へ、唯、一蹴りに蹴倒された、（再、迸る如き嘲笑）盜人は靜かに兩腕を組むと、おれの姿へ眼をやつた。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と思うか思わない内に、妻は竹の落葉の上へ、ただ一蹴りに蹴倒された、（再び迸るごとき嘲笑）盗人は静かに両腕を組むと、おれの姿へ眼をやった。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを訊かれるのが、一ち、あっしにゃあつれえんで――」　と、闇太郎は、わざとらしくもなく、目を反らして、「何でも、父御、兄御の方々にはうらみのひとつもおっしゃりたいようでしたが、そこは、おたしなみで、何の御遺言もござんせんでしたよ」「う、うむ」　と、隠居は腕を組む。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腕を組むにゃァ及ばねえ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くても面白くなくても、黙つて眉に皺を寄せて、腕を組むか両手をポケットに突込み、断じて拍手もせず、断じて拳固も振はない覚悟でゐる必要はありません。",
              "citation": {
                "source": "新劇の観客諸君へ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三四人づつ腕を組むと、一層元気よく、通から通へと無茶苦茶に駈けて行くのでした。",
              "citation": {
                "source": "文化村を襲つた子供",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うーん」　部下思いの辻艇長は、眼の前にひろげられた月面図の上に腕を組むと、しきりにうなっていた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真がみずから独立して、活版と親しく腕を組むことで、その独特の領域をもつことはまさに、ガラスの壁よりもぎとられたる一片の視覚を通して、視覚みずからが集団的性格と、組織的機構の中に沈みゆくことを意味する。",
              "citation": {
                "source": "壁",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "信号手は腕を組むような格好をして、左の手で顎を支え、その肱を右の手の上に休めていたが、その態度はなにか期待しているような、また深く注意しているようなふうにみえたので、わたしも怪訝に思ってちょっと立ちどまった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "信号手",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と辞儀をしながらお園はなお何やら傍にいて尽きせぬ身の上の話でもしたいような様子であったが、言葉を絶やすと共にそのまま腕を組む種彦の様子に、女は所在なげにその後姿もしょんぼりと再び静かな跫音を梯子段の下に消してしまった。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（シャムラーエフと腕を組む）話してあげるわね、ハリコフでどんなに歓迎されたか……ポリーナ、カルタ机の上の蝋燭を消してから、ドールンといっしょに椅子を押して行く。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彦兵衛が、しっくり腕を組むと、藤吉は、珍しくにこにこして、「彦、一足だ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、当然負けることがわからずに、いや、仮にわかつていたとしても、それに自ら眼をおゝつて、たゞぎようこうをのみたのんだ、その軽挙もう動は、いくら恥じても恥じたりない」　そこで、彼は眼をつぶり、腕を組む。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "一万両の小判をこっちに捲き上げられたので、こんな事でもして溜飲を下げなきゃ、諦めきれないんだろう」「――」「だが五郎八を殺したのはどういうわけだ」　銭形平次は死骸の前に高々と腕を組むのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰を下ろして我にもあらず腕を組むと、「お茶を召しませ」　可愛らしいお稚児、紫の大振袖、精巧の袴、稚児輪を俯向けてソッとお茶をすすめているのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔が燒けてしまつては、搜る工夫もないが――」　と腕を組む外はなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "富士見の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仏壇の中にある、懐ろ鏡を、林彦三郎が持って行くはずはない」「なるほど」　平次が深々と腕を拱くと、それを真似たように、八五郎ももっともらしく腕を組むのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「佛壇の中にある、懷ろ鏡を、林彦三郎が持つて行く筈はない」「成程」　平次が深々と腕を拱くと、それを眞似たやうに、八五郎も尤もらしく腕を組むのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "懷ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、なんでも彼女に聞いて下さい」と博士はいい、腕を組むと家鴨の群のほうに顔を向けた。",
              "citation": {
                "source": "博士の目",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日までジャヴェルは、ナポレオンの二つの態度のうち決意を示す方の態度をしか、すなわち胸に両腕を組む態度をしか取ったことはなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の店を出たときから、恵子は川島と手をつなぐか腕を組むかしていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの日々になんの当てもない自分たち、という心地良さが、彼と腕を組むことによって増幅された。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしあなたがどうしたって腕を組む相手が要るんだったら、ド・ラスチニャックさんの腕にすがりなさい」　子爵夫人は微笑みながらウージェーヌを見た。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
