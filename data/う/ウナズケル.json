[
  {
    "uuid": "d960f5a0-23d9-542c-815c-040069082574",
    "entry": "頷ける",
    "reading": {
      "primary": "うなずける",
      "alternatives": [
        "うなづける"
      ],
      "is_heteronym": false
    },
    "grammar": {
