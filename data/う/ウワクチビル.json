        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "又それがために、彼の上唇の辺は見るからに不平の多い人間である。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上唇を弾丸で横にかすり取られた者がある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　軍医は、上唇を横にかすり取られた幼なげな男に、こうきいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少年は、もう一度、上唇のさきが無くなった口を哀れげに拡げた、「こんなにおとなしい無抵抗な者を殺してもいゝんですか！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげもじゃの顎と、上唇をあつかましい笑いにほころばせながら。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足は忘れたか投出した、腰がなくば暖簾を立てたように畳まれそうな、年紀がそれでいて二十二三、口をあんぐりやった上唇で巻込めよう、鼻の低さ、出額。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻は尋常で、唇は少し厚く、笑うと上唇がきゅっとまくれあがる。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い上唇がこころもち上へめくれあがり、淺黒い頬をしてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアのわきの壁に、兩腕をうしろへまはしてよりかかり、めくれあがつた上唇をことさらにきゆつと尖らせて言ふのであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「……ド……毒婦ッ……」　青年はいつの間にか上唇を噛み破っていた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇にしては少し顔がそぐわないから何にしよう、何に肖ているだろう、この赤い鼻の高いのに、さきの方が少し垂れさがって、上唇におっかぶさってる工合といったらない、魚より獣よりむしろ鳥の嘴によく肖ている。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭角的な輪廓、よく通った鼻筋、広い額、が、その冷たさに触れてかえって心が温まると思われる様な感じを起させるのだったが、唯一つ、少し上にむくれている上唇が、可憐に見えた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "低く小さい、鼻よりも、上唇一、二センチ高く腫れあがり、別段、お岩様を気にかけず、昨夜と同じに熟睡うまそう、寝顔つくづく見れば、まごうかたなき善人、ひるやかましき、これも仏性の愚妻の一人であった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　としみじみいうのを、呆れた顔して、聞き澄ました、奴は上唇を舌で甞め、眦を下げて哄々とふき出し。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頤細く、顔｜円く、大きさ過ぎたる鼻の下に、賤しげなる八字髭の上唇を蔽わんばかり、濃く茂れるを貯えたるが、面との配合を過れり。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足は忘れたか投出した、腰がなくば暖簾を立てたやうに畳まれさうな、年紀が其で居て二十二三、口をあんぐりやつた上唇で巻込めやう、鼻の低さ、出額。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇にしては少し顔がそぐはないから何にしやう、何に肖て居るだらう、この赤い鼻の高いのに、さきの方が少し垂れさがつて、上唇におつかぶさつてる工合といつたらない、魚より獣より寧ろ鳥の嘴によく肖て居る、雀か、山雀か、さうでもない。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻は峰だけ特に目立ち、頬骨の下はげっそり落ちて、濃い髭は椀の上に植え付けられたように上唇に盛り上っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒ってでもいるのかと気を付けてみますと、上唇を舌の先で嘗めて、薄く笑っているのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいてみると、薄い上唇の真中に、剥げ残った口紅が暗い赤さに乾いていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあんと、京吉は上唇の裏に舌を当てて、「じゃ、そいつ、セントルイスにいるのか」「うん……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには赤い舌までが飛び出して、上唇や下唇をなめずりまわし、又はペロリと長く垂れ下ったりします。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "刷毛でつけた頬紅を、脱脂綿でまたほのぼのとふきとり、上唇の濃いルージュを、下唇に移して、油性のクリームで光らせる。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "橙の髪に、青白い顔はすさまじい傷痕で醜く変じており、その傷に引っ張られて上唇の外側がめくれ上がって、頬はまるでブルドッグ、両の目は突き抜けるような黒、髪の色と不思議な対比を見せていて、どの特徴もそこいらの乞食とは一線を画している。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん」「どこへ往ってらしたのです」「うん」「ほんとにどこにいらしたのです、皆さんが心配してらっしゃるのよ、ほんとにどこにいらしたのです」　広巳は上唇をちょっと顫わすようにした。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「品川ですね」　広巳はまた上唇を顫わしたばかりで何も云わなかった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜は、品川ですか」　広巳はまた上唇を顫わしたが、それはいくらか笑いになった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして厚い上唇は、恐悦至極といった様子で、それより一層厚い下唇の上にのっかっている。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、みつくちというんじゃありませんが、上唇の真中が、ちょっと歯茎を覗かせて反っているのを隠すためです。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻が丸くてこんもり高く、薄い下唇が上唇より少し突き出ている。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
