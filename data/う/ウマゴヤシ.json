        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "花のき村の入り口のあたりは、すかんぽやうまごやしの生えた緑の野原で、子供や牛が遊んでおりました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまごやしにだって、可憐な白い花が咲くって事を、先生は知らないのかしら……。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くつづいた堤のうまごやしの花は、兵隊のように皆地べたにしゃがんでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまごやしの花がいっぱいだし、ピクニックをするに恰好の場所である。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くつゞいた堤のうまごやしの花は、兵隊のように、皆地びたにしゃがんでいる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまごやしにだって可憐な白い花が咲くって事を、先生は知らないのかしら……。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れ路にはうまごやしが咲いてゐた。",
              "citation": {
                "source": "展望",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂いのいいうまごやしが沢山まじった、毛氈を敷いたような青草が、その崖と海との狭い間を蔽うていました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、その上に（でもペガッサスは大層たべものがやかましい方でしたから）、たいへんおいしいうまごやしの花でもあると、ちょっとだけ食べてみたりしました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、喉の渇きがなおると、うまごやしの甘い花を少しばかりむしって、お上品にたべてみました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の虫はまたむらさきうまごやしの若草を草刈り手が何んにも刈るものを見当らない程すつかり食べてしまふ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
