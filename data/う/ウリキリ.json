          ],
          "literary": [
            {
              "text": "「あゝ、あゝ、まるで売り切りの牛か馬のようだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の気持ちでは、出来るなら、売り切りにしたくねえんでね。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は、あの半分だけ借りて置いて、一応は伜と相談してから売り切りにしたいんですがね。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「売り切りじゃねえですよ。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はこうして半分だけ借りて行っても、すぐ又はあ、伜から金が要るって言って来れば、残りの半分を借りて、売り切りになるかも知れませんで。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
