    "definitions": [
      {
        "index": 1,
        "gloss": "untonsured (monk or priest or nun)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは有髪の僧であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有髪の僧は石像の前で静かに地上へひれ伏したが、何やら熱心に祈り出した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈っている有髪の僧を見ると、ふと若者は足を止めた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうぞお救いくださいまし」　有髪の僧の祈りの中から、こういう言葉が聞き取れた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い熱心な祈りを終えると、有髪の僧は立ち上がった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞしばらくお待ちください」「はい、ご用でございますかな」「この教団のお方と見て、お願いしたいことがございます」「私の力で出来ますことなら、何んなとご用に立ちましょう」有髪の僧は引き返した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうしてそれをとげるには、ここを出なければなりません」「では、お出掛けなさりませ」「私を捉らえて放そうとしない、神秘の力をどうしましょう」　有髪の僧は返辞をしない。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「他でもない懺悔です」　有髪の僧はこう云って、庄三郎を凝視した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　有髪の僧の物語りは庄三郎には驚異であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼には有髪の僧の物語り振りが好もしかった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「そこであなたにお訊ねします」有髪の僧は庄三郎へ云った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって罪を犯すことも一番多いのでございます」　有髪の僧の言葉には犯し難い自信がこもっていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……『真鍮の城の眷族ども』に迫害されるという事も、こういう意味から云う時は、肉身刑罰の一つとして甘受すべきものかもしれません」　次第に有髪の僧の声は、悲哀の調子を帯びて来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教団の教主たる光明優婆塞の容貌によく似ていると云われている、この石像の容貌と、有髪の僧の容貌とが怪しいまでに似ていたからであった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああそれではこの人は、光明優婆塞であるまいか」庄三郎は吃驚して、尚よく自分の前にいる有髪の僧を見ようとした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有髪の僧は階段を下の方へ下りて行った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが有髪だということだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有髪とあってはそうでもねえ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "法水は庵主盤得尼の切髪を見て、この教団が有髪の尼僧団なのを知った。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって頭に髪があるじゃないか」「だから私は有髪の僧じゃ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有髪の尼僧の一団なのである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二　火を吹き消した有髪の老尼は「鯱丸」とまたも命令的に云った。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有髪の老尼は何者であろう？",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挺の山駕籠へ高蔵尼を乗せ、それを囲んで有髪の尼達が、秩父連山を縦断して三浦三崎の方へ出かけたのである。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "居は気を移すで、寺の様な家に住めば、粕谷の墓守時には有髪の僧の気もちがせぬでも無い。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、さうした修験道の行儀喧しい時代以前に、呪術に達したから、山伏の形を以て、自由に土地を求めて歩いた時代を考へて見ると、無頼の徒・山伏・傭兵・らつぱ・かぶき者・芸能・唱門師の有髪の者・千秋万歳、――かうした自在な形で、移り歩いたらしい。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の習慣から『奥様』と尊敬められて居る斯の有髪の尼は、昔者として多少教育もあり、都会の生活も万更知らないでも無いらしい口の利き振であつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と斯の有髪の尼は独語のやうに唱へて居た。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "松女がその後有髪の尼として、清浄の生活を継続し、良人や主馬之進をとむらいながら、主税夫婦やお葉によって孝養されたということや、お葉が良縁を求めながら、その優しい心持から、藤八猿を可愛がり、いつまでも手放さなかったというようなことは、あえて贅言する必要はあるまい。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早還暦もすませ、何も彼も当守淡路守に任せ切りで、風月を友に暮して居りますが、有髪の法体とも思えぬ案外の元気で、半白の鬢にも血色の良い顔にも何んとなく返り咲く若い血潮が漲って居ります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
