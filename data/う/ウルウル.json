        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「teary-eyed」である。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「teary-eyed」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「teary-eyed」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "teary-eyed」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雲のわだつみ洞なして、　　青野うるうる川湧けば、あなや春日のおん帯と、　　もろびと立ちてをろがみぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてにでてみると、まわりの山は、みんなたったいまできたばかりのようにうるうるもりあがって、まっ青なそらのしたにならんでいました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマン丸い、うるうるした瞳と新鮮な頬の輝やきを曇らせて、はかなくも白け渡った投影を仄めかす。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてにでてみると、まはりの山は、みんなたつたいまできたばかりのやうにうるうるもりあがつて、まつ青なそらのしたにならんでゐました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、ウミガメフーミのところまでたどりつくと、大きな目をうるうるさせて見てくるわりに、ものも言わない。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
