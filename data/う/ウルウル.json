          "literary": [
            {
              "text": "雲のわだつみ洞なして、　　青野うるうる川湧けば、あなや春日のおん帯と、　　もろびと立ちてをろがみぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてにでてみると、まわりの山は、みんなたったいまできたばかりのようにうるうるもりあがって、まっ青なそらのしたにならんでいました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマン丸い、うるうるした瞳と新鮮な頬の輝やきを曇らせて、はかなくも白け渡った投影を仄めかす。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてにでてみると、まはりの山は、みんなたつたいまできたばかりのやうにうるうるもりあがつて、まつ青なそらのしたにならんでゐました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、ウミガメフーミのところまでたどりつくと、大きな目をうるうるさせて見てくるわりに、ものも言わない。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            }
          ]
        }
