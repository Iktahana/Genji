        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "第一、荷嵩の割合に金目が揚がり、商品も小綺麗な代物なので、河岸の中でも羨まれる魚問屋の一軒だった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前仲町で下りたのは――晩の御馳走……より前に、名の蛤町、大島町かけて、魚問屋の活船に泳ぐ活きた鯛を、案内者が見せようといふのであつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "代々魚問屋で相当な物持ちだったが、父親の代に没落した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州沖はどこかと海の彼方をじっと見つめては歯をくいしばり、黙々として骨身惜しまず働いている姿を変ってると思ったか、主人が訊ねて、もとは魚問屋の坊ぼんであると分ると、可哀想だと、帳場に使ってくれた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の醸造家を旦那に持ち、当時日本橋に在った魚河岸の魚問屋の若旦那を客情夫にしていて暮しに何の不自由もなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも魚問屋で右が醤油を造り、左が酒を造つた。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は川に近い通り――大きな魚問屋があって、鮭だの鱈だの一杯に昔並べられてあったところ今はさびしく荒凉とした通りになっているところを通って、四日市の通り近くまで行って、そしてまた細い巷路に右に入って行って見た。",
              "citation": {
                "source": "日本橋附近",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二は静岡の魚問屋の坊ちゃんで、倉の陰で子守相手に「塵かくし」ばかり仕て居たほど気の弱い頭の鉢の開いた様な子だったが十九の年、中学を出ると一緒に、良吉の家へ養子になった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人というのは、魚問屋の帳場に勤めていて、あまり高給を頂戴している方ではなかった。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "町といっても家数の少ない小さなさびしい町で、魚問屋や、呉服屋や、荒物屋や、いろんな商店がありましたが、いちばん魚問屋が多くあって、町全体が魚臭い空気に包まれていました。",
              "citation": {
                "source": "けしの圃",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと、海辺の町へ着いて、魚問屋や、漁師の家へいって聞いてみましたけれど、だれも、昨夜、雪の上に火を焚いていたというものを知りませんでした。",
              "citation": {
                "source": "大きなかに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを河野磐州自身のファミリーヒストリーについてみるなら、純封建的「豪族」河野氏の世系は、磐州の祖父の代にいたって、地主であり郷士であり、名目上の禄百石と五人口を給さるる藩士でさえあって、しかも呉服太物業・魚問屋・酒屋を経営していた。",
              "citation": {
                "source": "加波山",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇村先生は淡水魚問屋の離れ家を借り、私達は自炊していた。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚問屋の娘の加代もその中にいる。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝、この淡水魚問屋の突堤を目ざして、漁船が多く集って来る。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚問屋であり、資産家である吉見の主人は、素子とその兄妹とを生んで亡くなった妻の妹を、現在妻として暮していた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三女のフサエは魚問屋の息子に望まれて半ばさらわれるような形で、姉のカヤノよりも先に嫁入ったのであったが、一年もたたぬ間に呆気なく死んでしまった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那衆というのは米問屋の田丸屋益造、呉服太物糸綿商の折屋伝内、酒問屋の水尾屋割助、魚問屋、乾物問屋、……と、いやこれは、次にいる両替商の持木成助をごらんあれ、なんと成木持助でござるぞ、保良郡の豪家たる権右衛門殿のむすめ婿になりそこね、婚礼の席から逃亡した贋金作り、闇七こと成木持助でござる。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔この沿岸に何千万という漁民がいた頃の魚問屋の妻女のなれの果だと役場員がいい添えた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、その事に就ては、云うな、云ってくれるな』『けれど、今度お上洛りになる沖田様も伏原様も山口様も、皆、御浪人のうえに、日頃のお暮しとて、私たちよりもっと貧しいお方さえあるのに』『伏原も小網町の魚問屋に身寄があり、山口も妻の里方がどうかなる家柄だからだ。",
              "citation": {
                "source": "死んだ千鳥",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、弟の張順は足を洗って江州で魚問屋に変り、張横は依然この界隈で、不景気｜面な板子稼業にぼやいて、こそこそ悪さをつづけていたところだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい、江州へおいでなさいましたら、あっしが手紙を付けますから、魚問屋をやっている弟の奴にも、いちど会ってやっておくんなさいまし」　懺悔とともに、張が言った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの肌の白い魚問屋の主人。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまったとは」「彼が魚問屋の張順なら、その実兄の張横から私は手紙をもらっている！",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「張順の家は」　と考えてみたが、魚問屋の忙しい身だし、おそらくこんな上日和では江の上か城外の市場だろう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、茶道は、もう数年前に亡くなっている人だが、この町の武野紹鴎について、一通りは学んでもい、その方では、この町の大きな魚問屋でまた、十人衆の一人でもある千宗易と、同門下であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
