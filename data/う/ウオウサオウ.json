[
  {
    "uuid": "d0b9e236-4914-5104-99e8-35f1bb16765c",
    "entry": "右往左往",
    "reading": {
      "primary": "うおうさおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
