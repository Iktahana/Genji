        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "私は毎日うまい話について考えている。",
              "source": "幻辞"
            },
            {
              "text": "うまい話という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はうまい話の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはうまい話が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "うまい話を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはうまい話について学習した。",
              "source": "幻辞"
            },
            {
              "text": "うまい話の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はうまい話の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではうまい話が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "うまい話という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にうまい話という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではうまい話についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "うまい話を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとうまい話は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "うまい話について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではうまい話が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にうまい話は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりうまい話の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "うまい話は様々な場面で使われる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "釣られて、「――では、何かうまい話でも……？",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎次は心のうちで、「その日のうちに奉公口が定まって、その上にこんな御馳走が食べられるとは、こんなうまい話はない。",
              "citation": {
                "source": "三人兄弟",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、そんなうまい話があるんですか。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉永だってわかるもんか、初めっからあすこにいたからには、うまい話なら一丁のっていない筈はない。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、あいた口に牡丹餅よりうまい話だろう。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮もついていれば、うまい話だがそうはいかぬ。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "編物の仕事を彼の手で取次いでもらへば、編賃がほとんど倍額になるといふあのうまい話なのです。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……奥さんの能率給を別にして、利益配当は、山分けです」「そんなうまい話つてあるかしら！",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もつとうまい話をしませうか？",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮もついてゐれば、うまい話だがさうはいかぬ。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、一貫目四十四銭八厘に売れるとすれば、いかに金の価値が低くなった現今においても百個三銭五厘当時に比べ、随分うまい話じゃないか。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせお金持ちのところの養子だから、一から十までうまい話にはゆかないとは思っていたけれど。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし法政にとってはこれは大変うまい話なので、学長から会計主任まで相談して、待遇案も出来上がり、野上さんがその案をもって先生を訪問された。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無料で一晩中酒が呑めるんだから、こんなうまい話はない。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなうまい話はまたとあるまい。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あんまり棚からボタ餅のうまい話に、なんだか狐につままれたような変な気がして、なんと返事していいかまごついた。",
              "citation": {
                "source": "押しかけ女房",
                "author": "伊藤永之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボク、うまい話をしてやる」　五人が広間へ降りて行ってみると、森川夫人が、煖炉のそばの安楽椅子に沈み込んで、ひとりで泣いていた。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そんなうまい話はありつこないと自分を打ちけす。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "房代　そんなうまい話なら柳子さんにしたらどう？",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢形の」　萬七はあまりのうまい話に膽を潰しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "母娘巡禮",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな時代が早く来るとよいと立原は言ったが、自分でも半信半疑の状態で、そんなうまい話はあるまいというふうだった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなうまい話はないし、金五両という、夢のような大金を貰ったので、若者たちはみなのぼせあがった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「街」の住人たちはひっくるめて、うまい話、というものを信じない。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらはうまい話にとびついたため、これまでに幾たびとなく裏切られた覚えがある。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらにとって、この世にうまい話があるなどとは、とうてい信じられなくなっていたのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ」「ビールを飲ませて、世間を酔っ払わせて、うまい話ですな」「本当に」「何うです？",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい話じゃありませんか。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで五千円なら、うまい話だから、しょうちしたんです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五、六年頃のことですが、出物で二十余枚、一枚三十円で買ったその翌日、仲買の外人が来て五十円ずつに買うという、こんなうまい話はないとすぐに売りましたが、今では一枚三百円以上ですから結局大損をしたわけですと、これは明治四十年頃の話。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
