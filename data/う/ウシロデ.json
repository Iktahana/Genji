      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "putting one's hands behind one's back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが友だちと二人で悪漢の銀行破りの現場に虜になって後ろ手に縛られていながら、巧みにナイフを使って火災報知器の導線を短絡させて消防隊を呼び寄せるが、火の手が見えないのでせっかく来た消防が引き上げてしまう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の後ろ手からは甲府の方へ走る山がぼうツとあたまが見えないおほ牛の脊のやうに横たはつて、その脊の骨ぐみだけは薄くしめツぽい輪廓が附いてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは後ろ手で戸を閉める。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、男は礼儀正しい所作で立ち上がると、我々にお辞儀をし、部屋の奥隅にある扉から出て行き、後ろ手に閉めてしまった。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が入室すると、うしろから娘も滑り込み、後ろ手に扉の錠をかける。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして後ろ手に扉を閉めながらもう一言。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度こんなことがあったらのがしはしません」　島田家の物置から、ほんものの甲刑事が後ろ手にしばられて、猿轡をはめられて発見されたという報告が、溝川署へついたのは、それから五分もたたぬうちでありました。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はみな色の白い、美しい者ばかりで、身にはいろいろの色彩のある美服を着けていたが、いずれも後ろ手にくくり上げられて恐るおそるに頭を垂れてひざまずくと、石上の男はかれらを一人ずつ自分の前に召し出して、下衣を剥がせて地にひき伏せ、鞭をあげて打ち据えるのである。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "心げさう霜月ひと日、朝戸出に、小野の木守は、※高膚の阿利襪樹の根に散りぼひし實のあり數に驚きて、つと立ちかへり、目無し籠を後ろ手にふた行くごとく、ただ目に人を見し時は、なよび姿の耀ひわたる清らさに、戀は退りて、ふくろ心の奧ぶかに隱るとせしが、落ちゐて、やがて花やかに穗に現はれぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ手に縛り上げられた静脈のふくれ上った拳にはガラスの破片が突き刺さって鮮血で染まっていた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子に映つた鬼婆、振揚げた出刃庖丁、後ろ手にくくし上げられた娘、それから老女に化けた怪しい猫の幻影などは、夢のやうな恐怖を誘ひました。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ手に縛られているにもかかわらず、彼は膝の上に崩れ落ち、顔を土埃の中に打ちつけて、人の心を震わせるような、しゃがれた声で自責の念に駆られて、しばらく嗚咽していた。",
              "citation": {
                "source": "停車場にて",
                "author": "AT A RAILWAY STATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "この邊の川ぶちから見返ると、白倉山の後ろ手が、そこも岩だらけのあひだにこうえふしてゐるのが見える。",
              "citation": {
                "source": "鹽原日記",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "清子は久しぶりに後ろ手に組みながら、娘時代の友人たちを思い浮べた。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて、我がチェレ※ークの眼前へ、後ろ手にいましめられて、数名の若者に引つ立てられた、見るも痛ましい教父の姿が現はれた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズッコケかかった昼夜帯を後ろ手で抱え上げ抱え上げ滅法矢鱈にお辞儀を返した。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝吉は後ろ手に障子をしめ、「服部平四郎」と声をかけた。",
              "citation": {
                "source": "伝吉の敵打ち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時はまた、寒い北風の吹く中で井戸端の立木に内儀さんは後ろ手にゆはへつけられてゐました。",
              "citation": {
                "source": "白痴の母",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の下に白髪垂れたる後ろ手の母を見るなり山ほととぎす　皐月が咲き蜜柑の花が咲くやうになると人里近くにも山ほととぎすが出て来てしきりに啼く。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは木の下に白髪をかき垂れ後ろ手をして立つてゐる姿だが、不思議なこともあるものだ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は後ろ手に縛られていた。",
              "citation": {
                "source": "術数",
                "author": "DIPLOMACY",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い肌をあらわに後ろ手に縛し上げられて、蝦のように二重になってかがんでいるのだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "七瀬は、部屋の中へ入って、後ろ手に襖を閉めた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "将曹は、襖を開けて、入りながら「只今、言上」　と、坐って、後ろ手に、襖を閉めた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ手に閉めて、二人の前へ坐ると「何か、証拠の品が、あると申されるか」「ござります――これなる――」　仙波が、膝の上で、包みかけていた箱を、差出した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、益満が、綱手の腰へ、後ろ手に手をかけて、引寄せると、よろめいて、もたれかかった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しまつたと思つたときには、もうきり／＼と、後ろ手にしばり上げられてゐました。",
              "citation": {
                "source": "ラマ塔の秘密",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ手を負はせられつゝ七時雨　　　しぐれの涙掩ふ袖もなし　この奥州の寒地に於ける翁が獄裡生活の一片を、自叙伝の自筆草稿より抜抄す。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボウドレエルに似た像が荒い苦悶を食ひしばり、手を後ろ手に縛られて煤びた壁に吊された、その足もとの横長い粗木づくりの腰掛に。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は少年を捻じ伏せて後ろ手に帯で縛り上げてしまった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
