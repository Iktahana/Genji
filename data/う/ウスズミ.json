        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私の習慣として、手紙は読んで了へば、大概棄てるし、殊に訃報は直ちに破くのであるが、此度も私は読み終るや破かうとしたが、ハツと思つて思ひとゞまり、薄墨色のインクで印刷された端書をもう一度マジ／＼と見直した。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸助五六歳のころ妻の百合が里帰りして貰いきしその時｜粘りつけしまま十年余の月日｜経ち今は薄墨塗りしようなり、今宵は風なく波音聞こえず。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢさんは行止りに突きあたるまで調べ盡さうといふ息込みで、煤けた紙に殘つてゐる薄墨の筆のあとを根好く辿つて行つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのほかに薄墨草紙といふ草雙紙を貸したことはなかつたかね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "草雙紙は、かの薄墨草紙で、酷い主人の手討に逢つて、杜若の咲く古池に沈められたお文といふ腰元の魂が、奥方のまへに形をあらはしてその恨みを訴へるといふところで、その幽靈がもの凄く描いてあつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "道にさし出た、松の梢には、紫の藤かゝつて、どんよりした遠山のみどりを分けた遅桜は、薄墨色に濃く咲いて、然も散敷いた花弁は、散かさなつて根をこんもりと包むで、薄紅い。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の山々は、次第次第に、薄墨を合せ、鼠を濃くし、紺を流し、峰が漆を刷く。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の空は夕日の余光が水のように冴えて、山々は薄墨の色にぼけ、蒼い煙が谷や森の裾に浮いています、なんだかうら悲しくなりました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴんと張り拡げられた薄墨いろの肉翅のまん中で、毛の胴は異様に蠢き、小鳥のような足は宙を蹴る。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日は八分通り暮れ、園の奥や、墻壁の腰に薄墨を溶かしたような闇がたゆたう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の婆に挟まれ、一人に導かれて、薄墨の絵のように、潜門を連れ出さるる時、夫人の姿は後ざまに反って、肩へ顔をつけて、振返ってあとを見たが、名残惜しそうであわれであった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の待合のその羽目に、薄墨でぼかしたように、ふらふらと、一所に歩行いて附いて来る影法師。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄墨色の河岸を伝って、雲より黒い線路に響いた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハタと止めば、其の空の破れた處へ、むら／＼と又一重冷い雲が累りかゝつて、薄墨色に縫合はせる、と風さへ、そよとのもの音も、蜜蝋を以て固く封じた如く、乾坤寂と成る。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『汝、掠奪者よ』かう薄墨にかいた端書が来たとき、私は実に熱鉄をつかんだ様な心持がしました。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "『汝、掠奪者よ』かう薄墨にかいた端書が來たとき、私は實に熱鐵をつかんだ樣な心持がしました。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきは雨脚が繁くって、まるで、薄墨で刷いたよう、堤防だの、石垣だの、蛇籠だの、中洲に草の生えた処だのが、点々、あちらこちらに黒ずんでいて、それで湿っぽくって、暗かったから見えなかったが、少し晴れて来たから、ものの濡れたのが皆見える。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄墨でな、ひょろりと掌を一ツ圧しました、これが人間でござりません。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄墨、鬱金、またその浅葱と言ったような、どの桜も、皆ぽっとりとして曇って、暗い紫を帯びていた。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "連り亘る山々の薄墨の影の消えそうなのが、霧の中に縁を繞らす、湖は、一面の大なる銀盤である。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをの、透かし透かし、山際に附着いて、薄墨引いた草の上を、跫音を盗んで引返しましたげな。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋杭ももう痩せて――潮入りの小川の、なだらかにのんびりと薄墨色して、瀬は愚か、流れるほどは揺れもしないのに、水に映る影は弱って、倒に宿る蘆の葉とともに蹌踉する。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しさは絵にもかかれず暮の秋あきらめは紋切形の露の世や絵を見れば絵も薄墨や秋の花　十二日、青山墓地にて埋葬のこと終る。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菰を厚く巻いてやるプールの中へ、差し込む薄日に短い鰭と尾を忙しく動かすと薄墨の肌からあたたかい金爛の光が眼を射て、不恰好なほどにも丸く肥えて愛くるしい魚の胴が遅々として進む。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴんと張り拡げられた薄墨いろの肉翅のまん中で、毛の胴は異様に蠢き、小鳥のやうな足は宙を蹴る。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半開の眼が海の潮の一片のやうなうるみを籠めて長く引かれ、素直にそれに添つた薄墨の眉毛の情深さ。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨戸一枚繰り開けたるところより首をさし出して窺ふに、薄墨色の雲の底に有るか無きかの星影の見えたるなど、猶おぼつか無くは思はるれど望みを断つべくもあらぬさまとなりぬ。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この造成地の反対の端をくぎっている、まだ裸になっていない山のむこう側から、うすずみ色の雲がひろがりはじめ、彼らの頭上の白い雲を侵食しようとしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんぽぽの穂うすずみ色の梅雨空に、屋根の上から、ふわふわとたんぽぽの穂が白く散る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空にぱっとうすずみいろの煙が、ハンカチの包みをほおりだしたようにあらわれる。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
