    "definitions": [
      {
        "index": 1,
        "gloss": "fleeting life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "斯かる時芸術家が、否応なしに逐ひやられるのは風物の方へであり、世間がセチ辛くなればなる程、詩の方は却て浮世離れがして来るなぞといふことも、ありさうでないことではない。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかく浮世は辛いといふことは屡々浮世は辛くなければならぬといふやうにして発音されるのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世とて、辛くなくてすめば辛くない方がよいのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰へや歯に食ひあてし海苔の砂この秋は何で年よる雲に鳥蝙蝠も出でよ浮世の花に鳥秋近き心の寄や四畳半　こうした句の詩情しているものは、実に純粋のリリシズムであり、心の沁々とした咏嘆である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の江戸時代の日本人は、理髪店で浮世話や将棋をしながら、殆んど丸一日を暮して居た。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼く片親の手一つで育ってあまり豊かでない生活が朧げに胸にしみ浮世の木枯しはもう周囲に迫っていたから、何かの刺戟はすぐに訳のわからぬ悲しみを誘うたのだ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ学生の中にはずいぶん不真面目らしい茶目や怠け者も居て一体に何となく浮世臭い匂がこの教室全体に漂っているのを感じた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そ何がはかないと云っても、浮世の人の胸の奥底に潜んだまま長い長い年月を重ねて終にその人の冷たい亡骸と共に葬られてしまって、かつて光にふれずに消えてしまう希望程はかないものがあろうか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の人はいかなる眼で彼を見るであろうか。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の花の香もせぬ常闇の国に永劫生きて、ただ名ばかりに生きていなければならぬかと思うと、何とも知れぬ恐ろしさにからだがすくむ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "背景は私の好みで、北斎の浮世絵、富嶽三十六景中の傑作「電光の富士」を用いた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の欲を金に集めて、十五｜年がほどの足掻きかたとては、人には赤鬼と仇名を負せられて、五十に足らぬ生涯のほどを死灰のやうに終りたる、それが餘波の幾万金、今の玉村恭助ぬしは、其與四｜郎が聟なりけり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思ふ事、叶はねばこそ浮世とは、よく諦めた無理なこと」なのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「いき」のうちの「諦め」したがって「無関心」は、世智辛い、つれない浮世の洗練を経てすっきりと垢抜した心、現実に対する独断的な執着を離れた瀟洒として未練のない恬淡無碍の心である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋な浮世を恋ゆえに野暮にくらすも心から」というときも、恋の現実的必然性と、「いき」の超越的可能性との対峙が明示されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "式亭三馬の『浮世風呂』第二編巻之上で、染色に関して、江戸の女と上方の女との間に次の問答がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすもののモティーフはしばしば浮世絵にも見られる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「垢抜」した湯上り姿は浮世絵にも多い画面である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浮世風呂』に「細くて、お綺麗で、意気で」という形容詞の一聯がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世絵師も種々の方法によって脛を露出させている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきに「いき」な身振または表情を述べた時に、しばしば浮世絵の例を引くことができたのはそのためである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝最うきよろ／＼し出した、其で二足三足づゝ、前後左右を、ばた／＼と行つたり、来たり……　慌しく成つて来た。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　　十――水のすぐれ覚ゆるは、西天竺の白鷺池、じんじやうきよゆうにすみわたる、昆明池の水の色、行末久しく清むとかや。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちござくら、そばによりそう、うばざくら、ともにうきよの、はるをこそおしめ」「みだれなと、いとあさましく、くくられし、はぎなぞに、みを、よそえては、なく」「少年の恋は、禿頭のように捕えにくい、ツルツルして毛が無いから」　なぞいうのがある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "親も兒も妻も妹も持たざれば、　　　闇のうきよにちなみもあらず。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどりごゆたかにねむるみどりごは、　　　　　うきよの外の夢を見て、母のひざをば極樂の、　　　　　たまのうてなと思ふらむ。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい「人生は苦だ」とか、「うきよは苦悩の巷」だということは、たしかに真理です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いでや是より糊口的文学の道をかへてうきよを十露盤の玉の汗に商ひといふことはじめばや。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こゝろは天地の誠を抱きて、身は一代の狂人になりも終らば、人に益なくうきよに功なく、清濁いづれをまされりとせんや。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿六人、みんなおもしろい、あゝおもしろのうきよかな、蛙がゲロ／＼人間ウロ／＼。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
