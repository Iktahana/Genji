        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "左手をひくこと、右面をうつ場合のごとし――。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうめんどうなむつかしい事がらを説くには、「詩」の助けをかりなければならない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが器械仕掛けでメトロノームのようにきちょうめんに鳴るのではちっとも涼しくはないであろう。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうなれば、東京の地図が一枚で足りないというめんどうぐらいは我慢してもだれも小言はいわないであろう。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちょうめんにちゃんと曲がり角を曲がってあるくのと、その芝生の上を踏みにじって行くのとで、歩く距離にすれば三尺とはちがわない。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目と鼻の前だって、一旦｜家へ帰ってからだと、河岸の鮨は立食しても、座敷にはきちょうめんな、極りの堅いお孝さん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝月残る木槿が咲いてゐるながれ　島へ渡しの、氷や菜葉や郵便や・氷屋ができて夾竹桃の赤や白や・落ちてきて米つく音の水がながれる・近道のいちはやく山萩の花・水は岩からお盆のそうめん冷やしてある　　行乞雑感（一）　八月十一日晴、暑かつたが気持は軽かつた、仙崎町行乞、そして滞在、新相客は伊佐で同宿の老遍路。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは魚のやうにつめたくなつて目からさうめんの涙をたらし情慾のみたされない　いつでも陰氣な悶えをかんずるああこの噛みついてくる蠍のやうにどこをまたどこへと暗愁はのたくり行くか。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬屋の広告は構わんが、しらきちょうめんな人間に向って罪の子とは何んだい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田、島崎両氏からはしやんと断りの葉書が来た、この二人はいつもきちやうめんだと皆で話し合つた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢にきちょうめんに横に並んだ枝を出して白い蕾をつけて葉は無い。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白百合の五つ紋の黒紋付できちょうめんに坐ったアンリー。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、言ったあと、涼み話の仲間入りをしようともせず、這うようにしてあがった畳の上へごろりと転がると、君枝がつくって置いた冷しそうめんも食べずに、そのまま鼾だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝転んでいる他吉の上へ蚊帳を釣りながら、よっぽど起して、そうめんを一緒に食べながら、次郎のことを言い、プラネタリュウムの話もしようと思ったが、ぐんなりして鼾をかいている他吉の寝顔を見ると、起す気にはなれなんだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ理論で裏づけられたヒステリック感傷は治療がいっそうめんどうなようである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これだと思ってるが、やらないのか」「やるもんか、俺は、堅気の商人だ、そんなへんなことは知らねえや」「しかし」また何か揮る恰好をして、「これは判ってるだろうな、何を揮るか」「知るものか、きちょうめんの商人だ、賽ころなんか知るものか」　松山は大声に笑った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ旅の事で、何を極って、きちょうめんにしなければならんというでもなし、一向気取らない女主人で、夜も坊ちゃんを真中へ、一ツ蚊帳に寝るほどだから、お茶漬をさらさらで、じゃかじゃかと洗ってしまえば埒は明く。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来の上で、と辞して肯ぜぬのを、平にと納めさすと、きちょうめんに、硯に直って、ごしごしと墨をあたって、席書をするように、受取を――　　記一金……円也「ま、ま、摩……耶の字？",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きちょうめんにすわることなんぞははあねえもんだから。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きちょうめんに正座して、父は例の皮表紙の懐中手帳を取り出して、かねてからの不審の点を、からんだような言い振りで問いつめて行った。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が古藤を連れて横浜に行ったのも、仮病をつかって宿屋に引きこもったのも、実をいうと船商売をする人には珍しい厳格なこの永田に会うめんどうを避けるためだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして隣の部屋に気を配っていながらも、葉子は部屋のすみにきちょうめんに折りたたんである新聞を見ると、日本に帰ってからまだ新聞というものに目を通さなかったのを思い出して、手に取り上げて見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過敏にきちょうめんできれい好きな葉子はもうたまらなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから蕎麥、夏ならばそうめん。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでだって、二人の間の関係はきれいなものではあったが（勿論心の中まで彼がピューリタンであったわけではないが）その後は益々きちょうめんになって、光子が山吹町の路地に六畳に三畳の借家ずまいをするようになってから今まで、手紙の往復以外に、二人が直接会ったことは今夜とでも三度しかなかった位である。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳原なら大川べりを左へ曲がるのが順序ですが、まっすぐにそれを通り越して、どうやら行く先は浅草目がけているらしく思われましたものでしたから、少し寸法の違うどころか、伝六はとうとうめんくらって、うしろの駕籠から悲鳴をあげました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇二は、きまじめで、きちょうめんで、清潔好きな部屋だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "松茸は別として、……初茸、いぐち、卵茸、しめぢ、じごぼ、さうめん茸……」とあげて、そのあとにまだ何かあるやうで思ひ出せなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうめん茸とどつちが大きかつたかしら。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうめんは黄色だし。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
