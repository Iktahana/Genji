        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おれの村から持って行ったものが、何もかも飛びきりの上値で売れっちまってさ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし決して多額にむさぼらないのがえらいところで、千円ぐらゐでうけてきた品物が一万五千円ぐらゐに思ひがけない上値で買ひ手があると、三百円とか五百円とか予定してゐた口銭以外はそつくり売り手へ届けてかねての恩儀に報いるといふ心掛けである。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも一貫目当たりで、出盛り期の農家が青物組合の買上値段である。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の売り込み商を訪ねるたびに、貿易諸相場は上値をたどっているとのことで、この調子で行けば生糸六十五匁か七十匁につき金一両の相場もあらわれようとの話が出る。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜まれる娘は違うわね。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が何でもわたしゃアいいよ、首になっても列ぼうわね。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ゃすぐ引毀して、結直して見せようわね。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "串戯だよ、串戯だけれどもねえ、その位にさばけておくれだと、それこそお前さんの言草じゃあないが、誰も冷かしたり、なぶったりなんぞしないようになっちまうわね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、そうじゃあないよ、一旦は何、私だって、先刻のように云ったけれど、お前さんの心配をすることだもの、それに、どうせ、こんなからだだから、お前さんさえ愛想をお尽しでないことなら、もうどんなにでも私ゃなろうわね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは少し気取って「まあ、困っちまうわね」と言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ねえ、似合うわね、シルヴィア・シドニイみたいじゃない？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにわたしの心をいたわってくれるのなら、何とかおっしゃりようがあると思うわねぇ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもあなたの歌は、ぽつんと切れてしまうわねえ」　二番目の罰金は、ジナイーダに当った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ困っちゃうわねえ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困っちまうわね、山科さんところ、また一騒動したんですってさ」　縫子は、灰をいじくりながら唇を歪めた。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、電車にのって来る」　たまに、「ちょっとまあ腰でもかけといき、くたびれちゃうわね、まだちっちゃいんだもの」　などと云われることもなくはなかった。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここの女の人は、鹿児島の女と随分違うわね」「違う、違う。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あら飛行機屋さんにも判らないの、困っちゃうわね。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんなところで働くのは、体より神経の方が先に参っちゃうわね。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんなとこで働くの、体より神経の方が先に参いっちゃうわね。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼しちゃうわねホントニ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『心にもない事を云うわね、彼女は。",
              "citation": {
                "source": "昇降場",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "広も可哀さうだし、お前さんも気兼だし、第一わしの気骨の折れることせつたら、ちつとやそつとぢやなからうわね。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうじきわたし位に成長きくなってしまうわね」と冬子は母と顔を見合わした。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけど、そんなことになったら、なんだか違うわね。",
              "citation": {
                "source": "高尾ざんげ",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私「ひる間働いているからくたびれるんだよ」　咲「やっぱり違うわねえ。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかりすぎたせいか、よその村の人でないとたばこをくれなくなったわ」「そんなにたばこがお好きか」「馬鹿云うわね。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければキチガイのようにとびだしてきて、受話器を外してしまうわね」　すると木曾はいかにもバカバカしくてたまらぬように答えた。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「深い意味はないがね」「そう、それなら、スポットガールのこと私忘れてしまうわね。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだこの野郎と思うわね。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
