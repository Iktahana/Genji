        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "天明六、丙午年は、不思議に元日も丙午で此の年、皆虧の蝕があつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて、何かいわれのございましたことか、一々女の名と、亥年、午年、幾歳、幾歳、年齢とが彫りつけてございましてな、何時の世にか、諸国の婦人たちが、挙って、心願を籠めたものでございましょう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "午年ゃ景気がぴんぴんはねるというからね、さぞやおひざもともたいした景気だろうと思って、起きぬけに、ちょッくらとばかりないしょでいってみるてえと、――これがどうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは安政五年――午年のことでございます。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政午年――御承知の通り、大コロリの流行った怖ろしい年でございました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀屋の嫁のお元は弘化二年｜巳年の生まれと云っているが、実は弘化三年｜午年の生まれであるとお鉄は初めてその秘密を明かした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に午年ならば仔細はないが、弘化三年は丙午であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて余りに身分違いの家と縁組するわけにもいかないので、親たちから土地の庄屋にたのんで、人別帳をうまく取りつくろって、午年の娘を巳年の生まれと書き直して貰って置いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる午年の大コロリである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは確か安政｜午年の十二月、歳の暮にしては暖い晩でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史に残っている午年の大火である。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化七午年十二月十二日小通事末席被仰付。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書上は此を「寛延三庚午年」としてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦橋は書上に「天明八戊午年人始て曼公の術ある事をしる」と云つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時天明八戊午年人始て曼公の術あることを知る」と云ふ文である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年十一月七日、英国船一艘、那覇へ来着、彼国軍機大臣より、更に有無之品、致交易度趣之書状持越、又者右船乗頭よりも、同様交易筋之儀申聞候に付、去午年、仏国大総兵交着之節、和好交易等相断候趣を以て――「誰から、左様の物を手に入れた」　斉興は、大声で云って、久光を、睨みつけた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十五｜壬午年三月廿七日｜出生。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "午年毎に、第三期まで勤めあげた神人と交迭するのである。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（神武紀戊午年）とあるのは、をし・おし假名遣ひの違ひはあるが、同系の語ではなからうか。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども親戚のうちにお位牌がある、それには、「文化七庚午年円寂　木喰五行明満聖人品位　六月初五日」　これによると、九十三歳の円満｜示寂は疑うところがない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、午年生れは山にて跳るべからず、厄災あり。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕は、あいにく午年生れで、高いところへ登れば、たちまち目がくらむようにできているんだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "午年に北の方へ出たのも、あのとおりでしたよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはそもそもどういう意味かというと、日本の公民の戸籍は初め大化の時に調べまして、その戸籍の基本となるべきものは、天智天皇御代の庚午の歳の調査のもの、これを庚午年籍と云います。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その庚午年籍が久しい間我が戸籍の標準になって、その時分に村落を成し、一定の土地に住居していた者が、我が公民の標準になったのであります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると「出雲風土記」に見えている余戸は、天智天皇の時の庚午年籍に這入っておらぬもので、その後新たに戸籍に加わり、平民になったもの、それまで公に認められていなかった村を新しく拵えたという意味であります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に天智天皇八年に、「庚午年籍」を造って、浮浪人を断つとある。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」松喜楼　して見れば、一立斎広重が死の直前（安政自三辰至五午年）に作つた江戸百景にこれを「洲崎十万坪」として一望荒涼とした地域を空から大鷲の舞ひ下るすさまじい風景に表現したのも、肯かれる。",
              "citation": {
                "source": "洲崎の印象",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま翌年が午年なので、新年の紙上に次の簡単な一文をのせた。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬岳の代馬（えと文）　午年の縁起を担ぐのではないが、一つ変った馬をひき出して見たい。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
