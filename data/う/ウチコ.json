[
  {
    "uuid": "c4c11621-4f2f-578c-a438-cdef640ec7fd",
    "entry": "打ち粉",
    "reading": {
      "primary": "うちこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "形は丸筒、生地は竹、塗りは朱うるし、緒締めのふたがあって、中をしらべてみると、刀剣の手入れにはなくてかなわぬ紅絹の打ち粉袋がはいっているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "名乗りを気合に、抜き渡した一刀は、研ぎ上がってまだ手も触れず、青味がかった金肌に打ち粉の見える来国俊。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときとしては眺めているうちこどもはむこうの草木に気持を移らせ、風に揺ぐ枝葉と一つに、われを忘れてゆららに身体を弾ませていることがある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路三里は子供には少し難儀で初めのうちこそ母よりも先に勇ましく飛んだり跳ねたり、田溝の鮒に石を投げたりして参りますが峠にかかる半ほどでへこたれてしまいました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えゝ、申兼ねましたが、其が其の、些と道なりませぬ、目上のお方に、身も心もうちこんで迷ひました、と云ふのは、對手が庄屋どのの、其の、」と口早に云ひたした。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっちにいるのが、森のやくざ者だよ」と、娘は話しつづけながら、かべの高いところの穴の前にうちこんである、横木のうしろを指さしました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子は、こまに赤い色や、黄色い色をぬりつけて、そのまんなかに、しんちゅうのくぎを一本、うちこみました。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今はもう、よその家の走り使いや子守をすることはやめて、ただランプを売るしょうばいだけにうちこんだ。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちこそ愛嬌にもなるが、そのうちに、人は、てんで相手にしない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は、しぼまぬうちこそ、花である。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ未だ見ぬ北方の煙霞に身も霊もうちこんで見たかったのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてみんなで寄ってたかって、ある大きなたち木を根もとから切りまげて、その切れ目へくさびをうちこんで、その間へ大国主神をはいらせました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、何某の院に往き、滝の傍を歩いて往ったところで、髪は績麻をつかねたような翁が来て、「あやし、この邪神、など人を惑す」と云うと、真女児と少女は滝の中に飛び込んだが、それと共に雲は摺墨をうちこぼしたる如く、雨は篠を乱して降って来た。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよや、かのロオマ教の寺にひとしく、礼知りてなさけ知らぬ宮のうちこそわが冢穴なれ。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太は最初のうちこそお妖怪のことを頭においていたが、鮒が後から後からと釣れるので、もう他の事は忘れてしまって一所懸命になって釣った。",
              "citation": {
                "source": "おいてけ堀",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これまでの事件のうちこれほど奇抜なのはまずない。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、そのむすめは、かべにあけたあなに、うちこまれたとまり木を、ゆびさしながら、また話しつづけました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や国土やすらかに、恐怖の洞穴はうちこわされ、恐ろしき死のありしところ、生命と平安と現われたり」〔パリのジャコバン倶楽部の遺趾に建てらるべき市場の門扉にしるすために作られた四行詩〕　私は弱っていた、――あの長いあいだの苦痛のために、死にそうなくらいひどく弱っていた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "茂みと河とのあいだには、柵はうちこわされ、地面にはなにか重い荷物をひきずって行ったあとがあった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのうちこれぞというて大作はありませぬ。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭中将があの自分の新婦を見たらどんな批評をすることだろう、何の譬喩を用いて言うだろう、自分の行動に目を離さない人であるから、そのうちこの関係に気がつくであろうと思うと源氏は救われがたい気がした。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あの月をながめて酒をのんだらお美味からな』　馬賊の大将はさつきさんざんお月さまを憎んだことも鉄砲をうちこんだことも忘れてしまつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浴女』に於ける浴槽の中の湯のゆたりゆたりと揺曳する状態の描写は、たしかに彼女の写実家として神経をうちこんだ描き方であつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物にこれほど人間的な感情をうちこんで、そして人間的表情に接近させた作品は誰も描いてゐないのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者がその写生精神に立脚して種々の試み工夫をするといふことは、古い概念をうちこはして新しい自己の世界を樹立するといふ目的から為されてゐる場合が多い。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして画壇的位置の進退駈引に精魂をうちこみつゝも、画作をつゞけるといふ画家もあらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれ以上に、この雉が羽に力をいれたなら、その肉体がばら／＼に分解飛散してしまふであらうと思はれるほどに、作者の緊張はこの対象物にうちこまれてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌をうちこむことを熟練した。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つ股の袖ガラミ捕物道具を、そのトゲだらけのものをわが肉体にうちこめ私は肉を裂いてもまんまと逃げ去るだらう。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
