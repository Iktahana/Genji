    "definitions": [
      {
        "index": 1,
        "gloss": "noisy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "隣人がうっさい音楽を流している。",
              "source": "幻辞"
            },
            {
              "text": "工事現場はうっさい騒音が続いている。",
              "source": "幻辞"
            },
            {
              "text": "あの映画館はうっさい客が多くて困る。",
              "source": "幻辞"
            },
            {
              "text": "彼はいつもうっさい話をして邪魔だ。",
              "source": "幻辞"
            },
            {
              "text": "駅の近くはうっさい環境だ。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちがうっさい声で遊んでいる。",
              "source": "幻辞"
            },
            {
              "text": "この街はうっさい交通音が絶えない。",
              "source": "幻辞"
            },
            {
              "text": "夜間にうっさい動物の鳴き声が聞こえる。",
              "source": "幻辞"
            },
            {
              "text": "飛行機の音はうっさいほど大きい。",
              "source": "幻辞"
            },
            {
              "text": "そのうっさい態度は改めるべきだ。",
              "source": "幻辞"
            },
            {
              "text": "キャンセルの連絡がうっさい頻度で来ている。",
              "source": "幻辞"
            },
            {
              "text": "うっさい指摘は聞き飽きた。",
              "source": "幻辞"
            },
            {
              "text": "店員がうっさい勧誘をしてくる。",
              "source": "幻辞"
            },
            {
              "text": "この楽器の音はうっさいので調整が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "うっさい批判を受けるのは嫌だ。",
              "source": "幻辞"
            },
            {
              "text": "雨音がうっさいほど激しい。",
              "source": "幻辞"
            },
            {
              "text": "彼女の話し方はうっさくて疲れる。",
              "source": "幻辞"
            },
            {
              "text": "クラブのうっさい音楽環境は不快だ。",
              "source": "幻辞"
            },
            {
              "text": "朝からうっさい電話がかかってきた。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
