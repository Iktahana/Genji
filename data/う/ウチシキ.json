        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "沈の木の折敷が四つ、紫檀の高坏、藤色の村濃の打敷には同じ花の折り枝が刺繍で出してあった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "国破れて山河あり、城春にして草青みたりと、笠打敷て時のうつるまで泪を落し侍りぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国破れて山河あり、城春にして草青みたりと笠打敷きて時のうつるまで涙を落し侍りぬ夏草や兵どもが夢の跡　　　芭蕉卯の花に兼房見える白毛哉　曽良」　私はかくして芭蕉師弟が夏草に坐して涙を流したる心境の一部に接することの得たことを喜ぶのである。",
              "citation": {
                "source": "平泉紀行",
                "author": "──専攻科第一類歴史部──",
                "note": "青空文庫"
              }
            },
            {
              "text": "杖酔退出」、公事根源に、「昔は上戸を選で後取にめしけるとかや」、三中口伝に、「役送打敷を取て陪膳に進む」、台記に、「陪膳地下五位進み居り、役送地下五位折敷を取る。",
              "citation": {
                "source": "手長と足長",
                "author": "土蜘蛛研究",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ常大寺の本堂を、幾度も／＼調べましたが、時代の古びのついた、黒塗の須彌壇には絶對に仕掛けが無く、擬ひものゝ蜀紅の錦の打敷も、古りに古りては居りますが、何んの不都合も見られません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "贋金",
                "note": "青空文庫"
              }
            },
            {
              "text": "千兩箱は最初から蓋だけ二重になつて居り、薄板の赤樫の上側の蓋を拔き取つて、打敷の下に隱せば、その下から分厚な薄汚れた千兩箱が出て來る仕掛になつて居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "贋金",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな絲は何處にあると思ふ」「坊主の袈裟に、佛樣の打敷、――外にはありませんね。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんの有難い法衣や、打敷や、掛物の表具にはあんなベロベロの錦は使はない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ打敷けと命じるのだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく／＼と語れば、「そは承けがたき事」と打かたぶき打かたぶきするほどに、又も一声二声うちしきれば、「あれが声を郭公とや。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる所に敷皮うちしき、蓑うちきて夜を明かし、日を暮らす。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父上のは三回忌ですから仏壇に飾る「うちしき」というものをこしらえてゆきました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、銅貨一枚持っていないことは、しょうちしきっているのですが、思わずしらずそうしてみたのです。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
