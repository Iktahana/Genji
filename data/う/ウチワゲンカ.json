        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ひよつとしたら、神様もそのつもりで、黙つて、内輪喧嘩をおゆるしになつてゐるのかも知れない。",
              "citation": {
                "source": "悪魔の尾",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下の事天下の事と口ではいっても近頃の皆さんのなされ方あ、水戸城内がどうしたの、江戸の藩邸がこうしたのと、まるきり藩の内々の内輪喧嘩ばかりに身を入れていなさるように思えるが？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あり様いってしまえば、こねえだからお前さん方のしていることは何から何まで、書生派がどうの江戸藩邸の実権を誰が握ったのと、水戸の藩内の内輪喧嘩だけじゃありませんかねえ？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわねえが、この調子で内輪喧嘩ばかりで日を暮しておれば、先に行ってどうか知らねえが、あんた方のおつもりが下々に響く頃が来れば、かんじんの百姓は一人残らず消えて無くなっていやしねえかと思うんです。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからすぐに内輪喧嘩。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、士同士の内輪喧嘩、私達しもじもに何のかかわりがある訳じゃなし。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内輪喧嘩がどうしたと？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内輪喧嘩のない仕事があるか！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下のこと天下のことと口では言っても近頃の皆さんのなされ方あ、水戸城内がどうしたの、江戸の藩邸がこうしたのと、まるきり藩の内々の内輪喧嘩ばかりに身を入れていなさるように思えるが？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、有り様に言ってしまえば、こねえだからお前さん方のしていることは何から何まで、書生派がどうの江戸藩邸の実権を誰が握ったのと、水戸の藩内の内輪喧嘩だけじゃありませんかねえ？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わねえが、この調子で内輪喧嘩ばかりで日を暮して居れば、先に行ってどうか知らねえが、あんた方のおつもりが下々に響く頃が来れば、かんじんの百姓は一人残らず消えてなくなっていやしねえかと思うんです。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、士同士の内輪喧嘩、私達しもじもに何のかかわりが有る訳じゃなし。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内輪喧嘩のない仕事が有るか！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和戦両様の派が対立して、内輪喧嘩を内攻する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果はそれこそ果てしもない内輪喧嘩となつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "内輪喧嘩は大嫌いだ。",
              "citation": {
                "source": "明治文明史上に於ける福沢翁",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "――すると、直ぐ隣室の暗やみで、「……や……やかましいぞっ……人の苦痛も知らずに……ウーム……ウーム」　呻く者があると思うと、「そんな内輪喧嘩より、若先生が帰って来たなら、早く、今日の無念ばらしをしてくれっ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――後にしても、いくらだって取る処置はありましょう」二「そうだ、内輪喧嘩は、あとのことにしよう」　袁譚は、兵馬を再編制して、ふたたび黎陽の戦場へ引返した。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
