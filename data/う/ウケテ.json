        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこでこの三通のレッド・ペーパーに対する受け手の反応やいかにと問えば、第一の日本のソフトウエア市場に対するものには、いまだしとは言えど敏感な反応が返っているという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえＴＲＯＮが普及という点ではよく成果を上げえなかったとしても、池田が歴史に委ねたバトンが受け手を待っている事情に変わりはない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前すこしばかり、其処を手に入れる時に、お金を用立てた人が死んで、その後家たちは、新橋で旅館をもとからの商業にしているので、丁度引受け手を探していた、箱根塔の沢の温泉をゆずってもらって、経営しはじめた。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、東条、米内、小磯と三代も、一番馬鹿な、誰もひき受け手のないときに担がれて、まんまとその手に乗せられて総理大臣になる阿呆さ加減というものは、あったもんじゃありませんよ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、親爺は、子の愛からか、意地からか、引受け手のない無理な仕事をまんまと倅に押しつけられたといふことを、金輪際信じようとはしなかつた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "受け手の方は体をひらいて斬り返すか、退いてかわして斬るか、もしくは進んでツバ元で受けて巻き落して斬り返すか、いずれかで、攻めても受けても、どっちにしても一撃できめようという剣法だ。",
              "citation": {
                "source": "馬庭念流のこと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台やイスの修繕は、世の中がこうなる前でも、それはそれはたいそうで、ちよつと近所に引受け手がない有様ですから、どこの家でも、十年や十五年は、毀れたまゝにしておきます。",
              "citation": {
                "source": "Ｓ夫人への手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちある時、いつも話の受け手にばかりなっていた、このチルナウエルが忽ち話題になった。",
              "citation": {
                "source": "世界漫遊",
                "author": "ダウィット　Jacob Julius David",
                "note": "青空文庫"
              }
            },
            {
              "text": "引き受け手の気構えが、しゃんとしていないと、頼む方でも、どうもその気になれないものである。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でぶは入院して手術を受け手首から切断された。",
              "citation": {
                "source": "トンカトントンカッタカッタ",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の交感としての手稿文化が元となって、やがてそこが作品の源泉となるわけですが、もちろんプライヴェートなものと、公へと送る出版とは受け手が異なり、作品もその変化に合わせて書き直されることになります。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒岩万五が今日の作業の引受け手であつたのかと思ふと、興味が一段と増して来る。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つまた、これは売り払うとしても、処分するとしても、誰も引受け手がない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、引受け手は大いにあるにしても、読める人がない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて美しい歌手でなければ、その頃はもう日本でも引受け手がなくなっていたのであろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでに、受け手の側からとらえたレイス・レコードのブルースは、どんな役をはたしただろうか。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもレース開始十五分前、賭けの受け手がいない有様だった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の片側は翳り、片側は日射しをうけて、あつたかいけざやかにもわびしい秋の午前です。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "良いお天気で、幅二間程の、下高井戸駅通りは秋の日をうけて黄色く乾いてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の間の光を肩にうけて、女だけが、私を見送りに出てゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "他にも残つたものがあるとしても、十九世期の大家簇出の後をうけて、なんと微々たるものであらう！",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の窓は田園の遙けきながめにて、垣根に近き駒紫蘇の花、今ぞ日光をうけて、くれなゐの色滴らむばかりなる。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行の目的は、もしも運がよかったら鯨を捕る光景が見られるというのと、もう一つは、自分の先祖のうちに一人室戸岬の東寺の住職になった人があるのでその墓参りをして来るようにという父からの命をうけていたことである。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光うけて失神し　　庭の土面は附黒子。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おまへが情けをうけてくれないので、　　とにかく私はまゐつてしまつた……それといふのも私が素直でなかつたからでもあるが、　　それといふのも私に意気地がなかつたからでもあるが、私がおまへを愛することがごく自然だつたので、　　おまへもわたしを愛してゐたのだが……おゝ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼の姿は、すっかり眠りほうけているように見えた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはお金をまうけて、恋人に香ひの好い煙草一箱買はうとするのでもありません。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子戸の中は茶釜をかけた竈の火で暖かく、窓の色硝子の光線をうけて鉢の金魚は鱗を七彩に閃めかしながら泳いでいる。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの鳴ね聞き給へ、よもあやまらじ」と不審かしうなりて言へば、「月夜に寝ほうけて鳴出る時は常の声とも異なりぬべし。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼎をかぶって失敗した仁和寺の法師の物語は傑作であるが、現今でも頭に合わぬイズムの鼎をかぶって踊って、見物人をあっと云わせたのはいいが、あとで困ったことになり、耳の鼻も※ぎ取られて「からき命まうけて久しく病みゐる」人はいくらでもある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
