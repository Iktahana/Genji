        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "文六浮かぶ瀬も無い。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら色や愛嬌を売る稼業でも、頭脳と意地のないのは、何年たっても浮かぶ瀬がなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままにて郷にかえらば、学成らずして汚名を負いたる身の浮かぶ瀬あらじ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしてこの大事な瀬戸を漕ぎぬけなければ浮かぶ瀬はない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何んしろ細大｜洩さずだから、彼奴等も浮かぶ瀬が無いだろう。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を棄ててこそ浮かぶ瀬もあれ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――切りむすぶ、太刀の下こそ、地獄なれ、身を捨ててこそ、浮かぶ瀬もあれ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして後悔するときは、もう自分の浮かぶ瀬は無くなっていました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸人にカタギがなくては浮かぶ瀬がない。",
              "citation": {
                "source": "芸道地に堕つ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓一と結婚してはもう浮かぶ瀬がないやうだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後のことはいざ知らず、現世においては永劫浮かぶ瀬のない無間地獄というものはないはずです。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（切り結ぶ太刀の下こそ地獄なれ身を捨ててこそ浮かぶ瀬もあれ。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、一生浮かぶ瀬がない。",
              "citation": {
                "source": "春さきの古物店",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、日光御造営を目前にひかえて、柳生一藩、浮かぶ瀬のないことになる……と小刀のさきで蓋の紙をせせくる老人の額には、いつのまにか玉の汗が――。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方まで奪られるじゃあ、まったく、浮かぶ瀬がないよ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を捨てて浮かぶ瀬を求めようと、防禦の構えはあけっぱなしに、まるで薪でも割ろうとする人のようにスタスタと寄って来てはサッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかしく思いながら、「うむ、いかにも拙者は浅香だが、そういう尊公は――」「神尾喬之助」「ナ、何イ……神尾――」　抜いたのは同時だったが、虚心流捨身の剣の前に、四人の供は忽ち地に反って……身を捨ててこそ浮かぶ瀬もある喬之助の強刃、白蛇のごとく躍って慶之助に追い迫った。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を捨ててこそ浮かぶ瀬もあろう。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくもそんなことをぬかしゃあがった、この己を、こんな態にしたなあ誰だ、素っ堅気のお店者、これっぽっちも世間の汚れを知らなかった者を、騙し放題に騙しゃあがって、大恩ある主人の金を持ち逃げさせ、一生浮かぶ瀬のねえ泥沼へ引きずり込んだなあ誰だ！",
              "citation": {
                "source": "お美津簪",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
