        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "文学趣味のある彼女は豹一の真赤に染められた頬を見て、この少年は私の反撥心を憎悪に進む一歩手前で喰い止めるために、しばしば可愛い花火を打ち上げると思った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "万寿丸｜甲板部の水夫たちは、デッキに打ち上げる、ダイナマイトのような威力を持った波浪の飛沫と戦って、甲板を洗っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、水火夫室の出入り口は、波の打ち上げるごとに、すばらしく水量の多い滝になって、上のデッキから落ちて来るので、一々その重い鉄の扉を閉ざさねばならぬほどであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸から打ち上げる目標の烽火が紫だって暗黒な空の中でぱっとはじけると、※々として火花を散らしながら闇の中に消えて行く。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上のお免しを得るには、御注文の品を打ち上げるより外にはないということが、お前には分らんか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで千も万もの花火を一時に連けて打ち上げるようで、紅や青や黄色やその他｜種々の火花が散り乱れて、大空に舞い昇っていましたが、不思議な事にはその轟々と鳴る音をじっと聞いていますと、お父様の声のように思われるではありませぬか。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この海のない国は、温泉の中に機械製の波を起し、磯に打ち上げる波頭を想像しつつ抜き手を切って喜び勇んでいる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内を埋めた各国の観衆は、新しい一団の現れる度毎にドッと拍手の波を打ち上げる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "主として直径一寸ぐらい、時に直径一尺位の火山弾もうちあげているそうですが、打ち上げる高さはせいぜい二三百米にすぎず、内輪山の火口壁周辺にころがり落ちる程度で、沙漠の外側の外輪山で見物している我々には全然危険がないそうだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、岩の上に打ち上げる波の音は声たかく聞えた。",
              "citation": {
                "source": "浅瀬に洗う女",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿や鼠をロケットで上空に打ち上げると、それが自由落下している時間内は、重力がはたらかない。",
              "citation": {
                "source": "宇宙旅行の科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿波の右近三郎打ち上げるところの女髪兼安。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に肉が縮む、詰め込んだガーゼで荒々しくその肉を擦すられた気持がする、次にそれがだんだん緩和されて来る、やがて自然の状態に戻ろうとする、途端に一度引いた浪がまた磯へ打ち上げるような勢で、収縮感が猛烈にぶり返してくる。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "遭難火箭を打ち上げると、間もなく漁夫が、何事にでも手伝うつもりで、本土のあちらこちらから漕ぎ寄せて来た。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後、日本海は荒れることが少くなったそうだが、この日は海が大荒れで、私たちは伏木港外の雨晴という海岸へ義経の古蹟を見に行くはずであったが、海岸の路上に波がうちあげるために一時は通行ができなかった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "山内は、これだけの食糧ではとうてい長い漂流は出来ないから、兵隊はいずれ将校や下士官の犠牲にされるのだろうという暗い予想をいだき、檣の下から波のうちあげる筏の後部へ移って古い帆布の下へ入り、なにがあってもそこから動かないことにきめた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "筏に残っていた犠牲者の臀から肉を抉りとると、波のうちあげるギリギリの端へ行ってみなに背をむけ、｜叩き肉をつくる要領で念入りに叩き、立膝をしたまま、指先で丸めては口へ運んだ。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤッホー……あたしよ、居たら、返事をして……」　うちあげる潮のかしらが洞の内壁にあたって、鼻息のような音をたてる。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソ連やアメリカでは、Ｒすい星と通信をかわすために、人工衛星をうちあげる計画がたてられました。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
