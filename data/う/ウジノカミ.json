    "definitions": [
      {
        "index": 1,
        "gloss": "head of a clan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして、氏中最も正系に属する人を氏上と称して尊信し、他を氏人と言つたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小氏にも氏上があり、その小氏を統一して、その小氏全体は、本家である大氏の氏上を尊敬した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、氏上の先祖を祀つて、事ある毎に参拝した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此式では、まづ天皇よりの詔詞があり、此に対して、群臣中の、二三の大きな家の氏上が、全体を代表して出て（元は、家々で出たものである）、今年も俺に服従しろ、といふ意味の御言葉に対して、叛かぬといふ事を申し上げる。",
              "citation": {
                "source": "呪詞及び祝詞",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏上として諷誦の責任のあつた前代の奏寿其他の天子を対象とする呪言、氏人に宣る神言などは、新作を以てする様になつても、特別の心構へを以てせねばならなかつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子・皇親に対しての呪言の系統なる「ほぎ歌」を予め作つたのは、氏上としての古い神秘を忘れなかつたからである。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲国造は親任の時二度、中臣は即位の時一度だけであつたが、氏上の賀正事になると毎年あつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の賀正事にも、氏上はほを奉つて寿する。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ／″＼の氏上たり、村の君たる者として、当然持つた神主の祭祀能力から出たものと見える。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝詞になつては勿論だが、寿詞さへ、上級神人に口誦せられて居た例は、幾らもあるし、氏々の神主――国造＝村の君――と言つた意味から出た事であらうが、氏上なる豪族の主人であつた大官が、奏上する様な例もある。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷の呪詞・寿詞の中、とりわけ神秘に属するものは発表しなかつたらうと言ふ事は、本編に述べるが、「新室ほがひ」の呪言及び、其に関係深い家々の氏上たる人々の生命呪は、唯二つしか伝つてゐない。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸氏の氏上たる豪族にして神主なる人、下は国造から上は宮廷の権臣として政治に専らな者も、天子の為に生命の呪言を唱へるきまりであつた。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の氏上が寿詞を唱へる事は、其家々が邑落生活に権力を得た源を示している。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから考へると、蒭量を藤氏の氏上相承の宝とした訣もわかつて来る。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中臣の一部、藤原に居たものが、藤原を氏名として、複姓としての特定の神、其氏神・郷土々着の神等を祀つた様に、又、旧族大春日氏の氏族の中心たる氏上が、時々に交替して、その都度、其族長の祀る神を拝する例だつたらしいのを見ても、村及び氏族に隆替があり、中心が常に動いてゐたことが思はれる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子様以下の人に於ても、やはり、家々の氏上の魂は分割する。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の氏上家の主人は、大方もう、石城など築き※して、大門小門を繋ぐと謂つた要害と、裝飾とに、興味を失ひかけて居るのに、何とした自分だ。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "南家で持つて居た藤原の氏上職が、兄の家から、弟仲麻呂―押勝―の方へ移らうとしてゐる。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "大伴｜氏上家も、築土垣を引き※さうかな。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の掟の前には、氏上たる人の考へをすら、否みとほす事もある姥たちであつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くから氏上で、數十｜家の一族や、日本國中數萬の氏人から立てられて來た家持も、ぢつと對うてゐると、その靜かな威に、壓せられるやうな氣がして來る。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に居る時だけは、やはり神代以來の氏上づきあひが、えゝ。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏上づきあひぢやもの。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはまだ、藤原の氏上に任ぜられた訣やぢあ、なかつたつけの。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄公殿は氏上に、身は氏助と言ふ訣なのぢやが、肝腎齋き姫で、枚岡に居させられる叔母御は、もうよい年ぢや。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一代此方から進ぜなかつたら、齋き姫になる娘の多い北家の方がすぐに取つて替つて、氏上に据るは。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ大伴幾流の中から、四代續いて氏上職を持ち堪へたのも、第一は宮廷の御恩徳もあるが、世の中のよせが重かつたからである。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際よそほかの氏上よりも、此方の氏助ははたらいてゐるのだが、――だから、自分で、氏上の氣持ちになつたりする。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
