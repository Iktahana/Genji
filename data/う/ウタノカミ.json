        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "-------------------------------------------------------　播磨国飾東郡姫路の城主酒井｜雅楽頭忠実の上邸は、江戸城の大手向左角にあった。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀千代は寛文九年に十一歳で総次郎綱基となり、踰えて十一年、兵部宗勝の嫡子｜東市正宗興の表面上の外舅となり、宗勝を贔屓した酒井雅楽頭忠清が邸での原田甲斐の刃傷事件があつて、将に失はんとした本領を安堵し、延宝五年に十九歳で綱村と名告つたのである。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延三年に播磨国姫路の城主酒井｜雅楽頭忠知の重臣犬塚純則の六男に生れ、同藩青木某の女婿となり、江戸に来て昌平黌の員長に推された。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "講書のために上野国高崎の城主松平右京亮輝延の屋敷と、輪王寺｜公澄法親王の座所とへ伺候する外、折々酒井雅楽頭｜忠道の屋敷の宴席に招かれるのみであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "印南は此時代に酒井｜雅楽頭忠以浪人結城唯助として入塾した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡藩主久昭は夙く父の出入扶持には猶｜参河吉田の松平伊豆守｜信古の給する五人扶持、上野高崎の松平右京亮｜輝聡の給する二人扶持、播磨姫路の酒井｜雅楽頭忠顕の給する若干口があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ちは、酒井｜雅楽頭、酒井讃岐守、並に老中の邸で会議を開いたのであったが、寛永十二年十一月十日に評定衆の任命があり、同じ年の十二月二日からは評定所で会議を開き、それより毎月二日、十二日、二十二日をもって評議の式日と定めた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都に住んだその年の末に、徳川家茂公に将軍宣下があったため、酒井｜雅楽頭が代理として御礼に上京することになったが、酒井の屋敷は手狭なので、堂上方はじめの訪問を受けるには不便とあって、我藩の屋敷を借りたいと申込まれ、承知して私共は上ノ町の或る町家を借りて一時住むことになった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒井雅楽頭は、新年になって上京した、私はその行列を三条通りで見た、赤坂奴が大鳥毛の槍を振り立て拍子を取って手渡ししつつ練って行った。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽頭の引払われてから、その居間を見せてもらったが、そこに紫色をした蕗の薹が一輪ざしに活けてあったことを覚えている。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　慶安三年の五月ごろ、酒井雅楽頭の侍医で武州江戸大塚に住んでいた樽次こと茨木春朔と、やはり武州池上新田に住する池上太郎右衛門底深という人と酒合戦を行なったことは、茨木樽次が戲書『水鳥記』に詳しく書いてあるので誰も知っている。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、酒井雅楽頭様、（播州姫路藩主）深川一円。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "四代、雅楽頭忠清は専横のことがあり、大老職と大手御門先の上邸を召しあげられ、大塚の下邸に遠慮中、切羽詰って腹を切った。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽頭の屈託するようすが目にあまるので、犬塚はたまたま出府してきた国家老の本多民部左衛門をつかまえて相談をしかけた。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛延二年の春、桃の節句のすんだあと、雅楽頭の御前で、犬塚がなにげない顔でこんなことをいった。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御用部屋にお入りなされてから、四度目の春を迎えましたが、日々のご心労、お察し申しております」　雅楽頭は、俗に思案顔という気魄薄げな面持で、「そのことよ」　と肩を落して溜息をついた。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんともお痛わしいことで」　とソソリをかけ、媚びるように雅楽頭の顔を見あげた。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忠節に限りはなけれど、まず、ほどほどにお勤めなされませ」　雅楽頭は駄々っ子のようにふくれっ面をして、ちぇっと舌打ちをした。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このうえ、まだ勤めるのか……わしはもう倦いたぞ」「では、おやめなされては如何」　雅楽頭は手で脇息を打つと、力のない声で、ふ、ふと笑った。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽頭は細い顎をうごかして鷹揚にうなずき、「望めと言うなら、言ってみよう。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　雅楽頭の上願の筋は、柳営の内証向きで首尾よく裁許されたという噂だったが、五月の末、御老中御免のうえ、溜間詰に進み、あわせて厩橋から姫路へ所替を仰せつける旨、沙汰があった。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽頭はゆったりと盃をあけながら、チラチラと川合蔵人の顔をながめていたが、今日の慶事に、あまりにもそぐわないようすをしているので、たまりかねて、上段の間から声をかけた。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お家の大変というのに、どうして浮かれていられましょうや」　聞きとがめて、雅楽頭が問いかえした。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽頭は額ぎわまで血の色をあげて、「だまれ、口がすぎる。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "又内、忠蔵めらに、どのような武功忠節があって、四百石、百五十石というご加増を下しおかれたか」　雅楽頭は、しどろもどろで、「おのれは、藩祖さまが憑りうつったような高慢な口をきく。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "用人は、これはと、一と足あとへ退ると、蔵人はとっさの間に立構えになり、雅楽頭に会釈をして、すらりとお次へ出る。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽頭もそれをしおに奥へ入った。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この馬は雅楽頭の乗料で、雅楽頭から和解のしるしとして贈ったものだった。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
