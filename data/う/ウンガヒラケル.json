          ],
          "literary": [
            {
              "text": "長崎へ行けばキット運が開けると手筋に書いてある』　と云います。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "がどちらに運が開けるのか俺にもわからねえのよ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母あさまとご一しょに岩代を出てから、わたしどもは恐ろしい人にばかり出逢ったが、人の運が開けるものなら、よい人に出逢わぬにも限りません。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "と斯う女房がつむぢを曲げ出した、何を云つてやがるんだい、競馬場で酒を売つた儲けで、質をうけ出すなんていふ了見で、運が開けるものかへ、そんなケチをつける奴はたつた今出て行つてしまへ！",
              "citation": {
                "source": "競馬の日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは豚の児を撫でてやつたから、今年は運が開けるだらう。",
              "citation": {
                "source": "接吻",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも西洋の影響が多少加わって支那の暦法が研究され始める、数学者が暦術のことなどに注意するようになる、現行暦法の不完全なことが知られて、革新の機運が開ける。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど何よりも肝要なのは、こうしたいろいろな事のお蔭で、思いがけない話が持ち上がり、わたしたちの運が開けることになった次第です。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
