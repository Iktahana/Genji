  {
    "uuid": "b0193379-2aa4-5bdd-8def-945c56b5da48",
    "entry": "売るほど",
    "reading": {
      "primary": "うるほど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
