    },
    "definitions": [
      {
        "index": 1,
        "gloss": "inlet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "初めからボヘミアンであったヘルンは、晩年においてもなおボヘミアンであり、永遠に故郷を持たない浦島だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎さんの海が見えるよ。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オラーフ・トリーグヴェスソンが武運つたなく最後を遂げる船戦の条は、なんとなく屋島や壇の浦の戦に似通っていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の浦沖を過ぐと云う頃ハッチより飯櫃膳具を取り下ろすボーイの声｜八ヶましきは早や夕飯なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦戸の燈台が小さく見える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいぶ浦戸に近よった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃太郎、カチカチ山、舌切雀、瘤取り、浦島さんなど、父は子供に讀んで聞かせる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても此浦は平家の一門果て給ひたる所なれば痛はしく存じ、毎夜此磯邊に出でて御經を讀み奉り候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯山に、暫し岩根のまつ程に、暫し岩根のまつ程に、誰が夜舟とは白波に、楫音ばかり鳴門の、浦靜かなる今宵かな、浦靜かなる今宵かな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島さん　浦島太郎といふ人は、丹後の水江とかいふところに實在してゐたやうである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにわが浦島太郎が住んでゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎は、弟妹たちのそんな無遠慮な批評を聞いても、別に怒りもせず、ただ苦笑して、「好奇心を爆發させるのも冐險、また、好奇心を抑制するのも、やつぱり冐險、どちらも危險さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、浦島さん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "辨天樣の池畔などで、ぐつたり寢そべつて甲羅を干してゐるのは、あれは、いしがめとでもいふのであらうか、繪本には時々、浦島さんが、あの石龜の脊に乘つて小手をかざし、はるか龍宮を眺めてゐる繪があるやうだが、あんな龜は、海へ這入つたとたんに鹹水にむせて頓死するだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑ、繪本の畫伯もつい、（蓬莱も龍宮も、同じ樣な場所なんだから）浦島さんの案内役も、この石龜に違ひないと思ひ込むのも無理のない事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その赤海龜は、（赤海龜といふ名は、ながつたらしくて舌にもつれるから、以下、單に龜と呼稱する）頸を伸ばして浦島さんを見上げ、「もし、もし。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は驚き、「なんだ、お前。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これがつまり、子供のなぶる龜を見て、浦島さんは可哀想にと言つて買ひとり海へ放してやつたといふ、あの龜なのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浦島は苦笑して、「身勝手な奴だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は赤面し、「私のは批評ではない、これは、訓戒といふものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浦島は呆れ、「お前は、まあ、何を言ひ出すのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてね、こんなのを、聞いたふうの事、と言ふんですよ、浦島さん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　浦島は龜の驚くべき饒舌に閉口し切つてゐたが、しかし、その最後の一言に、ふと心をひかれた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　性温厚の浦島も、そんなにまでひどく罵倒されては、このまま引下るわけにも行かなくなつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　龜の甲羅に浦島が腰をおろしたとみるみる龜の脊中はひろがつて疊二枚くらゐ敷けるくらゐの大きさになり、ゆらりと動いて海にはひる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときびしい口調で命令し、浦島は素直に眼をつぶると夕立ちの如き音がして、身邊ほのあたたかく、春風に似て春風よりも少し重たい風が耳朶をなぶる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は船醉ひに似た胸苦しさを覺えた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浦島は寢呆けてゐるやうな間伸びた口調で言つた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
