[
  {
    "uuid": "8635d8f8-1959-5c52-9dc0-4e285f1988a2",
    "entry": "浦",
    "reading": {
      "primary": "うら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
