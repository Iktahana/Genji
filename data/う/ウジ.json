          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "横光氏が此の詩集の序に「惑乱を防ぐ克己」を以て此の詩人の特質としてをられることには意義がある。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、僭越乍ら、詩人諸氏が、何卒真率になられんことを希望してやまない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "槙氏の「道」は関西に住む人の幸福がよく感じられます。",
              "citation": {
                "source": "書信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく現に生存してゐる歌人諸氏が、最後的のものであらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原朔太郎評論集　無からの抗争中原中也　萩原氏の本はよく売れるさうである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで萩原氏は文学的苦労人である。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏に会つてゐると何か暖いものが感じられる。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから氏の本がよく売れることは、私としても喜びである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は実に誠実な人で、いつ迄経つても若々しい。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに氏のエッセイはとみると、時にダダツ子みたいに感じられる時がある。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその淫酒は、氏の詩人としての孤独のせゐである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何故だか萩原氏を思ふたびに、次のポオロの言葉をくちずさみたくなる。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば小松清氏によつて、行動主義文学といふのが提唱される。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下該詩集に関するルネ・マルチノオ氏の論文の概要を記さうと思ふ。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私と北原白秋氏とは彼の最初の知己であつた――あまつさへ、私自身しばしば彼の表現を模倣しようとして、愚かな失敗を繰返したことさへある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでよいです』と、そして何か困難な事件が起ったならば、法学士の梅氏に相談しろと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "常々菊池寛氏を敬愛して「英雄」と呼んで居たのも、やはりその反性格の爲であつて、丁度あの神經質のボードレエルが、豪放で世俗的なユーゴーを崇敬して居たのと同じである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は前から、室生君と共に氏を訪ねる約束になつてゐたので、この突然の訪問に對し、いささか恐縮して丁寧に禮を返した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は、かつて伊香保で知己になつた谷崎潤一郎氏に對しても、やや同樣の邪推なしに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（芥川君は死ぬ少し前、白秋氏の「近代風景」といふ雜誌に私の評論を出してる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "17　故人は平常、常に菊池寛氏を以て「私の英雄」と稱してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠の詩人宿命生涯を貫く萩原朔太郎　僕は少年の時、島崎藤村氏と薄田泣菫氏の詩を愛讀した。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや長じて後は、蒲原有明氏や北原白秋氏の作を讀んだ。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏と泣菫氏とは、少年時代の僕にとつて共に同じやうに好きであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泣菫氏の自選詩集には、僕が昔愛讀した詩が殆んど皆オミツトされ、僕の嫌ひだつた詩ばかりがしかも多くの斧鉞を加へて集めてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣菫氏の詩は、その初期の物（暮笛集・ゆく春）ほどよく、純粹なリリシズムが盛られて居るのに、自選詩集には、却つてその詩情を稀薄にした後期の敍事詩風の作が多く入れられてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "この自選詩集に對する不滿は、蒲原有明氏についても同じであつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、『詩もなければ韻文もない、辛うじて文学が……』ラフォルグはコルビエールの作品を愛してゐたが、部分的にしか了解してはゐなかつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんで、まるで、違うじゃないか！",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの眠たそうなプルウストをひとつうろたえさせてやろうじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
