  {
    "uuid": "5ff178a9-2722-5898-8f42-08046e5e0f63",
    "entry": "移り",
    "reading": {
      "primary": "うつり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――移り気な………。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は移り、風雪は空を飛んでる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふことが、では小説をやめて詩に移りなされといふことでは決してないのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間もない茂りの緑は霜にややさびて得も云われぬ色彩が梢から梢へと柔らかに移り変っている。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで郷里に居た時には少しも珍しくもなんともなかったものが、郷里を離れて他国に移り住んでからはかえって最も珍しくなつかしいものになる。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無趣味太宰治　この、三鷹の奧に移り住んだのは、昨年の九月一日である。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、甘味を常態と考えて、対他的消極性の方向へ移り行くときに、「いき」を経て渋味に到る路があることに気附くのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　次に地震予報の問題に移りて考えん。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の研究をしているうちに、空の色の影響に気が付き、それから、空の色そのものの研究に移り、ついに有名な有名なλ-4の方則に到達した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家族を挙げてターリングの邸内に移り、死ぬまでここでレーリーの片腕となって働いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は田端の家を移り、その庭をさへ破壞して、今や新しき生活に一轉すべく、過去のすべての者に別れを告げてる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に藝術の眞の評價は、それが新しく感じられる時期を去つて、やや古く、過去のものとして考へられる時代に移り、始めて◇正鵠を得るのである。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで移り氣な海のやうに引き離したり、引き寄せたりするお前、――かと思ふと、お前はその硝子に映る私達の姿をその向う側に見えるものと混んぐらかせたりする。",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが都会の新文化の発展に追除けられ追除けられして竪川筋に移り、小名木川筋に移り、場末の横堀に移った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は同じ東京となった放水路の川向うの江戸川区には移り住むのを極度に恐れた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、妾の理智は、ロダンさんの芸術の中に移り棲んだのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、赤｜阪に移り住んでからは、全く先生とも會戰の機を得ない。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四季その折々の風物の移り変りと、村の年中行事を、その時々にたのしめるようになったのは、私には、まだ、この二三年以来のことである。",
              "citation": {
                "source": "四季とその折々",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鸚鵡の一件で木村は初めてにがにがしい事情を知って、私に、それとなく、言葉少なに転宿をすすめ、私も同意して、二人で他の下宿に移りました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから改まって挨拶が済むと、雑談に移り、武は叔父叔母さし向かいで、たいがい毎日碁を打つ事、娘ふたりはきょう上野公園に散歩に出かけた事など聞かされた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の初め、彼は城下に住むことを厭いて、半里｜隔てし、桂と呼ぶ港の岸に移りつ、ここより校舎に通いたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この港の工事なかばなりしころ吾ら夫婦、島よりここに移りてこの家を建て今の業をはじめぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "細き枝に蝋燭の焔ほどの火燃え移りてかわるがわる消えつ燃えつす。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕なぎというのは昼間の海風から夜間の陸風に移り変わる中間に、一時無風の状態を経過する、その時をさして言うのである。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はうち方をやめて、いつでも攻撃に移り得る用意をして、姿勢を低く草かげに散らばった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎に居っても、時が移り変っていることは感じられた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、その名前だけを挙げて、プロレタリアートの反戦文学に移りたい。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現世の故郷はうつり変っても画の中に写る二十年の昔はさながらに美しい。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白に襞の多い着物と、頭の白い花の冠が非常によく似合い、私に持って来たクリスマス・プレゼントのチョコレートの箱の飾リボンの縁が、清楚にうつり合った色彩は、私に思わずつかつかと傍へ寄らしてしまったような、好もしい感じを与えました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
