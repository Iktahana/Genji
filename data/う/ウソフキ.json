        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句は「酒肆に詩うたふ」によって、如何にも秋風に長嘯するような感じをあたえ、詩としての純粋感銘をもち得るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の強さの程度は不明であるが海嘯を伴った暴風として記録に残っているものでは、貞観よりも古い天武天皇時代から宝暦四年までに十余例が挙げられている。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海嘯については猶更である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪では安政の地震津浪で洗われた区域に構わず新市街を建てて、昭和九年の暴風による海嘯の洗礼を受けた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では先頃深川の埋立区域に府庁を建設するという案を立てたようであるが、あの地帯は著しい颱風の際には海嘯に襲われやすい処で、その上に年々に著しい土地の沈降を示している区域である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめには負傷者の床の上で一枚の獣皮を頭から被って俯伏しになっているが、やがてぶるぶると大きくふるえ出す、やがてむっくり起上がって、まるで猛獣の吼えるような声を出したりまた不思議な嘯くような呼気音を立てたりする。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "必然的に銀暴落の大海嘯が全土を襲ったのだ。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根を渡る風の音す、門に立てる松の梢を嘯きて過ぎぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老夫は空嘯き、「なんだ、何がお気に入りません？",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌桂　木犀というもの、花は眼をたのしますほどにあらねど、時至りて咲き出づるや、たれこめて書読む窓の内にまでも其香をしのび入らせ、我ありと知らせ顔に園の隅などにてひそかに風に嘯ける、心にくし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚朴　ほゝは、山深きあたりの高き梢に塵寰の汚れ知らず顔して、たゞ青雲を見て嘯き立てる、気高さ比へんかた無し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "白きが暁の風に嘯きたる、紅きが日の午に立てる、或は架に倚りてを発したる、皆好し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが名はレギオン、我ら多きが故なりなどと嘯いて、キリストに叱られ、あわてて二千匹の豚の群に乗りうつり転げる如く遁走し、崖から落ちて海に溺れたのも、こいつらである。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この哀れなる姿をめぐりて漂う調べの身にしみし時、霧雨のなごり冷ややかに顔をかすめし時、一陣の風木立ちを過ぎて夕闇｜嘯きし時、この切那われはこの姉妹の行く末のいかに浅ましきやを鮮やかに見たる心地せり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は悠然としてズボンのかくしに手を入れ空を仰いで長嘯漫歩しているふぜいである。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にトリトンに牽かして行く貝殻型の車駕に御して海神が嘯いている。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って富士を見ても容易に自分の感情の働きかけに共鳴する様子もなく、むしろ、自分は自分でちゃんと暮らす道があると空嘯いている様子にも見える。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言つて空嘯き笑つた最早問答も無益と思つたから、私は突然船長を船室の外へ引出した『あれが見えませんか、あれが、あの悲慘なる信號の光を見て何とも感じませんか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此海嘯は後に分つたが、印度洋中マルダイ※」に二重傍線］島附近の海底の地滑りに原因して、亞弗利加の沿岸から、亞剌比亞地方へかけて、非常な損害を與へた相だが、其餘波が此孤島まで押寄せて來たのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十三回　十二の樽海底戰鬪艇の生命――人煙の稀な橄欖島――鐵の扉は微塵――天上から地獄の底――其樣な無謀な事は出來ません――無念の涙　大海嘯後の光景は、實に慘憺たるものであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何か變つた事でも起りましたか、若しや、昨夜の海嘯のために、海底戰鬪艇に破損でも生じたのではありませんか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といひながら、眤と私の顏を眺めて『然し、昨夜の海嘯は、吾等一同を希望の天上より、絶望の谷底へ蹴落したと思はれます。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、大海嘯が今から二三｜日以前の事で、海底戰鬪艇が未だ船渠を出ぬ内なら、第一に警戒すべき塲所は其處だが、今は、左迄で急いで、檢査する必要も無いと考へたのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も御存じの如く、海底戰鬪艇の總ての機關は、秘密なる十二｜種の化學藥液の作用で活動するのでせう、其活動の根源となる可き藥液は、盡く十二の樽に密封されて、造船所内の一部に貯藏されてあつたのだが、あゝ、昨夜の大海嘯では其一個も無事では居るまい、イヤ、决して無事で居る筈はありません。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の大海嘯の悽まじき光景では、其十二の樽の最早一個も殘つて居らぬ事は分つて居るが、それでも、萬に一もと思つて、吾等は心も空に洞中の秘密造船所の内部に驅付けて見たが、不幸にして大佐の言は誤らなかつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　空嘯いて、笛を鳴す。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と空嘯いて毛脛の蚊をびしゃりと叩く憎体面。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と空嘯きて打笑えば、美人はわっと泣伏しぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と空嘯きつつ小膝を拍ち、「おっと、まだ有る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
