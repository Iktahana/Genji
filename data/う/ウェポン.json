        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しばらくして、アメリカ海兵隊のウェポンズ・キャリアのトラックが一台、徐行して来た。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐行するウェポンズ・キャリアを運転していた若い兵士は、銭湯の前に立っている女性たちに視線を向けた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ウェポンズ・キャリアの荷台には幌が張ってあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つほどもなく、その銭湯の前に三台のウェポンズ・キャリアがあらわれた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と姉は、彼らのウェポンズ・キャリアに同乗して、基地まで帰ることになった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の夏の午後がゆっくりと夕方へと移っていく時間のなかを、四台のウェポンズ・キャリアは基地へと向かった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初にあの銭湯の前に停止したウェポンズ・キャリアには、ラッパ兵が乗っていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
