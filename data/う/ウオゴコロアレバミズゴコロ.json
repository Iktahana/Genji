          "literary": [
            {
              "text": "ファウストそれは魚心あれば水心だ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただ、お前にもわかってるだろうが、魚心あれば水心と言ってね……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷かな、物の奥を見通すやうな目附きを、詞に訳して言へば、「魚心あれば水心だ」とでもいふべきだらう。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚心あれば水心とは申しませぬ。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
