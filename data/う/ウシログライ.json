        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのためにこの証人には何かしら少し後ろ暗い所業を、しかもこの事件に聯関してさせておかないと都合がよくない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやもうから意気地がござりません代わりにゃ、けっして後ろ暗いことはいたしません。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは良人に対しても別段後ろ暗いことではないし――）（僕も――）（他人に疑られたつて仕方がないけれど、妾達の間にさへ厭らしいことさへなければ好いのだ。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――常々は、あんな淡白気なことを云ひ、研究道に余念がなかつたものゝ、一度びこんなことに出遇ふと、その悪だくみだけに頭を使ふ、惨めな、後ろ暗い人間になり変つてゐた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなにも監督が不正なことをしていたからではなく会計上の知識と経験との不足から来ているのに相違ないのだが、父はそこに後ろ暗いものを見つけでもしたようにびしびしとやり込めた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば、なにもそなたには後ろ暗いところはないはず。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　左う左う、その絵を描いてゐる時のこと――私は七郎丸と称ふ漁家の家号がくゞり戸の障子に筆太に誌してあるその友達の家が撥釣瓶のある竹籔の傍らをまはつて突当りの凹地の日溜りに、鳥の巣のやうに隠れたかの位置が後ろ暗い自分の心持に応はしく思はれて、崖に向つた北向きの離室を借りてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、かれが常に賭博に耽っているのと、まだほかにもなにか後ろ暗いことのあるのを、警察でも薄々さとっているらしいので、脛に疵持つかれは、こういう問題について警察へ顔を出すことを恐れている。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "放免されて後、彼女は以前の住家に近いあるアパートメントを借りて、やはり前同様の後ろ暗い仕事を始めていた。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「わたしの中には、悪い、後ろ暗い、罪ぶかいものが、なんていっぱいあるんでしょう。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "院は二条の朧月夜の尚侍になお心を惹かれておいでになるのであったが、女三の宮の事件によって、後ろ暗い行動はすべきでないという教訓を得たようにお思いになって、その人の弱さにさえ反感に似たようなものをお覚えになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で、一度もまだ後ろ暗いことをした覚えはない。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうやらこれも云えないと見える……後ろ暗いことでもあるのであろう」「黙れ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は物好にも自ら進んでこの後ろ暗い奇人に握手を求めた結果として、もう少しでとんだ迷惑を蒙むるところであった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとたんに、こんどは振向いて見ようと思うのだが、その勇気がなく、別に気恥しいことも後ろ暗いこともあるわけではないが、彼はそこの電柱にもたれて立止り、そのままずるずると腰をすべらして、屈みこんでしまったのである。",
              "citation": {
                "source": "立枯れ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、わたしの方にもちょっと後ろ暗いことがあるにはありましたが、大したことじゃありません。",
              "citation": {
                "source": "庶民生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本署へ同行を拒む以上は、君自身の心に後ろ暗いことがあるのだろう。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ暗いことがなければ、一緒に来るがいい。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（間）さうすると、おれは何も後ろ暗いことをした覚えはない。",
              "citation": {
                "source": "驟雨（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにこればっかりは浄瑠璃の鏡に照らされたって露いささかも身に後ろ暗いことはない。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私がただちに政界を去ることは内閣に何か後ろ暗いことがあるような印象を世間に与え、内閣を危機に追い込む結果になるのでそれは思い留まったが、しかし私が二度と社会の表面に立たぬ男になることはこの時からの覚悟であった。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に後ろ暗い行為でもあるやうに疑つてるのかい？",
              "citation": {
                "source": "すべてを得るは難し",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お聞きの通り、久兵衛さんは後ろ暗いところはございません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お民の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、私共は後ろ暗い稼業をして居るわけぢやございませんので」「な、何んて言ひ草だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "掏られた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "八「来いッ八」「どこへ行くんで、親分」「下手人が判った」「番頭の万次郎ですか」「いや、主人を殺すくらいな奴が、後ろ暗いことをしているはずはない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜を妓楼に明かした彼は伯母への手前、そういう場合にすぐそれと気取られるような憔悴した後ろ暗いさまを見せまいとして、わざとこちらから伯母を圧倒するような態度に出ようとその瞬間に思ったのである。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十七年の間に一つも後ろ暗いことのなかった女です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "八「來いツ八」「どこへ行くんで、親分」「下手人が判つた」「番頭の萬次郎ですか」「いや、主人を殺すくらゐな奴が、後ろ暗いことをしてゐる筈はない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、そんなことでもあったかしらと思い出そうとしたところで、まるで覚えはないしするので、煙のうちをでも歩くような気がして、何だか不安な、ほんとうに自分の身に後ろ暗い所でもありそうな日を送っていたのである。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "件のなんらかの後ろ暗い秘密というのは、実際には秘密というには大げさすぎる些細な事情なのであるのかもしれない。",
              "citation": {
                "source": "桃太郎",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
