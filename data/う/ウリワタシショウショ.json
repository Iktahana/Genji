          ],
          "literary": [
            {
              "text": "「実は、こういう用件なんです、私は当地のいろんな地主から農奴を買い取りまして、移住させようと思いますんで、売渡証書もありますから、登記の手続だけして頂けばいいんですがね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "売渡証書も申請書も持って参りました。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イワン・アントーノヴィッチ、この方の売渡証書を持って行って登記を……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "所長に対してはその農奴売渡証書はどうやら素晴らしい効果を齎らしたようだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
