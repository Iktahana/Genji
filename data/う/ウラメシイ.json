        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで彼女は、悲しいにつけ、苦しいにつけ、恨めしいにつけ、嫉ましいにつけ、お題目を唱え、太鼓を叩きました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慶次郎は、少し恨めしいように空を見まわしました。",
              "citation": {
                "source": "鳥をとるやなぎ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ても恨めしい雪の湖ではあると、わたくしはいつまでも眺め入っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはなつかしくも恨めしい方です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲大戦で毒｜瓦斯を吸い込んで肺を悪るくしてじりじり死んで行った夫の話は人事のようにペラペラ喋るが眼の前にしきりなしにおちて来るいつもの緊急令には恨めしい眼をして黙ってしまう。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房はわっと泣きだして、それを今日まで平気でいたお前が恨めしい。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしい、恨めしい、恐ろしい、ありがたい父であった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲンをかけ腎臓結核だときまると、華陽堂病院が恨めしいよりも、むしろなつかしかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨めしい事に思ひながら、なほそれを改め得ないでゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "草鞋の話旅の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いとどしく虫の音しげき浅茅生に露置き添ふる雲の上人　かえって御訪問が恨めしいと申し上げたいほどです」　と未亡人は女房に言わせた。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分を愛していた男を捨てて置いて、その際にちょっとした恨めしいことがあっても、男の愛を信じないように家を出たりなどして、無用の心配をかけて、そうして男をためそうとしているうちに取り返しのならぬはめに至ります。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨めしい理由をみずから追究して考えていくことが苦痛らしかったから、私は安心して帰って来て、またしばらく途絶えているうちに消えたようにいなくなってしまったのです。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さんか何かのようにあなたの悲しむのが恨めしい」　と、源氏が言うと、「私の運命がまだ私を人妻にしません時、親の家の娘でございました時に、こうしたあなたの熱情で思われましたのなら、それは私の迷いであっても、他日に光明のあるようなことも思ったでございましょうが、もう何もだめでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな無情な恨めしい人はないと私は思って、忘れようとしても自分の心が自分の思うようにならないから苦しんでいるのだよ。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人に逃げられてしまった今夜の始末を源氏は話して、おまえは子供だ、やはりだめだと言い、その姉の態度があくまで恨めしいふうに語った。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は伊予介よりつまらない男に違いない」　恨めしい心から、こんなことを言った。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえはかわいいけれど、恨めしい人の弟だから、いつまでも私の心がおまえを愛しうるかどうか」　まじめそうに源氏がこう言うのを聞いて小君はしおれていた。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人妻に恋をして三角関係を作る男の愚かさを左馬頭の言ったのは真理であると思うと、源氏は自分に対して空蝉の冷淡なのは恨めしいが、この良人のためには尊敬すべき態度であると思うようになった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもなく書く簡単な文字の中に可憐な心が混じっていたり、芸術的な文章を書いたりして源氏の心を惹くものがあったから、冷淡な恨めしい人であって、しかも忘れられない女になっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨めしい方」　と言って横にいる女に手をかけて起こそうとする。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨めしい人ではあるが自分を思い出して情人らしい手紙を送って来た点では憎くも女は思わなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はじめてのことではないが私としては恨めしいことですよ」　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「問われないのは恨めしいものでしょうか」　こう言って横に源氏のほうを見た目つきは恥ずかしそうで、そして気高い美が顔に備わっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "永久の夜が欲しいほどであるのに、逢わない時よりも恨めしい別れの時が至った。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を信じてくださらないから恨めしいのですよ」　などと、早く出て行く口実をさえ作って、朝日さす軒のたるひは解けながらなどかつららの結ぼほるらん　と言ってみても、「むむ」と口の中で笑っただけで、返歌の出そうにない様子が気の毒なので、源氏はそこを出て行ってしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こぼれるほどの愛嬌のある顔が、帰邸した気配がしてからすぐにも出て来なかった源氏を恨めしいと思うように向こうに向けられているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "左大臣は恨めしいことも忘れて落涙していた。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと、さすがに恨めしい人の姿が待たれるというのも恋する人の弱さではなかろうか。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所が場所であるだけ人生の無常さばかりが思われたが、その中でなお源氏は恨めしい人に最も心を惹かれている自分を発見した。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "御自身を残して母宮の行っておしまいになることがお恨めしいようであるが、さすがに無理に引き止めようともあそばさないのが御親心には哀れであるに違いなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
