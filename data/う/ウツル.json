[
  {
    "uuid": "92d4415a-106e-589a-840f-7fa86ee7c25d",
    "entry": "移る",
    "reading": {
      "primary": "うつる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to move (house)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "松江から東京に移るまで、ヘルン夫妻は、自分の家を持たなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『足を蹈んだのは僕が惡かつた、惡かつたから謝罪る、ねえ君、これは僅かだけれど膏藥代に、な、納めて呉れ玉へ、さあ』對手の心事、酒代にありと見て取つた若紳士は、事の組し易きを喜んで、手早く握つた銀貨、二枚、三枚、光る物手をすべつて男の掌に移るよと見る間に「呵」と叫んで紳士は身を轉換した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店はちょうど自分が今の処に移る少し前に新しく出来たそうである。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "引上げてゲッチンゲンへ移るときはさすがに名残惜しい気がするのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "碇を下ろして皆端艇へ移る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の翁がそう感ずると等しく、自然自体も感ずるのであろうか、翁の指尖が目途の正面を越して反対側へ撫で移るまもないところから地平は隆起し、麓から中腹にさしかかり、ついに聳え立つ峯巒となる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして船の中へ移るとき、わざとよろけて柚木の背を抱えるようにして掴った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がまはるたびに練瓦のジグザグな影も青く移る。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的から抽象的に移る道を明けてやらないで、いきなり純粋な抽象的観念の理解を強いるのは無理である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから古典教育に関する著者の長い議論があるが、日本人たる吾々には興味が薄いから略する事にして、次に女子教育問題に移る。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも同じ数だけなのですが、言語においては或る一時代の言語にあったそういう音韻組織は、時の移ると共に段々変って行くことがあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人が天竺鼠について試験したところによれば、たとえ健全なのと病にかかっているのとを接近させぬようにしておいても蚤が移ると感染する。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉へ移る少し前、初冬の風のうす寒い日に、僕等二人は連れだつて活動寫眞を見に行つた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつ君は鎌倉へ移る？",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年前と今との氣持の相違を書いて後半の追憶に移るのは自然ではあるが積極的な意味を持つてゐる譯ではない。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、彼女達の一家がこちらへ引移る前にしばらく仮泊していた品川の若木屋という旅館へ電話をかけて見ようと思って、彼女は近所の出入の酒や食糧品を売っている武蔵屋へ電話を借りに出ようとした。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸がどきどきしたものだ」と、さらに他の号外に移る。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本も東京辺では四月末から五月初めへかけて色々な花が一と通り咲いてしまって次の季節の花のシーズンに移るまでの間にちょっとした中休みの期間があるような気がする。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴動に移るけはいは多分に加わった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は單にこの獨斷を掲げるにとどめて、次に「戰爭」の批評に移る。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の魂の一部分あるいは全部がそれに乗り移ることなのだ」　喬はそんなことを思った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて実に抜け目なく観察していて、人にその気配が兆すと見るやたちまち逃げ足に移る。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或｜場処は路が対岸に移るようになっているために、危い略※が目の眩くような急流に架っているのを渡ったり、また少時して同じようなのを渡り反ったりして進んだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間に日影の移る一寸一寸、一分一分、一厘一厘が、政元に取っては皆好ましい魔境の現前であったろう歟、業通自在の世界であったろうか、それは傍からは解らぬが、何にせよ長い長い月日を倦まずに行じていた人だ、倦まぬだけのものを得ていなくては続かぬ訳だった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて元子の形状や大きさはどんなものかという説明に移る前に、これらの元子の種別の多種多様である事を述べている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　第四巻に移るに当たって、私は以上の三巻を取り扱って来た私の紹介の態度と方法に多少の変更を加える必要を感じる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、中学校から高等学校へ移るまぎわに立ったときに、なんの躊躇もなく生涯の針路を科学のほうに向けたのであった。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安の圧迫がとれて貴重な静穏に移る瞬間である。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわいもない幻影を追う目がガラス棚のチョコレートに移ると、そこに昔の夢のビスケット箱の中のメールコーチが出現し、五十年前の父母の面影がちらつき、左団次の知盛が髪を乱して舞台に踊るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあくびというのがやはり緊張から弛緩へ移るときに起こる生理的現象であって、とにかく顔面をゆがめ、声は出さなくても呼気を長くつき出し、そうしてぽろぽろ涙をこぼすのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
