        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "佐久間勝政も、飯之浦で福島市松、片桐助作、平野権平、脇坂甚内等の勇士が槍先を並べてかかるのを、兵四人までを切落して戦ったが、遂に斬死した。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "亦四条隆資は、河内等の野伏の混成隊を以て、生駒山方面の敵を牽制して居る。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天氣がよければ家内等は、運び來つた濡れものゝ仕末に眼の廻る程忙しい。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子が邪魔をすればするほど、ここにふみ止まって、京子の策略と戦い、倭文子を取り返す事は、男らしい態度だと思われたので、彼は時々新聞のよろず案内等で、下宿の広告を注意しながらも、川辺家を去る心はなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "塾生中の主なるものは掛川の宮崎健斎、上田の小島｜順貞、対馬の塩田｜良三、弘前の小野道悦、福山の内田養三、斎木文礼、岡西養玄、家守某、備中国松山の柳井柳仙、久留米の平川｜良衛、棚倉の石川良宅、上野国高林の松本文粋、新発田の寺崎某、山形の志村玄叔等で、其他猶津山、忍、庄内等の子弟があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎本軍弾丸尽き、却いて福島一渡尻内幾古内等を保有す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "高木市助が、参っておろうが、此奴に、すぐ、大砲の引出し方を命じて、肱岡に、吉井、土持、山内等が将曹へかかる」　高崎は、静かに、だが、決心と憤慨とに充ちた口調で、こういった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平春嶽や、中根靱負（雪江）や、橋本左内等の福井藩の主従が、此間に経過した苦悩を、身を以て感じることは、固より出来なかつたであらう。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又目前に橋本左内等の事を見聞きして来てゐるのである。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日には、平民新聞社と堺、幸徳、西川、石川、竹内等五人の家々に、一齊搜索が行はれました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側には、司馬家の親戚をはじめ、生前、剣をとおして親交のあった各大名、旗下の名代が、格に順じてズラリと居流れ、反対の側には、喪服の萩乃、お蓮様を頭に、峰丹波、岩淵達之助、等々力十内等重立った門弟だけでも、四、五十を数えるほど並んでいる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今晩の問題ではないが、ホンの一二例をいうと、たとえば河内・水内等という語である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぐひすや内等の者の食時分　　　　黙進　この句を読むと直に蕪村の「うぐひすや家内揃うて飯時分」を思い出す。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう二つ並べて見ると、「内等の者の」は「家内揃うて」よりも表現が不束なように思われる。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを眺めている内に、彼の秘密好きな性癖がさせた業であったか、咄嗟の間に、彼は池内等のあとを尾行してやろうと決心した。",
              "citation": {
                "source": "蟲",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく彼はその辺にあまたある記念碑の――打見たところは公民たるものの所行の記録を奴隷どもの前に示すのを恥づるかの如くにも土の下や色さまざまな苔や下草などの内等にかくれてゐるあまたの記念碑の面に、ありし日の栄誉の名残色褪せゆく記録を漁り歩くことに専念しはじめた。",
              "citation": {
                "source": "吸血鬼",
                "author": "ジョン・ポリドリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちらのような貧乏タレにゃ、そんなことはしとれゃせんのじゃ！",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（洋傘直し、洋傘直し、なぜそうちらちらかきねのすきから農園の中をのぞくのか。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははは、別嬪さんの、お前さん、手ばかりが、あすこで、真白にこうちらつく工合は、何の事あねえ、さしがねで蝶々を使うか、活動写真の花火と云うもんだ、見物だね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "川面には薄い靄が流れて、列び茶屋にはもうちらちらと提灯の火が揺らめいて見えた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうちらっと思いながら素早く話を他にそらした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、おれはここが気に入ってるからな、そうもいかんのだ」「給料高いからね、うちらの親父どもが、貧乏人からしぼりとってるおかげで」と、服部が笑う。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず三人のうちらしいな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍の者に照れくさいので、私が本を読んでると、「よう勉強してじゃがのう、うちらすぐ頭が痛うなるけえどな」「勉強じゃありませんよ、別に」　と私は本を閉じて、火鉢のかげにかくす。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく……」　うちらに微かな衣ずれの音があって、やがて扉のかけがねがコトリと音をたて、そして入口が静かに開かれた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょいと見ると、そこに一｜軒うちらしいものの形が、夜目にもぼんやり見えました。",
              "citation": {
                "source": "山姥の話",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方を遅く立ちましたから、月岡へ泊れば少し早いなれども丁度｜宜いのを、長い峠を越そうと無暗に峠へ掛りますると、松柏生茂り、下を見ると谷川の流れも木の間より見え、月岡の市街を振返って見ると、最うちら／＼灯のつく刻限。",
              "citation": {
                "source": "敵討札所の霊験",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お公卿さんの生れの方はうちらと違ふてゐやはるわ。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い菫―げんげ―が、もうちらほら咲いてゐる。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い菫―げんげ―が、もうちらほら咲いている。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
