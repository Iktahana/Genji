        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ジイドのように、いい年をして尚個体を先頭に立ててのたうちまわり、悪あがきをする、時々まるで十七八の少年を見るような熱狂ぶりを見せたりするが、これが作家の本当の姿ではないだろうか。",
              "citation": {
                "source": "枯淡の風格を排す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばマルクス・アウレリュウスのごとくローマ皇帝の位、すなわち政治のど真ん中にいても、心はその世界が嫌でたまらず、のたうちまわりながら、その世界から逃避しようと、彼の中の「知識」は叫びつづけている。",
              "citation": {
                "source": "知識と政治との遊離",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるスタイルとフォルムがのたうちまわりながら、はてしもなく展開する。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身からチューリップ色の汗を流してのたうちまわり、夜も昼も絶叫して、阿鼻叫喚のうちに悶死した。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "抵抗しがたい暴力がのたうちまわり、住民の生活をはねとばし、直線の大道路をひきまわし、しかも何一つとして完成させないで、突然その狂暴な力は虚脱した。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
