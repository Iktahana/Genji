        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だがもし果してさうだとすれば、反對にこれは憂ふべき現象であり、教育上の由々しき大問題であると思ふ。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に自分が「憂ふべき現象」と言つたのはこのことである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが眞に憂ふべきことは、かうした間ちがへたイデーによつて、子供をより善く教育できると考へ、その眞に「憂ふべき現象」を以て、却つて逆に「悦ばしい現象」と考へてるところの、日本の大人や教育者たちの思想である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし果して今の子供が、さうした眞の童話精神を喪失し、フアンタジイの夢を持たなくなつてしまつたことから、却つてその種の物への冷笑的態度を示すならば、正に大いに憂ふべき教育上の問題である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる教育は、文化の衰滅を招來するところの、憂ふべきデカダンスの教育ではあるけれども、斷じてその健全なる向上を計るものではないのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "單にその通用的便宜のために、疾患を疾患として放任し、惡に則つて惡を準用する如きは、一國文化の將來を憂ふる者の、斷じて贊與しないところであらう。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と私は答へて『たゞ無用なる吾等が、徒らに貴下等を煩はすのを憂ふるのみです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に貴下が、吾等を救はんとて、強いて危險を冐すが如きは、吾等の深く憂ふる處なり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『未だ實見はしませんが、御覽の通り、海面から餘程高いあの屏風岩の尖頭にも、海草が打上げられた程ですから、秘密造船所の内部は無論海潮の浸入のために、大損害を蒙つた事でせう、それが何か憂ふ可き事の原因となるのですか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れ実に憂ふべき現象に非ずや。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "心動いて而して色変ずる者は、其の将に敗れんとするを憂ふる也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂ふれば血壓は低くなる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂悒の義の「いぶせし」は氣噴狹しの意にして、憂ふる者の氣噴は暢達寛大なる能はざるの實に副うて居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　身から出た錆西　身は身でとほる　東のは※花外より到るにあらず、災星多くは自ら招くを云ひ、西のは、口あれば食はざること無く、肩あれば衣ざること無く、憂ふる勿れ身あれば即ち活くに足るとなり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ茲に此の事件に關聯して予のひそかに憂ふること二三あり。",
              "citation": {
                "source": "無題",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "又見よ、かの中央｜亜弗利加の黒奴がすなる如く、吾人の足に接吻しては礼拝幾度か低頭し、ひたすらに吾人の愛顧の衰へざらむことを憂ふるものは英吉利にあらずや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に又た、「頼襄論」の著者が文学嫌なることは兼ねて之を承知せり、而して其文学嫌なる原因は、世の中が華文妙辞を弄ぶを事として、実際道徳に遠かるを憂ふるに出でたる者なることをも承知して居たるなり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」邦家の事｜曷んぞ長舌弁士のみ能く知るところならんや、別に満腔の悲慨を涵へて、生死悟明の淵に一生を憂ふるものなからずとせんや。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の如き性を有つこと多ければ終身｜惘々として煩ふ所なく、想ふ所なく、憂ふる所なからむ。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "根岸庵時代の寧ろ愛すべき敬すべき無邪氣な小さな功名心は後に至つては甚だ憂ふべき現象を呈したやうである。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる事あるごとに、我は前の日には必ず氣遣ひ憂ふる習なりしが、アヌンチヤタに對する戀は我に彼友に抗する心を生ぜしめき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナルドオが姫を得んと欲せしは卑陋なる色慾にして、縱ひ渠一たびその願の成らざるを憂ふとも、渠は月日を費すことなくして、その失望を慰めその遺憾を忘れしならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡生王傳へ聞て極て憂ふ。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、一切の明日を憂ふ勿れ、今日、始末せよ、そして「兵士の歌だ――今日は黒パン、明日は白パン、――セント・ジオゲネスの樽を夢見よ。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはさうと、わたしは当今、不図した機会から、思ひも寄らぬ三崎の町に、たつたひとりで住むことゝなり、誰の竦毛を憂ふる心配もなく、ほろゝん――の唄をおもひ出し、春の波に溺れようとしてゐるのである。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわたしは、その水車小屋に附属する少しばかりの田畑を持つてゐたので、米や麦や大豆との交換で、酒樽は常に憂ふるところもなく満々として、大概の力持にも持ちあがらなかつた。",
              "citation": {
                "source": "書斎を棄てゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ふことは、決して労働組合主義者や、社会主義者や宗教家のみが憂ふることではない。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の女の誰か自らその色好を知らざるべき、憂ふるところは自ら知るに過るに在り。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる苦き枕頭に彼は又驚くべき事実を見出しつつ、飜へつて己を顧れば、測らざる累の既に逮べる迷惑は、その藁蒲団の内に針の包れたる心地して、今なほ彼の病むと謂はば、恐くは外に三分を患ひて、内に却つて七分を憂ふるにあらざらんや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と娘の旅の者を、人柱に捕えたということを聞いたが、さては――」「サ、われらがうれうるもそのこと。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
