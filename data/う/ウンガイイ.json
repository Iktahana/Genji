        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なるほど運がいいのう、旦那、どうも有難うごぜえます。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙の父親の話によると、こうやって虎狩に来ても、いきなり新しい足跡を見付けるなんぞというのは余程運がいい方で、大抵は二三日｜麓の農家に滞在させられるということだから、これはことによると、今晩は出て来ないのではないかな。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟あなたの御運がいいので……何しろ結構で御座いました」　というような会話が如何にもまことしやかに取り換わされます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に、おいしい食べ物をくれて、「お前さんは、ほんとうに運がいい人だよ。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて運がいいんじゃろね、何もないお前さんが、一日で大金持ちになるんじゃから。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも信次郎は運がいいのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "話のたねに一度聞いて置きたいと思うのですが、運が無いのか、まだ聞いたことがありませんよ」「聞いたところで、運がいいと云うわけでもあるめえ」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京ちやんは運がいいぞ。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが……全く、運がいいと云うもんですよ。",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生、運のいい野郎だ」　コロリで死んで運がいいとは何事かと、一座の人々はおどろいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、天罰と云うのか、運がいいと云うのか、年造はコロリに罹って、善八が召し捕りにむかった時には、もう死んでいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこの事件の犯人はよほど運がいい奴か、さもなければよほど狡猾な奴に違いありません。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも亡くなったこの子のおかあさんが、この子の運がいいように何かいい名前をつけようと、三日三晩考えぬいて、病気になって、いよいよ目をつぶるというときに、かすかな声で、「ああ、やっと考えつきました。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしいつも運がいいのよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おめえは未運がいいといふもんだ！",
              "citation": {
                "source": "霜",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時世時世で、金があっちからころがりこんで来るってこともあるもんで、その道に居合わせた者は、運がいいというだけさ。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ほんの一寸、深雪と、二人きりになれたと思や――一体、運がいいってのか、悪いってのか、月丸が、この山に登っているなんて、何んかの引合せだ――八郎太様の、御手引だ――やっつけろ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、よっぽど運がいい若者だ」　と、トラ十はエンジンのところにすわりこんで、ひやかすようにいった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一人は「運がいいように。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私が来ると顔を上げ、よく慣れた手付で罎の頸を叩き折り、「運がいいように！",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは運がいいよ」と、みょうなことをいった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子は夜明に生れたから運がいいと、そうお祖父さんは仰言ったんですよ。",
              "citation": {
                "source": "同胞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今日は運がいいぞ、畜生！",
              "citation": {
                "source": "競馬",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど大別すると、大量に魚を釣りたい、その目的のためには他人の迷惑も顧みない、という人と、釣れぬでもよし、若し釣れれば運がいいのだ、一日水に親しんだだけで何の不足も感じない、という気持の人との二種になるようである。",
              "citation": {
                "source": "釣場の研究",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどうまく、その老人が眠っているところを見つけるなんて、自分はよほど運がいいのだと喜びながら、ハーキュリーズはしのび足で彼の方へ近づいて行って、彼の腕と脚とをつかまえました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好夫人　　宅は、それや、隊長には運がいいんですの。",
              "citation": {
                "source": "写真（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルカージナ　この人はね、いつどこへ行っても運がいいのよ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日もやっぱり運がいいように。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつは運がいい。",
              "citation": {
                "source": "停車場で感じたこと",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、運がよかったんです」「運がいいとはなんのことだ」「近来になく手配りが早かった。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
