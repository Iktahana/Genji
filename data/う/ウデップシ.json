        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで、庄太の近所にいる腕っ節の強い男を味方にたのんで、人間も犬も一緒に片付けてしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝるためしは先代未聞のことなり」　そして更に、これは今の武士が武芸を怠った為に、足軽が数が多く腕っ節が強いのを頼み、狼藉を働くのであって、「左もこそ下剋上の世ならめ」と憤慨して居る。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に一番物を云うのは、腕っ節だ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っ節ばかりで、世間は渡られねえぞ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "式作法は稲荷の兄いに教わったかも知れねえが、あの度胸骨と腕っ節は、まさか教わりゃしねえだろうねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時、いちばん物をいうのは腕っ節だ！",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っ節ばかりで、世間さまは渡れねえぞ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎助　（今まで黙っていたが）腕っ節だとか駆引きだとか、そんなことをいっていちゃ限りがねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺あ腕っ節は強くはねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「といったら腹もたつだろうが、町方を預かっている者は、一に目学問、二に耳学問、三に度胸、四に腕っ節というくれえのもんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "囲碁の勝負なら驚かないが、腕っ節の試合となった日には、俺に勝ち目はないからなあ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは年の割に腕っ節が強く、自分でも武蔵坊弁慶の再来であるなどと威張っている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社および社長のためを思って、あれほど固く口止めをしておいたのに）　と思うと、野田は腕っ節が鳴りだすように感じた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私の見つけた電子本の腕っ節は、なかなか強そうで頼もしい。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ腕っ節の要る仕事なんだ」「そんなら、お前さんの船は同盟罷業じゃないんですね？",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの連中は腕っ節も強いし、頭もあって確かりした手合だが、どうだい君も仲間に入らないか」　と彼は膝を乗りだして、一段と低声になって、「ところで、こうした闘いは一遍にどっと勝を占めてしまわねばならん。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "力仕事に馴らされた岩佐の腕っ節が気持ちのわるいほど固く締めつけた。",
              "citation": {
                "source": "お菜のない弁当",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅幇とは、強盗、無頼漢等にて成り、その仕事も直情径行的に頗る荒っぽくやっつける方で、青幇には一度この紅幇の仲間に入って実務でウンと腕っ節を叩き上げたものがその大多数を占めて居る。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の方に好意を寄せていない群集の好奇心から来たものなのか、或は、自分より幾倍も強そうな相手の男の腕っ節から来たものなのか、或は、人だかりのしてる街路のざわめいた物影から来たものなのか、何れとも分らなかったが、兎に角それがどっしりと彼の心へのしかかってきた。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に腕力沙汰に及んだこともあるが、彼の強い腕っ節にかなう者はなかった。",
              "citation": {
                "source": "狐火",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っ節の続く限り何にでもぶつかってゆくんだ。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや世を詛い、時を憤る、元気の盛んな、かつ腕っ節の強い連中が、一方にはたまたま免れて、不義の富貴に太平楽を極めこんでいるものの、あるのを見ましたならば、ついにはとって活きるの道に出るようになるのも、実際やむをえない自然の成り行きであったでありましょう。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その問は、彼がドーヴァーのロイアル・ジョージ旅館で初めて知り合って、その後その時よりは親しくなっていた、例の腕っ節の強い、荒っぽい、赭い顔の婦人、プロス嬢★の発したものであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神武天皇から原子爆弾まで、腕っ節の強い者が偉いとされてきた。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っ節の強い供の者を出してやったあとで、源三郎を討ちとろうという計画だったのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "角に待つ連中は、声をひそめて、「あれで、泰軒先生は、腕っ節のつええばかりが能じゃアねえんだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おわい屋になるには、腕っ節が強く、肥桶をかつげる肩と腰があり、正直であればいいので、おわい屋が聖徳太子を知らないとしても一向差支えない。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達の胃の腑が腕っ節よりも弱かったか？",
              "citation": {
                "source": "敗れて帰る俺達",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父の安兵衛は正直者で御しやすいが、甥の吉太郎は頭も腕っ節もできているので、容易に手を下しようがないため、三人殺しの罪を背負わせて、平次に処分させようとしたのが重三郎の重大な錯誤でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そこで途中の藪でその腕っ節で貝が殺られるのか、そうは子供をあやすようにはまいらぬ。",
              "citation": {
                "source": "舌を噛み切った女",
                "author": "またはすて姫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
