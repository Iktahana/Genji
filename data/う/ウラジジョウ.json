          "literary": [
            {
              "text": "誰かが裏事情を正確に知り、陰謀を阻止するために動いている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "マザロフは裏事情を知らずに手紙を受け取りました。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、ホテルにつきました」第三十九章　敵の寝ぐら　再会を果たした二人は、裏事情を知る由もなかったが、差し当たりサーンス伯爵夫人を恐れる必要がなくなった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラスゴウ部長は裏事情に通じており、楽しんでいる風だ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラスゴウ部長を除き、私は誰よりもロンドン裏事情をよく知っています。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
