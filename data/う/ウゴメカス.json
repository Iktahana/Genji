        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何に致せ、古来学者を閉口させた平猴をコルゴと定めたは、予の卓見と大天狗の鼻を蠢かす。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "から騒ぎ騒ぐ野次馬、安価なる信仰家、単純なる心の尊敬すべき凡骨、神経の鋭敏と官能のデリカシイとに鼻｜蠢かす歯の浮くような文芸家はいるが、人生に対する透徹なる批判と、纏綿たる執着と、真摯なる態度とを持して真剣に人生の愛着者たらんと欲する人は無い。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに戴くと胃吉や腸蔵がどんなに怒るか知れません、だがしかし大層好い匂いがしますな、非常に香しくってさも美味そうな匂いが」と頻に鼻を蠢かす。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、この大騒動のまっただ中へ、耳を聾するばかりの轟々たるエンジンの地響を打たせ、威風堂々と乗り込み来たったのは、豪猪の如き鋭い棘を蠢かす巨大なる野生｜仙人掌をもって、全身隙間なく鎧いたる一台の植物性大｜戦車。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛虫の毛を逆立て芋虫の角を動し腹を蠢かすさまの恐しきを思えば、庭上寧ろ花なきに如かず。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分、こいつを見て驚かなかった日にゃ」　自分の仕事のように、鼻を蠢かすガラッ八。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "この風に七分の帆を張れば、明日の夕方までには海上三十里を渡いて見せまっしょ……と自慢まじりに鼻をうごめかすのであった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻にかける」という表現は、前の「鼻うごめかす」というのと同じような心理状態から出て来るものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近い例を挙げましても今までに出て来た……　……鼻をうごめかす……　……鼻にかける……　……鼻じろむ……　……鼻であしらう……　……鼻っ張りが強い……　……鼻毛が長い……　というような感じの中一つでも眼や口に出来るのがありましょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に自慢高慢に到っては、鼻にかけてうごめかすより他にかけてうごめかし処が無いのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『そら見給へ』と、裸男低き鼻うごめかす。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩人とも當時盛んに遠足したればこそ、今日の元氣もあるなれと、裸男ひそかに鼻うごめかす。",
              "citation": {
                "source": "粕壁夜行記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日まで舞台に躍る操人形のように、物云うも懶きわが小指の先で、意のごとく立たしたり、寝かしたり、果は笑わしたり、焦らしたり、どぎまぎさして、面白く興じていた手柄顔を、母も天晴れと、うごめかす鼻の先に、得意の見栄をぴくつかせていたものを、――あれは、ほんの表向で、内実の昨夕を見たら、招く薄は向へ靡く。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、おわかりかな」　その相談所長は、そう言って鼻をうごめかすのであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄貴、細工は流々、この通りだ」　がんりきは社前のところへ腰をかけて自慢そうに鼻うごめかすと、七兵衛も同じように腰をかけて苦笑い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "食品原料の特質を殺し、形を変え、色を変じ、味を別にして、一見一喫して、なおかつ、なんの原料によってつくった料理であるか、素人には容易にわかりにくいものにし、得意の鼻をうごめかすふうがある。",
              "citation": {
                "source": "日本料理の要点",
                "author": "――新雇いの料理人を前にして――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんずく、錦明宝という剣葉畝目地白覆輪の万年青をなめずらんばかりに大切にし、どこの町端の『万年青合せ』にも必ず持って出かけて自慢の鼻をうごめかす。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とう／＼やつて来ましたね」と、彼奴がへんに利口ぶつて、得意の鼻をうごめかすかと思ふと、もうその顔つきを浮かべたゞけでムシヅが走つた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとうやって来ましたね」と、彼奴がへんに利口ぶって、得意の鼻をうごめかすかと思うと、もうその顔つきを浮かべただけでムシズが走った。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、独りで将棋を指すときは、盤の向うに相手がいるかのように、一手一手について感心したり、へこたれたり、大いに自慢の鼻をうごめかすかと思うと、相手の立場になって嘆いたりした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うまいのねえ、ちいちゃんは」　お民は感に耐えたように、「あたしおお袖のとき、どうしてもうまく集まらないのよ」「せんはもっとうまかったわ」　おちづは鼻をうごめかす。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
