        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "荷物を、運転手と僕とで運び入れて、運転手と助手とが帰つて行くと、僕一人になつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手は子供を叱るので大忙しであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手に抱へられて、店屋の軒にやられた時、彼は「Ｓ子が来てやあしないか……？",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下の森田屋の前で、運転手と助手とが羽根をついている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手と火夫とが、船頭に何か冗談を云って、朗かに笑った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手がハンドルを握った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手も火夫も、鋭い表情になって、機械に吸い込まれてしまった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等あ」　ブリッジを歩きまわっていた、一運（一等運転手）は、コーターマスターに云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で待っていたお客に対して運転手が一々丁寧に、どうも気の毒だが御覧の通り一杯だからと云って、本当に気の毒そうに詫言を云っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分それらの御客と運転手とはお互いに「人」として知合っているせいであろう。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では運転手は器械の一部であり、乗客は荷重であるに過ぎない、従って詫言などはおよそ無用な勢力の浪費である。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私自身も郵便を投函する必要のあるとき自動車の運転手に「郵便函があったら留めてくれ」といおうか「ポストがあったらストップしてくれ」といおうか、どっちがよくわかるだろうかと咄嗟に迷うことがある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして月給取も店員も運転手も職工も小僧も女事務員も町娘も女給も仲居もガソリンガールも一緒になって踊っているのは何と美しく善いことだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全地帯に立って見ていた二、三人連れの大学生の一人が運転手の方を覗き込んで、大声で、「ソートーなもんじゃー」と云った。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手は苦笑しながら、なおも、ゆるやかに警笛を鳴らした。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "背広服の運転手や車掌はなんとなく電車内の空気をなごやかにする。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔北欧を旅行したとき、たしかヘルシングフォルスの電車の運転手が背広で、しかも切符切りの車掌などは一人もいず、乗客は勝手に上がり口の箱の中へかねて買い置きの白銅製の切符を投げ入れていたように記憶している。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時運転だからコースが変わったのかと思っていると、運転手が突然「オーイ、オイ、冗談じゃあないよ」とひとり言を言ってぐるりと車を引き返して呉服橋のほうへあともどりした。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある電車運転手は途中で停車して共同便所へ一時雲隠れしたそうである。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると運転手にも人間味が出て来るから妙である。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと一度引くには引いたが、運転手は聞こえないと見えて停車しないでとうとう通り過ぎて行った。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青梅街道を志して自分で地図を見ながら、地理を知らぬ運転手を案内して進行したが、どこまで行ってもなかなか田舎らしい田舎へ出られないのに驚いた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手が橋の上で車を止めて通りかかった老爺に、何が釣れるかと聞いた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところで天幕生活をしたらさぞ愉快であろうといったら、運転手が、しかし水が一滴もありませんという。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "がた／＼の古馬車と、なたまめ煙管をくわえた老馭者は、乗合自動車と、ハイカラな運転手に取ってかわられた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者はトラックの運転手をしている。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車も免許取だから、運転手台へ、ポイと飛び上ると、「急げ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――背中を一つ引撲く勢ひだから、いや、運転手の飛ばした事。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一｜行五｜人と、運転手、助手を合はせて八｜人犇と揉んで乗つた、真中に小さくなつた、それがしの顔色少からず憂鬱になつたと見えて、博士が、肩へ軽く手を掛けるやうにして、「大丈夫ですよ、ついて居ますよ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちを　すすむのは　１だいの　ばしゃで、　うんてんしゅは　マグレガーおじさん、　わきには　よそいきの　ぼうしを　かぶった　マグレガーおばさんも　いました。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
