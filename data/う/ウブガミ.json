    "definitions": [
      {
        "index": 1,
        "gloss": "guardian deity of pregnant women, newborn babies and one's birthplace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
