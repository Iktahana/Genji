        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "家の裏戸が明いて早起きのおかみさんが掃除を始める、その箒の音がこれに和する。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、弥助のおかみさんが、裏戸口から、「いわしをおくれ。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ丈ならば夢として不思議に思ふことでも何でもないが、裏戸を開けた壁の外側の圍も無い處に一人の病人が寢臺のやうな物の上に臥せつて居るのである。",
              "citation": {
                "source": "竹の里人〔三〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は、思ってはいないのだね、僕が気が狂っているとは……」　私がブランディの壜を裏戸棚にしまっていると、彼がこう訊いた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでホームズは素早く小さな路次に飛びこみ、木戸を開けて、荒廃した空地を通りぬけ、そして一軒の家の裏戸を鍵で開けて、その中に入り、また後からその戸を閉めた。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は裏戸の陰に聚まつて雜談に耽つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうえ處他人に見られたらどうしたもんだえ」側からいはれて「見てやあしめえな」と其女房は裏戸の口から庭の方を見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは直に自分の裏戸口に立つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はさういふ夜に褞袍を被つて他人の裏戸口に立たねば成らぬ必要な條件を一つも有つて居ない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏戸口の※の木の下に据ゑられた風呂には牛が舌を出して鼻を舐めづつて居る樣な焔が煙と共にべろ／＼と立つて燻りつゝ燃えて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎが手桶を持つた時勘次は裏戸の垣根口にひよつこりと出た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると又「何してけつかんだ」と勘次は裏戸口から一｜同を驚かして呶鳴つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯平は口の内で呟いて裏戸口へ廻つて見たら其處は内から掛金が掛つて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は又裏戸の口へ行つて見たが、掛金には栓を※したと見えて動かなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "博勞の娘らしい十三四の子が裏戸から南瓜を抱へてはひつて來た。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貴が誰だ／＼といひながら裏戸へ出るとばた／＼と五六人で遁げ出す足おとがした。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸になつたまゝがらつと裏戸を開けて風呂場へ駈けて行つた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此葵は夏になれば屹度こゝに咲くので裏戸が開け放してあれば往來からでもすぐ目につく。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺は裏戸口の風呂で暖まる。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つ又は手持不沙汰にして居たがやがて裏戸口から小便に出る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "小室の小笹裏戸覗いて　裏から帰る紺の前掛　麻裏草履あなた一人に情立てましよと泣いてわかれた　小室の小笹裏戸覗いて　裏から帰る紺の前掛　麻裏草履。",
              "citation": {
                "source": "別後",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕ぐれ、ぢつとしてゐると、裏戸があいた、樹明君だ、電球を持つてきてくれた、そしてバツト、そして五十銭玉一つ、さつそく酒を買うてくる、……感泣々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだきに裏戸を叩く声あり。",
              "citation": {
                "source": "小園の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏戸の音夜の夜中に裏戸を叩くことんことんとときたま叩く今夜来るとのたよりはないが可愛男じやないか知ら。",
              "citation": {
                "source": "沙上の夢",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "びんびん棉打て　　畑の茨に　　とろとろ日が照る裏戸覗くはみそもじさまかそなた思へば五分、棉打てぬ　　びんびん棉打て　　畑の茨に　　とろとろ日が照る。",
              "citation": {
                "source": "野口雨情民謡叢書　第一篇",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「攫うも攫わねえも、大たい、婆さんと何のかかわりもねえこった」「ふうん、えらそうに――ようし、覚えておいで――」　どこまで、図太いお三婆だか、そういうと、つと、立ち上ったが、裏戸に行って、水口の雨戸を開けようとする。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、正面に立っている古着屋らしい一軒の家の、裏戸が幽かに開けられたが、その際間から手が現われ甚内を二、三度手招いた。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戸を破るより仕方がない」そこで彼は全力を集め、裏戸へ体をぶっつけた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「驕慢」に音づれしなが獲物をと、うらどふに、えび染のきぬは、やれさけ、笏の牙も、ゆがみたわめり。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「驕慢」に音づれしなが獲物をと、うらどふに、えび染のきぬは、やれさけ、笏の牙も、ゆがみたわめり、又、なにものぞ、ほてりたるもろ手ひろげて「樂欲」にらうがはしくも走りしは。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
