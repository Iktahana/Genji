          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "勢ひがあまつて彼が縋りつく椿の幹、青竹、野生桑の枝、モチの幹等の夫々の一個所は、日毎の樽野の手触りで公園の運動器具のやうに不自然な艶を帯びてゐた。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』彼はまた、遊星は運動器官をもたないから自分で動くことはできないと言っている。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて、恰幅がよくて、運動好きのこの先生は、広い校庭に遊動円木や、廻転塔など、つぎつぎに運動器械を据えつけて子供を喜ばせていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その見知らぬ女の人は私の手をとって、いろんな運動器具に乗せてくれたりした。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一けんの店では、いろいろの運動器具をならべ、のきさきに写真などをかけていました。",
              "citation": {
                "source": "考えこじき",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
