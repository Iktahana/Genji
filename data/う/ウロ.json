        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "視線がウロウロするのだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の売出しごろには舞台の背景に巴里の場末の魔窟を使い相手役はジゴロ（パリの遊び女の情人）に扮した俳優を使い彼女自身も赤い肩巻に格子縞の Basque という私窩子型通りの服装をして彼女の唄の内容を芝居がかりで補ったものだが、このごろは小唄専門のルウロップ館あたりへ出る場合にはその必要は無い。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルウロップ館ではまだ晴やかで広すぎる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、七五郎だね」　「あッ、おッ母ァ」　「七五郎、今頃まで何処をウロウロしてたんだい。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も旅から帰ったばかりで、お半にも逢えねえ中に、旅に出るなァ辛えだろうが、なーに、半年も経ちゃ、ほとぼりもさめるだろう」　その時、児分の一人、表から来て、　「親分、変な野郎が五六人、先刻から、表をウロウロしていますが、何かあるんじゃありませんか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近の通り　三次走って来て三四郎を見失ってウロウロして居ると、一方、道から五六人ばたばたと逃げて来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっき、このあたりで、ウロウロしていたじゃありませんか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　入口で、眼をウロ／＼やりながら、慄えている、よごれて蒼い支那人を指さした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎尚も大声で、Ｔ「離縁じゃ、今日限り離縁する」　下ではウロウロして居ります。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤでも黴臭いものを捻くらなければ、いつも定まりきった書物の中をウロツイている訳になるから、美術だの、歴史だの、文芸だの、その他いろいろの分科の学者たちも、ありふれた事は一通り知り尽して終った段になると、いつか知らぬ間に研究が骨董的に入って行く。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をあまりに長く伸ばしていると、あるいはウロンの者として吠えられるかもしれないから、あれほどいやだった床屋へも精出してゆくことにした。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら大目付様がウロタエさっしゃっても、手がかりも足がかりもない立派な人間に疑いをかけさっしゃる筈はないが……扨は松倉十内がうろたえたかな……」「ええッ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "六人の人がこのまわりをウロウロしている。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の声はいゝ、コウロギはまだをさなく、キリギリスはいゝ。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間の永遠の秘密だ……』　15　その夜ドリアンはナルポウロ家の夜会に出席したが遉に心は鉛の如く重たく沈んで少しも浮き立たなかった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何んの爲に的もなくウロ／＼歩き廻ツたかを疑ひながら長屋の總門を入ツた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "その底無しの無邪気な、神々しいほどの美しさが、誰の目にもたまらない魅力を感じさせたので、さもなくとも悪戯好きな村の若い者は皆申合わせたように「マユミ狩」と称して、夜となく昼となく深良屋敷の周囲をウロ附いたものであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このパウロの句でも無かった事には、僕の論旨は、しどろもどろで甘ったるく、甚だ月並みで、弟妹たちの嘲笑の種にせられたかもわからない。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パウロに感謝だ、と長兄は九死に一生を得た思いのようであった。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の売出しごろには舞台の背景に巴里の場末の魔窟を使ひ相手役はジゴロ（パリの遊び女の情人）に扮した俳優を使ひ彼女自身も赤い肩巻に格子縞の Basque といふ私窩子型通りの服装をして彼女の唄の内容を芝居がゝりで補つたものだが、このごろは小唄専門のルウロップ館あたりへ出る場合にはその必要は無い。",
              "citation": {
                "source": "ダミア",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
