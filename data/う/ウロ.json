[
  {
    "uuid": "aff2cead-2829-5c07-bc5d-5ee1f9ab593a",
    "entry": "迂路",
    "reading": {
      "primary": "うろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
