        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "また左舷へ帰って室へはいって革鞄から『桂花集』を引っぱり出して欄へもたれて高く音読すると、艫で誰れか浮かれ節をやり出したので皆が其方を見る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮かれ節（浪花節）より他に芝居小屋に連れて行ってもらえなかった私が、たった一人で隠れてカチュウシャの映画を毎日見に行ったものであった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍談、落語、音曲、操り人形、声色、物真似、浄瑠璃、八人芸、浮かれ節、影絵など、大もの揃いで、賑やかな席である。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　出方の藤吉が、幸七へあわただしく囁いて、「つぎは浮かれ節の花坊主だが、知らせてようがすね。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　楽屋で弥助を摘んでいた浮かれ節の花坊主が、口いっぱいに頬張ってもごもごさせながら、「はい。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、夜になると仲仕の兼助の手引きで松島へ「浮かれ節」を聞きにいったり、くるわへ繰込んだりするひとかどの通人気どりだった。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "義太夫を浮かれ節と間違えた連中の気には入らずとも、真の義太夫好きは襟を正して聴いたものだ。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
