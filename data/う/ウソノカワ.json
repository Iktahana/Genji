        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "商売上で少し筋の悪い品を買って、飛んだ引き合いを食いそうになったから、ちっとの間どこかへ姿を隠すんだと云うから、一昨々日からこうして隠まって置いてやると、そりゃあ丸で嘘の皮で、市ヶ谷の女と心中しそこなったんだということを今初めて聞いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫を放った云うて、嘘の皮じゃ。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に誰が言い出したのか知らないが、ここの家に祟りがあるなどというのは嘘の皮で、祟りどころか、かえって福の神が宿っているといっても好いくらいだ。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俯仰天地に恥じないなぞと言ってる安宅先生の言葉は嘘の皮だ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫を捕りに来たなどというのは嘘の皮で、市野はここで女を待合せていたのかと、僕はひとりでほほえんだ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが流れて行くときに一匹の白い蛇が巻き付いていたという評判で、それは善昌の魂だなどと云い触らす者もありましたが、なに、それはみんな嘘の皮で、むかしの人はややもすると斯ういうことを云い触らす。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐をつかまえるなんていうのは嘘の皮だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは嘘の皮であつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「犬に食われたなんて嘘の皮だ。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目にここの家の戸をたたいたのは、貴様が冗談に庄五郎の声色を使ったのだということだが、そりゃあ嘘の皮で、やっぱり本物の庄五郎が引っ返して来たに相違ねえ」「いえ、それは……」と、藤次郎もあわてて打ち消そうとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の新聞を一頁よめば、到るところに、永年の嘘の皮が剥げて現れた醜い事実がさらけ出されています。",
              "citation": {
                "source": "美しく豊な生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの元首相ポアンカレー、外相ブリアン、英国の労働党外相ヘンダアソン等の嘘の皮が骨までひきはがれた。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもふとしたはづみで私はすつかりその嘘の皮をぬぎました。",
              "citation": {
                "source": "九州より",
                "author": "――生田花世氏に",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅から来て、新選挙地に草鞋をぬぎ、土着になるのを意味するのだときいたが、嘘の皮で、その前日にも打合せに来ている。",
              "citation": {
                "source": "議事堂炎上",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の雑音の方が高いのですから……電流が来ているなんて云ったのは嘘の皮です。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は後年に至て大老｜井伊掃部頭は開国論を唱えた人であるとか開国主義であったとか云うような事を、世間で吹聴する人もあれば書に著わした者もあるが、開国主義なんて大嘘の皮、何が開国論なものか、存じ掛けもない話だ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャワなどとは嘘の皮で、一八七六年八月七日、オランダの Leenwarder 町に生まれた。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、果実としてのバナナは元来そのいずれの部分を食しているかというと、実はその果実の皮を食しているので、これはけっして嘘の皮ではなく本当の皮である。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると女は、日本橋のさる老舗の娘などと言ったのは嘘の皮で、じつはこうやって方々の貸家を移り歩いてはにせの小判を造っている女悪党だとのことだった。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが来て見ると、本当は一つもないんです、頭から尻まで嘘の皮なんです。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝七　ハハ、いや、ねえ先生、いつか役人や技師が来て農村でも工業を大いにやらなきやならんと学校で何度も演説してさ、学校の先生達も馬鹿に力コブを入れてゐなさつたが、あんな事も嘘の皮だね。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさえつけておいて嘘の皮をひンむいて見せないと、木津さんなんてひとは、どんな化かされかたをするか知れたもんじゃないから、二人に追いついて、「ちょいと志貴子さん」と声をかけると、志貴子のやつ、びっくりしたような顔もしないで、「うち、志津子……まちがわんといとうわ」とすらりと受流したものなの。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも君は私に対してはもう敬意なんかもっていないようだけれどね――私がフリーダに一こと二こといってやれば、それで君があの子をひっかけた嘘の皮をはぐのに十分なんだ。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外※　探偵とは嘘の皮　その翌日。",
              "citation": {
                "source": "黒襟飾組の魔手",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外見は事実だが、内面から見ると嘘の皮です！",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチェリーナはすぐそれに対して、『為を思って言った』なんて嘘の皮だ、現につい昨日まだ故人の遺骸がテーブルの上にのせてあるのに、家賃の催促で自分を苦しめたではないかと『やりこめ』た。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "因果応報なぞというのは嘘の皮である。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫物なんて嘘の皮さ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、遷化するとか、京の六角堂へ参籠するため、夜ごとに通っているなどということも」「嘘の皮さ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男はうそをついたことでしょうし、もし私がそのうそを否定することに成功したなら、そのうそのかわりに新しいうそをつくというふうに、いつまでもつづいたことでしょう。",
              "citation": {
                "source": "流刑地で",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
