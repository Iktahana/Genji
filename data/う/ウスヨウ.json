    "definitions": [
      {
        "index": 1,
        "gloss": "thin Japanese paper (esp. vellum paper)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
