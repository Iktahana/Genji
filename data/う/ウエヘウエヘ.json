        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三階の廊下から見上げた山腹の各旅館の、明るく灯のともつた室々の障子の列が上へ上へと暗い夜空の上に累積してゐる光景は、龍宮城のやうに、蜃氣樓のやうに、又ニユーヨークの摩天樓街のやうにも思はれた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにもあくどいところやうるさいところがなくて上へ上へと盛り上がって行くような全篇の構成を観賞しつつ享楽することが出来るようである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一羽が逃げ出して上へ上へと階段を登って行く。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふら孑孑のようだわね……あれから、上へ上へと見霽の丘になって、段々なぞえに上る処……ちょうどここと同じくらいな高さの処に、」　振袖姿は、塚と斜めに立っている。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……茶町という旅館間近の市場で見たのは反対だっけ――今の……」　外套の袖を手で掲げて、「十貫、百と糶上げるのに、尾を下にして、頭を上へ上へと上げる。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行ってまいります」と、お姫さまは言って、すきとおったあわのように、かろやかに、水の中を上へ上へとのぼっていきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お城のほうへ、何度も何度もキスを投げてから、青い海の中を上へ上へとのぼっていきました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人魚のお姫さまは、そのものたちと同じように、自分のからだも軽くなって、あわの中からぬけ出て、だんだん上へ上へとのぼっていくのを感じました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんのからだは、だんだん、上へ上へと、ひきあげられていきました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処をどう歩いて、ドンナ事を考えて来たかわからないまま、熱病患者のようにヘトヘトになっている彼自身の身体と頭を、無理矢理に上へ上へと押し上げながら……　鉄梯子の上の写真製版室から真白い光明が、眼も眩むばかり射出されていた。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ上へとはしゃぎ出そうとする氏の都会的な陽性を、どうしても底へ引き込む陰性なものがある。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これで俺も助かるらしいぞ、猿に助けられるとは不思議なことじゃ）　大塚の身体は刻々に上へ上へあげられた。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐喜の浜の鍛冶の母を呼うで来い」「佐喜の浜の鍛冶の母……」　その声が止まると上へ上へあがっていた狼が樹から離れて、その周囲を廻りだした。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の路を一人の旅人は、上へ上へと登りながら前の方を見ますと、円い膨らみのある山が重なっておりました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人は途方にくれましたが、後へ帰るにしても人家のある処へは、一里ばかりもありますので、暗い路を足探りに探って、上へ上へと登りました。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕はとにかく、上へ上へと這い上った。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、何かおぼしめしがある、そんなもったいないこと」「へい、これは、どうも」「そうじゃ」　蛇は上へ上へと登って、やがて微紅い嫩棄に覆われた梢に姿を隠して往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ上へと、雲のなかまでとんでいきました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの上へ上へとのぼるなれど、路あしからねば車も行きなずまず。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は誰をもあとにして、その勾配の高い土手を一散に上へ上へとのぼつて行つた。",
              "citation": {
                "source": "草みち",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍事のあった現場へは目もくれようとしないで、人波をよけよけ通りぬけながら、土手について河岸っぷちを上へ上へとどんどんやって参りましたものでしたから、急にさま変わりをしたのは伝六です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "その舟も同じように、艫音を急がせながら、忍びやかに大川を上へ上へとのぼりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえに、舟はいっせいに上へ上へと前後して川をのぼりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも知らず、七艘の不思議な舟は、不思議な女をひとりずつ乗せながら、艫音をころして岸伝いにひたすら上へ上へと急ぎました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一目散に庭を横切り笹籔に覆はれた土堤を上へ上へと兎のやうに伝つて庚申堂の裏手に達した。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは我がちに帽子の中へ手を突っ込もうとするのだが、令嬢はそれを上へ上へと持ち上げて、力いっぱい揺すぶっていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ上へと少しづつ落葉を掻いて來てはそれを續けてゐると、やがて幅四尺に縦三尺位、厚さ五寸位の落葉の板のやうなものが出來上る。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えたり動いたりしているうちに、蛇の塀をわたるように頭から尾まで波を打ってしかも全体が全体としてだんだん上へ上へと登って行く、もう敵塁だ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "上へ上へと吊り上げられて行ったものが、禁止で、下へ下って一般生活の質の向上としてひろがって来るかといえば、どうもそういうことには行かなそうである。",
              "citation": {
                "source": "その先の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其故、上へ上へと積上げた空間のそのまた平面を、最少限の面積で、最大限の能率に活かすアパートメント経営者の、才覚にほかなりません。",
              "citation": {
                "source": "よろこびの挨拶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
