        "副詞-と",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "carelessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試験対策をうかうかしていると、合格は難しい。",
              "source": "幻辞"
            },
            {
              "text": "この状況を甘く見てうかうかしていると、後悔することになるだろう。",
              "source": "幻辞"
            },
            {
              "text": "彼はうかうかと三年間を過ごし、気づいた時には仕事が見つかっていなかった。",
              "source": "幻辞"
            },
            {
              "text": "病気の予防をうかうかしていると、重い症状に進行する可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "投資の世界ではうかうかしていると、資産を失う羽目になる。",
              "source": "幻辞"
            },
            {
              "text": "大切な書類をうかうか忘れていては、事業は成り立たない。",
              "source": "幻辞"
            },
            {
              "text": "娘がうかうかと恋人に会っていると、親としては心配せざるを得ない。",
              "source": "幻辞"
            },
            {
              "text": "危険な天候をうかうかと過ごしていると、災害に遭う可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "学生時代をうかうか遊んで過ごすと、後で大変な思いをする。",
              "source": "幻辞"
            },
            {
              "text": "会社の経営危機をうかうか傍観していては、倒産は避けられない。",
              "source": "幻辞"
            },
            {
              "text": "彼女との関係がうかうかしていると、すれ違いが生じやすくなる。",
              "source": "幻辞"
            },
            {
              "text": "環境問題をうかうか見過ごしていると、取り返しのつかない状況になる。",
              "source": "幻辞"
            },
            {
              "text": "この機会をうかうかと逃していると、二度と来ないかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "患者がうかうかと医師の指示を聞き流していては、治療は成功しない。",
              "source": "幻辞"
            },
            {
              "text": "政治をうかうか放置していると、民主主義は蝕まれてしまう。",
              "source": "幻辞"
            },
            {
              "text": "契約書をうかうかと読まずにサインするのは危険である。",
              "source": "幻辞"
            },
            {
              "text": "子どもの教育をうかうかと他人任せにしては、成長は期待できない。",
              "source": "幻辞"
            },
            {
              "text": "技術トレンドをうかうかと見過ごしていると、競争力を失う。",
              "source": "幻辞"
            },
            {
              "text": "安全装置をうかうか無視していると、事故は必ず起こる。",
              "source": "幻辞"
            },
            {
              "text": "人間関係の悪化をうかうかと放置していると、修復は難しくなる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それだのにこれに備うる事もせず、また強い地震の後には津浪の来る恐れがあるというくらいの見やすい道理もわきまえずに、うかうかしているというのはそもそも不用意千万なことである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、うかうかとそういうものに頼って脚下の安全なものを棄てようとする、それと同じ心理が、正しく地震や津浪の災害を招致する、というよりはむしろ、地震や津浪から災害を製造する原動力になるのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、診察の順番を待つ間――一時間近く――うかうかとその場景に見入って居りました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしうかうかしていると、色々な妙な思想がフィルムの形になって外国から続々入り込んで全国に燃え拡がるのは事実である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいかにも面白いのでうかうかと二、三十章を一と息に読んでしまった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつかしい顔をして聞いていた父は、「阿呆が、うかうかしよるせに、他人になぶり者にせられるんじゃ。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事をうかうか考えている自分を発見すると同時にまた、現在この眼前の食堂の中に期せずして笑い上戸おこり上戸泣き上戸｜三幅対そろった会合があったのだという滑稽なる事実に気がついたのであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして付け焼き刃の文明に陶酔した人間はもうすっかり天然の支配に成功したとのみ思い上がって所きらわず薄弱な家を立て連ね、そうして枕を高くしてきたるべき審判の日をうかうかと待っていたのではないかという疑いも起こし得られる。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなゆがめられた歓喜の日をうかうかと送っているうちに、私は、いままでいちども経験したことのない大事件に遭遇したのである。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭一君は木のぼりがじょうずで、よくその木にのぼっていて、うかうかと、知らずに下を通ったりすると、つばきの実を頭の上に落としてよこして、おどろかすことがありました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの道理をよく聴きわけて、必らずうかうか短い一生をあだにすごすではないぞよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの道理をよく聴きわけて、必らずうかうか短い一生をあだにすごすではないぞよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ちょっと伺いますが、吉原では何という遊女屋が有名ですか」　ついうかうかと考え込みながら見返り柳の辺りまで来た時に、斯う後から訊く者があった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの宝を持っていながら、なにをうかうか他所ばかり見て、無暗に宝を探しあぐねていたろう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上つい、うかうかと維摩の話をしてしまいましたが、肝心の話は私たちがもし病苦に攻められたとき、どう自分で慰めたらいいかという問題であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に心に留めもせず、何の気もなくなると、つい、うかうかと口へ出る。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬ振か、実際それとも、面を蔽うたので認めなかったか、心付かない様子で通過ぎたの、トお千世が袂を曳いたのに、葛木は宙を行くように、うかうかと思わず別れた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、笠ぐるみ振分けを捲り手の一方へ、褌も見える高端折、脚絆ばかりの切草鞋で、片腕を揮ったり、挙げたり、鼻の下を擦ったり、べかこと赤い目を剥いたり、勝手に軒をひやかして、ふらふらと街道を伸して行くのが、如何にも舞台馴れた演種に見えて、巽はうかうか独笑してその後に続いたのである。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわけで……枕の色も、閨の姿も、これは、一定さもあるべきを、うかうか聞くのであったから。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――身近な処から顔見知の人たちに、真三は、うかうかと聞き廻る。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――処をこの度の文づかい、泥に潜った閉門中、ただおおせつけの嬉しさに、うかうかと出て参ったが、心付けば、早や鰭の下がくすぽったい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって愛想気もない婆々が許でも、お休み下さりますお人たちに、お茶のお給仕をしておりますれば、何やかや賑やかで、世間話で、ついうかうかと日を暮しますでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟と聞きながら、うかうかと早や渡り果てた。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかうかと入って見ると、こはいかに、と驚くにさえ張合も何にもない。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、ほかに心当りもなく、自然あの人の足はうかうかと下鴨なら下鴨へ来てしまう。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、ふだんそんなことを考えもしないくらい、無邪気な人形となって、うかうか暮しているのが、舞妓というものだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖いほど速く年月が経つと、おたかがふと義枝の年数えてみると、うかうかと二十九だった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度も彼女は陶酔したように、うかうかと乗って、松島の最後の要求だと思えば、出してやらないわけに行かなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は少し我慢さえすれば、親爺は何でも言うことを聞いてくれ、小遣いもつかえば映画も見て、わがままなその日が送れるので、うかうかと昼の時間を暮らすこともあり、あまり収入のよくない朋輩に、大束に小遣いをやってみたり、少し気分がわるいと見ると、座敷を勝手に断わらせもした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は気軽に言ったが、母の柔らかい言葉のうちにひしひし胸に突き当たるものが感じられ、その場ではうかうか聴き流していたが、正味をつまみあげてみると、子息とお前とは身分が違うとはっきり宣告されたも同様だと思われてならなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
