[
  {
    "uuid": "feca9554-6205-517b-b0b5-ffb8e73c78d3",
    "entry": "うかうか",
    "reading": {
      "primary": "うかうか",
      "alternatives": [
        "ウカウカ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
