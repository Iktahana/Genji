      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clouds and haze",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "雲霞のような蝗虫の発生があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の外から北の方、まるで雲霞の軍勢だ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霞の如き將士あり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の赤蜻蛉、これがまた実におびただしいもので、秋晴の日には小さい竹竿を持って往来に出ると、北の方から無数の赤蜻蛉がいわゆる雲霞の如くに飛んで来る。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霞のごときわれわれに、表現を与えて呉れた作家の出現をよろこぶ者でございます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもまた雲霞のごとく後から後から押し寄せるのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百八十九村の民、雲霞の如く集まりて、其死を見送る。",
              "citation": {
                "source": "宗吾靈堂",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京には、地方から上って来る純真なもの、生き生きしたもの、又は充実したものを取って喰う商売人が、お互に爪を研ぎ、牙を磨いて、雲霞の如く待ち構えている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはその組合の仕事の標準となるべきもので、非常に厳密な且つ巧妙な手段に依って作られたものだそうだが、その結果、あの雲霞の如く浅草に押し寄せる人々は、平均三人で五円の金を持っている事がわかった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り拂ひて行かんとすれば；またも寄せ來る新手のつはもの；蹈み止りて戰はんとすれば寄手は雲霞のごとくに集りて、幾度跳ねても拂ひつくせず。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の赤蜻蛉、これがまた実におびただしいもので、秋晴れの日には小さい竹｜竿を持って往来に出ると、北の方から無数の赤とんぼがいわゆる雲霞の如くに飛んで来る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のたびは泰然としてはかなふまじと、神澤子帽をぬぎ、時計、紙入、蝙蝠傘を我にあづけ、身構いさましく、エイヤツト聲はかけねど、人を割て入りたれども、雲霞の如き大勢、叶ひ難くや、消息いかにと氣遣ふ間に、早くも列車は笛を鳴らして立去れば、取り殘されし數百千人、烟をながめて茫然たり。",
              "citation": {
                "source": "寧樂",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっさいをこんなふうに清算なさいまして深山の雲霞の中に紛れておはいりになりましたあとのわれわれ弟子どもはどんなに悲しんでいるかしれません」　と播磨の僧は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、如何にも「雲霞、あと遠山に越えなして／＼、いく関々の道すがら、国々過ぎて」来たやうに、肉づきの悪い青年だつた。",
              "citation": {
                "source": "金春会の「隅田川」",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのタローガッタの音は、初めは荒野をさまよう生活の音のようだったが、それが漸次に地にひれ伏す呻きのように陰に籠り、太い遠吠えの底おもくうねる波となり、草叢を震わせる絶え絶えな哀音に変ったかと思うと、押し襲ってくる雲霞の大群のふくれ雪崩れるような壮大な音になった。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霞のような味方の大軍に対して、戦った所が、仕方はありません。",
              "citation": {
                "source": "英雄の器",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「左様でございますか、一寸と塾の者にも見せとう御在ますと云て、塾へ持て来て、「如何だ、この原書はと云ったら、塾中の書生は雲霞の如く集って一冊の本を見て居るから、私は二、三の先輩と相談して、何でもこの本を写して取ろうと云うことに一決して、「この原書を唯見たって何にも役に立たぬ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコでもう日本人を掌の上に乗せて、不自由をさせぬように不自由をさせぬようにとばかり、桑港に上陸するや否や馬車を以て迎いに来て、取敢えず市中のホテルに休息と云うそのホテルには、市中の役人か何かは知りませぬが、市中の重立た人が雲霞の如く出掛けて来た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "我等の顔は、雲霞の如き前途の希望に輝いた。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、裏長屋の軒並から――大江戸の隅の隅のどぶという、溝の近所から、急に発生き出した、毒虫のように、雲霞のように飛び出して来た。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霞のごとき、魚群を、いくたびとなく蹴散らしながら、全速力をつづけること小一時間、「三角暗礁が見えます」　と、オルガ姫が知らせた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲霞のような原地人軍は、ついに前方五千メートルの向うの丘のうえに姿を現した。",
              "citation": {
                "source": "人造人間戦車の機密",
                "author": "――金博士シリーズ・２――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に立ったは来島十平太で、後に続いたのはゴルドン大佐、そうしてその後から雲霞のように続々として現われ出でたのはゴルドンの引率した二十人の兵と、十平太の率いた二百人の武士、しめて二百二十二人、日英同盟の勇士達であった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この凄まじい太刀風にまたもや土人軍は退却したが、その時忽然地下道を震わせ轟然たる大音響が鳴り渡り、それと同時にその時まで雲霞のように集まっていたオンコッコ軍が数を尽くしバタバタと地上へ転がった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有栖川宮熾仁親王を征東大総督に仰ぎまつり、西郷隆盛参謀、薩長以下二十一藩、雲霞の如き大軍は東海東山、北陸から、堂々として進出した。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に盆地を巡っている丘の、すぐの向こう側にもその衆徒が、雲霞のようにいるはずである。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山に隠れて雲霞を友として生きている仙人を無用意に驚かすことは心なき業である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一番に偵察者がやって来て、そのあとに雲霞のようにおびただしい月人隊がおし寄せるのかもしれない。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今まで雲霞の如く城壁にいた大軍は、掻き消すように見えなくなった。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで日々に信者が集って念仏に帰する者が雲霞の如く群って来る。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
