        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "日本の固有文化は外国人には一体に分かりにくい。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてドレスデンの國有文庫に殘つてゐた自家に關する古文書の中に旗手クリストフ・リルケの小さな記録を發見すると、彼はいまだ騎士道の衰へなかつた頃のその若い祖先と一體にならんとした。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して以前の窮屈な室へはいった時には、なんとなく学者の私有文庫を見せてもらうような気がした。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが時の精錬器械にかかって渾然とした一つの固有文化を形成するまでには何百年待たなければならないことか見当もつかない次第である。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも日本固有文化の精粋がアメリカの香のする近代文化に押しのけられて行く世相の一つであるとも言いたくなるくらいのものである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、近来わが国固有文化に関する研究が急激に盛んになって来たのに気がついて、愉快に感じると同時に自分も知らず知らずその趨勢に刺激されて、つい柄にない方面にまで空想の翼を延ばしたくなったようなわけである。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなればわが国の映画製作者でも批評家でも日本固有文化に関心をもって、これに立脚して製作し批評しているらしい人は少なくも自分の目にはほとんど見当たらないからである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その誤謬とは国民的民族的意識の喪失と固有文化への無関心無理解とであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は万葉から元禄までのあらゆる固有文化を消化し総合して、そうして蒸留された国民思想のエッセンスを森羅万象に映写した映像の中に「物の本情」を認めたのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頷聯の「元知郢国音難和、況復鳳雛毛有文」に父子が称へてあつて、三は冬旭の詩を言ひ、四は其子の書を言ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三椀捜枯腸、惟有文字五千巻。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子自身は有文事者、必有武備と申して居る位で、文弱一點張りの人ではない。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、具視は千種有文と相談して、宮中のご不自由のほどを、幕府からきている権力者に見せるがために、富小路敬直に伝えて主上の御膳を運び去る時、お肴一盤とお酒一瓶を拝領させて置いて、これを千種有文から酒井所司代の用人三浦七兵衛の手を経て若狭守忠義に送った。",
              "citation": {
                "source": "にらみ鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが京都方にも、公武合体の意見を抱いた岩倉具視、久我建通、千種有文、富小路敬直なぞの有力な人たちがあって、この人たちが堀河の典侍を動かした。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "中山｜大納言、菊亭中納言、千種少将（有文）、岩倉少将（具視）、その他宰相の典侍、命婦能登などが供奉の人々の中にあった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "――日本の文化水準は一般的に、最近｜頓に停頓して来たし、特に又日本固有文化は決定的な衰退の途を、もはや引きかえすだけの勢をもっていない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "無文字、唯刻木結繩、敬佛法、於百濟求得佛經、始有文字、知卜筮、尤信巫覡。",
              "citation": {
                "source": "隋書倭國傳",
                "author": "魏徴",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月下旬、千種有文の家来賀川｜肇を襲撃した中にもいたというし、つい先頃の足利尊氏の木像｜梟首事件にも、関わっていたという風説がある。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな自棄を云うもんじゃないよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「構うもんか、入ろう、入ろう。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことまで何のかんの云うもんか。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分を見るや泣き声を絞って、何だってもう浮いていたんですものどうしてえいやらわからないけれど、隣の人が藁火であたためなければっていうもんですから、これで生き返るでしょうか……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがリアリストというもんかな？",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多なことを云うもんじゃあないよ」　眼で知らされて、熊蔵はあわてたように口を結んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い者のこった、ちっとは面白いこともなけりゃあ稼ぐ張り合いがねえというもんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かまうもんか、ひっぱたいたれ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿、――五十三にもなって、人間が、自分の子供のような娘をどう思うもんか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことを云うもんじゃないわ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽なんか云うもんか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑うもんじゃありませんよ。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
