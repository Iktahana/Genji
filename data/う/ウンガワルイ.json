        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "運が悪いと頭を一つ位ポカと喰らせられる。",
              "citation": {
                "source": "井戸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とミハエルは答えた　――博覧会もあと一週間きりですが、運が悪いとこれっきり晴れずにしまうかも知れませんな。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "委任統治のテニヤン、ヤップ、パラオ、サイパンはもちろん、時々は赤道直下のオーシャン付近からオーストラリヤ近くまでも延しますが、もちろん冒険ですから、運が悪いとやられてしまいます。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "由兵衛はよくよく運が悪いと言わなければならない。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で聞いてみると「旦那さまのために三日月様に祈っておかぬと運が悪い」と申します。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたがいに運が悪いんだから仕様がない」　お絹は崩れるように蒲団の上に俯伏すと、お君は声を立てて泣き出した。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツヤ子さんのお父さんは「ツヤ子の運が悪いのです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運が悪いと、ゆうべは夜ふけまで隣りの杵の音にさわがされ、今朝は暗いうちから向うの杵の音に又おどろかされると云うようなこともあるが、これも一年一度の歳の暮れだから仕方がないと覚悟していたらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでここにもうひとつ妙な事には、この因果なテンダー機関車にまことに運が悪いと言いますか、宿命とでも言うのですか、十年近くもの永い歳月に亙って、機関車が事故を起す度毎に、運転乗務員として必ず乗込んでいた二人の気の毒な男があったんです。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もその女は気立ても悪くないものですから、いっそ世間に知れないうちに相当の仮親をこしらえて、嫁の披露をしてしまった方がいいかも知れないなどと、親たちも内々相談して居りましたのですが、思いも付かないこんな事になってしまいまして、つまり両方の運が悪いのでございます。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "運が悪いと云えば、まあそれ迄のことですが、何か又そこに理窟がないとも云えませんね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "運が悪いというほかに、なにかの仔細が無いとも云えねえな」「それだから、わっしの鑑定はまあこうですね」と、幸次郎は少しく声を低めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だか知らないけれど、皆な運が悪い。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はどうしてかう亭主運が悪いんでせう。",
              "citation": {
                "source": "花が咲く",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は敢えて運が悪いという。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに運が悪いとなると、あの片目の雌鴨みたいなのさえ居るんだからなあ。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんは、「やはり、短い名前の子は運が悪いというのは、ほんとうだ。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょんさんの弟は、「ちょんさんの落ちたのは名前が短くって、運が悪いからだ。",
              "citation": {
                "source": "長い名",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "男運が悪いのはお前も同じことじゃないかのと云う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこっちの手落ちだった事は一度もないんだが、不思議に運が悪いんだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に運が悪いと思っている」「然し、運が悪い所ではないじゃないか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右内は如何に御運が悪いとて、八百石取のお身の上が、人も通わぬ山中の斯様な茅屋に住っておいでになるのか、お情ないと気の毒そうに上って来ました。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "富子は肚の中では、どうしてかう宿六運が悪いのだらう、今度はあの絹川といふ色男のところへ押かけてみようか、いつそ社長のハゲアタマの二号に押しかけてみようか、色々と考へてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのカンカン寅が、人殺しの嫌疑でお上に捕ったと聞いたときは、どうしてわしゃ、こうも運が悪いのかと、力もなにも一度に抜けてしまってのう」　カンカン寅というのは例の仙太の親分に当る男で、昨夜あの海岸通の古建物で、折井山城の二刑事に捕った怪漢のことだった。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際引越しても輸送がうまく行かないこと、敵弾に当たれば運が悪いとあきらめようという気持、自分のところは大丈夫だという気持などがプラスに動いているらしい。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "運が悪い時は、まさにそんなものですねえ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「万字楼の白妙さんは、かわいそうなことを致しました、ほんとにお気の毒でございますよ、まあ、なんて運が悪いことでしょう」「万字楼の白妙さんが、どうかなすったの」「花魁はまだあれをお聞きになりませんか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
