        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "チューリップや大きな黄色いユリの花は、お年よりの奥さまがたで、みんなじょうずに踊って、舞踏会がうまくいくようにと、気をつけているんだよ」「でもね、お花たちは、王さまのお城でダンスなんかして、だれにもしかられないの？",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなに、うまくいくといいけどねえ。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うまくいくといいけど、」と姉は淋しげに微笑んで、「とにかくそれじゃ、やって見ましょう。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい思い出を持ったこの夫婦は、末永くきっとうまくいくだろう。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、絶対にうまくいくから。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、やはりそれがいちばんうまくいくことを知ってました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、うまくいくつもりですといいました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年こそもう商売のうまくいく自信が持てなくなった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、おれのあげるよ」　やはり、なにもかもがうまくいくわけはない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何回かやれば、うまくいくかも」「よし、じゃ、〈アイル・ゲチュー〉、テイク・ワン」　広岡が右足でカウントして、頭のベースラインを弾く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな商売をしても、うまくいくと思います。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを護りとおすには、三等国以下の科学力で、果してうまくいくでしょうか。",
              "citation": {
                "source": "『火星兵団』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この雛形ならどんなにでもうまくいくというのです。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめつからうまくいくわけはないぢやありませんか。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくいくと、君のお母さんに会えるかもしれませんよ」「えっ、ほんとですか。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし文鳳の方は京都の名所に限られて居るだけにその画景が小さいから、今少し宏大な景色を画かせたらその景色の写し工合が広重に比して果してうまくいくであらうかどうであらうか、文鳳の琵琶湖一覧といふ書があるならば、それには大景もあるかも知れんが、まだ見たことがないからわからん。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、シロとクロだけで、うまくいくでせうか。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくいくかしらと、シロが表からうかゞつてゐますと、そのとたんに、ぱつと何か目をかすめて、次にがら／＼と、戸がしまつてしまひました。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……五年目の終りになって、こんどこそうまくいくと思ったのが間違いで、致命的な問題に突当り、今までの研究は全部だめだと分った。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……たしかに、うまくいくはずなんだがなあ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたして、それはうまくいくであろうか。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙をうかがい、近いうちに、必ずキンギン国を、ばっさりと……）（おいおい、そううまくいくかね。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦田博士も一緒にやっつけてしまわねばならないが、博士はこの頃いつも工場に泊っているそうだから、多分うまくいくだろう。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地中を、あのロータリー除雪車のもっとしっかりしたようなもので、どんどん掘っていったら、きっとうまくいくかもしれない」　一郎は、なんとかして、そういう機械をつくってみたくて仕方がなかった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "多いほど、うまくいくと思うから」「よし。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい」「こういう図面だが、どうじゃ、うまくいくと思うか」　そういって、加瀬谷少佐は、封筒の中から一枚の紙をとりだして、それをひろげた。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくいくかな」　少佐は、手に汗を握っている。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日間｜頑張ると、五千人の人造人間部隊が出来るから、これをもって、イギリス本土への上陸作戦が、うまくいくにちがいないと考えたのである。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにもかも、お芝居のように、うまくいくのね。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とて、じつはこううまくいくとは、思っていなかったのだ。",
              "citation": {
                "source": "人造人間の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
