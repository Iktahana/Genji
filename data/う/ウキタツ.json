        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寒さの隨分嚴しい晩でしたが、しつきりなしに喫かす煙草の烟や、Ｍのお母さんの心添への伊太利亞ベルモットの醉ひに、皆の顏は赤く染まり、何となく座が浮き立つてゐました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、梢を透して林の中の靄が木立ごとだん／＼明るく茜色に浮き立つのを見て行きますと、櫟林はわたくしを中に歩かしたまゝ大地ごと誰かの大きな手で擡げられ、しず／＼宝の方へわたくしを近付かせられるように感じられてなりません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは、火鉢のことにこだはつた時は、丁度、眼前の勝負にかんかんになり過ぎて、気持が焦りに浮き立つてゐた。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉は、浮き立つほど嬉しかった。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼岸桜の咲くとか咲かぬという事が話の問題になる頃は、都でも田舎でも、人の心の最も浮き立つ季節である。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いつかわたしは、相手も忘れて、親しい友達にでもはなすやうに浮き立つた。",
              "citation": {
                "source": "好日の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐いような怖ろしいような、それでいて浮き立つような唆られるような心地がした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、行きついたその吉原は、灯影に艶めかしい口説の花が咲いて、人の足、脂粉の香り、見るからに浮き浮きと気も浮き立つような華やかさでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏がきて、期待で胸をふくらますようなこともなければ、クリスマスの浮き立つような華やかさもない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐いやうな怖ろしいやうな、それでゐて浮き立つやうな唆られるやうな心地がした。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　英則は胸を叩いて浮き立つのであつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は浮き立つた連中とローランドの店へなど赴いて、若しやハメでも外してはならない――と留意してゐた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼女は、しきりとわらひ声をあげながら、見ると、もう私よりも二三間上の坂へ達して、猪のやうなかたちの岩石の影から、「カム・オン／＼――速かに、そして緩漫に……」　などゝ浮き立つてゐた。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらゝかに心も浮き立つ山のけしき、蹈み迷ふたり、あやまてりと、案内の娘の肩をたゝくに、例のむつちり素知らぬ顏にて谷を下り行く。",
              "citation": {
                "source": "山家ものがたり",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母はどこへ行っても、気の浮き立つというようなことはなかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで闇に浮き立つ光の宮だ！",
              "citation": {
                "source": "勝利したプロレタリアのメーデー",
                "author": "――モスクワの五月一日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心がパリ祭だといって騒ぐのに、その日の朝は、矢代は眼がさめても一向に浮き立つ気持ちも起らなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いま少し自分も浮き立つべきだと思ったが、蘆の嫩芽の微風にそよいでいる物静かな沼の光りに、我ながら憎くなるほど落ちつきが出てしまい、却って、千鶴子に対し気の毒な遠慮のある思いさえされて来るのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺近くそそり立つてゐる丘の上には白い灯台が曇つた空へくつきりと浮き立つてゐる。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつくりと昔のやうに盛りあがつた肥りかたではなく、細い静脈の毛管が浮き立つてゐる。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道線に汽車が通るたび、線路添ひのこのホテルは浮き立つやうに震へた。",
              "citation": {
                "source": "暗い花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭から、耳、頤へかけて陰気な部屋の中に、くっきり白く浮き立つ繃帯をして、片方の眼だけ、微かに、白眼を見せて、眠っていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はまた、かうした苦悩の場合のみではなく、反対に心の中が満ち溢れ、幸福と平和とに浮き立つ時も、やはりその喜悦を人に語り共感されたい慾望を覚えるであらう。",
              "citation": {
                "source": "柊の垣のうちから",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴々しい光も、なつかしい色も、浮き立つような物の音も、何一つ楽の無い、あの灰色の墓場の塔へ、私はどうしても行く気にはなれぬ。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清く崇き鐘の音をして花に浮き立つ群衆を散らしめよ。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、もつと明るく、浮き立つ様なものにしたのではないか。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は粕谷か、明日は廻沢烏山は何日で、給田が何日、船橋では、上下祖師ヶ谷では、八幡山では、隣村の北沢では、と皆が指折数えて浮き立つ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ぐらゐ木村の勝利に亢奮し、来年の挑戦を夢みて、すでに心も浮き立つ思ひの者はゐない筈なのであるから。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理もない、この海浜都市が、溌剌たる生気の坩堝の中に、放り込まれようという、今日がその心もうきたつ海岸開きの日なのだから――。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その唄はなんのうたであるか知らなかったけれど、きいていると楽しくうきたつうちにも、どこか悲しいところがこもっていました。",
              "citation": {
                "source": "灰色の姉と桃色の妹",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
