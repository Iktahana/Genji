        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを当の松岡は（これは譬噺で、事実談ではありません）レニンに呆れられているという事にも気づかず、「なんだ、レニンってのは、噂ほどにも無い男だ、我輩の眼光におされてしどろもどろではないか、意気地が無い！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は角力に関しては少しも知るところが無いのだけれど、それでも横綱、男女川に就いては、時折ひとから噂を聞くのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂に拠れば、男女川はその身長に就いての質問を何よりも恐れるそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの噂に拠れば、男女川はひどく弱い角力だそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の廊下には、べたべた推薦のビラが張られて、選擧事務所なども、ものものしく、或るものは校門の下に立つて、登校の生徒ひとりひとりに名刺を手交し、よろしくたのみます、といつて低くお辭儀をして、或るものは、中學校の先輩といふ義理のしがらみに依つて、後輩を威嚇し、饗應、金錢、などといふばかな噂さへ立つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭座といふ名前が「火」の字に関係があるから焼けたのだといふ噂も聞きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭座という名前が「火」の字に関係があるから焼けたのだという噂も聞きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の間では彼等が世間に向つて抱くその野望からの当然の産物として出て来なければならなかつたのは、仲間同志に於ては、その仲間の誰でもを褒めたとも譏つたとも理由の分らない噂――まあまあ噂――さうつまり噂なんだ、それを作り出さんことに閑暇がない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂に依ると、二三日前から――さう、だから彼等の噂に一日と続くものはあんまりない筈である――竹山を辞職させようといふ社長の考へだといふ噂があつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "店へは郷里の新聞が来ているので話はよく郷里の噂になる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから昔の同級生の噂になる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本の近況から漱石師の噂になって昔話も出た。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、楠さんの細君が亡くなり、次にひどく酒飲みになった楠さんも若死をしたこと、亀さんが医師の家に書生をしていて、後に東京へ出て来てどこかの医者の代診をしているという噂を聞いたように思うだけである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば美術や音楽の方面においていわゆる官学派の民間派に対する圧迫といったようなことについて、具体的の実例をあげていわゆる官僚的元老の横暴を語るのであったが、それがただ冷静な客観的の噂話でなくて、かなり興奮した主観的な憤懣を流出させるのであった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそもう、小刀で切つて落さうか、死んだつていい、とまで思ひつめた時に、近所のあの酒飮みのお爺さんの瘤が、このごろふつと無くなつたといふ噂を小耳にはさむ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にも、誰にも絶對に負けぬ完璧の強者なんてのには、いま迄いちども逢つた事が無いし、また噂にさへ聞いた事が無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭座といふ名前が「火」の字に關係があるから燒けたのだといふ噂も聞きました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下界では未だ霜が結んだという噂も聞かないのに、天上の高寒に、早くも洗礼を受けて、甦ったように新しくなった山を見ると、水を浴びせられたように慄となる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この工事を県当局で認可する交換条件として上高地迄の自動車道路の完成を会社に課したといふ噂話を同乗の客一人から聞かされた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあつたが自分達の盆の餅をすゝめて、さうして此人達から新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か其處に來る筈の人――それは多分親分か何かゞ未だ來て居ないのを待遠しがつて噂をして居るらしかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかげで、それまではこの世における颱風の存在などは忘れていたらしく見える政治界経済界の有力な方々が急に颱風並びにそれに聯関した現象による災害の防止法を科学的に研究しなければならないということを主唱するようになり、結局実際にそういう研究機関が設立されることになったという噂である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜警で一緒になった人で地震当時前橋に行っていた人の話によると、一日の夜の東京の火事は丁度火柱のように見えたので大島の噴火でないかという噂があったそうである。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この工事を県当局で認可する交換条件として上高地までの自動車道路の完成を会社に課したという噂話を同乗の客の一人から聞かされた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあったが自分たちの盆の餅をすすめて、そうしてこの人たちから新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この噂がこの社会一般に伝わると、｜No. 11 という数は異様な神秘をもって賭博者流の心を捉えた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし泳ぎの達人であった王は、盾の下で鎖帷子を脱ぎ捨てここを逃げのびてヴェンドランドの小船に助けられたといううわさも伝えられた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた英雄の戦没した後に、こういううわさの生まれたのはいつの世でも同じだと思われる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに永生きをして八十くらいになったら、その時にそろそろマルクス、エンゲルスの研究でも始めるだろうと皆でうわさをすることである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二老人は三十歳前後のころ、ある役所で一年余り同僚であったばかりでなく、石井の親類が河田の親類の親類とかで、石井一｜家では河田翁のうわさは時おり出て、『今何をしているだろう』『ほんとにあんな気の毒な人はない』など言われていたのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
