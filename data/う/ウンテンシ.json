    "definitions": [
      {
        "index": 1,
        "gloss": "(professional) driver (of a taxi, train, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "地廻りの不良も召集され、運転士も幾人か出て行った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさ運転士は南方に氷塊の徴候のあることを報じた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午後になって、かれら船員は代理人を出して船長に苦情を申し立てようとしているということを二等運転士から聞いたが、船長がそれを受け容れるかどうかは甚だ疑わしい。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "迷信という問題に就いて、かくのごとく論究した結果、わたしは二等運転士のメースン氏がゆうべ幽霊を見たということ――否、少なくとも彼自身は見たと言っている事実を知った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリッジの上で、一等運転士ミルン氏と興味ある会話を試みた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その名声も彼が個個の指揮権を托される前に、すでに運転士としての技倆によって獲得したのであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食後、彼は食物がまだどれほどあるかを調べて来るように、わたしに命じたので、早速二等運転士とともに行ったところ、食物は予期したよりも遙かに少なかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで都合三人の証人があるので、二等運転士が見た時よりは、船員の主張がいっそう有力になってきた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "発狂せる船長と、幽霊におびえている運転士との間に、かつて私のような地位に立った者があるだろうか。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも馬鹿にしていたことも、今みずからこれを経験するに及んで、もはやミルン氏の話も、例の運転士の話も、いずれもこれを疑うことが出来なくなったからである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は甚だ暗く――その暗さは、船尾端艇の下に立っていてさえも、ブリッジの上にいる運転士の姿が見えないほどであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこのごろボースンにも、一等運転士にも見込みが悪いことを知っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ」と運転士が慇懃に腰をこゞめた。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のきいた運転士が車をつけたところが、果してそれであつた、彼は門前で車をおりて、右側の坂道を爪先上りに登つて行つた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし有りふれては産婆、看護婦、保姆、タイピスト、女事務員、女店員、見張女、マッサージ師、美容術師、女車掌や運転士、交換嬢、モデル女、女優一切。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等運転士がパイクソン。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らにも最初のうちはよく分らなかったけれど、船長や一等運転士などといろいろ意見を交換し合った結果、これは例の怪人集団の写真だという推定に落付いたんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言って小夜子は永田町へと運転士に命じた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　運転士は車を止めて風の強い叢のなかに帽子を捜したが、しかしそれも物の二分とはかからなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから中二日ほどおいて、ある夕方葉子の二階の部屋に二人いるところへ、女中のお八重が「今運転士さんが、これを持って来て、お迎えに来ました。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして長々と生垣を結い繞らした、木立の陰のふかい××閣の大門の少し手前のところで、小夜子は車を止めさせ、運転士をやって訊かせてみたが、そういう方はまだ見えていないというのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして運転士に方向を指そうとした途端に、四五人の学生はすでに車の周りを取りまいてしまった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芳沢さんってお爺さんのことか」「ううん、運転士。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等運転士のハウオウスがイサドル・ストラウス夫人にボウトに乗り移るように奨めると、夫人は断乎として拒絶して、「ストラウスの傍を離れるのは嫌です。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "レディ・ゴルドンが、「乗っても宜しゅう御座いますか」　と訊くと、ボウトの中から一等運転士のマアドック Mr. Murdock が答えた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時もマアドック運転士は、まるで劇場の前で貴婦人を自動車へ乗せるように、日常的な微笑と口調で手を差伸べてレディ・ゴルドンをボウトへ扶け入れている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアドック一等運転士が素早く切り離すと、ロウプはびゅんと唸って人々の頭上に挑ね返った。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車をうんてんして、ある山｜奥を、夜中に走っていました。",
              "citation": {
                "source": "ばかな汽車",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちを　すすむのは　１だいの　ばしゃで、　うんてんしゅは　マグレガーおじさん、　わきには　よそいきの　ぼうしを　かぶった　マグレガーおばさんも　いました。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、うんてんしゅがいないので、ウマたちはおちつかない、といったかんじでした。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
