        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「狸」でない子がわざとなんだか落着かないような様子をして天井を仰いでみたり鼻をこすってみたりして牽制しようとするなどはきわめて初歩であるので、その裏をかくつもりで「狸」自身がわざとそのような振りをすることもある。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっとも西山君のことだから、言いたい放題をいっているかもしれないが……」　清逸の心の裏をかくとでもいうような言葉がしばらくしてからまた園の唇を漏れた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、視覚の働きの裏をかくアンチエイリアスと呼ばれる技術を使って、文字をなめらかに見せる拡張もほどこされています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はこちらの裏をかくようにあざけりの笑みをくれて、徐かにここを立ち去った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼は、三日の間、夜の眼もねずに、悪魔の巧みの裏をかく手だてを考へた。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏をかく棺桶　田所検事を中心に、会議はつづけられる。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、その裏をかく手も考へられてゐるし、敵に十分の用意をさせて、一挙に殲滅的効果をあげることもある。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の眼をくらましてその裏をかく方便として、泰軒が栄三郎にすすめたのが、この、風流べに絵売りの変装であった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人者は大将が警察犬に凝っていることを知っていて、その裏をかくつもりだったのです。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆はわが身の裏をかくような観念を本能のように持つに至る。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その働きは、人間の理解の裏をかく。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へええ、それこそ聖物箱をねらつてると思われる当人で、わたしが頼まれたのは特にそいつの裏をかくためでした。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "牙は牙と打ち合い、唇は切れて血を流したが、バックは敵の防禦の裏をかくことができなかつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ仕手の裏をかく方法を探っていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "角助は、おれのやり口を知っとるけ、おれの裏をかくかも知れん。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、今日、特に、棚を吊ったのは、敵の裏をかく作戦である。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、皆の期待の裏をかくのが得意である。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれは、ただ不実を罰し不信の裏をかく場合だけにかぎるのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも、ちっとも不可思議ではない検証によってその裏をかくことができるかぎり。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しや敵の裏をかくカラクリ仕掛けがあるんじゃありませんか」　守は曲者の声が聞えなくなると、俄かに妹の事が気にかかって、老探偵を責めないではいられなかった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや、意外の悪知恵をはたらかせて、名探偵の計略の裏をかくようなことはないでしょうか。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小林君を変装させ、殿村探偵を尾行させて、しゅびよく敵の裏をかくことができたのです。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "してその降人を、都督には、どう用いて、曹操の裏をかくおつもりか？",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
