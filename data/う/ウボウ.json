        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "このごろはまた、自意識過剰とかいう言葉のひとつ覚えで、恥かしげもなくほうぼうへそれを言いふらして歩いているようです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あふげば、ぼうぼうたる草むらの山頂で、おほきな白つぽい雲がながれてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には風がながれてゐる、おれは小石をひろつて口にあてながら、どこといふあてもなしに、ぼうぼうとした山の頂上をあるいてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原には、よめな、つくしのたぐひ、せり、なづな、すみれの根もぼうぼうと生えてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原蓬の根がぼうぼうとひろがつてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはきみのわるい畸形の犬がぼうぼうと吠える月夜をぼんぼりのやうに病みつかれて歩いてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路の方で白い犬が、ゆめのやうなミスティックな響をもつてぼうぼうと吠えてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なみなす丘はぼうぼうと、　　　　　青きりんごの色に暮れ、大学生のタピングは、　　　　　　　口笛軽く吹きにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔中秘事雪ふかきまぐさのはたけ、　　玉蜀黍畑｜漂雪は奔りて、丘裾の脱穀塔を、　　　　　　ぼうぼうとひらめき被ふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお黙ってはいたが、コックリと点頭して是認した彼の眼の中には露が潤んで、折から真赤に夕焼けした空の光りが華※しく明るく落ちて、その薄汚い頬被りの手拭、その下から少し洩れている額のぼうぼう生えの髪さき、垢じみた赭い顔、それらのすべてを無残に暴露した。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "またたとえば忠犬美談で甲新聞が人気を呼ぶと、あとからあとからいろいろな忠犬物語がほうぼうから出て来て、日本じゅうが犬だらけになり昭和八犬伝ぐらいはまたたくひまに完成するのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも紙撚だったか藁きれだったか忘れたが、それでからだのほうぼうの寸法を計って、それから割り出して灸穴をきめるのであるが、とにかく脊柱のたぶん右側に上から下まで、首筋から尾※骨までたしか十五六ほどの灸穴を決定する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身では気がつかなかったけれど、よその人から見ると、ずいぶんぼうぼうと髪が伸びて、見苦しく、それだから散髪屋の主人も、私の意向をちゃんと見抜いてしまったのだ、それにちがいない、と私は流石に恥ずかしく思ったのである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、わざとほうぼうのポケットに手をつっこんでみるのだ。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の頼んだ電気屋が偶然最悪のものであったかもしれないが、ほうぼうに鳴らない玄関の呼び鈴が珍しくないところから見ると私と同じ場合はかなりに多いかもしれない。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどアルミニウムだかマグネシウムだかの閃光は光度において大きく、ストロンチウムだかリチウムだかの炎の色は美しいかもしれないが、始めからおしまいまでただぼうぼうと無作法に燃えるばかりで、タクトもなければリズムもない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼が、「ぼうぼう、ぼうぼう、」　赤鬼が、「ぐらッぐらッ、ぐらッぐらッ。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼうぼう、ぼうぼう。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぼうぼう、ぼうぼう。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "草ぼうぼうと茂った庭へ入り込んで、がさがさ騒いだと思し召せ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんでも猫の死骸なら、あすこへ持って行って打棄った奴があるかも知んねえ、草ぼうぼうだでのう、）と私、話をしただがね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、草花は、まるで荒れ野のように、道の上までぼうぼうとおいしげってしまいました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、まるで、森のおく深くみたいに、ぼうぼうとしていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
