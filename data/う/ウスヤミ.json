        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "薄闇が、ただ漾々と身邊に動いてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇い狭いぬけろじの車止の横木を俛って、彼方へ出ると、琴平社の中門の通りである。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其障子が一枚｜開かっていたが薄闇くって能く内が見えない。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇で其形は能くも見えぬが、人に似て人らしく無い。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小沢ははっとして、薄闇をとおして唖の娘の顔を見た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇が、ただ漾々と身辺に動いてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇の濕地にかげをひいてぞくぞくと這へる羊齒植物　爬蟲類蛇　とかげ　ゐもり　蛙　さんしようをの類。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらんとして何もない石畳と絨氈の奥まった薄闇へ、高い窓から射し入る陽の光がステンドグラスの加減で、虹ともつかず、花明りともつかない表象の世界を幻出させている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のなかに寝てゐた薄闇が匂ひもののやうに大気へ潤染んで散る。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は薄闇のなかで鈍く光つてゐる水のおもてを見つめながら、また、引きかへさうかしら、と考へた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は薄闇の水に腰から上だけ浮かした文吉に近寄ると、子供も手伝って文吉は無理やり船へ引き上げられました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "程よい富、程よい名望、三棟の土蔵へ通う屋根廊下には旧家らしい薄闇が漂っていた。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのしたの伽藍の甍半黄になかばほのかに、薄闇に蝋の火にほひ、円柱またく暮れたる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水面なるひと騒擾、さあれ、このとき、驀然に急ぎくる一列の郵便馬車よ、薄闇ににほひゆく赤き曇の快さ、人はただ街をばながむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そがもとに噴水のむせび濡れ濡れて薄闇に入る……空気は重し……なほ赤し……黄に……また緑……いつしかに蒸汽の鈍き船腹のごとくに光りかぎろひし瘋癲院も暮れゆけば、ただ冷えしぶく茴香酒、鋭き玻璃のすすりなき。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞ごろも近づくなべに、うつらかにあかる薄闇。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるものの疲れたる七月の午後、わが瞰望の凡ての色と音と光を圧すごとく、凡ての上にうち湿る「東京の青白き墳墓」ニコライ堂の内秘より、薄闇き円頂閣を越えて大釣鐘は騒がしく霊の内と外とに鳴り響く。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇のほのかなる光のなかに老舗立つひと町は寡婦のごとくわれゆゑに面変り、かくや病みけむ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が生ける間の「明」よりも、今ま死する際の「薄闇」は我に取りてありがたし。",
              "citation": {
                "source": "我牢獄",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "女等が去つてから百姓の手もとが漸く薄闇さを感じた。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "右を見ても左を見ても、灰色の薄闇が、層々と重って居た。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ行手にだけは、右や左や上下などよりも、もっとあかるい薄闇があった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほの／″＼とした光明を包んだような薄闇があった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇の中には、夜も昼もなかった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ薄闇の中を、前途の薄明を頼りにして、必死に辿るより外には、仕様がなかった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "娑婆から極楽へ来る迄の、あの気味の悪い、薄闇の中を通る時でさえ、未来の楽しみを思うと、一刻でさえ足を止めたことはなかった。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薄闇は、普通の夜の暗さなどよりも、ずっと気持がわるかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　銃声が轟然と真夜中の薄闇を揺り動かした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇の向こうに、ちらちらとかすかに人の影が見えるだろうか。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
