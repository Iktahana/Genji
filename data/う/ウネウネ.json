        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "広茫とした穂蓼の草原が、遠く海のように続いた向うには、甲斐の山脈が日に輝き、うねうねと連なっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれば私は心地よく、うねうねの暝土の径を昇りゆく。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その岸に寝た刀禰の川水がうねうねと白く光って通っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その玩具のような可愛い汽車は、落葉樹の林や、谷間の見える山峡やを、うねうねと曲りながら走って行った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江は、どこまでも海のような豊潤さと、悠々さをたたえて、遠く、ザバイガル州と呼倫湖から、シベリアと支那との、国境をうねうねとうねり二千里に渡って流れていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冴みきったよく磨かれた青ぞらで、まっ白なけむりがパッとたち、それから黄いろな長いけむりがうねうね下って来ました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の裾から部落の森の間をうねうねして谷川が流れてゐる。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、開いていた、その黒い戸の、裏桟に、白いものが一条、うねうねと伝っている。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "色がこいとかうすいとか、もようがうねうねしてるとか、まっすぐとか。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだじゅう、ポリプたちは、腕と指とをお姫さまのほうへ、うねうねと伸ばしていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い甍から椎の並木がうねうねと南へ伸びている。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽から這い出て、窓をひらき、うねうね曲って流れている白い谷川を見おろした。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは草や雑木の生えた小藪になっていて、すぐ右手に箱根八里の街道へ脱ける間道があって、それがだらだらとおりて土橋を渡り、前岸の山裾を上流に向ってうねうねと通じていた。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の間になった北斗の七星に白気のようなものがうねうねとかかっていた。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の澄みきった小さな流れがあって、それがうねうねと草の間をうねっていたが、それにはかちわたりの石を置いてあった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両手を前にさし伸べて……手探りをするように身体をうねうねと蜒らして……中心を取りかねているようであったが、そのうちに両手で夜具を押えつけると、スックリと寝床の上に立ち上った。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな山々が限りもなくうねうねと連つて居る。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はたうとう憤慨のバネに撥ぢかれて、あの日に天狗党の末孫から贈られた竹刀に取り縋りながらうねうねと立ちあがつた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れは白く日の光りを泛べてせゝらぎの音もなくうねうねと流れて行手の景色も見あたらなかつた。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬橇はあかるい舞台照明の青さの中をそれは静かにひつそりと走つてゐるのです、たくさんの電信柱の退却または都市建築物のすべてが幾何学派の絵画のやうに渦巻波の雪の道路はうねうねとうす緑の輪廓線に馳けてゆくのです。",
              "citation": {
                "source": "小熊秀雄全集-13",
                "author": "詩集（12）その他の詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども大船に救い上げられたからッて安心する二葉亭ではないので、板子一枚でも何千｜噸何万噸の浮城でも、浪と風との前には五十歩百歩であるように思えて終に一生を浪のうねうねに浮きつ沈みつしていた。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその木立の彼方には、疑いもなく箱根山の一団がうねうねと横たわっていた。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "路はやがて穉樹の林に入って、うねうねと曲って行く。",
              "citation": {
                "source": "新茶のかおり",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その恋心は啻にそこらにひろがつて行くばかりではなく、またそこらにある林や森や丘や川に満ち漲つて行くばかりではなく、うねうねと折れ曲つて行つてゐる丘添ひの道にも、深く泥濘に喰ひ込んでゐる車の轍の中にも、草の葉の上にも、篠笹の葉の末にも、何処にもすべて行きわたらないところはないやうな気がした。",
              "citation": {
                "source": "赤い鳥居",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "お作の小屋は温泉場の裏の斜坂の中央に当たっているので、下にはまずまばらに茅葺屋根、大根の青い畑が連って、その下に温泉場、二階三階、大湯から出る湯の煙、上を仰ぐと、同じ畠の斜坂の爪先上がりになっている間に一条の路がうねうねと通って、その向こうは煙るような楢林の灰色が連続した。",
              "citation": {
                "source": "ネギ一束",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼にかかった板橋を渡ると、細い田圃路がうねうねと野に通じて、車をひいて来る百姓の顔は夕日に赤くいろどられて見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと云ひながら、上体を傾けて、スイスイと頭を突きあげたり、ブルブルツと、幽霊のやうに手や脚を震はせたり、うねうねと体を伸縮させたりした。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "メデューサの髪の毛の蛇が、わたしの皮膚の下でうねうね動いているのが見えましょう。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
