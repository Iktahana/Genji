    "definitions": [
      {
        "index": 1,
        "gloss": "Uzen (former province located in parts of present-day Yamagata Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "文化元年六月には、羽前、羽後に地震があって象潟に海嘯。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩のもの云う」と子供心にも面白くない初同が済んで、「そオれ漢王三尺のげいの剣」という序になると、翁はそれから先の上羽前の下曲の文句の半枚余りを「ムニャムニャムニャ」と一気に飛ばして、「思い続けて行く程に――イヨー。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏日本では、羽前の三瀬から越後の村上あたりまで出て来る海岸路が涼しいところです。",
              "citation": {
                "source": "談片",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "福島駅を離れた汽車が岩代から羽前へ越えようとして大きな峠へかゝる。",
              "citation": {
                "source": "渓をおもふ",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "善吉は羽前の鶴岡に住んでいた人で、明治の初年頃までまだ生きながらえていた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ自分が閉伊郡花輪村という所で発見した狩猟の巻物、山神狩人秘法大事という写本にも、磐司磐三郎の発生地を下野国日光山のその麓としてあるけれども、奥羽地方になると陸前名取郡の磐司磐三郎山（２）をはじめ、羽前の山ノ寺縁起（３）など、その他にも諸所に万治、磐治などの住居した所が散在している。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽前の国の国司に陸奥中納言藤原豊光という人がありました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹原の郷里（羽前）にてはホツピキと称へて正月には今もして遊ぶなりと。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽前水沢駅で降りて半里、私はここの鞍乗りの一箇所へ、炉のある部屋をひとつ自費で建てたくもなって来た。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この平野の、羽前水沢駅という札の立った最初の寒駅に汽車が停車したとき、私は涙が流れんばかりに稲の穂波の美しさに感激して深呼吸をしたのを覚えている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝がた羽前と羽後の山間でわたし等の汽車は、大雪のため永いこと停車した。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折戸（をりと）尾張愛知　上総武射　下野塩谷　羽前西置賜　能登珠洲　越後西頸城　　　折戸（をりど）駿河有渡　越中上新川　越前阪井此等は、降り処で、降り口でなく、降り立つた場所であらう。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十六日、羽前村山郡新庄領の堺田に著き大雨のため宿る。",
              "citation": {
                "source": "支流",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽前庄内邊で「にはない行（？",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "小国川は昔、判官義経主従が都を追われ、越路をめぐって羽前の国の土を踏み、柿色の篠懸に初夏の風をなびかせて、最上川の緑を縫った棧道をさかのぼり、陸奥の藤原領へ越える峠の一夜、足をとどめた生月の村の方からくる源遠き峡水であるから、ここに棲む鰍の味が肥えているのは当然のことであろうと思ったのである。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽前と羽後の国境の岩山から滴りでて、新庄の町の西北を流れる鮭川へも行ってみた。",
              "citation": {
                "source": "姫柚子の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "取りあえず本号には、羽前庄内地方のオクナイ様のことを紹介して、次にいささかこれに関する臆説を述べてみたい。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一つは羽前東田川郡立谷沢村大字木ノ沢の、長南助右衛門氏方のオクナイ様で、同地の斎藤重作君が撮影して贈られたものである。",
              "citation": {
                "source": "オシラ神に関する二三の臆説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙北の俘囚　仙北の名は今は平鹿郡と川辺郡との間にある一郡の称となっているが、もとは広く山の北の義で、羽前境の連山以北、御物川上流の平野を中心とした一帯の地の総称であった。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月山、鳥海山、羽黒山　先ず羽前羽後の古名である出羽に就て一考する必要がある。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山植物の一つであるが、羽前〔山形県〕の飛島に生えているのは珍しいことである。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時忠という人は、そもそも出羽前司具信の孫で、兵部権大輔で、左大臣を贈られた時信の子であったが、故建春門院の兄として、また高倉天皇の外戚として、羽振りをきかせていた上に、清盛入道の北の方が姉であったから、この世の栄華は思いのままであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まず、この京にかくれて平家を窺うもの、出羽前司光信の子、伊賀守光基、出羽｜判官光長、出羽｜蔵人光茂、出羽｜冠者光義。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば羽前羽黒山のごときはそれであり、播州石の宝殿でも近年見たという人があるけれども、現に行って見ても見当たらないし、神官に聞いても知らぬというのである。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一例は羽前の庄内の町にて、毎夜深更になると狸の腹鼓の音がするとて、騒ぎ立てしことがあるに、よくよくただしてみれば、鍛冶屋の鞴の音であったということじゃ。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が羽前の上の山温泉に行きたるとき、旅館の下女の案内にて名高い稲荷に参詣してみた。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "△羽前の象潟　本土に入つては、先づ青森の十三潟と秋田の八郎潟とでありますが、此二つの潟は大きな潟ですが、自分は實地を調べて居りませぬ。",
              "citation": {
                "source": "潟に關する聯想",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一族の中では、羽前の左沢に移住したものは左沢某と呼んでいるが、安芸国に分れて行った家はそのままに毛利家と称しておった。",
              "citation": {
                "source": "名字の話",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、祭日又は季節に基づく名稱節供祭　　　　　　舊三月三日、播磨北條住吉神社たのも祭　　　　　八月朔日、羽前三山神社等つゆの祭　　　　　栗花落祭、飛騨栗原神社等雪祭　　　　　　　正月十五日、信州新野伊豆神社だら／″＼祭　　　　七日間の祭、下總千葉神社など二、祭地祭場　是には明かに二通りの式がある。",
              "citation": {
                "source": "祭禮名彙と其分類",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥後｜阿蘇郡の馬見原も崩崖はあるが、これは諸国に多数ある馬見塚または豆塚などと同じく、信仰より起った地名かと思う仔細があって例証にはせぬ（羽前山形の馬見崎川、常陸の馬見山なども同様である）。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
