        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "汝等祝福されてあるべきなり、其の他はすべて分解しければ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ星に甘え、われ太陽に傲岸ならん時、汝等ぞ、讃ふべきわが従者！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のもと林の中に、たゆけくも　仰ざまに眼をつむり、白き雲、汝が胸の上を流れもゆけば、　はてもなき平和の、汝がものとなるにあらずや",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "海はなが身の鏡にて、はてなき浪の蕩揺に、汝はなが魂打眺む　海は汝が身の鏡にて、と云はれるとなんだか罪でも犯した気持になる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなき浪の蕩揺に、汝はなが魂打眺む……「なーるほど…」と思ふのは、恐らくボオドレエルが私自身より意識的であることに気が付くからである。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等ともに闇くして、且はひめやか。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が底を探りたる、者とてはなく、汝がゆたけき内奥を、知るものとてなかりけり、さまで汝等秘密をば、守らんこと敏なりき！",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　　　（しかも汝とていまは亡し）",
              "citation": {
                "source": "四八　黄泉路",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つて疲れて私の瞼はイラ痒いとは云へ、人よ汝がそのやうなことを気にするのであれば、あゝ、それは世間をばかり心の中に相手として置いてゐるからだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "天日の下に口をあけ汝の過去を哄笑せよ。",
              "citation": {
                "source": "昔の小出新道にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の歴史を捨て去れかし。",
              "citation": {
                "source": "昔の小出新道にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等おのれを愛するが如く、汝の隣人を愛せよ。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝唯一人のそれとも最後の、情人か？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……愛せよ揺籃より柩にまで汝を愛せし者を愛せよ、わが愛したる者のみ独り、今も猶我をば愛す。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "火に充ちし手のナポリの聖女、心菫に泣ける薔薇、聖ギヂルが花、汝は見しや天の砂漠に汝が十字架？",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちよ、白き霊体、燃ゆる汝が空より落ちよ、――地極の聖女はわが目にはいと聖なれば！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠は汝が眼の裡に微笑むでゐた……此の世を去つた炬火、空にて再びともれよ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　惡魔よりも孤獨にして汝は氷霜の冬に耐へたるかな！",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて何物をも信ずることなく汝の信ずるところに憤怒を知れり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて欲情の否定を知らず汝の欲情するものを彈劾せり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて何物をも汝は愛せず何物もまたかつて汝を愛せざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝　寂寥の人悲しき落日の坂を登りて意志なき斷崖を漂泊ひ行けどいづこに家郷はあらざるべし。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『う……うぬ、穢れだ』滿身の怒氣を込めて、身を※くと、無殘、女は胸を一つ突かれて、仰向にばつたり倒れる。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今将棋が面白え処だ、済んでから逢おう、茶でも呑んで待ってろとは何をぬかしやがるんだ」　「うぬは、ど……」　「俺が今日此処へ来たなあ茶を呑みに来たんじゃねえッ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夏もお互に旅先や何かで久しく顏を合せなかつた二人、さて新秋になると、向うは熱海で勉強して大に強くなつたと自｜信を持ち、僕は僕で名人｜决定｜戰の觀戰記を書き棋力に相當加ふるものありとうぬ惚れて、共に張り切つてゐるのだからたまらない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬぼれやの山崎は、自分の欠点を知らなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬが商売で寒い思いをするからたって、何も人民にあたるにゃあ及ばねえ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は知恵でこの動物を気ままにしていると思ってうぬぼれている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬが誇をかすめとらむ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
