          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "色の黒い※野な顔をした田舎武士は、安政乙卯の年十月二日の午後十時、かの有名な安政の大地震に逢って、母を救い出そうとして家の中へ入ったところで、家が潰れて圧死した。",
              "citation": {
                "source": "死体の匂い",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒がすきで、亀の年という甘いお酒（瀬戸物の大きな瓶のかたちの器にはいっていた）をのませたのでその名をよく覚えてしまって、ある時、お前は卯の年、お前は巳の年と年寄りが言っていたらば、「あたしは亀の年。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜ふかくまで痛飮し、文の舍の贈れる兎を煮て、之を食ひつくすと共に、卯の年をも送りぬ。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　卯の年に生れて九星四緑に当るものは浮気にて飽きやすき性なりといへり。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙卯の年晩秋荷風小史第一　日和下駄　人並はずれて丈が高い上にわたしはいつも日和下駄をはき蝙蝠傘を持って歩く。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「明治十二年己の卯の年。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、木性の人は酉の年八月酉の刻に有卦に入り、卯の年まで七年間を吉とし、右七年を経れば八年目より五カ年間は無卦に入る。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿江子が卯の年で年女だからお前に豆をまかせてやってもいいけれど、家じゃ、鬼はーそと！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇、御年｜九十五歳乙卯の年三月十五日崩りたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁卯の年八月十五日崩りたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙卯の年三月十三日崩りたまひき。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は御年九十五歳、乙卯の年の三月十五日にお隱れになりました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天皇は御年八十三歳、丁卯の年の八月十五日にお隱れなさいました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙卯の年の三月十三日にお隱れになりました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒中に草の話をするのも時を得ないが、なるだけ因縁のあるように第一には「雪の下」、次には卯の年だから兎の何々という類の草の名を問題にする。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
