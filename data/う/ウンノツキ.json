        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「一羽でよせばよかったのを、もう一羽と長追いをしたのが運の尽きだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死骸を近所の川へでも投げ込んでしまえばいいのに、同じ寺の古井戸へ運んで来たのが二人の女の運の尽きで、忽ちわたし達の網に引っかかったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが本当の運の尽きだったのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったらお前は運の尽きだ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この俺を捕まえて変な真似をしやがったら、それこそ運の尽きだぞ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一所にならぬ話の筋は世間にあるまい……といったような自惚れから、柄にない無理算段をして通い初めたのが運の尽き。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに運の尽きと諦めるさ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな禅宗病患者が殖えたら日本は運の尽きだと思いますよ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芽出度過ぎて運の尽きとるじゃないか』『ドウすれあ良えかいな』『仕様はない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて露領沿海のタラバ蟹に延焼し、加察加の鮭、鰊と宛然に燎原の火の如く、又は蘇国の空軍の如く、無辺際の青空に天翔る形勢を示したが、その途端、何気なく差した湊屋の盃を受けて唇に当てたのが運の尽き、一瞬の中に全局面を、無学文盲の親友に泄われてしまった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石の謹厳な八代大将も総｜義歯をハメ直しハメ直し鼻汁と涙を拭い敢えず、苦り切ってシキリに汗を拭いていた武谷博士も、とうとう落城してニヤリとしたのが運の尽き。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりＡはそこで、久美子と子供達の写真を、何枚か撮っただけで、一先ず探険を切上げて来ればよかったのですが、そうしなかったのがＡの運の尽きでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも秀頼公御運の尽きぬるところか」と。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが再度渡米したとき、「今夜我が家で集まりがあるから」と誘われ、軽い気持ちで出かけていったのが運の尽きとなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小左衛門も山谷を逃げ出して来て、暫く一緒に忍んでいるうちに、お節の容貌が眼について豪家の嫁に貰われることになって、まず当分は都合よく暮らしていたんですが、こんにちで云えばリョウマチスか何かでしょう、両方の腕がこのごろ痛むので、森厳寺へ灸を据えに来たのが運の尽きでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その風呂敷も一緒に焼いてしまえば好かったんですが、そこが人情の吝なところで、風呂敷まで焼くにも及ぶまいと、そのまま残して置いたのが運の尽きでした」「そうすると、その風呂敷から露顕したんですか」「まあ、お聴きなさい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "お俊も万力に対しては内々用心していたのでしょうが、そこが運の尽きと云うのでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですぐに逃げればいいものを、自分の座敷へ荷物を取りに引っ返して来ると、主人が丁度いなかったもんですから、急にまた慾心を起して、行き掛けの駄賃に主人の胴巻まで引っさらって行こうとしたのが運の尽きで、とうとうこんなことになってしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを窺って、清五郎が鉄槌で頭をひと撃ち……」「お半を殺した三人は、幽霊が生きていることを知らなかったんですね」「そこが運の尽きです」と、老人はほほえんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "対手が君であつたのが運の尽きざるところなのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえも飛んだ女に可愛がられたのが運の尽きだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人は藤助を斬るつもりだったと云っていましたが、どっちにしても又出直して来たのが不覚で、とうとう運の尽きになりました」「茂兵衛と銀八はすぐに召し捕られましたか」「召し捕りました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはおしらべがおつきでござりますはず、ただ一つ死体を沈めるおりに、あやまって懐中のふた品を濠に落としたのが、悪運の尽きでござりました……」「あたりめえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月の十一日にも新規の品が三十六本仕上がりましたゆえ、そのうちの一本にいつものとおりこっそりとてまえの文を忍ばせておきまして、あすにも加賀様から沙汰のありしだい届けようと待ちあぐんでおりましたところ、運の尽きというものに相違ござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう斯うなっては運の尽きで、お近さんの秘密はみな暴露してしまいました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主を殺したどたばた騒ぎで、隣りの足袋屋が起きて来たので、お留は手に持っているその金の隠し場に困って、店の貝殻へあわてて押し込んだのが運の尽きでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが二人の運の尽きで、さっきお話し申したような事になってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "お角のところへたずねて来たのを、張り込んでいる幸次郎に見付けられて、あとを尾けられたのが運の尽きです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "菊人形の昔",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘ももうちっと仮病をつかっていれば、なんにも間違いはなかったのかも知れませんが、陽気もだんだん暑くなって来るので、もう我慢が出来なくなって、うっかり車湯へ出て行ったのが運の尽きです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり運の尽きですね」と、松吉は笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
