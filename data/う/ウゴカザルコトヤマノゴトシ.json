          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "されど狼狽へたりと見られんは口惜しとやうに、遽にその手を胸高に拱きて、動かざること山の如しと打控へたる様も、自らわざとらしくて、また見好げにはあらざりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく、「動かざること山の如し」と言われたのは、ごく短時間、しかもごく大ざっぱに観察してのことで、今日、精密な測量の結果は、明らかに大地の隆起沈降を証明いたしております。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "収　動かざること山の如しって言う形です。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "動かざること山の如しだ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かなること水の如く、動かざること山の如しといおうか、漣ほどの微動もない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
