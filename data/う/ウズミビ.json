        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寂しさを増したため却つて埋み火のやうに心の奥へ封じ込められてゐた情感がうづいて、何等かのあたたかみを求めるのであつた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちかは火鉢の側に來て坐り、埋み火を起しなぞしてゐた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の雪風に煽られたのか、炉の埋み火が燃え上がった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア一服なすって」　お島は家へ取って返して、平次とガラッ八のために、埋み火を起して、お茶の用意をしました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お気の毒だね、――ところで、誰がいったい佐渡屋を皆殺しにする気になるだろう」「わかりませんよ、親分」　平次が帳場格子の前にしゃがむと、品吉は埋み火の煙草盆を押しやって、自分も真鍮の煙管を取上げました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理的には肉体の完成に忙しく、そして精神的には他愛もない遊びと此頃の人らしい勉強に紛れて、暫くは天狗長兵衛作の観音様も、綾麿の記憶の下積になって、僅かに埋み火のように息づいていたのでしょう。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その埋み火が、新に薪を添えられて、燃えさかる情熱となったのは、綾麿が十七の年、声変りがして、鼻の下が薄黒くなって、理性と情慾と、信仰と迷信と、渦を巻いて五体を駈けめぐり始める頃でした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "観音様の頬",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう冷たく頑なに思い込んで来た旗岡巡査は、突然、十数年の埋み火を掻き立てられるように、瞼を赤くし、今にも声をあげて泣くかのように顔の筋をぶるぶると吊った。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お氣の毒だね、――ところで、誰が一體、佐渡屋を皆殺しにする氣になるだらう」「わかりませんよ、親分」　平次が帳場格子の前にしやがむと、品吉は埋み火の煙草盆を押しやつて、自分も眞鍮の煙管を取上げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから奥の二階のひと間へ導かれると、妻女が埋み火の上へ炭をついだ火桶を持って来、なお「もうぬるいかもしれないが――」などといって、茶を淹れて呉れたりした。",
              "citation": {
                "source": "おれの女房",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが後に彼は知ったのである、烈火は消え易いが、くすぶっている埋み火は冷えにくいということを。",
              "citation": {
                "source": "野分",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋へ戻って、寝衣に着替え、もういちど火鉢の埋み火をみてから、夜具の中へはいり、読みかけの「松代物語」というよみ本をひろげた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかはその枕許へそっと犬張子を置き、おせんと差向いに坐って火鉢の埋み火を掻きおこした。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――寝所の行燈を居間へ移し、火桶の埋み火をおこして炭をついだ。",
              "citation": {
                "source": "山椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて、お燕が、ふと「父」ということばでも洩らそうものなら、かの女の、呪咀の埋み火は、すぐ炎になって、全身を焦いた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより献帝のご隠忍は年久しいことだったので、胸中の埋み火は、たちまち、理性の灰を除いてしまった。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "初老の埋み火は亡き女の面影をあたためている。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜん、自分の中の埋み火があげた炎に、どうにも寝つかれない寝返りを、いくどとなくしている高氏としか見られなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
