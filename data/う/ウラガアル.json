        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし物事にはすべて裏の裏がある。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人が私のせいにしたのも何か裏があるのだと思ったからだ。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストレーカは聞くなりひどく心を乱したが、どういう裏があるのかはまったくわかっていないようだった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな功利的な気持ではなかつたが、……詮索すれば、人間の美しいとされてゐる行為にも、裏があるのだつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはともかくとして、これには死んだ農奴そのものじゃなくって、何か裏があるのよ、きっと。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、どんな裏があるとお思いになりますの？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな卑劣な、よくない裏があるなどと、どうして男たちが考えたのか、それはすぐに分る。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この昏睡には、きっと裏のまたその裏があるに違いないのだ」と意気地なくも検事も、やはり津多子夫人に纏わる、動機の確固たる重さに引き摺られるのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の言には表裏がある。",
              "citation": {
                "source": "夢の図",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿衣、袷はいうまでもなく、単衣さえも表裏がある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の性質においてもまた同じような表裏がある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は表裏があるという一言にて、他の事を聞くまでもなく、あてにならぬ偽君子なりと解せられる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは十分、理屈だが、ものにはすべて、裏がある。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は、聴けば、武士の表芸の中でも随一番の、剣法ではだれにもひけをとらねえという――だが、世の中は、すべて表裏があるもので、裏の用意もなけりゃならねえ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ものには裏がある。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "序文／自序",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ私自身、決してその裏をのぞかうなどといふ好奇心はなく、また、そんな裏があらうとは信じないが、宛も秘すべき裏があるかの如き印象を与へる一面的な誇張粉飾は、将来、報道者も慎まなければならぬと思ふ。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人住宅は、裏と表とがないと、ちょっと住みかねるものであるが、アメリカの家にも裏があることを知って大いに安心した。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところが、これもまた命運の然らしむるところだった、私は有明荘へ出かける途中で林謹直に逢い、私が今朝の現場整備から除外されたこと、従ってこの整備には何か裏があると感づいたのでした。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "安倍家の先代、大目附を勤めた丹後守が亡くなつたのは二年前、跡を襲つた丹之丞は、實は丹後守の甥で、當年三十二歳の男盛りで非常な才物には相違ありませんが、物事に表裏があるので目上の受けの宜い割に、家來に取つては結構な主人ではなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏には裏があるだろう」四　ちょうど一と通り見てしまったところへ、主人の六兵衛が来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そう言うのは表向きさ、物事には何でも裏がある。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "安倍家の先代、大目付を勤めた丹後守が亡くなったのは二年前、跡を襲った丹之丞は、実は丹後守の甥で、当年三十二歳の男盛りで非常な才物には相違ありませんが、物事に表裏があるので目上の受けのいいわりに、家来にとっては結構な主人ではなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏には裏があるだらう」四　丁度一と通り見てしまつたところへ、主人の六兵衞が來ました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巨盜還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常性というものにどういうディアレクティッシュな裏の裏があるかにもお構いなしに。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理には裏の裏があり、その又裏がある。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の建物について、the ground floor という表現も出てくるので後者なのかも知れませんが、四階建てでしかもその上に実験室を組めるほどの屋根裏がある大邸宅なのでしょうか。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※のメーデイのよろこびの深さがわかるだけに、建物のうら側のバルコニーにはメーデイの閑寂の裏がある。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは初めには、裁判所にはどんな論拠も歯がたたないと言われ、次に、ただしこれは公開の裁判の場合だけのことで裏には裏があるのだ、と言われたが、今度は、潔白な者は裁判所に対してなんらの援助も要らない、とさえ言われるのです。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう云ふことが時々あるので、自分は芥川の言葉に表裏があるやうな気がしてその不服を谷崎によく漏らしたものだ。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな土地じゃ、こう申しちゃ、何ですが、裏にうらがあるのが習わしですからな」と、捌けた調子で、対手の口うらを引いてみたが、お繁は言下に、「あの人旦那なんてありゃしまへん。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
