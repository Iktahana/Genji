        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "姿のない作品といふやうなものが充満してゐて、身動きも出来ない有様である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の動きにのみたよるという法はどうか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが夏の真昼の沈黙や、田舎の静寂さやを、麦の穂の動きにかけて、一語の重複した表象をしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の暮れるまでは影も見えず、夜はいつの間にか現われてガラスに貼り付けたように身動きせぬ。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "客車狭くして腰掛のうす汚きも我慢して座を占むれば窓外のもの動き出して新聞売の声後になる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜に往来へ財布を落しておいて小蔭にかくれて見ている、通行人があたりを見廻わしてそれを拾おうとするときに、そっと手許の糸を手繰ると財布がひとりでするすると動き出すというような深刻な教育法をも実行した事があったようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入院、といふことも考へましたが、それでも、やはり心の奧底で、かの高價な「二個のズルフオンアミド基」を有する世界的な新藥を、たのみにしてゐるところが在るらしく、そのうち卓效を奏するであらうと、身動きもならず靜かに横臥して、天に祈る氣持でありました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、なるほど、大小無數の魚どもがすきまもなく脊中を並べて、身動きもせず凝つとしてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところ世界中に流行したアメリカ映畫、あれには、こんな所謂「純眞」な雄や雌がたくさん出て來て、皮膚感觸をもてあまして擽つたげにちよこまか、バネ仕掛けの如く動きまはつてゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きがとれなかったんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は静に動き出した。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客は汽車が動き出すと一緒に、長くなったり、凭れに頭を押しつけたりして、眠りを続けた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その曲線は前に云った半円形を基とした半円筒の面の上をあちこち動きながらＺの方向に延びて行くのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがなんだか若芽についたあぶら蟲か、腫物につけた蛭の群のやうに、ぎつしり詰まつて身動きも出來さうにない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が動き出すと一團の生徒等は唱歌を唱ひ出した。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど身動きも出來ない程で、出る時に出られるかどうかと思ふ位であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁天の前に電車が一台停まったまま動きそうもない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌に聞いてもいつ動き出すか分らないという。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどもが生れて一人動きできるようになると、翁はこれを山に持って行って置いて来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからしてみれば、一夜の間は心を静め澄さねばならない女神の斎の莚にかかる動きゆらめくものが傍におることは親とはいえ娘の神の為めにならないことは判り切った話だ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という大きな乾坤の動きであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分の動きにつれて肯定と否定の両頭は直ぐ噛み合いを始める。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すきとほった硝子のやうな笛が鳴って汽車はしづかに動き出しカムパネルラもさびしさうに星めぐりの口笛を吹きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠に動きつつ永遠に交わらざる平行線は、二元性の最も純粋なる視覚的客観化である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「さわり」とは心の糸に触れる、言うに言えない動きである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "広小路の松坂屋へはいって見ると歳末日曜の人出で言葉通り身動きの出来ない混雑である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのときはもう硝子の呼子は鳴らされ汽車はうごき出しと思ふうちに銀いろの霧が川下の方からすうっと流れて来てもうそっちは何も見えなくなりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波がうごき波が足をたたく。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまた鉛筆がうごき出してするするっと288と二けた目までのとこへ書いてしまいました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遠ざかって行く陸地に小さな人の影が五つ六つうごき一人は両手を高くあげてまるで気違いのように叫びながら渚をかけまわっているのでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
