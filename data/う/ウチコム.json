    "definitions": [
      {
        "index": 1,
        "gloss": "to drive in (a nail, stake, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "心に打ち込むものはなかった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、五圓の遊びに命を打ち込む。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、五円の遊びに命を打ち込む。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし真にわが一心をこの画幅とこの自然とに打ち込むなら大砲の音だって聞こえないだろうと。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "松田もまだどこかにお坊つちやんの処はあるが、それかと云つてそんな女に打ち込むほどの初心でもないのである。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かアラを拾つて凱歌を挙げたかつたのであるが、私の読んだ箇所は、その作家も特別に緊張して書いたところらしく、さすがに打ち込むすきが無いのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒は敵の頭と股間を狙って打ち込むのであります。",
              "citation": {
                "source": "死人の手",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家をつくり、塔を組む、番匠なんどとは事變りて、これは生なき粗木を削り、男、女、天人、夜叉、羅刹、ありとあらゆる善惡邪正のたましひを打ち込む面作師。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「磨いて見せるほどあたいが打ち込む男は、この国府津にゃアいないよ」とは、かの女がその時の返事であった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今一つその終末に、主人公が屍体に爪と頭を打ち込むところで、何となく「余計な真似」というような感じがしました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分釘は槌で打ち込む時折れたのだらう。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳでは、文字による命令を綴りを間違えることなく打ち込むことが必要だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなぞも大工の考えそうなことで、長い釘を一本打ち込むのでも、素人では手際よく行かないものです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "男児が十五六歳になって次第に男らしくなり、自然に大望を起こす気象や、押し太鼓の初めは緩く、中は緩みなく、終りは急になって、打ち迫り、打ち迫り打ち込む調子も、皆張る気の相である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "后が一人自分から生まれるということに明石の報せが符合することから、住吉の神の庇護によってあの人も后の母になる運命から、父の入道が自然片寄った婿選びに身命を打ち込むほどの狂態も見せたのであろう。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "評論をやることで文化人で――、消費組合の土台をヱンヤラヤット打ち込む手伝ひをすることで階級人である新居格は河馬のやうな格好で人生をはにかんでゐる。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちを溜池へ打ち込む前に、そっちが山王のくくり猿、お子供衆の御土産にならねえように覚悟をしなせえ」　相手に嘲られて、播磨はいよいよ急いた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "模範船からすぐ引き上げろという信号がかかったので、今までも気づかいながら仕事を続けていた漁船は、打ち込み打ち込む波濤と戦いながら配縄をたくし上げにかかったけれども、吹き始めた暴風は一秒ごとに募るばかりで、船頭はやむなく配縄を切って捨てさせなければならなくなった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその間にもしっきりなしに打ち込む浸水を急がしく汲んでは舷から捨てている。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事をなさるにも手先や口先でなく、心をも身をも、打ち込む方だと思いましたの。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "音は翻つて私の頭天から釘を打ち込むかの如くに、めりめりと喰ひ込んで、その度毎に全身で堪へてゐる尿意が蜂の巣のやうに動揺した。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "家をつくり、塔を組む、番匠なんどとは事変りて、これは生なき粗木を削り、男、女、天人、夜叉、羅刹、ありとあらゆる善悪邪正のたましいを打ち込む面作師。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだろう誰か此方面に、鍬を打ち込む者は無いか。",
              "citation": {
                "source": "マイクロフォン",
                "author": "「新青年」一九二六年二月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一方の端を、土の中へでも打ち込むように尖らせているのだった。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事をなさるにも手先や口先でなく、心をも身をも、打ち込む方だと思ひましたの。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忽ち二人は襟を握って、無数の釘を打ち込むように打ち合った。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうも僕は、實のところ、さういふ仕事に對して一生懸命に打ち込む氣にはなれないんだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから本来を云うなら、ここに浪漫主義なら浪漫主義、自然主義なら自然主義の定義があって、何人の作物でも構わないからして、この定義に叶っただけを持って来てこの主義のうちへ打ち込むのが当然であろうと思われます。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンデリラという短い手銛のような物を、正面または横側から牛の背部、首根っこへ近いところへ二本ずつ打ち込む。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌をうちこむことを熟練した。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
