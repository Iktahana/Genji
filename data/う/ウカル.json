        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これに短波の受かるコンバーターを付けるサービスを始めたところ、新聞に紹介されたことも手伝って、これがじつに繁盛した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分で行つたら来年、四年で一高の試験が受かるかも知れないね。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢はな、二十の年に普通文官いうものが受かるし、新は中学校へ行っとった時に三番と降ったことがないんや。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、試験だって受かるかどうかわかりもしないのにさ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たんだの一囘で受かるやらう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし卒業した年にすぐ試驗に受かるものは少ないといふことも聞かされてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そななこと云うたかてお前、試驗が受かるもんやら受からんもんやらわかりやせん。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、おけいちゃんがどうして受かる筈の試験をはずしたかという苦しい事情の奥底までは、察しる智慧がなかったのであった。",
              "citation": {
                "source": "なつかしい仲間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "受かるはずもないと思い、大学は一校も受けずにいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちから送っているテレビジョンが受かるようになりました。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひさの試験は受かるかどうかわからないが、受かるようにしてやって、うかれば本年の冬はいないものと考えなければならず、あとのひとのこともなかなかむずかしくて閉口していたところですし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "２５０がこなせたら、ナナハンの試験なんて、すぐ受かる」「むずかしいって言うじゃない」「受ける人たちの程度が低いんだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども十円に売れなんて云ったおぼえもなし又十円に売っているとも思わない、ただまあ、フクジロがよちよち家を出たりはいったりして、それでよくこんなにもうかるもんだと思っていたと、こうだろう。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと一日がまんをして十月になつてから質屋へ行けば、利子がひと月分まうかると思つたので、僕は煙草ものまずにその日いちにち寢てばかりゐた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、「おれたちがもうかる」のであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "君と共に住めば手鍋さげてもと、青春の戀にうかるゝ都の若き男女に、かゝるさま見せてやりたし。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなくあっちのほうが金がもうかるといって、また大連へ出かせぎに行った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこれを売って株でも買っておくともうかるんだが、しかたがない」と嘆息したまま、やはり壁を向いてあぐらをかいている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの蕎麦屋はあれでだいぶもうかるだろうと話している。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてわが世はものうかる日日のねむりの續きのみ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の野に迷ひ出でたはつい昨日、旭日にうつる菜の花に、うかるゝともなく迷ふともなく、廣野を狹まく今日までは。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして、大谷君はやみ屋になりたいの」　先生がおたずねになると、大谷君はあかい顔をして、「お金がたくさんもうかるそうですから」　と申しました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりサヤサヤと云うかるい衣ずれが耳のきわでひびいた、夢中でつと身を引いた光君は障子をしめてそとに立って居た。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エジプト手相よりは、ずっともうかるにちがいない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お金もうかる、お金もうかる」　キシさんがそう言ったので、三人とも笑いました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなといり浪｜喘ぐ灣なかば萎ゆる帆のふかきはためき、ものうかるさまや、大船、ちからなく翅垂れぬる。",
              "citation": {
                "source": "春鳥集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "』九草やま草やま草葉みどりに匂ひ靡き、かがやく日ざしおほひて、絶間なくも靜かに夢見うかるる身にし添へば、ああわがこの身さながら空しき影。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "インフレ時代というものは、怠け者とか子供とか、正常では生活能力のない人間が生活力がある仕組で、ちょッと右から左へ物をうごかすと、勤労者の一ヶ月の給料ぐらいが、すぐもうかる。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縁談などゝいうものはマトモすぎるからヤヽコシクて、これがあなた、当世のヤミ商談なら、公定千円の紙、ヤミに流して二千五百円、これを百レン買って二十五万円、これを一万何千部かの本にして一冊七十円、七カケで売ってザッと七十万、諸がゝりをひいて、二十万はもうかる。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野も山も冬はさびしと思ひけり雪に心のうかるるものを』。",
              "citation": {
                "source": "『さびし』の伝統",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
