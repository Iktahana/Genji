          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今ね、お前さんのウェディングドレスを用意しているんじゃ。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツバメは二人の頭の上の巣の中で、じっと動かずにウェディングソングを歌いました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暴民はウェディング・ノイケルン地区に制圧さる」そうサブ・タイトルがつけられている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかまわず、多数の婦人子供の加った十万人ばかりの労働者の行進がベルリン各所に行われて、警官隊との衝突をおこし、ウェディング、モアビイト、ノイケルンその他の労働者街では市街戦になった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェディングとノイケルンにバリケードが築かれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンのメーデーに、ノイケルンやウェディングという労働者地区で、数十人の労働者の血が流された。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤い地区」ウェディング、ノイケルンはメーデー以来大きく浮びあがっているけれども、伸子や素子がベルリンでのこまかいありふれた日々の間にふれている場面のなかへまでは、新しく創られた生活の道がしみ出していなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブル中央に大きな白い塔が立っているのを、ビートリスはぼんやりと自分のウェディングケーキだと悟った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
