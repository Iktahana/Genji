    "definitions": [
      {
        "index": 1,
        "gloss": "rabbit hutch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学校の校舎の隣に、動物の世話をするためのうさぎ小屋が立てられた。",
              "source": "幻辞"
            },
            {
              "text": "田中さんは、自宅の庭にうさぎ小屋を作り、毎日の世話に励んでいる。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋は、防風と防雨に配慮した二層構造になっている。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちは、朝と夕方、うさぎ小屋の掃除と給餌の当番をしている。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋では、五羽のウサギが快適に暮らしている。",
              "source": "幻辞"
            },
            {
              "text": "農家のうさぎ小屋は、食用ウサギの飼育に特化した設計になっている。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋の床材は、ウサギの足に負担をかけないよう、わら製である。",
              "source": "幻辞"
            },
            {
              "text": "大学の生物学部では、実験用ウサギをうさぎ小屋で飼育している。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋は、トラ猫の被害から守るため、二重扉になっている。",
              "source": "幻辞"
            },
            {
              "text": "動物園の教育プログラムでは、うさぎ小屋の世話を通じて命の大切さを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋には、給水器と給餌器が最新式のものが取り付けられている。",
              "source": "幻辞"
            },
            {
              "text": "研究施設のうさぎ小屋は、厳密な衛生管理と温度制御がされている。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋の隣には、ニンジンなどの野菜を栽培する小さな畑がある。",
              "source": "幻辞"
            },
            {
              "text": "定年退職後、この男性は毎日、自分のうさぎ小屋の世話に没頭している。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋は、ウサギの繁殖プログラムのために特別に設計された。",
              "source": "幻辞"
            },
            {
              "text": "田舎の保育園には、子どもたちが優しさを学ぶためのうさぎ小屋がある。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋の屋根には、太陽光パネルが取り付けられており、省エネだ。",
              "source": "幻辞"
            },
            {
              "text": "ペット販売店の奥には、ウサギを一時的に保管するうさぎ小屋がある。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋は、博物館の野外展示として、来園者に観察の機会を提供している。",
              "source": "幻辞"
            },
            {
              "text": "このうさぎ小屋の建築には、日本の伝統建築技術が部分的に応用されている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たしかうさぎ小屋にさっきまでいた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
