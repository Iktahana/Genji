        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "岡は窓ぎわに行ってカーテンの陰から戸外をすかして見て、ポケットから巧緻な浮き彫りを施した金時計を取り出して時間を読んだりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然明らかな光線が室に射したと思うと、扉のところに、西洋蝋燭を持った一人の男の姿が浮き彫りのように顕われた。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "片面だけが磨かれていて、他の面には樹木、花、鳥、動物、昆虫、風景、伝説、幸運のしるし、神の像などの、浮き彫りの装飾が施されている。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宣言一つ」には、インテリゲンツィアのそういう歴史的な悲しい絶望がまざまざと浮き彫りされているのである。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嶋正利の『マイクロコンピュータの誕生』と引き比べてこのインタビューを読むと、嶋がいかに正確に、謙虚に、淡々とこの一大発明の誕生の経緯を跡付けているかがあらためて浮き彫りになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああマヌエラ、塩を雪のようにかぶって起きあがったとき、一つ二つ、臨終そのままの姿であるいは立ち、あるいは蹲まり、あるいは腕を曲げ、ゴリラや黒猩々が浮き彫りのように現われてくる。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の一枚岩にも、ところどころ自然がもてあそんだ浮き彫りのようなものが見られるけれど、それらもみな、蒼然たる古色を帯び煤けかえっているのだ。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼろかな気配のうちに、さすがに荘厳味を感じさせて、高く立っている如来像には見向きもせず、壇下を、手さぐりで、一探り、早くも、台の前かざりの、浮き彫りの、篏め込みの板を、触れて見て、彼は、それが、引戸になっているのを悟った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵といっても、高さ四尺ばかりの自然石の表面を削り、台座を下部に残して、地蔵の姿を浮き彫りにしたものです。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟するに小説全体の中でこの男が浮き彫りにほりあがればいいのだから。",
              "citation": {
                "source": "意慾的創作文章の形式と方法",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀟洒な建物には似合わぬ鉄門に、掲げてある小さい門標には「池谷控家」の四字が青銅の浮き彫りに刻みつけてあった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその部屋には、土や石で築いた寝台のようなものがあり、壁にはさまざまの浮き彫りで、絵画や模様らしきものや不可解な古代文字のようなものが刻まれてあった。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壱岐名勝図誌で準備しておいた知識ではあるが、此国へ来ると、まだ其地に臨まない先に、実感らしいものに浮き彫りせられて、其原因が捉へられさうな処まで、ちらつき出す刺戟を感じた。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "父逝いて幾年、晩秋がめぐりきて、夕陽が赤城の山襞を浮き彫りにするとき、私の眼には白川狐が、餅を食べている姿が甦る。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは荒削りの浮き彫りだが、いく代にもわたるひとびとの足にふまれて、ほとんどすりへっていた。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためでもあろう、端麗の鼻が、一方の側へ濃い陰をつけて、その端麗さを浮き彫りにした。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、鼻の反対側に同じように陰が濃くついて、同じように端麗さを浮き彫りにした。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松翁となった松鶴の「天王寺詣」にはやわらかに彼岸の日ざしが亀の池を濡らし、故枝太郎の「島原八景」は朧夜の百目蝋燭の灯影に煌く大夫の簪のピラピラが浮き彫りにされ、故枝雀の「野崎詣」は枝さし交わす土手の桜に夏近い日の河内平野が薄青く見えた、ちょっと数えても春の落語がこれだけあった。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがほとんど完成して、最後に低温室の中で人工雪のむつかしい結晶の撮影をしている時に、照明用のコンデンサー・レンズの調整をしていたら、ふいに結晶がぴかりと光って、凹凸が美事に浮き彫りのように見えたことがあった。",
              "citation": {
                "source": "自然の恵み",
                "author": "――少国民のための新しい雪の話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンダーラの浮き彫り彫刻などで見ると、一つの構図の端の方にはギリシアの神様がいたり、哲学者らしい髯の多い老人がいたりする。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜門の浮き彫りなどに現われた直線的な衣の手法は、夢殿観音には似ているが百済観音には似ていない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし竜門浮き彫りの拓本などを見ると、これに似た感じがそこにもある。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この作を百済観音と鳥式仏像との中間に置いて考え、あるいは竜門の浮き彫りと比較して考えるのは、その様式上の考察としては見当をあやまっていないかもしれぬ。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思いやり、そういう人の気をも兼ねるということになれば、作中の人物をくっきりと浮き彫りにし、それぞれにあらわな特徴を与えるということは、ちょっとやりにくくなる。",
              "citation": {
                "source": "藤村の個性",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『端の方にアルフアベツトの文字を浮き彫りに刻んだ、短かい綺麗な金属の棒を想像してごらん、或る棒の端にはａといふ文字があり、別なのにはｂ、或はｃといふ文字がある。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼は先刻から選りそろえておいた七、八冊のさし絵入りの漢書――それは皆彼の父が丹精して手に入れたものであった――を風呂敷に包み、また、彼の父が始めて南蛮｜鋳物の術を習いに幕府からヨーロッパへ派遣させられた時のみやげである小さい浮き彫りの鋳物をふところに入れると包みを抱えてふらりと表へ出た。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "古書と古道具の一切を売買する銅座町のある店で彼はその漢書を売り、またその浮き彫りを見せた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "赫色の毛むくじゃらの手が只わけもなくさわぎまわる中をルビーとダンラをうきぼりにした指輪のある手でスイスイと札をぬいて行く、おまけに手は白し爪は桜色になって居る。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今日でもありありと、全体のうきぼりがさながら目の前に現れるくらいあざやかであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの大理石のたなは、額ぶちのように暖炉をかこんだ、木製のりっぱなわくの上に乗っているのですが、そのわくの大理石の板を受けている部分に、横に長く、まるいうきぼりの彫刻が、いくつもいくつも、ずっとならんでいるのです。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
