        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ここの落葉松は、小御岳では風雪と引っ組んで、屈曲｜匍匐しているに似ず、亭々として高く、すらりと延び上っている自然のままの、気高さに打たれる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍で見ると、富士の万年雪の美しいのに打たれる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「彼の論文を読むと、研究の結果の美しさに打たれるばかりでなく、明晰な洞察力で問題の新しい方面へ切り込んで行く手際の鮮やかさに心を引かれる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――将棋の歩にもいろいろあるが敵の王頭にピシリッと捨身に打たれる歩もあれバ亦、棋士が手に困ってひょいと突く香の上の端歩もある。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにも打たれるとか動かされると云ふやうな點はない。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、今までのすべてをはつきりさせてしまふやうなその詞を聞かされた時、驚きに打たれると云ふよりも、騷いでゐた私の氣持はふと鎭まつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけに、打たれる度も深く強い。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに続いた桑畑が、晩秋蚕もすんでしまったいま、もう霜に打たれるばかりの葉を残して日に照らされていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ妄想という怪獣の餌食となりたくないためばかりに、私はここへ逃げ出して来て、少々身体には毒な夜露に打たれるのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "能を見て頭が下がるのは、かように生死以上の生死をあらわす「舞台＝戦場」の厳粛さに打たれるからではあるまいか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ悪く傍へよると、撥で打たれるぞ、と友達の衆に用心されたそのお孝が、俺の手を曳いて抱込んだでな。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから……雲の底にお月樣が眞蒼に出て居て、そして、降る事があるだらう……さう云ふ時は、八田潟の鮒が皆首を出して打たれるつて云ふんです。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でございますか」　白糸は微笑を含みて、呆れたる馭者の面を視つつ、「夜露に打たれると体の毒ですよ」　馭者は黙して一礼せり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳房に五寸釘を打たれるように、この御縁女はお驚きになったろうと存じます。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お姫さまは、むちで打たれるたびに言いました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、お姫さまは、むちで打たれるくらい、しかたがありません。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし老先生が打たれる時は舞台か出稽古の時ばかりで、うちでは滅多に鼓を持たれなかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに、ここから出ても、自分はやっぱり狂人、いや、癈人という刻印を額に打たれる事でしょう。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "我我の情緒が昂進して、何かの強い詩的感動に打たれる時、自然我我の言葉には抑揚がついてくる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それあおまえも、品質が好いからって二合ばかりずつのお酒をその度々に釜川から一里もあるこの釜和原まで買いに遣すような酷い叔母様に使われて、そうして釣竿で打たれるなんて目に逢うのだから、辛いことも辛いだろうし口惜しいことも口惜しいだろうが、先日のように逃げ出そうと思ったりなんぞはしちゃあ厭だよ。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何で打たれても打たれて佳いというものがあるはずは無いが、火を見ぬ塩魚の悪腥い――まして山里の日増しものの塩鯖の腐りかかったような――奴のは幾条にも割れ裂ける、それでもって打たれるので※の裂目のひりひりしたところが烈しく触るから、ごくごく浅い疵ではあるが松葉でも散らしたように微疵が顔へつく。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ打たれるのを楽しむような気持さえ何処かにあった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の世話をした若手代が、目の前で、額を煙管で打たれるのを、もじもじと見ていたろうじゃないか。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よ、貢さん、人に後指さされちゃあ、お前さんの肩身が狭いだろうと思ったし、その上また点を打たれる身になるとね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故といふに、友達なら、打つか打たれるか、兎に角勝負が附く。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "打たれるくらいなら先ずこッちゃから打って、敵砲手の独りなと、ふたりなと射殺してやりましょ』『なにイ――距離を測量したか？",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "過酷な労働が強制され、白人監督に笞打たれる黒色人褐色人の悲鳴が日毎に聞かれた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも王政維新なる標語を各藩に徹底させるのが、どうして、あんなに骨が折れたのかと不思議の感に打たれるので、黒田藩では特にこうした傾向が甚しかった事が窺われるようである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世の日本文學史上に特筆さるべき一世の大詩人が、狹い田舍町に於て全く人に知られず住み、世捨人の侘しい隱遁生活をしてゐることを考へると、それだけでも自分は無量の感慨にうたれるが、さらに蒲原氏によつて直接訴へられた所を傳聞するに及び、自分は押へられない憂鬱と憤怒に驅られた。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時にゃうたれることもあろうでか。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
