        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　と、私が訊くと、「ほら、そこにあるよ」　と、上の子が出て来た。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで上の子は、私たちを待つてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は下の子の来るのを、上の子とそこで黙つて待つてゐた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「王のおッ母ア、上の子供をおんぶして、工場へ泣いて来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は観念して、下の子を背負い、上の子の手を引き、古本屋に本を売りに出掛ける。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いな燃やさでおくべきと年上の子いきまきて立ちぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "年上の子、先に立ちてこれらに火をうつせば、童らは丸く火を取りまきて立ち、竹の節の破るる音を今か今かと待てり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん上の子はせいぜい六つぐらいで、いちばん下の子は二つをこしてはいませんでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子が面と向ってこういう真実の述懐を吐くとき、かの女には却ってむす子から、形の上の子供子供した点だけが強く印象づけられた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトと桃の恵投にあずかり、これで上の子のきょう一日の食料が出来たとはいうものの、下の子がいまに眼をさまして、乳を求めて泣き叫びはじめたら、どうしたらいいでしょうか。",
              "citation": {
                "source": "たずねびと",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに一ばん上の子どもが七つになりました。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の座敷から年上の子の泣き声が聞えた。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "年上の子供はこの砂山によじ登ってはすべり落ちる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのふ海の中の人魚や、原始人の母と貝殻の上の子供やを描いた上野山が、今日ライオンに鹿を喰ひ殺さしてゐる、大臣閣下の肖像を描き、魚をならべて描いてゐるといふ、絵の主題の上にも時代的な動揺と矛盾とが現れてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが手にさげたる五つの風船玉、路上の子供の心を惹くこと一方ならず。",
              "citation": {
                "source": "風船玉",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "漠然ではあるが、何のことか分つてゐる一番上の子供が、「お父、行つてお出で。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも楽しく　遊びたければ姉と妹と　仲よくなされと、お杉とお紺の手をとつて、丘の上の子供達は謡つてくれました。",
              "citation": {
                "source": "仲のわるい姉妹",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、智惠子は驚喜の聲を揚げて、矢庭に砂の上の子供に抱着いた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の子はふん、と鼻を鳴らし下の子と顏を見合せて笑つた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の子供達はみんな女で、もうそれぞれに身の始末はつけてあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "地続きにあるその古家は、二つに仕切って一方には震災のとき避難して来て、そのままになっている弁護士Ｔ氏の家族が住まい、三間ばかりの一方に庸三の上の子供たちが寝起きしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の女の子が、少しずつ愛嬌づいて来るにつれて、上の子は母親に顧みられなくなった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ―の家庭には、氷川より以上の子供達がづん／＼育ちつつあつた。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶山利一という年上の子は街の中で凧をあげるから持っていてくれと言って、私が持っていると糸枠を持って駈け出してその勢いで凧があがった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場へ赤ん坊はつれて行けないから、四つ五つの上の子に守をさせる。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる插話という以上の子供と大人の生活のいきさつが圧縮されて出ているので、こまかに事柄を追ってみれば、ここに叱る母の無理なさ、つい鋏でジョキジョキやってしまった子供の邪気なさ、その家ではその頃子供に切りぬき絵を買ってやることに心づかないでいる庶民ぐらしの肌合いというものが、まざまざと出ている。",
              "citation": {
                "source": "「保姆」の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の子二人は小学校へも行くといふ年になつた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお四人以上の子供を有する者は、家族数の多いがためにという原因の方に編入されているのだが、もしそれを合計するならば、第一級の貧乏人のうち約七割四分だけのものは、毎日規則正しくかせいでいながら、ただ賃銭が少ないかまたは家族数が多いがために貧乏線以上に浮かび得ぬのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで暮らす人に割り当てられるアパート式の住まい、さらに食堂や共同洗濯場、五歳以下の子供を昼間預ける育児舎、六歳以上の子供が共同生活を送る学育舎などもこの敷地内にある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえから、そのために崖のうえのこの草原を、とくに選定したのである。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
