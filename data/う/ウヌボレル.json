        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "君が自殺をしたなら、僕は、ああ僕へのいやがらせだな、とひそかに自惚れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、自惚れるだけのことはあったのかも知れない。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は特に奮発して晩酌三合（いつもは二合）、いゝ気持で寝てゐるところを揺り起された、臨検だといふ、お役目御苦労、問はれるまゝに日本禅宗史を一席辯じて、おまはりさんと宿の人々を感心させた（と自惚れる）。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が、まだ、ひとに可愛がられる資格があると自惚れることの出来る間は、生き甲斐もあり、この世も楽しい。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗鬱、愚痴、こんなものは敵だとおもつてゐるのだ、さりとて情熱の欠けた日にペンを構えてゐる己れの面つきを想像すると、どうしても、これも修業だと自惚れるわけにはいかなかつた。",
              "citation": {
                "source": "「学生警鐘」と風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自惚れると妙な理窟がつくもんで、新聞記者の大洞福弥君、二学士の落第を聞いて鼻を揺めかした子。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯んなことを云ふと、私が何か忠実な家族の一員で、世俗的な何かの負担でも感じてゐる（自分ではそんな風に自惚れることもあつたが）やうだが、私のこの他人に迷惑を及ぼす程の怠惰性は生来なのである。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　だが、Tetrazzini よ、そんなに自惚れるものではない。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角癩患者も、もういいかげんで自分の病苦を自惚れるのをやめたいものだ。",
              "citation": {
                "source": "独語",
                "author": "――癩文学といふこと――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般の西洋人が、特に日本の芸術に興味をもつてゐると自惚れるのは間違ひで、黒坊のお面や、子供の楽書を恭しく壁に飾つてゐる自称芸術愛好家は、近頃、巴里などにある。",
              "citation": {
                "source": "左団次一行",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "自惚れるがいいわ、勝手に……。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そう思うと自惚れるんです。",
              "citation": {
                "source": "雪の日",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファルスの作者といふものは、作中の人物を一列一体の例外無しに散々な目に会はすのが大好きで、自惚れる奴自惚れない奴に拘りなく、一人として偉いが偉いで、智者が智者で、終る奴はゐないのである。",
              "citation": {
                "source": "FARCE に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広大な大宇宙の中において、わが地球人類が最高の智能者だと自惚れる者があったら、その者はどうかしている。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に比較して自分の力を自惚れることすらできない感じよ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等人種だと自惚れる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はこんな若くて二人も弟子があると自惚れる前に圓朝は、二人も弟子のあるこの俺がデレリボーッという心持になっちゃいられない、早く早く真打にならなきゃ……。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん私は、チェーホフのいう喜劇の意味が、完全にわかったなどと自惚れるつもりはない。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん僕は、チェーホフのいう喜劇の意味が、完全に分ったなどと自惚れるつもりはない。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自惚れるにおよばない」　このへんでいいだろうと思って、あたしのほうから要約して結論をつけた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふ尾についてまた一人が、　三太郎ツどんも惣七どんも、その御面相で自惚れるさかい困るわい。",
              "citation": {
                "source": "心の鬼",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党は自惚れると、ついそんな気を起して、罠に陥ちるものだよ」　平次もさすがに感慨が深そうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡黨は自惚れると、ついそんな氣を起して、罠に陷ちるものだよ」　平次もさすがに感慨深さうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸事に対してあえて芸術とはいわない――俺だけが彫心鏤骨の苦心をしていると自惚れる人間は、私だけが熱烈なる恋をしていると思い込む芸者と、あまり大した違いのない低能である。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次身の上話",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら彼は、自作を演奏してくれる管弦楽団よりも、自作を出版してくれる本屋の方が見出しやすいとは、自惚れることができなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は皆そのままで日本一と自惚れるが宜いですよ。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "散髪屋の看板写真みたいに、規格型の顔をさらしてると思て、うぬぼれるな。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云うのを、「顔でうぬぼれるのはおよしなさいね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "のこのこ禮になど行かうものなら、却つて、うぬぼれるな、馬鹿な奴だ、と嗤はれるのがおちな氣がする。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬぼれるな、むさぼるな、こだはるな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
