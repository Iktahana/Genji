        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "長さ四五町幅三町ほど、極めて平滑な川床の岩の上を、初め二三町が間、辛うじて足の甲を潤す深さで一帶に流れて來た水が或る場所に及んで次第に一箇所の岩の窪みに淺い瀬を立てゝ集り落つる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ四五町幅三町ほど、極めて平滑な川床の岩の上を、初め二三町が間、辛うじて足の甲を潤す深さで一帯に流れて来た水が或る場所に及んで次第に一個所の岩の窪みに浅い瀬を立てて集り落つる。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、慰めるやうな囁きがやがて聞える頃、私はあの人の膝につっぷして、かさ／＼に乾いた胸を潤すやうな、涙の快さに浸つて居る。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人性の創造的行動のうちに深く滲潤することによって生活のリズムを把握しようとする」作家としてフェルナンデスの作品が、日本における行動主義の人々によって続々翻訳出版されるに至ったのである。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石は日本の伝統である官尊民卑が文学の領域にまで浸潤することを快く思わなかったのであろう。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土的な物産にしろ、それならばそれぞれの地方で一般の人たちがそういう製作品の味いで日常生活を特色づけ豊かにしているかと云えば、今日ではその地方を潤す色彩としてよりも、寧ろ郷土物産として都会へ売り出される目的でつくられる方が多いだろう。",
              "citation": {
                "source": "生活のなかにある美について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先端を揃えたものの芽も一斉に揺れ騒いで、一日一日と空は明るく、降る雨もみずみずしい温みで肌を潤すようになった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の民心に浸潤するの結果は、人を誤って法の罪人たらしむるに至る可し。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育の効の緩慢にして、ひとたびこれに浸潤するときは、その効力の久しきに持続すること明に見るべし。",
              "citation": {
                "source": "政事と教育と分離すべし",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言ふ共有のいろごのみの心を潤すのに十分である。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには始終そのすさんだ心を温め潤す愛がはたになければなりません。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁水｜滔々たる黄河の流れを貪り汲まんとする彼らをして、ローマの街にありという清洌なる噴泉を掬んで渇を潤すことを知らしめねばならない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを哲学的雰囲気のなかに抱くとき、尊き感激は身に沁み渡って、彼女の長き睫よりこぼるる涙はわれらの膝を潤すであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一見まずい材料をもってして、貴族、名門の口を潤すべき料理を考案しなければならなかった。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と咽喉の焼けるのを潤すために、飲残りのビールをまた一杯干して、大きく息をしながら顔の上に乱れかかる洗髪をさもじれったそうに後へとさばく様子。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "北阿にユダヤ勢力が浸潤することを述べた結論に、「一体北阿を舞台とする米英系の資本主義とソ連系の共産主義はどうなるかの疑問さえも成立しないのだ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉まで来ると、彼はまず自分の喉を潤す。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会に浸潤する卑俗的風潮のなかには、もっぱら愛国の美名を借りて単に自己の好むところを遮二無二現ぜしめようとする蒙昧主義がある。",
              "citation": {
                "source": "社会事情と科学的精神",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方は彼れの財貨を四、〇〇〇｜磅で売り、他方は、一〇、〇〇〇｜磅で売り、そして彼らは共に一〇、〇〇〇｜磅の資本を使用して二〇％の利潤すなわち二、〇〇〇｜磅を得ることもあろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もしそれが更により以上下落するならば、その価格は資本の通常利潤すら与えなくなるであろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の計を繰り返す勇気のなかった余は、口中を潤すための氷を歯で噛み砕いては、正直に残らず吐き出した。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "万人の胸を潤す物を作ることは我々の理想である。",
              "citation": {
                "source": "生きること作ること",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心を潤すような愛らしさが、すべての物の上に一面に漂っている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水なるかな、水ありて緑あり、水は咽を湿し、緑は眼を潤す。",
              "citation": {
                "source": "馬上三日の記",
                "author": "エルサレムよりナザレへ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やこの機会を利用してマルクス主義は、又唯物論は、大衆のモラルとなり大衆の気分となり、やがては大衆の風俗とさえなるように、地道に大衆の身辺に浸潤する時期なのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこういう風に社会化されて日常生活に浸潤する場合、それは同時に娯楽的な意味を得て来るのである。",
              "citation": {
                "source": "娯楽論",
                "author": "――民衆と娯楽・その積極性と社会性・――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の玉蜀黍がよく実り、ほどよい雨と虹とが彼等の天地を潤すようにと、玉蜀黍の花粉を撒いて祈祷を捧げるインディアンは、これ等、南欧に源を発した宗教的儀式を、どんな心持で眺めただろう。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『漏らぬ陰とて立ち寄れば　却って袖を潤す雫』　この松王、重盛様のお後を慕って、これまでお仕えしてまいりましたが、本日畏れ多くも御行脚の邪魔をいたしましたのは、長年のご恩にお報いすることもできないまま、最後の暇乞いを申し上げるためでございます。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "乏しき時にその父の舊友彼は訪ひ行きて、哀を求めて裾を曳き、上着を曳くも效なけむ、憐む友のある者は小さき盃取り出し、彼の唇潤すも彼の喉をば潤さじ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩集のはなし、詩集は本当に心をやすめ潤す力をもっているとおどろきます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
