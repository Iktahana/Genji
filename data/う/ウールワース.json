          ],
          "literary": [
            {
              "text": "僕はウールワースで見た。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウールワースのレストランで飲む朝のコーヒーを、ぼくは嫌いではない。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときいてくれて、はい、ください、と答えて注いでくれた二杯めこそ、真のウールワースのコーヒーだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのウールワースの朝食は、四ドルくらいで間にあわせることもできる。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウールワースのレストランでその朝刊を読みながら、ぼくは朝食をとった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウールワースを出たぼくは、ザ・バスに乗り、ショッピング・センターへいった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウールワースのまえにある交差点の赤信号で、自動車の列は止められた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のように後半をまとめればいい、ということを、ウールワースのまえの交差点でグラナーダを止めた瞬間、ぼくは思いついた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
