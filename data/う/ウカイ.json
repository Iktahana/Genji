[
  {
    "uuid": "2c1d25c4-88ad-5e1c-ba6f-fa3e11db5bc7",
    "entry": "迂回",
    "reading": {
      "primary": "うかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
