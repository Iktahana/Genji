      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "detour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たゞ左右の斷崕と其間を迂回り流るゝ溪水ばかりである。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、黄河を迂回して、側面からここを圧迫する馮玉祥の騎兵部隊と、泰山の南を縫うて、明水平野に出た陳調元の優勢な一部隊に圧迫せられ、又、戦わずに、界首と、黄河の線を抛棄した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "情のために道を迂回し、あるいは疾走し、緩歩し、立停するは、職務に尽くすべき責任に対して、渠が屑しとせざりしところなり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば路という路、右にめぐり左に転じ、林を貫き、野を横ぎり、真直なること鉄道線路のごときかと思えば、東よりすすみてまた東にかえるような迂回の路もあり、林にかくれ、谷にかくれ、野に現われ、また林にかくれ、野原の路のようによく遠くの別路ゆく人影を見ることは容易でない。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは殆んど人の歩るいた事のないような谷合を通り、前黒山、釈迦ヶ岳の山の中腹を迂回して深林の薄暗い中を行くのである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日は千曲川の船橋を渡り、妙高山、黒姫山の麓を迂回して越後国高田に出づ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "好事魔多しとはよく人の言ふ處で、私も其理屈を知らぬではないが、人間の一生に此樣な旅行は、二度も三度もある事でない、其上大佐と約束の五日目までは、未た三日の間がある、そこで、此深山を少しばかり迂回して皈つたとて、左程遲くもなるまい、また極めて趣味ある事だらうと考へたので、私は發議した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が大きく左｜舵を取って避けようとすると、同時に向うの機も薄暗い左の横腹を見せつつ大きく迂回して私の真正面に向って来た。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐるりと此の島を大迂回して、陰の港に到着するという仕組なのだろう。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹田と金木と相隔たる事、四角形の一辺に過ぎないのだが、その間に梵珠山脈があつて山中には路らしい路も無いやうな有様らしいので、仕方なく四角形の他の三辺を大迂回して行かなければならぬのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな身体になれば良いと佐伯は羨ましく眺め、心に灯をともしながらバスが迂回するのを待った。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　船首へまた大迂回して、測量室の下まで来たところで、Ｙはいきなり大声を挙げて、三等船室の階段を駈け下りた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山はいよいよ高く、林はいよいよ深く、道はいよいよ迂回して、気流はまたいよいよ冷ゆるばかりであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ私たちの自動車は最端の峠をその麓の坦道へと迂回し初めた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく上流へ出て迂回しようと思ったのである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨は人家ありけるよと打喜び、山｜岨の道なき処を転ぶが如く走り降り、やゝ黄ばみたる麦畑を迂回りつゝ近付き見るに、これなむ一宇の寺院にして、山門は無けれど杉森の蔭に鐘楼あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩軍は屡々間道から奇兵を出して襲撃したので、官軍は損傷を受けることが多かったが、官軍もさるもの、間道の迂回線に多くの兵を割いて四方から攻撃したので、この塁も陥り、ついに木葉を占領し、更に境木を攻略するに至った。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは薩軍が迂回して背後を衝くのを慮ったからである。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡山天王寺口の戦　五月七日、幸村は最後の戦場を天王寺附近と定め、城中諸将全部出でて東軍を誘致して決戦し、一隊をして正面の戦｜酣なる時迂回して背後を衝かしめんとした。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村茶臼山に陣し、毛利勝永は天王寺南門に備え、大野治長の先鋒銃隊東に在り、左方岡山口は大野治房を配し、迂回すべき遊軍は明石｜全登が精兵三百を率いた。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂回するためかと思ったが、車はそのまま真っ直ぐ天王寺の方へ走って行った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "車は後戻りすべく、夜更けの空気のなかに爆音を響かせて、不格好に迂回しはじめた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "船員らは纜を解いて、氷山を迂回して南方にむかって船を進めようと、しきりにあせっている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "河は迂回して海に灌いでゐるので、岨の下では甘い水と鹹い水とが出合つてゐるのである。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側は、駅から迂回して来た鉄路のある山腹の切断面、それから高架線、それらが万寿のかかってる方へ並行していた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上の方へ向つて、歩かう……」　と、彼はレコードの包をさげてゐる腕を挙げて、流れがゆるやかに迂回して来る明るい毛欅の林の方を睨んだ。",
              "citation": {
                "source": "繰舟で往く家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は吐息ばかりを衝きながら、眠さが襲ひ次第に飛び立たうとして、盃を傾ける毎に、今度は、凝つと眼をつむつて見るのだが、更に眠気も酔も襲はず、注ぎ込んでゆく苦い酒の流れが胸先を白々しく迂回するかのやうであつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ旧道をとるとすると白骨より三里ほど手前に大野川という古びた宿場があって、其処を迂回する事になり、辛うじて馬の通わぬ事もないという話であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、露国へ行って何をするツモリであった乎は友人中の誰にも精しく話さなかったが、左に右く出発に先だって露国と交渉する名士を歴訪し、更にその途上わざわざ迂回して後藤や小村やマレウイチと会見した事実から推しても二葉亭の抱負や目的をほぼ想像する事が出来る。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ、私の手踊りでも見せてあげませうかい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
