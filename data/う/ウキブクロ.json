          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「なんにも見えない」「救わなきゃならない、浮き袋と縄を投げこめよ」と富士男はいった、そうしてまたさけんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「気をつけろよ、岩が多いから乗りあげるかもしらん、そのときにあわてないように、浮き袋をしっかりとからだにつけていたまえ」　富士男は人々に注意した。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし綱がとどかなかったら、漁師は浮き袋でも木箱でもなんでも浮く物を投げてよこすだろう。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "船に備えつけの浮き袋を投げてやると、それにつかまった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は彼等はエスキモーが爲す如く、銛に長き紐を付け其｜端に獸類の膀胱抔にて作りたる浮き袋を括り付け置きしならんと考ふるなり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスキモーは斯かる浮き袋に息を吹き込み、且つ其氣の漏るるを防ぐ爲に栓を爲るの便を謀りて、角製の管を是に付け置く事なるが是と等しき物武藏西ヶ原貝塚及び下總柏井貝塚より出でたり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はコロボックルの遺物たる是等の角噐は實に浮き袋の口として用ゐられしならんと信ずるなり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "網形の押紋有る土噐片、骨器の刺さりたる大鯛の頭骨、浮き袋の口と思はるる角製の管、皆人類學教室の藏品なり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして溺れかかっている者が、つい眼の前に浮き袋のあるのをみつけたときのような表情で、それほんと、ときき返した。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カツオノエボシは、綺麗な形をしたゼラチン質の浮き袋を紫色の虹のように輝かせながら、ひっくり返ったり元に戻ったりしていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして奴の背骨近くの浮き袋が空気で膨れてしまえば、もう深く潜って死ぬことはできなくなる。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うきぶくろにつかまって、泳ぎなさいといったのだよ。",
              "citation": {
                "source": "赤土へくる子供たち",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
