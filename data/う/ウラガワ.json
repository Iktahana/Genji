[
  {
    "uuid": "963f7054-0515-5c82-ac0f-121f43adee61",
    "entry": "裏側",
    "reading": {
      "primary": "うらがわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
