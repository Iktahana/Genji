    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the reverse (side)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ヘルマンの教室を出て右を見ると河向いにウィルヘルム一世記念碑のうしろの胸壁の裏側が見える。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは上野の科学博物館とその裏側にある帝国学士院とが意外に遠く離れて見えるということである。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは考えてみると我がＭ君の説を裏側から云ったもののように思われて来る。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも彼だけの洞窟では壁の裏側に這つてる小蟲や、空氣の濕つぽい臭ひまで、殘る隈なく觸覺してゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一つの同じ景色を、始めに諸君は裏側から見、後には平常の習慣通り、再度正面から見たのである。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ一つの現象が、その隠された「秘密の裏側」を持ってるということほど、メタフィジックの神秘を包んだ問題はない。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいこの額の景色の裏側には、どんな世界が秘密に隠されているのだろうと。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幾度か額をはずし、油絵の裏側を覗いたりした。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者にしてもし、私の不思議な物語からして、事物と現象の背後に隠れているところの、或る第四次元の世界――景色の裏側の実在性――を仮想し得るとせば、この物語の一切は真実である。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私はすべての印象を反対に、磁石のあべこべの地位で眺め、上下四方前後左右の逆転した、第四次元の別の宇宙（景色の裏側）を見たのであった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも形而上の実在世界は、景色の裏側にあるのか表にあるのか。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕の裏側から脇の下へかけては、さかなの背と腹との関係のように、急に白く柔くなって、何代も都会の土に住み一性分の水を呑んで系図を保った人間だけが持つ冴えて緻密な凄みと執拗な鞣性を含んでいる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側は滑かであるが、裏側はずいぶんざらざらして荒筵のような縞目が目立って見える。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この縞はたぶん紙を漉く時に繊維を沈着させる簾の痕跡であろうが、裏側の荒い縞は何だか分らなかった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "リヒテンベルグの場合に放電板の裏側にできる第二次像の同心環が米田氏の現象に類するのは注意すべき事である。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻も早く修理したくて、まだ空襲警報が解除されていないのに、油紙を切って、こわれた跡に張りつけましたが、汚い裏側のほうを外に向け、きれいなほうを内に向けて張ったので、妻は顔をしかめて、あたしがあとで致しますのに、あべこべですよ、それは、と言いました。",
              "citation": {
                "source": "春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その硝子戸の裏側には、金文字でこうなっていました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその裏側に、「注文はずいぶん多いでしょうがどうか一々こらえて下さい。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の裏側には、「ネクタイピン、カフスボタン、眼鏡、財布、その他金物類、　ことに尖ったものは、みんなここに置いてください」と書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大急ぎで扉をあけますと、その裏側には、「クリームをよく塗りましたか、耳にもよく塗りましたか、」と書いてあって、ちいさなクリームの壺がここにも置いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の裏側には、大きな字で斯う書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の裏側に工場がある。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにかえって「裏側から見た戦争」というものがわりによく出ているようである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その硝子戸の裏側には、金文字でかうなつてゐました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその裏側に、「注文はずゐぶん多いでせうがどうか一々こらえて下さい。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の裏側には、「ネクタイピン、カフスボタン、眼鏡、財布、その他金物類、　ことに尖つたものは、みんなこゝに置いてください」と書いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大急ぎで扉をあけますと、その裏側には、「クリームをよく塗りましたか、耳にもよく塗りましたか、」と書いてあつて、ちひさなクリームの壺がこゝにも置いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺り――堂ビルの裏側は焼跡で、ひっそりと暗かったが、たった一つ、ぽつりと灯がついているのを見ると、豹吉は、「ああ、あそこや、あそこや」　と指した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達はその中で、一等堂々として見える新九番館を的にして行ったのだったが、玄関も窓も、すっかり暗くなっていたので、已を得ず、その裏側にある東京ホテルの玄関を敲いた。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤井先生は黒板のうらがわにかけてある竹のむちを持って、つかつかと石太郎のところへいき、いいかげんにしとけと、むちのえで、石太郎のこめかみをこづかれる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
