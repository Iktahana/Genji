    "definitions": [
      {
        "index": 1,
        "gloss": "bright (weather, mood, voice, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
