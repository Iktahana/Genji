        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "初めて大久保の新居に移った時は、春の麗らかな日であって、裏の竹藪で鶯がしきりに鳴いてた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の済んでしまった後の工事場は、麗らかな春の日でも淋しいものだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の陽ざしが麗らかに拡がった空のような色をした竹の皮膚にのんきに据っているこの意味の判らない書体を不機嫌な私は憎らしく思った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕の雲は火の如き夏の暮方、または日ざし麗らかに天｜清める秋の朝なんど、あるいは黒しくして、さすがに少時は塵埃の舞ふ都の中にあるをすら忘れしむ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "折り折り人の影がかなたの山の背こなたの山の尾に現われては隠れた、日は麗らかに輝き、風はそよそよと吹き、かしこここの小藪が怪しげにざわついた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「然う、」　と云つて其處に立つて考へたのは、身綺麗らしい女中であつたが、私はよくも見なかつた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狹い町に目まぐろしい電線も、銀の絲を曳いたやうで、樋竹に掛けた蜘蛛の巣も、今朝ばかりは優しく見えて、青い蜘蛛も綺麗らしい。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡そあらゆる速力と物音とを失って、麗らかな日ざしを宿したうす塵埃のかげろうの底で、静かに蠕動するそのたあいもない姿を、私はこの上もなく愛した。",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る麗らかな天気の日に、秋の高い青空を眺めながら、遠い昔の夢を思い出した。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその昏睡から醒めた時、彼は昔の青虫とは似もやらず、見ちがうばかりの美しい蝶と化して、花から花へ遊び歩き、春の麗らかな終日を、恋の戯れに狂い尽した末、歓楽の極に子孫を残して死ぬのである。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやそこには、何の鬱陶しい天氣もなく、來るべき航海日和の、いかに晴晴として麗らかに知覺せらるることぞ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にこそ、あの Auld lang syne（螢の光）の旋律が、古き事物や舊知に對する告別の悲しみを奏しないで、逆にその麗らかな船出に於ける、忘却の悦びを奏するのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間も、銀の輪を画くもの空に響く、何ともわかず、麗らかに甘く、くるしく、湿気さへ帯びて、その輪は次第に一｜点に縮まらんとす。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防整列玲瓏たり、燦爛たり、不尽の山、麗らや大海はるかに辷りあがる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼ひらけば、小春のごとも麗らかに空晴れわたり、身辺は雑木踈らに、名も知らぬ紅花｜叢咲き涼風の朝吹く汀、砂雲雀優にあがれり。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌輝る日麗ら万劫経たる海亀のこの諦めの大きなるかも　　　　　　　（原作）（27）┤　　　└日に照られ波にさらされ海亀の甲羅の苔も青寂びにけり　　　　　　（改作）　凡てがかういふ風であつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は時としてその繊細な平安朝の詠嘆、乃至は純情の雅びやかなる啜り泣き、若くは都鳥の哀怨調に同じ麗らかな心の共鳴を見出す事はある、而しなほ苦い近代の芸術にはまだその上に堪へがたいセンジユアルな日光の触覚と渋い神経の瞬きとを必要とする。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある春の麗らかな日曜日の朝お稽古に行ったら、稽古が済んでから翁は筆者を机の前に招き寄せて云った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその美意識によって春の野の花に調和し、春の日の麗らかさを高潮さすべく、最もふさわしい舞い姿にまで、代を重ねて洗練されて来たのが、あの蝶の舞い型であると考えられる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種類の鳥の唄う諧調は、全然無意味のまま、相似通っていて、春の日の麗らかさに調和し、駘蕩の気分を高潮さすべく、最もふさわしい諧調にまで、元始以来洗練され、遺伝されて来ている諧調の定型であるかのように思われる。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "麗らかな懶い春であった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その麗らかな自然の中で、相闘っている一方の人間が充分の余裕をもってその対策を考えているのだった。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清新な暖かい気流、麗らかな陽光。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近郷近在の村々は祭りの季節に入つて、私の知友連は野良その他の仕事を休み私の部屋を訪れて私に依つて西洋流のダンスを習つてゐたが、あまり毎日／＼麗らかな天気が打ち続く故、ひとつ、あの！",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "麗らかな珍らしい秋の一日を、それまで楽しんでゐた私も、同様な気持であつただらう太田も、一度に深い憂鬱と気づかひに捕はれて、医者のゐる上流へ急いだ。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一文は、その出立の朝の、空は麗らかに晴れ渡つて、もうやがて間もなく桃の花でも開きさうな温い朝の、三方を蜜柑の樹に深々と覆はれた丘を屏風とした村の――私達一行の出発の光景です。",
              "citation": {
                "source": "馬上の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ覚えているのは、丑尾さんが着古した袖無のちゃんちゃんを着て、頭を小ちゃなおちごに結っていたことと、それから、その日の小春の日影が実にうららかに暖かくのどかであったということだけである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは毎日一日役所の殺風景な薄暗い部屋にのみ籠っているし、日曜と云っても余計な調べ物や内職の飜訳などに追われて、こんな事を考えた事も少ないが、病んで寝てみると、急に戸外のうららかな光が恋しくて胸をくすぐられるようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手前はうららかな孔雀石の馬蹄形の淵になってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
