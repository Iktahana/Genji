        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが出来ざあ腕っこきでグリゴリー・ペトニコフから取り返しねえ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトモト千六は無敵な商売上手に生れ付いていたのが、女に痴呆けたために前後を忘れていたに過ぎないので、こうして本気になって、女にも酒にも眼を呉れず、絶体絶命の死身になって稼ぎはじめると、腕っこきの支那人でも敵わないカンのいいところを見せた。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だもんだから、お奉行さまも、ではだれか腕っこきの者にでもごく内密にやらせましょう、っていってるところへ、運よく行き合わしたのがあばたのあのだんななんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして腕っこきですよ。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクソウルは、タイタニック号でこそ四等運転士だったが、主席舵手として最長年の海上生活の経験を有する実際家上りの腕っこきだった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "何喰わぬ顔をして翌る朝、台湾館へ帰って来ると直ぐに華盛頓の大使に頼んで、紐育のプレーグっていう腕っこきの警察官に頼んだものだそうです。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っこきの特務員が、大きな眼を開けて、片時も放さず袋を握っていくのだ。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本名は綱吉といい、非常に腕っこきの岡引であった。",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っこきだけれど、少しガツガツした仕事振りで、品がない。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾児も七、八人持っていて、目明し仲間での腕っこきであった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "代官松は江戸においても、名うての腕っこきの目明しであって、その上に紋也と同じように、神田の区域に住んでいた。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っこきのところを束でお願い申したいんで」「キキキ貴様が、あ……案内して江戸へ戻るというのか」「はい。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの天一坊事件や、雲霧仁左衛門事件で大活躍をした方で、まア、腕っこきの警部さんといったところ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その月の晦日、天気の良い晩を選んで、平次は与力笹野新三郎を動かし、南町奉行から名指しで腕っこきの組を二十人ばかり駆り集め、一隊は牛込へ、一隊は麻布へ、一隊は築地へ、有名な寺三つに配置しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄哥、大層沈んでるじゃないか」「えッ」　振り返ると、石原の利助という四十男、同じ御用仲間ですが、評判の腕っこきで、平次とは自然、張合となっている人間です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り引つれて来たのは、人数は少ないが、平次の手下で、一騎当千の腕っこきばかり。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "振袖源太",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪之は小柄な若者で、顔だちもきりっとしているし、いかにも腕っこきの職人、といった感じにみえたが、いまはぐあいが悪いからだろう、眼はとろんとして動きが鈍く、唇にもしまりがなく、去定に診察されていながら、診察されているということにも、はっきり気がつかないようであった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕っこきという帳場だから、みんなわき目もふらない。",
              "citation": {
                "source": "醤油仏",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くり返していうが、わがロマン派の中からは、ひっきりなしに腕っこきの悪玉がでてきて（わたしは「悪玉」という言葉を好きで使うのだ）、俄然おどろくべき現実に対する敏感さと、実証的なものに対する知識を示すので、呆気にとられた警察や世間のものは、ただ茫然として舌打ちをするばかりである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちに政治家になってしまったが、若き記者としての万逸君は、名著『生死の境』を書いたりして、腕っこきの一人であった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダラニー、ザルモンド、ヘス　男女のトリオだが腕っこきが揃っているのでなかなか面白い。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大蝶丸は缶詰を東京まで積んでいって、三時間ばかりめえ帰って来ただ」と扶原支配人はゆっくりと云った、「あの船長は腕っこきで、そんな事故を起こしたことは一度もねえし、起こしたとすればちゃんと報告するだよ、海事裁判法（？",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男の鉄なあこは、専属の船頭である倉なあこ（ぐず倉）とともに、浦粕きっての腕っこきといわれた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千本」では腕っこきの船頭を揃えていながら、求められない限り、決して客に教えたり、客の意志に反対するようなことはない。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時はまだおつるには兄（のちに海で死んだが）がいて、若い漁師のうちでは腕っこきといわれるくらいだったから、べつに家へ仕送りをする必要もなく、好きな芸事の稽古にうちこむことができた。",
              "citation": {
                "source": "扇野",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大蝶丸は罐詰を東京まで積んでいって、三時間ばかりめえ帰って来ただ」と扶原支配人はゆっくりと云った、「あの船長は腕っこきで、そんな事故を起こしたことは一度もねえし、起こしたとすればちゃんと報告するだよ、海事裁判法（？",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれは参ちゃんのような能はねえけれど」と彼は別れるときに云った、「それでもいちにんまえの職人にはなるつもりだよ」「おめえは腕っこきになるさ」と参吉は励ますように云った、「やぶいりに会おう」三　それから三年経った秋、おひさの母親が死んだ。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「島藤」では腕っこきの一人になったようすで、大名屋敷や金持の家へ、直し物にかようこともあり、休みの日にも、遊ぶより仕事をするほうが面白い、というふうであった。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
