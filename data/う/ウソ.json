      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lie",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "舌もつれようともつれまいと花に嘘などつけはしないんだ。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身であるといふことは、嘘をつかないことであり、自分自身であることは意志的であることである。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　あははははははは………嘘だわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　今迄のはみんな嘘事と。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘字か、どうか不安なのである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中に、あんなにグロテスクな嘘をさかんに書き並べて、こんどはくるりと裏がえしの同様の嘘をまた書き並べています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ言葉で、その言葉には、みじんも嘘が無いのでありますが、ただ言葉で、あなたへの愛の証明をするよりほかには、何ひとつできぬ僕自身の無力が、いやになったのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嘘ですよ」一陣の風がスケッチブックをぱらぱらめくって、裸婦や花のデッサンをちらちら見せた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これは嘘なんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるっきり嘘なんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対に嘘じゃない」　私はひとりでふらふら外へ出た。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その美談は決して嘘ではない。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "としをとると自然に芸術が立派になって来る、なんてのは嘘ですね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は、少し嘘を言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、嘘を言わなくなりました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「フヽヽ、言ふと、みんなが呉れ呉れ言ひ出すから嘘を言ふちやつたい。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院で手術した患者の血や、解剖学教室で屍体解剖をした学生の手洗水が、下水を通して不忍池に流れ込み、そこの蓮根を肥やすのだと云うゴシップは、あれは嘘らしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は嘘をついてゐるのぢやありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもまた、見渡す限り、ただ薄みどり色の茫洋乎たる大空洞の片隅に、幽かな黒一點をとどめてゐるものが、たとひそれは嘘にしても月の影法師だと云はれて見ると、鯛の大群や火事だと思つて眺めるよりは、風流人の浦島にとつて、はるかに趣きがあり、郷愁をそそるに足るものがあつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浦島は驚き、「いや、嘘だらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この龍宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、知らなかつたなんて嘘ついて、ひどいわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鼻をすすり、嘘泣きをした。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて嘘泣きをしながら、「ついでにお前ひとりで、その岩乘ないい舟を作つてくれないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「世の中の人は皆、嘘つきだから、話を交すのがいやになつたのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな、嘘ばつかりついてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてさらに恐ろしい事は、その自分の嘘にご自身お氣附きになつてゐない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だつて、若い時からあなたのお家へ奉公にあがつてあなたのお世話をさせてもらつて、それがまあ、こんな事になつて、あなたの親御さんも、あれならばなかなかしつかり者だし、せがれと一緒にさせても、――」「嘘ばかり。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おや、どこが嘘なのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそろそろ空にも昼の明りが消えて了はうとしてゐて、電燈をめがけて飛んでくる虫も増していつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
