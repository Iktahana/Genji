        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを海山遠く取入れた話をするなんて、あんまり大袈裟だぞ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鸚鵡の持ち主はどんな女だか知らないがきっと、海山千年の女郎だろうと僕は鑑定する。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥海山はトリノウミと言ったらしい形跡があるので、これも入れるとするとＲはさらに四分の五倍だけに増すわけである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海山の寂しさを越えねばなりません。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　今日、今夜――唯今の事は、海山百里も離れまして、この姉さまも、知りますまい。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田の鳥海山だべが。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それじゃ、二人で、海山のお物語が出来ますね。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉名の文は典雅荘重であり、以言の文は奇を出し才を騁せ、其風体各々異なれど、いずれも文章の海山の竜であり象である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "※かなり我が高千穂、　　かぎりなし千重の波折、　　いざ祝げよ日の直射す　　海山のい照る宮居を。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああはれ、また春秋、　　ああはれ、そが海山。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※かなり我が高千穗、　　かぎりなし千重の波折、　　いざ祝げよ日の直射す　　海山のい照る宮居を。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからわしの身の丈ほどの大がめに酒を盛って、海山の珍しいごちそうをそろえて呼んでやろう、しかし、もしもらいそこねたら、あんな広言を吐いた罰に、今わしがしてやろうと言ったとおりをわしにしてくれるか」と言いました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わづか一間、それがお葉には海山の隔りのやうにも思へた。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――学資を十分に取って、吉原で派手をした、またそれがための没落ですが、従って家郷奥能登の田野の豊熟、海山の幸を話すにも、その「入船帳」だけは見せなかった。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が立合うて、思うには、祖父祖母、親子姉妹、海山百里二百里と、ちりちりばらばらになったのが、一つ土に溶け合うのに、瀬戸ものの欠が交っては、さぞ疼かろう。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大観を単なる海山の風景画家としてだけ見て行きたい。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユトリロはコンミニストの本部を描いたことを、大観が海山の風景を描き、その売上げを聖戦の資に献じたといふこととをいまここに論じようといふのではない。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚なる者なればこそ人にも勾引され候て、帰りたき空さへ見えぬ海山の果に泣倒れ居り候を、誰一箇も愍みて救はんとは思召し被下候はずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "島前の菱浦から西郷港に来る間の海山の眺めは、日本でも沢山はあるまいと思はれるほど景色の好いところですよ。",
              "citation": {
                "source": "談片",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州第一の高山は、豐後日向の界なる祖母嶽の五千八百尺、四國第一の高山は阿波なる劍山の六千四百五十二尺、中國第一の高山は伯耆なる大山の五千六百五十三尺、奧羽第一の高山は羽後なる鳥海山の七千三百五十九尺也。",
              "citation": {
                "source": "一萬尺の山嶽",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "渓流の潺湲もなければ、海山の眺めもなく、街道から入つて行くと、Ｆ町から通じてゐる電車の停留場があつて、其向うに混雑と二階建の家がかたまつてゐるといふやうな温泉場。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで明るかつた海山もわびしく辛くなつて来るやうな気がした。",
              "citation": {
                "source": "島からの帰途",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、円海山までいってたら、いまごろ、ひでえことになってたな」　高志がナップザックからラジオを出し、ぬれていないことをたしかめ、スウィッチを入れると、グラス・ルーツの〈レッツ・リヴ・フォー・トゥデイ〉が飛びこんできた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇穀言の随筆にも、宋僉憲は幼にして父をうしない、その形容を識らないので、方海山人に肖像をかいて貰って持ち帰ると、母はそれを見て、まことに生けるが如くであると、今更に嘆き悲しんだということが書いてある。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし紀州灘で見た熊野の連峰や、鳥海山や、彌彦山は今見ても好からうと思はれる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かずならぬ甥めが後世安楽のために、関白殿が施主となって大法要を催さるるとは、御芳志は海山、それがしお礼の申し上げようもござらぬ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少納言の御芳志は海山じゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
