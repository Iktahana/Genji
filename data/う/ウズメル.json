        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこで少し離れた土管に腰をかけて煙草を吸ひながら描きかけの繪の穴を埋める事を考へて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五六人の人かげが、何か堀り出すか埋めるかしてゐるらしく、立ったり屈んだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無闇に井戸を掘って熱泉を噴出させたために規則正しい大湯の週期的噴泉に著しい異状を来したというので県庁の命令で附近の新しい噴泉井戸を埋めることになった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、毛のすり切れてしまった破れ外套にくるまって、頭を襟の中に埋めるようにすくんでいた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんな生きている者を埋めるんですか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五六人の人かげが、何か掘り出すか埋めるかしているらしく、立ったり屈んだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想は書棚を埋める壁土にしか過ぎなかった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし黄銅の場合にこの種の単分子皮膜が固体面に沿うて自由に伸展し、吸着した湿気やガスを駆逐しつつ裂罅を埋めるかどうかは実験しなければ確かなことはわからない。",
              "citation": {
                "source": "鐘に釁る",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五、六人の人かげが、何か掘り出すか埋めるかしているらしく、立ったりかがんだり、時々なにかの道具が、ピカッと光ったりしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに小さな五六人の人かげが、何か掘り出すか埋めるかしてゐるらしく、立つたり屈んだり、時々なにかの道具が、ピカツと光つたりしました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁公は堀を埋める組、親父は下水用の土管を埋めるための深いみぞを掘る組。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで少し離れた土管に腰をかけて煙草を吸いながらかきかけの絵の穴を埋める事を考えていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後を埋めるものは前の続きの思考状態かというと、それは直ぐに取戻されては来ない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを和蘭の馬鈴薯を雪の様におろしてオリーブ油、酢、塩、胡椒で味をつけた中へなかば埋める。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又何とか云ふ可恐い島でね、人が死ぬ、と家屬のものが、其の首は大事に藏つて、他人の首を活きながら切つて、死人の首へ繼合はせて、其を埋めると云ふ習慣があつて、工面のいゝのは、平常から首代の人間を放飼に飼つて置く。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、べつの皮肉屋の言うのには、「七月一日から煙草が値上りになるのは、たびたびの盗難による専売局の赤字を埋めるためだ」と。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "埋めるのはいつでも埋められるだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "好奇心で一ぱいのかの女には却って何やかや観察の時間が与えられ都合がよかったが、常識的の社交の儀礼に気を使うらしい夫人は、ひどく手持ち無沙汰らしく、その上茶を勧めたり菓子を出したりして、沈黙の時間を埋めることを心懸けているように見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄念を深く土中に埋めるのです」　その苗木の列には、或は銀座通とか、日比谷とか、或は植主の生地でもあろうか、福岡県――郡――村とか書いた建札がしてあった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸新さんは、人足がいくらいくら、井戸囲いの土管がいくらいくら、土管のつぎめを埋めるセメントがいくらと、こまかく説明して、「先ず、ふつうの井戸なら、三十｜円もあればできるな。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "死力を籠めて、起上らうとすると、其の渦が、風で、ぐわうと卷いて、捲きながら亂るゝと見れば、計知られぬ高さから颯と大瀧を搖落すやうに、泡沫とも、しぶきとも、粉とも、灰とも、針とも分かず、降埋める。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死力を籠めて、起上ろうとすると、その渦が、風で、ごうと巻いて、捲きながら乱るると見れば、計知られぬ高さから颯と大滝を揺落すように、泡沫とも、しぶきとも、粉とも、灰とも、針とも分かず、降埋める。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、私の堤の決潰を埋めるために葛岡さんを土俵として持って来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の遺骸は、他に埋める墓所もないので、母の弟が家を受け継いでいる染井の墓地へ葬りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この中に生きたもの沢山いるのかい」「そうよ、沢山」「その生きたもの死んだら、どこへ埋めるの」　わたしは、はたとつまりながら「さあ」と言っただけでいると、わたくしに関わず文吉はひとり諾き顔で言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "困るという感情が強く胸から身体の八方を冷酷に焼け爛らして行くとそのあとへ絶望という空虚が時間も空間も浸み込めない緻密の限りの質を持ち込んでそこを埋める。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体の見つかったものは、穴を掘って埋めたが、時には手間をはぶいて四五人いっしょに一つの穴へ埋めるというありさまであった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の方へ背中を向けて頭を粟稈に埋めるようにしているが、その背中はぶるぶる慄えていると云うのだね。",
              "citation": {
                "source": "鼠坂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "死体の見つかったものは、穴を掘って埋めたが、時には手間をはぶいて四五人いっしょに一つの穴へ埋めるというありさまだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "林太郎はただツルの花をうずめるのをみていただけに相違ない。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
