              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "宇宙服一つで無重量空間に放り出されたような手がかりのなさに、しばらくは翻弄されていたのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその三人の人影が、ものものしい宇宙服に身をかためていることも、双眼鏡でのぞいた人々の目にはうつった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱いだり着たりするのには、はなはだやっかいな宇宙服ですから」　と、ロバート大佐は釈明をしてから、じぶんの名を名乗り、ふたりの随員を紹介した。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、お前たちが月の上に安全に降りられるようにと、ちゃんとりっぱな宇宙服が用意してあるから、安心をしていい。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くその宇宙服を着てみたいですね」「そのうちに、宇宙服の着方を、だれかがおしえてくれるだろう」　艇長と三郎とが、そんな話をしているうちに、またまた艇長のところへ、報告がどんどんあつまってきた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いよいよ月の世界へ下りることになったので、皆、むこうで宇宙服の着方をおそわっているのだ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も早く来い」「あ、宇宙服ですか、もう始まったんですね。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、宇宙服の着方をおしえる。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、実物を見せるがこれが宇宙服だ」　下から、大きな深海潜水服みたいなものが、さし上げられた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙服は、架台にかかっていた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の横に、その宇宙服をおいて、説明がはじまった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足の間接のところや腰のところが、まるで蜂の腹のようになっているが、これは手足の関節や腰を曲げるのに都合がいいように作ってあるのだ」　銀びかりのする宇宙服は、見れば見るほど、ものすごいものだった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……この下に、やはり軽合金と特殊ゴムとで出来た長靴をはき、宇宙服にぴっしゃり取付ける。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのほか、この宇宙服には、いろいろな仕掛けがついていますが、いずれも自動的にはたらくようになっているから、みなさんは、べつに手をつけなくてよろしい。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんしんしたでしょう」「うまく出来ているなあ」　艇夫たちは、口々に、このすばらしい宇宙服のことをほめた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ですか、君の質問は……」　三郎は、ちょっとあかい顔になって、「どうも、心配なことがあるので、おききしますが、この宇宙服を着ている間は、何にもたべられないし、何にものめないのですか」　と、たずねた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――みなさん、釦に気をつけてくださいよ」着陸命令　三郎たちは、その場で、宇宙服を配給され、それを着た。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、宇宙服を皆が着てしまったところは、実に異様な光景であった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして艇夫たちは、宇宙服を着こなすことが出来たのだった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙服をぬぐのですねえ」「いや、宇宙服を着たまま、それぞれの職場へもどってください。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすぐ、月へ上陸することになるから、今から宇宙服に身をかためていてください」「たばこがのめないから、つらいなあ」「たばこはのめないですよ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "司令塔に入ってみると、艇長や、その他の高級艇員たちも、いつの間に着たのか、すっかり宇宙服に身をかためて、持ち場についていた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇長の宇宙服には「艇長」と書いた札が胸と背中にはりつけてあった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつの間にか、艇長も宇宙服を着られたのですね」「おお、お前は艇夫の風間三郎だな。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の上へ降りれば、もっとらくになるよ」　艇長は、三郎の宇宙服を念入りにしらべてくれた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い宇宙服をきているのに、らくに歩けるようになったよ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "金属製の宇宙服をきているとは思われない。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の外套ぐらいの重さに感じていた宇宙服が、もっとかるくなって、やがて浴衣をきているくらいのかるさになってしまったから、三郎は、全くびっくりしてしまいました。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
