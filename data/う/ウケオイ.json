    "definitions": [
      {
        "index": 1,
        "gloss": "contract (for work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "相場師か請負師とでもいったような男が二人、云い合わせたように同じ服装をして、同じ折かばんを膝の上に立てたり倒したりしながら大きな声で話していた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の仕事は、すべて請負制度だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負制度は彼等の愛銭心を挑発して働かせる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負作業の出来高を調べるものゝように、仕事場に這入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負の〔二字分空白〕さんも居るだらう。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土木建築設計工作等請負　ニジニ・ハラウ、ふん、テレピン油の工場だなんて見るのははじめてだぞ。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「請負の方でも余程の損だったでせう。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体、あれは請負の岩間組の技師が少し急いだんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道院から進行検査があるので請負の方の技師のあせり様ったらありませんや、従って監督は厳しく急ぎますしね、毎日天気でカラッとして却って風は冷たいし、朝などは霜が雪のやうでした。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は農業でお父さんは村長でしたが平太はお父さんの賛成によって、家の門の処に建築図案設計工事｜請負といふ看板をかけました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エレベータとエスカレータの研究の為急に東京に参り候、御不便ながら研究すむうちあの請負の建物はそのまゝお使ひ願ひ候」　お父さんの村長さんは返事も出させませんでした。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生胆取りだの死人使い、奴隷売買、人殺し請負いナンテものは西洋人でなくちゃ出来ない仕事だと聞いておりましたがマッタクその通りだと思いましたナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "構造物の材料や構造物に対する検査の方法が完成していれば、たちの悪い請負師でも手を抜くすきがありそうもない。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると税務署長がすっかり変ってしまって請負師か何かの大将のやうに見えて来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "印刷を請負うのにも、近頃は前金をとり、不意の活字は同業者のところへ借りに走っていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社員、商人、株屋、土木請負師、興行師に芸人、土地の親分と、小菊たちにはちょっと扱い馴れない人種も多かった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子とは大分時代の違う按摩の娘は、この二三年二人とも上野の料亭山下に女中奉公をしているうちに、亀井戸に待合を買ってもらったとか、貧乏なブリキ屋の娘が、テケツ・ガールから請負師の二号になり、赤ん坊を大した乳母車に載せて、公園を歩いていたとか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の請負師だって云うのよ、頼みもしないのに無理に引かしてさ、石段の下に景ぶつを出す、射的の店を拵えてさ、そこに円髷が居たんですよ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリーはリヨンで王党の党員だったが矯激の振舞いがあったのでしばらくフランス縮緬の輸出の仕事を請負って東洋へ来た。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニラのキャッポ区に雑貨商を出している太田恭三郎が、アメリカ当局と交渉して、ベンゲット移民への食料品納入を請負い、味噌、醤油、沢庵、梅干などを送って来てくれたのは、そんな時だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負師や大工に責めを帰していいのか、在来の建築方式そのものに欠陥があるのかどうかわからない。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると請負師や大工に言ったくらいでねずみが防ぎきれるものならば大概の家にはねずみがいないはずである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百人という人間を髭を捻り稔り顎で使って来てる大請負師だぞ。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初、レーザーディスク株式会社との付き合い方は、仕事一本単位の請負でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中央部の突起部が緑屋を救い、この工事を請負った親方をも救ったのであった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、陸上における請負仕事、あるいは「せい分」仕事、と同じものだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場は父のものだが、開墾は全部矢部という土木業者に請負わしてあるので、早田はいわば矢部の手で入れた監督に当たるのだ。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また他の或る日本人は或る工事を請負って職工を捜すため浦塩哈爾賓間を数度往復したので三カ月の禁錮に処された。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この婆さんは呉服屋の仕立物をうけおい、その呉服屋が此村に持って居る貸家に、長い事、不精に貧しく暮して居るのである。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっこう　たくさん　うけおいますから　ゆうゆう　くらせるくらいには　かぜげました。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
