        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "書きくたびれるとスリッパのまま、廻転椅子の上に座り込んで、膝を抱えながらプカリプカリと、ウルトラマリンや、ガムボージ色の煙を吐き出す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国人なら、ここには無用だから、さっさと帰ってもらおう」　と、金博士は、大きなウルトラマリン色の色眼鏡を手でおさえながら、椅子のうえから立ち上ったのであった。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い航跡が消えて、元のウルトラマリン色の青い海にかえるところあたりに、執念ぶかくついてきた白いかもめが五六羽、しきりに円を描いては、漂流するごちそうめがけて、まい下りるのが見られた。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "色素は芸術家が使うウルトラマリン、カルミンおよびクリムソン・レーキ；アントワープ・ブルー、クローム・イエロウおよびインディアン・インク；だけではなく、普通のペンキ屋が使う粗野な色素もあるていど混ぜ物処理をされている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルミン、マッダーレーキ（アカネの根から作る赤紫色素）、ウルトラマリン（群青）、インディアンイェロウ（オレンジイエロー）は完全に純粋な水がなければ作ることはできない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "油絵具のウルトラマリンを生のままで力強く塗ったような濃い色彩である。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "油絵具のウルトラマリンを生のままで力強く塗つたやうな濃い色彩である。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "15例の着色剤は人工のジャーマン群青（ウルトラマリン）であり、これはナトリウムとアルミニウムの硫化物である。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び飛びに白の無地を交へて、クリムソン・レーキ、ウルトラマリン、ビリジヤン及びガムボージの各色を配した。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "またアメリカ人は“青くなる”といった私の答えに，頬にベッタリとコバルトブルーやウルトラマリンの絵具をなすりつけたとんでもない顔を連想したのかも知れません。",
              "citation": {
                "source": "“青い顔”",
                "author": "間所紗織",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
