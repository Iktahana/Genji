        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なぜならそこには、文化の末路を杞憂させるものがあるからである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時津から早岐まで、哀れげな小蒸気船に乗っての大村湾縦走はただうすら寒い佗しい物憂さの単調なる連続としてしか記憶に残っていない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私窩子のやるせない憂さ晴しである。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふる郷を立つときから紅色に萌し始めた人情の胸の中の未練のほむらは子の慕わしさにかき立てられ旅の憂さに揺り拡げられ、こころ一面に燃え盛っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さまだとて金滿家の息子株が藝人たちに煽動られて、無我夢中に浮かれ立つとは事が違ふて心底おもしろく遊んだのではありますまい、いはゞ疳癪抑へ、憂さ晴らしといふやうな譯で、御酒をめし上つたからとて快くお醉ひになるのではなく、いつも蒼ざめた顏を遊ばして、何時も額際に青い筋が顯はれて居りました。",
              "citation": {
                "source": "この子",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、近頃はまだ噂の行き亘らぬ吉原方面に場所を変え、そこを取引先との交際場にも、自分の憂さ晴らしにも使うようになった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂さも辛さも、糸に掛けて唄っておしまいなさりまし。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……垣の卯の花、さみだれの、ふる屋の軒におとづれて、朝顏の苗や、夕顏の苗……　またうたに、……田舍づくりの、かご花活に、づツぷりぬれし水色の、たつたを活けし樂しさは、心の憂さもどこへやら……　小うたの寄せ本で讀んだだけでも一寸意氣だ、どうして惡くない。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は紛れるともなく、その日その日の憂さを忘れて渡り歩るいた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは何もおつしやらず、例の如く少しお背中を丸くなさつて伏目のまま、身動きもせず坐つて居られましたが、やがてお顔を、もの憂さうにお挙げになり、学問ハオ好キデスカ　と、ちよつと案外のお尋ねをなさいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの憂さうに、さう言つた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもときどき、思ひ出したやうに、甚だ散文的な口調で、あれが三ツ峠、向ふが河口湖、わかさぎといふ魚がゐます、など、物憂さうな、呟きに似た説明をして聞かせることもある。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、みな、この憂さに沈むことの害毒を人一倍知れる心弱くやさしき者の自衛手段と解して大過なかるべし。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京吉の相手をしたダンサーは、慾も得も商売気も、そして憂さも忘れて――いや自分を見失ってしまうくらい、うっとりと甘くしびれるのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十番館には、戦争犯罪容疑者として収容される前夜、青酸加里で自殺した遠衛公爵の三男坊が憂さばらしか、それとも元来享楽的なのか、時どき踊りに来るほか、数名の華族のいわゆる若様が顔を見せて、ある際物雑誌にその行状記を素ッ破抜かれた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちのお嚊もどんと殖せ、俺ちも壮健で、うんと肥せ、種蒔け、種蒔け、蒔かずにやゐられぬ、蒔かねば憂さやの、子種はどつさり、畑は上々で、畝高で、水もよくきく、肥料もよくきく、種蒔け、種蒔け、づんと殖せ、そこら一面鋤いて返せ。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "台南旅情もの憂さや、老酒や、瓜子はとり食めども、にほひなし、昼はまだ彩燈の切子硝子。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "臺南旅情もの憂さや、老酒や、瓜子はとり食めども、にほひなし、晝はまだ彩燈の切子硝子。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の常ならば生面の客にさえ交わりを結びて、旅の憂さを慰めあうが航海の習いなるに、微恙にことよせて房のうちにのみ籠りて、同行の人々にも物言うことの少なきは、人知らぬ恨みに頭のみ悩ましたればなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が立ちし日には、いつになく独りにて燈火に向かわんことの心憂さに、知る人のもとにて夜に入るまでもの語りし、疲るるを待ちて家に還り、直ちにいねつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベアトリチエとの淨き戀、戰爭の間の苦、逐客となりてアルピイ山を踰えし旅の憂さ、異郷の鬼となりし哀さ、皆我詩中のものとなりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが日頃の憂さは悉く散じたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえＢＴＲＯＮを見舞った一連の動きには、一喜一憂させられた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗野にして幼稚なる私の言葉などを俟つまでもなく、そこには、あなた方の憂さを晴し健やかな夢を誘ふであらう万花燎乱たる十誡が、百も千も咲きそろふて居ります。",
              "citation": {
                "source": "〔モダン紳士十誡〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "悩みよ、恐れよ、憂さよ、この痴れ心よ、夢よ――消えて、花となれの切ない憧れであつた。",
              "citation": {
                "source": "真夏の夜の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の常ならば生面の客にさへ交を結びて、旅の憂さを慰めあふが航海の習なるに、微恙にことよせて房の裡にのみ籠りて、同行の人々にも物言ふことの少きは、人知らぬ恨に頭のみ惱ましたればなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が立ちし日には、いつになく獨りにて燈火に向はん事の心憂さに、知る人の許にて夜に入るまでもの語りし、疲るゝを待ちて家に還り、直ちにいねつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにたくさんひとが居るのに、誰も僕を知っていない、僕に留意しない、そう思うと、――いや、そうさかんに合槌うたなくたってよい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつの素顔は、眼も口も眉毛もないのっぺらぼうさ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうまあセカセカ云ふものではない、急病人も世の中にはあらうさ」　看護婦は急に消沈して俯いてしまつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
