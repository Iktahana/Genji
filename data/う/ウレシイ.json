        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "少しく飛躍ではありますが、印象の瞬間捕捉なぞといふ考へも、一見甚だ嬉しいことではありますが、而もそれが嬉しいのは、人間を器械の如く推定した上でのことでありまして、その実人間は器械ではありませんからさういふ考へは思ひ付きに終るでありませう。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォルムのない競技で以て、徒らに勝たうとばかりしてゐるやうなもので、仮令勝てたにしても、競技そのものを楽しむ気持はなく、勝つた時に熱病的に嬉しいだけで、十年の後に回想したらば、なんといふこともなかつたと、呆然としなければならない始末だらう。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる意志だけで為されたことは、為されたその時だけホンの瞬間熱病的に嬉しいかも知れなくても、なんの意義あることでもないし、人を喜ばすことでもない。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か心配でもあるのかと夫人が聞いたら、あまり楽しくて嬉しいので、いつまでこの家に住み、いつまでこんな幸福が続くかと思い、それがまた心配になって来たと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この同じ自然観が、芭蕉にあっては大いに異なり、鷹ひとつ見つけて嬉しいらこ岬　　　芭蕉　と言うような、全く魂の凍死を思わすような、荒寥たる漂泊旅愁のリリックとなって歌われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな厭な時候に、ただ一つ嬉しいのは、心ゆくばかり降る雨の夕を、風呂に行く事である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥濘のひどい道に古靴を引きずって役所から帰ると、濡れた服もシャツも脱ぎ捨てて汗をふき、四畳半の中敷に腰をかけて、森の葉末、庭の苔の底までもとしみ入る雨の音を聞くのが先ず嬉しい。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕快に喉をくすぐりながら通過して、體内にぽつと灯りがともつたやうな嬉しい氣持になる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、もう、」と言ひかけて、這ひ寄つて來た大きい蜘蛛を素早くぺろりと食べ、「おれは、もう、どんなに嬉しいか、いつそ、男泣きに泣いてみたいくらゐだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この白峰山脈縦断旅行も、これでおしまいになるのかと思うと、嬉しいような、気抜けがしたような、勝利の悲哀といったような、情ない心持が身に沁み泌みと味われて来る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ついでに洗う洗濯物が無くて、お湯にどっぷり入るときくらい嬉しいことはない。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは、健康で、着々、画業を進捗していることは、そっちからの新聞雑誌で見るばかりでなく、この間来たクルト・セリグマン氏の口からも、または横光｜利一さんの旅行文、読売の巴里特派員松尾｜邦之助氏の日本の美術雑誌通信でも親しく見聞きして嬉しい。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『独都より』の「リンデン」の作は、作者も云うてる如く、前の歌の淋しい内にも嬉しい親しみのある情調とは異なり、旅情の淋しさと自然のさびれた淋しみとを独りしみじみと味わってる情調が、一句一句の端にも湛うてる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年以前より連作論を唱えた予は、近日更に連作に就て一論を試みたく思うて居る際に、以上の四連作を得たことは、予に取って非常に嬉しいのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶なことを云われて民子は心配やら嬉しいやら、嬉しいやら心配やら、心配と嬉しいとが胸の中で、ごったになって争うたけれど、とうとう嬉しい方が勝を占めて終った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等二人はもとより心の底では嬉しいに相違ないけれど、この場合二人で山畑へゆくとなっては、人に顔を見られる様な気がして大いに極りが悪い。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに心持のよい朝だねイ」「ほんとに天気がよくて嬉しいわ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで民さんがりんどうを好きになってくれればなお嬉しい」　二人はこんならちもなき事いうて悦んでいた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しいにつけても思いのたけは語りつくさず、憂き悲しいことについては勿論百分の一だも語りあわないで、二人の関係は闇の幕に這入ってしまったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一四年ルムフォード賞牌を受けたときに、人への手紙に「私の光学上の仕事が認められたのは嬉しい。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと見ていると、何かしら嬉しいような有難いような気がして来る。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これは當時の僕にとつて、非常に嬉しいことであり、未だに深く白秋氏の御親切を忘れない。",
              "citation": {
                "source": "追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なーんだ、父っつあん、自分がやくざのくせに今迄俺がやくざになりてえと云うと目の色かえて叱るのは可笑しいや」石松は嬉しいから、多少はしゃいで言う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「今江戸中、　人気の焦点、　評判男の中村仲蔵が……」　「その仲蔵が……」と過去を想い起すらしく、Ｔ「二十年以前、　貧に窮して、　おやじ橋に捨てた　我子、仲蔵とは……」　「わしはこんな嬉しい事はない」　聞いてた雪枝が仕事の手を止めて、Ｔ「今晩にでも、　兄様に会いに行かれては？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「なりひら小僧とその一党はこんな調子のチョイと嬉しいお泥棒です」○＝同じなりひらの宅　さんぴん山左が立ち上った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにお嬉しい事なの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、かなしいやら、こわいやら、うれしいやら、はずかしいやら、胸が一ぱいになり、わからなくなってしまいまして、妹の痩せた頬に、私の頬をぴったり押しつけ、ただもう涙が出て来て、そっと妹を抱いてあげました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さんの原稿の番號をそろへるのが、毎朝、ずゐぶんたのしみなのだから、たくさんすすんでゐると、うれしい。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、うれしい時に限って、不機嫌な顔をする男なんだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに不思議なことはこの東海道には、京へ上るという目的意識が今もって旅人に働き、泊り重ねて大津へ着くまでは緊張していて常にうれしいものである。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
