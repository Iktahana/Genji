    "definitions": [
      {
        "index": 1,
        "gloss": "endorsement (of a cheque, bill, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "渋茶、甘茶、渋糟、甘糟、渋皮、甘皮などの反対語の存在も、この対立関係を裏書する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際吾人の行為に裏書きする根拠はいずこにありやというに、第一にこれら要素の空間的時間的分布が規則正しきという事なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについては世界中の信用のある学者の最大多数が裏書をしている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはここの仮説を裏書する。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違いのない筆で、領事館の裏書までしてあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民の暴動や大ストライキに××が出動するのは、それを裏書きする一つの証拠である。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒に裏書はしなかつた。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれはそのカフェがその近所に多く住んでいる下等な西洋人のよく出入りするという噂を、少し陰気に裏書きしていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また苦心の年月の長かったこと自身がその発明の巧妙さを裏書きするかのごとき暗示がほのめかされている。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番号から運転手の名前を探り出して、鼻薬を使いながら未亡人の行先を尋ねてみると、私の着眼が一々的中している事が裏書きされて来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろんあの煙突が伯爵の死後に起工されたことも、こうした判断を有力に裏書しているにはいたが……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのイヤ味は、或る事を繰り返し鍛練する事によって抜き得るので、前に掲げた各例は明らかにこれを裏書している。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには確かに生命の裏書きのしてある情景がある。",
              "citation": {
                "source": "水野仙子氏の作品について",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何んとなくその中に軽侮を投げられているような気がして、その裏書を否定するような言動をことさらに試みていたのだが、今日の演説と今の言葉とで、それをはっきり言い現わしたのを感じた時、心臓へのある力の注入を自覚せずにはいられなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあらゆる熱情を胸の奥深く葬ってしまって、氷のように冷かな正確な論理によって、自分の主張を事実によって裏書きしようとした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今おぬいの眼の前には、彼女の心の怖れを裏書きするような事実が語られているのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は復たと生れて來ない、さう思つた彼れの豫覺は悲しくも裏書きされて見えた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らの芸術に先生がたの裏書きをしてもらうくらいなら、僕は野末でのたれ死にをしてみせる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一僕たちのような頸骨の固い謀叛人に対して、大家先生たちが裏書きどころか、俺たちと先生がたとなんのかかわりあらんやだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛糞に汚れ切つたその姿にも冬の蟄居の長さと辛さが裏書きされてゐる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なんかゞホイットマン研究者の代表的な一人として見られるという事などは、日本の思想界の軽佻さを裏書きしたものと云はなければなりません。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ふのは代金の証書としては会社の手形で松村と、も一人奥田と云ふ松村の同僚の裏書が条件となつて居た。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ残つた問題は奥田の裏書である。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸畑に対する責任は手形の振出人たる信托会社と裏書人たる松村個人とがある。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れ松村はかくの如く思つて、奥田の裏書の責任を軽視した。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも厭だと云ひ切りもしないが快く裏書をしさうな様子もない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは約手で振出が誰で、裏書が誰でと云ふ条件ならと云ふので承知したんです。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥田の裏書と云つても、もし俺が親身になつて、どうか頼むとさへ云へば、反感も除れるであらうし、承諾を得ることも必ず出来得るんだ。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "石畳の上に爪立てた蹄のうらがきらりと光って、口の泡が白い。",
              "citation": {
                "source": "馬地獄",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村係長だけ、ねむりぐすりをのまされて、黒川記者がいなくなってしまったという事実によって、それがうらがきされました。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
