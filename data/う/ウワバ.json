        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "上歯と下歯がきっちり合い、引緊って見える口の線が、滑かになり、仏蘭西髭の片端が目についてあがる――父親は鮨を握り乍らちょっと眼を挙げる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べるときは、上歯と下歯を叮嚀に揃え円い形の煎餅の端を規則正しく噛み取った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上歯と下歯をまた叮嚀に揃え、その間へまた煎餅の次の端を挟み入れる――いざ、噛み破るときに子供は眼を薄く瞑り耳を澄ます。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛岡はわたくしを見ても気の付かぬ振りをして相変らず何とも言わずに例の上歯で下唇を噛み押えて笑いを我慢する様子をして、かたん／＼いわすのを続けています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に自然は上歯を下くちびるにあてがって思いきり長く息を吹いた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むし歯は自然に抜けたのもあり、医師の手によって抜かれたのもあり、年々に脱落して、現在あます所は上歯二枚と下歯六枚、他はことごとく入歯である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上歯二枚が一度に抜けたのであるから、上頤は完全に歯なしとなって、総入歯のほかはない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をさんざん苦しめた後に、だんだんに私を見捨てて行く上歯と下歯の数かず、その脱落の歴史については、また数かずの思い出がある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの思い出は、右の奥の上歯一枚である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンスーンが去ったのと歯の痛みが去ったのと、あしたはインドへ着くという楽しみとで、私は何か大きい声で歌いたいような心持で、甲板をしばらく横行闊歩していると、偶然に右の奥の上歯が揺らぐように感じた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の下歯と後の上歯と、いずれもそれが異郷の出来事であった為に、記憶に深く刻まれているのであろうが、こういう思い出はとかくにさびしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をさんざん苦めた後に、だんだんに私を見捨てて行く上歯と下歯の数々、その脱落の歴史については、また数々の思い出がある。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンスーンが去ったのと歯の痛みが去ったのと、あしたは印度へ着くという楽しみとで、私は何か大きい声で歌いたいような心持で、甲板をしばらく横行濶歩していると、偶然に右の奥の上歯が揺ぐように感じた。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の下歯と後の上歯と、いずれもそれが異郷の出来事であったために、記憶に深く刻まれているのであろうが、こういう思い出はとかくにさびしい。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしていると、上歯がみんな一時に生えている順にずり抜けた。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯――抜ける前の痛みだ、去年は旅で上歯が三枚ぬけた、今年はもうすぐ下歯が二枚ぬけるだらう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に上顎門上歯が幾分前に出て居りしや否や、下顎犬歯は普通人に比して長きや否や、犬歯の俗称鬼歯と称するものなりや否や。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と丑松は上歯を顕して、大きく口を開いて、身を慄はせ乍ら欷咽くやうに笑つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "上下揃った細い真白な歯並で、而も下歯が上歯の奥にはいり込んで合さるということがなかった。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上歯の先端と下歯の先端とがいつもかち合っていた。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、上歯と下歯とがかち合って先端で平らに合さってるために、下唇が少しつき出て残忍な相を作り、それに圧迫されて上唇が萎縮していた。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "下唇が殆んど目につかない位に歪んで、軽く上歯に噛まれてるような心持ちを与えていた。",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーニングラード大学の工科の実習生として放送局につとめているそのソヴェトの娘は、可愛く大きく育った十九歳の体だのに、笑うと上歯がみんなみそっぱだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さまも和一郎も、感情的にひっかかってごたついてばかりいたってはじまらないから、わたしは、実務的なことは実務的に片づけた方がいいでしょうと云っているだけだのに」　泰造は、ひとことも口を利かずアーム・チェアにもたれて腕組みをしている一方の手で、ときどき目立たないように上歯の義歯を動かしている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて夫人は、わざわざ上歯と下歯とを離すには当らないような言葉を口にした。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああああ、どうしても歯医者へ行かなくてはならなくなりました、上歯の妙なところに穴がポッカリあいてしまったわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次は吉沢といふ下歯が上歯にかぶさつた正直者で、えへへ　えへへ　とむやみに笑ひながら「槍の話をします」といつた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、一部の劇通に讚美せらるる「女定九郎」や、「鬼神お松」や、「うわばみお由」や、「切られお富」のたぐいは、みなこれ宮戸座の舞台における源之助の置土産である。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に挙げた「女定九郎」や、「鬼神お松」や、「うわばみお由」のたぐいは、大歌舞伎の出し物でない。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸末期には黙阿弥と対抗する著名の狂言作者にて、「佐倉宗吾」「切られ与三郎」「うわばみお由」など、その代表作と称せらる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
