        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "妾も、日出雄も、此儘海の藻屑と消えても、决して未練に助からうとは思ひませぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡す限り雲煙渺茫たる大空に漂蕩して、西も、東も定めなき今、何時大陸に達して、何時橄欖島に赴き得べしといふ目的もなければ、其内に豫定の廿五｜日も去つたならば、櫻木大佐も終には覺悟を定めて、稀世の海底戰鬪艇と共に、海の藻屑と消えてしまう事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ海の藻屑と消えるか、いつ片手をもぎ取られるか、いつ、遠洋航路につくかわからない、無細工な「海坊主」どもを、どこの「娘」が相手になるか。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し敗れたら、海の藻屑とならなければならない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、川上機関大尉は壮途半ばにして遂に南海の藻屑と消え去ってしまったのであろうか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、敵は海の藻屑となったのに、おれ達は生残った。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の者とも分らない航海者や、船乗人が、暴風で船を壊されて、海の藻屑となって、この浜辺に打ち上げられたものを、この海岸の漁猟人が此処に葬ったのである。",
              "citation": {
                "source": "越後の冬",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしら二人の命はともかくとして、大恩あるこの船の衆を、海の藻屑にしていいものだろうか。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは破船して、南海の藻屑と消える命を救われたことさえかたじけないのに、なんのゆかりもない三人の日本人を国へ送るため、雪の深いところで越年するつもりでいる。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "北部カリガラ方面は米軍の二十四、三十二師の完全な包囲環にしめつけられて戦意を喪失し、十一月のはじめに送りこんだ新鋭一個師団の大半は、レイテ到着前に海の藻屑になり、辛うじて上陸した部隊はいたるところで袋叩きになって殲滅されてしまった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "総噸数にして二十余万噸、これがために恨みを呑んで南海の藻屑と消え果てし無辜の人命は、女子供を入れておそらく二万余人にも上っていたであろうか。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウニデスに捲かれようが捲かれまいが、早晩やがては海の藻屑と消え果てて、南海に集う鱶の餌食となり終ることは、わかり切っている事実であった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
