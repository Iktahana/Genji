        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『僕は壮漢の後ろ影をじっと見送って、そして阿蘇の噴煙を見あげた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに見すぼらしき後ろ影、蓬なす頭、色あせし衣、われはしばしこれを見送りてたたずみぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はわれ知らずその後について、じっと少年の後ろ影を見ながらゆく、その距離は数十歩である、実は三十年の歳月であった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はあきれ返って、ぼんやり立って、少年らの駆けて行く後ろ影を見送った。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けむる霧雨の田んぼ道をゆられて行く幌車の後ろ影を追うような気がして、なつかしいわが家の門の柳が胸にゆらぐ。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安寿は泉の畔に立って、並木の松に隠れてはまた現われる後ろ影を小さくなるまで見送った。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも私はじっと立ち止まって、彼が人込の中へかくれて見えなくなるまで、その後ろ影を見送った。",
              "citation": {
                "source": "誰？",
                "author": "モリス・ルヴェル　Level, Maurice",
                "note": "青空文庫"
              }
            },
            {
              "text": "『腕を組んで車に揺られて行く老人の後ろ影を見送つて、僕は無量の感慨に打たれた』　語り終つた幸徳の両眼は涙に光つて居た。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜後ろ影を見送りながら、三四郎は、「広田先生や野々宮さんは嘸後で僕等を探したでせう」と始めて気が付いた様に云つた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "武にそう書えてやったもんな、母さんがおるで心配しなはんな、ての、ははははは、どれ」　口には笑えど、目はいささか懌ばざる色を帯びて、出で行く姑の後ろ影、　「御免遊ばせ」　と起き直りつつ見送りて、浪子はかすかに吐息を漏らしぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武男が憤然席をけ立てて去りしかの日、母はこの子の後ろ影をにらみつつ叫びぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "武にそう書えてやったもんな、母さんがおるで心配しなはんな、ての、ははははは、どれ」　口には笑えど、目はいささか懌ばざる色を帯びて、出で行く姑の後ろ影、「御免遊ばせ」　と起き直りつつ見送りて、浪子はかすかに吐息を漏らしぬ。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀様は父の立去る後ろ影を、凄い面をして睨めていましたが、「ええ、ようございますとも、出て参りますとも、幸内をつれてどこへでも、わたしは行ってしまいます、お父様のお世話にはなりませぬ、死んでも藤原の家の者のお世話にはなりませぬ」　お銀様は歯噛みをしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神尾主膳だけは残って、彼等の出て行く後ろ影を見送っていましたが、「酒だ、前祝いの雪見酒」　神尾主膳はそれから酒を飲みはじめたが、雪見の酒よりか、何か心祝いの酒のように見えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神尾主膳はじめ一座の者は、険しい眼をしてその後ろ影を見送るばかりで、さすがに身分柄、手荒いことも出来ません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒烟を吐いて本牧の沖に消えて行く巨船の後ろ影を見送っているうちに、兵馬は、壮快な感じから、一種の悲痛な情が湧いて来るのを、禁ずることができません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "海のおばさんの丸くなって逃げて行く後ろ影を、模糊の間にながめながら、茂太郎は、ぬれた身体を自分から顧みると、どうしても、その眼が、さいぜん海女が焚き残したところの、石塔の前の焚火のところに向わないわけにはゆきません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんりきは、御大相な奴等だ、いったい何をかつぎ込むのかと、一行の後ろ影を見送っていましたが、はっと気のついたことは、そうだ、そうだ、うっかり釣り込まれて、本職を忘れていたわい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に、その後ろ影を町並の角に見失ってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二人は岩倉三位の案内を受けて、その居間に通されるのでありますが、品川弥二郎は、大久保と岩倉の後ろ影を見ながら大いに考えさせられているようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "数馬は後ろ影を伏し拝み、不思議に痛みの消えた足を、踏みしめ踏みしめ歩み出した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ云う連中が行くのかい」と高柳君が顋で馬車の後ろ影を指す。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、弘は、心寂しく、その後ろ影に見入つてゐた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の羽色は濃い茶褐色で落葉の色に似通っているところから、草叢の間を歩いているときなどは余程近くに在っても中々見定めにくいのであるが、その牡鳥は多くは二尺位もある長々しい尾を持っているので、飛んで行く後ろ影を眺めわたすと、鮮かに他の鳥と区別することが出来る。",
              "citation": {
                "source": "茸をたずねる",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二　高橋と島田と清川とが談笑しつつ行く後ろ影を見送って、やはり呆然として立っているのが机竜之助でした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "甲源一刀流の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、足の早い野郎で、忽ちに後ろ影さえ見えなくなってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも不思議だ、今のあの武家は、たしかにあれは神尾主膳に違いない」　兵馬はこう言って、闇に消えて行く三人の後ろ影を見つめて追いかけました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "神明から浜松町へかけての通り、お浜の駈けて行く後ろ影。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豊は、ホッという息をつき、大急ぎで引っかけた着物の襟を直してその人の後ろ影を見送るのでありましたが、やっぱり、これはこの山に住む修験者か山伏のなかの一人――自分が今たずねて行こうとする修験者のお弟子かも知れぬ、或いはその修験者かも知れぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "竜神の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわと来り、燃えゆく旗は死に堕つる、夏の光のうしろかげ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
