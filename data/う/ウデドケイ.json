          ],
          "literary": [
            {
              "text": "「じゃあ、僕は失敬するよ」佐竹は小声でそう呟き、金側の腕時計を余程ながいこと見つめて何か思案しているふうであったが、「日比谷へ新響を聞きに行くんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラが地図と腕時計とをくらべながら云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツは右腕をあげて自分の腕時計を見て何気なく低くつぶやきました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」それから腕時計の竜頭を引っぱって針を直そうとしました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫はすこしわらってそれを見送っていましたが、ふと思い出したように右手をあげて自分の腕時計を見ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫はまたこっそりと自分の腕時計を見ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに腕時計は一時五分前なのにその大きな時計は一時二十分前でした。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで自分の腕時計を調べて、それからまるで食い込むように向うの怪しい時計を見つめました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕時計も六時、柱時計の音も六時なのにその針は五時四十五分です。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い農夫は、も一度自分の腕時計に柱時計の針を合せて、安心したように蓋をしめ、ぴょんと土間にはね降りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面台に犯人の遺した腕時計が光っていて、それが折から金につまった小娘を誘惑する。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕は腕時計に幻れる、午後十時半の指針をみて立上る。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一｜時十五｜分前だ‥‥」と、私は覺束ない星明りに腕時計をすかして見ながら答へた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラが地図と腕時計とをくらべながら云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂やあるいは電車の中などで、隣席の人のもっているステッキの種類特にその頭部の装飾を見ると、それに現われたその持ち主の趣味がたいていネクタイとか腕時計とか他の持ち物に反映しているように思われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行こう」カムパネルラが地図と腕時計とをくらべながら言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」それから腕時計の竜頭を引っぱって針を直さうとしました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツの農夫はすこしわらってそれを見送ってゐましたが、ふと思ひ出したやうに右手をあげて自分の腕時計を見ました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急いで自分の腕時計を調べて、それからまるで食ひ込むやうに向ふの怪しい時計を見つめました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い農夫は、も一度自分の腕時計に柱時計の針を合せて、安心したやうに蓋をしめ、ぴょんと土間にはね降りました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラが地圖と腕時計とをくらべながら云ひました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人　　（腕時計をみる。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉はふと腕時計を見た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉はハナヤの前で再び腕時計をみた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉は腕時計を見た。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、四時半までお話できますわ」　娘は腕時計を見た。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
