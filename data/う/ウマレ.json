        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かくて我等の意味もない会話が生まれる。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた英雄の戦没した後に、こういううわさの生まれたのはいつの世でも同じだと思われる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこういう時はちょっと風呂にでもはいって来ると全く生まれ変わったように常態に復する。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生命の物質的説明という事からほんとうの宗教もほんとうの芸術も生まれて来なければならないような気がする。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　今ではどうだか知らないが、私の国では村の豪家などで男子が生まれると、その次の正月は村じゅうの若い者が寄って、四畳敷き六畳敷きの大きな凧をこしらえてその家にかつぎ込む。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪家に生まれた子供が女であったために、ひどく失望した若い者らは、大きな羽子板へ凧のように糸目をつけてかつぎ込んだなどという話さえある。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実と虚と相接するところに虚実を超越した真如の境地があって、そこに風流が生まれ、粋が芽ばえたのではないかという気がするのである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、結局それはすむ世界の相違であり、生まれついた人種の差別である。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから生まれる効果は一プラス一が二になる代わりに三になり四になり十になるようである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやの間ではあるが、消えてはまた生まれ、あちらと思えばこちら、連続と隠顕と、ひととき眼を忙失させるけれども、なお眼を放たないなら、眺め入るものに有限の意識を泡にして、何か永遠に通じさすところがある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしは千｜人の黄金色の子どもが生まれたのです。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸なのは独創性をもって生まれた研究者である。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた一方で西鶴型の優れた科学者も時に出現し、そうしてそういう学者の中に往々劃期的な大発見、破天荒の大理論を仕遂げる人が生まれるようである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう生まれ合わせだと皆はいうけれど、そうばかりは思われない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから足ることを知る節制謙譲が生まれるであろう、と教える東洋風の教えがこの集のところどころに繰返して強調されている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第百三十七段の前半を見れば、心の自由から風流俳諧の生まれる所以を悟ることが出来よう。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような変痴奇論を敷衍して行くと実に途方もない妙な議論が色々生まれて来るらしい。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれてから七、八十歳で死ぬまで一度も風邪を引かないような人があったら、はたが迷惑かもしれない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての時代的な叙情詩のリズムは此所から生まれて来た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村はいつもになくまじめな、人をおしつけるような声で、「君はベツレヘムで生まれた人類が救い主エス、クリストを信じないか。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は名を六蔵と呼びまして、田口の主人には甥に当たり、生まれついての白痴であったのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "名を百合と呼び、大入島の生まれなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人を生んだ自然とその中における生活とがあってしかる後に生まれ出た哲学宗教思想や文学芸術に関する詳細な深奥な考察については、私などよりは別にその人に乏しくないであろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、その環境によって生まれた自然の多様性がさらにまた二次的影響として上記の一次的効果に参加することも忘れてはならないのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな国土もあることを考えると、われわれは蚊もいるが馬も牛もおり、しかも虎や獅子のいない日本に生まれたことの幸福を充分に自覚してもいいのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道のひぐまも虎と同様で、東北日本の陸地の生まれたとき津軽海峡はおそらく陸でつながっていたのではないかと思われるが、それがその後の地変のために切断してそれが潮流のために広く深く掘りえぐられた、それから後にどこかからひぐまが蝦夷地に入り込んで来たのではないかと想像される。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の精神生活　単調で荒涼な砂漠の国には一神教が生まれると言った人があった。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のような多彩にして変幻きわまりなき自然をもつ国で八百万の神々が生まれ崇拝され続けて来たのは当然のことであろう。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく日本の自然は西洋流の分析的科学の生まれるためにはあまりに多彩であまりに無常であったかもしれないのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人の詩にも漢詩にも、そうした傾向のものがいくらかはあるかもしれないが、浅学な私の知る範囲内では、外国の詩には自我と外界との対立がいつもあまりに明白に立っており、そこから理屈が生まれたり教訓が組み立てられたりする。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
