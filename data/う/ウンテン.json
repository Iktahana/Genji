        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "荷物を、運転手と僕とで運び入れて、運転手と助手とが帰つて行くと、僕一人になつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場が運転するためには、先づ発明家が製作品の設計を渡さなければならぬ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手は子供を叱るので大忙しであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＳ子の後から昇降口の方へ歩み寄つた、――ピヨツとＳ子は運転台の方へ走つて行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ子は運転台の近くに、彼は車掌台の近くに、離れて腰掛けてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手に抱へられて、店屋の軒にやられた時、彼は「Ｓ子が来てやあしないか……？",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下の森田屋の前で、運転手と助手とが羽根をついている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学者や化学者は物質を磨り砕いて原子の内部に運転する電子の系統を探っている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手と火夫とが、船頭に何か冗談を云って、朗かに笑った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手がハンドルを握った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手も火夫も、鋭い表情になって、機械に吸い込まれてしまった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等あ」　ブリッジを歩きまわっていた、一運（一等運転手）は、コーターマスターに云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長が、自ら舵器を振り、自ら運転した。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマシン油たるや、充分に運転しているジャックハムマーの、蝶バルブや、外部の鉄錆を溶け込ませているのであったから、それは全く、雪と墨と程のよい対照を為した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度人の小作りなのが揃って、唯灰色に荒れ狂うスクリーンの中で、鑿岩機を運転しているのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、鑿岩機さえ運転していないで、吹雪さえなければ、対岸までも聞える程の大声であった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山は運転を止めた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライナーの爆音が熄むと、ハムマーの連中も運転を止めた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で待っていたお客に対して運転手が一々丁寧に、どうも気の毒だが御覧の通り一杯だからと云って、本当に気の毒そうに詫言を云っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分それらの御客と運転手とはお互いに「人」として知合っているせいであろう。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では運転手は器械の一部であり、乗客は荷重であるに過ぎない、従って詫言などはおよそ無用な勢力の浪費である。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると池の真中に土手のやうなものが突出してゐて、その端の小屋のやうなものの中で何かしら機械が運転してゐるらしい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手でも足でも思い切り自由に伸ばしたり縮めたりしてはね回っているけれども、その運動の均衡が実に安定であって、非常によくバランスのとれた何かの複雑なエンジンの運転を見ているような不思議な快感がある。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると池の真中に土手のようなものが突出していて、その端の小屋のようなものの中で何かしら機械が運転しているらしい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄助は、まるで電車を運転するときのように落ちついて、立って一あし水にはいると、すぐその持ったものを、さいかちの木の下のところへ投げこんだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも私自身も郵便を投函する必要のあるとき自動車の運転手に「郵便函があったら留めてくれ」といおうか「ポストがあったらストップしてくれ」といおうか、どっちがよくわかるだろうかと咄嗟に迷うことがある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして月給取も店員も運転手も職工も小僧も女事務員も町娘も女給も仲居もガソリンガールも一緒になって踊っているのは何と美しく善いことだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくなかなか骨の折れた手のかかったメカニズムであるが所々に多少のがたつきがあったり大きな穴が見えたりするにしても、おしまいまで無事に連続して運転するのはなかなか巧妙なものである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は読者の心理学的機関に衝動を与え、その運転を導くような資料を提供するのであって、その作の価値はその資料の選択や、それを提供する順序や仕方によって規定される。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車をうんてんして、ある山｜奥を、夜中に走っていました。",
              "citation": {
                "source": "ばかな汽車",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
