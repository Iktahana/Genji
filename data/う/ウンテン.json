    "definitions": [
      {
        "index": 1,
        "gloss": "operation (of a machine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
