        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "海上の日の出がどんなに美しかろうが、海鳥が飛ぼうが、鯨がはねようがそんな事はどうでもよい、一刻も早く目的地に上陸して動かぬ地盤が踏みたいと願う。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十五回　白色巡洋艦大陸の影――矢の如く空中を飛走した――ポツンと白い物――海鳥の群――「ガーフ」の軍艦旗――や、や、あの旗は！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "此種の海鳥は、元來左迄に性質の猛惡なもので無いから、此方さへ落付いて居れば、或は無難に免れる事が出來たかも知れぬが、不意の事とて、心から顛倒して居つたので、其樣な事を考へ出す暇もない、急ぎ追ひ拂ふ積りで、一發小銃を發射したのが※失であつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳥ある夜ふけの遠い空に洋燈のあかり白白ともれてくるやうにしるかなしくなりて家家の乾場をめぐりあるいは海岸にうろつき行きくらい夜浪のよびあげる響をきいてる。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしととふる雨にぬれてさびしい心臟は口をひらいたああ　かの海鳥はどこへ行つたか。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳥ある夜ふけの遠い空に洋燈のあかり白白ともれてくるやうにしる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしととふる雨にぬれてさびしい心臟は口をひらいたああかの海鳥はどこへ行つたか。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まどろすの歌愚かな海鳥のやうな姿をして瓦や敷石のごろごろとする　港の市街區を通つて行かう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港には浪の音も鈍にひびらぎ、灰だめる氷雨雲空にみだれてすそあかる黄いろの遠に、海鳥煙濃き檣の闇に一列朱の色の大き旗鳴きもめぐりぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板の上から見ると、夥しい海鳥の群が此の低い珊瑚礁島を蔽うてゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは人間の子供位なのから、小さいのは雀位のものに至るまで、白いもの、灰色のもの、薄茶色のもの、淡青のもの、何萬とも數へ切れぬ數十種の海鳥共が群れてゐるのだが、殘念ながら、私には（同行の船員にも）一つも名前が判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板の上から見ると、夥しい海鳥の群がこの低い珊瑚礁島を蔽うている。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのは人間の子供位なのから、小さいのは雀位のものに至るまで、白いもの、灰色のもの、薄茶色のもの、淡青のもの、何万とも数え切れぬ数十種の海鳥どもが群れているのだが、残念ながら、私には（同行の船員にも）一つも名前が判らぬ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いもなく、水夫らの聞いたのは、舵鎖のきしる音か、あるいは通りすがりの海鳥の鳴き声であったろう。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳥が多かつたが、中には伊豆の天城から飛んで來るらしい山の鳥も混つてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンデルスゾーンにここの風物を――その寂寥、海の動揺、波のざわめき、海鳥の鳴声、風の号泣、大洋の怒涛などを、描いたきわめて美しい音楽、序曲「ヘブリディーズ」（一八三〇）がある。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "『エンサイクロペジア・ブリタンニカ』十一版二十四巻にかかる大海蛇譚の原因は海豚や海鳥や鮫や海狗や海藻が長く続いて順次起伏して浮き游ぐを見誤ったか、また大きな細長い魚や大烏賊を誤り観たか、過去世に盛えた大爬虫プレシオサウルスの残党が今も遠洋に潜み居るだろうと論じ居る。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "英名ファウルは独語フォーゲル、デンマーク語フューグルと等しくもと鳥の義だったが、今はシー・ファウル、ウォーターファウル（海鳥、水鳥）等の複名のほか、単にファウルといえば雌雄鶏を兼称する事となりいる（『大英百科全書』十巻七六〇頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからともなく海鳥の群れが、白く長い翼に羽音を立てて風を切りながら、船の上に現われて来る。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背羽根の灰色な腹の白い海鳥が、時々思い出したようにさびしい声でなきながら、船の周囲を群れ飛ぶほかには、生き物の影とては見る事もできないようになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、その三重の帆を海鳥の翼のごとく広げ、しかもそれでも足りないで、両舷の火輪を回して、やや波立っている大洋を、巨鯨のごとく走っているのだった。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、トビは海鳥じゃない」　慶一がトビを鷹とまちがえたのは、目のまえの景色のせいもあった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "信天翁　　　　　シャルル・ボドレエル波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生檎りぬ、楫の枕のよき友よ心｜閑けき飛鳥かな、津潮騒すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "信天翁　　　　　シャルル・ボドレエル波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生檎りぬ、楫の枕のよき友よ心閑けき飛鳥かな、奥津潮騒すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャルル・ボドレエル信天翁波路遙けき徒然の慰草と船人は、八重の潮路の海鳥の沖の太夫を生擒りぬ、楫の枕のよき友よ心｜閑けき飛鳥かな、奧津潮騷すべりゆく舷近くむれ集ふ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまいには、傷ついた海鳥が泣くようなかすかな悲鳴になってしまった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、島に夕暮が来て、日が荒寥たる硫黄ヶ岳のかなたに落ち、唐竹の林に風が騒ぎ、名も知れない海鳥が鳴くときなど、灯もない小屋の中に蹲っている俊寛に、身を裂くような寂しさが襲ってくる。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "団扇には、海鳥が海岸に打ち寄せる大波と青空のはるか彼方から勇んで獲物を狙い定めている様が描かれている。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "――船具を忘れ、海鳥を忘れ、純白のハンケチの雲を忘れ、私は黒い空気の中で、不潔な老婆らと睫毛の周囲を舞踏した。",
              "citation": {
                "source": "断片",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧は間もなく空中に消え去って、沼の彼方の砂浜には、海鳥の群が舞い飛んでいた。",
              "citation": {
                "source": "初秋海浜記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
