        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "で、仕事に疲れて来ると忽ち室内着を脱ぎ捨てスポーツシャツ一枚の姿で縁側でトレーニングをやった。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は旅行なれた風で、暫くするとその小鞄を膝の上で開け、地味な室内着を出して、坐ったまま上から羽織った。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後からノロノロやってきた小型の「｜空の虱」が二つ三つ、果敢な邸内着陸を敢行した。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以降は、室内着のまま虚脱状態に陥って、ひたすら西の窓から外ばかり睨み、雷を恐れて震え、日記にでたらめな内容を書くだけだった。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダッタン人の男の外着のような太い縞の室内着をきた素子が、そこに向ってかけている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも何とか云う亜米利加の活動劇の男装からヒントを得て、黒いビロードで拵えさせた三ツ組の背広服などは、恐らく一番金のかかった、贅沢な室内着だったでしょう。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑内着をつけ坑内帽を被り坑内靴を穿いて、ランプを提げさせられた時には余り仕度が仰々しいので少し後悔したようだったが、今更何とも仕様がない。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥雫が坑内着から滴っている。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "波うちぎはを東京の若紳士めく靴のさき。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その海豹島の波うちぎわ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見た幾千の膃肭獣の成牡（ブル）はその波うちぎわに殺到する。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、寧われはおほわだの波うちぎはに夢みむ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やつと波うちぎはに着くと娘はＢの腕からころげ落ちて、Ｃの方へ泳いで行つた。",
              "citation": {
                "source": "熱い砂の上",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、ボートは波うちぎわにつきました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてこれを、日本軍や、お父さまにしらせたらいいだろう」　高一は、なんとかしていいちえをひねりだしたいものと考えながら、ふと、波うちぎわを見ると、一つの大きなたるがながれついています。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "高一が、波うちぎわで、ひとつの大きなたるを見つけたことは、まえにいいましたが、近づいて、たるのふたをすこしあけてのぞいてみると、おどろくではありませんか、なかには、見おぼえのある電気鳩がはいっていたのです。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "下岡蓮杖の功績が新しく人々の科学常識の間にとりいれられたのは結構であったし、カメラを愛好する若い人々にとって、ターキーの舞台姿のポーズをとられたのも、鎌倉の波うちぎわで舞う女の躍動をうつせたのも、楽しいことの一つであったにちがいない。",
              "citation": {
                "source": "カメラの焦点",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉太郎は、草の中からそのやどかりをさがしだして、波うちぎわへほうってやった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "波うちぎわに、光るものがあった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭時に祓ひ浄める者をかむだちと言ふ処から見て、まうちぎみと共に神事に関係するものであらう。",
              "citation": {
                "source": "はちまきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄の紫の帯を著けたまちぎは、まうちぎみと同じで、やはり神事に与る。",
              "citation": {
                "source": "はちまきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の女の証言によると、この女は浜の近くに住んでいて、死体発見の話を聞く一時間ほど前に、自分の家の戸口に立って漁師の帰りを待っていたが、そのとき一人だけ乗った舟が、あとで死体の見つかったあたりの波うちぎわから出かけていくのを見た、ということだった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かういつて、波うちぎはの細みちづたひに、また歩いて行くのでした。",
              "citation": {
                "source": "さがしもの",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "手には、太いぼうちぎれを、にぎつてゐます。",
              "citation": {
                "source": "源八栗",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先の、きのうまで無住｜寺の墓場のあった個所は、ゆうべの暴風雨で崖が崩れて、はるか眼下の浪うちぎわに、大きな土砂のかたまりが、濃い液体のように食み出ていた。",
              "citation": {
                "source": "あの顔",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師が大きな魚籃をかついで、波うちぎわを歩いている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バカな野郎だ」月の光で　サト子が、石段を駆けおりて、磯の波うちぎわへ行くと、中年の刑事が、苦々しい口調でつぶやいた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、その波の波うちぎわにいる自分を感じながら、二つに畳める円テーブルの一つのたたみめを壁にくっつけて、ベッドに背中がさわりそうな僅のすき間で毎日少しずつ小説を書いた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こらしょ」　と、二人ずつでかついで、波うちぎわにつないである漁船に、つみこんだ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アジサシのひなは、まだ、羽が生えそろわないのに、よちよち歩いて、ぴいぴい鳴きながら、波うちぎわに、たくさんむらがって、親鳥が、海から魚をくわえて帰ってくるのを、待ちわびている。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
