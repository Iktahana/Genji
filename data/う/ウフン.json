        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "うふんと鼻で笑って、彼はその話を聞き流した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その時｜木戸に立った多勢の方を見向いて、「うふん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うふん、驚くな、いいか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の肉体は、だんだん焼かれる魚のようにこうふんして来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ感傷癖こそ脱しなかつたが、彼の中には宗教の匂のするものが、もうふんだんに磅※してゐた。",
              "citation": {
                "source": "あの頃の自分の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその下に闌更というふんどしかつぎがおります。",
              "citation": {
                "source": "俳句上の京と江戸",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜査にあたってばらばらになって、自分の好き勝手をすると、成績があがらないでしょう」「そうだ、そうだ」　と、二宮少年がこうふんして叫んだ。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うふん」　ピッシリ、撲り倒した。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで御供のようだね」「うふん。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭ができれば、藤尾なんぞは要らないだろう」　宗近君は軽くうふんと云ったのみである。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念がる助教授　ポオ助教授は、司令艇へ帰ってきても、こうふんをつづけていた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そういうたしかな証拠があるかぎりは………」　とポオ助教授はいよいよこうふんの色をしめし、「ギンネコ号はうそをついていると断定しないわけにはいかない。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとに長身でやせぎすの事務長テイイがらくだのような顔をこうふんにふりたててしたがった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの唇は、こうふんのために、ぴくぴくとふるえている。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それにつづいてかれらはこうふんのいろをあらわし、いつもとはちがって、年齢が五つも若返ったように元気づいた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚艇でも、みんな目を丸くし、そしてこうふんになげこまれ、それからみんないそがしく活動をはじめた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宇宙の秘密　ガンマ和尚とテッド隊長の会見は、劇的な光景をていして、隊員たちをいやがうえにこうふんさせた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうふんしては、いけません」「はなしてください。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よオし、貴様は、日本人でないことが、よくわかったぞ」「えっ、中国人だということがわかりましたか」「うふん。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図のうえで、日本のまわりを指さきでぐるぐるなでながら、「うふん。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「博士、人造人間エフ氏というのを、なぜそんなに僕に見せたがるのですか」「うふん、それは――それはつまり世界中で一番すぐれた人造人間だからです。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ケレンコはにやりとして、「うふん、だが、あれが日本艦隊だったら、もっと、こっぴどくやっつけるんだが、なにをいっても友邦アメリカだから、遠慮してあのくらいにとどめておくのだよ。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一台つくったら、君にもあげるよ」「うふん」と清君は遠慮ぶかい笑みをうかべたが、「ねえ丁坊、本社で聞いたんだけど、そのうち北の方で大戦争が起るんだってさ」「へえ、北の方で大戦争が……」　と、丁坊は眼をまるくした。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお前をさらってきたんだ」「へえ、一体、空魔艦は、どこの国の飛行機なのかね」「うふん、また訊いたね。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやそれよりもかかあのあの口ぶりを真似ていうと、現代の医学は実に跳躍的進歩をとげた――というべきであろうかナ、うふん。",
              "citation": {
                "source": "ヒルミ夫人の冷蔵鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふん、さうでもないわよ……それやさうと、今朝の日の出新報御覧になつた？",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うふん……」　ツマらないという風に苦笑して、あとは黙ってしまう。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはえらくこうふんしてるよ」　ホールが一｜心になだめた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒーをごちそうするから、ゆっくり話したらどうだい」　やがて、熱いコーヒーがはこぼれ、わかい船のりはひと息つくと、まだこうふんのさめないようすで話しだした。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふん囲気のなかで、康子は、安閑としていられるはずはない。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふん、こら、お妙さに見せたかったてえ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
