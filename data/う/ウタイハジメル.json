          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ギターを抱えて自分でも歌い始めると、気持ちはいっそうフォークソングに傾きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにどこかで一番鶏が歌い始める。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴やかな気持ちになった私は、我知らず学校でならった唱歌を歌い始める。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、突然、私たちの前面の樹立の真中から、力のない、高い、震え声で、節も文句もよく知っているあの唄を歌い始めるのが聞えて来た。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、万事うまくいったと見ると、彼女は意気揚々として、こんなに無事におさまっているのは誰のお蔭だと言わんばかりに、鼻声で歌い始める。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母親は、真剣になって、子守歌をうたいはじめるのでした。",
              "citation": {
                "source": "雲と子守歌",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母は、こんどは、しずかに、ゆっくりと力づよく、うたいはじめるのでした。",
              "citation": {
                "source": "雲と子守歌",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたび法師がびわをひきだし、その歌をうたいはじめると、なんともいえないあわれさ、悲しさがひびきわたり、鬼でさえも泣かずにはいられないほどでありました。",
              "citation": {
                "source": "壇ノ浦の鬼火",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（須川と嘉六も笑う）嘉六　（いきなり、胴間声をはり上げて、木曾節をうたいはじめる。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
