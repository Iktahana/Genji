        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "丸窓の小障子は外れていて、外に竹藪のある中に、ハアト形にどんよりと、あだ蒼い影が、ねばねばと、鱗形に溶けそうに脈を打って光っている。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、颯と吹いた夜嵐に、提灯は暗くなり、小波は白い毛を立てて、空なる鱗形の雲とともに亂れた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燒けた水を、目前、波の鱗形に積んだ、煉瓦を根にして、卒堵婆が一基。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒白鱗の帷子、同じ鱗形の裁着、鰭のごときひらひら足袋。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姓は源、氏は細木、定紋は柊であるが、店の暖簾には一文字の下に三角の鱗形を染めさせるので、一鱗堂と号し、書を作るときは竜池と署し、俳句を吟じては仙塢と云い、狂歌を詠じては桃江園また鶴の門雛亀、後に源僊と云った。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑いろの革で四角に出来てゐて、縁と蝶番の処とは勿論、四隅に附いてゐる鱗形の装飾も、表の真中に附いてゐる名の頭字の A の字も、皆銀である。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し涼しくなると、彼女は鱗形の銀紙を貼り付けた紅い振袖を着て、芝居で見る清姫のような姿になって、舞台で蛇を使うことがある。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱗形に垢のついた身体全体は、まるで松の幹が転がっているようだった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個小隊ないし一分隊の兵力を距離間隔六百メートルを間して鱗形に配置し、各独立閉鎖堡とする。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "無花果の枝、漆の葉、裏長屋の屋根などが雑然入組んで見える町裏を通して朝らしい光を帯びた鱗形の雲が望まれた。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が十九の時母は紅白の鱗形の襦袢の袖を着せた。",
              "citation": {
                "source": "小鈴",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋次第に更けて来る空には、細い鱗形の雲が飛び飛びに散つてる。",
              "citation": {
                "source": "海潮の響",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙の題簽に、ひよしさんわうまつり　　　　　天満あいごの若からさきのひとつ松のゆらい　　八太夫とあつて、宝永五年正月の、大伝馬町鱗形屋の出版である。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "景蔵に言わせると、当時、鱗形屋の定飛脚から出たものとして諸方に伝わった聞書なるものは必ずしも当日の真相を伝えてはない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "五「青山君――その後の当地の様子は鱗形屋の聞書その他の飛脚便によっても御承知のことと思う。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い処にかゝつてゐる時計は鱗形の彫をした黄楊の箱から、消え行く時間に又一時間を加へ、夜半の十二時になるまで時は次第々々に進んで行く。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いところは物の影がくっきりと地を這って、中の郷のあたり、甍が鱗形に重なった向うに、書割のような妙見の森が淡い夜霧にぼけて見える。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の中で降らなかつたのに、石庭を圍うてゐる土塀の六枚下ろしに葺いた瓦の上に、程よろしく新しい雪が鱗形に殘つてゐた。",
              "citation": {
                "source": "京洛日記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "単衣の裾を固く合せると、鱗形の帯の端をギュッと引絞ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "綾吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗末なこの貸事務所の鱗形のスレート屋根の上でも、盛んに雪は解けているのだろう。",
              "citation": {
                "source": "今朝の雪",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはよく整い、よく接合し、鱗形に並び、直線をなし、均斉を保ち、しかも凄惨な趣があった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい双六　文政八年の書き物に、ある人のコレクションに古板双六が二十八種のっていて、そのうちの二つ、鶴屋版の「甘露壺双六」と、鱗形屋版の「かわるが早いおででこ双六」が私の手もとにある。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
