        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "如何な重い痳疹でも内攻も何もせずに、スウウと熱が除れるちゅうて一枚五文で飛ぶような売れ行きじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出版社は売れ行きは思わしくないと言っていて。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛邦、近年神道を興すとて瑣末な柏手の打ち様や歩き振りを神職養成と称して教えこみ、実は所得税を多く取らんために神職を増加し、その俸給を増さしめ、売れ行きの悪い公債証書を売りつけんために無理早速に神社基本金を積ましむる算段と思わる。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけすけな書き手は、自分の処女作を買い占めて回ったり、目につく場所に移し変えたり、毎日欠かさず売れ行きを定点観測したりといった体験を語っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればきっと、出版社が切って捨てるほどの売れ行きにはならないはずだ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから標題が小説の売れ行きに関係するところも尠少でない。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで米国の出版者は思ひきつて英国版と同じ題名にかへて再版を出したら、急に売れ行きが増して来たといふことである。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "短篇小説集が一般に売れ行きが非常に少いことは顕著な事実で、長篇小説なら三四万の読者をもつ作者の短篇小説集が五千部以下しか売れないことは珍らしくない。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのところの景気だよ」「下がったり上がったりでござんす」「味にからまったことをいうおやじだな、お蘭しごきの売れ行きはどんなかい」「売れたり売れなんだりでござんす」「控えろ、何をちゃかしたことを申すかッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "性欲秘密薬と書画　最近の東京では、性病又は性病予防等に関する秘密薬の売れ行きが盛である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勢が東京市中に数倍の飲食店を作り、安流行、安贅沢品を流行らせると同時に、かような大商店にまでも影響したので、一時は実に物凄い程の売れ行きであった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シツダル、生れ故郷のことなんか思ひ出してぼんやりしてゐると、酒の売れ行きに関はるぞ！",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に肺病院を頂いた漁場の魚の売れ行きは拡大するより、縮小するのが、より確実な運命にちがいない。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌の売れ行きについては多少悲観もしていたが、先日の話によれば思ったほど悪くもなさそうなので大いに安心した。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "発売当初はあくまで、ビット・インに持ち込まれる数の多さから、「かなり売れているのでは」と予測の域を出なかったＴＫ―80の売れ行きは、しだいにはっきりと数字に現われはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフトウエアが書きやすくなれば、マイクロコンピューターの売れ行きが伸びるという読みには、インテルも同意した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田はＩＢＭの打ち出したパーソナルコンピューターらしいパーソナルコンピューターを作るという方針が、市場からどう評価され、どの程度の売れ行きを示すか、すぐにでもその答えを知りたかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月から出荷の始まったＩＢＭ ＰＣが、目覚ましい勢いで売れ行きを伸ばしているとのレポートを睨みながら、浜田は焦れながら西の回答を待ち続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがゲーム用ＬＳＩが巻き起こしたブームに引きずられるように、しだいに雑誌の構成はテレビゲーム中心に移り、そのことがいっそう『Ｉ／Ｏ』の売れ行きを伸ばした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七九（昭和五十四）年九月に出荷を開始したＰＣ―８００１が好調な売れ行きを示しはじめると、今度はアスキーの側に、ＰＣ―８００１で走らせるアプリケーションを売ろうとするアイディアが生まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八一（昭和五十六）年十月に出荷が始まると、ＰＣはすぐに爆発的な売れ行きを示した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぢや売れ行きに関るのは云ふまでもない事なのだから、貴公の方だつてつまらなからう。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ売れ行きにかかわるのは言うまでもないことなのだから、貴公の方だってつまらなかろう。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内にどう云ふ拍子だつたか、話題が当時評判だつた或小説の売れ行きに落ちた。",
              "citation": {
                "source": "岩野泡鳴氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、売れ行きが鈍くていつまでも減らないので、その重さったらなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその私を白旗氏は、その晩売れ行きのわるい本郷三丁目の角のところにまわした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ではもう人の家を訪ねるのにそう気骨は折れなくなったが、その代りやはり売れ行きはよくなかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
