        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "商売柄で若い時には随分浮いた噂もきこえたが、この十年以来は慾一方に凝り固まっているとかいうので、近所の評判はあまり好くなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお伝は二年越しここに奉公している正直者で、今までに浮いた噂などは勿論なかったと亭主は証明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "身持もよくて、これまでに浮いた噂もないという。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小三津は堅い女で、これまで浮いた噂も無し、今でもそんなことは無いらしいというのですが……」と、亭主は首をかしげながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、別に道楽をするという噂も無いようです」「お半は四十を越しても水々しい女だというが、それにも浮いた噂はねえのか」「それがね、親分」と、松吉は小膝をすすめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "情夫でもあるのかと訊けば、お冬さんは町でも評判のおとなしい娘にて、浮いた噂などかつて聞いたこともないという。",
              "citation": {
                "source": "慈悲心鳥",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はことし十八で、とかくにいろいろの浮いた噂を立てられ易いここらの茶屋娘のなかでも、初心でおとなしい女という評判を取っていることは、お絹もかねて聞いていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人気稼業はしていても、まだ十六の六三郎ですから、江戸にいた頃には一度も浮いた噂を聞かなかったのですが、どうもこの頃は様子がおかしいと、一座のうちでも年嵩の者は眼をつけるようになりました。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "舐め筆の娘はどっちも堅い方で、これまで浮いた噂はなかったようです」と、源次は摺り寄ってささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んやこの婦人に、浮いた噂のあろうはずがなく、またそうかといってひねくれて人殺しをするような気配もなかったことを証言する人々があった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……音楽をやっても、お嫁に来てみても、浮いた噂が立つ時でも――いつどんな場合でも、要するにあたしは、ほんの添え物みたいな女なのだわ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした理由からででもございましょうか年頃になられましても、浮いた噂とて一つもなく、しごくおとなしいお方でございました。",
              "citation": {
                "source": "ながうた勧進帳",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、お今には浮いた噂はなかつたのか」「大根畑の植木屋の專次といふのが心安くしてゐたさうですよ」「そつとつれて來る工夫はないか」「其處に居ますよ、お今のお袋と一緒に」　ガラツ八は死骸を跨ぐやうに、突き當りの長屋へ入つて行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗さは二人に劣らなかつたでせうが、これは働き者で親孝行で、お今、お三輪のやうに、浮いた噂などは微塵もなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大骨折で訊出したのは、娘には浮いた噂のないといふ世間の評判の裏書と、下手人の姿は見えなかつたといふことと、下駄屋の主人夫婦が、人から怨まれる筋のないことと、それから、娘を殺した赤い紐の結び目が、恐ろしく頑固な盲目結びであつたことなどでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、お今には浮いた噂はなかったのか」「大根畑の植木屋の専次というのが心安くしていたそうですよ」「そっとつれて来る工夫はないか」「そこに居ますよ、お今のお袋と一緒に」　ガラッ八は死骸を跨ぐように、突き当りの長屋へ入って行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "綺麗さは二人に劣らなかったでしょうが、これは働き者で親孝行で、お今、お三輪のように、浮いた噂などは微塵もなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大骨折で訊出したのは、娘には浮いた噂のないという世間の評判の裏書と、下手人の姿は見えなかったということと、下駄屋の主人夫婦が、人から怨まれる筋のないことと、それから、娘を殺した赤い紐の結び目が、恐ろしく頑固であったことなどでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "十七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "念のため、家中の者に逢つて、聽くだけは聽いて見ましたが、殺された嫁のお吉は、男のやうな氣性の女で、浮いた噂などは一つもなく、手代の時松は、昨夜横川町の親類へ法事があつて行き、一と晩泊つて今朝戻つて來たことがわかつて、全く疑ひから除かされてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき獲物",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の事務員をして二人の子供を女手で育てゝいるが、浮いた噂もない。",
              "citation": {
                "source": "出家物語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
