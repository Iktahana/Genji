    "definitions": [
      {
        "index": 1,
        "gloss": "amorous rumour (rumor)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
