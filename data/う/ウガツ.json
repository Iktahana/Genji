        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昼頃近くになっても霜柱の消えないような玄関の前に立って呼鈴を鳴らしてもなかなかすぐには反応がなくて立往生をしていると、凜冽たる朔風は門内の凍てた鋪石の面を吹いて安物の外套を穿つのである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それよりして奥入瀬川の深林を穿つて通る、激流、飛瀑、碧潭の、到る処に、松明の如く、灯の如く、細くなり小さくなり、また閃きなどして、――子の口の湖畔までともなつたのは、この焚火と、――一｜茎の釣舟草の花のあつたことを忘れない。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆大木の根に掛り、巨巌の膚を穿つ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始時代そのまゝで幾千年人の足跡をとゞめざる大森林を穿つて列車は一直線に走るのである。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹の径を通りぬけると果して、思ひがけない大道が深林を穿つて一直線に作られてある。",
              "citation": {
                "source": "空知川の岸辺",
                "author": "國木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると長年月の後には、「塵積って山となり、点滴石を穿つ」というように、必ず自分の才能特色が何らかの形をとって世に現れずにはいません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は山の狹間の左右に迫る、暗き斷崖を穿つて過ぎるのであつた。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀珠玉巧を極め、喬木高樓は家々に築き、花林曲池は戸々に穿つ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで更に君に就いての穿つた観察を下して見ると、君は昔のあのとき自分の作品を攻撃されて、興奮して反撥して、そこで縋りついて行つたものが、家業の活花であつたればこそ、今日までの半生を花に忠実に仕へて来た。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装まずしくとも足袋は必ず新しきを穿つべし、と茶の湯客の心得に書かれてある。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、土中に於て或障害に遭遇して復根を新土に※入する能はざるに至れば、其の發達は停止するの傾を爲すが、幸にして障害物の罅隙等を穿つて復び新しい土地に其の根を伸張するを得れば、俄然として活氣は増加し、發達は復び遂げらるゝのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に不思議なものを見ました――底なき雪の大空の、尚ほ其の上を、プスリと鑿で穿つて其の穴から落ちこぼれる……大きさは然うです……蝋燭の灯の少し大いほどな眞蒼な光が、ちら／＼と雪を染め、染めて、ちら／＼と染めながら、ツツと輝いて、其の古杉の梢に來て留りました。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の白痴殿の女房になつて、世の中へは目もやらぬ換にやあ、嬢様は如意自在、男はより取つて、飽けば、息をかけて獣にするわ、殊に其の洪水以来、山を穿つたこの流は天道様がお授けの、男を誘ふ怪しの水、生命を取られぬものはないのぢや。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――麻袋には昼飯の握つた奴、余るほど詰めて置く、ちやうど僥幸、山の芋を穿つて横噛りでも一日二日は凌げるだ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜胆青淀の岩壁をかく穿つもの、滲みいづる滴りの淡水とは誰か思はむ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会内にて、つまらぬ批評眼をもつて他の小悪小非を穿つものには、教会内の小善小仁すらも旌し易からず、而して今日の教会の多数は斯くの如くなるを悲しむなり。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸中の苦悶未だ全く解けず、行く行く秋草の深き所に到れば、忽ち聴く虫声｜縷の如く耳朶を穿つを。",
              "citation": {
                "source": "一夕観",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸の城山に洞門を穿つのである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "室を温め、竈に火を焚きつけても、壁の石を徹し、衣の綿を穿つ北｜欧羅巴の寒さは、なかなかに堪えがたかり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほ岩を穿つたトンネルが多く、荷車、荷馬車などはとても通れない。",
              "citation": {
                "source": "日高十勝の記憶",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "婉曲頗る人情の機微を穿つものあり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そは我が歌ひて半に至りし時、老女の絲繰る手やうやく緩く、はては全く歇みて、暗き瞳の光は我面を穿つ如く、こなたに注がれたればなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝ等の家は、概ね皆｜平家に窓を穿つことなく、その代りには戸口を大いにしたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "穿つこと僅に數尺にして石人現れければ、その工事は遽に止められき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒狹川もまた岩を穿つて流れてゐる溪であつた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸は曲折に富み、道路はその崎に沿ふことをせず、多く隧道を穿つて通じてゐるほどだ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "駿河灣一帶の風光",
                "note": "青空文庫"
              }
            },
            {
              "text": "（６）旧約伝道の書第十二章第六―七節、「然る時には銀の紐は解け金の盞は砕け吊瓶は泉の側に壊れ轆轤は井の傍に破れん、而して塵は本の如く土に帰り霊魂はこれを賦けし神にかえるべし」（７）穿顱錐で頭蓋骨を穿つ手術。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "後一年、不断、不沙汰ばかり、といううちにも、――大野木宗匠は、……常袴の紺足袋で、炎天にも日和下駄を穿つ。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し卯平は其の僅少な厚意に對して窪んだ茶色の眼を蹙める樣にして、洗ひもせぬ殼の兩端に小さな穴を穿つて啜るのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うして彼の卯平に對する憎惡の念が彼の心へ錐を穿つて更に釘を以て確然と打ちつけられたのであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
