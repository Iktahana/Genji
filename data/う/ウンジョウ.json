[
  {
    "uuid": "48a5b02d-485e-5856-a7b4-3b8e1540e21a",
    "entry": "運上",
    "reading": {
      "primary": "うんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
