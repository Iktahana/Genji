    "definitions": [
      {
        "index": 1,
        "gloss": "The Bathhouse of the Floating World (humorous book by Shikitei Sanba)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
