    "definitions": [
      {
        "index": 1,
        "gloss": "rising sea waves from late May to early June",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ひと日は、うるむ月の夜に、水漬く磯根の葦の葉を、卯波たゆたにくちづけし深日の浦をおもひいでぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ひと日は、うるむ月の夜に、水漬く磯根の葦の葉を、卯波たゆたにくちづけし深日の浦をおもひいでぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のようなみにくいからだでも灼けるときには小さなひかりを出すでしょう。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫まつくろけの猫が二疋、なやましいよるの家根のうへで、ぴんとたてた尻尾のさきから、糸のやうなみかづきがかすんでゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにもさびしい私の人格が、おほきな声で見知らぬ友をよんで居る、わたしの卑屈な不思議な人格が、鴉のやうなみすぼらしい様子をして、人気のない冬枯れの椅子の片隅にふるえて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狸はもうなみだで身体もふやけさうに泣いたふりをしました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狸はもうなみだで身体もふやけそうに泣いたふりをしました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓔珞は黄や橙や緑の針のようなみじかい光を射、羅は虹のようにひるがえりました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うあい、うあいだ、又三郎、うなみだいな風など世界じゅうになくてもいいなあ、うわあい。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにもさびしい私の人格がおほきな聲で見知らぬ友を呼んでゐるわたしの卑屈で不思議な人格が鴉のやうなみすぼらしい樣子をして人氣のない冬枯れの椅子の片隅にふるへて居る。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後たびたび同じ常山木の下へも行ったが、あの時のようなみごとなかぶと虫はもう見つからなかった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、よごれたやうなみにくい小さな白い花の為めに、その茎はもはや硬く、その葉は赤く土によごれて居るのであった。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの子のひたいにのっておやり、そうするとあの子は、おまえのようなみっともない顔になって、もう、おとうさまにだって見分けがつかなくなるだろうよ――。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "熬りつける樣な油蝉の聲が彼等の心を撼がしては鼻のつまつたやうなみん／＼蝉の聲が其の心を溶かさうとする。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は天下に欠くるものもないようなみち足りた感情が、胸のうちにむずむずと溢れてくるのを覚えた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "目のさめるようなみずみずしい美男僧でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なるほどその言葉の通り、皮膚のいろも、爪のいろまでが光沢を失って、ほんの昔、真紅の胴に白いろずくめのしぶきを切り乍ら、武者振りも勇しくこの大川を乗り切ったときの、あの目のさめるようなみずみずしさは、どこにも見えなかった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなのために、かわいそうなみんなのために殺してやったかと思えば、悲しいことはございませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分が悪いばかりでなく、こんなお化けのようなみにくい顔を諸人の前にさらすのは死んでもいやだと、富子は泣いて狂った。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一日に何度かまだ自分がどこにゐるかをも忘れてゐるやうなみじかい時間があつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうなみづみづしさ、若々しさの保たれる道は、對象への積極的な働きかけのなかにあることを駿介は知つてゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕、暮羊居に立ち寄つた、暮羊君とお客さんとが街へ出かけるあとからついていつたのがいけなかつた、とうたう喧嘩わかれに別れて戻るやうなみじめさになつてしまつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけれども、親愛なるジャガイモ、私の祖母たちはカンプラと東北の呼名で呼んだ馬鈴薯の種を、どこへまいたら、育って花を咲かせて、米の足しになるようなみのりかたをするだろうか。",
              "citation": {
                "source": "昔を今に",
                "author": "――なすよしもなき馬鈴薯と綿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もう御飯かけましたか」というなみのいつも穏やかな、歯の工合でも悪そうに引かかる国訛の残っている声がした。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "読ませやうとする上からはかういふ好奇心を引くやうなみだしをつけることも必要なことかもしれないがよむ方ではみだしの割にはよんでしまつてから「なあんだ」と云う風につまらながつて仕舞つてだん／＼に興味を引かなくなつて仕舞ひはしないかと思はれる。",
              "citation": {
                "source": "女教員の縊死",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏のやうなみかけ倒しな人は少いと思ひます。",
              "citation": {
                "source": "妾の会つた男の人人",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで、あんな、これ以上の貧しさはないやうなみぢめな生活に四年も五年もかぢりついてゐたのだつて、皆んなあの子の為めだつたのですもの。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "滓を飲んで旦浦時代を追憶した、滓なんて飲む人があるからおもしろいと、あの時代は考へてゐたが、今の私はその滓でさへろく／＼飲めないではないか（現に一昨日は十銭しかないので、わざ／＼新町まで出かけて滓を飲んで来たやうなみじめさだ）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＡＳＣＩＩ』にはアメリカの雑誌で仕入れたねたを中心にパーソナルコンピューターの最新動向をまとめていたが、本拠地を移せばより新鮮な情報を直接つかみ、水滴をまとった桃のようなみずみずしい記事が書けるに違いないと思えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
