        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は野球部で活躍している。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が試験に合格した。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は真面目に勉強している。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は新しい技能を習得した。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が頑張って良い成績を取った。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は仲間を大切にしている。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が困っているなら手伝う。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は礼儀正しい性格だ。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴とは学生時代からの付き合いだ。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が昇進の話を聞かせてくれた。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は信頼できる同僚だ。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴がプロジェクトをリードしている。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴の判断は的確だ。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が創意工夫で問題を解決した。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が業界の動向に詳しい。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は駅伝選手として活躍している。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が音楽の才能を示している。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴は社会貢献活動に参加している。",
              "source": "幻辞"
            },
            {
              "text": "うちの奴が地域の発展に関心を持っている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "うちの奴等はそれを知らない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちの奴等、何を食ってやがったんだろう」　浅い皿の上から甘藷の煮ころばしが飯粒をつけて転げ出している。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの奴らには、おれから、いいように言って置く。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの奴らには、おれから、いいやうに言つて置く。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにせ、うちの奴らはみんな手癖が悪いだから？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "どだい、うちの奴とおっかさんとがうまく行くもんじゃない。",
              "citation": {
                "source": "築地河岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方、うちの門の前におつぽり出されてゐたのを誰かうちの奴が氣を利かして門の中に入れて置いてやつたんだ。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳二　　あらゆる女の如く、と云ひたいが、うちの奴は例外だ。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの奴、なんとかならないもんでせうか。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈　　それと小学校の生徒ね、うちの奴もさつきさう云つてましたよ。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈　　いや、うちの奴は活動の趣味を解しないんですよ。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今うちの奴も、なんだか眩暈がするとかつて、着物を着替へかけて、出るのを見合せてるんですがね。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈　　うちの奴は平気ですよ。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはさうと、うちの奴がこんな場所の店へいきなり出て、お客が取れるでせうか？",
              "citation": {
                "source": "天國の記録",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「考えてもきりがないようなもんだし、うちの奴みたいに、てんから考えない女も、つきあえたものじゃなし……」　立ち上って、竹村は、「ところで、きょうは、ひっぱり出しに来たんだ。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――うちの奴も五黄だった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、うちの奴は実にそういうことはしなかったからさ……女のひとなら、だれだって、編物ぐらいするのが普通だろう？",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこらでうちのやつに会わなかったですか。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "シゲ　　わしも、うちのやつのいびきを、いつまでも聞いてたよ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで悪事を働いて、それをかくすために、ああいうかっこうをして、なるべく人を近よせないでおくつもりかもしれないね」「うちのやつは知ってるのかね？",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはどうも、うちのやつにちょっくら、言ってきかせなくてはなるまい。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがろうそくをもって、うちのやつが家じゅうの戸じまりをしてまわったんだから、まちがいないな。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "相かわらず、いつも、呑ンだくれていやがるな」「よけいなお世話だ、やい、安」「なんだ」「てめえ、うちのやつに頼まれて、今朝、何処へ駕をやったんだ。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
