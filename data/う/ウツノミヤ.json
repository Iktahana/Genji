        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "宇都宮へ着いてさへ、船に乗つた心地がした。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たやすく貴嬢が掌いだしたまわぬを見てかの君、早く受けたまわずやと諭すように物言いたもうは貴嬢が親しき親族の君にてもおわすかと二郎かの時は思いしなるべし、ただわれ、宇都宮時雄の君とはこの人のことよと一目にて看破りたれば、貴嬢に向かってかかる物の言いざましたもうを少しも怪しまざりき。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "詳しき説明は宇都宮時雄の君に請いたもうぞ手近なる。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "水天髣髴の間に毛筋ほどの長堤を横たえ、その上に、家五六軒だけしか対岸に見せない利根川の佐原の宿、干瓢を干すその晒した色と、その晒した匂いとが、寂しい眠りを誘う宇都宮の田川の宿――その他川の名は忘れても川の性格ばかりは、意識に織り込まれているものが次々と思い泛べられて来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉が宇都宮に宿営した時に政宗は片倉小十郎を従えて迎接した。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから関白が武威を奥羽に示すのに従属して、宇都宮から会津と附いて来たのであるが、今しも秀吉の鑑識を以て会津の城主、奥州出羽の押えということに定められたのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、こんなことを語つたり思つたりしてゐる中に、晴れたり曇つたりする日の右手の車窓には梅雨の雲の間に筑波の山が下總の青田の上、野州の畑の上から美しいその姿を見せ、左方の日光つゞきの山々はなほ薄雲の中に隱れてゐて、早くも宇都宮に着き、やがて日光驛に着いた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都宮にてこの茸掃くほどあり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今宵来て泊つてゐる赭顔の安中大佐も、小男の宇都宮中佐も、主人の流義が好いと云ふので、内でも人の処に泊つても、服装一切は傍を離さないのである。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　安中と宇都宮とは、八の出した貨幣を見に出て来て、八に対しては何の警戒もせずに蹲んだ。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貨幣を手に取つて見てゐた宇都宮が笑つた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　宇都宮は情報掛で、外国新聞を見てゐるので、こんな事を云つた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　安中は西班牙の Piaster や葡萄牙の Tostao を宇都宮に見せて問うてゐる。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧友は伊沢道之、加波山の暴動の時には宇都宮にいたがために、富松正安等と事を共にするの厄を免かれることができたが、群馬の暴動は免かれることができなかった。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近江の佐々木社より佐々木氏、下野の宇都宮の社司より宇都宮氏、香椎・宇佐の両社領より大友氏勃興せるがごとし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、そういった工合で、東京中は喰い詰める――し、勿論何でさ、この近在、大宮、宇都宮、栃木、埼玉、草加から熊ヶ谷、成田、銚子。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婢の話によると、宇都宮の在にいる老人の甥の娘とかが今度むこを取るについて、わざわざ呼ばれて行ったということであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろ、宇都宮から三里あまりも引っ込んでいる田舎ですからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは宇都宮在の生まれで、子供のときから日光附近の大雷に馴れているので、ほかの人々ほどには雷を恐れなかったらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は幾つで、どんな女だ」「おかんは二十三で、五年まえから奉公しているんだそうですが、ちっとも江戸の水にしみねえ女で、どうみても山出しですよ」「おかんは日光、重吉は宇都宮、おなじ国者だな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる晩は宇都宮に着いたが、その翌日も午すぎまでここに逗留して、伝兵衛は澹山を案内して二荒神社などに参詣した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都宮は日光颪が吹きつゝあつたけれど滿洲の冬を凌いで來た爲めか寒いとは思はなかつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐れな看護婦は到頭そのために解雇されて宇都宮を去らねばならなくなつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　翌朝僕は急に宇都宮へ立つた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは暫くのことでお目に掛つてそれから宇都宮へ行くといふ文意で明日が丁度其日に當つて居た。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都宮へついて出口の方へ急いで行かうとすると僕は驚いた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の留まつて居れといふ言は彼は心の中で宇都宮へついた時から待つて居たであつたらう。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
