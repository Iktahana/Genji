        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それ故今小室のことを思ふにつけても、彼兩人のことも思ひ出でゝ、新しきを得て舊きを疎むに至るを耻ぢたのである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋をする位なら人にすぐれた恋をし、人を疎む場合には之も人にすぐれて疎まうと云つたのは、それは他人ではなくもとより私自身であつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや田沼を疎むようになった。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏にても負けぐせつきたるをば、下鳥といひて世は甚だ疎む。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然それが五右衛門にも解り、五右衛門も秀吉を疎むようになった。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方の志を嗤わない者が、貴方を疎む心になど決してならない者が、一人いることを思って下さい。",
              "citation": {
                "source": "わが師への書",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逢ふ夜は君が手枕、来ぬ夜はおのが袖枕、枕あまりに床ひろし、寄れ枕、枕さへ疎むか」といふ小唄を地と掛け合ひで、老のさび声で謡ふあたりは、殊に味が深かつた。",
              "citation": {
                "source": "枕物狂",
                "author": "川田順",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を外に浮れ歩くあの様子は、平生猫に好意を持っている人にすら、疎むとか、憎むとかいう心持を起させやすい。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "『閑吟集』に「逢ふ夜は君が手枕、来ぬ夜は己が袖枕、枕余りに床広し、寄れ枕こち寄れ枕、枕さへ疎むか」といい「科もない尺八を枕にかたりと投げあてても、さびしや独り寝」という類、いずれも同じ情趣を伝えているが、季節は別に現れていない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "古き文に、ここを叙して、「悲しさの余りに、とかくもせで、かたらひ伏して、口をすひたりけるに、あさましき香の口より出来たりけるにぞ、うとむ心いできて、なく／＼はふりてける」と書いてある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると自分はそうだそうだ、おれは派手な方がいいんだ、陽気にやってくれと言って、ここで死んでちゃ邪魔なんだろうとむっくり起き上って一緒に騒ぎだし、到頭自分のためのお通夜の仲間にはいってしまったという夢である。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとむやみに便所か何かに立つ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひゅうとむちを鳴らして、馬をお馬場の向こうへ追い返しておくと、まっしぐらに駆けだした少年を道案内に立てながら、その場に米屋へ向かいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弘光君じゃないか」　と、云うとむこうからも、「――君じゃないか」　と私の苗字を云った。",
              "citation": {
                "source": "妖影",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体から云うとむしろ馬鹿気ている。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人が上げるあさましい叫び声などを聞いては、大将がうとむのも道理であると思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国橋の上下に――　そのころ、五、六歳のアンポンタンの感想は――というとむずかしいが、おしっこのことだった。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "身ぶるいするのは、櫻の木の下を通る時だけ、毛蟲の魔物が、とりつくのだからだろうとむつは思いました。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ署長さんの前に連れて行って下さい」　犯人自白の心理と云うとむずかしくなるが、どう云うものか犯人は出来るだけ偉い人の前で自白したがるものだと云う。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※々数千言と云うとむやみに能弁にしゃべるように聞こえてわるいが、時間から云えば、こんな形容詞でも使わなくってはならなくなるくらい論じていた。",
              "citation": {
                "source": "長谷川君と余",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は意地張という点において、どっちかというとむしろ陰性の癇癪持だから、発作に心を襲われた人が急に理性のために喰い留められて、劇しい自動車の速力を即時に殺すような苦痛は滅多に甞めた事がない。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や起き上るたびにもう動き出さうとむづむづしてゐる肉体を感ずる時、いつたい人間を何と解いたら良いのであらうか。",
              "citation": {
                "source": "頃日雑記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなふうにいうとむずかしい態度になるようだが、そこが造化のたくみで、純な娘の本能の中に、自分を保護する本能と相手を見わける英知とがおのずとそなわっているのだ。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして漠然たる空間を、ゆうゆうとむこうへ行く。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うとむやみに気にかかって、私はそこそこに友人と別れて、家の方へ帰っていった。",
              "citation": {
                "source": "白日夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜやらなかったかというとむろん然るべき理由はある。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こればかりは私の生来の悲願であって――どうも、いけない、私は生れついてのオッチョコチョイで、何かというとむやみに大袈裟なことを言いたがるので、もっともこうして自分をあやしながら私は生きつづけてきたのだ。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が感じた唯一の違いはこの病毒から出る透明液の状態であって、どちらかと言うとむしろ黒味を帯びていて、傷口の周りに広がる発疹は人痘試料を同じように使ったときにふつう感じるよりも、もっと丹毒様であった。",
              "citation": {
                "source": "イングランドの西部の諸州とくにグルスターシャーで見つかった病気で、牛痘の名で知られているウシ天然痘の原因および効果についての研究",
                "author": "AN INQUIRY INTO THE CAUSES AND EFFECTS OF THE VARIOLAE VACCINAE, A DISEASE DISCOVERED IN SOME OF THE WESTERN COUNTIES OF ENGLAND, PARTICULARLY GLOUCESTERSHIRE, AND KNOWN BY THE NAME OF THE COW POX.",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、夫は赤ン坊を通して彼女を愛撫している、と思うとむらむらとして、いきなり愛子を引ったくってしまいました。",
              "citation": {
                "source": "あの顔",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "季節からいうとむしろ早過ぎる瓦斯煖炉の温かい※をもう見て来た。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
