    "definitions": [
      {
        "index": 1,
        "gloss": "inner mysteries (of a field of study)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もし全般に通じようとすれば勢い浅薄に流れ、もし蘊奥を極めんとすれば勢い全般の事は分らずにしまわなければならぬような有様である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども、之を以て直ちに老生の武術に於ける才能の貧困を云々するは早計にて、嘗つて誰か、ただ一日の修行にて武術の蘊奥を極め得たる。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にものもたで　　十字架にすがる、とは汝の常に歌いし処にして、その蘊奥なる意義を知らんがため汝は今働くこと能わざるものとなれり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代の歌人がわずかに客観的趣味を解しながら深くその蘊奥に入るあたわざりしは、第一に「新言語新材料を入るるべからず」という従来の規定を脱却するあたわざりしに因る。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚的事象に徹するところに、そこに写実の蘊奥がある（或る画家の所感を読みて）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人は到底日本人ほど印度の霊妙、支那の技芸の蘊奥を研め得ぬから、結局東西の文化を悉く咀嚼し世界的完全なる発達を遂げる者は大和民族ならんか。",
              "citation": {
                "source": "東西相触れて",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に学問は常識以外の智識にして、学問の蘊奥を極むれば、それだけ常識以外の常識を発達せしむ。",
              "citation": {
                "source": "教育の最大目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は懇願し、或は威嚇し、或は訓戒し、とにかく、話術の蘊奥をつくして説く。",
              "citation": {
                "source": "「沈黙」の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "面壁九年能く道徳の蘊奥を究むべしといえども、たとえ面壁九万年に及ぶも蒸気の発明はとても期すべからざるなり。",
              "citation": {
                "source": "文明教育論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "学理の蘊奥を講じて、天下の人材を養成するものは学者である。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "余巻を開き、細玩するに、複する者は之を芟り、闕く者は之を補ひ、譌る者は之を正し、綜核究窮、直ちに原書の蘊奥を尽す。",
              "citation": {
                "source": "杉田玄白",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら研究の自由だからと言っても、ちゃんと大学令に、国家に枢要なる研究の蘊奥を極めとある以上、（本当はそんなことは書いてないが）国家に害あるような研究を自由にやるという法はないじゃないかね」「いや勿論で御座いますよ。",
              "citation": {
                "source": "語呂の論理",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる栄誉に対しては、今より一層精を励まし、神を凝らし、もってますます妖怪の蘊奥を究め、宇宙の玄門を開き、天地の大道を明らかにし、生死の迷雲を払い、広く世人をして歓天楽地の間に逍遥せしめ、永く国家をして金城鉄壁の上に安座せしむることを、かつ祈りかつ誓うところであります。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "常態は皮相にして、変態は蘊奥なり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切経の一冊読むにも一千頁は読まなくてはならぬ、自然に深入りして、仏教の蘊奥とまではいかなくても大分詳しい所まで調べようというようなことになって来たのであります。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア教育制度は初め、学問の蘊奥や国家に枢要な知識や人材や良妻賢母等々のありと凡ゆる理想の下に、もっと「健全」な計画を立てた筈であった。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史その物の蘊奥を見てゞもゐるやうに。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は少年のころから専らにんじゅつを愛好しかつ惑溺するあまり、これが史的事業の検覈と究明のため、文献を渉猟し遺跡を踏査して、すでにその蘊奥をきわめているが、その眼をもってこれら一連の猿飛小説をみるに、その小市民的みみっちさとけち臭き合理主義とに憫笑を禁じ得ないのである。",
              "citation": {
                "source": "艶妖記",
                "author": "忍術千一夜　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "又た正科の外、別に英語の一科を設け、子弟をして深く新主義の蘊奥に入り、詳にその細故を講ずるの便を得せしめんと欲するは、余の諸君と共に賛する所なり。",
              "citation": {
                "source": "祝東京専門学校之開校",
                "author": "小野梓",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟うに、新主義の学を講ずる、唯りその通般の事を知るに止るべからず、必らずやその蘊奥を極め、又た事に触れ、勢に応じてこれが細故を講究すべきの事多うし。",
              "citation": {
                "source": "祝東京専門学校之開校",
                "author": "小野梓",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に独逸を捨てて取らず、仏蘭西を措て顧みず、却て英書を取てこれを我学生に授け、以て大に新主義の蘊奥を極むるの利を与え、以て詳にその細故を講ずるの便を得せしめ、往々学問の独立を謀らんと欲するものならん。",
              "citation": {
                "source": "祝東京専門学校之開校",
                "author": "小野梓",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか寄手のやつらを防ぎやぶってくれ」「ご安堵あれ、北条流の蘊奥をきわめた丹羽昌仙が、ここにあるからは、なんの、伊那丸ごときにこの人穴を一歩も踏ませることではござらぬ」　轟又八は、いつのまにか、こそこそと雑兵のなかへ姿をかくしてしまった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "光秀の兵理軍学の蘊奥も、ここに至ってはすでに施し尽きていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる兵家の蘊奥を傾けても、この江岸一帯の陣容から欠点を捜し出すことはできないでしょう」　曹操はことごとくよろこんで、さらに、彼を誘って、丘を降り、今度は諸所の水寨港門や大小の舟行など見せて歩いた。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、どうもいない人がいるわけではなし、といって、あんな鼓をほかに鳴らす人はこの近所になしと、いろいろ考えてみて、あんまり気味がわるいのによけい震えていたんでごぜえます」「ふふうんのう！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、両名の傷は申し合わせていずれも背をうしろから袈裟掛けにやられているではござりませぬか」「ふうんのう――しかし」「いえ、断じて眼の狂いござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
