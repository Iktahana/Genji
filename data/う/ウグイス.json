    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese bush warbler (Horornis diphone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "初めて大久保の新居に移った時は、春の麗らかな日であって、裏の竹藪で鶯がしきりに鳴いてた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚は、大仰な言いかたをすれば、鶯の羽のような汚い青さで、まったく光沢がなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯の鳴くやちいさき口開けて　単純な印象を捉えた、純写生的の句のように思われる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鶯という可憐な小鳥が、真紅の小さな口を開けて、春光の下に力一杯鳴いてる姿を考えれば、何らかそこにいじらしい、可憐な、情緒的の想念が感じられる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例として桜狩美人の腹や減却す人間に鶯鳴くや山桜　人里離れた深山の奥、春昼の光を浴びて、山桜が咲いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間」という言葉によって、それが如何にも物珍しく、人跡全く絶えた山中であり、稀れに鳴く鶯のみが、四辺の静寂を破っていることを表象している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち句の意味は、行人の絶間絶間に鶯が鳴くと言うので、人間に驚いて鶯が鳴くというのでないと主張している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓には朝の光がさし込み、庭には鶯が鳴いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯のあちこちとするや小家がち「籬落」という題がつけてある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あちこちとする」という言葉の中に、鶯のチョコチョコした動作が、巧みに音象されていることを見るべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ蕪村の句で「鶯の鳴くやあち向こちら向」という句も、同様に言葉の音象で動作を描いてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯の声遠き日も暮れにけり　春の暮方の物音が、遠くの空から聴えて来るような感じがする。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来日本の詩歌には、鶯を歌ったものが非常に多いが、殆んど皆退屈な凡歌凡句であり、独り蕪村だけが卓越している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば鶯のあちこちとするや小家がち　　　蕪村春の海ひねもすのたりのたり哉　　　蕪村　の如く、「あちこちとするや」の語韻から、鶯のチョコチョコとする動作を音象し、「のたりのたり」の音調から春の海の悠々とした印象を現わしているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯や駒鳥はいつも鳴いてゐるし、樹陰の深い緑は所々にあるし、それだけで山間の別天地をなした鮮新な温泉町としてゐる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴室の硝子障子を通して新緑の山を見てゐると、どこかで鶯が鳴いて居る。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも上根岸八十二番とか思うていたが家々の門札に気を付けて見て行くうち前田の邸と云うに行当ったので漱石師に聞いた事を思い出して裏へ廻ると小さな小路で角に鶯横町と札が打ってある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、着京後間もなく根岸の鶯横町というのを尋ねて行った。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯横町は右下半に曲線を描いて子規庵は長さ一センチくらいのいびつな長方形でしるされてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線路の右端の下方、すなわち紙の右下隅に鶯横町の彎曲した道があって、その片側にいびつな長方形のかいてあるのがすなわち子規庵の所在を示すらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を書いていたら、急に三十年来行ったことのない鶯横町へ行ってみたくなった。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯横町も消えているのではないかという気がして心細くなって来た。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこの樹の茂りを見てはじめて三十年前の鶯横町を取返したような気がした。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯横町の椎の茂りを見ただけで満足してそのまま帰って来てよかったような気がする。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰ってから現在の東京の地図を出して上根岸の部分を物色したが、図が不正確なせいか鶯横町も分らないし、子規自筆地図にある二つの袋町も見えない。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈黙してたたずんでいると、鶯鳴き、ホトトギス鳴き、カケスが鳴き、眼覚めた鳥が、一せいに声を合せて鳴き立てる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこら辺りにやしおの花が鮮に咲き、丸味のある丘には一面茶の木が鶯餅を並べたように萌黄の新芽で装われ、大気の中にまでほのぼのとした匂いを漂わしていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶯の声まだ渋く聞ゆなり、すだちの小野の春の曙」というときの渋味は、渋滞の意で第一段たる「正」の段階を示している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は野火の煙の低迷する如く、富士の胴中を幅びろに斜断して、残んの月の淡い空に竜巻している、うぐいすのなく音も交る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソプラノがベースに聞こえたりうぐいすの声が鵞鳥のように聞こえるのでは打ちこわしである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
