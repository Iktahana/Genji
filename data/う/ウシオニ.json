[
  {
    "uuid": "94ad3f67-9469-5719-bf85-00da1ed102ee",
    "entry": "潮煮",
    "reading": {
      "primary": "うしおに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "boned white fish boiled in salted water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "潮煮の鯛の目、鮑の蒸したのが涼しそうで、熱燗の酒がヒヤリと舌に冷いくらい――貴女が云った自棄ですか――　夕方、今しがた一時は、凪の絶頂で口も利けない。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の朝になると、まだ暗いうちに一帳羅のフロックコートを着て、金鎖を胸高にかけて、玄関口に寄せかけた新調の自転車をながめながら、ニコニコ然と朝飯の膳に坐ったが、奥さんの心づくしの鯛の潮煮を美味そうに突ついているうちに、フト、二三度眼を白黒さした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて鯛の潮煮などがテエブルの上に運ばれた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "渇はやまず、うしほのみ、――ただ海の水、　　　　いかにかせむ、玳瑁を焚きて潮煮たる。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理当番が、島にいた正覚坊の、潮煮と焼肉を出した。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯は、正覚坊の焼肉と、潮煮。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼魚、潮煮、かめの油でいためたのもたべたが、これには、たいせつなたきぎを、使わなければならないから、たびたびはできない。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩焼にも、うしおにも、一塩の干物にも、家族を喜ばすに足りるだろう。",
              "citation": {
                "source": "夜の黒鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょっつるにしても、うしおにしても、考えてみれば、魚の料理である。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも三百年の伝統の中に、いつの間にか鯛のうしおには焼塩を使わずに荒塩を用いるとか、ある種の煮物には出汁やその他の調味料を入れないとか色々の制約が出来ている。",
              "citation": {
                "source": "室鰺",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、誰やら、笠をかぶって、窓の外の夜更けを通って行く人影が、扇を口に当て、はや潮の――うしおに巻かれて迷うよ友の千鳥は。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
