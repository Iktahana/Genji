    "definitions": [
      {
        "index": 1,
        "gloss": "nape (of the neck)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "改良事項は今以てチヨイチヨイ持出されたが、その実績を見ることは忘れてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々記入する書式の中の宗教という項に神道と書いたら、それはどういう宗教だと聞かれて困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに万一にも眼界の狭い偏執的な学者でも出て来て、自分に興味のないような事項の観測の無用論を唱えたりするような場合には事柄はますます心細くなる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長なす黒髪を項の中から分けて豊かに垂れ下げ、輪廓の正しい横顔は、無限なるものを想うのみ、邪なる想いなしといい放った皎潔な表情を保ちながら、しら雲の岫を出づる徐なる静けさで横に移って行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお竹のほかには杉皮も二元的対立の一方の項を成すものとして「いき」な建築が好んで用いる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かれいの贈物」という同一の事項が偶然に継起的に繰返されたのだ。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通りの定まった版行で押した項目だけを暗誦的に説明してしまえばそれでもうおしまいで先様御代りである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論科学全体の綜合的歴史はとても教えることは出来ないが、ある事項に関する歴史でよろしい。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時Ｒ研究所での仕事に聯関して金米糖の製法について色々知りたいと思っていたところへ、矢島理学士から、西鶴の『永代蔵』にその記事があるという注意を受けたので、早速岩波文庫でその条項を読んでみた。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも西鶴の知識慾の旺盛であった事は上述の諸項からも知られるが、しかし西鶴の知識慾の向けられた対象を、例えば馬琴のそれと比較してみるとそこに興味ある差違を見出すことが出来るであろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした例としては『諸国咄』中の水泳の達人の話、蚤虱の曲芸の話、また「力なしの大仏」の色々の条項を挙げることが出来る。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例えば『桜陰比事』二の三にある埋仏詐偽の項中に、床下の土を掘っても仏らしいものは見えず「口欠の茶壺又は消炭螺からより外は何もなかりき」とある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西鶴についてはなお色々述べたいこともあるが、ここではただ表題に関係のあると思われる事項の略述に止めた。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現今の物理学的気象学の立場より考えて、今日のいわゆる要素の数は大体において理論上主要の項を悉したりと考えらる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海洋に関する物理的事項の重なるものについては近頃出版した拙著『海の物理学』にその梗概を述べておいた。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一項に第二項を加え更に第三第四と無限の項を附け加えると、その総和は有限なものになる。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかくのごとく収斂するためには逐次の各項の間に一定の条件が満足されなければならぬ。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また無限の項から成る級数の初めの数項以下を省略しても、吾人の官能上差別を感じないという事にもなる。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは自然界の現象が有限な項から成る方程式である程度まで代表され得るというのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限にあるべきはずの残余の項の効果が微小となるのは、あながち最初に出した簡単な級数のようになるというのではない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで云う残余の項は多くはもっと速やかに急に収斂するのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一つ忘れてならぬ事はこれらの微小な残余の項が多くはいわゆる偶然の方則に従って分布され、プラスとマイナスとが相消去するために結果が蓄積せぬ事である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この考えでは方則を云い表わす方程式は初めから有限の独立変数を含む有限の項から成るものである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあるいはこれらの力の方則を表わすべき数式の第一項に対して第二項以下の小さい事に驚くと云わねばならぬ事になりはしまいか。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなじが熱って来た様だ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チタ子は断髪にしたうなじを紺色の海にむかってこころよさそうに左右に振って見せました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尊寺〔二〕宮沢賢治白きそらいと近くしてみねの方鐘さらに鳴り青葉もて埋もる堂のひそけくも暮れにまぢかし僧ひとり縁にうちゐてふくれたるうなじめぐらし義経の彩ある像をゆびさしてそらごとを云ふ",
              "citation": {
                "source": "中尊寺〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の宿ぬさをかざして山つ祇、　　　舞ふはぶらいの町の書記、うなじはかなく瓶とるは、　　峡には一のうためなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業式三宝または水差しなど、　　たとへいくたび紅白の、甘き澱みに運ぶとも、　　　鐘鳴るまではカラぬるませじと、うなじに副へし半巾は、　　慈鎮｜和尚のごとくなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待（いよいよしおれる）農民一（気の毒になる）「じゃ、あんまりそう言うなじゃ、人の医者だて治るごともあれば、療治｜後れれば死ぬごともあるだ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
