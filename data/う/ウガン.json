[
  {
    "uuid": "fd023811-7c2a-5049-8afb-8cad4f911d41",
    "entry": "右岸",
    "reading": {
      "primary": "うがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "right bank (of a river)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "北上川の蛇行水路の右岸の平野に低湿の沼沢地が一面に分布しているのは不思議である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は靉河右岸に沿い九連城以北に工事を継続しつつあり、二十八日も時々砲撃しつつあり、二十六日｜九里島対岸においてたおれたる敵の馬匹九十五頭、ほかに生馬六頭を得たり――「どうです、鴨緑江大捷の前触れだ、うれしかったねえ、あの時分は。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩橋の下、右岸には古の米廩の跡なほ存し、唱歌にいはゆる「一番堀から二番堀云※」の小渠数多くありて、渠ごとに皆水門あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸の農夫も菽を種ゑ、右岸の農夫も菽を作つた。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに秋水大に漲つて左岸の堤防は決潰し、左岸の堤防の決潰した爲に右岸の堤防は決潰を免れたといふ事實が有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時に於て、左岸の農夫は運命の我に與みせざるを歎じ、右岸の農夫は自己の熱汗の粒々辛苦の結果の收穫を得たことを悦んだとすれば、其の兩者はいづれも欺かざる、又誤まらざる、眞事實と眞感想とを語つて居るのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の相反して居るの故を以て左岸の者の言と、右岸の者の言との、那の一方かが、虚僞で有り誤謬で有るといふことは言へぬのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ左岸の者は、人力を遺れて運命を言ひ、右岸の者は運命を遺れて人力を言つて居るに過ぎずして、その人力や運命は、川の左右を以て扁行扁廢して居るのでは無いことも明白である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰航の時、私たち一行の舟は右岸の白樺林の前に散在するオロチョン人の部落の前に差しかかった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下流の右岸には秀麗な角錘形の山（それは夕暮富士だと後で聞いたが）山の頂辺に細い縦の裂目のある小松色の山が、白い河洲の緩い彎曲線と程よい近景を成して、遥には暗雲の低迷したそれは恐らく驟雨の最中であるであろうところの伊吹山のあたりまでをバックに、ひろびろと霞んだうち展けた平野の青田も眺められた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村、三田村附近では、右岸の高さは六七尺以上で、昇降には不便であったらしい。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝倉勢左岸に迫らんとすれば、家康勢これを右岸に逐い、徳川勢右岸に迫らんとすれば、朝倉勢これを左岸に逐いすくめた。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて孫三郎景健の危急を救い漸く右岸に退却した。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "長岡郡の国府に在任していた国司などが、任期を終えて都へ帰って往くには、大津の崎と云う処から船に乗って、入江の右岸になったこの地をさして漕いで来て、それから外海に出て、泊り泊りを追うのでありました。",
              "citation": {
                "source": "宇賀長者物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば或日の晝すぎ、トラステヱエル（テヱエル河の右岸なる羅馬の市區）なる友だちを訪はむ、とのたまひしは、我がためには祭に往くごとくなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸の農夫も豆を植え、右岸の農夫も豆を作った。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるのに洪水が起こり左岸の堤防は決壊し、左岸の堤防の決壊によって右岸の堤防は決壊を免れたという事実がある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に於いて、左岸の農夫は運命が我に味方しないのを嘆き、右岸の農夫は自分の労苦の結果によって収穫を得たと喜んだとすれば、その両者は何れも欺かない、また誤りのない、真事実と真感想とを語っているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その相反している故をもって、左岸の者の言葉と右岸の者の言葉の、どの一方かが虚為で有り誤りであるということは言えないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ左岸の者は人力を忘れて運命を言い、右岸の者は運命を忘れて人力を言っているのに過ぎなく、その人力や運命は川の左右によって偏っているのでは無いことも明らかである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩谷温泉までは細径ありて、右岸に通ず。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩谷温泉より上は径なくして、ただ「やまべ」釣りの踏みたる跡、右岸にあり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の老人を導者として、沼尾川の右岸を下る。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川右岸の小村落にして、かねて、河内川流域の最奧の人里也。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "園邊川の右岸に、長屋門いかめしき一構への家あり。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "石棺の露出せる處に、里見廣次の墓と題する石塔を訪ひ、總寧寺の境内を過ぎ、右に兵營、左に練兵場を見て、國府臺を下り、市川の村はづれより市川橋を渡り、小岩驛より汽車に乘りて歸ることとしけるが、日なほ高ければ、小利根川の右岸を下ること凡そ十町、善養寺一名小岩不動に立寄りて、星下松を仰ぎ、影向松を撫す。",
              "citation": {
                "source": "川魚料理",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流さして、右岸の堤上を歩す。",
              "citation": {
                "source": "國府臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　小利根川の右岸捨鐘はこれにて濟みたり。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉街道に出で、引返して、市川橋を渡り、小利根川の右岸を上る。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様の居さつしやる処の知れるまでは、何でもお前様する事に逆らはねえやうにと言ふだで、随分好き次第にさつしやるが可うがんす。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
