        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "蝶ヶ岳から短沢へ下りて来た自分は、先ずこの清い流れに嗽ぎもし、頭も洗い、顔も拭いた、気が遠くなるような悪臭の蕕草を掻き分けたことや、自分の肩から上を気圏のように繞ぐっていた蚋の幾十｜陣団やに窒息するかと苦しんだことも、夢の谷へ下りては、夢のように消えて、水音は清々しい。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉附近の路が酷くくずれている、宿の前で嗽いをした筧の水などは、埋没してしまっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小舎の前の渓水に嗽ぐ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は狂気のように躍り上って、悦んだ、そうして小さい谷川へ下りたときには、敷石の水成岩の上に、腹這いになって、飲む、嗽ぐ、洗う、もう浸かるばかりにして、やっと満腹した。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が嗽に立って台所へ出た時、奈々子は姉なるものの大人下駄をはいて、外へ出ようとするところであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "醉つて見知らぬ男と友人になつたり、兄弟と呼んで接吻した醉漢は、朝になつて百度も唾を吐いて嗽ひをする。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートサイドでレモンの皮のはいった塩水で嗽をしてスエズ運河の両岸の夜景に挟まれて身の丈を長くした妾は天晴れ一人前の女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どう致しまして、」と奥で嗄た声がして、続て咳嗽がして、火鉢の縁をたたく煙管の音が重く響いた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "臘月みふゆの火すばるを高み、　　のど嗽ぎあるじ眠れば、千キロの氷をになひ、　　　　かうかうと水車はめぐる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんはしばらくゴホゴホ咳嗽をしてゐましたが、やっと心を取り直して、又講義をつゞけました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "梟の坊さんはしばらくゴホゴホ咳嗽をしていましたが、やっと心を取り直して、又講義をつづけました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は寝たまま含嗽をすると、頸に巻きつけている真綿の襟巻を外して、夜着を深く被った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まではさも殊勝なりし婦人、電のごとき眼を新聞に注ぐと斉しく身を反し、伸を打ち、冷切ったる茶をがぶり、口に含み、嗽して、絨毯の上に、どっと吐出し、「何だい、しみったれな。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し吐いたとみえて、嗽い茶碗や濡手拭が丸盆の上にあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、眼がさめると良寛さんは、庵の裏の小さい泉へいつて、口を嗽ぎ顔を洗つた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃って育児院の子供等が、朝の含嗽をさせられているようでもある。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてとよ……生肝を取って、壺に入れて、組屋敷の陪臣は、行水、嗽に、身を潔め、麻上下で、主人の邸へ持って行く。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴は洗面所で嗽いして、顔も洗わず部屋へ帰って押入れをあけ、自分の行李の中から、夏服、シャツ、銘仙の袷、兵古帯、毛布、運動靴、スルメ三｜把、銀笛、アルバム、売却できそうな品物を片端から取り出して、リュックにつめ、机上の目覚時計までジャンパーのポケットにいれて、朝食もとらず、「三鷹へ行って来る。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は行きがけに、安手な京焼の赤湯呑を引攫うと、ごぼごぼと、仰向くまで更めて嗽をしたが、俥で来たのなどは見た事もない、大事なお花客である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は水指の水を嗽茶碗に取つて、小桶の湯を金盥に取つて、楊枝を使つて顏を洗ふのである。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なる程、嗽をしてしまふと、乾いた手拭で嗽茶碗を拭く。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏を洗つてしまふと、湯をバケツに棄てて、手拭を絞つて金盥を拭いて、それに嗽茶碗を重ねる。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつがだんだん大きくなって肋骨の内側をコスり削って咳嗽を連発さしたり、声帯に伝わる神経を圧迫して声を嗄らしたりし初めるのであるが、それでも本人はまだ気付かない事がある。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その時ふいに、低いゴロゴロゴロゴロと云う含嗽するような音につづいて、木の上をはげしくたたく音が聞えて来た。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "境も嗽手水して、明王の前に額着いて、やがて、相並んで、日を正射に、白い、眩い、峠を望んで進んだ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台の前に坐らせて、嗽茶碗で濡した手を、男の顔へこう懸けながら、背後へ廻った、とまあ思わっせえ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が嗽に立つて臺所へ出た時、奈々子は姉なるものゝ大人下駄を穿いて、外とへ出ようとする處であつた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先驅の光が各自の顏を微明るくして日が地平線上に其の輪郭の一｜端を現はさうとする時間を誤らずに彼等は揃つて念佛を唱へる筈なので、まだ凡てが夜の眠から離れぬ内に皆悉口を嗽いで待つて居ねばならぬのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなそう言って笑うがいい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまつたね、話がないんだ、と言つて笑ふと、娘さんは、私の窮屈がつてゐるのを察して、男は無口なはうがいい、と言ひ置いてさつさと部屋から出て行つて呉れた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
