[
  {
    "uuid": "a7cfa05e-3409-535a-be1f-b99f5e8b2421",
    "entry": "禹歩",
    "reading": {
      "primary": "うほ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
