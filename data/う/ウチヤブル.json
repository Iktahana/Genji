        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あれも Alexander Selkirk とか云ふ水兵の實事譚を種子にして作つたものださうですが、西班牙の海上權を打ち破る程の海軍も、一人手放した時、あれ程の爲事をする水夫のゐる國だから、發展することが出來たのでせう。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三の丸を打ち破る事は出来たが、城中の戦略は十二月の時と同じく、弾丸弓矢大石の類は雨の如くである。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてひとりでにできたこの壁を打ち破るという事ができるとしても、その努力は今の健康が許さないと思っていた。",
              "citation": {
                "source": "球根",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かの部屋の外から声を掛けるのに、戸を締めて寝ていると、拳骨で戸を打ち破ることもある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の奸佞邪智を打ち破る為に走るのだ。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが本邦に渡来してあたかも邪視もっとも強力なりし猿田彦崇拝と合して昨今の庚申崇拝が出来たので、毒よく毒を制する理窟から、以前より道祖神と祀られて邪視防禦に効あった猿田彦が、庚申と完成された上は一層強力の眼毒もて悪人凶魅どもの眼毒を打ち破るのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋を撃ちこわす場合は、家根を打ち破るばかりで、地を傷めないのが普通である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて片一方の脚だけでもあげさせることが出来れば、石になったという信念を打ち破ることが出来るからと思って、色々苦心して見たが、少しも成功しなかった。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神病治療にあっては、すべての妄想は他の妄想をもって打ち破る外はない」　こう博士に諭されても、助手たちは如何なる妄想を患者に起させてよいかわからなかった。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は色々考えた結果、全身を流れて来る静脈血の炭酸量を少くしたならば、この困難は打ち破ることが出来るかと思いました。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパで、自然主義の持った役割は非常に大きく、過去のヨーロッパ文化がその宗教的な伝統、騎士道の遺風、植民地政策の結果から生じた女性尊重と精神的愛の誇張から生まれている男女の性生活の偽善を打ち破る力があった。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼は当時の自分の力では打ち破ることの出来なかった周囲のごまかし、小市民の毒によって、少なからず制約されている。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう可能性があり、どういう障碍物があり、どんな方法でそれを打ち破ることが出来るかを研究しあう会だと思う。",
              "citation": {
                "source": "明瞭で誠実な情熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事情をはつきりさせることは近代の認識論的偏見を打ち破るために必要なことであるから、更に立入つて論究してみようと思ふ。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかゝはらず私はそれを打ち破ることをしなかつた。",
              "citation": {
                "source": "感想の断片",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方電子デバイス側には、旧態依然たる発想を打ち破る提案は、我々が示したとの記憶が残っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞭はりゅうりゅうと風を切って、所｜嫌わず雨のように、馬の皮肉を打ち破るのです。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう場合には、他人の説を打ち破る才に長けた如何なる弁護士といえども、彼女と論戦を試みれば結局、内心よりの確信にはとうてい敵わぬことを発見したに過ぎないだろう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは内海の静かな造船港だ貝の蓋を閉じてしまったような因の島の細い町並に油で汚れたズボンや菜っぱ服の旗がひるがえっている骨と骨で打ち破る工場の門の崩れる音その音はワアン、ワアンと島いっぱいに吠えていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは内海の静かな造船港だ貝の蓋を閉じてしまったような因の島の細い町並に油で汚れたズボンや菜っぱ服の旗がひるがえって骨と骨で打ち破る工場の門の崩れる音その音はワアン　ワアン島いっぱいに吠えていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは内海の静かな造船港だ貝の蓋を閉じてしまつたやうな因の島の細い町並に油で汚れたヅボンや菜つ葉服の旗がひるがへつて骨と骨で打ち破る工場の門の崩れる音その音はワアン　ワアン島いつぱいに吠へてゐた。",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "全世界に亘る『狂人の暗黒時代』と、その中に蔓延する『キチガイ地獄』を、自分の学説の力で打ち破るべく、何もかも打ち忘れて盲進する当初の意気組を回復した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うと私は、何かしらこの絵巻物の中から、一切の神秘と不可解とを、一挙に打ち破るに足る或る恐るべき秘密の鍵を発見しそうな予感に打たれつつ、唇を強く噛み締めた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア法水君、君は旗太郎の不在証明を打ち破るんだ」「いや、この評価は困難だよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞭はりうりうと風を切つて、所嫌はず雨のやうに、馬の皮肉を打ち破るのです。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそういう思想を打ち破るために来た者じゃ」　白法師の眼はこう云った時｜焔のように輝いた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新感覚派の主張が気に喰はなければ、それを打ち破る主張を立てるがいゝ。",
              "citation": {
                "source": "自問自答",
                "author": "――所謂「新感覚派」の為めに――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の音楽は二十世紀の音楽であって、彼の作品は、十九世紀のあらゆる作曲法をも打ち破る新たなる形式を繰りひろげてきたのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによつて何か大切なものを失ふのだといふ「迷信」を打ち破るつもりでした。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や更始一新、王政復古の日に当たり、眼前の急務は何よりまずこの弊習を打ち破るにある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
