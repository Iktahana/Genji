    "definitions": [
      {
        "index": 1,
        "gloss": "very thin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "厚紙か何かの筒の横腹から四つ足を出したものが猫の胴になりその一端に薄っぺらな短い尻尾が付いている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし非常に粗末な薄っぺらな品である。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近頃本屋の棚で薄っぺらな「インゼル・ビュフェライ叢書」をひやかしていたら、アレクサンダー・ウラールという人の『老子』というのが出て来た。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして俺が毎晩家へ帰って来る道で、俺の部屋の数ある道具のうちの、選りに選ってちっぽけな薄っぺらいもの、安全剃刀の刃なんぞが、千里眼のように思い浮かんで来るのか――おまえはそれがわからないと言ったが――そして俺にもやはりそれがわからないのだが――それもこれもやっぱり同じようなことにちがいない。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていかにもぞんざいで薄っぺらなものに思われて来た。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな薄っぺらなものが噴出されたとしても、空中で衝突し合って砕けやすいであろうし、また落下の衝動でも割れないわけにはゆかないであろうと思われた。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地理初歩」という薄っぺらな本を夜学で教わった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顔の葉を御覧なさいまし、表はあんなに薄っぺらなもんですが、裏はふっくりしておりますもの……裏を聞いて下さいよ。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）大体われ／＼の文学が軽佻で薄っぺらなのは一に東京を中心とし、東京以外に文壇なしと云う先入主から、あらゆる文学青年が東京に於ける一流の作家や文学雑誌の模倣を事とするからであって、その風潮を打破するには、真に日本の土から生れる地方の文学を起すより外はない。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という薄っぺらな心境であろう。",
              "citation": {
                "source": "最近の感想",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と道学者に言われるような、薄っぺらな奴等が、先生の目を抜こうなぞと、天下を望むような叛逆を企てるな。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをお土産だなんて図々しくほらを吹いて、また鰻だって後で私が見たら、薄っぺらで半分乾いているような、まるで鰻の乾物みたいな情無いしろものでした。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいって、ぜんざいを注文すると、薄っぺらな茶碗に盛って、二杯ずつ運んで来る。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもせぬ、……お前も忘れてはおるまい、……青いクロース背に黒文字で書名を入れた百四十八頁の、一頁ごとに誤植が二つ三つあるという薄っぺらい、薄汚い本で、……本当のこともいくらか書いてあったが、……いや、それ故に一層お前は狼狽して、莫迦げた金と人手を使って、その本の買い占めに躍起となった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄っぺらで、無性格なＲ・Ｌ・Ｓ・の通俗小説と批評家のいう所のものが。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肯定できないのは、お前の倫理観が、凡そ芸術家らしくもなく薄っぺらだからだ、という見方もあるのは承知している。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）薄っぺらでも何でも、俺の倫理観は（俺の場合、倫理観は審美感と同じだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、こんな意味も内容も無い東京生活の薄っぺらな一断面が、太平洋の濤に囲まれた小さな島の・椰子の葉で葺いた土民小舎の中で、家の周囲にズシンと落ちる椰子の実の音を聞いている時に、突然思出されたものか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのも、ホームズが分析的推理を見事に発揮した事件や、その独特の捜査方法の真価を見せつけたような事件というのは、しばしばその真相そのものがあまりにも薄っぺらで陳腐なものであるため、わざわざ世間の皆様にお伝えすべきこととも思えないからだ。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物の非利己的な自己犠牲的な愛のなかには、単なる人間のさもしい友情や薄っぺらな信義をしばしば嘗めたことのある人の心をじかに打つなにものかがある。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、とにかく洋館などは、過去の大地震に煉瓦一枚落ちなかったほどに、堂々として、内部の装飾も家具もこの頃の文化住宅の薄っぺらな、吹けば飛ぶような安手なものとは違って、荘重典雅を極めている。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと、見詰めていると最初銀かニッケルと思った金属は、銀ほどは光が無くニッケルほど薄っぺらでないのに、気が付いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーコンには気の毒なくらい薄っぺらな粗末な仮綴である。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラック建築の色や形が如何に派手で変化が多くて、薄っぺらで毒々しいかは前に述べた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒々しい、薄っぺらな色彩のバラック街……眼まぐるしく飛び違う車や人間……血走った生存競争……そんな物凄い刺戟や動揺めきをうけた柔かい少年少女の脳髄は、どれもこれも神経衰弱的に敏感になっている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "口も筆も不調法な地方の若い人の自覚の力　さなきだに、毒々しい薄っぺらな都会の文化は全人類に飽かれつつある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪人者の、やわら取りのというからは、どんな逞ましい強そうな男かと思えば、それはまだ廿二三歳の町人風で、色の小白い痩せぎすの、小二才とか青二才とかいいそうな、薄っぺらな男であったので、市兵衛も案に相違して、しばらく呆れてその顔をながめていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、震災当時まで三十余年を経て来たのであるが、震災以後それがまたいつか廃止されて、今日では薄っぺらな西洋紙に粗悪な印刷を施した、見るからに安っぽいプログラム式の物になってしまった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちのような老人の眼から観ると、今日の劇場と観客とは、安インキの薄っぺらなプログラム一枚によって、よく象徴されているように思われる。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄っぺらでもいいから沢山雑誌を出せ、本屋を説いて出版もさせろ、どしどし会合もしろ、講演会もやれ、街頭へビラも張れ。",
              "citation": {
                "source": "わかりきった話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
