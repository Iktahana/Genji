        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "口が乾いて舌が上顎に貼り付く。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エ」でも日本の「エ」よりももっと舌に力を入れて言う「エ」と、舌を下げて上顎との間を広くして言う「エ」とを区別するという風に、色々沢山違った母音を用いる。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（斃ちても可えか……はあ、）　と呆れたやうに大きな口を開けると、卍を頬張つたらしい、上顎一杯、眞黒に見えたさうです。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっけと唾を絞って吐き出したが、最後の一ひらだけは上顎の奥に貼りついて顎裏のぴよぴよする柔いところと一重になってしまって、舌尖で扱いても指先きを突き込んでも除かれなかった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子に投げられて上顎の奥に貼りついた桜の花びらの切ないなつかしい思い出で――復一はしきりに舌のさきで上顎の奥を扱いた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一は試験室の窓から飴のようにとろりとしている春の湖を眺めながら、子供のとき真佐子に喰わされた桜の花びらが上顎の奥にまだ貼り付いているような記憶を舌で舐め返した。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず上顎の入歯をはずし、道路の片隅に安置せり。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田氏の上顎が全部ぶさいくな義歯なのを看破したからである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くわっとあけた口、　上顎、舌、　両頬の髭、　眼光。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛声をかけたり、地謡を謡ったりしているうちに、翁の上顎の義歯が外れ落ちてガチャリと下歯にぶつかる事が度々であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイパーとは上顎骨甚だ短く大毒牙を戴いたまま動かし得る蛇どもで、和漢の蝮もこれに属するからまず蝮と訳するほかなかろう。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎の舌が上顎へひっついてしまった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が私の病院に来てから間もなく私がある中年紳士の上顎竇蓄膿症の手術をした時に、初めて助手を命ぜられた彼女は、忙しく動いている私の指の間から、麻酔患者の切り開かれた上唇の間に脱脂綿をスイスイと差し込んで、溢れ流れる血液を拭き上げて、切開部をいつも私の眼によく見えるようにして行った。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤児は生まれてからまだ二タ月か三月しか経つまいと思われるぐらいの嬰児であったが、その上顎の左右には一本ずつの牙が生えていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその赤児はどうした因果か、生まれるときから上顎に二本の長い牙が生えている鬼でございまして、本人は勿論、兄弟たちも世間へ対して外聞が悪いと申して、ひどく困っているということを聞きましたので、わたくしはすぐにそのお北の家へたずねて参りました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思ふと「家うちのこと」が、鉤になつて上顎に引ツかゝつた。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に争う兄弟も無いのに、切に小言を言いながら、ガツガツと喫べ出したが、飯は未だ食慣れぬかして、兎角上顎に引附く。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人體の頂上には、また脊骨の丸まつたもの、頭蓋骨があつて、手が上顎で、足が下の顎で、手指と足指とは上下の齒である。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑弥呼は長羅の腕の中から、小枝を払った※の枝に、上顎をかけられた父と母との死体が魚のように下っているのを眼にとめた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に上顎門上歯が幾分前に出て居りしや否や、下顎犬歯は普通人に比して長きや否や、犬歯の俗称鬼歯と称するものなりや否や。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下顎、犬歯は噛合するとき上顎歯列の前に出ずるや、及び智歯の存否。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かシュー、シューという響をともなう彼の声は、一遍ぐっと押えたままその力をゆるめず上顎の方から限りなく対手に向ってのびて来るようで、はたから口を利くきっかけをつかませないところがあるのであった。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎の舌が上顎へ密着て仕舞つた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾は口腔内の上顎から後頭部にはいって、一発で即死とのことだった。",
              "citation": {
                "source": "父の形見",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく上顎の糸切歯がここに喰いこんで、四郎少年の皮膚と肉とを破り、頸動脈をさえ喰い切ったのであろう。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時局柄のトンカツやテキを上顎と下顎に挟んで、顳※を痛くするのとは訳が違う。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは自分の舌が上顎に釘づけにでもなったくらいで、いやだといういの字も言うことができなかったのです。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしには舌が上顎に附着してしまつたやうな気がしたのである。",
              "citation": {
                "source": "クラリモンド",
                "author": "LA MORTE AMOUREUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわいいおかたに――世にもなつかしい、世にもきれいなかわいいおかたに、どうぞよろしく……」すると突然、かれの義歯がうわあごからはずれて、したくちびるの上へ落ちた。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
