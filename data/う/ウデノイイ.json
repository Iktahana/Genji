        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "事実、すばらしく腕のいい美容師であった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の良人は相当腕のいい機械技師で人間も悪くなかったが、酒を飲むと病弱な妻をひどくいじめた。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説はそういう心持にアサが辿りつくまでの経緯、腕のいい職工であるが勝気で古い母に圧せられ勝な良人の山岸との心持の交錯、大変物わかりのよい職長梶井のうごきなどを語って展開されているのである。",
              "citation": {
                "source": "徳永直の「はたらく人々」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子も二三枚そこで仕立てて腕のいいことを知っていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後から行きますわ――私、これから大いに腕のいいところおめにかけなけりゃならないんですもの」「じゃ、たいてい、あの橋を真直出たところ辺にいるから」　二人は庭から木戸へ出てゆく。",
              "citation": {
                "source": "夜の若葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし腕のいい技師や職工は、そんなわけにいかない。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに腕のいい人でしたからね――」　いずれにしても二人が死んだ後、お由殺しの事件の捜索は即刻打切られてしまったので、これ等はただ苦労性の人々の臆説にすぎないのである。",
              "citation": {
                "source": "白蛇の死",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋へ行っても腕のいい料理人は男であるし、仕立屋でもほんとうにうまい一流の仕立屋は男である。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも主として、腕のいい医者としてでしたな。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、今のソヴェトには、あの船がひっぱり上げられるだけ腕のいい潜水夫はいませんよ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほかにやることを知っていたら、バルナバスは自分が全然満足していない使者の勤めなんかすぐやめてしまうでしょうよ」「弟さんは腕のいい靴屋じゃないんですか」「そうなのよ」と、オルガはいった。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花　死んだお父っあんな、そんな、そんな腕のいい木びきだったの？",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこの子を腕のいい大工にしようと思っている。",
              "citation": {
                "source": "聖家族",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも吝嗇な客ほど釣果にも執着が強いから、腕のいい船頭をもっぱら覘う、という迷惑な関係が生れるのだそうであった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうだいの死んだ父は和助といい、浦粕の船宿では誰よりもしょうばいがうまく、上客はみな「千本」に集まったし、船頭も腕のいいのが揃っていたこと、朝日紙へ週一回ずつ釣通信を書いていたこと、鯉釣りの名人で、いつも蒸気河岸の上で鯉を釣り、不漁で帰る客があると、その鯉を持たせてやったこと。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は腕のいい植木職だったが、もう七十幾つという年でほんの手伝い稼ぎしかできないという、痩せていて小さいが、日に焦けた緊った躯つきで、歯切れのいい調子でものを云うところなど、まだなかなか肯かぬ気に満ちていた。",
              "citation": {
                "source": "野分",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は腕のいい大工でも日に三匁がたいがいの相場だから、不服を云われる筈はなかった。",
              "citation": {
                "source": "しじみ河岸",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三日間、あっしたちはいっしょでした、あっしは博奕のことは知らねえので、ただ側で見ているだけだったが、辰あにいの腕のいいのと、顔の売れてるのには吃驚したもんです。",
              "citation": {
                "source": "枡落し",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "良さんは腕のいい刷毛作りで、刷毛といってもヘアー・ブラッシなのだが、問屋でも彼の作った物は高級品として扱い、一流化粧品店とか洋品店、百貨店などへ納入していて、けれども仕事がのろく、数があがらないので、「ごうがにえる」と云われた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸万はその名を留吉といって、もともとは腕のいい旋盤工だった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のときから仕込んでおかないと、腕のいい鋳物師にはなれないというのがおやじの意見で、なまじ上の学校へやると、この商売をいやがるからという気持もあったようだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと腕のいい奴は何人もいる」「ケ・ヴァ（※とんでもない）」少年は言った。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や国王の面影はなく、粋で上品な若い英国紳士が、ボンド通りにある腕のいい誠実な仕立屋から出てきたかのよう。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
