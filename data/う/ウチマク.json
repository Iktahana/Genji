        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし故人がそういう方面の内幕話に興味を有ち、またそういう材料の供給者を有っていた事はたしかである。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位信任をされておれば、いろいろ内幕も聞いたろう、また、ただ見たばかりでも大概は知れそうなもんだ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐人の阿魔なんぞに惚れられやあがって、この合の子め、手前、何だとか、彼だとかいうけれどな、南京に惚れられたもんだから、それで支那の介抱をしたり、贔負をしたりして、内幕を知っててもいわねえんじゃあねえか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在でも月刊雑誌の編集部では随筆の類は「中間物」と称する部類に編入され、カフェーの内幕話や、心中実話の類と肩をならべ、そうしていわゆる「創作」と称する小説戯曲とは全然別の繩張り中に収容されているようである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大部分は料理、裁縫、手芸なぞの切抜記事で、上流婦人や女優の消息、芝居、展覧会なぞの報道を申訳だけに掲載していたが、本来の目的は一箇月に一度位ずつ、女学校や、上流家庭の内幕を素破抜いて、その新聞の全部を高価く売り付けるのであった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きにもっともな話……」「……又、大目付様からの御内達で、どのような場合でも蔵元屋の内幕に立入って、蔵元屋の信用に拘わるような事を探り立てしてはならぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても恐ろしゅうて恐ろしゅうて、気が揉めて気が揉めて……という涙ながらの物語で、蔵元屋の内幕を洗い泄い喋舌って帰りましたが、イヤモウ肝の潰れるお話ばっかりで……」　松倉十内はここが大事と思ったらしく、眼を丸くしたまま点頭いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ又、昨晩の蔵元屋のお召捕騒動で、様子は丸きりわからず、気も顛倒しております処へ、今朝ほど良助さんがヒョッコリ見えましたので、蔵元屋の内幕を残らず承りました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしビックリなされましたろうなあ」「イヤモウ……只今貴方様から承りましたお話とは寸分違わぬ蔵元屋の内幕で、驚きに驚きを重ねますばっかり……その上に又一つの驚きと申しまするのは、御城内から私の父の半左エ門へ御差紙が参りました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　均平はこの世界の内幕は、何も知らなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その位信任をされてをれば、種々内幕も聞いたらう、また、ただ見たばかりでも大概は知れさうなもんだ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐人の阿魔なんぞに惚れられやあがつて、この合の子め、手前、何だとか、彼だとかいふけれどな、南京に惚れられたもんだから、それで支那の介抱をしたり、贔負をしたりして、内幕を知つててもいはねえんぢやあねえか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか探せぬと思っていたところ、いくらでも売物があり、盛業中のものもじゃんじゃん売りに出ているくらいで、これではカフェ商売の内幕もなかなか楽ではなさそうだと二の足を踏んだが、しかし蝶子の自信の方が勝った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、料理屋を開くには、もう少し料理屋の内幕や経営法を知って置いた方がよい。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集部が用意した「インサイドウォッチャー」という連載タイトルには、人にまつわる企業の内幕話を書いて欲しいというライターへの期待が現れている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれももう少し考えるから、おめえは善ぱと手分けをして、伊豆屋と和泉屋の内幕を探ってくれ」「こうなると此の春、府中へ行って来て好うござんしたね」「むむ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の内幕を八橋に覚られまいという懸念から、彼はいつもよりも金づかいをあらくして見せた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "君だから内幕を話すが二銭に三箇の石鹸ナ。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は御心配になつて眼の廻るほどな忙がしい目をなすつて申込人の身分財産性質等の内幕を一々詮議遊ばす。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちから訊きもしないのに何故こんな内幕咄をするのか解らなかったが、一と月ばかり経って公然入社の交渉を受けた時初めて思い当った。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども校長先生がその立像をお嫌いになるホントウの理由を聞いてみますと又、世にも馬鹿らしい内幕なのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その卑怯な事実を支配している連中は、その矛盾を塗りつぶすためには……そこから市井の内幕を見すかされないために、いろんな形式や、相談や、挨拶や、宣言や、発表や何かでその間を埋めてしまった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新後、新政府の権威を見せるために、又は人民を煙に捲いてドンドン改革をして行くためには、法令でも、布告でも、何でも、漢語と片仮名で塗りかためて人民の前につき立てて、内幕をのぞかれないようにする必要があった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸時親しくなるに連れて、彼女の家の内幕が次第に解かって参りました。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は暗いうちから市場へ行き、夜は皆が寝静まる時まで板場で働く、そんな内幕も妻に語るようになった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから如才もあるめえが、その辰伊勢という店の内幕も一と通りは調べあげてくれ」「わかりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "取わけ竹山に想像を費さしたのは、横濱の棧橋に毎日行つて居た事があるといふ事と、其處の海員周旋屋の内幕に通曉して居た事であつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂乱した肉慾が、神の定めも人の掟もあっけなく踏み越えて、ただひたすらに作り上げた傑作がこれであり、里虹一座の人たちは、まったく油地獄のそれのように、うちまく油流れる血、踏みのめらかし踏みすべらかして、とめどない足のぬめりに、底知れず堕ち込んで行くのだった。",
              "citation": {
                "source": "人魚謎お岩殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "偵察機全機でうちまくってみるんだ。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗組員は皆一挺ずつ小銃と青龍刀を持っている外に、船の底に機関銃が二挺も隠してあって、いざという時には、それを甲板に持出して、相手の船をうちまくるのです。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
