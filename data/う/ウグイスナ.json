    "definitions": [
      {
        "index": 1,
        "gloss": "young greens (of mizuna, Japanese mustard spinach, rape, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
