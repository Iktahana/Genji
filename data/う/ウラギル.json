        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしそういう方法によって進歩して来た結果はかえってその方法自身を裏切る事になった。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、眼はこれ等すべてを裏切る憂欝な大きな眼だ。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土佐の貧乏士族の子の雑煮に対する概念を裏切るような贅沢なものであった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は僕もまだ年が若く、客觀の認識力がなかつたので、室生君の「東洋趣味への傾向」を、詩の同志を裏切る者として腹を立てた。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんた、もし裏切るようなことがあれば妾がどんなことをする女か知っている？",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には自分に反き人を裏切るあらゆる虚僞があつた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父も自己の主張を裏切るやうな、この不可解の事實を發表するのが如何にも殘念であつたらしく、それ以上には何も祕密を洩さなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、俺れと、俺れの兄弟を裏切るような行為をしくさったくらいにゃ、生かしては置かないぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの私の眼を裏切る音が深祕な感情を持つて聽こえはじめる。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほたるの信頼を裏切るな。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　＊　　　　　　　＊　書棚とピアノとオルガンと、にわか百姓の素性を裏切る重々しい椅子とで昼も小暗い父の書斎は都会からの珍客で賑わっていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのも、わざと向島へつれて行ったりして、暗に幾人かの女を世話していることを衒かし、自身の金力と親切を誇示するかのような態度に、好い気持のするわけもなく、それに目を瞑るとしても、今まで世話になった若林を裏切るだけの価値があるかどうかの計算もなかなかつかないのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、眼はこれ等すべてを裏切る憂鬱な大きな眼だ。",
              "citation": {
                "source": "ダミア",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、もう一年、おゆるし下さい、と長兄に泣訴しては裏切る。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、あの人たちを信頼し、心の隅では尊敬さえしているのに、あの人たちは、へんに僕を警戒し、薄汚いものにでも触るような、おっかなびっくりの苦笑の態度で僕に接して、ああ、あの人たちは、そんなに上品な人たちばかりなのかねえ、いつでも見事に僕を裏切る。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい徒党の形式、それは仲間同士、公然と裏切るところからはじまるかもしれない。",
              "citation": {
                "source": "徒党について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの先生の親切を裏切るのが、せつなくて、それできょうまで僕はこの学校に愚図愚図していたと言ってもよいのです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その力に反抗する事はこの場合不可能であり、またそれを一人で裏切る事が何等の效果にもならない事をよく知つてゐた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は君を、裏切ることは無い。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは御厚意裏切ること無いかと案じています。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はわたしが彼等を裏切るようなことを告げてもたゞ「それもよかろう」「まあ、やるがよい」という大様なポーズを取るだけになっている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの触感があたしを裏切るなんて。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛から落ちた話を聞かないと男は言ったが、それを裏切るように、彼は真っ逆さまにころげ落ちたのである。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金が欲しさに親しい友人迄裏切るような下劣な奴に、もう私の仕事は頼もうと思わぬと。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡部等が強硬に一戦を主張した裏には、信長の用間に陥り、佐久間信盛が戦い半ばにして裏切ることを盲信して居たからだとも伝えるが、この事は単なる伝説であろう。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠三郎が齎した勝家の内意を知ると、将監は、主人勝豊も秀吉の味方となり、某も一方の固めを任された程である、今裏切ることは武士として情ない、と答えて諾しようとしない。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしらを裏切るなら、ボブ・カラザズ、貴様をジャック・ウッドリと同じ目に遭わせてやる。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、強い感情が起って彼の体躯がほんとうに大きくなり、この断言を裏切る瞬間があった。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、どうしてそんなことができよう――友だちの信らいをうらぎるなんて……。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "理智が論理的に考えつめて生み出したテーゼをも、じっさいの現場にさらしたばあいに往々にして感情はそれをうらぎると言ってもよい。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
