        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この店の先祖がどういう訳だか店の名を付けなかったが、商売は非常に繁昌し子孫代々名無しの牛屋で通っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牛屋は、ボッコひっそりとしとるじゃないや。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "健吉は、稲束を投げ棄てゝ急いで行って見ると、番をしていた藤二は、独楽の緒を片手に握ったまま、暗い牛屋の中に倒れている。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岡惚れの対象となって、江戸育ちだというから、海津か卵であろう、築地辺の川端で迷惑をするのがお誓さんで――実は梅水という牛屋の女中さん。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、牛肉でも、あの牛屋に吊したような赤と白茶の片脚だけのが、内地は百姓屋の軒や周囲の荒壁にぐるりと掛け連らねた唐辛子、唐黍、大根の如く、いや、それを十層倍にしたぐらいの大きさのものが、まるで牛肉の祭礼のようだといいと思えたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人一座の二人までは敷かせる座蒲団の模様が違って、違った小紋も、唐草も、いずれ勧工場ものにあらざるなく、杯洗と海苔とお銚子が乗って出るのも、牛屋のちゃぶ台の真中へ丸く木を填めてあろうという組織であるのに、お座料がまた必ずしもお安くない。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい此間まで茅場町の牛屋の女中と好い仲だつたんだつてさ、ところがさ、彼奴、あれでゐて、とてもきりよう自慢なんだつて！",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しんで、信心家の種牛屋の政吉さんに伺ひを立てて見ると、「お前さんの部落には、牛の神さんがありはしないか。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松喜という牛屋はいつ頃から出来たか、ずっと以前はなかった様だ、しかし二十年位は経つだろう。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の牛屋では一丁目に吉川というのがあって、今は新橋ステーションわきの有楽軒？",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛屋も一時、カフェーやレストラン等の興隆とともにパッタリさびれて、『いろは』をはじめ大どこが大分店をしめたが、近来又々盛んになった。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛屋の姉さんというものはこれまた昔かわらぬ趣がある。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれ牛屋の姉さんが断髪になって現れたら、これは事だ。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年ならずして彼は別に、五条の方に牛屋を始めた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何業がよからうかと四五日相談しつゞけたが、矢張り飲食店の方が経験もあり、景気もよし、場所も場所だといふので、洋食屋と牛屋とを兼ねてやらうといふことに決した。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り何や、おまはんが二十五になるまで辛抱して働いて呉れさへすりや、伯父さんはおまはんにも暖簾を分けて、洋食屋でも牛屋でも好きな店出さしてやるよつて。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五まで忠実に働いたら、洋食屋か牛屋をもたしてやるといふ約束めいた言葉を、私はそのまゝ言葉通りに聞きはしなかつたけれど、そんな十年も末のことはどうなるか分らないと思つたけれど、その後いつまでも私の心から消えなかつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論外にも沢山同じような鳥屋でも牛屋でも、また普通の日本料理屋でもあるにはあるけれど、そこらは何処でも皆芸者が入るので、家族づれで純粋に夕飯を食べようとか、友達なんかとゆっくり話しながら飲もうとかいうのには、少し工合が悪いといったような訳である。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "体のいい仕事よりもと、私のさがした職業は牛屋の女中さん。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフエーだの、牛屋だの、めんどくさい事よりも、いっそ屋台でも出しておでん屋でもしようかと思う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御亭主は株屋で、細君は牛屋の女中だそうだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲毛の旅館の女中と、浅草の牛屋の女中の口が一番私にはむいている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日から牛屋の女中だなんて悲しい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして、あんな牛屋なンかにいるの？",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は牛屋の女中だつて、札束を頬つぺたへ投げ返へす心意気があつたつていふぢやないのウ‥‥随分真実つくしてたの、馬鹿らしい話だわねえ」　百合子は紅くなつた薬指の指輪の跡をいたはりながら、オパルの石を、キリキリと壁でこすつてゐた。",
              "citation": {
                "source": "「リラ」の女達",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "加能氏が牛屋の下足番をされたと云うのを何かで読んでいたので、よけいに心打たれたのでしょう。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェーだの牛屋だのめんどくさい事より、いっそ屋台でも出しておでん屋でもしようか。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男に食わしてもらう事は、泥を噛んでいるよりも辛い、程のいゝ仕事よりもと、私のさがした職業は牛屋の女中さん。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三丁目のえちかつつて牛屋、ロースあほり一丁つてな事云つて、きれいな姉ちやん澤山ゐたもンだ。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或るとき難波橋の吾々得意の牛鍋屋の親爺が豚を買出して来て、牛屋商売であるが気の弱い奴で、自分に殺すことが出来ぬからと云て、緒方の書生が目指された。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            }
          ]
        }
