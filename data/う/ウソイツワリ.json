        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんな今だからこそ、私は正直に嘘偽りなく記すことができる。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "その美しい王の手を取ることが出来るかと思へば、どんな嘘偽りをなしても、何でもない、と思つた。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の態度か、言葉かの何処かに、嘘偽りがあるように思われてならなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたは、藤十郎の嘘偽りのない本心を、聴かれて、藤十郎の恋を、あわれと思わぬか。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶかしい事を申しおるが、まことの事かッ」「なんの嘘偽りがござりましょうぞ。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの基督の仇敵が言ふことといへば、一つ残らず嘘偽りぢや！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の態度か、言葉かの何処かに、嘘偽りがあるやうに思はれてならなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女の言葉に嘘偽りはない。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまったく嘘偽りのない話なんだよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘偽りを教えられたのでは後日になって、愚庵が申分けが無い。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して嘘偽りは申しません。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせんの身についてた、嘘偽りのねえ生爪なんだ」「馬、馬鹿にしちゃァいけねえ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当にやる気かの」「三日三晩、一睡もしずに考え抜いた揚句、お願いに参上いたしましたやつがれ、毛頭嘘偽りは申上げませぬ」「よかろう。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「魚屋様は商人でのご名家、嘘偽りないお方、それゆえ現金は戴かずとも、必要の際にはいつなりとも用立て致すとお認し下されば、それでよろしゅうございます」「それはそれはいと易いこと、では手形を差し上げましょう」　サラサラと一筆書き記すと、それを乙女へ手渡した。",
              "citation": {
                "source": "郷介法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "買ったり売ったり何遍もしたが、身につくところは極く少ない」　とは嘘偽りのない告白だろう。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちその意味で彼女の書いたといわれる手記は決して嘘偽りではないと考えて見当違いではない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも気持ちに嘘偽りはない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は報道価値を高めて、売行きを増さんがためには、平気で嘘八百を書き立てるものだといわれているが、ラ・ナシオン紙といい、前掲エキセルシオール紙といい、さすがは一流紙だけあって多少の見当違いはあるにせよ、まず嘘偽りもなければ、作為の痕も見受けられぬ。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはそんな嘘偽りを述べ立てて、人の憐みを買おうという気持なぞは寸毫もない。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国への嘲笑めいた緩い敵対的態度は多かれ少なかれインテリゲンチャの義務みたいなものではあるのだが、多くは嘘偽りのない情動である。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、うそいつわりの、書いてあろうはずがない。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「叡聖文武なる日本皇帝よりおくられたもので、それにうそいつわりの書いてあろうはずはないぞ。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔、覚鑁上人（興教大師）は、「もし自分のいうことが、うそいつわりだと、思うならば、自ら修して知れ」　といっていますが、その修するというのが、この修慧です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち凡夫の語には、うそいつわりが多いが、仏の言葉には、決してうそいつわりはありません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは平生よく「うそも方便だ」ナンテ平気で、うそいつわりをいい、ヒドイのは「うそが、方便だ」と考えている人があります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論｜贋物じゃない、正直正銘、うそいつわりのない上等品ばかり並べておく。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそいつわりのない男の資格においてさ」「…………」「それじや、まずいかね？",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非お文を頂戴いたしとうございます」　うそいつわりのない真心を面にみせて、涙ながらに言う信俊の言葉に、奥方も一方ならず喜んだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間の気持に、うそいつわりはなかった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしわたしくの申しあげますことを、うそいつわりとお思いくださいますならば、だんなさまお調べくださいまして、スグにご合点のおまいりになる話でございます。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
