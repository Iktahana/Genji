          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "机の前や実験室では浮かばないようないいアイディアが電車の内でひょっくり浮き上がる場合をしばしば経験する。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一揺り揺れて、ざわざわと動くごとに、池は底から浮き上がるものに見えて、しだいに水は増して来た。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも一旦は沈んだが、また浮き上がると、その鼻のさきへ牛の頭……。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおねえさまが、浮き上がると、そのときちょうどお日さまが沈みましたが、これこそいちばんうつくしいとおもったものでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、死んでから二日たってから投げこまれたとしても、死体がそんなに早く浮き上がるかどうかも、疑わしい点である。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかと言えば、あの議論は、三日以内に水面に浮き上がる死体の公算の問題以上のものを含んでいるようなふりをしてはいないんだから。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち目になったら最後、人間は浮き上がるがめんどうになる。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリシタンバテレンのしわざなら格別、さもないかぎりは、ひとりでにいれずみが膚に浮き上がるはずもござるまい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタガタと動く漁師の喧嘩場が眼の前に浮き上がる。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "お後ろ姿を見送りながら中の君は枕も浮き上がるほどな涙の流れるのをみずから恥じた。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹の眼のような泡が幽かな音を立てて浮き上がる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇が現代生活から浮き上がる最も大きな原因は、職業演劇人の大部が、観衆が無意識に舞台に求める夢を自ら夢みる力を失っているところにある。",
              "citation": {
                "source": "演劇への入口",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "金や銀の重みを去れば、船は、軽くなって浮き上がるでありましょう。",
              "citation": {
                "source": "赤い姫と黒い皇子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び浮き上がることはありません。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その八　時計館の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "が輪廓は少しく浮き上がる。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いものがしだいに衰える裏から、浮き上がるのは薄く流した脂の色である。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾を色どる模様の華やかなるなかから浮き上がるがごとく調子よくすらりと腰から上が抜け出でている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "『恋人』の体は、たちまち押し上げられ、押し沈められ、また浮き上がる。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            },
            {
              "text": "この迷の海から浮き上がることがあろうと、まだ望んでいることの出来るものは、為合だ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡の上にでも浮き上がることが出来るように水に親しく馴れている。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時福井屋の二階のほのめく物の影は、欄干に乘出してヂツと此方を見入るのが、夕陽の中に白々と浮き上がるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅い扱帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　その晩、子刻過ぎ、黒木長者の嚴めしい土塀、丁度人肌地藏の上のあたりへ、星空を背景にして、屋敷の内側から浮き上がるやうに攀ぢ登つた者があります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人肌地藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき福井屋の二階のほのめく物の影は、欄干に乗出してジッとこちらへ見入るのが、夕陽の中に白々と浮き上がるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅い扱帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　その晩｜子刻（十二時）過ぎ、黒木長者の厳しい土塀、ちょうど人肌地蔵の上のあたりへ、星空を背景にして、屋敷の内側から浮き上がるように攀じ登った者があります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震の前に深層のプランクトンが表層に浮き上がることは、田子教授の観察、末広恭雄博士の研究によって明らかであるが、これも地震前に発する微動のためかも知れない。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで社会科学の研究は一つの循環をなし渦巻きをなして、存在の客観的現実を離れて浮き上がる可能性を有って来るのである。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たしてその泥は煙のように軽くその小石を中心にして浮き上がるのでありました。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢というものは、病的な状態にある時には、並みはずれて浮き上がるような印象と、くっきりしたあざやかさと、なみなみならぬ現実との類似を特色とする、そういう事がたびたびあるものである。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "水に沈めれば、浮き上がる。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばら骨が浮き上がるほどの息遣いに、喉は涸れ、舌は黒コゲのように干からびてしまった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
