        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "相場師か請負師とでもいったような男が二人、云い合わせたように同じ服装をして、同じ折かばんを膝の上に立てたり倒したりしながら大きな声で話していた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "構造物の材料や構造物に対する検査の方法が完成していれば、たちの悪い請負師でも手を抜くすきがありそうもない。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると税務署長がすっかり変ってしまって請負師か何かの大将のやうに見えて来た。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社員、商人、株屋、土木請負師、興行師に芸人、土地の親分と、小菊たちにはちょっと扱い馴れない人種も多かった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子とは大分時代の違う按摩の娘は、この二三年二人とも上野の料亭山下に女中奉公をしているうちに、亀井戸に待合を買ってもらったとか、貧乏なブリキ屋の娘が、テケツ・ガールから請負師の二号になり、赤ん坊を大した乳母車に載せて、公園を歩いていたとか。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の請負師だって云うのよ、頼みもしないのに無理に引かしてさ、石段の下に景ぶつを出す、射的の店を拵えてさ、そこに円髷が居たんですよ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負師や大工に責めを帰していいのか、在来の建築方式そのものに欠陥があるのかどうかわからない。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると請負師や大工に言ったくらいでねずみが防ぎきれるものならば大概の家にはねずみがいないはずである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百人という人間を髭を捻り稔り顎で使って来てる大請負師だぞ。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも学生の方が二人と、たしか木見さんとかいう請負師の方と、それから、大宅さんとかいってこの春からお役所へつとめておられる方とが、よく見えたように思います。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして噂によると、その請負師のかたと今の所に同棲しておられたということですわ」「被害者の懐中より一通の封書と一通の電報とが発見された。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "電文の末尾にあるキミとは請負師の木見のことではなかろうか」「屍体にはメリンスの掛布団をかけて一見眠っているように見せかけてあった。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもここには江戸ッ子のあらゆる階級を網羅しているので、こちらには立ちん坊、そっちには俥屋、隣りには呉服屋の旦那、向家には請負師といった風である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の博士、技師、請負師なぞの歓迎ぶりと来たら大変なものであった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その又博士や技師に一切の責任を負わせて仕事をするのが、請負師の習慣と来ているから堪らない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に今まで復興の労働者を歓迎していた親方や請負師連は、逆に賃金の不払を始めた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘密工事「わしんとこの吉が御厄介になっとりますそうで、――」　と、シンプソン病院の受付に、真青になってとびこんで来た五十がらみの請負師らしい男があった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この附近は極めて淋しいところで、だだ半哩ばかり北の方に、タヴィストック市のある請負師が、病人や、ダートムアの新鮮な空気を楽しみたいという人達をあてこんで建てた別荘風の家が一かたまりあるだけだ。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、そんなことに経験のある請負師が呼ばれて、相談にあづかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負師は困つたやうにいく度か立木のなかを見あるいてゐたが、やがてシユワツブ氏の前へ出て来たをりには、晴々しい顔つきをしてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　請負師はビステキのやうに顔からあぶら汗を流した。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "増築の出来｜栄えが庸三の期待を裏切ったことはもちろんであったが、一旦請負師の要求に応じて少なからぬ金を渡し、貨車で運ばれた建築用材を庭の真中へ積みこまれてしまうと、その用材からしてすでに約束を無視したものだということに気がついていても、今更どうすることもできないのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　請負師はそう言って、金を持って行ったのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この請負師は庸三の懇意にしている骨董屋の近くに、かなり立派な事務所をもっていて、その骨董屋の店で時々顔が合っていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは上州辺の女で、田舎で芸妓をしていた折に、東京から出張っていた土木の請負師に連れ出されて、こっちへ来てから深川の方に囲われていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは、請負師の妾をしているころから、劇しいヒステレーに陥っていたらしく思われた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "工面のよい商人か、請負師とでも一緒になって、姐とか何とか言われて、陽気に日を送っていた方が、どのくらい気が利いてるか知れやしない。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十六　そんな噂がいつか町内へ拡がったところから、縁起を祝うために、鈴木組と云う近所の請負師の親分の家で出た註文を、不意に受けたのが縁で、その男の引立で、家が遽に景気づいて来た。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
