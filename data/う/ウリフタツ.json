    "definitions": [
      {
        "index": 1,
        "gloss": "exactly alike (in appearance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あの娘は年齢から眼鼻立ち、背丈恰好、物腰、声音まで、死んだお熊さんに瓜二つ……と申す仔細は、ほかでも御座んせん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "出世を競り合うて呪咀い合うものと聞いた、蔵元屋の前の御寮さんが、コッソリ里子に遣ったままにして置いた芋屋の娘……正しく蔵元屋の血統を引いた、お熊さん同様の一点の疵もない卵の剥き身、生さぬ仲の芋屋の老人夫婦を真実の親と思い込んでの孝行振りまで、お熊さんと瓜二つの生き写し。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "上品な額や、花車な頤や、さては振分け髪を一束づつ載せた細りとした肩のあたりと云い、瓜二つどころか全く豆と豆との如くと云っても足りない位である。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し高過ぎるくらゐに鼻筋がツンとして、彫刻か、練ものか、眉、口許、はつきりした輪郭と云ひ、第一櫻色の、あの、色艶が、――其が――今の、あの電車の婦人に瓜二つと言つても可い。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗　真に、瓜二つでございますねえ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あなたと瓜二つだ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老い疲れたる帝国大学生、袖口ぼろぼろ、蚊の脛ほどに細長きズボン、鼠いろのスプリングを羽織って、不思議や、若き日のボオドレエルの肖像と瓜二つ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まず都へ上って年を経て、やがて国許へ立帰る侍が、大路の棟の鬼瓦を視めて、故郷に残いて、月日を過ごいた、女房の顔を思出で、絶て久しい可懐さに、あの鬼瓦がその顔に瓜二つじゃと申しての、声を放って泣くという――人は何とも思わねども、学問遊ばし利発な貴女じゃ、言わいでも分りましょう。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まったく、魚じゃ鯔の面色が瓜二つだよ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その顔かたちが、俊子と瓜二つに生長しているんだ。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の息子は、体格と云い容貌と云いまるで瓜二つで、二人とも同じような白い蚊飛白の浴衣を着、同じような黒い錦紗の兵児帯を締めている。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "品のよい鼻、白皙の面、それは自分の介抱を受けながら、横死した青木｜淳と瓜二つの顔だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子供が先生と瓜二つなんですもの。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "コヤツ（私）の眼鼻立ちが中村半太夫と瓜二つになっていることは近所の子守女まで知っていることもあの絵馬堂で初めてきいた。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜二つ　見知らぬさむらいにひっかかえられ、驚いたのは君尾である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お探しなすっているお京様、まだお目つけになれませんので」「これは容易に目つかりますまい」「あの、妾に似ておりますそうで」「下世話にいう瓜二つ」「では、やっぱり妾のように、お美しい方なのでございますのね」「ううん」と広太郎面喰らってしまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「似たとはおろか瓜二つ」などといいますが、よく見れば、どこかきっと違っている所があるのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "品のよい鼻、白皙の面、それは自分の介抱を受けながら、横死した青木淳と瓜二つの顔だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小胡瓜二つ　三銭、中大根一本　四銭。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "外債募集のためアメリカへやって来た何とかいう世界地図にものっていないような弱小国の麗わしい姫が、ニューヨークへついて間もなくオタフク風にとりつかれてしまったので、その身代りを瓜二つな容姿をもった一人の貧乏で悧※な失業女優がつとめて、終りには目出度大新聞の若い社主と結婚するという筋であった。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、いつか鼠坂の心霊実験会で逢い、それからのち、真夜中の銀座裏で突飛な質問を浴せかけたあの神田仁太郎という怪青年に瓜二つの顔だったから。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる頃外を見ても、やっぱりそれと瓜二つなごろた石の山腹が窓をかすめて行く。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまは敏ちやんの寢顏を打戍り乍ら仰有います「圭一郎に瓜二つぢや喃」とか「燒野の雉子、夜の鶴――圭一郎は子供の可愛いといふことを知らんのぢやらうか」とか。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "目鼻立ちは自分に瓜二つでも、心のうちの卑しさを直ぐに見せるやうな、僞りの多い笑顏だけは妻にそつくりだつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―９８０１は松本の目に、ＰＣと瓜二つに見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様はまた、連れて来た二｜匹の馬をごらんになりますと、大きさから毛色まで、瓜二つといってもいいほどよく似た馬で、同じような元気ではねていました。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとキエフや、ガリシヤの土地や、カルパシヤの山地から、自分の顔に瓜二つの死人どもが、うようよと立ちあがるのが見えた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜二つと言っても好かったですから。",
              "citation": {
                "source": "温泉だより",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……眼元なら口元なら、似たとは愚か、チンツンシヤン、瓜二つ……やないか。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共、アルマ、マチラの兄弟は生まれ落ちるとからの双生児で、私の方が後から生まれましたために、今までの習慣に従って、仮りに兄貴と名乗っているにはいるので御座いますが、実は揃いも揃った瓜二つで、声から、眠る時間から、学校の成績から、ネクタイの好みまで、弟のマチラと一分一厘違わない。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
