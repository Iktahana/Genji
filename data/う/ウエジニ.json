        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鳥もけものも、みな飢え死にじゃ人もばたばた倒れたじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を触れるものがみんな黄金になるのでは飢え死にするほかはない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俺がいなかったら、おまえたちは飢え死にをするよりしかたないところだったんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏というものは辛労いもので、妻子が飢え死によるのを見ると気に入らん奴の世話にでもなりとうなるものじゃ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私が言うと、「飢え死に寸前、すっかり忘れていた。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "差し当たっての問題は、ここで僕らは早めの昼食を摂るか、それとも飢え死に覚悟でニューヘイヴン駅構内の軽食堂までたどり着かんとするか。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以下十九字不明）凍死し、飢え死にし、病死し、自殺し、殺戮されることは、その状態なのだ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄上のお恨み晴らさぬうちに飢え死にしてはなりませぬ、と思いまして、思案にくれたあげく」「やまがら使いに身をおとしたと申さるるか」「あい、さようでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう美しい、いじらしい少女を乞食にしておくということが不憫であるばかりでなく、前にもいう通りのお触れが出ている以上、かれは何人の恵みをも受けることが出来なくなって、早く他領へ立退くか、あるいはここでみすみす飢え死にしなければならないのである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつの家じゃあ、みんなを飢え死にさせてしまったのですからね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら困るからって、お前一人ぐらいは飢え死にはさせぬ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "年よりならきッと書きそうな冒頭の文句も何もなしで、いきなり、度々手紙をやったがいつ金を送ってよこすつもりかと書き出し、東京で貴様はどんな偉い運動をやっているか知らんが、こっちでは一家五人が飢え死にしかけている。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "金はあっても売り者がないので、みすみす食物を摂ることが出来ず、錦の衣裳を纒ったまま飢え死にをした能役者もあった。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれを断れば、悪魔の子はきっと飢え死にか凍え死にかするに違いありません。",
              "citation": {
                "source": "天下一の馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢え死にしかけた事もありますし、山中で盗賊に襲われたこともありますよ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達を飢え死にさせるつもりなら、それでいいよ！",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ貰うもんか、飢え死にしたって貰やしない。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉に老友が答えて、奥さん我々は来年の春から夏へかけて、餓死するであろうというのであるから、遅くも田植え頃までには一家親族が飢え死に、死に絶えるかも知れません。",
              "citation": {
                "source": "岡ふぐ談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、私はこの炭焼夫婦だけは飢え死にさせず、末永く夢を実現した美しい人として生かして置きたいと思う。",
              "citation": {
                "source": "猿ヶ京",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくその多数は飢え死に凍え死にするか、あるいはひと思いに自殺でもしたでありましょうが、幸いに生き残ったものでも、腹が減っても喰うものがなく、寒くても着るものがなく、さりとて働こうにも仕事がないとあったらどうでしょう。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて多数のものは飢え死にしましょうが、一方には掠奪が始まりましょう。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のヒステリックな言動や、蔑むような冷やかな、奇怪ともなんとも不可解な視線を投げつけられたら、以前の彼女なら泣きもしたろう、怨みもしたろう、出て行きますとか飢え死に死んじまうとか脅し文句も並べたろう。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでとうとう観世様を、妾達仲間の掟通りに、空洞内の土牢へ入れ、飢え死にさせることにいたしました。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもはもう、好皮子一つ口にせず、敵に殺されるより先に、飢え死にしそうでございます。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに空中に行った人間は五万人からあるというが、みな空中で飢え死にして、死骸がぼたぼたと天から落ちて来るというが、事実相違はあるまいなア！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした犬は、酷使の代償に、ただ棒で殴られるか、ののしられるばかりで、そのあげく、飢え死にでも凍え死にでも勝手にしろ、とばかりに車から蹴り出され、やっと車からはずしてもらえるのでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、パトラッシュ以外、誰一人、ネロがひとりぼっちでみじめに飢え死にしようとしていたことを知らなかったのでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人いれば飢え死にはしない。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "サント・ドミンゴにおいては、インディアンはその残酷な圧制者を飢え死にさせるために、故意にその土地の耕作を放棄した３）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、孔子が門人たちと共に天下を巡歴して、陳の国と蔡の国の国境近くを通っていた時、無道の人たちに囲まれ、糧食を断たれて飢え死にしそうになったことがありました。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
