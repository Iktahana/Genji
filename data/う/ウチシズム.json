          ],
          "literary": [
            {
              "text": "私の胸は飽くまで弱々しく打ち沈むばかりであつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十七日の対話以来、妻はＯの話が出る度に打ち沈むやうに見える。",
              "citation": {
                "source": "嫉妬する夫の手記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそうなって、真実その艇長が、フォン・エッセンだとしたら、自分が自分を指摘されたところで、なにもそう、暗い気分に打ち沈むことはなかろうと思われます。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
