  {
    "uuid": "094765d2-1e1c-5724-a462-73acc426db21",
    "entry": "討つ",
    "reading": {
      "primary": "うつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "Godan verb with 'tsu' ending",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to attack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こゝへ奉公住みして足かけ三月のあひだに、討つべき隙はなかつたか。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみの　討つべきこゝろも鈍つたか。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之介　たとひ佐々木殿を討つたとて、死んだ父さまが返りませうか。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたきは妾ひとりで見事に討つてみせう。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "工藤は親のかたきを討つつもりで、伊東祐親の父子を射させたのである。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の仇は必ず討つと、彼は曩の日お杉に誓ったのである。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、母の死際に着てゐた小袖が証拠になつて、不思議にも隣の家の主人がその盗人であることが判つたので、かれは自分の主人の助太刀をかりて、母のかたきを討つた。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子が成人して母のかたきを討つたのは何うであらうか。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はばニイチェは、師匠の仇敵を討つた勇士のやうなものである。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふわけで、その弟は仇敵を討つための旅をしてゐたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、仇敵を討つための道具をどうして手離すことが出来よう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あなたは今仇敵を討つと仰有いました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵を討つといふのは人を殺すことでせう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虱でさへも仇敵を討つために、やせさらぼうて生きてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇敵を討つ筈だつた人が討つのをやめて、仇敵の家を出てゆきながら、自分はいいことをしたと思つて涙をこぼした、といふことをきいた時、栄蔵もつい貰ひ泣きをした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十五日官軍東叡山を囲みて彰義隊を討つ。",
              "citation": {
                "source": "能久親王年譜",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その讐仇を討つのに……邪魔に……邪魔になるのは貴方一人……」「……エエッ……さてはおのれ……」「お覚悟ッ……」　という必死の叫びが、絹を裂くように庭先に流れた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "只晴賢と戦争するについて、主君の為に晴賢の無道を討つという看板を掲げ、名分を正したに過ぎない。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年時代厳島に詣で、家臣が「君を中国の主になさしめ給え」と祈ったというのを笑って「何故、日本の主にならせ給えとは祈らぬぞ」と云った程の男だから、主君の仇を討つということなどよりも、陶を滅して、我取って代らんという雄志大略の方が強かったのである。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり鼓も博奕も共に打つものであるから、敵を討つということに縁起をかついだものである。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、織田の長臣柴田｜修理亮勝家は、上杉景勝を討つべく、佐々｜内蔵助成政、前田又左衛門利家、佐久間｜玄蕃允盛政、及び養子伊賀守勝豊以下を率いて、越中魚津に在陣中であった。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明くれば天正十一年正月、秀吉、かの滝川一益を伊勢に討つべく、大軍を発した。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗徒勢を討つこと三百人余であった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は、一度は生駒山に逃れ給うたが、「自分は今、兵を起して入鹿を討つならば勝てるだらうが、一身のため、人民を傷つけたくない。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天正十二年には、秀吉は統一の功を急ぐために徳川家康と同盟し、一方では長曾我部｜元親を降して四国を平げ、上杉｜景勝と和して北国を定め、島津｜義久を討つて九州を従へた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖国　秀吉の朝鮮出兵は、朝鮮を討つためではなくて、大明国を征するのが目的であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶対に、警部、あなたにはわかるでしょう、その盾は守りきれなかったが、正義の剣の方は、まだ仇を討つためにそこにあるということが。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾領主に凌辱の限りを盡した、日置忍男に對する憤恨を晴す道なく、罪なき、公等と知るも、公等を討つて憤を漏らすの餘儀なき今宵である。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "長平は無論に死罪でしたが、長吉の方はまだ子供でもあり、どこまでも親のかたきを討つつもりでやった仕事ですから、上にも御憐愍の沙汰があって、遠島ということで落着しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつらと僕はする……風もある……松林を透いて空が見えるうつらうつらと僕はする。",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
