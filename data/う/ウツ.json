    "definitions": [
      {
        "index": 1,
        "gloss": "to shoot (a gun, person, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "靈智萩原朔太郎ふるへる、微光のよるに、いつぱつ、ぴすとるを撃つ、遠方に、金の山脈、かすかな、黒曜石の發光。",
              "citation": {
                "source": "靈智",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば西洋の惡魔が、日本では鬼や天狗の類となるし、昔の童話に出る武者修業の豪傑が、今日の新しい童話では、飛行機に乘つて機關銃を撃つたりするところの、科學的武裝をした日の丸太郎の類に變るのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎は、ふんと笑つて狸の泥舟を兎の舟につないで、それから、櫂でぱちやと水の面を撃つ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒服の支那人が、室内で、左の肘を水平に曲げ、拳銃をその上にすえて、ねらって撃つ真似をしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何を撃つのか、目標は見えなかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち杜はしずかになって、ただおびえて脚をふみはずした若い水兵が、びっくりして眼をさまして、があと一発、ねぼけ声の大砲を撃つだけでした。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵船右より襲へば右舷の速射砲之を追ひ、賊船左より來れば左舷の機關砲之を撃つ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち杜はしづかになつて、たゞおびえて脚をふみはづした若い水兵が、びつくりして眼をさまして、があと一発、ねぼけ声の大砲を撃つだけでした。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王鎧どんなものだと云つて、是を石崇に示すや、石崇一笑して鐵如意を以て撃つて碎く。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾と頭を以つて撃つた炎の大蛇は、黒蛇に變じて剩へ胴中を蜿らして家々を卷きはじめたのである。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを待受けて囲み撃つという計略であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "守ること固きものは誘うて之を撃つ、我が塚田巡査は孫子の兵法を心得ていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "撃ってもクシャミをしながら撃つのですから、弾丸はとんでもない方へ行ってしまいます。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男を撃つより先に、やはりこの女と、私は憎しみをもって勝敗を決しよう。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲を撃つわたしはびらびらした外套をきて草むらの中から大砲を曳きだしてゐる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああエルサレム、エルサレム、予言者たちを殺し、遣されたる人々を石にて撃つ者よ、牝鶏のその雛を翼の下に集むるごとく、我なんじの子どもを集めんと為しこと幾度ぞや」という所まで読んで、思わず声を挙げて泣いたあの夜を、忘れたか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴしゃと小さい音が聞えるほど強く菊代はその野中の掌を撃つ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち高ぶること莫からんために我を撃つサタンの使なり。",
              "citation": {
                "source": "パウロの混乱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキ細工の雀が時計の振子のように左右に動いているのを、小さい鉛の弾で撃つのだ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸将之を撃つを難んず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣鋒折れ欠けて、撃つに堪えざるに至る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱能、周長等、王の急を見、韃靼騎兵を縦って庸の軍の東北角を撃つ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王壮士万人を分ちて敵の援兵を遮らしめ、子｜高煦をして兵を林間に伏せ、敵戦いて疲れなば出でゝ撃つべしと命じ、躬ずから師を率いて逆え戦い、騎兵を両翼と為す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大日本史や、記に「将門撃つて三千人を殺す」とあるのは大袈裟過ぎるやうだが、敵将維幾を生捕りにし、官の印鑰を奪ひ、財宝を多く奪ひ、営舎を焚き、凱歌を挙げて、二十九日に豊田郡の鎌輪、即ち今の鎌庭に帰つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近い例を擧げようならば、人試みに直立して胸を張り拳を固め頭を擡げ視を正しくして、横綱が土俵入りをして雄視するやうな姿勢を取り、そして兩手を動かすこと數分時、或は上下し、或は屈伸し、或は撃つが如くし、或は攫するが如くして、任意に力を用ふれば、忽にして身暖く筋張るを覺ゆるであらう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その言葉が、助七を撃つた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああエルサレム、エルサレム、予言者たちを殺し、遣されたる人々を石にて撃つ者よ、牝鶏のその雛を翼の下に集むるごとく、我なんじの子らを集めんと為しこと幾度ぞや、然れど、汝らは好まざりき」馬鹿なことです。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンパンと電線をねらって撃つと、電線は一本ずつプツンプツンと切れるんだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつらと僕はする……風もある……松林を透いて空が見えるうつらうつらと僕はする。",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
