        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鳥や鼠や猫の死骸が、道ばたや縁の下にころがっていると、またたく間に蛆が繁殖して腐肉の最後の一｜片まできれいにしゃぶりつくして白骨と羽毛のみを残す。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十二月二十九日『東京朝日新聞』）　　　　　　　　　五十七　　　　　　婦人と動物学者　テキサス大学のモントゴメリー教授は、衣服その他の粧飾に鳥類の羽毛を使用する事を絶対的に禁じたいと論じている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の捕獲が盛んになればますます羽毛が安くなり使用高が次第に増して結局は鳥の種類が絶えるようになるだろうと云っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれも天然の設計に成る鳥獣の羽毛の機構を学んで得たインジェニュイティーであろうと想像される。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その剣は、豚を突殺すのに使ったり、素裸体に羽毛をむしり取った鵞鳥の胸をたち割るのに使って錆させたのだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また壁と壁の支えあげている天井との間のわずかの隙間からは、夜になると星も見えたし、桜の花片だって散り込んで来ないことはなかったし、ときには懸巣の美しい色の羽毛がそこから散り込んで来ることさえあった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、突然の暴行の後に釈放された白い母鳥も、ほんのちょっとばかり取り乱した羽毛をくちばしでかいつくろって、心ばかりの身じまいをしただけで、もう何事もなかったように、これも瞬間の驚きから回復したらしい十羽のひなを引率してしずしずと池の反対の側へ泳いで行くのであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の酷寒には水滴の代わりに美しい羽毛状の氷の結晶模様ができる。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥やねずみや猫の死骸が道ばたや縁の下にころがっているとまたたく間にうじが繁殖して腐肉の最後の一片まできれいにしゃぶり尽くして白骨と羽毛のみを残す。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い柔らかい鶏の羽毛を拇指の頭ぐらいの大きさに束ねてそれに細い篠竹の軸をつけたもので、軸の両端にちょっとした漆の輪がかいてあったような気がする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽毛のようでなく、鳥のように軽くなければいけない、とその本に書いてあるぜ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝燕は、今日こそはしたわしいナイル川に一日も早く帰ろうと思って羽毛をつくろって羽ばたきをいたしますとまた王子がおよびになります。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細長い痩せた体をふくよかに包むお祖母さんの被布の、何とかいう白茶地には、真白な鳥の羽毛が、ふさふさと織り込まれて居るのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よい、よい、よい」という具合いにお祖母さんが歩くと、お祖母さんの体一ぱいの羽毛が、同じ調子で、「ふわ、ふわ、ふわ」と揺れるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは鶴の羽毛であるとかやは教えられてからこの羽毛を着けて居た鶴を想像するふしぎな快感とお祖母さんの「他所ゆき」というかすかな好奇心が交って、夢の様なぼっとした気持で、この被布の姿のお祖母さんを見るのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……青く錆びたわたしを掛けて、鉄漿壺を載せ、羽毛楊枝が渡してある。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中、ねうちものは、毛卷におしどりの羽毛を加工するが、河蝉の羽は、職人のもつとも欲するところ、特に、あの胸毛の火の燃ゆる緋は、魔の如く魚を寄せる、といつて價を選ばないさうである。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の重さ、とでも言おうか、生命の渋さ、とでも言おうか、そのような充実感は少しも無く、それこそ、鳥のようではなく、羽毛のように軽く、ただ白紙一枚、そうして、笑っている。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らの上官たちは、頭に羽毛のついた帽子を被り、陣営の中で阿片を吸っていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい白鳥が羽搏いて過ぎるときに、落してゆく羽毛ほどだつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がもしそれを持ったなら、まるで、変り羽毛の雛鳥のように、それを持たない世間から寄って蝟って突き苛められてしまうではないか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまもなくおすのおしどりのかたわらに、やや小さいめすのおしどりが、くちばしでおのれの羽毛をととのえながらよりそっていた。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スランプトハ、コノ様ナ、パッション消エタル白日ノ下ノ倦怠、真空管ノ中ノ重サ失ッタ羽毛、ナカナカ、ヤリキレヌモノデアル。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そこでじゃがや、姉めが乳の下の鳩落な、蝮指の蒼い爪で、ぎりぎりと錐を揉んで、白い手足をもがもがと、黒髪を煽って悶えるのを見て、鳥ならば活きながら、羽毛を※った処よの。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡の花田は烏の羽毛を毟しってしまって俎の上で肉を叩きにかけていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときかの女は羽毛のように軽くなってその人に添った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は空に湧く白い粉雪の一片一片を今生れたばかりの活きた羽虫の一匹一匹として喜び、大人は死んだ鵝鳥のそのむしり散らした羽毛の一片一片に譬へて観賞します。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "駝鳥の卵や羽毛、羽扇、藁細工のかご、貝や珊瑚の首飾り、かもしかの角、鱶の顎骨などで、いずれも相当に高い値段である。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは稍静かなれど紅塵ようやく深く鉄道構内の煤煙風に迷うもうるさし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人がその青い粘土も持って来たのでしたが、蹄の痕があんまり深過ぎるので、どうもうまくいきませんでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
