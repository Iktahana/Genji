        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "頬杖ついて、うっそりしている。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――これではいかに伝六がうっそりといえども、はっきりと右門のいぶかしかった今までの行動が読めたものでしたから、額をたたかんばかりにしていいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくよくまた、うっそりもあったものじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "手間と金をかけたんだから」　五人が、ワラの調達したスイカを食べ、テープをさかなにして、なごやかにコーヒーを飲んでいるところに、なにやら袋をかかえて、山崎がうっそりとあらわれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "といいたげな、いかさま大胆沈着・傍若無人の不敵な空気が、世慣れたこなしとともにうっそりと漂っているんだから、瞬間にして、私は思った。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は大河です」「僕は乙彦だよ」彼はうっそり笑った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やい、ここなうっそりどもめ。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うっそり者の狂人め！",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだと困るね」　芳本は日増に不快と焦燥の念に悩まされて、暗い顔してうっそりかまえている耕吉に、毎日のようにこんなことを言いだした。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うよりも妻の方で、うっそり者のこの私を、一人でやるのが不安だったらしい。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北番所の例繰方で、奉行の下にいて刑律や判例をしらべる役だが、ろくろく出勤もせず、番所から持ち出した例帳や捕物控などを読みちらしたり、うっそりと顎を撫でたりして日をくらしている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は、うっそりと懐手をして突っ立ったまま草履を眺めていたが、それを手にとって素早く表裏へ眼を走らせると、無造作に地べたに投げ出す。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は懐手をしながら、まだいぶりかえっている焼跡をうっそりと眺めていたが、黒焦げになった死骸を見ると、連れの遊び人のほうへふりかえって、「これは、焼け死んだのじゃねえ、だれかが殺してから、火の中へ投げこんだのだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "……嘉兵衛と鶴吉を虎列剌と判定てうっそり帰って来たのは、いってえどいつだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "ねずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は、吹屋のトバ口に立って、うっそりと眺めていたが、ひょろ松のほうへ振りかえって、「ああして捏たり延したりしているところを見ると、まるで餅屋だな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏と鳶　松平越前の脇門を出ると、顎十郎は、手にからす凧と糸巻を持って、うっそりと常盤橋を渡りかける。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿げた長い顎をつンのばして、うっそりと浮木を眺めている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "丹頂の鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさのおどろきから立ちなおって、すぐに泰軒へ目を返した月輪組は、いつのまに奪ったものか、そこに見覚えのある左馬の愛刀を抜きさげて、半眼をうっそりと突っ立っている乞食先生のすがたを見いださなければならなかった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで雨乞いでもするような恰好で、うっそりと腰をかけているのが、顎十郎。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蕃拉布",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんともむず痒い気持で、うっそりと腰元の顔をながめていると、このとき腰元は、手の甲を口にあてて、ほほほと艶に笑った。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにうっそりの顎十郎も、多少の感慨があるらしい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は、揚屋格子のほうをうっそりと眺めながら、「あの陽ざしの工合では、もう辰の刻。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにうっそりなお姫さまでも、そぎゃん愚なことをするはずはありまッせん。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田氏は、不得要領な顔で、うっそりと口髭を撫でていたが、「さて」と曖昧なことをいいながら、自分の布団を担いで、南側の洋館のある一郭のほうへ出て行った。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田氏は口髯を撫でながら、うっそりと見おろしていたが、「気ちがいのつぎが、捨児か……すこし、授かりものが多すぎるようだな」　と、わけのわからないことをつぶやいた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんなら、犬ころのように飛びついて来て、おおはしゃぎにはしゃぐところなのに、ひとりずつ窓際の椅子にかけて、うっそりとうつむいている。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の禿げた、悲しげな顔をした馬は、いかにもひだるそうに、力なく横腹に波うたせながら、首を垂れ、うっそりと眼をとじている。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は焦れ切っていたところだったのでいきなり、「貴様、狭山か」と声をかけたが、こちらを見ながら、うっそりとしているばかりで返事もしない。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだひとにすまないから」　聞いているのかいないのか、真名古はうっそりと腕を組んで何か考えているようだったが、やがてモゾモゾと上衣の衣嚢をさぐって、鼻紙といっしょにつぶれかかった板チョコレートを取り出して花のほうへ差出し、「一つおあがり」　花はキッと口を結んで、「あたしを子供だと思ってるのね。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア、掛けなさい、立っていないで」　真名古はうっそりと椅子に掛けると、「お申付けの調査は内訓の通りに只今果しました。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
