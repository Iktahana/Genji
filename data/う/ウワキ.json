        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だつて君そこに浮気があります浮気は悲しい音楽をヒヨツと忘れさせること度々です空　空　空やつぱり壁は土で造つたものでした。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」は恋の束縛に超越した自由なる浮気心でなければならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋と云はれて浮いた同士」が「つひ岡惚の浮気から」いつしか恬淡洒脱の心を失って行った場合には「またいとしさが弥増して、深く鳴子の野暮らしい」ことを託たねばならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蓮の浮気は一寸惚れ」という時は未だ「いき」の領域にいた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人ごとに、我が身にうとき事をのみぞこのめる」云々の条は、まことに自分のような浮気ものへのよい誡めであって、これは相当に耳が痛い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――………浮気しよって？",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――……うん、浮気しよった！",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮気ものにインターナショナルの戦勝盃を与えて、お前涙もろい女、近代主義の楽天家、お前が私を愛する心、俺のためには死をも辞せない。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜ルーマニア人が浮気の虫を……におろしに行った間、「――おい、Ｙ、今晩はおれにつきあえよ――」　と、貴女が云ったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私はまた、浮気な貴女を愛することは禁断道路を歩むよりも一層困難に思うのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アダ、貴女の浮気の虫はいつまでたってもなおらない。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の建物の死面に女達は浮気な影をうつして、唇の封臘をとると一人の女が青褪めた朋輩に話しかけた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の浮気な釦穴が、多数の男性によってつくられた鋳型のように、慇懃に籐椅子にもたれていた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女の夫の田村英介氏は才能あるにもかかわらず不幸にしてまだ無名の文士ではあったが、スマ子女史がつねに「彼氏浮気もの」と称しているだけになか／＼各方面に発展してスマ子女史に愉快な煩悶をときどき提供するのであった。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときスマ子女史は、彼女の「彼氏浮気もの」を待つあいだを英語の勉強をしたり寝台のうえで体操をしたり日本の作家の有名な小説を読んだりしているが「彼氏浮気もの」が、にこ／＼わらいながらかえってくれば、悦しくなって、なにしろ彼は可愛いいので、だがすこしばかり眼に涙をためて、――おかえり！",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、浮気の道を封ずることは男の特権だからな。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　田村スマ子女史が眼覚めると、隣室で仕事をしていた「彼氏浮気もの」が、――やあ、お眼ざめですか、親愛な女史よ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのまにかスマ子女史の「彼氏浮気もの」は階下の電話口にやってきて四家フユ子を呼びだした。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤さんは浮気者だから、ここの家へ来るなんて旨いことを云って、どっかへしけ込んでいるんじゃありませんかえ」と、お新は笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちのような浮気参りもあるんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "無暗に食い散らしをするような浮気者じゃあるめえね」「それがどうも判りませんの」と、お登久は妬ましそうに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもあいつが浮気もので、ちょいと色に迷ったばかり、おいやならよしなさい、よそを聞いてみますという、お手軽なところだと、おれも承知をしたかもしれんが、どうしておれが探ってみると、義延（巡査の名）という男はそんな男と男が違う。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の述ぶるところによれば、いかにも女の客の多かったのは事実であるが、向こうだけのかってなうわきからで、うちの若主人にかぎっては、かつて一度も女との浮いたうわさなどを聞かなかったというのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なぞとたいへんな騒ぎで、場内はもうわきかえるばかり――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ある機械などは共同で買つて共同作業するやうにせよともいはれるが、田圃での共同作業といふものはさうわきから考へるやうにすらすらとやれるものではない。",
              "citation": {
                "source": "東旭川村にて",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "死なれる前ごろ、私が行くと、「もうわきまえてはいます」　と言葉少なく訴えられた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼女等のあいだに謂ゆる『うわき』をするというようなことがあったとしても、それはごく内密に行われたので、事実は、少しも外部に漏れず、相変らず猫｜魚くわぬ顔で澄ましていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくば、大奥へ、ふたたび、追いやられねばならぬおからだでござるぞ――な、そこを、ようわきまえて――拙者、くだくだしゅうは言わぬ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "初瀬はあのお山の向うわきになつてます。",
              "citation": {
                "source": "斑鳩物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐れ入り奉りまする――なれど、いっこうわきまえませぬ」　すると吉宗、何を思ったか、いきなり及び腰に自ら扇子で御簾をはねると、ぬっと顔を突き出した。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
