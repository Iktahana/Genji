        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "過去よながいながい孤獨の影よその影を岩にひきずる冬の日の薄暗い濱邊に立つて意味のふかい人生を見る。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の十一時、不意の自動車、薄暗い電氣、細長い五本の指、死後の生活の話、ふり亂した長髮、蒼ざめた病身の顏、影のやうに消えた後姿。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」妹は、夕闇の迫った薄暗い部屋の中で、白く美しく笑って、「ねえさん、あたし、この手紙読んだの。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は馬場とふたり、本郷の薄暗いおでんやで酒を呑んだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の夏に特有な、梅雨時の暗い天気と、畳の上にカビが生えるような、じめじめした湿気と、そうした季節に、そうした薄暗い家の中で、陰影深く生活している人間の心境とが、句の表象する言葉の外周に書きこまれている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良という侘しい古都に、薄暗い古道具屋の並んだ場末を考えるだけで寂しいのに、秋の薄暮の灯ともし頃、宵の燈火の黄色い光をイメージすると、一層情趣が侘しくなり、心の古い故郷に思慕する、或る種の切ないノスタルジアを感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの新日本的の那須野と対照して、那須温泉そのものの薄暗い感じを思ふのは不快である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣装にすれば色彩の鮮明な、白とか、青とか、水色とかいつたやうなものが好く、建築にすれば、感じの薄暗い田舎風の家より、明るい西洋建築や、軽快な都会風の家屋が好い。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗いランプの光で寒竹の皮をむきながら美しい絵を思い浮べて、淋しい母の横顔を見ていたら急に心細いような気が胸に吹き入って睫毛に涙がにじんだ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い狭い路地のような町をゾロゾロ歩いている人通りを見ただけでああた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い廊下のドアを開けて、室へはいると世の中が明るい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして黒光りのする台所の板間で、薄暗い石油ランプの燈下で一つ一つ皮を剥いでいる。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い湿っぽい朽葉の匂のする茂みの奥に大きな虎杖を見付けて折取るときの喜びは都会の児等の夢にも知らない、田園の自然児にのみ許された幸福であろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは毎日一日役所の殺風景な薄暗い部屋にのみ籠っているし、日曜と云っても余計な調べ物や内職の飜訳などに追われて、こんな事を考えた事も少ないが、病んで寝てみると、急に戸外のうららかな光が恋しくて胸をくすぐられるようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と旦那は怒り、ぎよろりと妻子を睨んですつくと立ち上り、奧の薄暗い部屋に退却して、そつと鏡を覗き、がつかりして、「これは、駄目だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れてくると、この薄暗いのが、何とも言へずやはらかく心を休めてくれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一体どうするのが、俺には一番いいのだろう）　彼は、暑さにジタバタする子供の寝顔を、薄暗い陰気な電燈の光に眺めた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "わやわやと騒がしい家の中は薄暗い。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の先七八間の所は木の蔭で薄暗いがそれから向うは畑一ぱいに月がさして、蕎麦の花が際立って白い。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "這入った処は薄暗い桟敷のような処で、それに一杯に人が居るようであった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬近い夜の風が、薄暗いプラツトホームを吹き渡つてゐた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで或る街の深夜に、ぐでぐでに醉つて死場所を探してゐる不幸な紳士が、場末の薄暗い地下室で、チャップリンの扮してゐる乞食ルンペンと邂逅する。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その跡には、薄暗いベンチから身を起して、喪服を着た数人の婦人が続いた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "半盲になつてゐる目が、薄暗い食堂の中の物を見分けるまでには、余程暇が掛かる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月頃の薄暗い天気の日に、十一時頃になっても光線が足りない時なんぞは、どんなにか気を揉んだものだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まだその内に居殘つてゐた者たちは、ときどきこつそりと、部屋の中央にある、大きな、薄暗い塊りへ眼をそそぎながら、それが單に腐敗物の上に被せられてゐる大きな衣類に過ぎないことを望んでゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處から私の泊つてゐるＭホテルまではまだ七八町の道程だつたが、送らうといふ水島君の詞を強ひて斷つて、薄暗い並木の蔭を私は一人俯向き勝ちに歩き始めた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其處よ……」　頷いて、薄暗い明りの下ながら、私はその刹那に初めて女の顏を眞面に見詰めた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが單調で薄暗いやうなそのあたりの景色が私を倦きさせた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の隅田川岸と言へば自分の記憶にもぼんやり浮ぶが、低い家の立ち並んだ薄暗い泥の道、晩秋のうそ寒い川風の中をトボトボと辿り行くであらう寂しい葬送行進曲！",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
