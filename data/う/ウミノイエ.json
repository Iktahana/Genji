        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だがいつかの熱海の家は、借金の形に取られてしまつたといふ話ぢやないか。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "金を寿海の家に齎した「坂の若先生」とは誰か。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於て壬子九月に榛軒が勧進帳を観、十月若くは十一月初に塩田、矢島が寿海の家を訪うたことが明なるに至つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本から近ければ、海の家だとか云うて皆遊びに来ればすてきなんだが、遠いのでしかたが無い。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "無間地獄　這々の体で逃げ出した私は、さすがに追跡が恐しくなって、その夜は鳴海の家を叩いて、泊めて貰った。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスでは海に行くと、かならず砂はまにたくさん車輪のついた箱がたの着がえ部屋があってね、子どもたちは木のくま手で砂をほじっていて、あとはずらり海の家にその後ろが線路の駅。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに海の家という屋号の店があった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "見晴らし台まで上がり、海の家の前を歩いて停留所までいった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家がここには二軒あった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家には、シャワー・着替え、という看板が出ていた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "土手には海の家がびっしりとならんでいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家はどれもみな盛業中であり、海岸の人出は亜紀子や裕一の気持ちを浮き立たすのにちょうどよかった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の時間がゆったりと経過していき、海の家のござの上で、ふたりは昼寝までした。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家の人たちは、どうするのかしら」「店を閉じて引き上げるだろう」「そうね」「誰もいなくなるよ」「それが私の夢だったの」　気持ちをこめてそう言い、亜紀子は裕一にむきなおった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一日ずっと海岸にいて、夕方になって人が少なくなり、夜が来てほとんど人がいなくなって、海の家は閉じて明かりが消え、ついには自分だけになった海岸に、自分だけはまだいるの」「夢？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロッカーを借りた海の家へ引きかえし、熱いシャワーを浴びて体と髪を洗った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅くまで開いている海の家が何軒かあり、そのうちのひとつで、亜紀子は熱い紅茶を飲んだ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家の明かりがすべて消えた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうまで長く続いているそのスペースの海側には、今年の営業をとっくに終えた海の家が、窓を板でふさぎ、軒を接して何軒もならんでいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏にはどの海の家も満員となり、駐車場は自動車で身動きがとれなくなる。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいないそのスペースを斜めに歩き、海の家のあいだをとおり、邦子は海岸に出た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "連なっている無人の海の家の前を、ひとりで歩いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家の列を前にして、自動車がいまは一台も停まっていない広い駐車場のなかを、海にむけて斜めに歩いていく少年をひとり、邦子は見た。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の家の、赤や青のペイント。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坂の秀吉か、東海の家康か。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
