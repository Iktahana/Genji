        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "交通がうっ滞して進まない。",
              "source": "幻辞"
            },
            {
              "text": "道路の工事でうっ滞が生じている。",
              "source": "幻辞"
            },
            {
              "text": "朝の通勤ラッシュでうっ滞が起きる。",
              "source": "幻辞"
            },
            {
              "text": "血流のうっ滞は健康に悪い。",
              "source": "幻辞"
            },
            {
              "text": "駅の改札でうっ滞が生じた。",
              "source": "幻辞"
            },
            {
              "text": "業務のうっ滞を解決するために対策を講じた。",
              "source": "幻辞"
            },
            {
              "text": "積書類のうっ滞を片付ける必要があ。",
              "source": "幻辞"
            },
            {
              "text": "工事による交通のうっ滞が予想される。",
              "source": "幻辞"
            },
            {
              "text": "高速道路のうっ滞情報をチェックしている。",
              "source": "幻辞"
            },
            {
              "text": "消化器官のうっ滞は便秘の原因になる。",
              "source": "幻辞"
            },
            {
              "text": "リンパ液のうっ滞を解消するマッサージをした。",
              "source": "幻辞"
            },
            {
              "text": "郵便物のうっ滞でお待たせしました。",
              "source": "幻辞"
            },
            {
              "text": "承認プロセスのうっ滞を解決する。",
              "source": "幻辞"
            },
            {
              "text": "港での物資のうっ滞を防ぎたい。",
              "source": "幻辞"
            },
            {
              "text": "通関手続きのうっ滞が問題になっている。",
              "source": "幻辞"
            },
            {
              "text": "都市部での水のうっ滞は浸水につながる。",
              "source": "幻辞"
            },
            {
              "text": "静脈のうっ滞が血栓を形成する危険性がある。",
              "source": "幻辞"
            },
            {
              "text": "商品流通のうっ滞でお客様にご迷惑をおかけしました。",
              "source": "幻辞"
            },
            {
              "text": "うっ滞の原因を分析して対策を講じた。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
