[
  {
    "uuid": "ed902ac3-7c6c-5573-b332-3d5ca2103e00",
    "entry": "上手い",
    "reading": {
      "primary": "うまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "skillful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（ああ、身震がするほど上手い、あやかるように拝んで来な、それ、お賽銭をあげる気で。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と相手の笛の上手いことをほめた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　――踊が上手い、声もよし、三味線はおもて芸、下方も、笛まで出来る。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズが自分の感情を隠すのが上手いとはいえ、私には興奮を抑えつけていることが容易にわかったし、私の方も嬉しくて心躍るのだが、その半分は冒険のため、もう半分は謎のためで、ホームズの捜査に加わるときにはいつも感じるのだった。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿部だけは、地主やその手先の役場の、とても上手い奸策だと云った。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "華美でエキゾチックで、ロマンチシズムの真骨頂のような作家的なゴーチェの文章を、バルザックが単純に上手いと感歎したというところにも、まざまざとバルザックが美の内容について錯雑した感受性をもっていたことが覗われるのである。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡倉氏の説明するところはなかなか上手いので、私に嫌といわさないように話しを運んでいられる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "真似が上手ければ上手いほど可笑しい。",
              "citation": {
                "source": "茶色っぽい町",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに農民らしい、一言きいて多くのことが分るような上手い言葉なんてものは、一つもこの小説の中にはない。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房さん確かりした男らしい人がすきなんだわね、鈴木さん、弓が上手いんですって」「やめて頂戴よ」　房は片腹痛く苦笑した。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上手いな」「……ええもん見せたげまひょか」　手提袋から、彼女は手帖を一つ出した。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この技師は俳句も上手いが、優秀な豪い技師ですよ。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「塩野君なんか、あれでサロンの技術は上手いんですかね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子さんはなかなか云い方が上手いや。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたところが下のホールに高さんという中国人ね、ほら、船の中で二等にいたダンスの上手い中国人がいたじゃないか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこのベンチの置き方も上手いですよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番操縦の上手い顔の緊った美しい青年は、悠悠とひとり遠方を廻って来ては、急ピッチでいつも真紀子の横腹へ突入して来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何か久慈は云いたそうに薄笑いを泛べてから、ふと翻るおもむきで、「じゃ、僕の方が写真上手いぞ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日見てると、浅右衛門の手つきなかなか上手いよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年をへし糸の紊れの苦しさにという、安倍貞任の歌があるが、あなたも、さアどうかしらなど云うところを見ると、貞任みたいになかなか歌が上手いなア。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡太郎は矢で狙っても、歌が上手いといのちを救うんだからね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうそう、相当にこの人の俳句も上手いのがあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とやったんです」　詰襟服を着た少年の尾野が、「この頃は犬の鳴声の素敵に上手い奴もいるってネ」　そう云いながら、パン菓子へ手をのばし、一どきに三つ四つ掌へ握りとって食べている。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは、みんなこんな工合に、俺が繕ってやる」　「上手いもんだね」　「そうとも、お針だって料理だって、出来ないものはないよ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからは、みんなこんな工合に、俺が繕ってやる」「上手いもんだね」「そうとも、お針だって料理だって、出来ないものはないよ。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は、まだ黒吉と同じように、十位だったが、顔は綺麗だし、芸は上手いし、自由な小鳥のように朗らかで、あの気六ヶ敷い団長にすら、この上もなく可愛がられていたから、この陰惨な曲馬団の中でも、彼女だけは、充分幸福なように見えた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何さ、一体……呼んでおいてサ」「葉ちゃん……葉ちゃんは、やっぱり上手いね」　黒吉は、考えてもいない言葉が、急に口から転げ出て、ハッとした。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薗道由子は葉子と親しくはしていたが、彼女ほど美貌でもなく、又、芸の方も、目立って上手いというほどではないので、葉子のみを考えていた黒吉とは、自然、没交渉だったのだが、葉子というものを、改めて見直さなければならなくなった今、由子の登場は、黒吉の心に、何等かの波瀾を起すのではないか、と思われた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそれらの小説を讀んで上手いとも下手いとも決める事が出來なかつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "先生の忠告",
                "note": "青空文庫"
              }
            },
            {
              "text": "オール、もっと上手いと思って居たのにうまく動かず。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
