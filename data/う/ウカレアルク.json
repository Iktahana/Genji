        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "じゃ、伝六ッ、辰ッ、おおかたふたりで池ノ瑞でも浮かれ歩くつもりにちげえねえから、見失わねえようにすぐあとをつけろ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえにこそ、花のたよりも上野、品川、道灌山からとうに八百八町を訪れつくして、夜桜探りの行きか帰りか、浮かれ歩く人の姿が魔像のような影をひきながら、町は今が人出の盛りでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之、識る人も識らぬ人も醉うては無禮講の風俗をかしく、朱欒の實のかげに幼兒と獨樂を囘はし、戸ごとに酒をたづねては浮かれ歩く。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば「人生は楽しいものだ」と云つて浮かれ歩く手合に、それほど同感はしてゐない。",
              "citation": {
                "source": "「明るい文学」について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに加うるに、ロンジュモーの御者（訳者注　美声を持ったある駅馬車の御者が結婚の間ぎわに女をすててオペラ役者になって浮かれ歩くという歌劇中の人物）をもってしなければならない。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
