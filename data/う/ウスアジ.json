        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "灰皿のほうは肉の薄味、線の丸さ、波形の縁のうねり、その他どう見ても優しいそうして濃まやかな感じの持ち主の手になったものとしか思われない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友情という感情内容が何となし薄味であるかのように感じられる程、それは異性の間に社会感情の間では若々しい芽である。",
              "citation": {
                "source": "異性の間の友情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰈の薄味は好きですよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もうどんは大好きだつたし、二宮の家にゐた頃は、お嬢さまもうどんが好きで、絹子がほとんど毎日のやうにうどんを薄味で煮たものであつた。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "粟で造った薄味のものとか、雑菌がはいってる酸味のものとか、あんなのではない。",
              "citation": {
                "source": "どぶろく幻想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、これも薄味付けしたお粥を拵えて、できた粥の中へなめこを入れる。",
              "citation": {
                "source": "夜寒に火を囲んで懐しい雑炊",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは春先の若い蕨を塩漬けにして置いたものですが、塩をもどして、薄味で煮て見ました。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "野菜椀のうちによく合せてある蕗などにしても、ああイヤ甘い薄味なのよりは、惣菜味の“ショッパイ”煮方のほうがいい。",
              "citation": {
                "source": "舌のすさび",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらのは、当時は手打ちで、薄味で、薬味には細い香ばしいネギが、大丼に出してあった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぎわのいい女性で、さきほど台所に立ったのにとヨシオが思う間もなく、やや薄味の小粋な料理がいくつも、食卓にならぶのだった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（プラトン）　人々をおたがいにひきはなし、愛のもっとも薄味なものしかあたえないことに繁栄の土台をおいている社会に対する強烈な疎外感をきっかけに自分たちの生活を根本からつくりなおそうとする若者のムーヴメントと切りはなしてロック音楽を考えることはできない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、活動写真館の中売りが「ええアイス、アイスクリン」と呼びながら売っていた、薄味のアイスクリームも、少年の日の思い出だ。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄味というのは、卵も牛乳も碌に入っていない、お粗末な、だから一個五銭位だったろう、そういうアイスクリームなのだ。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、デザートに出た、ババロアの味、ソーダ水の薄味のレモンのシロップ。",
              "citation": {
                "source": "食べたり君よ",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説としては、どぎついところのあるものでなく、いわば、うすあじの作品と言えるが、江戸の情緒を描き出したあの背景は素晴らしいし、一服の、ほのあたたかい人情味とともに、芸術品としては、高いクラスのものだと信じている。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
