        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夏引きの麻生の麻を績むやうに、そして、もつと日ざらしよく、細くこまやかに―。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏引きの麻生の麻を績むやうに、そして、もつと日ざらしよく、細くこまやかに――。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏引きの麻生の麻を績むやうに。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏引きの麻生の麻を績むように、そして、もっと日ざらしよく、細くこまやかに――。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "苧糸を績むということは、もう見たことも聴いたこともない子どもが多くなっているが、麻の皮をはいで蒸して乾してよくさらして、白くきれいな部分だけを、爪の先で細かくわって、つないで撚りをあたえて一すじの糸にして行くことで、蚕のはく糸の細いものを五つ七つと合わせて行くのとは、仕事がまるで反対になっている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いまするどく鋭刃を合せ、手はしろがねとなり、われの額きずつき、劍術は青らみつひにらじうむとなる。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、とりきんで足袋を引っぱったら、私はからだの重心を失い、醜くよろめいた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、拝借しよう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、行って見ようか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、こんどの世話はごめんこうむる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主はあまく、いいとしをして口髭なんかを生やしてゐながら「うむ、子供の純真性は大事だ」などと騒ぐ。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、おまへに見せてやるものがある、」彼は父の言葉をこれまで耳にすると、ガクツとたゞ一度だけする身慄ひと共に父の方を瞶めた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主はあまく、いいとしをして口髭なんかを生やしていながら「うむ、子供の純真性は大事だ」などと騒ぐ。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、まあ、さうだが、いまは土が凍つて固くなつてゐるから掘るのが困難だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ、ううむ、と大袈裟に唸りながら、めちや苦茶に鎌を振りまはして、時々、あいたたたた、などと聞えよがしの悲鳴を擧げ、ただもう自分がこのやうに苦心慘憺してゐるといふところを兎に見てもらひたげの樣子で、縱横無盡に荒れ狂ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、いい加減に、カチカチ山あたりでごめんかうむつて來るんですな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸はたちまち七轉八倒して、「ううむ、何ともない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、」幽かな溜息をついて、「漕げないことも無いがね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "範疇、当為、止揚、妥当などというむつかしい言葉も今日ではもう日用語になりきってしまった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "焜炉の火に煙草をすっていて、自分と等しく奈々子の後ろ姿を見送った妻は、「奈々ちゃんはね、あなた、きのうから覚えてわたい、わたいっていいますよ」「そうか、うむ」　答えた自分も妻も同じように、愛の笑いがおのずから顔に動いた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非立ち會はせてくれ‥‥‥‥』『さ、それが、大抵の人がさう云ふんだ‥‥‥‥』『だが、僕は爲事の點から云つても、それには少し慣れてゐる積りだ‥‥‥‥』『うむ、とに角君の妻君の生死に係る事だからそれは無理もないがね。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――緑色の上着を着た……」「うむ、ゐるゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ……」「この酒塲での一番腕つこきなんださうだよ。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がまるで踏みくちやにされてしまつてる……」「うむ、踏みくちやにされてしまつてるは好いね。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ‥‥」と、河野は頷いた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、そりやさうだとも。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、六七月｜頃になると、それを切花にして客｜間に飾る……」「ああ、どんなに奇※でせう？",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、お前も行きたいか？",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そことは君が号外を前へ置いてひどくがっかりしているところだ」「それはいけない、そんな気のきかないところは御免をこうむる。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、客の来ているのは私に取って勿怪の幸いで、それをしおに早々に帰って来ました」「ふうむ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
