        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しばらく見ているうちに私はそれが雄の鳴くたびに「ゲ・ゲ」と満足気な声で受け答えをするのを発見した。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを極まり悪そうにもしないで、彼の聞くことを穏やかにはきはきと受け答えする。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどそう言えば、私が話しかけてもとんちんかんな受け答えばかししていたのは、いつものこととはいいながら、ひとつにはやはりそのせいもあったのかも知れない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗に溶ける白粉の匂い、かんばかりで受け答えしている話声。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等を彼は何も専門的や具体的智識があって受け答えするのではない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如何にも物馴れた常識的な客間の状勢は日本の客を受け身にさせ、暫らくガルスワーシーの日本の風物に対する質問等に景子達はただ柔順に受け答えしなければならなかった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者にあまり高い教養はないらしく、たびたび受け答えがわかりにくくなりましたが、それは私たちの言語の知識が限られているせいだと思います。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、このごろ、このきまりきった挨拶の受け答えが、めんどうくさくて、うるさくって、たまらないのである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼だの、用だの、所得だの、黙契だのという言葉を忘れて、孔子と曽子のこの一場の受け答えの光景を考える時は、朱子の説明が如何に能く説明されているかが、合点されるだろう。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから此の頃の屋敷の様子や、外記にかかわる親類たちの噂などを根掘り葉掘りいろいろ聞きただしたが、世間慣れている角助は如才ない受け答えをして、綾衣に聞かして悪いようなことはなんにも言わなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎は大勢の親分と立てられている人だけに、人間もなかなか如才ないらしく、初対面から打ち解けていろいろの話を仕掛けますけれども、こっちは針の筵に坐っているのですから、満足の受け答えができよう筈がありません。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごもっともです」　事務長は虻に当惑した熊のような顔つきで、柄にもない謹慎を装いながらこう受け答えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興録はいいかげんな事をいって一日延ばしに延ばしているのでたまらなくなって木村が事務長に相談すると、事務長は興録よりもさらに要領を得ない受け答えをした、しかたなしに木村は途方に暮れて、また葉子に帰って来て泣きつくように上陸を迫るのであった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛子があの年ごろで男の前にはっきりああ受け答えができるのは葉子にも意外だった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどこをどう話が通ったか覚えていないが、三十分ばかりたつうちに、自分も重吉もいつのまにか、いわゆる「あのこと」の圏内で受け答えをするようになった。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな電話が実際にかかっているように受け答えするらしいのです」「とにかくソンナ訳でユリ子は、大急ぎでお化粧をして、盛装を凝らして病院を出て行ったそうです」「プッ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼はしずかに歩きながら優しい柔かい声で僕にいろいろのことを話しかけたが、子供の僕は軽く受け答えをするだけで、大抵はだまって聞きながら歩いていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、いかにもこの相手が荷厄介らしく、なんだか滅入ったような気乗りのしない調子で、しぶしぶ受け答えをしていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、「ええ」とか「いいえ」とかいったたぐいの、短い言葉で受け答えしていて、眼を上げずに、ただほほ笑んでいた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とさも親しげに呼びかけながら、庸三をそっち退けの、朗らかな声で話しかけたが、博士は庸三に気を兼ねるように、むしろ話のはずむ彼女に目配せしたいような目つきで、穏やかに受け答えをしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そんなことを話そうとも思わず、またよし思ったとしても話しすることはできずに、ただ礼ちゃんの聞くままに受け答えしていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "受け答えのよい人で話｜上手で、あったとも聞いた。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とつっけんどんな受け答えに、丹霞和尚がこたえて言った、「もし、お舎利の出ない仏様なら、何ももったいないことはないではないか。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　久慈は矢代が訊ねても黙って千鶴子と受け答えしながら、「僕、矢代だよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "受け答えの様子では矢代は帰っているらしい。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼にする物象が絶えず跳ね動いているような活気に矢代は人からも押され気味になり、受け答えにも窮する遅鈍なものが、いつの間にか自分になっているのを感じた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのどの話もみな矢代の知らぬことばかりだったが、ある山科という人物の話になって来たとき、別に取り立てていうべき事でないにも拘らず、妙に塩野の受け答えが渋りがちにっかえ、ときどき矢代の方を向きかけようとしては、表情をもみ消す彼の気苦労の様子を見た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "益満は、時々受け答えしながら「諸事節約になってから、だんだんふえてきた」　と、独り言をいっていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　髪を分けた頬を白く、手首とともに、一層扉に押当てて、「あああ」　とやさしい、うら若い、あどけないほどの、うけこたえとまでもない溜息を深くすると、「小県さん――」　冴えて、澄み、すこし掠れた細い声。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは……その時の私と、由紀とのうけこたえに、女のものいいが交りましては、尚お申憎うございますから、わけだけを、手取早く。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
