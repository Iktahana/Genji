        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "年齢の相違気力の差、たゞもうこのまゝ……窓の向ふは内庭らしい。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武は黙って内庭に入りました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と今度はなお強く言いましたので私も仕方がないから、のっそり内庭に入りました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、「由」は下男の吉蔵が焚火をして居る内庭へ薪割台など運んで来て腰をかけてあたたまって居る、膝に黒の碁盤縞の俥の前掛の毛布を、きちんと畳んで置いたりして。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間、次の間、仏壇の間、という順に、内庭の木立の繁み近くに迄建て連ねられた幾つかの座敷に沿うた縁廊下は、遥々と見渡すほどに長く延びて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第八場その一（祇園精舎の内庭である。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内庭の石だたみの上に草の編物を敷き、弟子達が離れて二列に座して居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の残りを入れた壺ひとつだけ、内庭の中央に残し置く。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを合図に教団の人々左右より出で来り、二列に内庭に立つ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中『古酒』中の「よひやみ」「柑子」「晩秋」の類最も旧くして『魔睡』中に載せたる「室内庭園」「曇日」の二篇はその最も新しきものなり。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年八月　　室内庭園晩春の室の内、暮れなやみ、暮れなやみ、噴水の水はしたたる……そのもとにあまりりす赤くほのめき、やはらかにちらぼへるヘリオトロオブ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（……駄目ですよ、何をなさるんですよ、）　養父が何をはじめたであらうかと思つて、鉛筆を控へて内庭越しに離屋の方を見た。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所は内庭に面した所で、雨戸を締めてない客室の前の廊下に、新らしい籐椅子を此方向きに置いて、白い浴衣を着た叔父が仰向きになつてよつかかつて、団扇を膝のあたりに置いてゐた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は表口からは上がらないで、内庭からすぐに母のいるえん先へまわった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い内庭に踏石がほんのり白く浮んで見えた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いぶかりながら、見とがめられぬように本堂の横から裏へ回って、方丈の間とおぼしきあたりの内庭先へこっそり忍び入ってうかがうと、果然目を射たのは、そこのくつ脱ぎ石の上に脱ぎ捨てられてある一足のなまめかしい女げたでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その玄関さきも、前庭、内庭も、荒れるがままに荒れ果てて、一面にぼうぼうと枯れ草ばかりでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "内庭にはまた水門から堀がつづいて、船頭たちはどこへ姿を消したか、ぬしのないしめなわ舟がなぞのごとくに見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかりのてがらに得々として、名人右門をしかりしかり、息をころして内庭へ回りながら、子分べやらしいひと間の障子をそっとのぞいてみると、なるほどいるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねこ伝がふんぞりけえっているところはどっちだよ」　伝六にしかられながら三下奴が案内するままに内庭さきへはいってみると、いかさま不審な死に方でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "声をたよりに奥へはいってみると、へやは内庭にのぞんだ離れの六畳。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのふた間の前に、ずっと広い廊下があって、廊下の外はあまり広くない内庭でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "内庭か、外庭か、どっちにしても外科べやの近所の庭先にちげえねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六一つ芸の名に恥じず、中べいを乗り越えていってみると、案の定、内庭と外庭との境になっている外科べやの小窓下に、ねらいをつけたその血がめがあるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "足音の近づくと同時に、がばと起きあがって待ちうけているところへ、三庵の家の下男が、案内も請わず内庭先へ飛び込んでくると、密封の一書を投げこみながら、そのまま急ぐようにせきたてました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへ来な」　そこの庭口のくぐりからはいって、こっそりと内庭へ回りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして馬子がそれを一俵づつ背中に負うて、内庭を通つて倉に運んで行く。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、雌鷄はひとりで内庭の方に入つて來て、頻に何かを搜してゐる模樣だつた。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の者達が注意して裏庭には出さないやうにしたので、一日内庭の固い土の上を仲好くあさつて歩き、時々勝手の上り框に載つて餌をくれと人にせがむやうな顏付をしてゐた。",
              "citation": {
                "source": "白い雌鷄の行方",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかうしてゐるところへ、馬車の轍の音がしたけれど、その馬車は長いこと内庭へ入つて来なかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
