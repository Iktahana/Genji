    "definitions": [
      {
        "index": 1,
        "gloss": "women's bridal robe with trailing skirts worn over a kimono",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "Ｓ＝境内　武蔵が大小の木太刀を手に悠々と腰打ち掛けて居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）８０＝（Ｆ・Ｉ）峠の頂上　五人組が腰打ち掛けて待って居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）80＝（Ｆ・Ｉ）峠の頂上　五人組が腰打ち掛けて待って居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "纖き手をベルナルドオが肩に打ち掛けて秋波を送れり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報は至急な用件で発信者が発したものと分かってはいるが、碁を打ち掛けているので直ちにはそれを開封しないで、左の手に握ったまま二手三手と碁を打つ。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速返事の電報を打たなければと思うが、打ち掛けたこの碁も今｜少時で勝負が付くことだから、一局済んでから返事を出そうなどと、やはり続けて碁を打っている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その猴取って置きの智慧を揮い、戸を開いてその上端に厚き毛氈を打ち掛け、戸の返り閉づるを拒ぎ、やすやすと目的を遂げたそうだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多忠朝の先手が、二、三発敵にさぐりの鉄砲を放つと、等しく越前勢たちまち七、八百挺の鉄砲を一度に打ち掛け、立ち籠めた煙の中を潜って、十六段の軍勢林の動くがごとく、一同茶臼山に打ってかかった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時候はよし、四方の景色はよし、木蔭の石灯籠の傍などに、今の玩具を置いて其所に腰打ち掛けて一服やっている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蘆の葉のおもちゃのはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀧口｜行く／＼四方の景色を打ち眺め、稍々疲れを覺えたれば、とある路傍の民家に腰打ち掛けて、暫く休らひぬ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝五つ時に天満から始まつた火事は、大塩の同勢が到る処に大筒を打ち掛け火を放つたので、風の余り無い日でありながら、思の外にひろがつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　遠山はかう云つて、傍輩と一しよに死骸のある所へ水を打ち掛けてゐると、消防方が段々集つて来て、朝五つ過に火を消し止めた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅の方は利かねえ気の奴だったから、野猪狩に持って行く鉄砲を打ち掛けた。",
              "citation": {
                "source": "里芋の芽と不動の目",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『みんな、見物ばかりしてねえで、お酒でも買って上げな、そうしねえてと今夜この仏様がよ、打ち掛け姿で礼に廻って歩くと……』　爺さんが気味の悪い冗談をいうと皆も、『何も化けて出るこたありゃしまい、散々思いあって思う男と死に遂げるなんて、こんな甘い話があるもんかい。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れたる木に腰打ち掛けて光代はしばらく休らいぬ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊の毛皮を打ち掛けた黒檀の牀几はどこへ行った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅裏を取り、表は白綸子、紅梅、水仙の刺繍をした打ち掛けをまとったその下から、緋縮緬に白梅の刺繍をした裏紅絹の上着を着せ、浅黄縮緬に雨竜の刺繍の幅広高結びの帯を見せた、眼ざめるばかりに妖艶な、二十歳ばかりの女であって、主殿頭の無二の寵妾、それはお篠の方であった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし母がそれを打ち掛けた姿は、今想像してもまるで眼に浮かばない。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき呉清源必勝の局面が打ち掛けになったとき、坊門の棋士が総勢集まって研究し、前田六段（当時）がついに起死回生の名手を発見し、そのために碁がひっくり返って本因坊の二目勝になったという秘史があるからなのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉氏良しという局面であったが、この時、秀哉名人が、一門の者を集めて、打ち掛けの次の打ち手を研究し、結局、前田六段が妙手を発見し、このお蔭で、黒の良かった碁がひっくりかえって、負けとなった。",
              "citation": {
                "source": "呉清源",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるところ、長州様蒸気船二艘まいり、石火矢打ち掛け、逃げ行く異船を追いかけ二発の玉は当たり候由に御座候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "高崎勢は同所の橋を破壊し、五十人ばかりの警固の組で銃を遠矢に打ち掛けたまでであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一道の白光闇を貫く　邪法を用いて巨大な柱を引き抜いたとは夢にも知らず、右門は五右衛門の強力を心｜窃かに嘆じながら、今は遁がれぬ必死の場合、両手を岩に打ち掛けて、金剛力は出しても、地の中深く喰い込んだ苔｜蓬々たる孕石は、身弛ぎ一つすればこそ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを十個だけ打ち掛けようぞ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛皮を打ち掛けた牀几の上へ悠然と腰掛けた一人の武士、これぞ一団の大将と見え、身には直垂を付け鎧を着流しまだ角髪の艶々しきに故意と冑を従者に持たせ烏帽子を額深く冠っている。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度水を打ち掛けられた犬のような姿である。",
              "citation": {
                "source": "鴉",
                "author": "シュミットボン　Willhelm Schmidt-Bonn",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたく疲れたりければ、暫し休息せんとて岩に腰打ち掛けたるまゝ、茫然として吾あるを知らざりしが、忽ち跫音渓間に起り、低く咆哮するものあるを聞く、怪しんで顧れば、渓に臨める巨巌の下に其色墨よりも黒き物の半身を顕はせるを見る、相去ること四百歩許、熟視すれば熊也。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅田の浦の汀の石に立つて近江の湖を見た時と、三津の濱の捨舟の端に腰打ち掛けて瀬戸内海を眺めた時といづれを湖いづれを海と見定めがつかう。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の土人たちは声で嚇し、かつ鉄砲をその前後の空間に打ち掛けて、悪魔を追い攘おうとしたがついに効を奏せず、捕われた者は茂みに隠れてしまった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三歳、五歳の祝ひ着は今の芝居のうちかけで見るやうな花蝶総縫ひのちりめんに下着を赤のゑぼしちりめんといふので重ねてありました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
