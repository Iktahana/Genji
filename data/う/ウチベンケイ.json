    "definitions": [
      {
        "index": 1,
        "gloss": "someone haughty and boastful at home but meek and reserved outside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
