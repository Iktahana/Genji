        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今の自分から見ると此等の畫家は實に羨ましい有福な身分だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか非常に羨ましいような気がして同時に今まで出なかった涙が急に眼頭を熱くするのを感じた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶井君と三好君との交際は、側で見てさへ羨ましいほど親密で、しかも涙ぐましいほどに純情だつた。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「己はトルストイが羨ましい。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが気の毒なというよりはむしろ羨ましいような気のする時がないでもない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に羨ましい境遇だと思わねばならない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羨ましい、素晴しく幸福そうな眺めだった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自然さ、そして才気の底の知れなさ、秀吉は、天下に嘗て代って見たいほどの羨ましい人間には出会ったことがありませんでしたが、この利休を見てからは、その気持ちが少々あやしくなって来ました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵曹無念の切齒をなし、『えい、殘念だ／＼、此樣な時、本艦の水兵が羨ましい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これを見ると、羨ましいか、桶の蔭から、むくと起きて、脚をひろげて、もう一匹よちよちと、同じような小狗は出て来ても、村の閑寂間か、棒切持った小児も居ない。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひるはまたお酒をいたゞいた、行乞米を貰つて下さつてお布施を下さつた、襦袢の手入、浴衣の洗濯、そして褌まで頂戴した、黎々火さんはほんとうによい肉縁の人々を持つてゐる、お父さんの温情、お母さんの慈愛、あゝ羨ましい。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺にいる人からも必ず、松林の縁の街道を走る自動車の姿は一目で見える筈だし、そうすれば、幌なしの座席に相乗りしたアメリカの活動役者の恋人同士のように颯爽たる男女の様子は、この上なく羨ましい光景として見送られるに相違ないのです。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子の素直で素朴な親への愛情は、均平にも羨ましいほどだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の健康と自由さへあるならば、街路に日向ぼつこをしてゐる乞食さへも羨ましいのだ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味からいうと、美々しい女や華奢な男が、天地神明を忘れて、当面の春色に酔って、優越な都会人種をもって任ずる様や、あるいは天下をわがもの顔に得意にふるまうのが羨ましいのです。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな雑誌の編輯後記を見ても、大した気焔なのが、羨ましいとも感じて居る。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真黒な身体を、素直に伸びた足を、筋肉の盛上った肩つきを、三造は此の上なく羨ましいものに思った。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、こうした外観の惨めさにもかかわらず、この老人は、実に――全く羨ましいほど――いつも幸福そうに見える。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたも佳い別嬪に可愛がられて羨ましいの。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は彼等の傍を通り抜けながら、ふと優越的な気持が同情に先立つらしく、さげすみの眼をちらと投げて行ったが、北山の眼はそんな旅行者が羨ましい眼付だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の一生には私を泣かせるような素晴らしい女はもはや現われないだろうが、しかしよしんばつまらない女とでも泣けた時代が羨ましいのである。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを君は殆ど何の苦しみもなく歩いてゆく、何にも知らぬ子供のやうな心で進んでゆく、羨ましい事だと思ふ。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで国府津へは三度目だが、なかなかいいところだとか、僕が避暑がてら勉強するには持って来いの場所だとか、遊んでいながら出来る仕事は結構で羨ましいとか、お袋の話はなかなかまわりくどくって僕の待ち設けている要領にちょっとはいりかねた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」學務部長に隨喜の涙を流す吉田の姿が、急に、皮肉でも反語でもなく、誠に此の上無く羨ましいものに思はれて來た。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、羨ましい位見事な身體であつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、羨ましい位見事な身体であった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間椅子」では、あの主人公の性格をもう一息、突込んで脚色してもらいたいと思いながらも、椅子というものの不可思議な感じを、あそこまでエグリ付けられた氏の大手腕に、羨ましいまで感心させられてしまいました。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはありませんよ、おんなじですよ、」「ぢや、いよ／＼、家にゐて、持つて来て貰ふが好いな、かうなると独身者が羨ましい、」「独身者が何故羨しいんですの。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩本は羨ましいうえに好奇も手伝って、どこへ往くか見たくなったので、己も急いで山西の置いて往った金に幾等かの金を足して、食卓の上へ投げだして、「おい、ここに一円二十銭ある、足りなかったら翌日の晩だ」と、云って急いで戸外へ出た。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり、立派だわ、うらやましいわ」　と声に出して言った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
