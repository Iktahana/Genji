        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんな莫迦な事があるはずは無いという叔孫に、それでも近頃仲壬が君公から拝領したという玉環を佩びていることは確かですと牛が請け合う。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "請け合うが、話したいときに話ができる相手というのは、僕のようなものには至極大切で、考え自体がやたら面白いというわけではないのでね。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに付記された内容の正しさは私が請け合う。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わっし一人で請け合うわけにゃあ行かねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時分木彫りをわざわざ頼みに来るのは不思議のようであるが、この沢田は貿易物の他に、地の仕事をも請け合うのですから、私に木彫りを頼みに来たのであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石炭はドウダイ」「桑港まで請け合うよ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、それはわたしが請け合う。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず必ず桐庵、太鼓判を押して請け合う」　いやが上にも念を押すように、「さればさ阿父さん同様の商売もよかろう。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が請け合うよ、心配することなんか何ひとつありはしないんだよ……」彼は私をまるで子供のように宥めながら、真心をこめていたわるように囁いた、「請け合うよ、何にもありはしないんだよ！",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ごとが出来るものか」　荒木陽一郎が、請け合うように、こう言い切った時だった。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵だけでも、ボストンじゃ十のうち九の家庭やクラブから叩き出されるのは請け合うし、今ならどうして私が地下鉄や地下室に近寄りたがらないか判ってくれたとも思う。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「請け合うが、あの女め立ち聞きしている！",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君が今まで見たこともないブツだと請け合うぜ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "請け合うよ、全然分からなかったから。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみには何も危害を加えないし、請け合うけど、本当のことを言えば有利になる。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "当該拳銃を調べたところ、確実にその拳銃がシルバデール公爵のものだと断定された」「何とまあ」「君、事実だ、請け合うよ。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "レポート提出はおたがいさま」　と、柾生がうけあう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをすれば、私はこの水兵の生命をうけあうわけにはゆかない」　とドクトルが反対した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だが、ひょろ松、ここでじっくり糸を垂れていると、……かならず釣れるか、おまえ、きっとうけあうか」　みょうにからんだようなことをいう。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょろ松は、へこたれて、「うけあうという訳にはいきませんが、まあ、ひとつやってごらんなさいまし」「まあ、じゃ、いやだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが、かならず、うけあうといわなきゃア、この辺で水を蹴ッくらかえして釣れないようにしてやる」「こりゃアおどろきましたな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "……じゃ、まあ、うけあいますからやってごらんなせえまし」　顎十郎は、ニヤリと笑って、「よし、とうとううけあうとぬかしたな。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、小林君の身の上をうけあうことはできませんよ。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
