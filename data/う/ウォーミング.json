          ],
          "literary": [
            {
              "text": "けれども……）いや、ざっと、ウォーミングアップ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何事にも、ウォーミング　アップといふことが必要でございますと存じます。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何事にも、ウォーミング・アップということが必要でございますと存じます。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞は「これこそ夜間大編隊来襲のウォーミング・アップなり」と報じ、一般の注意を喚起した。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一日目はウォーミング・アップ。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いもののためのウォーミングアップとして。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなこと書いている、これも一種のウォーミングアップかもしれないからどうぞあしからず。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
