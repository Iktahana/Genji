        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……王はトーレ・フンドに切りつけたが、魔法の上着は切れなかった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦いが終わってトーレ・フンドは王の死骸を地上に延ばして上着を掛けた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年修学旅行で〔以下数文字分空白〕「お父さんはこの次はおまへにラッコの上着をもってくるといったねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニがまださう云ってしまはないうちに、「ジョバンニ、お父さんから、らっこの上着が来るよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてきうくつな上着の肩を気にしながらそれでもわざと胸を張って大きく手を振って町を通って行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニが云はうとして、少しのどがつまったやうに思ったとき、「ジョバンニ、らっこの上着が来るよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジョバンニ、らっこの上着が来るよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ前の席に、ぬれたやうにまっ黒な上着を着た、せいの高い子供が、窓から頭を出して外を見てゐるのに気が付きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、すっかりあはててしまって、もしか上着のポケットにでも、入ってゐたかとおもひながら、手を入れて見ましたら、何か大きな畳んだ紙きれにあたりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして読みながら上着のぼたんやなんかしきりに直したりしてゐましたし燈台看守も下からそれを熱心にのぞいてゐましたから、ジョバンニはたしかにあれは証明書か何かだったと考へて少し胸が熱くなるやうな気がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下流のまっ青な水の上に、朝日橋がくっきり黒く一｜列浮び、そのらんかんの間を白い上着を着た騎兵たちがぞろっと並んで行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い上着を着ているし、きっと裸馬だろう。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春告鳥』は「主女に対する客人のいで立ち」を叙して「上着は媚茶の……縞の南部縮緬、羽織は唐桟の……ごまがら縞、……その外持物懐中もの、これに準じて意気なることと、知りたまふべし」といっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春色恋白浪』に「鼠色の御召縮緬に黄柄茶の糸を以て細く小さく碁盤格子を織｜出したる上着、……帯は古風な本国織に紺｜博多の独鈷なし媚茶の二本筋を織たるとを腹合せに縫ひたるを結び、……衣裳の袖口は上着下着ともに松葉色の様なる御納戸の繻子を付け仕立も念を入て申分なく」という描写がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春色恋白浪』に「鼠色の御召縮緬に黄柄茶の糸を以て細く小さく碁盤格子を織出したる上着、……帯は古風な本国織に紺博多の独鈷なし媚茶の二本筋を織たるとを腹合せに縫ひたるを結び、……衣裳の袖口は上着下着ともに松葉色の様なる御納戸の繻子を付け仕立も念を入て申分なく」という描写がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "質素なる黒の上着に麦藁帽子の拵にて、遠慮らしく徐に入り来る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（モデル娘忙がわし気に帽を脱ぎ、上着を脱ぎかかる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（フロックコオトの上着を脱いで床の上に投り出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてチョッキのみになりたるに心付き、床の上にある上着を取上げ着る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、艶拭巾を取りて、絵具箪笥の抽斗の、まだ開けある中にしまい、忙がわしく上着を着る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は上着を着、帽を被り、何か用あり気に戸の近くに立ち留りいる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "また暫く歩きて、突然為事机の傍に寄り、机の上の物を上を下へといじり廻し、終りに壁に掛けたる袋の中よりブラシを見出して手に取り、上着の塵を払う。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――緑色の上着を着た……」「うむ、ゐるゐる。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして青いうわぎのすそをひろげて、そのうえにふってくる雪をうけました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こう妹をなだめておいて、やがて、親たちがねしずまると、ヘンゼルはそろそろ起きだして、うわぎをかぶりました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンゼルは、かがんで、その砂利を、うわぎのかくしいっぱい、つまるだけつめました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "くつも　ないので　よつあしで　はしると　ぐんぐん　はやくなって、　うまくいけば　にげられたと　おもうのですが、　うんわるく　スグリの　あみに　つっこんでしまい、　うわぎの　おおきな　ボタンが　ひっかかってしまったのです。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに　あおの　うわぎで　しんちゅうの　ボタンつき　おろしたての　ものでした。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグレガーおじさんが　やってきて　もってきた　ふるいを　ピーターの　うえから　ぱっと　かぶせようと　しましたが、　ピーターは　すんでのところで　うわぎを　ぬぎぬぎ　あとに　のこして　にげだしました。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            }
          ]
        }
