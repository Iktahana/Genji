        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "内風呂は兎かくに火災を起し易いからである。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に下町のような人家稠密の場所では内風呂を禁じられていたので、大家と云われるほどの商家の主人でも、大抵は銭湯へ入浴に行った。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後はその禁制も解かれ、且は地方人が多くなった為に一時は内風呂が頗る流行したが、不経済でもあり、不便でもあるというので、明治の中頃からは次第に廃れて、大抵は銭湯へ行くようになった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正以後、内風呂がまた流行り出して、此頃は大抵の貸家にも風呂場が附いているようになったが、それが又どう変るか判らない。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここの店には内風呂があるんですか」と、半七はまた訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の者は車湯へまいりますが、奥では内風呂にはいります」「この頃に風呂の傷んだことはありませんかえ」「よく御存じで……」と、四郎兵衛は相手の顔をみた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「去年の暮に、備前屋の内風呂が傷んだので、娘はおまえの湯へ来たそうだな」と、半七はまた笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその計略がうまく運ばないので、娘もひとりで焦れ込んでいるうちに、内風呂がまた傷んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし東京の銭湯は公共のもので、田舎の内風呂とは違つてゐる。",
              "citation": {
                "source": "入浴",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝楊枝を銜えながら、いっしょに内風呂に浸った時、兄さんは「昨夕も寝られないで困った」と云いました。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "清六どんは恐ろしい湯好きで、内風呂の立たない晩は、必ず町内の巴風呂へ參ります」　金次は皆んなの顏を見乍ら、思ひ出し思ひ出し續けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その前に一応町内の二つの風呂屋にも当って見たが、二軒ともお栄が来たことはないというのだ」「近江屋には内風呂がありますよ」「そうだってね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "清六どんは恐ろしい湯好きで、内風呂の立たない晩は、かならず町内の巴風呂へ参ります」　金次は皆んなの顔を見ながら、思い出し思い出しつづけました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の江戸は、町家は言ふまでもなく、武家でも内風呂を持つてゐるのはたいした贅澤で、一般の人達は町風呂へ行くのが精一杯、暖かいうちは、行水で濟ますのが世間並だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの宿屋にも公平に内風呂というものはないので、その井の字なりの町のまんなかにある三｜棟の大湯へ、四方の旅籠のお客様がみな手拭をブラ下げて蝟集していた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
