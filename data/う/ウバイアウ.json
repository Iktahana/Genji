        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "親しい友人の間で彼女を奪い合うというようなことがいやだったからでもあったが、本人の彼女の態度がだれのほうをより多く愛しているのか、どうしてもはっきりとしなかったからでもあった。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し愛が相互的に働く場合には、私達は争って互に互を奪い合う。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ここに不審というのは、ふたりともおれが使った、おまえではない、このわしが使い込んだのじゃ、梅五郎の申し立ては偽りでございます、いいえ、豊太の申し立てはうそでござりますと、互いに罪を奪い合うのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに主家への忠義だての罪であったにしても、互いに罪を奪い合うのがそもそもの不審でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の客引が客を奪い合う様子、昔の宿場よろしくの光景なり。",
              "citation": {
                "source": "湯ヶ島の数日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "根という根は互いにまつわりついて、お互いの水気や養分を奪い合うのでした。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大企業や大組織のユーザーが巨大なシステムを組んでいるＡＣＯＳでは、互換性の維持を最優先しながら、忍び足で機能を拡張していかざるをえなかったものが、目の前の顧客を奪い合う激しい競争が常のオフィスコンピューターでは、むしろ積極的に新しいアイディア、新しい技術を取り込むことが不可欠だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このグループの作業はプロトタイプの完成後に正念場を迎える」と釘をさした浜田は、まず手始めに新一六ビット機と市場を奪い合うことになるだろう各社のマシンに、どのような経路でアプリケーションが供給されているかを分析するよう求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の霊魂を奪い合う天使と悪魔とを見ているのである。",
              "citation": {
                "source": "おぎん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、寝る時には、各自に自分の布団の中へ猫を奪い合う。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来夜毎の酒盛りにも、十六人の女たちが、一生懸命に奪い合うのは、素戔嗚ではなくて、黒犬であった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦の年から翌年へかけて、食糧の窮迫と食糧危機の予想とにより、至る所にある焼け跡は、奪い合うようにして耕作されました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹は猿を殺して食うからむろん猿の敵であるが、猿同志は互いに食物を奪い合うものゆえ、猿もたしかに猿の敵である（Simia simiae lupus）、頸をかみ切って殺すも、餌を奪い去って殺すも、ただ多少直接と間接との相違があるだけで、その結果にいたっては毫も異なるところはない。",
              "citation": {
                "source": "動物界における善と悪",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋しい人を奪い合う「生きてくださいよ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は彼女を奪い合うように抱いたり下したりした。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊田も気取らない気質で、大豆を奪い合う「豚」という遊びの時なんか「おい、駄目だ駄目だ、ひどいよ」と、どら声をあげて、雪枝の夫にくみついたりした。",
              "citation": {
                "source": "杉子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、キャアキャア云いながら、引掻いたり、転し合って奪い合う様子を、例の横目で眺めながら、「何たら態だ！",
              "citation": {
                "source": "風に乗って来るコロポックル",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らと対抗して、そのわずかな日向の場所を奪い合うようなことは、さすがになし得なかった……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たがいに相手の有するよきものを奪い合う。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ら悔いの念なく互いに恋人を奪い合うべしだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "いとも粗雑な矢来を囲って、外からは見えないようにそれへ筵を張り廻してある人寄せの見世物が、六、七ヵ所に紙旗や毛槍を立て、その閑人の群れへ呼びかけて、客を奪い合う様はなかなか真剣な生活戦だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの村の子どもたちは、夏休みになってから毎日大池にきて、こちらの村の子どもたちと水あび場をうばいあうのでした。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
