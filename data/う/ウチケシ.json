        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "またある時は「あなた、かくしているでしょう、きっとそうだ、あなたそうでしょう」とうるさく聞きながら、余の顔色を読もうとする、その祈るような気づかわしげな目づかいを見るのが苦しいから「ばかな、そんな事はないと言ったらない」と邪慳な返事で打ち消してやる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうかと云ってあ〔ゝ〕いふ眼付き、厭な眼付は打ち消し得ない。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秘かな心の下で最後の「死」の怖れに触れては、それを打ち消していた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつを持って行ったかな」と、半七は少し迷ったように蛇のゆくえを見つめていたが、「いや、そうじゃあるまい」と、又すぐ打ち消した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が慇懃にあいさつする言葉を打ち消して、『いやそうあらたまれては困る。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、この世の中は、白いのです」　と、さきの二つの小鳥の言葉を打ち消しました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、信州の諏訪は十月じゃあるめえ」と、半七は打ち消した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――まさか」　と、打ち消してみたものの、舞台の上の冴子を見ている自分の眼が、昨日の単なる好奇的な眼と違った燃え方をしていることは、もう否定できなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、と直ぐに打ち消した。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、とあわてて打ち消した。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなくなりになつた事に就いて、これも北条氏の手に依つて殺害せられたのだといふ不気味な噂が立つたさうでございますが、それは私がやつと七つか八つになつたばかりの頃の事でございますし、またそのやうな事に就いての穿鑿は気の重いことで、まあ、そんな事はございますまいと私は打ち消したい気持でございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、被害者が政黨屋の三人だといふ事から、ふと胸を掠め過ぎた一種の反撥的な快さを、私は打ち消し得なかつた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小説というものを間違って考えているのであろうか、と思案にくれて、いや、そうで無いと打ち消してみても、さて、自分に自信をつける特筆大書の想念が浮ばぬ。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」必死に打ち消し、「お願いがございます。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつこく迫っていた順平に、いつかは許してもよいという気があるいは心の底にあったのではないかと思われて、しかしこれは余りに滑稽な空想だと直ぐ打ち消した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なぞと、すぐに日本を打ち消してしまいたがる人があるが、それは記紀から万葉、催馬楽、田楽、諸国の地謡というものを真には研究して見ないからだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめまして、僕は三島讓と云うものですが」　讓が云いはじめると女は手をあげて打ち消した。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行末の楽しみの相手なりし者を討ち果したらむ今は、わが身に添ひたる、もろ／＼の大千世界を打ち消して涯てしも無き虚空に、さまよひ出でし心地しつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この逆定理を応用してその本心を打ち消し、その性格を隠して、鼻の表現をさながらにそれらしく変化させて行く事が出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんでもない、ただ見るのが好きなばかりでした……」と、準之助は、あわてて打ち消した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだと僕はたいへん心苦しいんですが……」　しかし、前川のぎごちない言葉半ばに、新子は静かに首を振って、打ち消した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」圭子は、あわてて打ち消した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」前川は、あわてて打ち消した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめまして、僕は三島譲といふもんですが、」　譲が云ひはじめると女は手をあげて打ち消した。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつこく迫っていた順平に、いつかは許してもよいという気があるいは心の底にあったのではないかと思われて、しかし之は余りに滑稽な空想だと直ぐ打ち消した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の頭は未だ健全なんだ」自分で自分の言葉を打ち消した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、土門の言うことだから、出鱈目にちがいないだろうと、あわてて打ち消してみたが、しかし、先刻土門がそわそわと小屋を出てしまったのは、舞台の銀子を見てなにか察したのであろうと思えば思われたし、それに、ふざけた調子ではあったが、土門の電話での抗議ぶりには、いくらか本当めいたものがあるとも思われた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君は、じぶんのばかげた考えをうちけした。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まさか、そ、そんなことはありません」と和太郎さんは、おかあさんがそばにいるので、あわててうちけしました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、和太郎さんがいくらうちけしてもむだでありました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
