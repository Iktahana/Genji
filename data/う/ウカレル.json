        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――大師匠だと恐入っても、その場の事は察し入っても、飲んだ酒にも酔えば、娘子には浮かれるわ……人間ですもの。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "花と酒、君も浮かれる春の季節に、たのしめ一瞬を、それこそ真の人生だ！",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ者ども、うんと浮かれるがいいぞ、おれたちの祭りが来たのだ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "○レビゾールに間違われるフレスターコフにロイド目鏡をかけさせ、世紀末的にひょろ長い体の線を強調させ、蜘蛛のように馬鹿馬鹿しく陰鬱で、皆がこの若者を中心にして浮かれるところ、音楽を入れて、妙に複雑なゴーゴリの雰囲気を出した。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしさに浮かれる風狂の士か。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱虫ばっかりそろっていて――」　丹波の苦笑の顔を、月に浮かれる夜烏の啼き声が、かすめる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、上方の人は端の思はくに頓着しないで、浮かれる時は老若男女が體裁を構はず浮かれ拔くのが常であるから、此のあたりではこんな姿もさほど珍しくはないのであらう。",
              "citation": {
                "source": "二月堂の夕",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうちから、いつもになく浮かれるとか、はしやぐとか、萎れてゐるとか、心配さうにしてゐたとか――」「いえ、そんなことはありません」　平次の問ひを、母親のお組は強く否定しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵のうちから、いつもになく浮かれるとか、はしゃぐとか、萎れているとか、心配そうにしていたとか――」「いえ、そんなことはありません」　平次の問いを、母親のお組は強く否定しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "好意をよろこぶのは人の礼で、自然、宴に浮かれるのは旅情であるとしているような両使だった。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "又コクリの上に卵を載せると良く踊り、三｜絃を弾くと大いにうかれる。",
              "citation": {
                "source": "狐狗狸の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女のうかれ勝な心、うかれるかと思えばすぐ沈む。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、樹明君と磯部君とを招いて残肴残酒でうかれる、うかれすぎてあぶなかつたが、やつと散歩だけですました、めでたし／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉にうかれる佳子が雛菊寮の中の共産党毛ぎらいのふん囲気におのずから一致しかねているところも無理がない。",
              "citation": {
                "source": "『労働戦線』小説選後評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりのぼせぬまでにうかれるのも春は良いものじゃワお身の唇はその様にうす赤くて――はたから見ても面白い話が湧いて来そうに見える。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで月夜｜鴉のうかれる声。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野公園では咲き誇る桜の下で、花見客がうかれる陽春を、私はうすぎたない冬服姿で、もらった十銭玉が汗をかくほどにぎりしめ、赤げっとを小わきに抱いて、とぼとぼ歩き出した。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
