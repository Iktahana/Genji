          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "科学者がその方則を述べる字句の巧拙や運算の器用不器用は必ずしもその方則の価値と比例しないのと一般であろう。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでキッコはその鉛筆を出して先生の黒板に書いた問題をごそごその藁紙の運算帳に書き取りました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕そして教壇へ行ってテーブルの上の白墨をとっていまの運算を書きつけたのです。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなちょっと運算してそれからだんだんさっと手をあげました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると三郎は、どこから出したか小さな消し炭で雑記帳の上へがりがりと大きく運算していたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理には五分もすきはなく、数学の運算に一点の誤謬はなくても、そこに取り扱われている「天然」はしんこ細工の「天然」である。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "算術の最も易い寄せ算をするにしても、散る氣でもつて運算して居たら、桁違をしたり、餘計な珠を彈き込んだり仕さうな事である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "算盤で運算しようとしても、気が散れば必ず過失を生じがちである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また気が弛めば必ず運算するのに明敏ではなくなりがちである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "数その物は確実であっても数を算出する運算の方式は必ずしも正しいとは信じられない、」と。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「覆面算」といふのは、數字が虫に喰はれて穴があいてゐるのではなく、文字又は符號の覆面をつけてゐる運算なのであつて、皆さんたち名探偵はその覆面を推理の力で叩き落として數字を剥し出すのだ。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、一金五萬兩也、右借用候事しかじかといふやうな一本建の數値だけがあつてそのうちの數字が虫に喰はれてゐるのでは、探しやうがないが、もしそれが加減乘除の運算書であれば、その一部が虫に喰はれてゐても、前後の關係から推理によつて正確に判別することができる。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しばらく氣を落着けて、じつとこの運算書を眺めてゐると、うまい手懸りがだんだんと見つかつてくるのである。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで運算書の中のＳを０として再び書き改める。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあこの邊で、原運算を整理して下に示して置かう。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでにお話して參つたやうなシャーロック　ホームズ探偵的な解き方ではなく、その運算書から多元の聯立方程式を得、それからばりばりと解いていく方法もございます。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、一金五万円也、右借用候事しかじかというような一本建の数値だけがあってそのうちの数字が虫に喰われているのでは、探しようがないが、もしそれが加減乗除の運算書であれば、その一部が虫に喰われていても、前後の関係から推理によって正確に判別することができる。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しばらく気を落着けて、じっとこの運算書を眺めていると、うまい手懸りがだんだんと見つかってくるのである。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあこの辺で、原運算を整理して下に示して置こう。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでにお話して参ったようなシャーロック・ホームズ探偵的な解き方ではなく、その運算書から多元の聯立方程式を得、それからばりばりと解いていく方法もございます。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、自然の前で仕事をなす画家は、どんな味が最後に画面に盛られるか、如何なる答がこの運算によって現れるかを知らない場合が多い。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで力ある作家は、複雑なる運算によって答に必要なものを吸収するが、頭の悪い作家は、あるいは基礎的工事を欠く処の作家は、必要なものまでも捨ててしまい、捨つるべきものを拾って見たり、結局画面は混雑してただ心の亡霊と自然の糟だけが画面に漂う。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子構造としてのあらゆる運算の研究。",
              "citation": {
                "source": "線に関する覚書６",
                "author": "李箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方の壁を黒板にして、そこへ生徒が総出になって運算を書きつけている。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この和算がなぜ西洋の数学に変えられたかと云うことについては、いろいろの理由もあるのですが、大体には運算の方法がめんどうであったり、またごく特別な問題だけを主にしていましたので、それよりも広い西洋の数学で置き換えられることになったのでした。",
              "citation": {
                "source": "關孝和",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は徳目の運算なのだから教科書も可能だし試験も可能だ。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が道徳内容を一時的にしろそういう固定物に転化することは、つまりその後之を公式として運用するためでしかない筈だが、そうならば之は道徳を例の徳目運算におきかえることに他ならない。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば旧教に対する新教というものの関係は、謂わば或る力学の基礎方程式の運算を学ばせるものとしてもっと近く学ぶべきですね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの交響曲は、一つの抽象的な論法であって、算術の運算のようなふうに、主題がたがいに対立しあるいはつみ重なってるがように、彼には思われたのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
