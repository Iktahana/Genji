[
  {
    "uuid": "10ebde65-1ee7-5d90-9bc4-9a46c34380e7",
    "entry": "嬉しがる",
    "reading": {
      "primary": "うれしがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
