    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to seem glad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「常に孤独で居る人間は、稀れに逢う友人との会合を、さながら宴会のように嬉しがる」とニイチェが云ってるのは真理である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しがる、自慢をする。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そのかわり、今ね、憤るなよ……お転婆な、きみが嬉しがる、ぐっとつかえが下って胸の透く事をしてお目に掛ける。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何にしても、これなら先方だって充分嬉しがるに違いない。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常に孤独で居る人間は、稀れに逢ふ友人との会合を、さながら宴会のやうに嬉しがる」とニイチェが言つてるのは真理である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も多い中には万年筆道楽という様な人があって、一本を使い切らないうちに飽が来て、又新しいのを手に入れたくなり、之を手に入れて少時すると、又種類の違った別のものが欲しくなるといった風に、夫から夫へと各種のペンや軸を試みて嬉しがるそうだが、是は今の日本に沢山あり得る道楽とも思えない。",
              "citation": {
                "source": "余と万年筆",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを無理に嬉しがるのは、何だかありもしない翅を生やして飛んでる人のような、金がないのにあるような顔して歩いて居る人のような気がしてならなかった。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが長次、お前も十七、虹蓋つくる奴等が手筋も大方知つてゐようが、世の中は千人寄つても盲ばかりの素人たち、見かけ倒しの品物でも異つたものを嬉しがる馬鹿さ加減つたらねえ！",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、好事にも、わざと自分の腰をずらして、今度は危気なしに両手をかけて、揺籠のようにぐらぐらと遣ると、「アハハ、」といよいよ嬉しがる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟々視ればどこにか俤が似通って、水晶と陶器とにしろ、目の大きい処などは、かれこれ同一であるけれども、英吉に似た、と云って嬉しがるような婦人はないから、いささかも似ない事にした。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘が惚れた男に添わせりゃ、たとい味噌漉を提げたって、玉の冠を被ったよりは嬉しがるのを知らねえのか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毛利さんに妹さんがあったら、きっと綺麗な人だと思うわ」　と、相手の嬉しがるような言葉を口に出しかけた多鶴子が、不意に顔色を変えて言葉をのみこんだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「臨海亭のお客さんだ、お客さんだ」　益雄は何故そんなに子供が嬉しがるか判らなかった。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥の空で雲が動くように、大浪の間に帆が一ツ横になって見える時分から、爪立つものやら、乗り出すものやら、やあ、人が見える、と手を拍いて嬉しがるッていう処でさ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとよさんは、わたしがいくとそりゃ嬉しがるの、いくたびにそうなの、人がいないとわたしを抱いてしまうの、それでわたしが帰る時にはどうかすると涙をこぼすの」　おはまからこれだけの言を聞いたばかりで、省作はもう全身の神経に動揺を感じた。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "菖蒲湯に這入って粽を食った時は、僕はいつでも此日本と云う国が嬉しくて堪らなくなるな」　岡村は笑って、「君の様にそう頭から嬉しがって終えば何んでも面白くなるもんだが、矢代君粽の趣味など嬉しがるのは、要するに時代おくれじゃないか」「ハハハハこりゃ少し恐れ入るな。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人が何と教へて見た所で本當にしませんし、揶揄つたら面倒だしそれよりか嬉しがるやうなことに仕向けた方が當り障りがありませんからね………………」　女房は語り續ける。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは無邪気なＩ子が、殊にもさう云ふことを嬉しがる人の好さをもつてゐるからであつた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しがる時はこれつきり無いと思ふとね。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　延子は決して訝しがる様子もなく反つてその無頓着を嬉しがるやうに、「あなたは本を読み出すと夢中なのね、さつき電話の時もさうだつたんでせう。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さつきは、この飛び方は照子に見られなかつたのかも知れないぞ……さうだとするとまた一つ余外な弱味を握られてしまつたものだ、あゝ止せばよかつた――と、私は気付いたが、余り照子が嬉しがるので、加けにこの方が余程安楽だつたので、ヤケ糞の余り調子づいて、更に妙な格構をして飛びあがつた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那の仰しやる通り日本のやうな猶だ男女七歳にして席を同ふせざる封建道徳の遺習が牢乎として抜くべからざる国で、若い女の許へ臆面もなくノコ／＼サイ／＼やつて来るはどうせ軽薄な小才子か、女の御用を勤めて嬉しがる腰抜の無気力漢だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "月雪花は魯か犬が子を産んだとては一句を作り猫が肴を窃んだとては一杯を飲み何かにつけて途方もなく嬉しがる事おかめが甘酒に酔ふと｜仝じ。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼が嬉しがると、小学生はてれてしまった。",
              "citation": {
                "source": "鳩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も彼は、父が嬉しがるやうに、出来るだけその時の母の言語や動作に尾鰭をつけて芝居もどきに喋つたのだ。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ふ迄もなく、金春家の主人は香道には極の素人で、今時の文学者と一緒に蚊取線香の匂ひを嬉しがる方の男だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女といふものは、どんな人の墓よりも栗のきんとんの方を嬉しがるものだといふ事をその男はよく知つてゐたのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来の外交はもはやジュネヴで演説をしたり、たんかを切ってうれしがるだけではすまなくなるであろう。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さま、どんなにうれしがるかしれねえ！",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見せてよ」　と死んでも見たくない思いでそう言えば、あら、いやよ、あら、いやよ、と言って、そのうれしがる事、ひどくみっともなく、興が覚めるばかりなのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
