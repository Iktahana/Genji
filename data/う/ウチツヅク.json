[
  {
    "uuid": "a779397e-4932-54bd-8e40-b8d9d51afa4e",
    "entry": "打ち続く",
    "reading": {
      "primary": "うちつづく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
      ],
      "ctype": null,
