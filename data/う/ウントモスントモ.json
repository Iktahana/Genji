          ],
          "literary": [
            {
              "text": "「己アたつた今ゼツテルベルグさんのところを訪ねて來たんだが‥‥」　と、カアルソンは息を切らしながら、「と、ところが、臺所にやアちやんと電氣がついてるのに、うんともすんとも返答がないんだよ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙って放って置くと、それきりお前はうんともすんとも言って来なかった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんともすんともいう間はないのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしどもの方が先に教会へ着きまして、やがて四輪が着くと、わたくしどもはあの方が降りてくるのを待ったのですが、うんともすんとも。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はうんともすんともいわなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句が好きなんだそうで、夜、寝る前に松右衛門殿にさまざまの近作を披露して、その感想を求めたけれども、越後は、うんともすんとも答えぬので、清七殿ひどくしょげかえって、さっさと寝てしまったが、あの時は可哀想だった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、起っている人間が、うんともすんとも言わずに即死するわけは絶対にありません。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では下田の細君が、どんどん木戸を叩いて呼んでいるのに、林の家ではうんともすんとも返事がなかった。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、寝台の上に横たわっている杉田二等水兵が、まるで黙ったきりで、何を話しかけてもうんともすんともいわないからである。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワロージャがうんともすんとも云えないうちに、　――ナターリヤ・イワーノヴナ！",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きないんなら母さんに起きて貰わなくちゃ駄目じゃないの」　姉がうんともすんとも云わないのを見て、登美は隣室へ襖越しに叫んだ。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんともすんとも返事無之候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに「うんともすんとも返事無之候」であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしこのキット、組み立て終わってもそれ自体では、うんともすんともいってくれない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも帰って来ると上機嫌で饒舌をするのに、今日に限ってうんともすんとも云わずに、黙アって坐りこんで、毒でも食べるように不味そうに夕食を食べてさ。",
              "citation": {
                "source": "生さぬ児",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、アカーキイ・アカーキエウィッチは、まるで自分の目の前には誰ひとりいないもののように、そんなことにはうんともすんとも口答え一つしなかった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はお桐は偉う楽やら、うんともすんとも音がせんな。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから差向で十二時近く迄やつて居るが、亭主の方は勝つても負けても、うんともすんとも云は無いで、念入りに考へて札を打つ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはこれが本當の叔母さんだつたらいいなあといふ人のことを、小説の中で勝手に本當の叔母さんにしちやつたんですが、今度は、私はうんともすんとも言はず、ただどつちつかずの、すこし悲しさうな微笑をして見せました。",
              "citation": {
                "source": "嘉村さん",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど、ぎゃんぎゃんやかましいことをいった蟻田博士が、その後うんともすんともいってこないことだった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸木は、うんともすんとも返事をしなかった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中漂流以来、戦友戸川のことを思い出し、こっちもこんどは一つ細心且沈着にいこうと努力をつづけてきたわけだが、たかが無電器械一つと思うのが、どうしたってこうしたって、うんともすんとも直りはしないのだ。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういくら呼んでも、うんともすんともいって来ないのである。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にか、トルコだか、どこだかへ転任をして、うんともすんとも云はずしまひです。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも早く目ざめる父が今日に限って、うんともすんとも云わないのを不審に思い、しずかに襖をあけました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その白いものはうんともすんともいわず、身動きひとつしません。",
              "citation": {
                "source": "こわいことを知りたくて旅にでかけた男の話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんともすんともいわず、ぼろ着物はもえほうだいです。",
              "citation": {
                "source": "こわいことを知りたくて旅にでかけた男の話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は大声をあげてさけぼうとしましたが、どうしたものか、うんともすんともいうことができません。",
              "citation": {
                "source": "マリアの子ども",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰一人訪れるものもない家、ひっそりと静まりかえって、晩秋の淋しい陽射しに、庭前の雑草の花のみがいたずらに咲きほこっている草葺家の中に、彼女はひとり閉じこもったきり、うんともすんとも音を立てなかった。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞が気をきかして、絶えずあれこれと注意してくれればよささうなもんを、これがまた、わいわい云ふ時には云ふが、云はん時にはうんともすんとも云はんので困る。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
