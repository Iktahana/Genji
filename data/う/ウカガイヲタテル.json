    "definitions": [
      {
        "index": 1,
        "gloss": "to ask for instructions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
