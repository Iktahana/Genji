        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同じ産神様｜氏子夥間じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の氏子のこの数々の町に、やがて、あやかしのあろうとてか――その年、秋のこの祭礼に限って、見馴れない、商人が、妙な、異ったものを売った。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余りの事ゆえ尋ねるが、おのれとても、氏子の一人じゃ、こう訊くのも、氏神様の、」　と厳に袖に笏を立てて、「恐多いが、思召じゃとそう思え。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、銑吉のごとき、お月掛なみの氏子をや。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒は粒でも、ピリッと辛いぞ、これでも勇みの山王の氏子だ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが「氏神」と「氏子」といふ関係の発生した一原因である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭典は従来氏子人民好んでこれを全うし、崇敬も実意のあらん限り尽しおれり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、合祀されし社の氏子、遠路を憚り、ことごとく合祀先の社へ参り得ざるをもって、祭日には数名の総代人を遣わすに、多勢に無勢で俘虜降人同然の位置に立つをもって、何のありがたきことなく早々逃げ帰る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、多年等閑に付し来たれる神社を、一朝厳命の下に、それ神職を置け、基本金を積めと、短兵急に迫られし結果、氏子｜周章、百方工夫して基本金を積み存立を得たるも、また値上げ、また値上げとなり底止するところを知らず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "従前と変わりしこともなければ、氏子また策を運らし、俸給を定規より少なく神職に与え、ないよりは増しだろう、ぐずぐず言わば合祀するぞ、と今度は氏子より神職を脅し、実際は割引で与えながら規定の俸給を受けおるような受取証を書かすこと。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて焼けたる諸社の氏子へ一向通知せず、言わば神社が七十二も焼けたるは厄介払いというような村吏や神職の仕方ゆえ、氏子ら大いに憤り、事に触れて、一カ月前にも二大字｜合従して村役場へ推しかけ荒々しき振舞いありし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩故障を容れしに、氏子総代、神主と一つ穴で※言揚々として、むかしよりかかる英断の神官を見ず、老樹を伐り倒さば跡地を桑畑とする利益おびただしとて、その時伐採り見て哭きし村民を嘲ること限りなし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に基本財産というべき金なくとも、氏子みな入費を支弁し、社殿の改修、祭典の用意をなし、何不足なく数百年を面白く経過し来たりしなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾邦に金羅比丘あり、獨處專念を稱せられた（増一阿含經三）是も鰐を奉じた氏子だらう。",
              "citation": {
                "source": "毘沙門の名號に就いて",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、氏神、本殿の、名剣宮は、氏子の、こんな小僧など、何を刎ねようと、蜻蛉が飛んでるともお心にはお掛けなさいますまい。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "當日は白い狩衣の神官が獨で氏子の總代といふのが四五｜人、極りの惡相な容子で後へ跟て馬場先を進んで行つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "神官が卓の横手へ座を換て一寸笏で指圖をすると氏子の總代等が順次に榊の小枝の玉串を持つて卓の前に出て其の玉串を捧げて拍手した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氏子の住所は蛇なく、他の神の氏子の住所は、わずかに径を隔つも蛇棲む。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうでもないと、うじうじこねくり廻しておるのが分別じゃと言うわ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみ　　ひゆうじこつけ……！",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この箱の中には、おそろしい秘密がふうじこんである。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鉄の箱の中には、三つの書きものがふうじこめてあった。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、まだ字のかけるあいだに、この遺言書をかいて、鉄の秘密箱をつくらせて、保険会社の証書と、ほんとうに大洋丸の沈んでいる場所をしるした海図といっしょにふうじこんで、じぶんのひとりむすこにのこした。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
