        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "殊に両人ともまだ琉球のことばを忘れて居ないで、たやすく思ふまゝに言ふことが出来て居たといふことは謝源をムシヤウに嬉しがらせた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに気をまわせば、吉弥は僕のことについていい加減のうそを並べ、うすのろだとか二本棒だとか、焼き餅やきだとかいう嬉しがらせを言って、青木の機嫌を取っているのではないかとも思われた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きっと身受けして本妻に」　と行く先々で嬉しがらせる金鎖……。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハツハツハ……五十三で死んでしまつては親父も気の毒には気の毒だが、それもまア好いだらうさ、あと十年生きたところで僕が親父を嬉しがらせることがあるとは思へない。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて、新調の羽織、袴を着て出かけることが滝野を可成り嬉しがらせた。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はこんな事で若い寡婦を嬉しがらせる事なら、自分達の顔一杯｜楽書をしても苦しくないと思つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お玉はこのおばあさんを担ぐつもりずらに」　とおげんは笑って、あまりに突然な姪の嬉しがらせを信じなかった。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "後生ですから『奥さん』だけは廃して頂戴よ」　こころやすだてから出たこの御言葉は、言うに言われぬほど男の心を嬉しがらせたようでした。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんまと一杯ひっかかったと思ったが、米粒と豆の技が美事だったのと、父のことを言って嬉しがらせようというその心根に好意がもてたので、その場で――ちょうど秋だったので、一、二枚の紅葉をその画帳にかいてあげた。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎんの手足を綺麗だとほめて顔が火照るほど嬉しがらせたりした。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある折、一段語りおえて、親たちを嬉しがらせたあとで、「御褒美のかわりにお酒が飲みたい」といって、七歳のおそのやんが生一本の灘の銘酒を五合ばかり飲んで、親たちや養母を驚ろかせたりした。",
              "citation": {
                "source": "竹本綾之助",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "小町　まあ、あんな嬉しがらせばっかり！",
              "citation": {
                "source": "二人小町",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　意地の強い僕は母を嬉しがらせるよりもなるべく自我を傷けないようにと祈った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは美人だなア、とか、教養が高くて僕の始めての驚異の女性だなどゝ嬉しがらせを言つて帰る。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それそれ、面白いぞ、手んぼうの方へ加勢が出た」　その加勢は幸いに無勢の方へ出たのだから、見物を嬉しがらせました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで後見がおれば、太夫さんのために面白おかしく芸当の前触れをして看客を嬉しがらせるだろうけれど、米友にはさっぱり後見が附いていません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫自身にも、見物を嬉しがらせるようなチャリが言えないから、ただ眼を円くして見下ろしているばかりです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の話は嬉しがらせの駄法螺だろう。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からそれを楽しみにしているというような嬉しがらせの文句が書いてあった。",
              "citation": {
                "source": "心づくし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともお前さんのくるのを知って、念入りの化粧ッてところか」「嬉しがらせは殺生でげす。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の怨めし気な表情は堪らなく彼を嬉しがらせた。",
              "citation": {
                "source": "乗合自動車",
                "author": "川田功",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼の声音や幸福そうな笑顔で、私の訪問がひどく彼を嬉しがらせたことがわかった。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子を嬉しがらせるほか能のない、生ッ白い青二才とばかり思い込んでおったのが、あの、俺に髪を取られた顔を上げた時の、豪快な笑い声はどうだ！",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く好い所を見つけて嬉しがらせてやりたまえ」　彼はただこう云っただけで、取り合う気色もなかった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂の主の御来臨だぞ』と低い声で『うんとおだてて嬉しがらせてやれよ』　友達はあどけない顔をして私の傍にまいり『僕、小母様を、××宮妃殿下のお忍びかと間違えちゃったあ』と云うのです。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地では「昔の御領主様」などと、嬉しがらせてくれた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "）としての、初日の不揃いとか、幕間の長いとかいうような見物心理の圧制から解放されて、気の短い、頭の正直な見物を嬉しがらせたことは非常なものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "よにもさむしくふしぎな魅力にみちた「青猫」はかくして生れ出で、かくして人々のたましひをいうわくし、うれしがらせさみしがらせ、むずがゆがらしめる、死ぬまでうれしくむずがゆがらしめる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩とは、人々の魂を迷はし、うれしがらせ、殺すことであるか。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのくちばしで、とんちをふりまいて人をうれしがらせる。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
