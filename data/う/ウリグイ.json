    "definitions": [
      {
        "index": 1,
        "gloss": "living by selling off one's possessions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
