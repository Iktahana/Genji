          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "実は熱海の駅で汽車を待っているあいだに、休み茶屋へ飛び込んで、ビール一本と何だかの罎詰一本、まさかに喇叭は遣らないけれども、息もつかずにぐっと聞こし召して、その勢いで猛烈に、かかる山路へ突貫して来たのよ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、熱海の駅である。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の駅で客ひきしてる一寸法師の妹を知らねえかア。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此米山の腰を米山｜嶺とて越後北海の駅路なり、此｜辺古跡多し。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀郷出兵　征討軍が、都を発向したのは、一月二十七日であり、二月上旬には、もう大行軍の列が、東海の駅路を、東へ東へ、蜿々と、急いでいたはずである。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
