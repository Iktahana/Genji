        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鞍山站の馬鞍のような山が暗くなって、その向こうから砲声が断続する。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心皆あらたまりて、たゞ馬鞍をのみ重くす。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "くるしといへども、馬鞍牛車と心をなやますにはしか（二字似イ）ず。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間五十年、化転の内をくらぶれば、夢まぼろしのごとくなり――」　桶狭間の決戦にのぞみ信長の舞った敦盛の謡いが、本能寺を見ている矢代の口にも自然にのぼって来て、躊躇するものの轡すべてを彼は切り落そうとし、馬鞍を叩く手つきで窓枠の縁を打った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "食牛羊皮襖、靴箱、馬鞍。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "平治以来、螺鈿を鏤め金銀を装ひ、時流の華奢を凝したる、馬鞍刀槍も、是唯泰平の装飾のみ。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一空さまが、通新石町から馬鞍横町へ折れて、小柳町、鍋町東横丁と過ぎて不動新道へはいると、和泉屋の総本店はすぐ眼についた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大納言殿のお供で必ずや参るであろうからと再会を楽しみにしていたのに、何で又来てはくれなかったのであろう、知行の庄園始め、馬鞍、その他、数々の引出物まで用意して待っておったのに」　といかにも残念そうであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『経国大典』に当時下官の者に銀入糸の馬鞍を禁止した旨が記してあるから、この錠も一般庶民の用品ではなかったことが推察される。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "使司馬鞍首止利仏師造。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一族の老武者、若武者、またお旗本やら、近習やら、それぞれのお役の者やら、金銀の馬鞍、青貝の鏤め、蒔絵の光、開いた傘、つぼんだ傘、弓とうつぼの群、鉄砲の筒の列、赤柄の槍の林……。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、全軍みな紅の旗をさし、真っ先に立った一名の英雄も、兜、鎧、剣装、馬鞍、すべて火よりも赤い姿をしていた。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし折よく彼を慕ってきた味方の救いが間に合ったので、だんだんと厚い囲みに守られ、馬鞍山をさして逃げ落ちた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐るべきは陸遜だ」　時すでに遅く、彼が天を仰いで痛嘆したとき、その陸遜の軍は、馬鞍山のふもとを厚く取り巻いていた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当節流行の合巻のはじまりは、あっしの「雷太郎強悪物語」でげすが、あれは浅草観音｜利益仇討というまくら書きがありやすとおり、敵うち物でげす。",
              "citation": {
                "source": "仇討たれ戯作",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
