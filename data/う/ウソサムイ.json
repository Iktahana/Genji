        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その頃の隅田川岸と言へば自分の記憶にもぼんやり浮ぶが、低い家の立ち並んだ薄暗い泥の道、晩秋のうそ寒い川風の中をトボトボと辿り行くであらう寂しい葬送行進曲！",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "らんの根もとには卵のからがふせてあって、それに道のほこりがつもって、うそ寒いように見えました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭の根もとには卵の殻が伏せてあつて、それに道の埃がつもつて、うそ寒いやうに見えました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど秋の末、葉をすつかり払ひ落されて丘の上に、うそ寒い風に吹かれて立つてゐる一本の木のやうに、自分の心が何のよるべもなく、ぽつんとこの世界に取残されてゐるやうな感じであつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それほどの師にすら、秋成の現実の対照に向つては、いつも絶対の感情の流露を許さぬ習癖が、うそ寒い疑心をもち＝＝師のいひし事にもしられぬ事どもあつて、と結局は自力に帰り、独窓のもとでこそ却て研究は徹底すると独学｜孤陋の徳を讃美して居る。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣の乾きにもう初冬の色を見せている堀川は黒い水の上にうそ寒い夕靄を立てゝいます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは何とも知らずこの寮にうそ寒い怯えを感じました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、もしその気配に自分の熱情が揺がされでもしたら、自分が何か非常に卑しい軽率な存在にでも見えだすかも知れない――そう思うとかの女はかすかなうそ寒いような慄えに全身をひきしめられた。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　鮮かな緑の低い丘陵、そのところどころの黒と立枯れのうそ寒いとど松林、それだけの眺めの下に、ぽつぽつと家が五、六戸。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太は八月でも雨のふる日はうそ寒い。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰白色の搖動く幻だけが此の島の主となる日を考へると、妙にうそ寒い氣持がして來た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の上には明暗の交ったうそ寒い光が漂っているようだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰白色の揺動く幻だけがこの島の主となる日を考えると、妙にうそ寒い気持がして来た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、いかにも麗らかさうに話頭を転じたが、話してるうちにまたも背中の方からゾーツとするうそ寒い陰気に吹き寄せられて敵はなくなつて来た。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜巻村の村長から兼て噂に聞いてゐたところの、風鈴湯といふ聴くだに今季うそ寒い山峡の沸し温泉を目ざした。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫の手術着の肩のあたりは、醜く角張って、なんとも云えないうそ寒い後姿だった。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそ寒い夕方、台所の露次で、他所の犬が来て、マルの乳を吸っていることもあった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそ寒い冬の黄昏が白い窓掛の外に迫つて居て、モウ薄暗くなりかけた室の中に、種々器械の金具が侘し氣に光つて居る。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "うそ寒い冬の黄昏が白い窓掛の外に迫つて居て、モウ薄暗くなりかけた室の中に、種々な器械の金具が佗し気に光つて居る。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋がふかうなる――ソデナシを着てゐてもうそ寒い――雨が落葉をたゝいて虫がないてゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "病中・ともかくも生かされてはゐる雑草の中・をんな気取つてゆく野分ふく・蛇がひなたに、もう穴へはいれ　十一月七日うそ寒い風がふいて晴れてくる、蒲団を干す、と、またしぐれてくる、柿の葉が生もののやうに舞ひ散る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひえ／″＼として、単衣一枚ではうそ寒いので襦袢をかさねた、夜は蒲団をだして着た。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はうそ寒い、一杯やりたいな、ゼイタクをいふな！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一枚の炭素紙みたいに古い建物の並列を押しつけて、真夏だというのに、北のうす陽は清水のようにうそ寒い。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき／＼て倒れるまでの道の草・酔ひざめの星がまたゝいてゐる（野宿）　風が出てうそ寒い朝がやつてきた・夕寒の豚をひきずりまはし・すこし熱がある風の中を急ぐ　跣足の子供らがお辞儀してくれた三日振に湯に入つて髯を剃つて一杯ひつかけた、今夜はきつといゝ夢をみることだらう！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "また雨だ、うそ寒い、何だか陰惨である、しかし庵は物資豊富だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "林間に散つてゐる黄葉と、林梢に群つてゐる乱鴉と、――画面のどこを眺めても、うそ寒い秋の気が動いてゐない所はない。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "林間に散っている黄葉と、林梢に群がっている乱鴉と、――画面のどこを眺めても、うそ寒い秋の気が動いていないところはない。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本を発つ時は、うそ寒い陽気だつたのに、海防から、河内、タンノアと南下して来るにつれて、急に季節はまた夏の方へ逆もどりしてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "・百舌鳥のするどくその葉のちるや　　　老祖母追憶・熟柿のあまさもおばあさんのおもかげ　南天の実のいろづくもうそさむい朝・空はゆたかな柿のうれたる風のいろ　十月九日酒、酒、そして酒だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
