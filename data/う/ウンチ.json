        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "タヴェルニエーの『印度紀行』に、ウンチミッタ辺で毎朝蝋のごとき粗製の黒砂糖と麦粉と牛酪を練り合せて泥丸となし、馬に嚥ましめ、その後口を洗い歯を潔めやると見え、サウシの『随得手録』二には、麪麭で馬を飼った数例を挙ぐ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊やは、ウンチがでないかね」「また、オジチャン、泥亀をとるんだろう。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の文学的ウンチクを示すようにいい順で一つよませて上げたいと考えて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何から何まで一知半解であるが、チリもつもれば何とやらで、一知半解のウンチクは頭にあふれ、書物は書斎にあふれている。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一知半解のウンチクも馬脚を現す心配がないばかりか、ことによると、彼ですらも何かの新発見ができるかも知れない処女地のようであった。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクの推理によれば、これには深刻なるカラクリが隠されてるね」　タコスケがまた名タンテイのウンチクをかたむけてみせた。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "九州の人がきけば小倉をオグラと読みながら造詣もウンチクもあるまいと思うであろうが、早い話が、小倉百人一首というように、実は小さな倉と書いてオグラと読むのが一般的なのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は仮病を使って一室にこもり、ウンチクを傾けてアチャラカの脚本を書いた。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のウンチクは学ではなくて育ちであった。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はサッと踊りでゝ、中央の先頭に立ち、フラダンス、ヴギウギ、アクロバット、ウンチクを傾けての合成品、ヘッピリ腰で踊りまくり、一同が引っこんでからも、一人残って熱演。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は孔子様の学説についてウンチクがあるそうじゃないか。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史的事実に拠ってウンチクを傾けたのであるが、ウンチクが不足であるから、ちょッと傾けると、たちまちカラになる。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "老蝮はさっそく御礼に参上して、最も熱心に、そのウンチクをかたむけて、あれかれと政治むきの助言をしていた。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯者曰く、お前さんも斯界の古老であるから（というのは病気を診察した古老じゃなくて診察された古老だということさ）経験を生かして、大いに語るべきウンチクがあるでしょう。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、山登りのお弁当について、若干ウンチクをかたむけようかと思います。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三方損の三人目とか、覆水盆にかえらずとか、近代イソップ物語の原理についてウンチクをかたむけたいところがあるですが、今日は急ぎますから、失礼します。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユウンチュとユウシとは偶然の暗合だろうが、音が非常によく似ている。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初あの委員達の会合の席上で、「小説戯曲中の人物で、墓や記念碑を建てられたものが幾人あるだろう」という、「話の泉」的な問題が持ち出され、大いに若い委員達のウンチクを傾けたことであった。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物帖談義",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、これらの「先輩たち」は、よい気になってゴマカしているけれど、演劇芸術家としてのウンチクや経験など大したものは持っていない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、ドブ釣りのアユと、友釣りのアユは……」　独特の、手の振り方を交えながら、三十分でも一時間でも、ウンチクを傾ける。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "事、石神（シャグジとよむよ）道祖神に関しても、拙者年来のウンチクがあって、帝釈様の御神体なぞ、余アマネクこれを知るｅｔｃの学がある。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　シュルレアリズムのウンチクも及ばないのは仕方がない。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩作の情熱は高鳴っても、詩の体となすべき言句にウンチクがないから、ピカドンの徒は詩はダメです。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
