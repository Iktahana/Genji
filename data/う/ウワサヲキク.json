[
  {
    "uuid": "148d3ab7-e238-5cb1-aef8-1053c49bf57b",
    "entry": "噂を聞く",
    "reading": {
      "primary": "うわさをきく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
