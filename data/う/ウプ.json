        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "動画をうｐするのに時間がかかりました。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、声は、もうぷっつり聞えなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集は大きな感情をもつたひとつの浪のやうなものだどこへでも流れてゆくひとつのさかんな意志と愛慾とのぐるうぷだ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへでも流れてゆくひとつのさかんな意志と愛欲とのぐるうぷだ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりは地面にこぼれ、くぼんだところにたまって、いっそうぷんぷんとよいにおいをさせました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふとった男はこう言って、にたにた笑いながら、いきなりぷうぷうふくれ出して、またたく間に往来一ぱいにつかえるくらいの、大きな大きな大男になって見せました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いきなり、ぷうぷうとからだをふくらして、とうとう泉一ぱいにふくらんでしまいました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外で気に喰わないことがあって、家でそうぷりぷりするものじゃないよ。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくもく勝ったぞ」「ぷうぷうぷうぽうぽうぷう」　らっぱは千三の伯父覚平で、叫んでるのは善兵衛である。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぷうぷうぽうぽう」とらっぱが鳴った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぷうぷうぽうぽう」「バンザアイ」　こうなってくると黙々隊は急に活気づいてきた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……清き心のますらおが、剣と筆とをとり持ちて、一たびたたば何事か、人生の偉業成らざらん、ぷうぷう、豆腐イ、ぷうぷう」　　　　　　　　　十一　柳一家はいつも幸福に満たされていた、光一の心はいつも平安であった、かれの一番好きなのは朝である。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "山木と河合とがその方を見上げると、ネッドはいつの間に服装をかえたのか、頭には赤いターバンをぐるぐる巻き、身体にはぞろりと長く引摺ったカーテンのような衣を着、いやに取済ました顔付をしていたが、山木たちがあまりいつまでも見つめているものだから、はずかしくなって、とうとうぷっとふき出した。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "はうぷとまんなどの流儀を取り入れる先に、これが可なり素質的に歌舞妓に合ふものがあつて、どうかすれば、却て煩ひになりさうな点すらも感じられるのである。",
              "citation": {
                "source": "花の前花のあと",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、祖母にて、ふぢい又は、ぷぢいは、うふぢい又は、うぷぢいの略にて、大父の義。",
              "citation": {
                "source": "「琉球の宗教」の中の一つの正誤",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近に地獄沢というところがあって、そこは地中からくさいガスがぷうぷうとふきだしていて、一キロメートル四方ばかりは草も木もなく、ただ一面に、灰色の石ころの原になっていた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛矢温泉に湧出る湯も、実はこの地獄沢からぷうぷうふきだしているガスによって、地中で温められている地下水だった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳元では、例の通り、ひゅうひゅうぷくぷくと、火星の生物が、奇声を出しながらしきりに騒いでいた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ひゅうひゅうぷくぷくと言う声が、火星人の口から出ていないで、のどのあたりから出ていることだった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅうひゅうぷくぷくの声は、首と肩とのつぎ目のあたりから、もれて来るのであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると下の方から、また例の、ひゅうひゅうぷくぷくと火星人の声がして、こっちへ近づいて来る様子なので、びっくりしてまたもとへ引返した。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の火星人はまるい頭をあげて、ひゅうひゅうぷくぷくと、喜びの声をあげた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのぷうぷうは豚の仔がないたのではなくて、艇夫長の鼻が鳴ったのであった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒーが、ぷうぷうふいているじゃないか」「あっ、コーヒーのことを忘れていた」　三郎は、大いそぎで、コーヒーのところへとってかえした。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど日当たりのいい縁側に、おばあさんがすわって、下を向いて、ぷうぷうと糸車をまわして糸を紡いでいました。",
              "citation": {
                "source": "おじいさんの家",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、黒いやわらかな土からは、来年さく草花の芽が、もうぷつぷつとみどり色に頭を見せていたのです。",
              "citation": {
                "source": "朝の公園",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯父さん、そうぷりぷりしなさんな」と、甥は云った。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
