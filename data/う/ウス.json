        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何れにしても、それは成つてみれば運命の臼の加減といふほかないのであるが、成つてみるまでは人には各々胸の混沌、直観としてのイデエがあるばかりである。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に私を驚喜させたのは、その水田に臼づくところの、藁屋の蔭の水車であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれでも目につく大室山を先手にして、その後に寄り添って、長尾山、片蓋山、天神山、弓射塚、臼山など、富士山を御本丸として大手からめ手に、火山の出城を築きあげている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし小江の葦蟹を貰ったら辛塩を塗り臼でついて塩にして永く貯えの珍味とする。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺の「ボンネットを一度水車小屋の磨臼に抛り込んだ以上」は、つまり一度｜貞操を売物にした以上は、今さら宿命とか身の行末とかそんな素人臭い歎きは無い。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、牛部屋では、鞍をかけられた牛が、粉ひき臼をまわして、くるくる、真中の柱の周囲を廻っていた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、臼の漏斗に小麦を入れ、おとなしい牛が、のそのそ人の顔を見ながら廻っているのを見届けてから出かけた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苅った稲も扱きばしで扱き、ふるいにかけ、唐臼ですり、唐箕にかけ、それから玄米とする。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「籾擂を機械に頼みゃ、唐臼をまわす世話はいらず、らくでええけんど、頼みゃ、頼んだだけ銭がかゝるんじゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるやかにが出て来たりまた栗のいがや搗臼のようなものまでも出て来るが、それらは実はみんなやはりそういう仮面をかぶった人間の役者の仮装であって、そうしてそれらの仮装人物相互の間に起こるいろいろな事件や葛藤も実はほんの少しばかりちがった形で日常にわれわれの周囲のどこかに起こっていることなのである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂やいが栗や臼がかにの味方になって登場するのもやはり自然の方則に従って出て来るので、法律で蜂と栗と臼の登場を禁じると、今度はさそりやばらやたくあん石が飛び出して来るかもしれない。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきまではばたばたばたばた云ってゐたけれども、もう今はおとなしく臼の上にとまってゐるよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「穂吉さんはね、臼の上をあるいてゐたよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきまではばたばたばたばた云っていたけれども、もう今はおとなしく臼の上にとまっているよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「穂吉さんはね、臼の上をあるいていたよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に十四、五両も上がる臼が幾個とかあって米を運ぶ車を曳く馬の六、七頭も飼ッてある。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "月もなく、日もなく、樹もなく、草もなく、路もない、雲に似て踏みごたえがあって、雪に似て冷からず、朧夜かと思えば暗く、東雲かと見れば陰々たる中に、煙草盆、枕、火鉢、炬燵櫓の形など左右、二列びに、不揃いに、沢庵の樽もあり、石臼もあり、俎板あり、灯のない行燈も三ツ四ツ、あたかも人のない道具市。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその火鉢といわず、臼といわず、枕といわず、行燈といわず、一斉に絶えず微に揺いで、国が洪水に滅ぶる時、呼吸のあるは悉く死して、かかる者のみ漾う風情、ただソヨとの風もないのである。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光、ただに身に添うばかりでなく、土に砕け、宙に飛んで、翠の蝶の舞うばかり、目に遮るものは、臼も、桶も、皆これ青貝摺の器に斉い。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "進まれもせず、引返せば再び石臼だの、松の葉だの、屋根にも廂にも睨まれる、あの、此上もない厭な思をしなければならぬの歟と、それもならず。",
              "citation": {
                "source": "星あかり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淵沢小十郎はすがめの赭黒いごりごりしたおやじで胴は小さな臼ぐらいはあったし掌は北島の毘沙門さんの病気をなおすための手形ぐらい大きく厚かった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草食獣にある臼歯もあれば肉食類の犬歯もある。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でその中四枚が門歯四枚が犬歯それから残りが臼歯と智歯です。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でそんなら門歯は何のため、門歯は食物を噛み取る為臼歯は何のため植物を擦り砕くため、犬歯はそんなら何のためこれは肉を裂くためです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臼歯は草食動物にあり犬歯は肉食類にある。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの形、とうがらしや、臼や、鋏や、赤や白や、実にさまざまの学生のばけものがぎっしりです。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、その空さへもうすくもり、かみつけの山に雪くれば、魚らひそかに針をのみ、ま芝は霜にいろづけど、ひとり岸邊に針を垂れ、來らむとする冬を待つ。",
              "citation": {
                "source": "冬を待つひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
