          ],
          "literary": [
            {
              "text": "或る晩、売子宿の店主からこう訊かれた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬に吠えられたり、女中に断わられたりしても、すぐ引っ込んでしまうんじゃ、いつまで、行商で飯は食えないぜ」励ますつもりか、売子宿の店主は、ぼくを馬鹿扱いにして云った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、売子宿の店主から、そう云われると、何か安易な気もちもして、依頼心をそそられ、行かないのは自分の馬鹿なせいかもしれないと思った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
