[
  {
    "uuid": "a3f1ee02-2e43-5303-96fe-f044fccb26de",
    "entry": "飢え",
    "reading": {
      "primary": "うえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
