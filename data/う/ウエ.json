    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hunger",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "之の欠乏する限り、対人せる場合に現はれる感情も、飢えた獣の感情に似る他はないのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際あの頃の政府は、馬鹿な悪い親で、大ばくちの尻ぬぐいに女房子供の着物を持ち出し、箪笥はからっぽ、それでもまだ、ばくちをよさずにヤケ酒なんか飲んで女房子供は飢えと寒さにひいひい泣けば、うるさい！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢えに泣いているはずの細民がどうかすると初鰹魚を食って太平楽を並べていたり、縁日で盆栽をひやかしている。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、猫入らずまで混ぜてあったのだが、兎に角私は、滅茶苦茶に甘いものに飢えていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語で言えば、丁度熱心に、大声で、息をはずませて、人が千人も前に立っていて、その詞を飢えたものが麪包を求めるように求めている積で、語り出すような工合に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の連合委員会の事業振興の決議案にもかかわらず、閑散とした取引市場をとりまいて、日一日と失業者と、彼らの飢えが生産余剰と反比例して街の広場に堆積して行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学運動は、ゼイタクな菓子を食う少数階級でなく、一切のパンにも事欠いて飢え、かつ、闘争している労働者農民大衆の中にシッカリとした基礎を置き、しかも国境にも、海にも山にも妨げられず、国際的に結びつき、発展して行く。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、家庭の温かさと、情味とに飢え渇していた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは血に飢えている犬を嗾かけて、お作を咬ませたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、飢えた宿なしの犬のように、あらゆる感覚を緊張さして、どこでも、くん／＼嗅ぎまわっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の支那兵は、女学生の寄宿している宿へ入り、彼等の飢えた性欲を十分に満足させた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、常に慾情に飢え、金のない、かつかつの生活を送っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌がなくて飢えた家畜は、そこら中で悲しげにほえていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももしヴェーッサンタラ大王のように大へんに徳のある人ならばそしてその人がひどく飢えているならば木の枝はやっぱりひとりでに垂れてくるにちがいない。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども電光があんまりせわしくガドルフのまぶたをかすめて過ぎ、飢えとつかれとが一しょにがたがた湧きあがり、さっきからの熱った頭はまるで舞踏のようでした。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が自分の鬱屈した部屋から逃げ出してわれとわが身を責め虐んでいた間に、彼らはほんとうに寒気と飢えで死んでしまったのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このこじき根性が抜けないおかげで今日をどうやらこうやら飢えず凍えず暮らして行かれるのかもしれないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "血に飢えたる猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "置いていっても、飢え死するようなことはないだろうね。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢え死することはないだろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥もけものも、みな飢え死にじゃ人もばたばた倒れたじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十たび目は、あまりの飢えと身にあまる、その実の重さにまなこもくらみ、五たび土に落ちたれど、ただ報恩の一念に、ついご自分にはその実を啄みなさらなんだ、おもいとどいてその十番目の実を、無事に親子に届けたとき、あまりの疲れと張りつめた心のゆるみに、ついそのままにお倒れなされたじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇の知識に飢え渇いていた私は、あばら屋の中で黴臭い紅茶をすすめながら、次から次へと愚問を連発した。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を触れるものがみんな黄金になるのでは飢え死にするほかはない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし俺がいなかったら、おまえたちは飢え死にをするよりしかたないところだったんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田　　ところがその男が貧に逼り、飢えに疲れてとうとう昨日死んでしまった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして飢えが逼ってきた。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために俺たちは三度のものも食えないほどに飢えてしまうんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムは小さなマミミとただ二人、寒さと飢えとにガタガタふるえて居りました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには流石の髯将軍も首を縮めて、お得意の奇声を放つこと飢えたる豚のごとし。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
