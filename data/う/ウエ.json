  {
    "uuid": "f4d3d235-0c9d-5f58-be00-65f058ee7ea5",
    "entry": "上",
    "reading": {
      "primary": "うえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
