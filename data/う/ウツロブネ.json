    "definitions": [
      {
        "index": 1,
        "gloss": "unidentified craft said to have washed ashore in Ibaraki Prefecture during the Edo period (sometimes alleged to have been a UFO)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "浪高く小砂を転じ、忽ち捲いて忽ち落つ、之れを見て快意そゞろに生じ、身を飜して浪上にのぼれば、自から虚舟の思あり。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "荘子に虚舟の譬がある。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼虚舟と同じである。",
              "citation": {
                "source": "鴎外漁史とは誰ぞ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚舟鴨を風呂敷に包みて持て来る。",
              "citation": {
                "source": "雲の日記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」しかしわたくし共の経験する所を以てすれば、虚舟と雖、触るれば必ずしも人の怒を免れない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒は彼｜虚舟にも比すべき空白の能く激し成す所ではないからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我身堪笑似虚舟、漂蕩任風不暫留、横断大西洋上路、復踰赤道入南球。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
