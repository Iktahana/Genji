          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今日の日本は、千の平凡人よりも一人の快男児を要し、十万百万の平凡人よりも、一人の英雄豪傑を要する時代なり、大英雄、大豪傑出でずんば、日本は世界の大舞台に立つて、宇内の第一等国となる能はず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が邦は陸海軍の精鋭をもつて、宇内の強國を驚かして居る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇内を睥睨し、日月を叱※せし、古来の英雄何すれぞ墳墓の前に弱兎の如くなる。",
              "citation": {
                "source": "富嶽の詩神を思ふ",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "否文句以上、筆以上の壮観で、烈々｜宇内を焼きつくす概があった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に宜しく宇内に照臨し、皇化の曁ぶ所、遠邇あることなかるべし。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、武力的帝國主義は既に過ぎ去りたるも、資本的帝國主義は宇内の大勢を左右して、正義公道の行はれざること、なほ二千年前の外交と異なるなければなり。",
              "citation": {
                "source": "韓非子解題",
                "author": "小柳司気太",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治学的に人類学的に宇内の最も貴重すべき一大古物なり。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "上無始に溯りて其以前に物あることなく、此宇内の最も貴重すべき古物をして常に鮮美清麗の新物たらしめ、下無終に延きて其以後の物有ること無からしむること是れ豈我儕日本人民の至頂に非ずや。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "元が朔漠から起つて宇内を昆一してから、西域の囘教徒が續々支那内地に移住した。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "群山の上に挺立すること數百尺、雲は斜にその半腹を帶のごとく卷きて、空の碧、日のかゞやき、ある時は茶褐色の衣を着け、或時は深紫の服をかさね、朝は黄金の寶冠を戴きて、來り朝する宇内の群山に接するの光景は、いかにわがあくがれ易き心を動かしたりけむ。",
              "citation": {
                "source": "秋の岐蘇路",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上八策は、方今天下の形勢を察し、之を宇内万国に徴するに、之を捨てて他に済時の急務あるべし。",
              "citation": {
                "source": "船中八策",
                "author": "坂本竜馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇内の大勢も心得ず、人斬包丁ばかり振り廻すのは人間の屑と云わなければならない。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "却て宇内平和策とか無戰論とかを主張する人、殊に又具體的主義主張を以て爭はんとする人に此見方を勸めて見たい。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣く知識を世界に求め、宇内の大勢に立ち後れず、進んでこれに導かうとする以上、世態文明の變遷發展はもとより當然のことである。",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國何者そ、獨逸何者そ、佛國何者そ、露國米國何者そ、苟も雄を宇内に爭ふ者は、一として此元氣の勃興發動底止する所を知らさるに非すや。",
              "citation": {
                "source": "海島冐險奇譚　海底軍艦",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄を宇内に稱せむと欲せは、國を擧けて大に女兒教育の法を講し、以て其元氣の本源を開發するに若くはなきなり。",
              "citation": {
                "source": "海島冐險奇譚　海底軍艦",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてことにかの宇内の舞台においてもっとも豪胆活溌なる演劇者の中心たる欧州諸国を見よ。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ宇内の運動は東洋に集まり、東洋の運動はインドに集まり、しかしてインドの運動はアフガニスタンに集まる。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "看よ看よ今日において宇内を睥睨する通邑大都のごときも、近世史の始めにおいては実に憐れむべき微少なるものにして、彼らはいかにして封建豪族、鷲鳥の一抓一攫を免れたるか。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "二氏のごときは実に宇内の大恩人にして無冠の皇帝といわざるべからず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなれば今日｜宇内の経済世界の現象は実にこの言の空望にあらざることを吾人に向かって保証すればなり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずくんぞ宇内の形勢を洞察して武備主義を一変して生産主義となし、貴族社会を一変して平民社会となすの端緒を啓くを要せんや。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今や天破れ、地驚き、滔々たる洪水は天に漲り、山となく、川となく、城となく、市となく、水天茫々、ただ瀾飛び、濤舞うの今日において宇内の大勢に抗せんとする、それ難からずや。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上八策ハ方今天下ノ形勢ヲ察シ、之ヲ宇内万国ニ徴スルニ、之ヲ捨テ他ニ済時ノ急務アルナシ。",
              "citation": {
                "source": "船中八策",
                "author": "慶応三年六月十五日",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月の綸旨に、「豈料らんや藤原｜実美等、鄙野匹夫の暴説を信用し、宇内の形勢を察せず国家の危殆を思はず、朕が命を矯て軽率に攘夷の令を布告し、妄に討幕の師を興さんとし、長門宰相の暴臣の如き、その主を愚弄し、故なきに夷舶を砲撃し、幕使を暗殺し、私に実美等を本国に誘引す云々」。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋行して宇内の新知識を究めんと欲すること多年。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するに「サツマ辭書」計畫以前のことと思はれ、その兄といふ人は、献吉より上か下かわからぬが「宇内の新知識を究め」たい志は、猶やむことなくして、その頃の長崎にうろついてをり、とほく太平洋を睨んでゐたのであらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくこんな新らしいタイプの日本人が、たくさん名も無い人間のうちにゐたにちがひなく、私らはちやうどこの頃、ロシヤ船に乘りこんで宇内の知識をきはめんとて、若い吉田寅次郎が江戸から長崎へむかつてすたこらいそいでゐたのを思ひだすだらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲がもうだいぶ高くなつて、路にそつてる箇所はズツとホコリで殆んど黒くなつてるのが、熱い上に熱くした。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『間拔奴、見損やがつたか、汝、記憶えとけ、深川の芳兄いてで鳴らしたもんだい、手前達の樣な、女たらしに、一文たりとも貰ふ覺えはないぞ、ヘツ、どうだい、その面は、いやにキヨロツキやがつて、憚乍ら口惜しけりや腕ツコキで來い、白痴ツ』『女たらし』の一言に力を罩めて憤怒の焔燃ゆるが如し、果然彼には一物あり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
