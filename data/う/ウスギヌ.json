    "definitions": [
      {
        "index": 1,
        "gloss": "thin or light silk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いかめしい城郭のようなライブラリーも柔らかで憂鬱な霧の薄絹に包まれている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝は気がつかなかったが、道の西手に一段低い畑には、蕎麦の花が薄絹を曳き渡したように白く見える。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が心の何方に走れりとも知らで、乳に倦きれば乳房に顔を寄せたるまゝ思ふ事なく寐入し児の、頬は薄絹の紅さしたるやうにて、何事を語らんとや、折々曲ぐる口元の愛らしさ、肥えたる腮の二重なるなど、かかる人さへある身にて、我れは二タ心を持ちて済むべきや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護色のような薄絹の手袋。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるひどい雨の日の昼ごろにたずねて来たときは薄絹にゴムを塗った蝉の羽根のような雨外套を着ていたが、蒸し暑いと見えて広くはげ上がった額から玉のような汗の流れるのをハンケチで押しぬぐい押しぬぐい話をした。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴたりとついて留まったが、飜然と此方へ向をかえると、渚に据った丘の根と、海なるその岩との間、離座敷の二三間、中に泉水を湛えた状に、路一条、東雲のあけて行く、蒼空の透くごとく、薄絹の雲左右に分れて、巌の面に靡く中を、船はただ動くともなく、白帆をのせた海が近づき、やがて横ざまに軽くまた渚に止った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――肩、両眼、腰、足の先と、膚なりに、土耳古人が狙って縫打に打つんだが、弾丸の煙が、颯、颯と、薄絹を掛けて、肉線を絡うごとに、うつくしい顔は、ただ彫像のようでありながら、乳に手首に脈を打つ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……艶なる女優の心を得た池の面は、萌黄の薄絹のごとく波を伸べつつ拭って、清めるばかりに見えたのに、取って黒髪に挿そうとすると、ちっと離したくらいでは、耳の辺へも寄せられぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と少し膝を浮かしながら、手元を覗いて憂慮しそうに、動かす顔が、鉄瓶の湯気の陽炎に薄絹を掛けつつ、宗吉の目に、ちらちら、ちらちら。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身長身幅より三四倍もある尾鰭は黒いまだらの星のある薄絹の領布や裳を振り撒き拡げて、しばらくは身体も頭も見えない。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台では、長髯の豪傑が四つの金襴の旗を背中にさして長槍を振りまわし、また、半裸体の男が幾人もそろって一斉にとんぼ返りを打ったり、小旦が出て来て何か甲高い声で歌うかと思うと、赤い薄絹を身にまとった道化役が、舞台の柱にしばられて胡麻塩髯の老人に鞭でひっぱたかれたりするのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の山の松杉の遠く真白な中から、柳が青く綾に流れて、御堂の棟は日の光紫に、あの氷月の背戸あたり、雪の陽炎う幻の薄絹かけて、紅の花が、二つ、三つ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼鉄いろの馬のり衣裾長に着て、白き薄絹巻きたる黒帽子を被りたる身の構けだかく、今かなたの森蔭より、むらむらと打出でたる猟兵の勇ましさ見むとて、人々騒げどかへりみぬさま心憎し。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼鉄いろの馬のり衣裾長に着て、白き薄絹巻きたる黒帽子をかぶりたる身の構えけだかく、いまかなたの森蔭より、むらむらと打ち出でたる猟兵の勇ましさ見んとて、人々騒げどかえりみぬさま心憎し。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡い夜霧が草の葉末におりて四方は薄絹に包まれたようである。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は薄絹に掩われたように、懶く空を渡りつつあった。",
              "citation": {
                "source": "土竜",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉樹が寒風に嘯き早春の欅の梢が緑の薄絹に掩われるのも、それは皆すべて植物の生理的必然の作用に他ならない。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……艶なる女優の心を得た池の面は、萌黄の薄絹の如く波を伸べつゝ拭つて、清めるばかりに見えたのに、取つて黒髪に挿さうとすると、些と離したくらゐでは、耳の辺へも寄せられぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに美しい後ろ姿をした一人の、非常に疲労した様子で、夏の初めの薄絹の単衣のような物を上から着て、隠された髪の透き影のみごとそうな人を右近は見つけた。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りざまに、その面を掩うていた黒い薄絹のヴェールを、かなぐり捨てゝ、無造作に自動車の中へ投げ入れた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い月明りが薄絹のようにたよたよと顫えている後壁の隙間から、魚の腹のような冷い燐火が、三つ四つ続けさまにふらふらと飛び出したかと思うと、その瞬間、「き、き……。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔、一条戻り橋にあらわれたという鬼女のように、彼女は薄絹の被衣を眉深にかぶって、屋形の四足門からまだ半町とは踏み出さないうちに、暗い木の蔭から一人の大きい男が衝と出て来て、渡辺の綱のように彼女の腕をしっかりと掴んだ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りざまに、その面を掩うてゐた黒い薄絹のヴェールを、かなぐり捨てゝ、無造作に自動車の中へ投げ入れた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が山の南の肩の一角から光を滑らして、村の家々を包む時は、西の嶽が暗緑の濃厚な色を呈して、青い空にくつきり輝いて、爽かな感じを與へるが、日が次第に天に冲して、斜めに東の峰を照り付けると、淡青の色は薄絹の艶を増して、滑らかな心持の好い感じとなる。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙か向ふに薄墨色をしてゐる山の端から、夕靄が立ち初めて、近くの森や野までが、追々薄絹に包まれて行くやうになつた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟と響く遠音とゝもに、汽車が北から南へ走るのが、薄絹を透いて手遊品の如く見えた。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ船の中の水夫の姿さえ、薄絹の奥にあるようだ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼろな月の下に、薄絹の角かくしも怪しく震えて、花嫁は俥上に白い顔をうつむけてゐた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面が風にゆれるうすぎぬのように、静かに、静かにしずんでいきました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、輪を描く水色のそれの煙を眺むれば、黄金のうすぎぬ軽々と舞うて空ゆく身が見える。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
