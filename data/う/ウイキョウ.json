        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――おや、茴香の匂いがするよ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッシェール夫人はほの／″＼とした茴香の匂の中で、すっかり酔って居る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ああ見まもれどおもむろに悩みまじろふ色の陰影それともわかね……熱病の闇のをののき……Hachisch か、酢か、茴香酒か、くるほしく溺れしあとの日の疲労……縺れちらぼふWagner の恋慕の楽の音のゆらぎ耳かたぶけてうち透かし、在りは在れども。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘋癲院の陰鬱に硝子は光り、草場には青き飛沫の茴香酒冷えたちわたる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そがもとに噴水のむせび濡れ濡れて薄闇に入る……空気は重し……なほ赤し……黄に……また緑……いつしかに蒸汽の鈍き船腹のごとくに光りかぎろひし瘋癲院も暮れゆけば、ただ冷えしぶく茴香酒、鋭き玻璃のすすりなき。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇日の色なき街は清水さす石油の噎、轢かれ泣く停車場の鈴、溝の毒、昼の三味、鑢磨る歌、茴香酒の青み泡だつ火の叫、絶えず眩めく白楊、遂に疲れてマンドリン奏でわづらふ風の群、あなあはれ、そのかげに乞食ゆきかふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "茴香酒のごときひとすぢつと引きつ、切りつ、忘れつ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色、黄色、意気で高尚で、しとやかな、茴香のいろ、卵いろ、「思ひ出」のいろ、好きな児猫の眼の黄いろ、浮雲のいろ、ほんにゆかしい三味線の、ゆめの、夕日の、音の黄色。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しき日その花をながめて空いろのつゆのいのちのそれとなく消なましものをロベリヤのさく感覚の小函　いつの日か懐かしいと思つて小※に据ゑて置いた忽忘草も、青い金剛石花も、空色のロベリヤももうみんな枯れてしまつて、小石川の植物園に新たに茴香の花の咲く時節が来た。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつぞやは死なうとも思つた、俺の好きな植物園の薬草花壇で、毒薬を喫んで、あの大蒜の根や、茴香の蕾を抓み散らして、精一杯に苦んで、藻掻いて血を吐いて、而して笑つて真蒼に腐つて了ひ度い――とも思つた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は茴香、えび蔓實ぞ色づきつ、　　　　ああひとつば、素腹の性を恨みわび、夜を泣き濡れて、　　　　ああひとつば、萎ゆれど、姫は目も空に往き過ぎましぬ　　　　ああひとつば。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のゆく日の東京に茴香艸の花つけて淡い粉ふるこのごろを、ほんに品よきかの國のわかい王もさみしかろ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒穗草の匂、茴香の匂、胡桃の匂がする、またよく熟れて摘みとつた果物の匂がする。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "茴香、愛の女神の青雲の髮。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "茴香、野罌粟、黄蜀葵、色々と物言ひかけるよその小花よりも、おまへたちの方がわたしは好だ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この煎餅の表面の、後から糊で貼り着けたらしい小さな小豆を砕いた様な木の実だが、色々調べた結果、学名は日本産｜大茴香、普通に莽草又はハナシバなぞと呼ばれる木蘭科の常緑小喬木の果実であってな。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "四秋は茴香、えび蔓實ぞ色づきつ、　　　ああひとつば、素腹の性を恨みわび、夜を泣き濡れて、　　　ああひとつば、萎ゆれど、姫は目も空に往き過ぎましぬ、　　　ああひとつば。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "空からは、静かな冷気が下りてきて、野菜ばたけからは、茴香の香りが漂ってきた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「茴香酒がございますよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、その茴香酒をくれい。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人の逢ふが短き夜となりぬ茴香の花橘の花　橘が咲き茴香が咲き夏が来た、短い夜はいよいよ短くなつた、たまの逢瀬を楽しむ恋人達には気の毒だが、せめては暗にも著しいこれらの茴香の匂ひ、橘の匂ひでも嗅がせたい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "極楽鳥のめでたきとは　うたたねの夢路に人の逢ひにこし蓮歩のあとを思ふ雨かな　であり　春の磯恋しき人の網もれし小鯛かくれて潮けぶりしぬ　であり　来鳴かぬを小雨降る日は鶯も玉手さしかへ寝るやと思ふ　であり　恋人の逢ふが短き夜となりぬ茴香の花橘の花　である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたには茴香（王に）それから小田巻。",
              "citation": {
                "source": "オフェリヤ殺し",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シトロンでも煽る調子で食事｜毎に葡萄酒や茴香酒を飲む。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大茴香でございます」「おおこれが茴香か。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茴香といえば高価な薬草、さすが大槻玄卿殿は、当代名誉の大医だけあって、立派な薬草園を持っておられる」　さすがの葉之助も感心して、園に添って歩いて行った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはビールのさかなにしているもので、彼はすべての書類の上にそのビスケットにかかっている塩とういきょうとをこぼしていた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
