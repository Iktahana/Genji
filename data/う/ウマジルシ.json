    "definitions": [
      {
        "index": 1,
        "gloss": "battle standard raised next to the horse of a commander",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
