          ],
          "literary": [
            {
              "text": "うつらうつらと僕はする……風もある……松林を透いて空が見えるうつらうつらと僕はする。",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつれて、希望という虹がうつらうつら夢みられて来る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女神の上厠は、はこそのものよりも、うつらうつら物うち考えられるのでこれも永い。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は赤い帯を、こま結びにしたまま寝たり起きたりして、この不満が何処から来たものか、どうしたら癒されるかと、うつらうつら持て扱っていた。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉清輝と田川とは、傷の痛さに唸りながら、半ば、うつらうつらしつつ寝台に横たわっていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうです、一片の肉塊を艇内に残して海中に墜落したるものなり――なんという悲壮な最後だろう、僕は何度読んでも涙がこぼれる」　酔いが回って来たのか、それとも感慨に堪えぬのか、目を閉じてうつらうつらとして、体をゆすぶっている。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてうつらうつら日溜りに屈まっていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごはんの知らせが来ても、私は、からだ工合が悪いから、きょうは起きない、とぶっきらぼうに言い、その日は局でも一ばんいそがしかったようで、最も優秀な働き手の私に寝込まれて実にみんな困った様子でしたが、私は終日うつらうつら眠っていました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その籐椅子を見つめながら、うつらうつらまどろんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林という林、梢という梢、草葉の末に至るまでが、光と熱とに溶けて、まどろんで、怠けて、うつらうつらとして酔っている。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "また中には酔ってしゃべりくたぶれて舷側にもたれながらうつらうつらと眠っている者もある。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後二週間ほどたって、自分は用談の客と三時間ばかり相談をつづけ、客が帰ったあとで、やや疲れを覚え、横になったまま庭をながめて秋の日影がだんだんと松の梢をのぼって次第に消えてゆくのを見ながら、うつらうつらしていた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳にうつらうつら襲って来る甘い倦怠――　千歳はいつか慶四郎の肩に頭を凭せて歩いている。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、痴呆の無感覚にだんだん隔って行く自分をうつらうつら無意識と意識の境いに置きながら佇っていた。",
              "citation": {
                "source": "真夏の幻覚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがあまりに息詰まるほど嵩まると彼女はその嵩を心から離して感情の技巧の手先で犬のように綾なしながら、うつらうつら若さをおもう。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その八月二日の午すぎ、わたくしが支那漢時代の石に刻んだ画の説明をうつらうつら写していましたら、給仕がうしろからいきなりわたくしの首すじを突っついて、「所長さんが来いって。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "起こすのも悪いと思って、そっと部屋を出たが、均平もうつらうつらと夢心地に女たちの声を耳にしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が座席へ帰って来たのは、もう二時ごろで、銀子もうつらうつら気がついたが、ちょっと身じろぎをしただけでまた眠った。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　けれども、どの花も、気持よさそうにお日さまの光をあびて、うつらうつらと、自分のおとぎばなしや、お話を夢に見ていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、うつらうつらしているだけなのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきいきと働いていた考えが、うつらうつらしていることもあります。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、働きださない考えが、うつらうつらしていることもあるのです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は夢とも現実とも別目のつかないこういう気持に牽かれて、モナミへ入り、テーブルに倚りかかって、うつらうつらむす子と行った巴里のキャフェを想い耽る。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間に交っていると、うつらうつらまだ立ち初めもせぬ野山の霞を想い、山河に引き添っているとき、激しくありとしもない人が想われる。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつら眠って、いろいろな夢を見た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、うつらうつら眠ったら、こんどは試験だ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつらうつらしていたら、ひどく汗が出て、気持もさっぱりして来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
