[
  {
    "uuid": "0b0b554e-d4e3-5a2c-88e2-898afbc9300f",
    "entry": "末枯れ",
    "reading": {
      "primary": "うらがれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
