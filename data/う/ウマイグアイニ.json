        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "私は毎日うまい具合にについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合にという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はうまい具合にの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはうまい具合にが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合にを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはうまい具合にについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合にの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はうまい具合にの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではうまい具合にが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合にという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にうまい具合にという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではうまい具合にについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合にを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとうまい具合には複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合にについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではうまい具合にが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にうまい具合には重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりうまい具合にの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "うまい具合には様々な場面で使われる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、先に云ふ「血迷つた粗朴さ」が、今後うまい具合に立ち直つてゆくとすれば、恐らく詩に対する関心を増すことともなるのであらうと思はれるのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそんな大量生産の際に、一つびとつの死なぞはうまい具合に行きつこはない、が、そんなことはあまり大したことではないのだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "このやうな今日に、一の死がうまい具合に行つたとて、誰がそんなものに價値を置くだらう？",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり人間をとって食べるので、或る勇士がついに之を退治して、あとの祟りの無いように早速、大明神として祀り込めてうまい具合におさめたという事が、その作陽誌という書物に詳しく書かれているのでございます。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "編粗朶が相当に重いのと、それを穴の上にうまい具合に蓋をするのには手間が取れた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの時、船長は、そのマストがきれいになり、サイドが化粧し、うまい具合に満船したという報知を、チーフメーツから受け取って、彼女と、酒を飲んでいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、うまい具合に、この難関だけはひとりでに解決して、みな子の方から、今日は伯母さんのところへ久しぶりで行ってきたいと言い出したのである。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "『我々もたまには歌にして見たいといふ考も起るのですが、こればかりは別才だと見えまして、何うもうまい具合にまとまりません……』『いゝえ、そんなことは――？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、夢中で走っているうちに、うまい具合に藪から出たが、同時に昏倒してしまったのであった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と陸とは人々の眼をくらますように、神様がうまい具合に造ってくれてあるものだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい具合に喧嘩もせずして遊ぶものだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、だんだん何らの興奮もなくなり、疲労がうまい具合に救ってくれているのに気がついた。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送ラジオの波長の百分の一位に当りますから、うまい具合に受信機には全然ラジオを聞かないで済みました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝登校のときに松さんがもって来た大袋四ツが持出されて、うまい具合に分配されてゆくのだった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれのう、もう掴まるか、もう掴まるかと思って、両手で鳥を抑えると、ひょいひょいと、うまい具合に鳥は逃げるんです。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを最後にしたいんだが、あの十字架のところへ、うまい具合に白い雲が一つ来てくれんと勿体ないね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋と、風景と、人情と、画家の仕事と、そして食物とが随分うまい具合に調子が合って行くので画家は楽しんで毎日の仕事に夢中になれるのですが、今のような日本の状態ではちょっと望み難いことでありましょう。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、西村がうまい具合にその土地を横領してしまったのだ」「ふーん」「もっともこれは瀬川側の言い分で実際のことは分からないが、とにかく瀬川は西村を相手に横領の告訴をして、数年間争ったのだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんな重いものが、ふりまわせるかしら）と、始め隣りの御隠居さんから借りて来たときは心配した一郎だったけれど、そのつるはしをうまいことふりあげて、下ろすときにはつるはしの重味で、さっとふり下ろすと、うまい具合につるはしは土の中にくい込むのだった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が生憎うらなり君の方では、うまい具合にこつちの調子に乗つてくれない。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがあいにくうらなり君の方では、うまい具合にこっちの調子に乗ってくれない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はうまい具合に、前進をはじめたかと思うと、またどんどんと後方へ押し戻されて、思うように前進ができなかった。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は片足が悪いから、跪まろうとしてもうまい具合には跪まれないから、胡坐と跪まるのを折衷したような非常に窮屈な坐り方です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ風に却々うまい具合に考へまして、朝廷からの保護がなくなると一般人民に依て維持することを考へたのであります。",
              "citation": {
                "source": "應仁の亂に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ「うまい具合に」――村人の表現を借りると――出来ていたが、しかし実際なかなかそう行かないものとみえて、「今日来る」、「明日は必ず来る」と組合で確言するにも拘らず、まだほんの少し――桑畑への割当分しかやって来ず、「重点」と称せられる水田の分は一向姿を見せなかった。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "果せるかな、半熟でちょうどうまい具合に処理してあった。",
              "citation": {
                "source": "すき焼きと鴨料理――洋食雑感――",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマザクラと緋カンザクラとはだいぶ花時が食い違っていれど、しかし早く咲いたヤマザクラと遅く咲いた緋カンザクラとがうまい具合に交媒したことが万一あったとしたら、そのときはそのあいの子ができないものでもないと想像する。",
              "citation": {
                "source": "寒桜の話",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といっても、まだおくらは女だ、柿村屋は、食える男でない、おくらをうまい具合に立行かぬようにし、あの森の中から追い払ったのも柿村屋の仕事だろうなどといった。",
              "citation": {
                "source": "凍える女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねがね彼は思つてゐる、俺は自由を吹消さう、うまい具合に、臘燭のやうにと。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまいぐあいに世界的に有名なタイフーンのいつも通る道筋に並行して島弧が長く延長しているので、たいていの台風はひっかかるような仕掛けにできている。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
