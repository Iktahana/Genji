        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "明治四十二年の暮には南ドイツからウィーンを見物してヴェニスに泊ったのがちょうどクリスマスであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人はその名の示すようにこの料理を伊太利ミラノのコトレツと考え、ドイツ人は墺太利の首府ウィーンの料理と考えているらしい。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしメストロウィークを崩したような大物になると、どうにも自分などのようなものの好意の圏外に飛出してしまう。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四に近頃やられたのはロチェスターの外科医ウィーゲル博士だという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何となく軒端に菖蒲を葺いた郷国の古俗を想い浮べて、何かしら東西両洋をつなぐ縁の糸のようなものを想像したのであったが、後にまたウィーンの歳の暮に寺の広場で門松によく似た樅の枝を売る歳の市の光景を見て、同じような空想を逞しゅうしたこともあった。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国、仏蘭西、独逸とずいぶんながいごったごたした旅行を続けておしまいにウィーンへやって来る。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は美しい星空で、その下にウィーンの市が眠っている。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男はそのときどんなことを思ったかというと、これはいかにも古都ウィーンだ、そしていま自分は長い旅の末にやっとその古い都へやって来たのだ――そういう気持がしみじみと湧いたというのです」「そして？",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はウィーンへ行きたくなった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の中でリップ・ヴァン・ウィンクルが元気よく自分の名を叫ぶと、反響がおおぜいの声として「リーッウ・ウァーン・ウィーンウール」と調子の低い空虚な気味の悪い声であざけるように答えるのが、いかにも真に迫っておもしろかったのを記憶する。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンで夜おそく町をうろついて、タンネンバウムを売っているのを見た時にちょうど門松と同じだと思ったのと、ヴェネディヒで二十五日の晩おびただしい人が狭い暗い町をただぞろぞろ歩くのを見てさびしい思いをしたきりでしたが、ことしはここの田舎で田舎らしい純粋の降誕祭を経験しました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者の唱歌は昨年ウィーンで聞いたほうがむしろよかったと思います。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学術部長のウィーゼ博士は物静かで真摯ないかにも北欧人らしい好紳士で流暢なドイツ語を話した。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日また別の席でこれらの人たちと晩餐を共にしてシュミット、ウィーゼ両氏の簡単な講演を聞く機会を得た。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーゼ氏の話によると数年来かの国の気象学者たちは、気圧その他の気象学的要素の配置から夏期における北氷洋上の氷の分布状況を予報することを研究し、それがだいぶうまく的中するようになった。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓上の花瓶に生けた紫色のスウィートピーが美しく見えた。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫色のスウィートピーを囲んだ見合いらしいはなやかな晩餐の一団と、亀井戸への道を聞いた寒そうな父子との偶然な対照的な取り合わせが、こんな空想を生む機縁になったのかもしれない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンのある男は厳重なる検閲のもとにウインドボイテル（軽焼きまんじゅうの類）を六十九個平らげた。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと若い仲間でのレコード七十九時間と三十分というのはウィーンのウィリー・ガガヴチューク君の手に帰した。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は嘗て、墺国の首都ウィーンで、体育家の人気者ホーエンスタインという人に面会しまして、親しく氏の自然運動科学の実地を見せて貰いました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところはウィーン市のコニー島というところにある自然運動学校でありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーン市内の青年男女の有志者が、芝生の上で終日、四つん這いになって暮しているのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビーと紫水晶のかけらのスウィートピー。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒と間違えられては大変と思いましたので……どうぞ御勘弁を……」スウィートポテトー　心中のし損ねが村の駐在所に連れ込まれた……というのでみんな見に行った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまりお前達二人はスウィートポテトーであったのじゃナ」　硝子戸の外の暗の中で二三人クスクスと笑った。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……違います……スウィートハートです……」「フフ――ウム」　と巡査は冷やかに笑いながらヒゲをひねった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はもう我慢出来なくなりましたから、勇作さんと一緒に、どこか遠い所へ行ってスウィートホームを作ります。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の私のスウィートピイちゃん。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィートピイは、蘇鉄の真似をしたがる。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中背で小肥りの体を、金髪に調和する褐色のツウィードの服で包んで居る。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
