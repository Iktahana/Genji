    "definitions": [
      {
        "index": 1,
        "gloss": "to move",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ポマードは生え際ばかりに厚く塗つたくつてあつて、その太い首が動くたびに山猫か何かの感じがした。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なにをする』流石の男も、少し正氣になつて、激した口調で『失敬な、貴樣は』『何だと』芳は體を突き出した、苦み走つた、黒い眉毛がヒリリと動く。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その婆さんの鼻の動く工合までも覚えているような気がするのである、これもはなはだ官能的である。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白兎やモルモットらしいものが檻の中に動くのが見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返る門柳監獄の壁にかくれて流れる水に漣※動く。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまん中の土が妙に動くと思っていると、すうと二葉が出て来た。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、何であったか、坊主の耳の動くことを書いてあったのを面白いと思ったことがあるくらいである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更らしく死んだ人を悲しむのでもなく妹の不幸を女々しく悔やむのでもないが、朝に晩に絶間のない煩いに追われて固く乾いた胸の中が今日の小春の日影に解けて流れるように、何という意味のない悲哀の影がゆるんだ平一の心の奥底に動くのであった。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はまた川になる、川の面は、呼吸も吐かず静まりかえっているように見えるが、足を入れると、それこそ疾風が液体になったように全速力で走っている、流れの浅く、彎入した、緩やかなところに背を露わした石がある、苔が厚く活物の緑が蠢めいている、水草の動くのは、髪の毛がピシピシと流電に逆立つようだ。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私は嘆息する、天地の間には、風が吹くのでなければ、霧が流れるのだ、そのたびに、天幕の中へ、ザアと小粒の雨がそそぎ入る、柱代りの金剛杖が、キュッと呻る、杭に纜われた小舟が、洪水に飜弄されるように、油紙の屋根が、ペラペラ動く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、自分から動く火吹き達磨のように、のたうちまわった挙句、船首の三角形をした、倉庫へ降りる格子床（グレイチン）の上へ行きついた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も、船会社と、船会社から頼まれた海軍だけだったが――　やがて、彼女が、駆逐艦に発見された時、船の中には、「これじゃ船が動く道理がない」と、船会社の社長が言った半馬鹿、半狂人の船長と、木乃伊のような労働者と、多くの腐った屍とがあった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい事には吾々太陽の陪臣微々たる人間の目には堂々たる太陽の歩武がどちらに向いているという事がはっきり分らぬが、ただ周囲に動いている諸星の中でリーラ派のは速く動くように見え、カメロパルダリス派のは割合に吾等と歩調の差が少なく見えるから、先ず吾等は後の派に属するものと考えねばならぬ。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "槓杆の効用は人の知る通り、昔の力学者が「適当な支点を与えてくれれば地球もころがして見せる」と威張ったのは槓杆の効能を極端に云ったものである、だから適当な槓杆と支点を与えれば虻の力で大象も動く、美人の繊手で横綱も釣上げられる。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形が人間らしく動く飾物を見ようとするのだ。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――感情で動く動作にも、経済で動く動作にも。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞳が動くとき娘の情痴のような可憐ななまめきがちらつく。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人々が石か岩の動くように感じただけだった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の床几で鼠色羽二重の襦袢の襟をした粗い久留米絣の美少年の姿が、ちらりと動く。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ鏡がものを映し窓掛けが風にふわふわ動く。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械は八時半から動くからな。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の中だし、アルキメデス、水の中だし、動く動く。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がこの上を流れるでしょう、石が水の底でザラザラ動くでしょう。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿、今もし此處におはしまして、例の辱けなき御詞の數々、さては恨みに憎みのそひて御聲あらく、さては勿躰なき御命いまを限りとの給ふとも、我れは此眼の動かんものか、此胸の騷がんものか、動くは逢見たき慾よりなり、騷ぐは下に戀しければなり。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正式な平衡を破って、髪の形を崩すところに異性へ向って動く二元的「媚態」が表われてくる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとした考えの穴があると動くはずの器械が動かないのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かな愚かな表情を、院長さんとその園芸家とどっちが頭がうごくだらうといった風の――えい糞考へても胸が悪くなる。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と技手云へば、種子やまくらんいこふらん、　　　　ひとらかすみにうごくともなし。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人はしばらく押問答をしていたが間もなく一人ともつかず二人ともつかず家のなかにはいって来てわずかに着物のうごく音などした。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかさんがおどろいて泣いてポーセの名を呼びながら一生けん命ゆすぶりましたけれども、ポーセの汗でしめった髪の頭はただゆすぶられた通りうごくだけでした。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
