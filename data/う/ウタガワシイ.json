    "definitions": [
      {
        "index": 1,
        "gloss": "doubtful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それと事がらは別だが、いわゆる輿論とか衆議の結果というようなものが実際に多数の意見を代表するかどうか疑わしい場合がはなはだ多いように思う。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの負債を弁済する事が生涯に出来るかどうか疑わしい。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな谷の斜面の突端にでも建てたのでは規準様式の建築でも全く無難であるかどうか疑わしいと思われた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかしこういう場合における実際の犯人の心理を表現したものであるかどうか少し疑わしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの説が日本の浴場にも通用するかどうか少し疑わしい。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この流行言葉を口にする人の中で、本当に学位濫造の事実があるかないかを判断するだけの資料と能力をもっている人がどれだけあるかは極めて疑わしいと思われる。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、物理学教科書にある方則と寄宿舎の規則との区別を自覚している生徒がどれだけあるか疑わしい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かようなわけで、ｅとyeとがすべてｅになったとする説は極めて疑わしい。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "村田春海なども疑わしいというようなことを言っているのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で「ケ」の仮名については、私のこれまで見た奈良朝時代のすべての文献の中で、疑わしい例はただ二つだけしかないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし『古事記』が、平安朝になってから偽造されたものとすれば、これほど厳重に仮名を遣い分けることが出来るかどうか非常に疑わしいと言わなければなりません。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も容易に信じない代りに、また疑わしいものでも容易には否定しないのが彼の特長であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体職工的の「仕上げ」という事が芸術品の価値にどれだけ必要なものであるか疑わしい。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう点だけでも自分の見るところでは津田君と同じような人が他に幾人求め得られるか疑わしい。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か訊問するんだな、何をきかれたって、疑わしいことがあるもんか！",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれができたとしたところでどれだけの手がらになるかは疑わしい。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし骨董は果して古銅から来た語だろうか、聊か疑わしい。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそう考えるだけの確かな根拠があるかどうか自分には疑わしい。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の幼時にこの事を話した老人は現に自分でこれを体験したかのごとく話したが、それは疑わしいとしても、この老人の頭の若かった時代にこの話がかなりの生々しい色彩をもって流布されていた事は確からしい。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし実験室で、ある指定された条件のもとにおいて行なわれた実験が必ずしも直接に野外の現象に適用されるかどうかは疑わしい。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような考えを実際の場合に応用して具体的の数量的計算をする事は、今のところ、不可能であり、またしいてこれを遂行しても、その価値は疑わしいものである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、頭の中で考えただけでは充分につじつまが合ったつもりでいた推論などが、歴然と目の前の文章となって客観されてみると存外疑わしいものに見えて来て、もう一ぺん初めからよく考え直してみなければならないようなことになる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたしてそういうことが実際にありうるかどうか自分にははなはだ疑わしい。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも自分には疑わしい。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭公の場合には明らかに雌を呼ぶためだと解釈されているようであるが、ほととぎすの場合でもはたして同様であるか、どうかは疑わしい。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナのような大陸にも「涼」の字はあるが日本の「すずしさ」と同じものかどうか疑わしい。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは吹き抜き廊下のせいだというはなはだ手取り早で少し疑わしい学説もある。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜くてすごい女なら、電車の停留場の一区間を歩く度毎に、三十人くらいは発見できるが、すごいほど美しい、という女は、伝説以外に存在しているものかどうか、疑わしい。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ならばフォルマリンか何かで消毒するだろうが、あのころそういう衛生上の注意が行き届いていたかどうか疑わしい。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの記事がすべて正確であると仮定した場合でさえ、その必要が疑わしいくらいならば、記事が不正確である場合にはどうなるだろう。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
