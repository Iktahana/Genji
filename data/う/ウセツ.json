[
  {
    "uuid": "dd507fb5-523b-5c76-a538-fd9c402d6d70",
    "entry": "右折",
    "reading": {
      "primary": "うせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "turning to the right",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かうして、私の母家はこの水の右折して、終に二条の大きな樋に極まり、渦を巻いて鹹川に落ちてゆくその袂から、是に左したるところにある。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "囂囂囂とそのつり橋を渡ってまた右折する。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その本流と付知川との合流点を右折して、その支流一名｜緑川を遡航する舷に、早くも照り映ったのは実にその深潭の藍碧であった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォータルー橋通りを突っ切って、川を渡り、ウェリントン街を走り、そこで右折、そして気がついたらボウ街にいた。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿はづれの小川の橋際に今は唯だ一軒だけで作つてゐるといふとろゝ汁屋にとろゝを註文しておいて其處から右折、四五町して吐月峯に着いた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして目白橋を渡つて、左折、近衞公のお邸に行き當つて右折、一二町もゆくととろ／＼とした下り坂になつた其處の窪地全體が落合遊園地といふものになつてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "東京の郊外を想ふ",
                "note": "青空文庫"
              }
            },
            {
              "text": "右折して進んで行く。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "その最も小なる路を取り、つき當りて右折し、間もなく左折すれば、儒者棄場に達すべし。",
              "citation": {
                "source": "豐島ヶ岡",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前を右折して石磴をのぼれば、武尊の祠あり。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠、鞍掛兩巖の間より岩脈の上に出でて右折すれば、石祠あり。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の急斜面を登りて、火口丘に達し、幾度も上下して火口丘をつたい、兜岳とて、巌のみの重なり合える峰に突き当り、右折して火口丘を下る。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一溪に沿うて右折し、不動堂の前を過ぎて溪に下り、四五町ゆけば、溪窮まりて、飛流絶壁を走る。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "白河の市街に入り、右折して南湖に向ふ。",
              "citation": {
                "source": "白河の七日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、我等は下妻さして行くこと二里、梶内より右折して関城の趾を探り、若柳、中上野、東石田、沼田を経て、一時間ばかりは闇中を歩きて、筑波町に宿りぬ。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿を朝鳥と共に立ち出でて、途に神野寺を過ぎ、左に日本武尊を祀れる白鳥神社の石段を見上げて、右折すれば、九十九谷に出づ。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三町にして右折し、線路を越えて、廐の門を入る。",
              "citation": {
                "source": "三里塚の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "和泉新田火藥庫の土手を右に見て、代田橋を渡り、凡そ十町にして右折し、玉川上水を渡れば、龍泉寺あり。",
              "citation": {
                "source": "新武藏野の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりに名高き橋本といふ料理店を左に見て、妙見橋を渡り、川に沿うて右折して萩寺に至る。",
              "citation": {
                "source": "吾嬬の森",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊川をわたり、湊村より右折し、和合地を經て、鬼涙山を攀ぢ、終に鹿野山に達す。",
              "citation": {
                "source": "房州の一夏",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当奉行所にては手に余る珍事｜出来いたし候あいだ、ぜひにお力添え願いたく、右折り入って申し入り候。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの二分を俯瞰すると、前方が中庭をはさんで並行した別の病棟で、西方に渡廊下をもって右折して続いた医務室などの建物があり、東方には病院の裏門が眼近に迫っていた。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、私の母家はこの水の右折して、終に二條の大きな樋に極まり、渦を卷いて鹹川に落ちてゆくその袂から、是に左したるところにある。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "囂々とその釣橋を渡つてまた右折する。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この具合ならば、導者を待たずとも、辨天瀧に至りて、待ち合はすことにせむとて、歩みかくれば、辨天瀧へゆかむには、その手前の路を右折せざるべからずと、後ろの方より呼ぶ聲す。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "右折すれば、間もなく、辨天瀧を得たり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭くて深い谿谷の上に架してある神橋を渡り、石段をのぼり、朱塗りの鳥居をくぐり社務所の前を右折すれば、正面が神宮社殿である。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は此處に車を捨てて、徒歩維新の古戰場なる今市町を過ぎ、右折して大桑に到らんとす。",
              "citation": {
                "source": "日光山の奧",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯崗子温泉入口と一行其他（後列向つて右より梅原君・加藤・某君・西田君・女中達）（前列右より佐藤・晶子・温泉の主婦）遼陽の白塔と遼河　大安寺の背後の宝台山を少しく登つて右折すると、羅漢洞の奇勝がある。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "無量観を辞して渓を下り、更に少しく右折して山を登り竜泉寺に来た。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれたくも思はかれつ名はうせつ。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
