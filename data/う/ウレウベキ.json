        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしそういう事実からして、統計的研究――物理学方法論から見た一つの方法としての――が本質的に無価値なるがごとき「感じ」を与えるようになるとしたら、それもまた憂うべきことである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "優善は渋江一族の例を破って、少うして烟草を喫み、好んで紛華奢靡の地に足を容れ、とかく市井のいきな事、しゃれた事に傾きやすく、当時早く既に前途のために憂うべきものがあった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国王子に潔身の祓私が明治政府を攘夷政府と思たのは、決して空に信じたのではない、自から憂うべき証拠がある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "然りといえども、その消極を想像してこれを憂うれば、また憂うべきものなきに非ず。",
              "citation": {
                "source": "旧藩情",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも皆、学問上には憂うべきの大なるものにして、その憂の原因は学者の身に閑なくして家に恒産なきがためなり。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "方今わが国民においてもっとも憂うべきはその見識の賤しきことなり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の品行は高尚ならざるべからざるの論　前条に「方今わが国においてもっとも憂うべきは人民の見識いまだ高尚ならざるの一事なり」と言えり。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も憂うべき所にして、ある人の説に十全の正直は十全の親愛と両立すべからずといいしも、この辺の事情を極言したるものならん。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "国民の繁殖力からいえば憂うべき事もないのですが、未婚男女間に行われる不倫な性交と私生児の増加とは、現在の生活を暗黒にし将来の日本人種を劣弱にする事ですから、その点について男子側の反省を促すと共に女子｜自らも反省しなくてはなりません。",
              "citation": {
                "source": "女子の独立自営",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――乳不足の若い母親が多くなりつつあるのは、憂うべきことながら、その代りに、牛乳や人工乳が発達してきたことは、子供のためによいことであろう。",
              "citation": {
                "source": "風俗時評",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは憂うべきことに違いない。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人その本務を逸脱して余事に奔走すること、既に好ましくないが、更に憂うべきことは、軍人が政治を左右する結果は、若し一度戦争の危機に立つ時、国民の中には、戦争が果たして必至の運命によるか、或は何らかの為にする結果かと云う疑惑を生ずるであろう。",
              "citation": {
                "source": "二・二六事件に就て",
                "author": "河合栄治郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ官職を帯びて巡廻するものが、轎夫なきために一歩も進めなくては公務のために憂うべきことである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき重税を課しては国のために憂うべき事であると、佐倉宗吾を気取ったまではいいが、佐倉宗吾のように命を捨てたかといえば、なかなか捨てるどころか、かえって強盗強姦したものもある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人がいかに脳漿を絞っても専門家を凌駕して天下後世へ伝わるほどの名句が出来るはずもないのに、無用な事へ心を労してそれがために実用の智識を等閑にするのは最も憂うべき事だ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "農としては出水を憂うべきだが、遊び好きなる事に於て村の悪太郎等に劣るまじい彼は、畑を流るゝ濁水の音｜颯々として松風の如く心耳一爽の快を先ず感じて、尻高々とからげ、下駄ばきでざぶ／＼渡って見たりして、其日｜限りに水が落ちて了うのを毎に残念に思うのである。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの芝居が、現在、あんなにまで「受ける」というのは、時代的にみて、多少憂うべき徴候ではないでしょうか？",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、話を前に戻せば、現代日本人の憂うべき傾向は、決して、知識の不足でも、学力の劣位でもありません。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中絶は憂うべきことであり、不必要なことである。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで現在の日本にとって、一番憂うべきことは、近い将来における動力源の不足である。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう愚鈍な老人に遠征隊輸送の重任を委ねるのは、革命及び帝政時代の国外亡命者にたいして過度に寛大と厚意を示す復古政府の憂うべき態度から来たものだが、愚かなまでに善良なショーマレーの寝顔を見ていると、この老人をこれ以上不幸にする気はなくなった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし日本人の能率が米国人の能率の三分の一しかないのだとすれば、我ら日本人の将来はまことに憂うべきものである。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国の農家の経済がうまく行かず、従って地方の青年達が都会を指して来るということは憂うべき事と思う。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "内務省の観察によると、高級官吏の若い候補者達のこの憂うべき傾向は、結局今の若い者に腹がないからで、腹を造らせるには、禅寺あたりで修養させるに限るというのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊は、病気と脱走とでいよいよ兵力を弱め、憂うべき状態に陥っている。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "今最後の発育を遂げようとしている総ての作物が、荒い風に会い、強雨にたたかれるということは憂うべきことである。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても只ごとでないらしいのは、彼女を知る者すべてにとって、憂うべきことである。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔の人に憂うべきことが三つあつたが、今はその憂うべきことを通りこして、全く救いがたいものになっているらしい。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
