        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "松島はそうした世渡りに特別の才能をもっており、女の信用を得るのに生まれながら器用さもあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、いぎりすの或る大きい蟹は、生まれながらに甲羅が赤くて美しかつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は生まれながらの傍観者である。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔先生こそ生まれながらの聖人というものではないか、しかも自ら「学ぶ外なし」と言われて、生まれながらの聖では不足とされ、「思えども益無かりき」と語られたではないか、煩悶あればいよいよ学ぶべし、懊悩あれば尚更学ぶべし、およそ心思・智慮・行為・動作に滞るところがあれば、それは即ち困である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれながらの聖人で無いのであれば、天然自然に完全純粋で精美容明な人はいない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我は生まれながらにして、之を知る者にあらず、古を好んで学に努めて之を求める者である」『論語（述而十九）』と言われたのを考え、孔先生が自我自尊の驕り無く、謙遜誠実・小心誠意の心をもって学ばれたことを思うべきである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めから地方官級の家に生まれた人は、貴族をまねて、思想的にも思い上がった人になっている者も多いのに、この夫人は貴族の出でありながら、下の階級へはいって行く運命を生まれながらに持っていたものか、卑しい性格の叔母君であった。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく肩身の狭い日本に生まれながら、その頃の若者はそれぞれ一癖も二癖もあり、吾輩自身も自分がかつてこれほどの事がよく出来たと驚くほどの働きをした。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と生まれながら、そんな誘惑を感ずる事さえやくざな事だと思った。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで打ち明けなかったが、自分は日本でも屈指な豪商の身内に一人子と生まれながら、からだが弱いのと母が継母であるために、父の慈悲から洋行する事になったが、自分には故国が慕われるばかりでなく、葉子のように親しみを覚えさしてくれた人はないので、葉子なしには一刻も外国の土に足を止めている事はできぬ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歓楽に耽溺しやすい、従っていつでも現在をいちばん楽しく過ごすのを生まれながら本能としている葉子は、こんな有頂天な境界から一歩でも踏み出す事を極端に憎んだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もかけずに、無断で人の庭先までも押し入るとは、ふらちなやつと思いましたが、同役同僚とはいうものの、とにもかくにも先輩でしたから、何ご用かと名人みずから立ち上がって縁側まで出迎えると、こやつ、よくよく生まれながらのかたき役でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のいい父親と弱々しく情愛の深い母親とを持ったこの身は、生まれながらにしてすでに薄倖の運命を得てきたのである。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "不仕合せな女に生まれながら、自分はお前というものに取りすがって、今日までこうして生きていたのである。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村には山田｜留吉という生まれながらの白痴があるのだそうです。",
              "citation": {
                "source": "白痴の知恵",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、龍太郎には、生まれながらに悪人の素質があったものか、いったん殺そうと思い立ったが最後、俗にいう悪魔に魅入られたとでもいいますか、どうしても、凶行を演じないではいられなくなったのであります。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしぎな縁女の話一　生まれながらにして、人間以外のものに、すなわち妖怪変化のものの処に縁づくべき約束のもとにあり、その娘が齢ごろになると種々な形式でもってそこに嫁いでゆくというような口碑伝説がいくらもある。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはこの娘は生まれながら水性の主の処へ嫁ぎゆくべき縁女と生まれ合わせていたので、いまはちょうどその時期がきて、これから北方三十里ばかり隔たった閉伊川の岸｜腹帯という所の淵の主のもとにいったのだ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話のほうは生まれながらにそうなれとの因縁でもって山河の主に嫁ぐということである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らの生まれながらの罪を救済するための罪なきものの贖罪としての十字架が、真に愛のシンボルであるとも思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは生まれながらの感情です。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってまた生まれながらの恋愛家でもあるのだ。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "（仏教の「即身即仏」参照）人は生まれながらその人として完全である、その人として生長し、その人として死ねばそれでいいのである。",
              "citation": {
                "source": "自分だけの世界",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれながらにして、完成された芸術を生むということはあり得ません。",
              "citation": {
                "source": "旧作",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくふさふさとしたよい黒髪をもって生まれながら、わざわざ長い時間をかけてその黒髪をちぢらしている。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば人間という動物があくまでも盛んに子を産み、しかもその人間を育てるにはどうしても食物が必要だという以上、さまざまの罪悪や、貧乏のために難儀するのは、われわれの力でいかんともすることのできぬ人間生まれながらの宿命だというのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果的にＯＳの時代は、当初からこれに対応しようとしたマルチ16やパソピア16によってではなく、ベーシックマシンとして生まれながら突如としてＭＳ―ＤＯＳマシンに変身するＰＣ―９８０１によって開かれることになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』すると言下に伝令兵の姿が扉口に現われたが、七尺ゆたかの大男で、その頑丈な手が、生まれながらに馭者にでもなるように出来ているといったやつで――いわば歯医者の手先といった男なんです……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　うまれながらにして大好物。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、紳士、客人には、あるまじき不料簡を、うまれながらにして喜多八の性をうけたしがなさに、忝えと、安敵のやうな笑を漏らした。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
