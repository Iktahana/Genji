        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この歌の心ばっかりは山上憶良様でもわかるまい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊谷直好の和歌に、よもすから木葉かたよる音きけは　　　しのひに風のかよふなりけりというがあれど、自分は山家の生活を知っていながら、この歌の心をげにもと感じたのは、じつに武蔵野の冬の村居の時であった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お組が、ついうつかりと乘せられて、「私にもよくは分らないけれど、あの、何う云ふ事を申すのだえ、歌の心はえ。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お君さんが、ついうつかりと乘せられて、「私にもよくは分らないけれど、あの、何う云ふ事を申すのだえ、歌の心はえ。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "髯が啜る甘酒に、歌の心は見えないが、白い手にむく柿の皮は、染めたささ蟹の糸である。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにや新人のモツトオに觸れデカダン樂派の新星グリークがピアノの律に啜泣く定家卿選歌の心ばかり世にあはれ深きはあらじかし。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹く風をなこその関という歌の心を一言でいい切る事が至難なのと同様に、どうも、親切な教訓ほど、一言で明示する事はむずかしいようである。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに先生はこのたびの茶会に於いて、かの千利休の遺訓と称せられる「茶の湯とはただ湯をわかし茶をたてて、飲むばかりなるものと知るべし」という歌の心を実際に顕現して見せようと計ったのであろう。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのみなもとを悲しめ、而して至醇なそのみなもとの歌の気禀をかりそめにも傷くるな、笛の匂を知れ、完成された大和歌の心根に更に悲しい銀光の燻しをかけよ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより二年目、寛永三年九月｜六日主上二条の御城へ行幸遊ばされ妙解院殿へかの名香を御所望｜有之すなわちこれを献ぜらるる、主上｜叡感有りて「たぐひありと誰かはいはむ末※ふ秋より後のしら菊の花」と申す古歌の心にて、白菊と名附けさせ給由承り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの末木の香は「世の中の憂きを身に積む柴舟やたかぬ先よりこがれ行らん」と申す歌の心にて、柴舟と銘し、御珍蔵なされ候由に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより二年目、寛永三年九月六日｜主上二条の御城へ行幸遊ばされ、妙解院殿へかの名香を御所望有之、すなわちこれを献ぜらる、主上｜叡感有りて、「たぐひありと誰かはいはむ末※ふ秋より後のしら菊の花」と申す古歌の心にて、白菊と名づけさせ給う由承候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの末木の香は、「世の中の憂きを身に積む柴舟やたかぬ先よりこがれ行らん」と申す歌の心にて、柴舟と銘し、御珍蔵なされ候由に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は伯母の家で作つたと云ふ短歌を書いたノートを出して見せたり短歌の心得と云ふやうなありふれた問ひを発したりした。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "業平朝臣の（名にしおはゞいざこととはむ）歌の心をまのあたり、鳥の姿に見たいと言ふ、花につけ、月につけ、をりからの菊紅葉につけての思ひ寄には相違あるまい。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蝮も倒れた時茅の幼芽が立って傷つけたから、山にあって人や畜生の身に立ち困らせる、刺が立つの意で茅を山立ち姫と呼び、人を蝮が咬まば茅に告げて蛇の身に立たしむるぞと脅した歌の心でなかろうか。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌の心は、昔嶋田の時主てふ勇士が、霊有て人を悩ます石を射ると矢が石に立つて抜けず、撫子の花を開いたと藻塩草に出す。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「高しとて何にかはせんなよ竹の、ひとよ二よの仇のふしをば」という古歌の心であった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　重きが上の小夜衣――むかしは殿上人にも宮仕えしたという侍従が、これほどの歌の心を覚りかねたのであろうか。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれも実はその古歌の心を覚っているのであるが、師直の前であらわにそれを説きあかすのを憚って、好い加減に取りつくろって逃げて来た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれが父にきびしく責め問われて、とうとう其の歌の心を正直に白状してしまったのであろうと想像した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小夜衣の歌の心、もう御承知とござりますれば諄うは申しますまい。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ「国民文学」や「文学界」に旗挙げをして、新しい思想運動を興そうとした血気なロマンティックな青年たちに、歌の心を授けた女の多くは、おおかた葉子から血脈を引いた少女らであった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は伯母の家で作ったと云う短歌を書いたノートを出して見せたり、短歌の心得と云うようなありふれた問いを発したりした。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時か式部が兼房の朝臣に送つたと云ふ人知れず物思ふ事は習ひにき花に別れぬ春しなければ　其の歌の心も今こそ赤染衞門に沁々と頷かれる心地がして、優艷極まりなき和泉式部のやうな人に、浮氣に輕卒に一時の戯れに、言ひよつては離れてゆく、流の如き大方の男の群を今更憎まずにはゐられないやうな氣がした。",
              "citation": {
                "source": "誠心院の一夜",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なかなかに己が舟出の旅しもぞ昨日の淵を瀬とも知りぬる』この歌の心をお解し下さりませ。",
              "citation": {
                "source": "誠心院の一夜",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私などにはとても深いことはわかりませんけれども……それでも歌の心持を押しつめて參れば、やはり佛に近づく心が致しますので……』　ある日は窕子はこんなことをそのあるじの僧に言つたりなどした。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やどり木は色変はりぬる秋なれど昔おぼえて澄める月かな　と古風に書かれてある歌の心に、薫は羞恥を覚え、哀れも感じて、里の名も昔ながらに見し人の面がはりせる閨の月かげ　返事ともなくこう口ずさんでいたのを、侍従が弁の尼へ伝えたそうである。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其と同時に、橘に昔を偲ぶと言ふ古歌の心持ちを、格別どの歌に拠ると言ふことなしに思ひ寄せたまでゞあらう。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いている中に、人々の眼からは悲しみの涙が熱く流れ、あわれの運命を傷む溜息が、唇から漏れ、肩を震わせて歌の心に同情致しました。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
