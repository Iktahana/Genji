        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "半七はその結び文をあけて見ると、女文字で「十五や御ようじん」と書いてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいい」　半七はその帳面を受け取って、かの結び文の「十五や御ようじん」と引き合わせると、松吉も縁へ這いあがって覗き込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうじんには、いろわ、わからぬなれども、さむき着ものであつたから、あを（青）であらうといへば、おてるわ、かんしんした。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "精進日覚、×日　　朝×日　　昼まで×日　　終日しょうじん　そんなふうに書いて張ってあるが、三十日間に、幾日もあきのない家もあった。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処にいふもおずしやうじんの如きは、殊に名高いものになつて居た。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者なんかで、遠方へ出稼ぎに行つてるものも、やはり、所謂其もおずしやうじんを実行したものだ。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もおずしやうじんは、三个日は無論厳かに実行するのだが、其数日前から、既に、そろ／＼始められるので、年内に煤掃きをすまして、餅を搗くと、すつかり精進に入る。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "来客があつても、もおずしやうじんのなかまうちである村の人は、なるべくは、座敷にも上げまいとする。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ売り　二つ売り　　×工賃へらされた金箔で仏像のおめかし　　×太陽に飢えてつるはし闇を掘りつづける◆九月一日発行『りうじん街』第一巻第七号八月・九月合併号柳人塔（河北）鶴　彬――自由律川柳――網窓あけ放てば　　ひらいてた――つぼみよ死ね！",
              "citation": {
                "source": "鶴彬全川柳",
                "author": "鶴彬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すぐ騙されさうに見えるわよ、ようじんしないと困ることがあるわ。",
              "citation": {
                "source": "汽車で逢つた女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "文士というものは原稿のうえに同じ詩人とか文士をほめるということは、よくよくのことでないと対手方の名前を原稿には書かないものだ、それほど、ようじん深く対手を見つめてから名前なら名前をやっと書くものだ、だが萩原朔太郎はそんなことはお構いなしに私のことを、率直にほめてくれていた。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し三階に登るときには、ようじん深く滿子が外出してゐる時とか、洗濯をしてゐて相當時間のかかる仕事を見てから、登ることにしてゐた。",
              "citation": {
                "source": "帆の世界",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンリ　だけどなんだなあ、ありゃ全体、どう言うじんかねえ？",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもいいから、暫く御逗留なさいね、少しの間、この福井の御城下を見物したり、三国へとうじんぼうをたずねたりして、当分こちらにいらっしゃいね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゅうふうという　びょうきは　子どもには　かからぬ、わしの　ような　ろうじんにだけ　ある　びょうきじゃ。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの　くすりは、ろうじんの　ちゅうふうには　よく　きくが、子どもが　なめたら　いのちが　なくなる。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一休さんは　ようじん　おさおさ　おこたりなく、いえに　はいりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも　一休さんと　したしく　して　いる、みえいどうという　おうぎやの　ろうじんふうふが、ある日　とつぜん　一休さんを　たずねてきて、「一休さん、ながく　おつきあい　いただきましたが、このたび　わけあって　みせを　やめ、くにに　かえる　ことになりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろうじんふうふは、目に　なみだを　ため、「とんでも　ございません。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ろうじんふうふは　びっくりして　しまいました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ろうじんふうふから　ふでと　すみを　かりると、一休さんは、「さあ、わたしは　今日から　あなたがたの　むすこです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、いって、ろうじんふうふを　あそびに　だして　やりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうがた、ろうじんふうふが「一休さん　どうなすったかな。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようじんするがいいよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「火のようじん……。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ようじんしないと……」　そのこえがきえると、ゆかが、ぱっと二つにわれて、四かくなあながひらきました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、あいてには、目に見えない手下が、ついているんですから、ようじんなさらないと。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしぎなろうじん　木村さんのうちの近くに、こうしゅう電話が立っていました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが、そのまわりを取りまいていると、ドアが開いて、中から、ひとりのろうじんが出てきました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、あっけにとられて、そのろうじんを見送っていましたが、ポケット小ぞうは、明智たんていのぶかに、なにかささやくと、そのまま、ろうじんのあとをつけていきました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
