          ],
          "literary": [
            {
              "text": "花村様が英雄でも討手に敵対したが最後必ず打ち負けるでございましょう」「私はそれとは反対じゃ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝はよし打ち負けるとも、けっして負けることのない軍隊に属しているのだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に網を船の底へうちまける。",
              "citation": {
                "source": "大謀網",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひでえところだなと、栄二が思わず顔をしかめたとき、雨がうちまけるようなひどい降りになり、さぶは長屋の一軒へとびこんだ。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
