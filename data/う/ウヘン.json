        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "紙の左上から右辺の中ほどまで二条の並行曲線が引いてあるのが上野の麓を通る鉄道線路を示している。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」此「而」の字の中の縦線二条が右辺に逸出してゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのうち右辺からかけて室を一周し終ろうとする際に、思いがけなくも、法水のすぐ横手――扉から右寄りの壁に闇が破れた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "観経曼陀羅の中にも、内外陣左辺右辺のとり扱ひについて、種々の相違はあるやうだが、定善義十三観の中、最重く見られてゐるのが、日想観である。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右辺左辺と、位置を別にしてゐるが、順序として、定善義第一日想観に続く様に解せられる所から、何かの関聯が、考へられて居たのでないかと思ふ。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "観経曼陀羅の中にも、内外陣左辺右辺のとり扱いについて、種々の相違はあるようだが、定善義十三観の中、最重く見られているのが、日想観である。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右辺左辺と、位置を別にしているが、順序として、定善義第一日想観に続く様に解せられる所から、何かの関聯が、考えられて居たのでないかと思う。",
              "citation": {
                "source": "山越しの阿弥陀像の画因",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は門の右辺に横たわって顔を地面に向けていたが、彼の顔を見るとわっと泣き出した。",
              "citation": {
                "source": "幸福な家庭",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "右辺はΩb(pb, π, ρ ……)となり、同じ変数 pb の函数であって、初めゼロから増大し次に減少してゼロ（無限遠点において）となる函数である。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこれらの二方程式においては、左辺は同一であって、従って右辺の間に方程式Otpt+Oppp+Okpk+ …… =Da+Dbpb+Dcpc+Ddpd+ ……が成立する。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "不等式の右辺の唯一の項Ｕは、pt の値がゼロであるときにゼロであるのはもちろん、この pt が正のある値をとってもなおゼロである。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "右辺は同じ変数 pt の函数であって、初め増加函数であって、次いで減少函数となる。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この右辺は幾何学的には販売曲線 MN によって表わされ得る。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生きくれよ」というへんな言葉ではじまる短歌ばかり、五十でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはなんというへんな、わけのわからんやつだろうと、またいつもの感を深くしたのである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうへんです」　と、聞きかえしたが、そのとき僕の脳裏に電光のようにひらめいたものがあった。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、曾呂利よ」「へーい」「へーい」というへんじが、トラ十の気に入った。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がよく知ってる人だが、どんな人だかはわからない、そういうへんな人が、やって来るような気がしますよ」　私はだんろに薪をくべて、さかんにもやしました。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうへんてこなやつが、さっきからウロウロしているんだ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうへんな人形の力を借りなければ取出せない場所というと……」　田鍋課長にも、全く見当がつかなかった。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、お化けというよりもそういうへんな顔をした怪神とも見える。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うへん、ま、仕方がないわ。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っていますか、道夫さんは、四次元世界がどんなものであるかということを」「ぼく、知らない」　道夫は、なぜ四次元などというへんな名前のものを大事そうにかつぎだしたのか、気がしれなかった。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "酋長ミンチが、やがて椰子の葉でこしらえた大きな団扇のようなものを、右手にさしあげて頭の上の方でふると、がらがらというへんな音が、あたりになりひびいた。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは各国の学者が、このムビウムを発見したハンガリーの天文学者ムービー氏のことを気が変だといい、そのために、そういうへんな名がついたのだった。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "給料をもらうことは当然のような気がし、人に与えることは自分をよくみせたいというへんな虚栄だと思ってやめてしまった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お父さんは、こうへんじをしました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも殺されたばかりの重信がのこりの絵を仕上げにかえってきているところいかにも芸道の士の幽魂らしく、さらにその落款の「朱肉も乾かず」というへんな生々とした実感さ。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、頭がかうへんにしびれて来やがつて、ひとりでに天空へ舞ひあがるやうな、一種なんともいへない荘厳な感動で、全身がぶるぶるふるへる始末さ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　するとこういうへんじがかえってきた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
