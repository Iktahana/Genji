        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中にみえる杉の植木は、いといとしめつぽくは感じる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が蛇を追ったといって叱られ、植木屋が筍を抜いたといって怒られ、はては『おババさま』の姑でさえが、枯れた朝顔をぬいたというので『おババさま好き人です。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木が好きで、學校のぐるりに樣々の植木を、優雅に配置し、ときどき、ひとり、兩手をうしろに組んで、その植木の間を、ゆつくり縫つて歩いてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の事も子供の事も、ちっとも心配していない様子で、ただ、お庭の植木の事ばっかり言って寄こします。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば菓子屋、植木屋、吹屋、射的場の前には、今一客を止めず。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず映画に現われたのは一つの小さな植木鉢であった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つみびとの歌　　阿部六郎にわが生は、下手な植木師らにあまりに夙く、手を入れられた悲しさよ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう家は大抵周囲に植木が植込んであって、それが有力な障壁の役をしたものらしい。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工房の外は廻り縁になっていて、矩形の細長い庭には植木も少しはあった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は腰高の塗骨障子を境にして居間と台所との二間のみなれど竹の濡縁の外には聊かなる小庭ありと覚しく、手水鉢のほとりより竹の板目には蔦をからませ、高く釣りたる棚の上には植木鉢を置きたるに、猶表側の見付を見れば入口の庇、戸袋、板目なぞも狭き処を皆それぞれに意匠して網代、船板、洒竹などを用ゐ云々」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早それはいひツこなしとゝめるも云ふも一筋道横町の方に植木は多しこちへと招けば走りよるぬり下駄の音カラコロリ琴ひく盲女は今の世の朝顔か露のひぬまのあはれ／＼粟の水飴めしませとゆるく甘くいふ隣にあつ焼の塩せんべいかたきをむねとしたるもをかし。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人に聞いてみると、せんだって四つ目垣の朽ちたのを取り換えたとき、植木屋だか、その助手だかが無造作に根こそぎ引きむしってしまったらしい。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物を扱う商売でありながら植物をかわいがらない植木屋もあると見える。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手な植木屋が良い木を枯らす。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の前には梅と福寿草をあしらった植木鉢が並んでいた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の門、植木屋の庭、花屋の店など、坂下を挟みて町の入口にはあたれど、のぼるに従いて、ただ畑ばかりとなれり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の檜葉の手入れをしていた植木屋たちはしかし平気で何事も起こっていないような顔をして仕事を続けていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木鉢や、金魚鉢が、要所要所に置かれて、小ざっぱりした散髪屋である。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向側の鏡が、九枚も上手に継いであって、店が丁度二倍の広さに見えるやうになって居り、糸杉やこめ栂の植木鉢がぞろっとならび、親方はもちろん理髪アーティストで、外にもアーティストが六人もゐるんですからね、殊に技術の点になると、実に念入りなもんでした。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら、今夜よく寝んで、あしたはマリオ農学校、マリオ工学校、マリオ商学校、三つだけ視て歩いても大丈夫だと思って、気もちよく青い植木鉢や、アーティストの白い指の動くのや、チャキチャキ鳴る鋏の銀の影をながめて居りました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にお庭の立木にも植木屋の手が這入らなくなったらしい。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに植木屋夫婦が暮している。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め植木屋夫婦が引越して来た時、井戸がないので何卒か水を汲ましてくれと大庭家に依頼みに来た。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方で木戸を丈夫に造り、開閉を厳重にするという条件であったが、植木屋は其処らの籔から青竹を切って来て、これに杉の葉など交ぜ加えて無細工の木戸を造くって了った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋の女房のお源は、これを聞きつけ「それで沢山だ、どうせ私共の力で大工さんの作るような立派な木戸が出来るものか」　と井戸辺で釜の底を洗いながら言った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃア大工さんを頼めば可い」とお徳はお源の言葉が癪に触り、植木屋の貧乏なことを知りながら言った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "生の牛乳にうえきったかれらとしては、さもあるべきことである。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "めし屋ののれんの中からは、味噌汁やご飯の香りがうえきった清造の鼻先に、しみつくようににおってきました。",
              "citation": {
                "source": "清造と沼",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると　うえきばちの　なかかもしれない。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしで　ふみつけられそうに　なりましたが、　ピーターは　まどの　そとへと　とびだして　ついでに　うえきを　３つ　たおしました。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            }
          ]
        }
