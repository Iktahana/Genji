        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "僕は高森のことを想ふと、いつも一匹の美しい仔熊を聯想する。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人美しい女が目にとまつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい女といふものはよいものである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に透明な青味を帯びた、美しい貝のやうな詩である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの詩集は、北原兄の『思ひ出』以後における日本唯一の美しい抒情小曲集である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには少年に特有なあの美しい感傷と、生娘のやうな純潔の気高さがあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生は、彼にとつては一つの美しい現実であり、同時にまた理想である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私共の求めてゐたものは、もつと鮮新で、もつと自由で、そしてもつとしんみりとした情熱をもつた、純日本言葉の美しい音楽であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤村氏の自選詩集には、過去の作品での最も秀れたもの、最も純粹で美しいものばかりが選りぬいてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "病弱を美しいと思い描いたことがなかったか。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くあの「ポツダム宣言」の約束を全部果して、そうして小さくても美しい平和の独立国になるように、ああ、私は命でも何でもみんな捨てて祈っています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たち、さびしく無力なのだから、他になんにもできないのだから、せめて言葉だけでも、誠実こめてお贈りするのが、まことの、謙譲の美しい生きかたである、と僕はいまでは信じています。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、美しい結婚できます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この遭難者の美しい行為を、一体、誰が見ていたのだろう。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その美しい行為は厳然たる事実として、語られている。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも知られぬ或る日、或る一隅に於ける諸君の美しい行為は、かならず一群の作者たちに依って、あやまたず、のこりくまなく、子々孫々に語り伝えられるであろう。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座通りといふ賑やかな美しいまちがある。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、どうやら無事に言い納めた時に、三十歳を少し越えたくらいの美しい人があらわれ、しとやかに一礼して、「はじめてお目にかかります。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて、またひとり、三十ちょっと前くらいの美しい人があらわれ、これもやはり、姉でございます、という御挨拶をなさるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」下の姉さんが、上の姉さんの背後から美しい笑顔をのぞかせて言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼女の鼻は美しい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想的に美しいばかりでなく目に美しい物が我々には何れだけ必要だか分らないと思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今、この訳詩を読んだ西洋人の心象には、耶蘇教寺院のベルが鳴つてる町の通りを、美しい花輪や花束の群が、雲のやうに行列して行く光景、即ち葬式のイメーヂが浮んだのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉場や避暑地の興味に於ける大部分は、一種のロマンチツクな夢幻的情趣――山巒の奥深く美しい生活の夢を捉へるといふやうな、言はば山間都市に対する蜃気楼的な幻想――にある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は相当に美しいが、何分近在の百姓が大勢詰めかけるので、伊香保そのものの空気が、まるで田舎の温泉場に変つてしまふ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塵埃にくすぶった草木の葉が洗われて美しい濃緑に返るのを見ると自分の脳の濁りも一緒に洗い清められたような心持がする。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい毛氈がいつでも敷いてあって、欄間に木彫の竜の眼が光っていた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処で買ったかと聞いたら、町の新店にこんな絵や、もっと大きな美しいのが沢山に来ている、ナポレオンの戦争の絵があって、それも欲しかったと云う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
