        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……口惜い、）と恍惚して、枕にひしと喰つかしって、うむと云うが最期で、の、身二ツになりはならしったが、産声も聞えず、両方ともそれなりけり。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が空に響くようなからりと晴れた小春日和だったが、翌日からしと／＼と雨が降り続いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度公の薨ぜられた其年に将門は下総に勇ましい産声をあげたのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が室に響くようなからりと晴れた小春日和だったが、翌日からしとしとと雨が降り続いた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、産声が空に響くようなからりとした小春日和だったが、翌日からしとしと雨が降り続いた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　十一　しばらくして菊枝が細い声、「もし」「や、産声を挙げたわ、さあ、安産、安産。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は泰然自若として、不景気のソファに腰をおろしてしまつたね、とにかくお前は私の生みの土地ではあつたが、たゞ私に瞬間、産声をあげさしたところお前は邪険ではなかつたが決して親切とは言へなかつたよ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの恐ろしい沈黙の中から起こる強い快い赤児の産声――やみがたい母性の意識――「われすでに世に勝てり」とでもいってみたい不思議な誇り――同時に重く胸を押えつける生の暗い急変。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くしてかすかな産声が気息もつけない緊張の沈黙を破って細く響いた。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人造人間の発見」「試験管から人間が生れる」「今秋までにはオギャアと産声をあげる」というようなセンセーショナルな標題をかかげているのがあるかと思うと、村木博士と内藤女史との肖像をならべて「これが試験管で出来る赤ちゃんの御両親です」などと書いているのもあった。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして人々は草鞋がけで、また足弱の婦人子供はしやんしやんと鳴る鈴をつけた馬の背で、或ひは藤蔓で編まれた山駕籠で櫛型の丘を登り降りしてゐた頃に、私は、何故か、この村で産声を挙げさせられたといふ話は元から知つてゐた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこそあの怪しげな呻き声も、のたうつような戦慄陣痛の苦悶であり、奇妙な風船笛のような鳴き声も、すこやかな産声であり、怪しげな濁り水も、胎児の保護を終えた軽やかな羊水であったのか、とわれながらいまさらのように呆れ返るのだった。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日の午前九時四十分　健康な産声を高々と、独りの姉を補佐すべく産れて来た児は、七日後に寿江子と名づけられた。",
              "citation": {
                "source": "暁光",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の生んだ子が産声を立てるのを聞くと云ふものは、どの位嬉しいものだか、お前さんまだ知らないのだ。",
              "citation": {
                "source": "聖ニコラウスの夜",
                "author": "SANKT NIKOLAUS BEI DEN SCHIFFERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹松たちがソフトウエアによって命を吹き込めば、パーソナル・ダイナミック・メディアは、今、ここで産声を上げるのだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は余程お人好しと見えて、何も知らずに鶴江殿を嫁に貰ったのか、但しは万事心得ていて、それを知らぬ顔でいたのかそこまでは聴かなんだが、何しろそこで産声を挙げられたのが金三郎様じゃ。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃父は家族を携えて江戸の藩邸に住んでいたので、私はこの江戸で産声をあげたのであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その叫喊は生まれいずる者の産声であり、その恐怖は新しき太陽に対する眩惑であり、その血潮は新たに生まれいでた赤児の産湯であった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時に、家の中から、お前の産声が聞こえてきたのだ。",
              "citation": {
                "source": "彗星の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「魔の空間」の撃墜　力強い第一宇宙戦隊の産声に、感激を新たにして、帆村荘六は、左倉少佐と山岸中尉の許を辞してもどった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "言ひ換へれば、天子、毎年、新に蘇らせられると言ふ信仰の下に、其産声を意味する祝詞が、御代始めの祝詞ともなり、同じ考へから、時に行はれた大嘗祭の祝詞となり、或は、元旦ののりととも、分れて行つたのであつた。",
              "citation": {
                "source": "高御座",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟、即位ののりとは、神自体にして、神人なる天子の産声であり、また、毎年復活して、宣り下し給ふ詔旨でもあつたのである。",
              "citation": {
                "source": "高御座",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "托胎の月満ちて、唯我独尊を叫ぶ産声があがる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ娑婆塞ぎであろうが、それでも産声だけは確に挙げた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙なことをいうようだが、おれの回想のなかで産声をあげた小さな魂は、幸か不幸か、そんな年廻りを身につけて生れて来たのだ。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれ出る子供に不具者がありはしないかと、心配されていたが丈夫な赤ちゃんがつぎつぎと産声をあげた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥羽伏見に敗走した将軍｜慶喜東帰して、江戸城内外戦火を予期して沸騰するさなかから、芝新銭座に「慶応義塾」が産声をあげた。",
              "citation": {
                "source": "福沢諭吉",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "此二大山脈の始まる所に潺湲たる産声をあげて、其懐に養われつつ倶に北に走ること三十里、その尽くる所に雪を噴く奔湍と雷のような瀬の音とを収めて、日本海に注ぐものは即ち幽峭並ぶものなき黒部の峡流である。",
              "citation": {
                "source": "黒部峡谷",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は七ヵ月の早生児で、祖母の肌に懐かれて、漸く産声を上げたという。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "真山あさひは所内で女の子を産んだが、そのあさひ自身、二十五年前に栃木刑務所の産室で産声をあげた。",
              "citation": {
                "source": "虹の橋",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
