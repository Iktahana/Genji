            }
          ],
          "literary": [
            {
              "text": "「僕ァね、こなひだン所で昨日またうんと飲んぢやつたよ」またしても三田村は大きい声で笑ふのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田様のお家の、あの画が、もつと、うんと、高くなつてくれたらいゝと思つて居ります。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊田様のお家の、あの画が、もっと、うんと、高くなってくれたらいいと思って居ります。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "液體力學の教へる處ではかういふ崖の角は風力が無限大になつて壓力のうんと下がらうとする處である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だだっぴろく……うんと手足を空に延ばした春の桜が、しゃんら、しゃらしゃらとどこかへ飛んで行ってしまった。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この秋は邸のまわりの栗の樹からうんと実もとれますし、来秋から邸についた葡萄畑で素敵な新酒を造りますよ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）猫は立ちあがりからだをうんと延ばしかすかにかすかにミウと鳴きするりと暗の中へ流れて行った。",
              "citation": {
                "source": "猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、悦治はひとりはさみを出したので、みんなにうんとはやされたほかに鬼になった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんうんと心配してるぞ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに『えびづる』や『あけび』をうんと土産に採って来ます」「私は一人で居るのはいやだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　脚は一八〇プロセントくらいに、眼と眼はうんとくっつけるか、思い切り開いて、さてこの腕をどうやろう。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんったらそんな事ちっとも言って寄こさないのね」　「親の儂に一言の挨拶もしねえで、何処の馬の骨か分らねえ様な女と一緒になりやがって………」　「兄さん帰って来たら、うんと叱言を言ってやるといいわ」　「おや？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして穴がすつかり埋められてしまふと、蜂は暫く穴のまはりを歩きまはつてゐたが、やがてぷうんと翅音を立てながら、黒黄斑の弧線を清澄な秋の空間に描きつつどこともなく飛び去つて行つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また髭にうんと絞られるぜ‥‥」「可哀想になあ‥‥」　中根熊吉の「馬さん」は二｜年兵の二｜等卒で、中隊でもノロマとお人好しとで有名だつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを米屋の番頭から聞きこんだあるはしっこい女は、じゃ、うちにある外米を売ってあげよう、うんと安くしてあげてもかまわないから、と云いだした。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身の力をこめて、うんと枕木を踏んばり、それで前へ押さなきゃならない。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「署長さんにうんと叱られたぞ」「署長さんに叱られたかい。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさ出来ればよ、うなも町さ出はてもうんといい女子だづごともわがら。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は何時のまにか、うんと顏を陰氣にしてしまつてゐた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "根ッから早や狐でなければ乗せ得そうにもない奴じゃが、そこはおらが口じゃ、うまく仲人して、二月や三月はお嬢様がご不自由のねえように、翌日はものにしてうんとここへ担ぎ込みます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生が郵便配達をつかまえて、ビールの息とシガーの煙を吹きかけながら、ことしもまたうんと書留を持って来てくれよなどと言って困らせている。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日思い切って左の頬をうんと切り落としてから後はこの不思議な幽霊に脅かされる事は二度となくなった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うんと、うしろを短く刈り上げて下さい。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次には、うんと引っぱり歩いて、こづきまわして、面皮をひんむいてやろうと思った。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子は、ねばねばして、気味がわるいから、あなたに一度うんと叱っていただきたいと思いまして、と奥さんが言い、旦那さんは、そうか、どこにいるんだ、と言い、奥さんは平然と、どこかそこらにいるでしょう？",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、誰かと、うんと戦争の話をしたい。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんにさう言つて、うんと笑はれましたけれど。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お氣になさらず、うんとおさわぎになつたはうが、ようございますわ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
