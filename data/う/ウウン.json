[
  {
    "uuid": "2bc73c61-a591-59e9-9124-965577f1351c",
    "entry": "ううん",
    "reading": {
      "primary": "ううん",
      "alternatives": [
        "うーん",
        "ウーン"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "um",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「これ、誰のものですか」「ううん、わかりません」",
              "source": "幻辞"
            },
            {
              "text": "友人に「行きたい？」と聞かれて、彼は「ううん」と首を振った。",
              "source": "幻辞"
            },
            {
              "text": "店員に「何かお探しですか？」と聞かれ、「ううん、大丈夫です」と返答した。",
              "source": "幻辞"
            },
            {
              "text": "子どもが怒られて「ううん、やっていません」と否定している。",
              "source": "幻辞"
            },
            {
              "text": "母が「宿題は終わった？」と聞くと、子どもが「ううん」と答えた。",
              "source": "幻辞"
            },
            {
              "text": "兄が妹に「これで足りる？」と聞き、妹が「ううん」と首を横に振った。",
              "source": "幻辞"
            },
            {
              "text": "駅で道を聞かれ、「ううん、私も初めてです」と答えた。",
              "source": "幻辞"
            },
            {
              "text": "医者が患者に「このような症状は以前ありましたか？」と聞くと、「ううん」と返答。",
              "source": "幻辞"
            },
            {
              "text": "上司が部下に「進捗状況は順調か？」と聞き、「ううん」と報告された。",
              "source": "幻辞"
            },
            {
              "text": "友人の申し出に「気持ちは嬉しいが、ううん、遠慮しておく」と返した。",
              "source": "幻辞"
            },
            {
              "text": "子どもが転んで痛がりながら「ううん、もう大丈夫」と言った。",
              "source": "幻辞"
            },
            {
              "text": "会議で案を提示されたが、「ううん、このやり方では無理だ」と意見した。",
              "source": "幻辞"
            },
            {
              "text": "親友に「私について来てくれる？」と聞き、「ううん、今日は用事がある」と返事。",
              "source": "幻辞"
            },
            {
              "text": "客が商品を確認して「ううん、これで良い」と購入を決めた。",
              "source": "幻辞"
            },
            {
              "text": "夫が妻に「夜遅くなるかも」と言い、妻が「ううん、そう」と返事した。",
              "source": "幻辞"
            },
            {
              "text": "採用面接で応募者に「前職で営業経験がありますか？」と聞き、「ううん」と返答。",
              "source": "幻辞"
            },
            {
              "text": "生徒が先生に「この問題、分かりますか？」と聞かれ「ううん、難しい」と答えた。",
              "source": "幻辞"
            },
            {
              "text": "パーティーで「何か飲みますか？」と聞かれて「ううん、今は結構です」と返した。",
              "source": "幻辞"
            },
            {
              "text": "警察官が容疑者に「犯行を認めますか？」と質問し、「ううん」と否認した。",
              "source": "幻辞"
            },
            {
              "text": "恋人に「明日一緒にいられる？」と聞き、「ううん、残業があるの」と返答した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お侍の果し合か」　「ううん」　「じゃ渡世人か、其奴ァ面白え」　石松、起き上って表へ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝店　石松、お静に、　「お父っつあん怒ってたか」　「ううん」　源兵衛、呼ぶ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、彼女はずるそうに白い眼をひらくと、「ううん、おれがよくなかった。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ううん」と勝子は首をふって「『ヨ』ちっとこへ行くの」とまたやっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、しょうせんかく」「朝鮮閣？",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちがいますともわらびます」「ううん」鼻ごえをして、勝子は義兄を打つ真似をした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木樵は草の中にどしりと落ちてううんと云ひながら少し動いたやうでしたがまだ気がつきませんでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木樵は草の中にどしりと落ちてううんと云いながら少し動いたようでしたがまだ気がつきませんでした。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、ううん、そう号令を掛けちゃ出せやしませんさ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ううん」　と、君勇は床几に腰を掛けながら、「――今日は浮気休み」　寂しく笑った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん……」　千枝子は、ふと小郷虎吉の脂切った顔を想い出した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泣いちゃ判らんよ」　鶴雄は乾いた声を不安そうに出しながら、「――二階のお客さんに泣かされたのか」　鈴子の顔を覗き込むと、「ううん」　と、可愛いい首を振って。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ううん」　と、冴子は勿論首を振った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、なんでもあれへん。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ううん……どうだっていいことなんだよ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、ただその活動はね、お客へ向って戦争へ行け行けって、やたらに進軍ラッパを吹いたり太鼓鳴らしたりしているの。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、ただちょっとふらりと来てみたのさ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、お父さんよかったら、今日にでも話してみるつもりだわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん別に……後で話すわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ううん、何ということなしいやになったの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　若林が訊くので銀子も、「ううん、そうでもないの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、召集の声をきくと久助君は、「ううん」と、向かふに聞えるやうに返事をして、すつくと立ちあがつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パパ、一郎が……ううん、あの男の児が……そっくりなの一郎に……パパ……」「うん、うん」「あの子にすこし、随いてって好い？",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、云い過ぎたから好かったの、あははははは」　規矩男も「あはははははあ」と笑っちまうと、あとは二人とも案外けろりとして、さっさと歩き出した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
