    "definitions": [
      {
        "index": 1,
        "gloss": "to float",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある日二階の縁側に立って南から西の空に浮かぶ雲をながめていた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また江上の夏の夜の情趣も浮かぶであろう。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこう考えて、浮かぶことのできない、とうてい出ずることのできない、深い悲しみの淵に沈んだような気がした。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はありありと亡き人の俤が目に浮かぶ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この条件に及第する樹の画があるかと思ってみても「雪」の枯枝などがやはり先ず心に浮かぶ。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六浮かぶ瀬も無い。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の眠｜催す様なるこの水音を源叔父は聞くともなく聞きてさまざまの楽しきことのみ思いつづけ、悲しきこと、気がかりのこと、胸に浮かぶ時は櫓握る手に力入れて頭振りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "書く気持がぐらついて来たのがその最初で、そうこうするうちに頭に浮かぶことがそれを書きつけようとする瞬間に変に憶い出せなくなって来たりした。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけの上から「上」に浮かぶものはいろいろあるが、それは別に働力のためであると考えている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおぜいの押し合う力の合力の自然変異のために神輿が不規則な運動をなしている状態は、顕微鏡下でたとえばアルコホルに浮かぶアルミニウムの微細な薄片のブラウン運動と非常によく似た状態を示している。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの多くは科学の世界の表層に浮かぶ美しいシャボン玉を連ねた美しい詩であり、素人の好奇心を刺激するような文明の利器を陳列したおもしろい見世物ではあるが、科学の本質に対する世人の理解を深め、科学と人生との交渉の真に新しい可能性を暗示するようなものは存外にはなはだまれである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験や観測でなくて純粋な理論的の考察であっても、一つの指導的なイデーが頭に浮かぶのは時としては瞬間的であって、そうして、かろうじて意識の水平線の上に現われるか現われないかという場合がある。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば場面が一転して、海上から見た島山の美しい景色が映写された瞬間にわれわれの頭には「どこだろう」という疑問が浮かぶ。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場面が、あとの「氷をもって来い」でフラッシュバックされて観客の頭の中に浮かぶ。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ宵ながら月は高く澄んで、さえた光を野にも山にもみなぎらし、野末には靄かかりて夢のごとく、林は煙をこめて浮かぶがごとく、背の低い川やなぎの葉末に置く露は玉のように輝いている。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間には私はそこらの店先にある商品を点検したり、集まっている人たちの顔やあるいは青空に浮かぶ雲の形態を研究したりする。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、水上に浮かぶ二つの浮き草の花が水中に隠れた根によって連絡されているようなものである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからなほ三十分も飲んだ後、辞して立たうとすると、先刻は腰も打つたとみえ、腰が痛くてよろけさうになり、医者に助けられて自動車に入れられた時は、なんとも羞しく、玄関に立つて可笑しさを怺へてゐた奥さんの顔は、自動車が田圃の中の道路を走つてゐる間中、眼に浮かぶのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議とはいいながらも、こうなると誰の胸にも先ず浮かぶのは、余一郎さんとお角さんとの関係です。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら色や愛嬌を売る稼業でも、頭脳と意地のないのは、何年たっても浮かぶ瀬がなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉妬を感ずる理由は少しもなかったが、たまに外出した均平の帰りが遅かったりすると、すぐ子供たちのことが頭脳に浮かぶのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼い無限の海原が自分を吸い込もうとして蜿蜒をうっている、それがまず目に浮かぶのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんが、あのお家のがらんと広いお台所で、夕方ひとり、白い女らしい手で、上手にお魚をお料理していた様子も、はっきり浮かぶ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた、辻の真昼どき、白楊にほひわななき、雲浮かぶ空の色｜生あつく蒸しも汗ばむ街よ、あな音もなし、鐘はなほ鳴りもわたらね、炎上の光また眼にうつり、壁ぞ狂へる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままにて郷にかえらば、学成らずして汚名を負いたる身の浮かぶ瀬あらじ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "繿縷をまとうた蘇武の目の中に、ときとして浮かぶかすかな憐愍の色を、豪奢な貂裘をまとうた右校王李陵はなによりも恐れた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が去ってから始めて、牛男の顔に会体の知れぬ笑が微かに浮かぶ。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かせ給ふは何ならん、何事かの御打合せを御朋友の許へか、さらずば御母上に御機嫌うかゞひの御状か、さらずば御胸にうかぶ妄想のすて所、詩か歌か。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔残丘の雪の上に〕残丘の雪の上に、　　　　　　　　二すぢうかぶ雲ありて、誰かは知らねサラアなる、　　　　女のおもひをうつしたる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹藤に越ゆる尾根の上に、　　なまこの雲ぞうかぶなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
