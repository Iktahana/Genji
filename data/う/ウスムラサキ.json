        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "男、コーヒーを啜つて天井の隅を凝視したまゝ――右手の指に挟まれた葉巻から、冷い空気の中を薄紫の煙が細く細く立ちのぼる。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "細長いかっちりした薄紫の鈴――桐の花です。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらやましくて、私のこしらへたのはしかし、さすがに墨色では粋すぎるので薄紫で菱形を大きく出して見ました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸女「薄紫といふやうなあんばいで意気だねえ」上方女「いつかう粋ぢや。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "西の方の空は一体に薄紫にぼかした様な色になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、よごれた彼等は、ユラ／＼と立上る薄紫の煙に姿がボカされた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みかかった雲は、東方からさしてくる赤い日の出に、薄紫色に染めぬかれて、ゆるやかに動いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……顔馴染の濃い紅、薄紫、雪の膚の姉様たちが、この暗夜を、すっと門を出る、……と偶と寂しくなった。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……発と朱が底へ漲ると、銀を蔽ふて、三｜脚の火が七つに分れて、青く、忽ち、薄紫に、藍を投げて軽く煽つた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みくり」を通過して平たくひしゃげた綿の断片には種子の皮の色素が薄紫の線条となってほのかに付着していたと思う。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓障子の紙の色が黒みがゝつた薄紫になつた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の壞れた所を物の五十間ほども土俵で喰ひ留めた、その土俵の藁は半ば土になつて、畑中に盛り上つた砂の間からは、所々に一かたまりになつて、大根の花が薄紫に咲き出て居た。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手も細り、色傘を重そうに支いて、片手に白塩瀬に翁格子、薄紫の裏の着いた、銀貨入を持っていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "点滴るごとき情の光を、薄紫の裏に包んだ、内気な人の可懐しさ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の屋根と相向つて、眞蒼な流を隔てた薄紫の山がある。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菖蒲は取つて、足許に投げた、薄紫が足袋を染める。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薄紫の花一輪、紅の珊瑚に、深みどりの、海の色添う小さな枝、実は二ツついたりけり。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟か袖かであるらしく、且つ暗の綾の、薄紫の影が籠む。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきれいなのが三人ばかりと、私たち、揃つて、前津の田畝あたりを、冬霧の薄紫にそゞろ歩きして、一寸した茶屋へ憩んだ時だ。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい虹が立ちまして、盛りの藤の花と、つつじと一所に、お庭の池に影の映りましたのが、薄紫の頭で、胸に炎の搦みました、真紅なつつじの羽の交った、その虹の尾を曳きました大きな鳥が、お二階を覗いておりますように見えたのでございます。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その森、その樹立は、……春雨の煙るとばかり見る目には、三ツ五ツ縦に並べた薄紫の眉刷毛であろう。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は水線に玉を沈めて、雪の晴れた白山に、薄紫の霧がかかったのである。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古奈、長岡――長岡を出た山路には、遅桜の牡丹咲が薄紫に咲いていた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふいはれもあらで、薄紫のかはりたる、藤色の衣着けられ候ひき。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五　河の氷がようやく崩れはじめ、大洋の果てに薄紫の濛靄が煙るころ、銀子はよその家の妓三四人と、廻船問屋筋の旦那衆につれられて、塩釜へ参詣したことがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "『青、薄紫、濃褐色！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い木だまにはそのうすむらさきの立派な花はふらふらうすぐろくひらめくだけではっきり見えませんでした。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんじりともしないで東の空がぼうっとうすむらさきになったころ見ますと屋根の上には一面に白いきらきらしたものがしいてあります。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こころこころをばなににたとへんこころはあぢさゐの花ももいろに咲く日はあれどうすむらさきの思ひ出ばかりはせんなくて。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前もうしろも、上も下もまつたくとろりとしたやうなうすむらさきの霞が、深々と垂れ籠めてゐましたが、十歳や十一歳の身そらで、だいそれた謀叛をたくらんだといふのも一つはたしかに、その霞の誘惑だつたとわたしはいま思ひます。",
              "citation": {
                "source": "金比羅參り",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
