[
  {
    "uuid": "e0c70a73-864a-5fa3-88d1-7bb663c9dd6f",
    "entry": "ウエスト",
    "reading": {
      "primary": "ウエスト",
      "alternatives": [
        "ウェスト",
        "ウェイスト"
      ],
