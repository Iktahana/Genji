        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こは富山県の良港にて、運輸の要地なれば、観音丸は貨物を積まむために立寄りたるなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この裏通りに一軒手頃な貸屋があり、今は鉄道の運輸の方の人が入っているが、少し手入れをすれば店にもなる。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵粮の運輸乏しきに、兵勇もさまでおほからず。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "海陸運輸の便があり、嘗つて、北条氏、足利氏等の九州征略の際にも、博多はその根拠地となった程である。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長のブランド氏は電鈴を押して運輸課長のポッター・フード氏を呼んだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　駅長と運輸課長とは驚きの余り顔を見合せた。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ市は港町の関係上、海陸連絡の運輸労働者――浜人足、仲仕が圧倒的に多かった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜人足――この運輸労働者達は「親方制度」とか「現場制度」とか、色々な小分立や封建的な苛酷な搾取をうけ、頭をはねられ、追いつめられた生活をしているので、何かのキッカケでよくストライキを起した。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働組合の実勢力をなしているのが、港の運輸労働者だ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――運輸労働者が一斉に蹶起したとしても、Ｙ市の「工場労働者」がその闘争の外に立つことは、他の何処の市でもそうであるように分りきっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "運輸労働者のストライキには、そのかゝげる「要求」の中に、必ず工場労働者をも動かし得るような「条項」を入れること。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お店でも、僕の親父は日本運輸の重役だと思つてゐるんだもの。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハツハツハ……運輸会社の重役か！",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は樽野と結婚する前も、学校の帰りにはその父が経営してゐた運輸会社の事務所へ回つて今のに似た小事務を司つてゐた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば今年の秋の初め、野菜が非常に配給困難に陥った、その理由は消費組合内の反革命的分子の策動と、運輸状態が悪かった為めに起ったことである。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云う場合に実際活動をして、消費組合の監督運輸方面を活溌にさせたものは衝撃隊と、軽騎隊と、婦人労働者の中から選ばれた代表者の仕事であった、勿論凡ての団体は男女の労働者勤人から成立っている。",
              "citation": {
                "source": "露西亜の実生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国民経済の計画化」（日満北支一体）は、基礎産業の国営、輸入国営、輸出奨励、為替管理、軍需工業国営、中央銀行及び保険国営、工業商業農業各金融の調整、運輸産業の総合的改革、配給統制（専売制度の拡充）、政治機構の能率的改革、総合的国力発展計画、を含む。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヵ年計画はソヴェトの運輸網を、一九二八年の八万キロメートルから十万五千キロメートルに拡大しようとしている。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、ソヴェト五ヵ年計画は、全同盟内の運輸網一九二八年八万キロメートルであったのを、三三年には十万五千キロメートルにしようとしている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運輸大臣であった苫米地は地方にいる息子から不正な大量物資輸送を受けて辞職し、息子は収監された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　当時福山と江戸との間の運輸通信がいかに難渋であつたかは、此書に由つて知られる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度震災後間もなくのことであつた、まだ交通運輸の状態も平生に復して居らず、時折罹災者と称して金の無心をする者が訪ねて来たり、何となく物情騒然たる雰囲気の漂つてゐた頃、一人の青年が吉田二本松の私の寓居をおとづれた。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒドイのになると、市電の職場が運輸とか、車庫とか、被服工場とか色々に分かれていて、それぞれの問題があることすら知らない奴がいる。",
              "citation": {
                "source": "新しき夫の愛",
                "author": "――　牢獄の夫より妻への愛の手紙　――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿も今年はいつになく豐年だつたけれど、釘が手にはいらないので箱がつくれないし、運輸が思ふやうにゆかないので、柿も二束三文に賣つた話をしてゐた。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧を初めその他の第一必要品の配給を容易にするためには、船腹の不足を補って多数の軍艦を代用するも好く、全国の汽車をそれらの運輸のために臨時に無賃とするも好いでしょう。",
              "citation": {
                "source": "食糧騒動について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東地方大地震ということが、函館へ最初にはっきり伝えられたのは、鉄道局の運輸課を通じてであったらしい。",
              "citation": {
                "source": "帰京記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "全ソヴェト同盟の大建設事業に伴ってこの夏は、運輸が従来にない重大な意義をもっているにかかわらず、各所に貨物の渋滞、延着が訴えられている。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実は、プロレタリアートの建設事業の血管を管理している運輸労働者の大衆的自己批判を求めている。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うんゆこう、いつか、もっとさきになって身に暇が出来たら、――おれは長命するぞ悠二郎」「私がそう申上げた筈です」「それよりもっとだ、勘右衛門よりなが生きをする、――聞えるか、おれは八十まで生きるつもりだぞ、聞いているのか、悠二郎」　桑の葉が揺れ、悠二郎のなにやらもごもご答えるのが聞えた。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
