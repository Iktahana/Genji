        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかもあっさり打っちゃることも出来ない気持であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、苦学もいちどは、やってみるといい」打っちゃるように、ゆるしてくれた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、うっちゃるように答えましたが、泰さんは反ってその返事に人の悪るそうな眼つきを返しながら、「何さ。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　しかし天野北山としては、解らないと云ってうっちゃることは、どうにもこの際出来難かった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほどの宝とあれほどの女を、うっちゃることが出来るものか」「それはまアさようでございましょうが」「俺が内陣へ入りたがっている。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっちゃるごとく日記を閉じて目をそらしたとき、ああ君が恋しいとつくづく思った。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはいつも、曖昧な微笑と冷淡な言葉とで、うっちゃることにしている。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざと寄らせてうっちゃる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うっちゃり」も勝のうちだから、わざと寄らせてうっちゃる名人が現われると、オチオチ寄れなくて、おもしろかろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたらなかったら、ただ銭うっちゃるようなもんだしな。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら君たちは、そんなにやすやすと自分たちの計画をうっちゃるのかね？",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのに、俺あ、その春子さんを、心からうっちゃることが出来ねえ」……そう言って金吾さん――しみじみ溜息をつきましたよ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと言って、うっちゃることがあった。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、はげしくうっちゃるように、身をそむけるように肩を動かした。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、福村をうっちゃることができて、こうして、いい気持で乗込んだのもかなりに図々しいが、今までの身持を、この際すっかり忘れて、平気でそれを引寄せて、うれしがっている神尾も神尾です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は亭主に言った、「これではまるで子供をうっちゃるようなものだね。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれをうっちゃるなあ惜しいな。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカバカしく、がっかりしたが、私はうっちゃることもできず、むずかしい顔をしていた。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
