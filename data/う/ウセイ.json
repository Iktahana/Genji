      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sound of rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「昔思ふ草の庵の夜の雨に涙なそへそ山ほととぎす」これは「盧山雨声草庵中」といふ句のある白楽天の漢詩を日本風に訳したものだと言ふ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然強風が吹起こつて家を揺がし雨戸を震はすかと思ふと、それが急に丸で嘘を云つたやうに止んで唯沛然たる雨声が耳に沁みる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然強風が吹起こって家を揺るがし雨戸を震わすかと思うと、それが急にまるで嘘をいったように止んでただ沛然たる雨声が耳に沁みる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨声が激しくなると、びくりとするが、その神経の脅えは薬力に和められて、かえって、すぐその後は眠気を深めさせる。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの燕王も心に之を悪みて色｜懌ばず、風声雨声、竹折るゝ声、樹裂くる声、物凄じき天地を睥睨して、惨として隻語無く、王の左右もまた粛として言わず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長楽　宮中　雲気散じ、朝元　閣上　雨声収まる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち茲に暫らく閑天地を求めて、心頭に雲を放ち、胸底に清風を蔵し、高眠安臥、興を暮天の鐘にさぐり、思を緑蔭の流光に托し、風鈴に和して吟じ、雨声を友として語り、この夏中百日を暢心静居の界に遊ばんとす。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "強烈な平和の希望者は、それでも、今にも雨が静かになればと思う心から、雨声の高低に注意を払うことを、秒時もゆるがせにしてはいない。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "沸くが如きその心の騒しさには似で、小暗き空に満てる雨声を破りて、三面の盤の鳴る石は断続して甚だ幽なり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草を去ったのは明治十二、三年以後で、それから後は牛島の梵雲庵に梵唄雨声と琵琶と三味線を楽んでいた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶庵侯と漱石４・18（夕）　西園寺陶庵侯の雨声会が久し振に近日開かれるといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだつたかの雨声会に、夏目漱石氏が招待を受けて、素気なく辞退した事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年首相西園寺公望が、文士を招待して雨声会を催した時、漱石はその招待を「時鳥厠なかばに出かねたり」の一句を送って出席しなかった。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねむれない、ねむれない、雨声を聴く、虫声に耳傾ける、そしてとろ／＼とすれば、何といふ夢だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に眼が覚めて、雨声虫声の階調を傾聴した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "明け方、雷鳴そして雨声、春雷でもあるまい、冬雷か、ぬくい、ぬくい、ぬくすぎる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山声水声雨声、しづかにもしづかなるかな、幸にして山崎益道老師在院、お目にかゝることが出来た。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜も夜もすがら水音がたえない、階下は何だか人声がうるさい、雨声はトタン屋根をうつてもわるくない、――人間に対すれば憎愛がおこる、自然に向へばゆう／＼かん／＼おだやかに生きてをれる。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "師弟共に黙して雨声を聴くもの多時、忽ち一人あり。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋をつたふ雨声が滝のやうに激しくなり、ゆき子はふつとまた現実に呼び戻される。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お敏は雷鳴と雨声との中に、眼にも唇にも懸命の色を漲らせて、こう一部始終を語り終りました。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程ふと気がついて見れば、不相変小止みない雨声と一しよに、御前へ詰めてゐた女房たちが局々に帰るらしい、人ざわめきが聞えて来る。",
              "citation": {
                "source": "好色",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮窓外雨声を聞く。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "燭を点じて書を読むに、雨声虫語と相和し風情頗愛すべきものあり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨声に至りては怒るに非ず嘆くに非ず唯語るのみ訴ふるのみ。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "地を叩く雨声、空に転がる雷、耳へ口を寄せても根限り呶鳴らなければ通じない。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次西園寺内閣の当時、駿河台の私邸へ文士を呼び集め、「雨声会」と号して、文学談を交わしたことは、世間周知であるが、その頃、私は新聞記者であって、まだ小説は書いていなかった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀟々、外の雨声ばかりで、寒室の燭は、油も凍るか、いとど火色も細い。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国人が常識的健全なのは紅茶ばかりのんでそうして原始的なるビフステキを食うせいだと論ずる人もあるが、実際プロイセンあたりのぴりぴりした神経は事によるとうまいコーヒーの産物かもしれない。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿蘭陀の通事たちに、シロオテの日本へ渡って来たわけを調べさせたけれど、シロオテの言葉が日本語のようではありながら発音やアクセントの違うせいか、エド、ナンガサキ、キリシタン、などの言葉しか聞きわけることができなかったのである。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
