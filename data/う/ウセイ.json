[
  {
    "uuid": "280595a0-fd7f-5a86-9bfb-8e093f76671d",
    "entry": "雨声",
    "reading": {
      "primary": "うせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
