        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "浦島太郎さんの海が見えるよ。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島さん　浦島太郎といふ人は、丹後の水江とかいふところに實在してゐたやうである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにわが浦島太郎が住んでゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎は、弟妹たちのそんな無遠慮な批評を聞いても、別に怒りもせず、ただ苦笑して、「好奇心を爆發させるのも冐險、また、好奇心を抑制するのも、やつぱり冐險、どちらも危險さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬喩を引けば浦島太郎が竜宮の一年はこの世界の十年に当たるというような空想や、五十年の人生を刹那に縮めて嘗め尽くすというような言葉の意味を、つまり「このエントロピーの時計で測った時の経過と普通の時計と比べて一年と十年また五十年と一瞬とに当たる」と説明すればよいかもしれぬ。",
              "citation": {
                "source": "時の観念とエントロピーならびにプロバビリティ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい皆いやいや引っ張り出されて、浦島太郎になって帰って来た連中やぞ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎なら玉手箱の土産があるけど、復員は脊中の荷物だけが財産やぞ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「けちくさい仕事はせんというのが、掏摸の良心や、浦島太郎みたいに、ぼうっとなっている引揚早々の男を覘うのは、お前けちくさ過ぎるわい。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島さん　浦島太郎といふ人は、丹後の水江とかいふところに実在してゐたやうである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎は、弟妹たちのそんな無遠慮な批評を聞いても、別に怒りもせず、ただ苦笑して、「好奇心を爆発させるのも冒険、また、好奇心を抑制するのも、やつぱり冒険、どちらも危険さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老憊の肉体を抱き、見果てぬ夢を追い、荒涼の磯をさまようもの、白髪の浦島太郎は、やはりこの世にうようよ居る。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "期限付の約束に追立てられることもなく、又、季節の繼ぎ目といふものも無しに、たゞ長閑にダラ／＼と時が流れて行く此の島では、浦島太郎は決して單なるお話ではない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "期限付の約束に追立てられることもなく、また、季節の継ぎ目というものも無しに、ただ長閑にダラダラと時が流れて行くこの島では、浦島太郎は決して単なるお話ではない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、客観的には浦島太郎が、龍宮の乙姫様のところから、帰って来るのではないかと思われるほど、美しく、詩的であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のお伽噺のうちでは『浦島太郎』が一番好きでございました、ただ浦島と云う名を聞いただけでも『あゝ浦島』と申して喜んでいました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると浦島太郎も夢ではない。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "六五　浦島太郎の釣竿寢覺には、浦島太郎の釣竿といふものが有りました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも伯父さんの話して呉れたことですが、浦島太郎の釣をしたといふ岩もありました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、あの浦島太郎が龍宮から歸つて來まして自分の姿をうつして見たといふ池もありました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしむかし、四〇〇と一六年ほど前、漁師の倅の浦島太郎は、住之江の浜から自分の舟を漕ぎ出して、漁に出た。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "風変わりな従者たち――とは海の生き物たちである――が、正装して、両名を迎えに出て、龍神の義理の息子となる浦島太郎に丁寧に挨拶した。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浦島太郎といわっしゃったか？",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また、この記録には、「後淳和天皇の御世、天長二年、浦島太郎、帰る。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私は浦島太郎の夢を見たのです。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な猿蟹合戦、または浦島太郎。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、浦島さん、亀の子へのっかって海へ行ったのよ」　　　浦島太郎は亀にのり　　　波の上やら海の底　みのえは唄っているうちに稚な心に戻った。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎は、毎日つりざおをかついでは海へ出かけて、たいや、かつおなどのおさかなをつって、おとうさんおかあさんをやしなっていました。",
              "citation": {
                "source": "浦島太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
