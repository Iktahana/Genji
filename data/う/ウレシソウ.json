        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "近所のお内儀さんなどが通りがかりに児をあやすと、嬉しそうな色が父親の柔和な顔に漲る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「犬は大丈夫かい」「エエエエ直っきに来ますわ」「どうしてあの崖を駈け登れるだろう」慕門次は笑っている、ひょいと見ると、鼻をフン、フン、やりながら、もういつの間にか、傍へやって来て、嬉しそうに尾を掉っている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はなぜこれが早く判らなかったのだろうという顔つきをして、嬉しそうに箸を取り上げる。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもおあがりなさい」　鉢を差し出してやると、娘は嬉しそうに食べ、水を掬って来て飲ませると、娘はやっと元気を恢復した様子、そこで娘の身元ばなしが始まりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛は沢山の草を見ても、格別嬉しそうにもしませんでした。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先刻までは悲しみと疲れとにやつれ果てていた老母の顔が、さも嬉しそうに、今まで見たことのないほど嬉しそうにかがやいて見えるのであった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日｜麹漬をつけるからって、お母さんがそう云うから、私飛んできました」　民子は非常に嬉しそうに元気一パイで、僕が、「それでは僕が先にきているのを民さんは知らないで来たの」　と云うと民子は、「知らなくてサ」　にこにこしながら茄子を採り始める。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日採りにきてよい事しました」　民子は女だけに、棉の綺麗にえんでるのを見て嬉しそうにそう云った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでか、爺っつあんいやにニコニコして居ると思ったよ」　源兵衛爺さん嬉しそうに、　「なアお静、儂清水へ行って来ようと思うんだが……」　「清水へ行くって、兄さんの処、分ってるの」　「なーに、次郎長親分を訪ねて行きァ分るサ」　「でも、兄さんが帰ってから一緒に行けばいいじゃないの？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と其の男、Ｔ「その又、仲蔵の　男ッ振りのいい事ッたら」　と馬鹿に賞めて居るのを、　窓の中で、嘉助老人嬉しそうに聞いて居た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「エッ」と訳の分らぬ仲蔵、でも嬉しそうに、　「あの出ても構いませんか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々五郎蔵の方ジロリと見ては、嬉しそうに笑って居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が嬉しそうに「父上様Ｔ「よい事　聞いて参りました」　嘉助が「何だ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝も嬉しそうに、Ｔ「其処で　人知れず親子の　対面なされたら……」　「ウンウン」と老人。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝も父の笑顔見て嬉しそう――　と、ツト立って表の間へ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江も、Ｔ「長七さん」　と嬉しそうに抱き付いて泣き伏す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しそうで独り言、Ｔ「どうやら　宮本武蔵って先生に　遭えるらしい」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "村人の一人が、Ｔ「六助さんも確か巳年じゃ」　二人は嬉しそうに語って居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が嬉しそうに、Ｔ「女の仇討は　珍しいぞ」　老臣がイヤイヤ、Ｔ「御免蒙ります」　断わられて、お殿様、悲観した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんは妾を見ると、子供のように嬉しそうな顔をして、すっかり落着いて、妾の用意の出来るのを待っていらっしゃるのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国人達は彼女達の日本｜髷を珍らしがって嬉しそうにはしゃいでいた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘は嬉しそうに、にこにこしながら、手を出した。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　吉永は嬉しそうに云った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「べらぼうめ、そんなことがあるもんか」　女房の制めるのもきかずに、彼はおまきの台所へ忍んで行って、内の様子を窺っていると、やがておまきの嬉しそうな声がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十三日　今日学校から帰って田に行ってみたら母だけ一人｜居て何だか嬉しそうにして田の畦を切っていた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母も嬉しそうだったし祖母もいろいろ向うのことを聞いたことを云った。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、さも嬉しそうに莞爾してその時だけは初々しゅう年紀も七ツ八ツ若やぐばかり、処女の羞を含んで下を向いた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "品物は侘しいが、なかなかのお手料理、餓えてはいるし、冥加至極なお給仕、盆を膝に構えてその上に肱をついて、頬を支えながら、嬉しそうに見ていたわ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　与平という親仁は、涅槃に入ったような形で、胴の間に寝ながら、仏造った額を上げて、汗だらけだけれども目の涼しい、息子が地蔵眉の、愛くるしい、若い顔を見て、嬉しそうに頷いて、「晩にゃ又柳屋の豆腐にしてくんねえよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん得物の増して行くのをのぞき込んで、頬を赤くしてうれしそうな溶けそうな顔をする。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
