          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "客の私が、却って浮寝鳥に枯柳の腰模様の着物の小皺もない娘の膝の上にハンケチを宛てがい、それから、鮨を小皿に取分けて、笹の葉を剥いてやらねばならなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮寝鳥　冷え冷えとしたなかに横はつて、まだはつきりと目のさめきらないこのかなしさ。",
              "citation": {
                "source": "ある時刻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "爛々と暁の明星｜浮寝鳥一月十日　夜。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽搏きて覚めもやらざる浮寝鳥十二月十日　二百二十日会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高嶋米峰氏主宰の学生文壇二号に、初めて、小説を投稿したその「浮寝鳥」当選。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "題はいま考えると、ひどく古風なもので、“浮寝鳥”というのであった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
