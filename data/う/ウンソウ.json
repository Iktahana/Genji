        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私の女を私から奪略した男の所へ、女が行くといふ日、実は私もその日家を変へたのだが、自分の荷物だけ運送屋に渡してしまふと、女の荷物の片附けを手助けしてやり、おまけに車に載せがたいワレ物の女一人で持ちきれない分を、私の敵の男が借りて待つてゐる家まで届けてやつたりした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃またアメリカでは飛行機で大西洋を飛び越し、運送船の力を借らず航空隊を戦場に輸送しようという計画がだいぶ真面目に研究されており、それについては大西洋の気象という事が重要な問題になるのである。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二突堤より運送船××丸にて出帆す。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、愛国心に満ちた士官の持つ、それと同じ心臓で、運送船で敵地に送られた陸兵の上陸や、大連湾の攻撃や、威海衛の偵察、旅順攻撃、戦争中の軍艦に於ける生活、威海衛の大攻撃等を見、聞き、感じて、それを報告している。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その牛は荷車を牽く運送屋の牛であった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を配達先へ届けると同時に産気づいて、運送屋や家の人が気を揉むうちに、安やすと仔牛は産まれた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも茣蓙で包んで上箱に入れて、貴重品扱いにして門司の山九運送店宛に出して下さいな。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お届けをしようか、受取りにおいで下さるか、という両国辺の運送問屋から来たのでした。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　銀子の帰りが遅いので、分寿々廼家のお神と内箱のお婆さんとで、看板をもった車夫を一人つれて、河縁を捜しにやって来た時、銀子は桟橋にもやってある運送船の舳にある、機関の傍にじっとしゃがんでいた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保時分、酒樽は別に船積みするという理由の下に、新運送業が起った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運送店に捜すよう詰責したが、絶えて返事が無かった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の近所の或運送屋（？",
              "citation": {
                "source": "悲しき思出",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも五年級から代表に狩り出されて、売場の番に立ちましたが、そのとき、葛岡は花の運送の世話に来て、わたくしの立っているのを見ますと、その前後は全くわたくしを避けていたのに係らず、ずか／＼とわたくしのところへ来て、「こんなところへ立って見世物になるんじゃない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左隣の船は運送会社のマークの付いた高提灯を立て、紅白の幕で飾った会社の社員や関係者の家族の乗込んだ伝馬船で、シャツの上衣の良人が舷からガーゼの簡単着を着たこどもにおしっこをさせていますと、その妻は「酔ってるから、あなた、坊や落っことしちゃいけませんよ」と後から危がっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女も、お忙しいでっしゃろさかい……」　言うているうちに、君枝はふと、自分も看病の合間に運送屋の手伝いをして見ようかと思った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童路地の近くに、便利屋というちっぽけな運送配達屋がある。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや、開けた山裾、家があちこち、みんな日の丸の旗を掲げた、つい前もお祭り気分の運送屋、毛糸がありますと、貼り紙した店の横の雨戸袋。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに運送兼業の雑貨店や、やや小綺麗な店屋が飛び飛びに二、三軒はあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国通いの船を持っていて、それに新七という男を乗せて、運送の業を営んでいる。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸壁を築きたくも、砂が無いので、近衛の工兵が、山麓から、土砂を採って袋に入れ弾雨の中を背負って運送し、自壁を急造した。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵糧を日本より運送するようにては如何で明に入ることを得ん」と。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐縮して帰って行くその女運転手の後姿を見ながら、君枝はふと、自分も看病の合間に運送屋の手伝いをしてみようかと思った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童路地の近くに便利屋というちっぽけな運送配達屋がある。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一はその夜のうちに荷物を纒めて朝運送屋へ頼み、午頃「ヴィクター」で赤井と、野崎の二人と落合った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはクリミヤ戦争が最高頂に達した年のことで、古くから使っていた罪人船は、黒海で運送船として使用されていたのであった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "運送船グロリア・スコット号は航海中、失われたと海軍省より発表され、その本当の運命については、何事も世の中には知れなかった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはクリミア戦争まっただなかの五五年のことで、古くからの囚人船はほとんどが黒海で運送目的に使用されていた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の機会には、白髪の老紳士が同居人に会いたいと言って来たし、また別珍の制服に身を包んだ駅詰めの運送屋がやってくることもあった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「当年十八歳に　相成りまする」　うんそうかと上機嫌の殿様が「どうじゃ爺、Ｔ「其方、誰かに　殺されて呉れぬか？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
