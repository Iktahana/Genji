    "definitions": [
      {
        "index": 1,
        "gloss": "shooter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある日温麦の打ち手というを聞き誤って、伯父の心替りと思い取って、忍んで入道を害し、寺を去り、この池に血刀を注ぐ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一つ探さなければなるまい、この打ち手は何うしても見物人には見せられない。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ珍しい打ち手でいらっしゃいます」　と少将はおもしろがって言うのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉氏良しという局面であったが、この時、秀哉名人が、一門の者を集めて、打ち掛けの次の打ち手を研究し、結局、前田六段が妙手を発見し、このお蔭で、黒の良かった碁がひっくりかえって、負けとなった。",
              "citation": {
                "source": "呉清源",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この半分の速力で弾丸を打ち出すことの出来る人でも、引金を握っては一ぱし確かな腕を持った打ち手に相違ない。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よい上の句が出ないと見える」「よい打ち手がめつからぬと見える」　二人は哄然と笑い合った。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし打ち手は異うらしい。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打とうと思えば小父様など、たった一打ち手間暇はいらぬ。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武州川越在の千頭津右衛門といえば、碁打の間には全国的に名の知れた打ち手。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚八ほどの打ち手が見落すのはフシギであるが彼は血迷っていたのであろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は素人日本一とうたわれた碁の打ち手、母とても結婚後習い覚えた碁が東太が三ツになる時には素人天狗を打ちまかすほどに上達した利巧者、二人の仲に低能が生れる筈はないから、よほどオクテの大器晩成塑。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレがあの局面の説明をしない限りは誰にも分りやしないのだ」　まさかに千代が相当の打ち手で、この秘密を見破っているとは知らないから、甚八の胸にはムクムクと宝探しの黒雲がむれたった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく千代は相当の碁の打ち手と新十郎が睨んだ通り、津右衛門が暗示したのは石の下だと知っていたのだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟練した打ち手の間にあっては、一勝負に数日を要し、一つの手に一時間かかることもある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち手の一人が先ず盤上の好きな点にこの円盤を置いて勝負を始めるが、目的は敵の円盤を、円盤の連続線で包囲して了うにある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な打ち手には階級がある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一階級の打ち手は第二級の打ち手に対して、最初一個の代りに二個の円盤を置く権利を与える。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく第三級の打ち手は、三個置く権利を持つのであろう。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お嬢さま、あなたはすぐれた鼓の打ち手だと存じます、お城の鼓くらべなどにお上りなさらずとも、そのお手並は立派なものでございます。",
              "citation": {
                "source": "鼓くらべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずいといったら、これ程まずい打ち手はなかったのだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者造園学のテキストに、　　　おのれが像を百あまり、著者の原図と銘うちて、　　かゝげしことも夢なれやと、青き夕陽の寒天や、　　　　Ｕ字の梨のかなたより、革の手袋はづしつゝ、　　　しづにおくびし歩みくる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その標うちてテープをさめ来！",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はツとばかり胸をうちて瞻るひまに衰へゆく。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌水うちて残んの日かげ濡れたるにもの言ひてます母のしたしさおなじく街中は瓦重なる夕かげをまだじじとある蝉が庭木に瀬戸内海しづかや船ゆきゆく。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ、ここの丘窪、明るけど古さび棚田、うれしけど冬の日棚田、その空に翔る群禽、鶺鴒の薄黄の羽根のただ波うちて影もとまらず、影もとまらず。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ、ここの丘窪、明るけど古さび棚田、うれしけど冬の日棚田、その空に翔る群禽、鶺鴒の薄黄の尾羽のただ波うちて影もとまらず、影もとまらず。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は疲れたる腦髓に鞭うちて、強ひて思議せしめんとしたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "野津由氏の乞ふまゝに、裸男先づ書きなぐりて曰く、紅葉鱒温泉高さ五千尺四　闇の金精峠風景の美に打たれ、孵化の話に興を催し、珍らしき馳走に舌皷うちて、この湖畔に凡そ二時間ばかり費して、今や午後二時半となりぬ。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐して東京灣と關八州の山野とを眼下に見下す絶景も、北吹く風のさむきに、戸の外に閑却して、浴を取るより早く杯を傾け、陶然たる醉心地快く、峯の杉に吹く風の音を、忘れては浪の音と聞くも、ひと夜濱邊にやどりて、ひねもす波騷ぐ岸を辿りし名殘にやと、烏山のうちいづるに、げにわれもと、相槌うちて笑ひし。",
              "citation": {
                "source": "房州紀行",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶なるかなや、　　　　君は誰、笛なげうちて　　　　物狂。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
