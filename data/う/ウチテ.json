[
  {
    "uuid": "db89c6fe-91fb-50e4-88de-ac360fc040f2",
    "entry": "打ち手",
    "reading": {
      "primary": "うちて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
