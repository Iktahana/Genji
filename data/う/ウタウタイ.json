        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かつて酒量少なく言葉少なかりし十蔵は海と空との世界に呼吸する一年余りにてよく飲みよく語り高く笑い拳もて卓をたたき鼻歌うたいつつ足尖もて拍子取る漢子と変わりぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十蔵はその片目を細くして小歌うたいつ、たちまち卓を打ちて、君よかの問いの答えはいかにしたまいしとその片目をみはりぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな歌うたいだろう」　という好奇心で、その映画館へはいることは、むろん小郷にとっては辛いことだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、おとなりの庭の、ボダイジュにとまっている、歌うたいの小鳥さんたちには、それがあるわ。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポルトガルなら、こんなことはないと思うわ」　そして、その歌うたいの小鳥を、かわいそうに思いました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、男性であることを、ひとに聞いてもらうのには、もっと機関車のような力を、持たなくちゃだめだね」　二羽の中国のニワトリは、歌うたいの小鳥をひとめ見ると、すっかり夢中になってしまいました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、歌うたいの小鳥さん。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんが食べおわって、また横になったとき、歌うたいの小鳥がそばへやってきました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、わたしは、ひと眠りしよう」　歌うたいの小鳥は、すっかりびっくりしてしまいました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなかわいい歌うたいの鳥は、もう二度と、わたしたちの仲間になることはないわ。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずしい漁師のやどへも、お百姓のやねへも、陛下から、またこのお宮から、とおくはなれてすまっておりますひとたちの所へも、この小さな歌うたいどりは、とんで行くのでございます。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、台所きっての歌うたいで、お茶わかしとは、腹がわりの兄さんでした。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、なあによあの西洋人」「――今度、シネマへ出る歌うたいだってさ。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌うたいは、算盤のみちに明るかったから、利子のことがなかなか細かく手堅かった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌うたいは、笑窪のよったあどけない顔で、いろいろな指示をした。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この写真は余興に出る歌うたいだ、流行歌をピアノに合して歌う。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと大使の奥様は私を余興の歌うたい扱いをしているんですから、欧米の社交界の慣例によって、プリマドンナをお客様に紹介する、エチケットも知ってか知らずか、お構いなしで、大統領はもちろんのこと、お客様に紹介しないで、私に歌をうたって頂戴とおっしゃるのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる「歌うたい」や「詩造り」が多い。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声をきいてから、他の歌うたいの声をきくと、あまり筒抜け過ぎて、その歌が煙突から出るもののようにしか響かなかった。",
              "citation": {
                "source": "触覚の世界",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子の面を被って踊るので、ササラ方があり、歌うたいがあり、棒方二人、五尺ばかりの物を持つ。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な歌うたいや、役者や、踊り子もやってくるにちがいありません。",
              "citation": {
                "source": "花咲く島の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭園の主人は、いままで寂しくてしかたのなかったのが、世界の有名な歌うたいがきたり、美しい踊り子がきて踊ったり、また役者などがくるということを想像しますと、そうなったら、どんなに幸福だろうと考えたのでした。",
              "citation": {
                "source": "花咲く島の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七の見慣れぬ旅人　（蝋燭にて倒れたる旅人の顔を照して）この歌うたいは、何処かで見たように覚えている。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "）や、（驚いて）この歌うたいは冷いぞ。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七の見慣れぬ旅人　この歌うたいは、Ｘの町を幾年前かに通ったことがある歌うたいに似ている。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもこの歌うたいのうたって歩いた歌を覚えている。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちこの歌うたいの姿が見えなくなった。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五の見慣れぬ旅人　その歌うたいに相違ないか。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七の見慣れぬ旅人　保証は出来ぬが、その歌うたいによく似ている。",
              "citation": {
                "source": "日没の幻影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたうたいは竹内浩三うたうたいは　うたうたえと　きみ言えど　口おもく　うたうたえず。",
              "citation": {
                "source": "うたうたいは",
                "author": "竹内浩三",
                "note": "青空文庫"
              }
            }
          ]
        }
