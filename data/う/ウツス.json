[
  {
    "uuid": "683c9d85-424f-5d40-af9c-d4811264d493",
    "entry": "移す",
    "reading": {
      "primary": "うつす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to transfer (to a different place, group, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "仮りにその要求の満足される場所が生活の方に転移するとしても、転移したら転移したとしての詩心の表現物、即ち詩は要求されるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「達沢君もー」と云つて候補者は、その時傍に来た達沢から校長にと視線を移すと、カラカラ笑つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにどんな訳者が、それを日本語に移すことが出来るだらうか。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃では神棚の燈明を点すのにマッチは汚れがあるというのでわざわざ燧で火を切り出し、先ずホクチに点火しておいてさらに附け木を燃やしその焔を燈心に移すのであった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩しくなって眼を庭の草へ移すと大きな黄色の斑点がいくつも見える。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が打っ突ると、直ぐに次へ眼を移す。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年も、殆んど毎日のように、導火線に火を移す彼等であっても、その合図を待つ時には緊張しない訳には行かなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "導火線に火を移す時は、たといどんな病気でも、一時遠慮するものだ、と。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色、すなわち灰色は白から黒に推移する無色感覚の段階である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "顕著に高い音をもって突如として始まって、下向的進行によって次第に低い音に推移するような楽節が、幾つか繰返された場合は多く「いき」である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今かりにここに移す。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんは妾の魂を粘土の塊の中に、移すことに成功なすったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、私はタージ・マハール・ホテルに止宿する商用の旅を彼地につづけていたのであったが、Ｍ物産の主任Ｓ氏の紹介で宿を赤丸平家の倶楽部に移すと同時に彼地の日本人に紹介されるのであった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が二人の間には、膝から下を切断し、おまけに腹膜炎で海豚のように腹がふくれている患者が担架で運んで来られ、看護卒がそれを橇へ移すのに声を喧嘩腰にしていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "担架に移す時、バラバラ落ちそうになった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分がその隠れた欲望を実行に移すかどうかという段になると吉田は一も二もなく否定せざるを得ないのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当下に即ち了するという境界に至って、一石を下す裏に一局の興はあり、一歩を移すところに一日の喜は溢れていると思うようになれば、勝って本より楽しく、負けてまた楽しく、禽を獲て本より楽しく、獲ずしてまた楽しいのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで物質界に関する普遍的な知識を成立させるには第一に吾人の直接の感覚すなわち主観的の標準をいったん放棄して自分以外の物質界自身に標準を移す必要がある。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再び汀の血紅色の草に眼を移すと、その葉が風もないのに動いている。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャーナリズムのあらゆる長所と便益とを保存してしかもその短所と弊害を除去する方法として考えられる一つの可能性は、少なくも主要な新聞を私人経営になる営利的団体の手から離して、国民全体を代表する公共機関の手に移すということである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、とにかくこうした映画で日常教育されている日本現代の青年男女の趣味｜好尚は次第に変遷して行って結局われわれの想像できないような方向に推移するに相違ない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「僧やや寒く寺に帰るか」「猿引きの猿と世を経る秋の月」では僧の姿が猿引きの猿にオーバーラップ的に推移するのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラの焦点が近い花から遠くの木へ移動すればスクリーンの観客はちょうど遠くへ目を移す感じがするはずである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の伯爵のガス排出の音からふざけ半分のホルンの一声が呼び出され、このラッパが鹿狩りのラッパに転換して爽快な狩り場のシーンに推移するのである。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は母や弟妹に私の心持ちを打ち明けた上、その了解を得て、この土地全部を無償で諸君の所有に移すことになったのです。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園は自分の前にしとやかに坐っているおぬいさんに視線を移すのにまごついた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸袋のすぐ横に、便所の窓の磨硝子から朧な光のさすのに眼をうつすと、痩せたやもりが一疋、雨に迷う蚊を吸うとてか、窓の片側に黒いくの字を画いていた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　朝霧が山村を罩めて、鶏の声が、霧の底から聞える、黄色い南瓜の花に、まだ夢が残つてゐるかして、寝惚けた姿をしだらなく大地に投げ出してゐる、ぼツと白壁が明るくなる、森がうつすらと、烟つぽい緑を、向うの山の懐に、だんだら、染めに浮かせる、起き上つて支度をする頃は、方々の家から、軽い炊煙が立ちはじめた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山腹に眼をうつすと、あの雪の中で藍になって雪が消えたように見える所がある。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま女神は湛えた水の一つに姿をうつす。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
