        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あゝ我がはらから誰と遊ぶ」　ふと薄寒い感じが体の中をすつと抜けて通るやうに思ふと、お末は腹の隅にちくりと針を刺すやうな痛みを覚えた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ碌々遊びもしないと思ふ頃、ふと薄寒いのに気がついて空を見ると、何時の間にか灰色の雲の一面にかゝつた夕暮の暮色になつて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明いて居た窓から、薄寒い風が、すっっと這入って来て、五分心の裸ランプが、ぼぼぼーと油煙を吐き始めた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "凉しい風が薄寒い秋風に変って、ここの柳の葉もそろそろ散り始める頃、むざんの斧や鋸がこの古木に祟って、浄瑠璃に聞き慣れている「三十三間堂棟由来」の悲劇をここに演出した。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "-------------------------------------------------------　雨を含んだ風がさっと吹いて、磯の香が満ちている――今日は二時頃から、ずッぷりと、一降り降ったあとだから、この雲の累った空合では、季節で蒸暑かりそうな処を、身に沁みるほどに薄寒い。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "波を蹴立てて、風の薄寒い港内を一まわりすると、ランチが岸へ着いた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲を掴むような問題で、薄寒い晩に東京駅のプラットフォーム迄引き出されることは、可なり苦痛でありましたが、職業柄是非もない事ですから、「それなら行く事は、行って見ましょう。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はさびしくそれを瞰あげていると、もう西へ廻りかかった日の光は次第に弱くなって、夕暮を誘い出すような薄寒い風にふるえる花びらが音もなしに落ちた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸じゅうの混雑を一つに集めたかと思われるような両国にも、暮れゆく秋の色と匂いとが漲っているように見えるのが、このごろの薄寒い朝の景色であった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂部もほほえみながら聴いていると、春もまだ薄寒い夕暮れの風が天から吹きおろして来て、高い天主閣の甍をゆすって通った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十日もたちゃ霜が降りようってえいうこの薄寒い秋口に、毎晩毎晩何を着て寝ていたんでしょうね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が薄寒い秋風に変って、ここの柳の葉もそろそろ散り始める頃、むざんの斧や鋸がこの古木に祟って、浄瑠璃に聞き慣れている「丗三間堂棟由来」の悲劇をここに演出した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は昼から薄寒い雨がふりつづいて、渡しを越える人も少なかったが、暮れてはまったく人通りも絶えた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には薄寒い風が、ヒューヒューと電線を鳴らして、夜漁の船の発動機がタンタンタンタンと聞えていた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲の秋は早いので、もう薄寒い風の吹き出した夕暮に、内地から郵便物が到着したという通知があったので、わたしたちは急いで師団司令部へうけ取りにゆくと、岡本宛の分として五、六通の郵書とひと束の新聞紙とを渡された。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れてゐる、薄寒い風も吹いてゐた。",
              "citation": {
                "source": "札幌時代の石川啄木",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄寒いような風が、障子を開けた縁から吹いて来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "田圃に薄寒い風が吹いて、野末のここ彼処に、千住あたりの工場の煙が重く棚引いていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝は薄寒いようで、賑やかでも引緊った空気は、昇る太陽につれて膨み機嫌よくなって来る。",
              "citation": {
                "source": "思い出すかずかず",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最う秋の末で薄寒い頃に袷に襦袢で震へて居るのに、どうしたかいくら口をかけてもお前は来てくれず、夜はしみじみと更ける、寒さは増す。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか薄寒い日である。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、猪之介はこの薄寒い初秋に額の汗を拭き／＼した。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは薄氷を踏むような薄寒い思いに似た、鋭く不安定なうつろな圧迫だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　鏡子は我子の言葉から、春の末の薄寒い日の夕暮に日本の北の港を露西亜船に乗つて離れた影の寂しい女を幻に見て居た。",
              "citation": {
                "source": "帰つてから",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄寒いような竹やぶの陰だったがね。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は土用中ながら薄寒い日であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな薄寒いような日、突然圭介の母が見舞に来た。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ梅雨の時期にはならないが、昨日も今日も、いつ晴れるとも知らず降りつゞく雨は、已に袷からセルの單衣を着た氣早い人の肩に羽織を着せかけ、久しく冷えたまゝの火鉢の灰に再び炭火をつがせるやうな、薄寒い濕つた氣候を呼び返す。",
              "citation": {
                "source": "歡樂",
                "author": "永井壯吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
