    "definitions": [
      {
        "index": 1,
        "gloss": "to be wet (with tears)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "三十九年九月　　軟風ゆるびぬ、潤む罌粟の火はわかき瞳の濡色に。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子の閉つた青い街を、濡れに濡れた舗石のうへを、ピアノが鳴る……金色の顫音の潤むだ夜の空気に緑を帯びて消えてゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルウヴルの美術館でリユブラン夫人の描いた自画像の前に立つても其抱いて居る娘が、自分の六歳になる娘の七瀬に似て居るので思はず目が潤む。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、久しく忘れていたものに、眼がしらが潤むのを、唇を喰縛ってこらえた。",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルウヴルの美術館でリユブラン夫人の描いた自畫像の前に立つても其抱いて居る娘が、自分の六歳になる娘の七瀬に似て居るので思はず目が潤む。",
              "citation": {
                "source": "巴里にて",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」読み行くうちに二人の表情、驚異となり、歓喜となり、怪訝となり、また感激に潤む眼となった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "霙で、電燈の灯もうるむかと思われるような暗鬱な冬の夕暮であった。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の状涙にうるむが如し。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりそめの、人のなさけの身にしみて、まなこ、うるむも、老いのはじめや。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものなべてさは妙に女の眼ざしあはれそが夢ふかき空色しつつ、にほやかになやましの思はうるむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "色わかき夜の星、うるむ紅。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年八月　　立秋憂愁のこれや野の国、柑子だつ灰色のすゑ夕汽車の遠音もしづみ、信号柱のちさき燈淡々とみどりにうるむ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※の外は物古りし街、風湿める香のぬくみに、寺寺の梵音うるむ夕間暮、卯月つごもり、行人の古めく傘に、薄灯照り、大路赤らみ、柑子だつ雲の濡いろ、そのひまに星や瞬く。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたまに、灯さす格子はあれど柩うつ槌の音ただにせはしく、煉瓦つむ空地には、あはれ誰が子ぞ、心中の数へぶし拙なげながら音もうるむ連弾のかなしきしらべ、いつになく旅人の足をとどめて、灯は青く柳立つ闇にともりき。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』――愛の羽寄り添ひ、青瞳うるむ見れば、築地の草床、涙を我も垂れつ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、前川は深くうなずくと、たちまち自分の目頭がうるむのを覚え、新子が限りなく、いじらしくなり、ギュッと抱きしめて、顔中に唇の雨を降らせたい激しい衝動を感じるのを、息を呑み込んで、ズンズン歩きつづけることで、やっと押えた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の一周忌も、もう明後日ですわ」（眼がうるむ）十吉、眼をぎょろ／＼させている。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　見ると善蔵氏の眼鏡の下の、見張つた眼は余の気の為だつたかも知らないが、その力の強さに似ず、微かにうるむで見えた。",
              "citation": {
                "source": "余の倅に就いて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三片の花弁は水底から拾ひ上げたばかりの貝のやうに、月光に映えて水々しくうるむで居ります。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと日は、うるむ月の夜に、水漬く磯根の葦の葉を、卯波たゆたにくちづけし深日の浦をおもひいでぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ泪にうるむ眼をとじて思考すること五分間……又となき若き日の思い出は……ああ、頼もしくもあり寂しくもある日は……時の運行！",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ひと日は、うるむ月の夜に、水漬く磯根の葦の葉を、卯波たゆたにくちづけし深日の浦をおもひいでぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三忘れがたみの『追懷』は、密ごころのふところに、小野の月映うるむ夜を、空のあなたにあくがれぬ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄曇りの空には微熱にうるむ瞳がぼんやりと感じられた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰捨てて白梅うるむ垣根かな　加ふるに凡兆の予等の為に夙に津頭を教ふるものあり。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がうるむ様な気がする。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを眺めた京之介、もう一ぱいに目がうるむ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨頭草の花、空色の花の瞳のうるむのは、暗い心を見｜透して、わたしのために歎くのか。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は寒い下弦の月の暁近く濃霧にうるむ頃まで語り明かし、次の朝、冬子は春風楼へ「芸妓になる可く」行ってしまった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年五月二十六日にも私はラヂオを通じて野球リーグ戰の早立二囘戰の状況を聞いてゐたが、戰ひ終つて統制ある「都の西北」の合唱されたのを聞いた時、私の眼がおのづからうるむを覺えた。",
              "citation": {
                "source": "校歌「都の西北」と私",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
