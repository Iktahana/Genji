          ],
          "literary": [
            {
              "text": "その反動で、ウインドシールドの横幅いっぱいに、海水が跳ねた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "水位が上昇していく様子を、ウインドシールド越しに僕たちは観察することが出来た。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインドシールドの高さのなかばを海水が越えると、ガラスを降ろしてある両側の窓から、車内に海水が入って来るようになった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウインドシールド越しに見る外の光景は、ガラスの水槽のなかをのぞき込んでいるのと似ていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
