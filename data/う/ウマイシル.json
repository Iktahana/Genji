          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんまり一人でうまい汁ばかり吸っていると、今に腹が痛みだすんだから。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　昔、ラスキンが人から剽窃呼ばわりをされたのに答えて、独創ということも、結局はありったけの古いものからうまい汁を吸って自分の栄養にしてからの仕事だというような意味のことを言った。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この婆がまた悪い奴で、表向きは駄菓子屋をしていながら、この娘三人を引き摺り込んで、盗んで来た品物をほかへ捌いてやって、中途でうまい汁を吸っていることが露顕したので、これも一緒に召し捕られました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも心得てゐて、祭といふやうなものからうまい汁を吸つてゐる、ケチなずるさではないかと思つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい汁を吸つてゐるといふことはあるにしろ、ともかく彼は牛の神さんを信じてゐる。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の勞働でうまい汁を吸つてゐるものや、勞働を手なぐさみにしてゐる、勞働の嚴しさを身を以て知らぬものに限つてその言葉を使つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を利用しうまい汁を吸つてやらうといふのでも、愼重に計畫し、徐々に引綱を思ふ壺へ手繰り寄せるといふのではなくて、溺れるものが藁をつかむやうに、一寸でも自分の足しになると思ふものには、情なく縋りついて來るのだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕等はその間にあつて、多少のうまい汁が吸へるの、さ――丸で火事場泥棒も同樣、さ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "損をしさへしなければいゝ」といふ責任のがれ、一つは、「出来るだけ苦労をしないで、うまい汁を吸はう」といふ射倖心理であります。",
              "citation": {
                "source": "日本文化の特質",
                "author": "――力としての文化　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "行きがかりでこうなったが、村の若い衆にうまい汁を吸わせてみても、自分は別に面白くもない。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまい汁を吸う役は後に控えている。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、薬屋がうまい汁を吸つてゐるわけに違ひない。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで秘密を握っている二人が、自分一人でうまい汁を吸いたいのは人情であるから、二人で殺し合いをしたようにも考えられるが、浅虫家の立場から考えてみると、二人一しょに殺してしまえば永久に秘密の洩れることがなくなるのだから、二人を殺してしまいたいのは更に必死な願望であるに相違ない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の祖先は代々相当の頭脳と処世術にたけていたらしく、今日で云えば長と名のつく重役についたことはないが、局次長とか部長という追放の境界線のあたりで、人目にたたずにうまい汁を吸うのが家伝の法則の如くであったという利口な一家。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十　冷笑鬼",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生と柳生対馬守とのあいだにできたこの婚約を、じゃまして、これだけの財産と道場を若い後妻お蓮様の手に入れ、うまい汁を吸おうという陰謀なのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のことをひとり胸に畳んで、手前の親分いろは屋文次にさえぶちまけないのを変だと見ていたら、それも道理、お役徳という小者根性から、虎の威を嵩にきてだいぶちょくちょくうまい汁を吸っているものとみえ、御免安のやつ、何かとんでもないことをもくろんでいるらしい――。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――近頃あの野郎にも人氣が出たから、師匠の東海坊が死ねば、そつくり跡を繼いでうまい汁が吸へると思つたんでせう」「そいつは三河島の兄哥の見當違ひだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを横取りした上、お若が金持の跡取で乘込めば、皆んなうまい汁が吸へる」「――」「それまで企らんだところへ、竹中十兵衞が現はれた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "苫三七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――近頃あの野郎にも人気が出たから、師匠の東海坊が死ねば、そっくり跡を継いでうまい汁が吸えると思ったんでしょう」「そいつは三河島の兄哥の見当違いだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそんな事をするかと言いますに、聡明な法王がその位に即きますと近臣の者がうまい汁が吸えない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国から金を沢山貰って自分一人がうまい汁を吸えばよいという考えですから、国民に難儀をかける位の事は一向平気です。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなこの際大いに英国から金を取って、うまい汁を吸いたいという狡い考えを起して居る悪い人間もあるらしい、ではないきっとあるに違いないです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは二つとも混って居るかも知れん、鉄道や病院を拵えて、人を利益するというは全く仏教の趣意に適った遣り方であるに拘わらず、人の国を取ってうまい汁を吸う事ばかり考えて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそういうふうにして戦争が成り立ちますれば、その戦争に幾多の兵士の生命を賭けて戦うたネパール人は僅かにうまい汁を吸うに止まって、多くの利益は英国人に帰することになるのでございましょう。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "（津村はだまっている）三芳　（それを引き取って）しかしそいつは世の中がこんなふうになったので、急にそんなふうに言っているだけで、ほんのこの間まで、あんたがたは、やっこさんたちのために、そして、やっこさんたちのおかげで、さんざん働きもし、うまい汁も吸ってきたんだからなあ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその間に何かうまい汁がありとすれば、その余瀝を啜って、皿まで噛ろうという先生だから、お松に尋ねられたことも、素直には言ってしまわないことはわかっています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもそれではうまい酒が飲めないから博奕をする、博奕をするのは性質のよい方で、性質の悪いのになると人の秘密をさぐり、それを種にうまい汁を吸おうとする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで向うが折入って御無心に来る、こっちが高くとまって、それでいやならおよしなさいという腹でいると、背に腹は換えられないから向うが往生してしまうんでさあ、向うに働かしてこっちは懐手をしていて、うまい汁はみんな吸い上げてしまう、こんな面白い商売はまたとあるもんじゃない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（矢崎新兵衛の「枕をならべて、出馬」を笑えんじゃないか）　そう思いながら、今度はゆっくりと、「人の、牛蒡で、法事をする――自分は手をよごさず、うまい汁を吸うのは、民政党の十八番であります」「お前の十八番は、法事で牛蒡をすることじゃろ」　誰かが弥次って、また、ひとしきり、場内がどよめいた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海へ行って、うまい汁を吸ってやるんだと意気｜軒昂たる男だっただけに、誰よりもひどく惨めに残酷に、船酔いに苦しめられているのは、いかにも皮肉で、俺は同情とちがうものをそこに感じていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
