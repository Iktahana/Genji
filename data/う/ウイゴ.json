        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "西の浮川横綱が、高千穂バローズ（現ユニシス）の研究所でソフトウエアに携わっていた初子夫人と二人三脚で会社を起こして以来、日本語ワープロで成功物語を書き上げた経緯はいずれ追う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の浮川夫人にして一太郎開発の中心となった、初子さんである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューター・メーカーの高千穂バロースの研究所を、浮川との結婚を機会に辞していた初子のプログラマーとしての力は、大きな戦力だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてのオフィスは、徳島の初子の実家の応接間。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯十三節に「その膚の肢は蝕壊らる、すなわち死の初子これが肢を蝕壊るなり」とあるを見れば、この悪人必滅の主張が明かにヨブを指したものであること確実である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死の初子」とは死の生みし者の中最も力あるものの意にて、癩病を指したものであろう。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は我とも覚えず浅ましがりて、産後を三月ばかり重く病みけるが、その癒ゆる日を竣たで、初子はいと弱くて肺炎の為に歿りにけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通り蚕室は初子の日初めて掃除したので、子の日を用ゆるは専ら鼠害を厭する意と見える。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "小平初子氏は一部原稿の寫しと口述速記とに力を藉して下さつた。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る名士の若夫人が入院して初子を生んだ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台で出版された案内記や絵葉書によると、院本で名高い局政岡とは三沢初子のことだそうで、その墓は榴ヶ岡下の孝勝寺にある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初子は四十八歳で死んだ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその裏面の消息を詳しく知らないが、とにかく反対派が種々の陰謀をめぐらした間に、初子は伊達｜安芸らと心をあわせて、陰に陽に我が子の亀千代を保護した。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは云う、政岡は浅岡で、初子とは別人であると。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは云う、当面の女主人公は初子で、老女浅岡が陰に助力したのであると。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな疑問は大槻博士にでも訊いたら、忽ちに解決することであろうが、私は仙台人一般の説に従って、初子をいわゆる政岡として評したい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく嘘でも本当でも構わない、わたしは「伽羅先代萩」でおなじみの局政岡をこの初子という女に決めてしまった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく、政岡というのは芝居の仮名で、本名は三沢初子である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "初子の墓は仙台にもあるが、ここが本当の墳墓であるという。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡山町の白石初子といふ人は後にお貞さんが出京して專心文學の修業にかかつた時の後援者の一人であつたが、そして私も面識があるが、此お初ちやんがさうした女塾へ新弟子として入つてくる所から此小説ははじまつてゐる。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女塾の友達に別れ心を張りつめて上京した彌生は、しばらくして後、白石初子に短い手紙を送つてゐる。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の亡くされたのは君の初子であった、初子は親の愛を専らにするが世の常である。",
              "citation": {
                "source": "我が子の死",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いうまでもなく、政岡というのは芝居の仮名で、本人は三沢初子である。",
              "citation": {
                "source": "目黒の寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁金がリアリズムの見地でリアルであるかないかは、彼にとって問題でなく、作者が自分の主張の代人である久内を自由人として鋳出すに必要なワキ役のタイプとしていかす必要にだけ腹をすえて、雁金も山下も、妻、初子すべてを扱っている。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の初子が十日以内に生まれるはずです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その側にかしづいてゐた主な女は、亀千代を生んだ三沢初子と品との二人で、初子は寛永十七年生れで綱宗と同年、品は十六年生れで綱宗より一つ年上であつたらしい。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の中で初子は家柄が好いのと後見があつたのとで、綱宗はそれを納れる時正式の婚礼をした。",
              "citation": {
                "source": "椙原品",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫間犬丸と名をいつわり、どんなてがらでもたてて将軍家光にちかづき、ほろびうせた豊臣家のため、また祖父団右ヱ門のため、ひと太刀うらもうとしたにそういござらぬ。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷はあいての左肩から乳へかけて、左ななめに斬りつけているはずじゃ」「なら、だんなさま、たしかにご隠居さまはそのときの曲者にそういございません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたからくるおかたこそ龍太郎さまにそういござりませぬ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
