        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして自分の実際の身長よりも二寸くらい低く言うそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "附け鬚模様の銀｜鍍金の楯があなたによく似合うそうですよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人が西洋の楽器を取ってならす事はならすが音楽にならぬと云うのはつまり弾手の情が単調で狂すると云う事がないからで、西洋の名手とまで行かぬ人でも楽の大切な面白い所へくると一切夢中になってしまうそうだ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそう時々帰って来るには及ばぬ……とカンカン。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝例の通り、人夫を※って、西山峠を越えた、妙法寺の裏から、去年とは違った道――北海とも、柳川通りともいうそうだ――を登った、そうしてデッチョウの茶屋の前で、去年の登り道と一ツに合った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを「捩じれ窪」というそうだ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の峰からは、大残雪が横尾の谷へと白く走っている、御幣岳からずり下りに、梓川の方へと立て廻わす大岩壁は、屏風岩とも、仙人岩とも言うそうで、削ったようなのが、大手をひろげて立ち塞がっている、東の空にピラミッド形をしてそそり立っているのは、常念岳らしい。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでしばらく飼うと脂気が抜けてしまうそうで、そのさっぱりした味がこの土地に相応しいような気もした。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、お決まりの癖が出たね」　長煙管で煙草を一ぷく喫って、左の手で袖口を掴み展き、着ている大島の男縞が似合うか似合わないか検してみる様子をしたのち「うっちゃってお置き、そうそうはこっちも甘くなってはいられないんだから」　そして膝の灰をぽんぽんぽんと叩いて、楽譜をゆっくりしまいかけた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生時代には学期試験とか学年試験とかいうものがやはりそうした峠になっていたが、学校を出ればもうそうしたものはないかと思うと、それどころか、もっともっとけわしい山坂が不規則に意想外に行手に現われて来た。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も雑煮の競食などということが普通に行われていた頃であるから多くの人には切餅の一片二片は問題にならなかったかもしれないが、四軒五軒と廻る先々での一片二片はそうそう楽なものではないのである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的の知識はそうそうたやすく終局に達せらるるものではない事を呑み込ませて欲しいものである。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通りの知識と熱心と忍耐と誠実があらば、そうそう解決のつかぬような困難の起る事は普通の場合には稀である。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋へんの言葉で怒ることをグザルというそうであるが、マレイでは gusari となっている。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前等二人が余り仲が好過ぎるとて人がかれこれ云うそうじゃ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒るという動作をしなければ怒りの感情は発育を遂げることが出来ずに消えてしまうそうである。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせこういう種類の下宿屋住居で、そうそう愉快な室もないはずであるが、しかし随分思い切って侘しげな住まいであった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう問題を、少し立入って考究し論議するとなると、事柄は存外複雑になって来て、おそらく、そうそう簡単には片付けられないことになるであろう。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語に「霧の堤」という語があるが、これは障るという意味よりはむしろ海上などで霧が水平線に堤のように下りて陸と見違えるようなのをいうそうである。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち巣の中にある他鳥の卵、云わば我子の乳兄弟を嘴で突き破って殺してしまうそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度米国の某鉄道会社で試験した結果によれば、人夫が六人掛かりで半日にやっとする仕事を、この器械でやれば四人でわずか一時間に片付けてしまうそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が、Ｔ「何時も貴方と　御一緒の……」　「こんな頭で、こんな顔の」雪枝が言えば、　半次「そうそうＴ「あの先生なら　此村大吉」　ゲーッ？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそうと思い付いてその娘さんの背後から声掛けた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銀杏でもプラタヌスでも、やはり一種の生物であってみれば、ただの無機物のようにそうそう簡単でないのはむしろ当然のことであろう。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、こうして河の真中でやっていれば、いかに東京人でも、そうそう傍まで押しかけて覗きには行かれない訳である。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫はあたかも何事も起らなかったかのようにうそうそと橋の欄干を嗅いでいた。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると番頭は、ほうそうですか、でも私は、三反持ちかえりのところをこの眼で見たんですが、と云う。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、よし、じゃ、もうそうするでない。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう、青ぞらのあんな高いとこ、巻雲さえ浮びそうに見えるとこを、三羽の鷹かなにかの鳥が、それとも鶴かスワンでしょうか、三またの槍の穂のようにはねをのばして白く光ってとんで行きます。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、そうそう、ありますとも。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
