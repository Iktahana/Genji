        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "フックラと莟のように、海に浮いた島々が、南洋ではどんなに奇麗なことだろう。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤※の浮いた水には妙に無気味な感覚があつて、何処かの草むらから錦の色をした蛇でも這出しさうな気がした。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤※の浮いた水には妙に無気味な感覚があって、どこかの草むらから錦の色をした蛇でも這出しそうな気がした。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れてゐたことは、二人の手首の、水にひたったとこが、少し水銀いろに浮いたやうに見え、その手首にぶっつかってできた波は、うつくしい燐光をあげて、ちらちらと燃えるやうに見えたのでもわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「粋と云はれて浮いた同士」が「つひ岡惚の浮気から」いつしか恬淡洒脱の心を失って行った場合には「またいとしさが弥増して、深く鳴子の野暮らしい」ことを託たねばならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は勿論のこと、僕よりも一層話したかったに相違ないが、年の至らぬのと浮いた心のない二人は、なかなか差向いでそんな話は出来なかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それを忘れた時の台詞はきっと（映画）になった場合、浮いたものになる。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、彼女は青磁のリノリウムに花の浮いた波浪をつくると、突然、佗しさを堪えた悲しみの堰がこわれるのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "燭台の青い灯に浮いた鏡の中の黒衣の人間の顔が瞬間消えて見えなくなりました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚｜迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は塵の浮いたテエブルの面に眼を落したまま、身動きもせずに默りこんでゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売柄で若い時には随分浮いた噂もきこえたが、この十年以来は慾一方に凝り固まっているとかいうので、近所の評判はあまり好くなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、情夫でもこしらえたとかいうような浮いたお話なら、おっしゃる通り、わたくしも大抵のことは大目に見て居りますけれども、どうもそれがまことに困りますので……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお伝は二年越しここに奉公している正直者で、今までに浮いた噂などは勿論なかったと亭主は証明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "……間もなく、湯に浮いた垢がキレイに掬いとられていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊の木の中でも樺の木でも、またかれくさの地下茎でも、月光いろの甘い樹液がちらちらゆれだし、早い萱草やつめくさの芽にはもう黄金いろのちいさな澱粉の粒がつうつう浮いたり沈んだりしています。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れていたことは、二人の手首の、水にひたったとこが、少し水銀いろに浮いたように見え、その手首にぶっつかってできた波は、うつくしい燐光をあげて、ちらちらと燃えるように見えたのでもわかりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と向うへ突いた、男の身が浮いた下へ、片袖を敷かせると、まくれた白い腕を、膝に縋って、お柳は吻と呼吸。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）貫五さんは、この峠を、もとへ二｜町ばかり、樹ぶり、枝ぶり山毛欅の老樹の、水を空にして、湖の雲に浮いた、断崖の景色がある。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもたしかに流れてゐたことは、二人の手首の、水にひたしたところが、少し水銀いろに浮いたやうに見え、その手首にぶつつかつてできた波は、うつくしい燐光をあげて、ちらちらと燃えるやうに見えたのでもわかりました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し思ったより静で、妹お光の浮いた笑声と、これに伴う男の太い声は二人か三人。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "積荷のない為め、思うさま船脚が浮いたので、上甲板は海面から小山の様に高まって居る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその男の寂しい笑顔を見ると、自分と珪次があんなに突き詰めて情熱を籠めて行動して来た生活が、まるで浮いた戯れのように顧られました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い犬の鼻づらが、水を出て浮いたむこうへ、銑さんが艪をおしておいでだった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、どういたしまして。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さそりは一生けん命遁げて遁げたけどたうたういたちに押へられさうになったわ、そのときいきなり前に井戸があってその中に落ちてしまったわ、もうどうしてもあがられないでさそりは溺れはじめたのよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういたして、目のくるめくような楽の急調を、常の日に調べようと致すのでございましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）まあ、お互にこういたして笑っていられます間に、お暇乞をいたしましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋しき父母兄弟に離れ、はるばると都に来て、燃ゆるがごとき功名の心にむちうち、学問する身にてありながら、私はまだ、ほんのこどもでしたから、こういういたずらも四郎と同じ心のおもしろさを持っていたのです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
