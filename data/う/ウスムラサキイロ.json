        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "青みかかった雲は、東方からさしてくる赤い日の出に、薄紫色に染めぬかれて、ゆるやかに動いていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙を見ると、薄紫色の絹地に白い紙が貼られ、それに『日本名婦伝』と書かれている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりが薄紫色に沈んでしまうと、多鶴子と離れている時間がひしひしと迫って来て、豹一の心を滅入らせた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の色がだんだんに薄紫色に薄らいで行き、やがて東の空が橙色に燃え出すと多鶴子と別々にすごした悩ましい時間ももはやどこかへ消え去ってしまった想いで、じたばたと立ち騒ぐ心も諦めのなかに沈んでしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高原地帯の原始林は既に、黝んだ薄紫色の新芽に装われていたが、野宿をするには、未だ寒かった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「眩しいわ」　紀久子は馬車の上に薄紫色のパラソルを開いた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く左の方には薄紫色の犬崎が、私達の通って来た海岸へ続くのであろう、この大きな内海を抱きこむようにして、漂渺たる汀を長々と横えている。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス管の中に、清澄な液を口のところまで充たしており、その中に灰色とも薄紫色ともつかない妙な色の、どろっとしたものが漬かっていた。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、生きているぞ」　薄紫色の腸が、よく見ると、ぐにゃりぐにゃりと動いている。",
              "citation": {
                "source": "生きている腸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその薄紫色の虹の上端が始め見えたときよりも遙かの上空まで細くなって伸びているのを認めただけだったということだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、言葉に出して呟かないまでも、頭のなかでさう思ふだけでも、幾らか調子が強過ぎ、線がきつぱりし過ぎるほど、ひつそりとした十月の夕暮で、薄紫色の靄がかつたものが、忍びやかに草の葉を滑り、しつとりと木の間木の間に滲み入らうとしてゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅咲きの紅梅の花さへもが、いつの間にかすつかり散り去せて、あちこちの街角から涌きあがる温泉の煙りが駘蕩として薄紫色の山々を撫でゝゐた。",
              "citation": {
                "source": "タンタレスの春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬木立の連った梢が薄紫色にぼうと霞んでいて、まだ新芽の出そうな気配もないから騒がしげな心も起らない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄紫色に大体は癒着しているように見えながら、探りを入れたら、深く入りそうに思える穴もあって、そこから淋巴液のようなものが入染んでいた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿の詰つた口、薬物の反応らしい下縁の薄紫色に斑点つけられた目、ちやうどそれは土の人形か、胡粉を塗つた木彫の仏像としか思はれない首が、持ちかへる度に、がくり――とぐらついた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに鍵屋の最中の薄紫色をした粒餡が、東京ではちよつと食べられないやうな素直な軽い味をもつてゐた。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせんがこの部屋で菫の刺繍なぞを造ろうとしては、花の型のある紙を切地に宛行ったり、その上から白粉を塗ったりして置いて、それに添うて薄紫色のすが糸を運んでいた光景が、唯｜涙脆かったような人だけに、余計可哀そうに思われて来た。",
              "citation": {
                "source": "刺繍",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹腔が岩片に潰されてしまって、その無残な裂け口から、幾重にも輪をなした腸綿が、ドロリと気味悪い薄紫色をして覗いておりましたわね。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清涼飲料水の看板を掲げた酒場の薄紫色のガラス扉がおりおり開いて、洋服を着た男たちが出たり入ったりしていた。",
              "citation": {
                "source": "宝石の序曲",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "原一面薄紫色に煙つてゐた。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀色に、淡紅色に、薄紫色にいろいろになって波うった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁スイッチが押されるとジジジーというかすかな音がして、この放電管が薄紫色に輝きだした。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い爛れた眼のような火影が、女の薄紫色の厚い唇と、男の毛虫のような太い眉毛の上に泳ぎ付いた。",
              "citation": {
                "source": "森の暗き夜",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "降雪中の街の景色と、屋上における観測の場面とがなくては、どうにもシナリオが書けないので、毎日待っているが、夕方になると一天雲もない空の地平線近くが薄紫色に霞んで、春の光の兆しが見えるような日ばかり続いて如何にも心細かった。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ今日も寝坊して気の毒だなと思って「テーブル」の上を見ると、薄紫色の状袋の四隅を一分ばかり濃い菫色に染めた封書がある。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは一様に浄衣の下に薄紫色の衣を着けていたが、水にぬれて、丁度喪服の色に見えた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
