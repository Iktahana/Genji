        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は曾て大正七、八年の頃に、三宅やす子さんの發行して居られたウーマンカレントといふ小さい雜誌に、自分と仙子さんとの交渉を、可成り正直に心からの聲を出して書いた事があつた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリーマンの妻としての暮しにおいても、サラリー・ウーマンとしての暮しにおいても。",
              "citation": {
                "source": "現実の道",
                "author": "――女も仕事をもて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "互にまともな結婚もなかなかできない下級サラリーマンとウーマンとが、自分たちのゆがめられしぼられている小さい恋の花束を眺めて、野暮に憤る代りに、肩をすくめ、目交ぜし合い、やがて口笛を吹いてゆくような新らしげな受動性。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば正月号の『ウーマンカレント』のカレントなども、新聞の寸評的効果を与えようとした点広く社会問題をとりあげている点面白いが、私には、問題の表面を滑りすぎた評言が与えられているところ物足りなかった。",
              "citation": {
                "source": "是は現実的な感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本質においては反人民的な勢力のスポークス・ウーマンとなりつつあるとき、小池富美子の自然発生の生のたたかいが、岩をめぐり、草の根にしみて、より高い人民的なものに成長しはじめていることは、意義ぶかい現実である。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅やす子の『ウーマンカレント』を中心とし小規模の救援事業をした。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月三十日（金曜）『ウーマンカレント』の為に、埃及神話のセトナと魔法の書を訳してあげる。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十四日（金曜）『ウーマンカレント』のために感想「是は現実的な感想」。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ウーマンカレント』合評会記、一寸よみ、あまり上滑りのして居るのにおどろいた。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔備忘録〕一月に書いたもの　是は現実的な感想――ウーマンカレント　沈丁花　　　　　――文芸春秋　一月二十八日　Ｙナスに出発　松川やよくない由。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんの激しい気性に圧倒されて育ったせいか、マダムも一通りの負けギライで相当のスポーツウーマン、勝負ごとに相当強いらしいけれども、烈火の気性は全然ないのである。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「ア・ウーマン」といったのに、これでは「ア・グループ・オヴ・ウイメン・エンド・チルドレン」である。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらたなレコーディングもはじまり、『アイ・ガット・ア・ウーマン』がヴィクターでの最初の吹きこみになった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
