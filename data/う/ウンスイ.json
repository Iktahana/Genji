        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こうした同じ「心の家郷」を、芭蕉は空間の所在に求め、雲水の如く生涯を漂泊の旅に暮した。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "から鮭も空也の痩も寒の内　雲水に似た旅人芭蕉も、時には一定の住所に庵を構えて、冬の囲炉裏を囲みながら、侘しく暮していたこともある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき見た雲水僧の言葉態度が妙に心に引っかかっていた。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ――楼に入ると直ぐに楼の女から雲水僧の到着を聞かされたので、国太郎の全身は殆ど僧に対する一つの探求心になって、客たちを成るたけ早く部屋々々へ引き取らせ、自分は馴染の太夫の部屋に起きていて終夜、魯八を間者に使って雲水僧の消息を一々探り取らせた。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯八の諜報に依ると、雲水僧は登楼して以来、普通の遊客と少しも違わぬコースを取った。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると男はかの雲水僧なので国太郎は、はっとして階段の蔭に隠れて様子を見ていた。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲水僧はすっかり女にうつつを抜かれた様子で、玄関で草鞋を穿くまで浅間しいまでに未練気な素振りを見せて居る。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の九十日間は雲水達はどこかの寺の道場に宿りを求め静に座禅工夫にいそしむのであった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて慧鶴は思い切って馬翁に暇を告げ桜の頃檜木村をあとにして、雲水の旅に出かけた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道に入り切って右往左往していると妙なもので彼も雲水社会に多少名を知られるような一人となった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同輩ぐらいの年期の雲水は彼を信じられる頼母しい友人と認めて伴れになることを好んだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼からみるとその程度の幸福を望んでいる雲水たちは苧殻の屑のように思えた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢へ来たときにある雲水から馬翁が重病にかかって而も介抱するものが一人もいないという話を聞込んだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかせばや信田の森のふる寺の小夜ふけがたの雪のひゞきを　斯くて三十四歳の時は、押しも押されもせぬ一廉の禅師になり、亡師のあとを継いで松蔭寺の住職となり、まだ破れ寺ではあるが、そこに蟠※してぽつぽつ集って来た雲水に向って教育をはじめた頃である。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌黎信とせず、審に其の仔細を詰れば、韓湘高らかに歌つて曰く、青山雲水の窟、此の地是れ我が家。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "總角より教外の旨をあきらめ給ひて、常に身を雲水にまかせ給ふ……　殆ど暗誦した雨月物語の青頭巾の全章を、雪にむせつゝ高らかに朗讀した。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく風采がわるいので、どうせこの寺に厄介になつてゐる雲水坊主位のものだらう、と思つて、「今日は、和尚はをられますか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚だつて雲水だつて同じだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも、それをやつて見ようと思つて、はるばる雲水して、長崎へやつて来ました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また雲水に出掛けるのかい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と申しあげたとき、こんなつまらない雲水坊主で、一生を終るとは思はれなかつたらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝の諱は允絶えて又｜如何ともする能わず、仲の兄｜馳還ってに至り、光固汝頴の諸州に托鉢修行し、三歳の間は草鞋竹笠、憂き雲水の身を過したまえりという。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人柄はまことになつかしいものでござるが、世捨人入道雲水ばかり出来ても善人が世に減る道理。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あいにく留守だが、そこは雲水、風の加減で、ふわりと帰る事もあろう。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲水ああもう秋ぢやな。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の道心が定まって、もう動かないのを自覚すると、師の坊の許しを得て、諸人救済の大願を起し、諸国雲水の旅に出たのであった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとし、満洲から帰って海清寺に落ちついた甚斎は、僧堂に自分の気に添わない雲水が二、三人いることに気がついた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雲水たちの食事の世話を焼きだした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、雲水たちは汁鍋の蓋を取ってびっくりした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
