        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その首を口にふくんで適当な圧力で吹くと底のガラスの薄板がポンという音を立ててその曲率を反転する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな築山と木枝の茂みや、池と庭草は、電灯の光は受けても薄板金で張ったり、針金で輪廓を取ったりした小さなセットにしか見えない。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ鉛錘は近来の考に成りたる由にて、「にっける」の薄板を被せたれば光り輝きて美し。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄板を組合せて名｜刺形の暗箱をこしらへる。",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "政枝の薄板のようになった下腹に、ひとりでに少し力が入った。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木工場と鋳造場と、その向うの薄板工場と、第一工場のデッキの下を潜り抜けて、購買組合の前から通用門を抜けると往来へ出る。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには死骸が二人の職工の手で事務室へ抱え移されていたために、現場の模様が全くわからなくなったので、取調べがだんだん大仕掛になって行って、犯人が逃込んだと思われる、木工、鋳造、薄板、第一工場の全部の職工が一人一人に訊問されたせいでもあったろう。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その端々、隅々から赤や、青や、茶色の焔がポーッと燃え上るたんびにそこいら中が明るくなって、又、前にも増した暗黒を作って行く物すごい光景を、薄板工場の中から湧き起るケタタマシイ雑音の交錯が伴奏しつつ、星だらけの霜の夜を更けさせて行く。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハッハッハッハッ……あばれちゃ……いかん……ハッハッハッハッ……動いちゃ……」　折柄起った薄板工場の雑音のために、その声は掻き消されて行った。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下から又、薄板の隔膜と反故紙の腸があらわれた。",
              "citation": {
                "source": "微笑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "店先には小さな薄板に下手なしかも大きな字で大寺餅ありと書いてある。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると前の臺の上に長さ二三尺、幅六七寸ほどの薄板をおき、せつせと鉋で削つてゐるのだつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と熊吉はそれまでに削りあげた何枚かの薄板を繩でからげてそこの壁に立てかけ、自分も火鉢の側に寄つて來ていつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "またオカ河の材木置場から薄板を盗むことも（たまに）やった。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屑拾いよりもっと有利な仕事は材木置場から薄板をかっ払うことであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薄板をかっぱらうことについてゴーリキイは説明する。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ切り其のことを忘れてゐたが、今日はまた早くから、麗はしい朝日に照らされて、其の黄色い薄板が、※のやうに乾してある。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔かい新緑の風は、こんなに市塵の深い瓦の上へも吹いて來て、乾された薄板が、搖々と動いてゐる。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が膳部を下げてから、私はまた欄干の側へ出て、更に其の※のやうな薄板が微風に搖々してゐるのを眺めてゐたが、どうも串とは受け取れなかつた。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はパイプに火をつけ、外の暗闇にでたくなかったので、部屋の薄板を一、二枚はがして火にくべ、夜が明けるまで煙草をすいながら考えつづけた。",
              "citation": {
                "source": "マカーガー峽谷の秘密",
                "author": "THE SECRET OF MACARGER'S GULCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "または、ぴんと張りつめた薄板のようなものがどこかにあって、それが風に鳴るのであろうか。",
              "citation": {
                "source": "春盲",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄板、ボール紙などを取り出す。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また風を起こすためには団扇は扁平でなければならぬが、扁平である以上はこれを一種の薄板として蠅をたたくために用いることができる。",
              "citation": {
                "source": "脳髄の進化",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝋マッチ」をてらして辛うじて板の上へ出たが、絶壁にも比すべきところに、突き出された二本の丸太、その上に無造作に置かれた一枚の薄板、尾瀬沼のそれにも増した奇抜な便所に、私は二の足を踏まざるを得なかった。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は自分がもうずっとずっと前から材木屋をしているような気がし、この世の中で一ばん大切で必要なものは材木のように思えて、桁材だの、丸太だの、板割だの、薄板だの、小割だの、木舞だの、台木だの、背板だの……といった言葉の中に、何となく親身なしみじみした響きが聞きとれるのだった。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "百済観音は確かにこの鋼の線条のような直線と、鋼の薄板を彎曲させたような、硬く鋭い曲線とによって貫かれている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ、それから見せてくれ」「へエ、へエ、どうぞ此方へ――」　番頭に案内されてグルリと路地を廻ると、高塀に圍まれた裏口で、三尺の潜戸はかまち寄りの薄板を三寸四方ほど鋭利な刄物で切拔かれ、其處から手を差込んで、易々と輪鍵を外し、棧を拔いて潜戸を開けた樣子は、物凄いほど鮮やかな手際です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは今日の英国を、莫大な荷物――長いあいだ世帯を張っているうちに積みあつめ、それを焼きすてる勇気をもっていない、がらくた物を大トランク、小トランク、薄板箱、包み荷につめて旅行をしている老紳士だと考える。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "千兩箱は最初から蓋だけ二重になつて居り、薄板の赤樫の上側の蓋を拔き取つて、打敷の下に隱せば、その下から分厚な薄汚れた千兩箱が出て來る仕掛になつて居りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "贋金",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜそんなに寒くなるかといふのに皮がうすいためで、なぜ皮が薄いかといふのに、それは土用に生れたからです。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            }
          ]
        }
