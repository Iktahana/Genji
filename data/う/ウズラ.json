        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "敵萩原朔太郎鶉や鷓鴣の飛びゆくかなたにふたたび白堊の城は現はれ　風のやうに消えてしまつた。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゼットが始めて彼に捉えられてサン・ラザールの館――即ち牢屋へ送り込まれるときには生鳥の鶉のように大事にされた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし春の夕闇に鶉の下蒸しの匂いが廚房から匂って出なかったら通りがかりの人はおそらくこの辺にあり勝ちの住宅附事務所とも思って過ぎてしまうだろう。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は滅亡の中からいま店の名物となって居る dortsch というスープと「スウヴァロフの鶉」という二いろ料理を持ち出した。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――山鳩七｜羽、田鴫十三、鶉十五｜羽、鴨が三｜羽――　づしりと其の中にあるが如くに見て取られる。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと水をつけておいて、柔かにぐいぐいとこう遣りさえすりゃ、あい、鷹化して鳩となり、傘変わって助六となり、田鼠化して鶉となり、真鍮変じて銀となるッ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山家、村里は薄紅の蕎麥の霧、粟の實の茂れる中に、鶉が鳴けば山鳩の谺する。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれそりゃ、田鼠化為鶉、雀入海中為蛤、とあってな、召つかいから奥方になる。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "田鼠化為鶉、親仁、すなわち意気となる。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "田鼠化為鶉、馬丁すなわち奉行となる。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩一歩あるくたびごとに、霜でふくれあがった土が鶉か梟の呟きのようなおかしい低音をたててくだけるのだ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは鶉のやうに羽ばたきながらさうして丈の高い野茨の上を飛びまはつたああ　雲よ　船よ　どこに彼女は航海の碇をすてたかふしぎな情熱になやみながらわたしは沈默の墓地をたづねあるいたそれはこの草叢の風に吹かれてゐるしづかに　錆びついた　戀愛鳥の木乃伊であつた。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは鶉のやうに羽ばたきながらさうして丈の高い野茨の上を飛びまはつた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂簾には潤ひのある字で『鶉居』と書いてあつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『鶉居』と書いたのは鶉は常居なし、といふいひ慣しから思ひついた庵号だつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "住み切らうと決心した南禅寺の小庵『鶉居』にも住み切れなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョッピリ叔母さんも、お弟子を五人連れて、鶉で頑張っているそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またな、その心を汲取って、鶉へ嬉々お帰りやした、貴女の優しい、仇気ない、可愛らしさも身に染みて。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　私はな、丸官はんに、軋々と……四角な天窓乗せられて、鶉の仕切も拷問の柱とやら、膝も骨も砕けるほど、辛い苦しい堪え難い、石を抱く責苦に逢うような中でも、身節も弛んで、恍惚するまで視めていた。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間、引船、桟敷などいうべきを、鶉、出鶉、坪、追込など称えたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めていると雨竜が頭を出しそうでもあるし、この空に鶉の茹で卵を一つぽんと落したら支那料理の燕巣湯にも思い取られそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白、カナリヤ、四十雀、鶉に文鳥に黒鶫、鳥もいろいろあるなかにおかめ鸚哥はおどけもの焦れて頓狂に啼きさけぶ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには紅い葵が咲き、向日葵が盛り、西瓜や鶉豆の花、唐黍の毛などがそよいで、それに露西亜人の丸太組の家もところどころに残っているし、異国風の実にまた新鮮な風景だった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白、カナリヤ、四十雀、鶉に文鳥に黒鶫、鳥もいろいろあるなかに、おかめ鸚哥はおどけもの、焦れて頓狂に啼きさけぶ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶉鳴く畑のしげふの。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐｜綏々として蕩たることあり、鶉奔々として良なし、悪貫已に盈つ。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶉奔奔として良なし、悪貫已に盈つ。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早々に飯をくってしまって、かのうずら籠をかかえて店を出ると、表はもう暗かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな化け物屋敷に長居はできない、帰ってくれと云われたのを幸いに、喜右衛門はうずら籠をかかえて怱々に表へ逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪者どもが徒党して、喜右衛門をこの空屋敷へ誘い込んで、不思議な化け物をみせて嚇しておいて、持参のうずらを奪い取ったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
