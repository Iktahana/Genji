[
  {
    "uuid": "95c7391c-2810-5ca8-afae-955f986a5df3",
    "entry": "受け",
    "reading": {
      "primary": "うけ",
      "alternatives": [
        "ウケ"
      ],
      "is_heteronym": false
    },
    "grammar": {
