          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「どうやったらうまく」とのこだわりは、そもそも「誰に何を訴えかけるのか」との根源的な問いに変化して枝雀を救った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりかえした袱紗包みを胸のところにあてて、しょんぼりとうつむきながら、「これを、愛一郎さんにおわたしすると、それっきりになってしまうの……それはもう、暁子には、わかっているんですけど……」　すっかり取乱して、サト子になにか訴えかけるのだが、サト子は言うことがないので、口をつぐんでいた。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞳は明るかったが、何か急ぐようで、何か求めるような、何か訴えかけるようなものがあった。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリーンができることはせいぜいの支配下にない俺の意識の一部に訴えかけることぐらいだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔かたちはどうしても思いだせないが、ぜんたいの姿と、そのときどきの身振り、泣き声や叫び声、訴えかける言葉などは、つい昨日のもののように鮮やかに、はっきりと記憶からよみがえってきた。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都、奈良、そして湖の箱根で、魅惑的な旅館に宿泊し、畳の伝統に満ちた美しい部屋で布団の上に寝る、という旅行の楽しさを訴えかけるコマーシャルだった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "魅力とは、どんなことにせよ、なにかを人に訴えかける力、ということです」「そんな被写体が見つかるかい」　そこへ教授が戻ってきた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
