        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "飯島に就て　寄宿舍の受付には外國からの映畫雜誌が飯島宛に澤山來る。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛西という名が、旧東京人の父には、市内という観念をいかにしても受付けさせなかった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　局へ内地の新聞を読みに来ている、二三人の居留民が、好奇心に眼を光らせて受付の方へやって来た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お道がなんと云つても、夫は受付けて呉れなかつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と片眼の細顔の、和服を着た受付が丁寧に言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付はそれを受取り急いで二階に上って去ったが間もなく降りて来て「どうぞ此方へ」と案内した、導かれて二階へ上ると、煖炉を熾に燃いていたので、ムッとする程｜温かい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付はそれを受取り急いで二階に上って去ったが間もなく降りて来て「どうぞ此方へ」と案内した、導かれて二階へ上ると、煖炉を熾に燃いていたので、ムッとする程温かい。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付の十蔵、卓に臂を置き煙草吹かしつつ外面をながめてありしがわが姿を見るやその片目をみはりて立ちぬ、その鼻よりは煙ゆるやかに出でたり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十蔵は受付の卓に倚りて煙草を吹かし、そのさまわがこの夜倶楽部に来し時と変わらず見えたり、ただ口元なる怪しき微笑のみ消えざるぞあやしき。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何も悪いことはないのだからと、じぶんでじぶんをはげまして勢よく玄関の正面の受付にたずねました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると受付の巡査はだまって帳面を五六枚繰っていましたが、「ああ失踪者の件だね、人事係のとこへ、その左の方の入口からはいって待っていたまえ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をはいると、すぐ受付があって私たちはみんな求められて会員証を示しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、笑ってばかりいて、てんで受付けません。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ホテルの受付へでも届けてやるという親切があなたにあれば、一生恩に着ますよ」「まア、そんなにマッチが……」「凄いニコチン中毒でね」「じゃ、届けてあげますわ、仕方がない」「何時頃……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "このホテルの受付の女とも、何かあるらしいの。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉は喫茶室を出ると、受付へ行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五三号室　　　　須賀信吉（われわれは軽佻か倦怠かの、どちらか一方に陥ることなくして、その一方をまぬがれることは出来ない）三三三号室様　と書いて、受付へことづけて置いたことを想い出しながら、言った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロビイの受付で、鍵を貰う時、「三百三十三号室への伝信、渡してくれた……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間、ホテルを出る時書いて、受付へ渡しておいたのである。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "受付の女の電話の声に魅力を感ずること。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子が約束どおり来たということ、そして、ロビイに信吉が見当らぬので、受付へ立寄って、わざわざ部屋へ電話を掛けさせたことが、信吉には何かうれしかったのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を洗って、あわててエレヴェーターに乗り、受付へ行ったが、冴子はそこにはいなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「須賀さんでいらっしゃいますか」　と、受付の女が声を掛けた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、こんな清潔な娘が受付にいたのかと信吉は眼を見はった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ」「御面会の方は、喫茶室にいらっしゃいます」「ありがとう」「いいえ」　ちらと、受付の女と視線が合った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ今出て来た新聞社の玄関から、受付の女に咎められるのも構わずに、一気に階上へ駈け上ると、何度も来たことのある調査部の扉をたたいて中に這入った。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "北川冬彦は嘗て最も潔癖に日本産の文學をうけつけなかつた詩人である。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弔礼のために、香川家を訪れたものが、うけつけの机も、四つばかり、応接に山をなす中から、其処へ通された親類縁者、それ／″＼、又他方面の客は、大方別室であらう。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この梟野郎めが――」　班長は、てんでうけつけない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、うけつけないのであった。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
