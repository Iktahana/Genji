      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "we",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昼間は毎日暑く、今産院にゐる娘は「ブーラ、ブーラ、ブーラブラ」といふ象といふ題の児童唱歌をオルガンで歌ひ、姉娘は夜になるとパウリスタに連れてつてアイスクリームを食べさせてくれた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナストウリ、モノサシトハサミ、カガミガアリマス、イケニフネ……」大急ぎでそれだけ読んだが、そこで息が切れた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のこたあない、ストーヴの中のカステラ見たいな、熱さには、ヨウリスだって持たないんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（来春はムスカリとチュウリップです。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偵察すればロシヤ、グロンボイ、リュウリックの三巡洋艦にして此の時既に我が友船泉丸は撃破せられ左渡又同じ運命に陥入らんとしつつあり」　突然に機関銃の音、　一同はッとなる。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう少し先のところで、マルテとあるのは、あの有名な「手記」の主人公マルテ・ラウリッヅ・ブリッゲを指してゐることは言ふまでもない。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その音は上方にずんずん押し擴がりながら、狹いヴァル・フルウリィぢゆうに一ぱいになつてしまひました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」『スズサン、リヨウジカンケイサツニコウリユウセラル、ドナタカスグゴライセイヲコウ――ハナカワヤ』「おや、すゞがあげられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとこうだろう、するとカルクシャイヤのおやじめ、あわてくさっておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはまるで赤や緑や青や様々の火がはげしく戦争をして、地雷火をかけたり、のろしを上げたり、またいなずまがひらめいたり、光の血が流れたり、そうかと思うと水色の焔が玉の全体をパッと占領して、今度はひなげしの花や、黄色のチュウリップ、薔薇やほたるかずらなどが、一面風にゆらいだりしているように見えるのです。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねずみ捕りの方も、痛いやら、しゃくにさわるやら、ガタガタ、ブルブル、リュウリュウとふるえました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめった五月の黒つちにチュウリップは無雑作に並べて植えられ、一めんに咲き、かすかにかすかにゆらいでいます。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は風が吹きたちまち太陽は雲を外れチュウリップの畑にも不意に明るく陽が射しました。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼砥の上で金鋼砂がじゃりじゃり云いチュウリップはぷらぷらゆれ、陽がまた降って赤い花は光ります。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一足チュウリップの方に近づきます。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふう、チュウリップの光の酒。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュウリップの光の酒。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒があんなに湧きあがり波を立てたり渦になったり花弁をあふれて流れてもあのチュウリップの緑の花柄は一寸もゆらぎはしないのです。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいくらこぼれたところでそこら一面チュウリップ酒の波だもの。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュウリップ酒で漬けた瓶詰です。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせチュウリップ酒の中の景色です。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュウリップ酒に火がはいったのです。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうそう、だからこれはあの白いチュウリップでしょう。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュウリップの幻術にかかっているうちに。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまへは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとかうだらう、するとカルクシヤイヤのおやぢめ、あわてくさつておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君から、キヤベツとキユウリとを送つてきた、明日のために、明日は緑平来、そして白船来の日である。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、あの赤いフウリンソウや、それから、小さなヒナギクもだ」　じっさい、カシワの木は、なにもかも、自分といっしょに、大きくならせたかったのです。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いフウリンソウと、小さな白いマツユキソウとが、まるで、鈴でも持っているように、チリンチリンと音をたてながらはいってきました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
