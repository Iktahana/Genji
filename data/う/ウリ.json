    "definitions": [
      {
        "index": 1,
        "gloss": "melon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なんだか瓜の肌でも見るやうだ。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋ふかき隣は何をする人ぞ秋さびし手毎にむけや瓜茄子　芭蕉の心が傷んだものは、大宇宙の中に生存して孤独に弱々しく震えながら、葦のように生活している人間の果敢なさと悲しさだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの小さな家の中で、手毎に瓜の皮をむいてる人々は、一人一人に自己の悲しみを持ってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏畑の竹藪の中の小径から我家と往来が出来て、垣の向うから熟柿が覗けばこちらから烏瓜が笑う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから朝市の大きな西瓜、こいつはごろごろして台へ載りにくかったのをようやくのせると、神様へ尻を向けているのは不都合じゃと云い出してまた据え直す。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日　垣にぶら下がっていた南瓜がいつの間にか垂れ落ちて水引の花へ尻をすえている。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸鼻は、むしろ、師に拾てられ、垣を燒かれた瓜の花。",
              "citation": {
                "source": "先生三人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸からつるべで水汲むのだが、冷してある水瓜にあたらないやうに、つるべ槽を下ろさなければならない。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫時水瓜を上げておいてからすればいいのだけれど、先生は今日のみならず、何時でも水瓜を冷やしてある時は、冷やしたまんまで水を汲まれるのが常らしいから、一寸それを変更してはならないものの如くである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　朝霧が山村を罩めて、鶏の声が、霧の底から聞える、黄色い南瓜の花に、まだ夢が残つてゐるかして、寝惚けた姿をしだらなく大地に投げ出してゐる、ぼツと白壁が明るくなる、森がうつすらと、烟つぽい緑を、向うの山の懐に、だんだら、染めに浮かせる、起き上つて支度をする頃は、方々の家から、軽い炊煙が立ちはじめた。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、土民の一人が瓜わらべを拾って持って来て呉れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒形をしていて柔かい生毛の背筋に瓜のような竪縞が入っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで瓜わらべと呼び慣わされていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはそのままでわしが貰おう」　翁は、瓜わらべを抱えて戸外へ出た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜わらべはくねくね可憐な鳴声を立てて鼻面を翁の胸にこすりつけた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は螺の腹にえび蔓の背をした形で、瓜わらべを抱え、いつの間にか、いつぞや、息子の岳神に教えられた山ふところの猪の相撲場に来ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は相撲場の中へ入り瓜わらべを土の上へ抱き下した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "螺の腹にえび蔓の背の形をした老翁と、筒形の瓜わらべとは、猫が毬を弄ぶように、また、老牛が狼に食まれるように、転びつ、倒れつ千態万状を尽して、戯れ狂った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜わらべにちょっと頬ずりして土に置いた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜わらべの和毛から放つらしい松脂の匂いが翁の鼻に残った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜わらべは小竹の中へ逃げ込みそうなので片手で押えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を滑った瓜わらべは逃れて小竹の茂みに走り込んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父さまは山中の猪の相撲場で、猪の仔の瓜わらべと遊び戯れているとき、猪の親に襲われ、牙にかかってお果てなされた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはこんやの星祭に青いあかりをこしらえて川へ流す烏瓜を取りに行く相談らしかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はみんなで烏瓜のあかりを川へながしに行くんだって。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ザネリ、烏瓜ながしに行くの。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十字になった町のかどを、まがらうとしましたら、向ふの橋へ行く方の雑貨店の前で、黒い影やぼんやり白いシャツが入り乱れて、六七人の生徒らが、口笛を吹いたり笑ったりして、めいめい烏瓜の燈火を持ってやって来るのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の中には、ぴかぴか青びかりを出す小さな虫もゐて、ある葉は青く〔〕すかし出され、ジョバンニは、さっきみんなの持って行った烏瓜のあかりのやうだとも思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでやっていっても中途半端でほうり出されます。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
