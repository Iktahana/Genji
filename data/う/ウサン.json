        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "見ず識らずの女が夜ちゅうに人の店へあがり込もうというのは、なんだか胡散らしいとも思ったが、お徳はもう三十を越している。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹の犬が豊吉の立っているすぐそばの、寒竹の生垣の間から突然現われて豊吉を見て胡散そうに耳を立てたが、たちまち垣の内で口笛が一声二声高く響くや犬はまた駆け込んでしまった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この目準があるものだから、いくら老僧たちが嘲笑的な態度を執ろうとも最後には彼等の胡散の誘惑から免れて初一念が求むる方向へと一人とぼとぼ思念を探り入れて行った。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」となお胡散らしく薄目で見上げる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん遣りかねますまいよ」「その晩橋場の交番の前を怪しい風体のやつが通ったので、巡査が咎めるとこそこそ遁げ出したから、こいつ胡散だと引っ捉えて見ると、着ている浴衣の片袖がない」　談ここに到りて、甲と乙とは、思わず同音に嗟きぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は爺婆の方が横着で、嫁をいじめる口叱言を、お念仏で句読を切ったり、膚脱で鰻の串を横銜えで題目を唱えたり、……昔からもそういうのもなかったんじゃないが、まだまだ胡散ながら、地獄極楽が、いくらか念頭にあるうちは始末がよかったのです。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして胡散臭そうに女を見乍ら誂を聞く給仕男へ横柄に、――ちょいと。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『書物の出現』を書いたアンリ＝ジャン・マルタンは、「買い手が印刷術という新しい方法に胡散臭さを感じていた」であるとか「写字生たちに気づかれてその神経を逆なで」しないため、といった諸説を否定してこう結論づけています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "常磐津の師匠と雇い婆、あいつらもなんだか胡散だから、出這入りに気をつけろ」　なにを云うにも人通りの少ない場末の町である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と胡散くさい目色をして、女を見下す。",
              "citation": {
                "source": "絶望",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに立っていた門番の老人は、胡散そうな眼つきをして、先きに立った Frohman の胸を突いた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも胡散な奴と知ったゆえ、二度目に駕籠脇へ近よろうとした前、篠崎竹雲斎先生お直伝の兵法をちょっと小出しに致して、ぴたり駕籠の天井に吸いついていたのじゃよ」「ま！",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いか程小理屈ぬかそうと、夜中｜胡散な者の通行は厳禁じゃッ、戻りませいッ、戻りませいッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡散な者とは何事じゃ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いか程小理屈ぬかそうと、夜中胡散な者の通行は厳禁じゃッ、戻りませいッ、戻りませいッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも水引奉書に飾り立てた品々が、ずらずらとそこに並べられたのを見眺めると、胡散げに退屈男を遠巻きにしながら監視していた若侍の面々が、期せずしてざわざわとざわめき立ちました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならばなにゆえ胡散げに市中をさ迷いおった。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥刺しといい貴様といい、愈々｜胡散な奴原じゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「胡散な捨て子が三人もあっちゃ、どうやらいわくがありそうだから、とち狂っていねえで、はええところしたくをしろといってるんだよ」「ちッ、ありがてえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、聴く耳もなく先程から、何となく胡散な眼つきであたりの様子を物色してゐたが、不図門脇のモロコシ畑の一隅に、堀立の野外厠を発見すると、思はずお神楽の武将が快諾の見得を示すみたいな実にも物々しい仁王立で、はつたと胸を叩き、沈重にかぶりを縦に振つた。",
              "citation": {
                "source": "夜見の巻",
                "author": "「吾が昆虫採集記」の一節",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、警部は最初から苦り切っていて、ろくに口もきかず、胡散臭げに支配人のすること為すことを、ジロジロ覗っていた。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人々が、何か胡散臭い目つきでこちらを眺める気がして私は、いつまでも窓から顔を出していることも出来なかった。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人女にも、於七が吉三のところへ夜決心してしのんで行って、突如、からからと鈴の音、たちまち小僧に、あれ、おじょうさんは、よいことを、と叫ばれ、ひたと両手合せて小僧にたのみいる、ところがあったと覚えているが、あの思わざる鈴の音には読むものすべて、はっと魂消したにちがいない。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは私たちの「逆廻り」を、うさんくさそうな傍目を使って、あわれむが如き素振りでゆき過ぎた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさん、大きなどんぐり、こいも／＼／＼／＼／＼みんな大きなどんぐり」と小さい泥だらけの指先で帽子の中に累々としたどんぐりの頭を一つ一つ突っつく。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところをわが青海流では、死屍水かかずしてよく浮くといって、平泳ぎのこころだ」「それは、よくおとうさんがおっしゃる、あの渾沌未分の兄弟か何かなの」　小初は食後の小楊枝を使いながら父親を弥次った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人たちがわりに気丈でぎょうさんらしく騒がないのに感心した。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石を敷いた狭いゴミだらけの通りを、え体の知れない支那人が、犬のようにうさんくさく行ったり来たりする。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも有りがとうさん。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだ、高がこれ股引きがねえからとって、ぎょうさんに咎め立てをするにゃあ当たらねえ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
