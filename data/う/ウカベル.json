        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かの茫漠たるステッペンやパンパスを漂浪する民族との比較を思い浮かべるときにこの日本の地形的特徴の精神的意義がいっそう明瞭に納得されるであろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感情を思い浮かべるためには、われわれが都会で経験する停電を思い出してみればいい。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思い浮かべるたびに、私は今いる都会のどこへ行っても電燈の光の流れている夜を薄っ汚なく思わないではいられないのである。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が都会を想い浮かべるごとに私の「疲労」は絶望に満ちた街々を描き出す。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼はその荒れ寂びた空想のなかに、恐ろしいまでに鮮やかな一つの場面を思い浮かべる。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠れなくなると私は軍艦の進水式を想い浮かべる。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次へ愛するものを失っていった母の、ときどきするとぼけたような表情を思い浮かべると、彼は静かに泣きはじめた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年東京会館の屋上庭園などで涼みながら銀座へんのネオンサインの照明を見おろしているときに、ふいとこの幼時の南磧の納涼場の記憶がよみがえって来て、そうしてあの熱い田舎ぜんざいの水っぽい甘さを思い出すと同時になき母のまだ若かった昔の日を思い浮かべることもある。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち船はもうずんずん沈みますから、私たちはかたまって、もうすっかり覚悟して、この人たち二人を抱いて、浮かべるだけは浮かぼうと船の沈むのを待っていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一つ思い浮かべるとその悲劇の有様が目の先に浮んで来て、母やお光が血だらけになって逃げ廻る様がありありと見える。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどその幻に似て遠きかなたに浮かべるさまは年若き者の夢想を俤にして希望という神の住みたもうがごとく、青年の心これに向かいてはただ静かに波打つのみ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれを見るたびに、楊枝をかみながら絵絹に対している春田居士を思い浮かべる。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が帰つた後で、うつかりまた耳の下へ手をやつてゐるのを、弟の眼がマジマジとするので気が付いて、急に手を下ろすと、一瞬弟の眼は後悔の色を浮かべるのであつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝っぱらから何だろうと思って、すぐに支度をして出て行きました」　半七老人は表情に富んでいる眼眦を少ししかめて、その当時のさまを眼に浮かべるように一と息ついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまんま何とも云えない悲痛な微笑を浮かべると、又モトの通りにうなだれて行ったというんだがね。",
              "citation": {
                "source": "殺人迷路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには教師までが口のあたりに薄笑いを浮かべる始末だ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は最早瞼をつまみ上げることも薄笑いを浮かべることも止めて、神妙に、というより呆気にとられたように、私の前に突立っていた。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "その曲が、なんだかポートセイドの小船の楽手らのやっていたのとよく似た心持ちを浮かべるものであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズはほんのしばらく考えをめぐらせると、ふしぎな笑みを浮かべるのであった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、その男は皮肉な笑いを浮かべる。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　満面の笑みを浮かべる。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人はこちらの顔色をうかがうと、苦笑いを浮かべる。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると連れは不可解な笑みを浮かべる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずらりと並んだコピー機に学生たちが張り付き、吐き出されてきたコピーを専用の機械が製本のためにばたばたと二つに折っていく光景を思い浮かべると、なんだかその様が、書き手と読み手の願いのすれ違いを象徴しているように思えてきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はまだ明らかとなっていないタマゴの中のマシンの姿を思い浮かべるには、設計図となる遺伝子が何と何の結び付きによって生まれたかを探るのが近道だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま帰ったばかりだがきさまといき会うはずだが、いやそりゃどうでもよいが、きさまはいくつになる」　芳輔はこういわれてすこし父をあなどるような冷笑を目に浮かべる。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ようやく、最後の一人がデッキへはい出た時には、今汽笛を鳴らして通った船は、浮かべる一大不夜城の壮観を見せて、三マイルも行き過ぎているであろう。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山の木立ち、池の中島のほとり、広く青み渡った苔の色などを、ただ遠く見ているだけでは飽き足らぬものがあろうと思われる若い女房たちのために、源氏は、前から造らせてあった唐風の船へ急に装飾などをさせて池へ浮かべることにした。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔あくたうかべる朝の水〕宮沢賢治あくたうかべる朝の水ひらととびかふつばくらめ苗のはこびの遅ければ熊ははぎしり雲を見る苗つけ馬を引ききたり露のすぎなの畔に立ち権は朱塗の盃をましろきそらにあふぐなり",
              "citation": {
                "source": "〔あくたうかべる朝の水〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いな見よ東かれらこそ、　　　古き火薬を燃し了へぬ）うかべる雲をあざけりて、　　　ひとびと丘を奔せくだりけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
