    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to come into being",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もちろん、数学の公理や論理はきわめて簡単明瞭であり、使用される概念も明確に制定されているに反して、言語による思考の場合では、これらのすべてのものが複雑に多義的であるから、一見同様な前提から多種多様な結論が生まれ出るように見える。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから実物の写真では表現し難い詩が生まれ出る。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活祭の節、キリスト教徒が鶏卵を食い相｜贈遺するに付いて、諸他の習俗、歌唄、諺話、欧州に多いが、要するに天の卵より雛の生まれ出るにキリストの復活を比べ、兼ねて春日の優に到ると作物の豊饒を祝うたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "木部との愛着の結果定子が生まれるようになったのではなく、定子というものがこの世に生まれ出るために、木部と葉子とは愛着のきずなにつながれたのだとさえ考えられもした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "率先垂範の美風は兵と全く同一生活の体験の中から生まれ出るべき筈である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、結婚した両性の生活として、親になってこそ始めて使命の完うされるものであると云う立場から、幾人であろうとも生まれ出る子等を、しんから悦び迎える者。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは立体的な複雑な触覚の音楽が作り出されると同時に目で見てもさも軟らかそうな、堅そうな、滑らかそうな、ゴツゴツらしいヘナヘナネバネバ円く長く珍しい立像が生まれ出ることだと思う。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くだけ泣けばあとには雨上りのような、はれやかさが生まれ出る。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりと抱きあった、まる／＼肥った健康らしい女の双児は、生まれ出るためにあまりに多くの血を母より奪ったのであった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「傑れた作品とは、緊張した意識の流れから、熟れた果実がいつか枝から落ちるように、生まれ出るもの」　表現への慾求が生む理想論。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、父親たる私の両腕に抱かれていたころのごく小さな彼はどういう者であったか、また彼はいかなる情況のもとで世に生まれ出ることを求めたかを、ここに回想してみたいのである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになったら、夢の卵がかえって金色の鳥が生まれ出ることでしょうか？",
              "citation": {
                "source": "夢の卵",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しそうに生まれ出る新月の影。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人達の中から、新日本が生まれ出るかと思えば、感慨無量である。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "變轉の若き日　三男に生まれた上、生まれ出ると間もなく形式ながら他家の養子にされた私は、いはば一家の餘分ものでした。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少年達から、二十年後の世界が生まれ出るのである。",
              "citation": {
                "source": "図書館法の成立",
                "author": "――燃えひろがる火は点ぜられた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "書には必ず人格が反映しているもので、人格が反映していない人格以上の書の生まれ出ることなど、まずもってあり得ない。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術の歴史におきましては、あるいは日本の後進国であるかも知れませんが、百年後の米国には驚くべき美術文化が発展し、驚異に価いする偉大な作品が生まれ出るかと考えられます。",
              "citation": {
                "source": "陶芸家を志す者のために",
                "author": "―芸術における人と作品の関係について―",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ助手数人を要するとしても、正真正銘の自作というものが自分の窯から生まれ出ることになった。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてのいい伝えから一歩も出ないで、今もなお指導者の力次第で生命ある物体が生まれ出ると妄信することの危険を感ずるのままに、一言否多言を費やした次第である。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣痛の極まるとき、あらゆる罪のつぐのいをはたし、潔められた、新しい私が生まれ出るのである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれ出る子供に不具者がありはしないかと、心配されていたが丈夫な赤ちゃんがつぎつぎと産声をあげた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本的篤農精神が巧く機械化と融合すると、こういう結果が生まれ出るのである。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の自由な、余裕ある、落ちついた態度は、ゲエテを模するまでもなく、彼の享楽人としての素質から生まれ出るのである。",
              "citation": {
                "source": "享楽人",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてついに、肉欲的恋愛から独立した、精神的に透明な、かぐや姫の空想が生まれ出るのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼の物質的、精神的な境遇への研究が彼のばあい重要である理由は、境遇が、作品の生まれ出る雰囲気を形成しているからである。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "各種の半合法的暴力はここから続々として生まれ出る。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうなっても良いものが生まれ出るばかりなのが、古美術品の共通価値である。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才的な人間は百万人の中に一人しか出て来ないし、偉大な天才、人類の完成者は、幾百万人と流れ過ぎた後に、やっと生まれ出るか出ないかです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦患のなかからのみ、真の幸福と歓喜は生まれ出る。",
              "citation": {
                "source": "ベエトォフェンの面",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
