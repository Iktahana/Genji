[
  {
    "uuid": "7e0baecc-ae58-5b3a-bb33-f31eb769aa02",
    "entry": "旨煮",
    "reading": {
      "primary": "うまに",
      "alternatives": [
        "あまに"
      ],
      "is_heteronym": true
    },
    "grammar": {
