        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "典六「御助勢申すとも」　雪枝「有難う存じます」と其の場に嬉し泣きに泣き伏す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不憫で、そして、いま「男だ」と云ったばかりの薫の声が遠い昔から自分に授っていた決定的な男性の声のような頼母しさを感じて嬉し泣きに泣けて来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来たポチを見ると、太郎さんは抱きついて嬉し泣きをしました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚吉も嬉し泣きに泣きながら、脱いだ着物を着て、最前のめしやに帰って来て、ヒョロ子に今までのことをお話ししますと、ヒョロ子も涙を流して喜んで、「それはよいことをなさいました」　とほめました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、何だか夢のようだ」　と、親子四人、手を取り合って嬉し泣きに泣きました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、「アッ、お兄様」　と言って嬉し泣きに泣きながら春夫さんに縋り付いた女の児がありました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッ、美代ちゃん」　と云うと、春夫さんも嬉し泣きに泣きました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペテロやヨハネやバルトロマイ、そのほか全部の弟子共は、ばかなやつ、すでに天国を目のまえに見たかのように、まるで凱旋の将軍につき従っているかのように、有頂天の歓喜で互いに抱き合い、涙に濡れた接吻を交し、一徹者のペテロなど、ヨハネを抱きかかえたまま、わあわあ大声で嬉し泣きに泣き崩れていました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると若日子の父と妻子たちは、「おや」とびっくりして、その神の手足にとりすがりながら、「まあまあおまえは生きていたのか」「まあ、あなたは死なないでいてくださいましたか」と言って、みんなでおんおんと嬉し泣きに泣きだしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房も番頭も嬉し泣きに泣いた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と嬉し泣きに泣きながら縋り付いた。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人同時に言い、ひしと抱き合い、それから嬉し泣きにおいおい声を放って泣いた。",
              "citation": {
                "source": "走れメロス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光は嬉し泣きにまた泣いた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧も生れて始めて嬉し泣きに泣いた。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見た白髪小僧は直ぐに裸体になって川の中に飛び込んでその娘を救い上げましたが、間もなく人々の知らせで駈けつけた娘の両親は、白髪小僧に助けられて息を吹き返した娘の顔を見ると、只もう嬉し泣きに泣いて、濡れた着物の上から娘をしっかりと抱き締めました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ると両親は、又もや一人小供が生れたように喜んで、嬉し泣きに泣きました。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉田二等水兵は、嬉し泣きしているのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母は一人で玄関のそとまで僕を送りだして、自分もやはり嬉し泣きに泣いていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの使命は遂に全うせられたッ」　僕たちは鍵を高くさし上げると、感極まって互いにひしと抱き合い、共に相手の胸に顔を埋めて嬉し泣きに泣いた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "満場のドヨメキの中に弟の身体が運び出されますと、私はもう嬉し泣きの涙で向うが見えなくなってしまいました。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もうわたしはその時には、御主人の膝を抱いたまま、嬉し泣きに泣いていたのです。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "子鶉も嬉し泣きに、「チックヮラ／＼。",
              "citation": {
                "source": "孝行鶉の話",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙に咽せぶ嬉し泣きを暫く続けて居りました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後一時の汽車に乗り、汽車の中から日本公使館に電報を打ったので、汽車がその夜九時にプラーグに着いた時、松田書記官が駅に出迎えて下さったので、地獄で仏に逢ったような気がして、私は松田さんにすがりついて嬉し泣きに泣きぬれてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はパティにお目にかかれることもない、まして御一緒のステージに出られようとは夢にも考えていなかったので、嬉し泣きに泣いたことは申すまでもありませんでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお……」　といって、その静枝嬢はバタバタと畳の上を飛んでくるなり、妾の胸にとりすがって、嬉し泣きにさめざめと泣くのであった。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその陰で、突然、それが病人にもわかるほど、嬉し泣きに泣きじゃくり出したのだそうだった。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギリシア人は、アジアの山から地中海を見たときに嬉し泣きをし、自分たちの労苦の限界を知ってむちゅうで歓呼した。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（嬉し泣きに泣く）ラネーフスカヤ夫人、ガーエフ、ピーシチク登場。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、何べんも嬉し泣きに泣きたいような思いになりながら圓朝は、船で小糸の家までおくられていった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
