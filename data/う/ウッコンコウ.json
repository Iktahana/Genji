          ],
          "literary": [
            {
              "text": "また、高※の鬱金香。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、浮きのこる鬱金香。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱金香黄と、紅と、みどり、生な色どり……※粉細工のやうなチユウリツプの花よ、葉よ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの公園の花壇には、今でも鬱金香や黄水仙が、電燈の光に咲いているであろうか？",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鬱金香の花はわたしが縫取をして、それを職人にしたてさせたのよ。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし鬱金香が大嫌いさ。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけれどあの人はなんにでも鬱金香を付けなくちゃあ気が済まないのだもの。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "）わたしがこの上沓に鬱金香の繍取をさせられたのは、お前さんが鬱金香を好いているからだわ。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾らお前さんが鬱金香が好きだって、いろんな人を迷わせるような癖を持っていたって、とうとう誰もお前さんと一しょにはならないでしょう。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鬱金香の上沓も持って行くわ。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんの鬱金香の付いている上沓も持って行くわ。",
              "citation": {
                "source": "一人舞台",
                "author": "ストリンドベルヒ　August Strindberg",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱金香を見詰めつつ、戀に身の細る花賣むすめ。",
              "citation": {
                "source": "ハルレム",
                "author": "HARLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "天鵝絨のように生えた青草の上に、蛋白石の台を置いて、腰をかけた、一人の乙女を囲んで、薔薇や鬱金香の花が楽しそうにもたれ合い、小ざかしげな鹿や、鳩や金糸雀が、静かに待っています。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜀葵は木のやうに高く伸び、百合は開き、鬱金香や薔薇が微笑んだ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その気紛れの洋傘直しと園丁とはうっこんこうの畑の方へ五、六歩｜寄ります。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
