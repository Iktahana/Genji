        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "宇宙時代になっても、やはり汲取舟は必要だというのが、人間なのである。",
              "citation": {
                "source": "人工衛星へ汲取舟が行く話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙時代というような言葉が流行し、それが何か人間を変えることのように思われているのも、その一つの現われである。",
              "citation": {
                "source": "科学の限界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年ソ連が人工衛星に犬を乗せて飛ばすことに成功した時、日本では「宇宙時代」来るといって、大騒ぎをした。",
              "citation": {
                "source": "高度八十マイル",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近来はですね、宇宙時代、宇宙をあたかも人間が征服でもしたかのごとく、ソ連でも宇宙船が飛んだ、アメリカでもやった、というたびに、上を向いて宇宙時代をいう。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その宇宙時代から私たちの生活、心になにがもたらされたでしょうか。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を動かして、口をあいて、ただ宇宙時代といっているのはどうかと思うのであります。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、われわれがただ宇宙時代といって口をあいて見物するばかりで、なにになりましょうか。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
