          ],
          "literary": [
            {
              "text": "ほかに、どんな仕事があるっていうんだ」「『ウェイターなんか、どうだ？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔して悪かったな」「いいえー、ウェイターになれば、すむことです。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿は避暑客で、殆んど満員と云うくらい、雨で往来は静かだが、名物の木彫りや、絵はがきを並べた店先きには、ちらほら人だかりもして、昼飯の仕度をしていたらしいウェイターが、セルヴィエットを手にもったまま、窓からガイドに、行く先きを聞くのも、山よりの村らしくて面白い。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェイターはその瓶を下げて、新しいデカンターに反対のあったワインの半分を入れ、それを他の瓶からのもので満たした。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "落着いた食堂で、純白のテーブル掛のかかったテーブルに着くと、黒ん坊のウェイターが、サーヴィスして呉れる。",
              "citation": {
                "source": "想い出",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンを、皿に載せないで、直かに、テーブルクロースの上へ置かれたのに、いささか面喰いつつ――パンの粉を、黒ん坊のウェイターが、時々刷毛で掃除して呉れた。",
              "citation": {
                "source": "想い出",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょいと後を向いて、又お代りだという表情をすると、黒ん坊のウェイターは、笑いもせずに、たちどころに、大きな皿を僕の傍へ持って来るのだった。",
              "citation": {
                "source": "想い出",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェイターがやってきてプディングを下げていく。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと顔をめぐらせ、ダイニング・ルームの入口を見ると、ウェイトレスやウェイターたちを統率する役割の日系のおばさんが、ぼくのほうを見ていた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイニング・ルームのウェイトレスやウェイターたちの監督である日系のおばさんに、夕食のためのテーブルをひとつ、ぼくは予約した。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェイター、外の天気は」「最悪でございます。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
