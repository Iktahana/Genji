    "definitions": [
      {
        "index": 1,
        "gloss": "ridge (in field)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
