          ],
          "literary": [
            {
              "text": "更に、円タクの運転免許は、兵役をすましたものに限りこれを渡すといふ規定を当分実行すること。",
              "citation": {
                "source": "都市文化の危機",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島に住んでいる人で、無効になっていない運転免許証を持っている人であれば誰にでも資格があるのだそうだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに運転免許を取った」「自分の車なの？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸籍、住民登録、保険証、運転免許証、印鑑登録といったものです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は運転免許を取ったのよ」　夏子が言った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
