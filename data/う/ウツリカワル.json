    "definitions": [
      {
        "index": 1,
        "gloss": "to change (with time, the ages, the seasons, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夕なぎというのは昼間の海風から夜間の陸風に移り変わる中間に、一時無風の状態を経過する、その時をさして言うのである。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは室内のトランクが汽車の網棚のトランクに移り変わるような種類である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに目を通し始めるや、友人の顔に楽しげな笑みが浮かび、次第に強い興味と本意気を示す表情へと移り変わる。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが目まぐるしく移り変わるパターンの下には、時代を突き抜けてしまったような核がどっしりと腰を据えていたりする。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎劇は影薄く、新派劇ひとり驕って、わが劇界の覇権は前から後へ移り変わるかと見られた時に、あくる三十七年の二月には、かの日露戦争の幕が開かれた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "万物は皆すべて移り変わるものです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちつ、もたれつという「相対｜依存」の関係も、万物は移り変わるという「万物流転」の原理も、ことごとくみなこの「因縁」という母胎から生まれてくる真理であることは、すでに述べたとおりです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "院は移り変わることのすみやかな人生を寂しく思い続けておいでになって平生よりも深く身にしむ音をかき立てておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "鈴虫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならず、貧富・強弱の有様は天然の約束にあらず、人の勉と不勉とによりて移り変わるべきものにて、今日の愚人も明日は智者となるべく、昔年の富強も今世の貧弱となるべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また両岸の移り変わる光景を眺めた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然に感激と絶望との間を移り変わる黙示録的な調子で、重大な問題をこねまわしていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また回廊の影が移り変わる様子や、子供達が芝生で遊んでいるのを眺めていた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になると彼女の姿は初霜のように生き生きとなり、彼女の目は皺が寄っていて、そこには踊り子が作る微笑があったと思えば、手形割引業者の苦々しいしかめっ面に表情が移り変わるのだった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "走馬灯のように移り変わる、それがことごとくこの世のものではないところの、怪しくも美しい光景、私はその当時の見聞を、どのような言葉で形容すればよいのでしょう。",
              "citation": {
                "source": "鏡地獄",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災後の、万事に慌ただしい、猫の眼のようにうつりかわる気分に慣れた父兄は、わけもなく胡麻化された。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国の歴史がうつりかわるにつれて揚子江沿岸の軍閥が擡頭して、白人の事業を破滅に導き、それがやがて辛じて老父の屍を葬る二代目イーベンをせき立てて宜昌から遁走させる「偉大なスローガン」の怒号と高まって来るまで、作者は身についている揚子江航行の知識を十分に発揮して手堅く描いている。",
              "citation": {
                "source": "「揚子江」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史の激しくうつりかわる時期には、標語めいたものはどんどんうつり変り、表面からそれを追えばそこには矛盾も撞着も生じる。",
              "citation": {
                "source": "身についた可能の発見",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『プラウダ』が刻々にうつりかわるСССР全土の、世界プロレタリアート全体の問題について書いている。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、家の中におさまって磨き立てている趣味とは全く反対のもの、年から年へとうつりかわる自分たちの生活で家をつかんで持っているような、傍若無人さのような、精力的ながさつささえ感じられるのである。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、ときどき、それらのうつりかわる自然に対して、ぼんやりながめましたが、「ぐずぐずしていると、じきに日が暮れてしまう。",
              "citation": {
                "source": "ちょうと三つの石",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "茜さんは、眼を細めて、うつりかわる対岸の景色をながめたまま、いつまでもおし黙っている。",
              "citation": {
                "source": "キャラコさん",
                "author": "蘆と木笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山は天気予報、水は魚類の動静を見る外には、霞が浦が如何あろうと筑波がこうあろうと頓着もない万作が眼には何も見えぬが、お光の眼には、四季刻々うつりかわる景色が如何様に面白く珍らしく見えたであろう！",
              "citation": {
                "source": "漁師の娘",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
