        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「お母様の御息所はきわめて聡明な人だったのですが、私の若気のあやまちから浮き名を流させることになりました上、私は一生恨めしい者と思われることになったのですが、私は心苦しく思っているのでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは権田原心中の浮き名を流す機会を失って、おめおめと庄太に追い立てられて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紅い口びるを吸わして首席を占めたんだと、厳格で通っている米国人の老校長に、思いもよらぬ浮き名を負わせたのも彼女である。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがもとになって浮き名を立てることになり、私との関係をにがい経験だったように思って、くやしがったままで亡くなられたが、必ずしもそうではなかったのだ。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日までは尊貴な親の娘として尊敬されていた人が、つまらぬ男にだまされて浮き名を立て、ある者は死んだ親の名誉をそこなうという類の話は幾つもあるから、姫宮であっても女であれば同じことで、宿命などということはことにわからぬものだから、私が配偶者を選ばずに捨てておくことは不安だとも一方では考えられる。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "神聖な方としてお守り立てしていきたかった宮様も、世間の女並みに浮き名を立てられておしまいになることがもってのほかに思われてならなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は不断ごく慎ましくて、幸いに只の一度もそんな浮き名を立てられたことがなかったけれど、今度はけちがつくだろうと思って、慄然としました。",
              "citation": {
                "source": "麻酔剤",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が酒を飲まんことは、母上も知っておるはずじゃが、なぜ酒をくだされたろう」「何時も貴方がお堅くしておられますから、すこしは、浮うきなされるようにと、それで奥様からくだされたものでございましょう」　婢はこう云いながら盃を持ってそれを平三郎の前へだした。",
              "citation": {
                "source": "水面に浮んだ女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波のうえにうきながら、おねえさまたちは、かなしそうにうたいました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、にんげんが、ずつうでくるしむように、木にとっては、このかわのいたいのは、かなりこまるびょうきなのでした。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "母ちやんと、小ちやい子は、びようきなんだもの。",
              "citation": {
                "source": "乞食の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへかおを出したお妙ちゃんは、「マアマアほんまにようきなはった早う御上り、まってたのやから」こう云って私の手をひっぱった。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨みなはてぞ世の運命、無限の未來後にひき無限の過去を前に見て我いまこゝに惑ありはたいまこゝに望あり、笑、たのしみ、うきなやみ暗と光と織りなして歌ふ浮世の一ふしもいざ響かせむ暮の鐘、先だつ魂に、來ん魂にかくて思をかはしつゝ流一筋大川の泉と海とつなぐごと。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひこうきなかまは、ぼくのかおをみて、ぶじにかえってきたことをよろこんでくれた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、もうきなさる時分だよ。",
              "citation": {
                "source": "二番めの娘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケット小僧は、手さぐりで、それにつかまり、足をはなして、水にうきながら、井上君のからだに、だきつきました。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みどり色の手が、ぜんぶあらわれると、つぎには、むらさきとみどりと黄色の、ふといしまになった肩が見え、それから、れいのぶきみな大トカゲのからだが、水の中にフラフラうきながら、あらわれました。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、沢庵は三斎から蓮花を贈られて、うきなからあはれことしの花もみつ　これも蓮のいけるかひかな　と詠んだ。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
