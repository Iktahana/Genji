    "definitions": [
      {
        "index": 1,
        "gloss": "rumour (of a love affair)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
