        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども私はさっき、もうわるいことをしないと誓ったしこの猟師をころしたところで本当にかあいそうだ。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出来ましたかね」　私のおやじは、伜をカラカッて楽しむというわるい癖がある。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が、どうわるいというのでも無いのに、すっかり陰気に濁ってしまって、溜息と、意地悪い囁きだけが、エルシノアの城にも、またデンマークの国中にも満ち満ちているような気がします。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来は虚栄心の強い男でありながら、――いやそのためか、豹一は華やかな名とか社会的な地位を鼻の先にぶら下げている連中には、一応は「因縁をつけたがる」というわるい癖があった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人気だつてさうわるくはありません。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡いとは、どうわるいのぢや。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一とうわるかつたとおもふことを言つてごらんなさい。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、一とうわるかつたのは何でしたらう。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんながそれほどお気に召したら、めっぽうわるい段じゃごわすまいが、それにしても、あの女はだんなよりおおかた七、八つも年増じゃごわせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうわるいことばかりあるものではない……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、支度を」「僕は、からだが悪いので……」「どこが、どうわるい」「心臓やその他……機上で人事不省になるなんて、醜態ですからねえ」「なあに、心臓なんか、大丈夫だ。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となつてふりかへつてみれば、ただもうわるい夢を見つづけて來たやうなものだが、五年前のその日はるかに今日の日をのぞみみたときには、考へてみただけでもう精魂の盡きはてるおもひがするのであつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中島湘煙や福田英子の政治活動が、なるほど或る点では奇矯でもあったろうが、それもその時代の歴史の生きた姿であり男女同権の真実な要求としては評価されず、「女の風俗が大そうわるかった」時代としてばかり教え込まれ、当人たちもそう感じるような自分の教育を正しいものと思いこんでいる時代の空気。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藪の鶯」の女主人公である悧溌な浪子が、そういう歴史の脈動を評価する力を、反動期に入ったその新時代的教養からちっとも与えられていないで、至極皮相に「明治五六年頃には女の風俗が大そうわるくなって」と周囲から注ぎこまれ、おそわったとおりに片づけているところは強い関心をそそられる。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんとおばあさんは、いつも出がけに瓜子姫子に向かって、「この山の上には、あまんじゃくというわるものが住んでいる。",
              "citation": {
                "source": "瓜子姫子",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の風俗が大そうわるくなって。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗心地はさうわるくない。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかる　　うわる　　はやす　　くらすうまる　　くらむなどは、将然法と語尾との関係と見ることが出来る。",
              "citation": {
                "source": "日本品詞論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちは、そういうわるいことをしないようにしてくれ……めずらしい、うまいたべものをたくさん、われわれにくれ……」　水棲魚人からはこんなことしかきくことができなかった。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうわるいやつばかりでないだろう、君のようないい少年もいるのだから。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこが、どうわるいのです……？",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いお眼が、いっそうわるくならなければよいが――自分のことを、いったい何と考えていられるであろう？",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんないい方を、そんなに苦しめるなどと、何というわるい女でございましょう。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いっそうわるいのは、ああした打ちかたを余儀なくさせた君らの態度だ。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返して申しますが、この出来事のすべては私に対してただ不快としばしの腹だちとをいだかせただけですが、またいっそうわるい結果を生ずることもありえたのではないでしょうか？",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実際あのときは私もそうわるい意味で言ったんじゃありません。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "南瓜頭というわる口があるが、西瓜はまだまし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇評に於ても同様、不肖の私もさうであつたが、劇評上で彼のやうにさうほめられもしないが、さうわるくいはれない人も珍しかつた。",
              "citation": {
                "source": "中村梅玉論",
                "author": "大根か名優か",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじさんの仕事はうまくいっているのかい」「まあまあだね」　半助は眼で笑った、「うまくいってるっていうほどでもないが、まあそうわるいってこともないね、まあぼちぼちってところだね」　六ちゃんは「ふーん」と鼻で云った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ」「堀口というわるい奴が初めに僕の帽子を払いおとしたものですから、内藤君がおこって突きとばしたんです」「内藤さん、まあお見せなさい」　と奥様が立ってきて口のあたりをあらためた時、正三君の目から大つぶの涙がポロリポロリとこぼれた。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
