          ],
          "literary": [
            {
              "text": "四「おい、兎狩りに行こうか。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が前以て注意をしたんだ、――兎狩りにさえ出なけりゃ、こんなことになりゃしなかったんだ！",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国にいるとき兎狩りを二、三度したことがある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はこのへんでも熊狩りなどもやつたさうですが、この頃は主に兎狩りをするのだと云ひます。",
              "citation": {
                "source": "匈奴の森など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兎狩りでも思いつかれたかな」　そして、手をあげて、すこし離れた箇所を指さした。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "物見遊山と申してもそれは至って単純なもので、普通はお花見、汐干狩、神社仏閣詣で……そんな事は只今と大した相違もないでしょうが、ただ当時の男子にとりて何よりの娯楽は猪狩り兎狩り等の遊びでございました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
