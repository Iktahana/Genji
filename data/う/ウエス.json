        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何週間か前、ブレッシントンさんが私のところへやってきて、どうも見たところ、相当に動揺した状態で、彼の話では、ウエスト・エンド界隈で押し込みの窃盗があったというのです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九七七年二月、サンノゼで開かれたウエストコースト・コンピューター・フェアーをのぞいた体験が、その後の古川の進路を決定づけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫たちは、倉庫からグリスを取り出して、ウエスにつけてその手に握った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、一々塗ることが不可能であるために、二人のセーラーはワイアをグリスのついたウエスで握ってるという形になって現われるのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "大月は自分の椅子へ腰を下ろすと、さも満足そうにウエストミンスターに火を点けた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓はウエストミンスター教会にある。",
              "citation": {
                "source": "ポウの本質",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "双之介さん、つと立つて何か持つてきた、ウエストミンスターだ、一本いたゞいてブルの煙をくゆらす、乞食坊主と土耳其煙草とは調和しませんね。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……入雲洞さんから、敷島の百本入を一函頂戴した（双之介君からウエストミンスター、酒壺洞君からチエスターフイールドを貰つたのと共に漫談のいゝ材料だ）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九九（明治三十二）年、アメリカの電話企業、ウエスタンエレクトリック社が発起人となって設立された、第一号の外資合弁会社。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は口元が歪むほどの冷笑を湛えて、背後の書架から、ウォルター・ハート（ウエストミンスター寺院の僧）の「グスタフス・アドルフス」を取り出した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは今世紀の初め、ゲッチンゲンに起った出来事なんだが、オット・ブレーメルという、いかにもウエストファリア人らしい鋭感的な少年が、同地にあるドミニク僧団の附属学園に入学したのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かだ、ウエスト・エンド｜通りの雑踏が蜂のうなりのように聴えてくる都心｜紐育下町のなかにも、こうした閑寂地がある。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラゴウエスチエンスキイ寺院の暗い中に灯の幽に点つた石の廊下を踏んで、本堂の鉄の扉の間から遠い処の血の色で隈取られた様な壁画を透かして眺めた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其午後｜乗合自動車に乗つて東京の銀座と浅草とを一緒にした様に賑やかな、ピカデリイの大通りへ出て食事を済まし、ゼエムス公園を抜けてウエスト・ミンスタア寺を訪ひ、丁度日曜の勤行に参り合せたのを初めに、今｜此筆を執る日まで丸｜八日経つ間に倫敦の御寺と博物館と名所とを一通り見物して仕舞つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は窓の外にウエストミンスターの塔の見える広い部屋で、カクストンという部長の訊問を受けた。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラゴウエスチエンスキイ寺院の暗い中に灯の幽に點つた石の廊下を踏んで、本堂の鐵の扉の間から遠い處の血の色で隈取られた樣な壁畫を透かして眺めた。",
              "citation": {
                "source": "巴里まで",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、昔はよく女学生が電報――例の黄色いウエスタアン・ユニオン鐘組織の紙片――を手にして、校庭の隅でしょげ返っていたりすると、同室の仲間なんかが訊いたものだ。",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夏同宿には窪田空穂氏や、茨木猪之吉氏も居られ、又丁度穂高登山に来られたウエストン夫妻も居られた。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ウエストンから彼女の事を妹さんか、夫人かと問われた。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時ウエストンから彼女の事を妹さんか、夫人かと問はれた。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは石と西とで區別される川を意味する名稱です」「はあ、ピエール・ド・リビエール（川の石）と、ウエスト・ド・リビエール（川の西）ですか」　とマダムは速解する。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三インチのウエストが二十五インチにおなりになったのは、牛乳と卵を召上りすぎたせいなんだわ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　いえ、望月さんは、永久に二十三インチのウエストだというわけ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諏訪子　いえ、望月さんのウエストが。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マネキン　望月さんのウエストは、一体、意志があって。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "感情でもいいわ、つまり、そのウエストの寸法に、考えたり感じたりする場所があって。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "望月さんのウエストは決して勝手すぎやしないでしょう。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエストには、ございませんよ。",
              "citation": {
                "source": "鋏と布と型",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノースウエスト航空会社のＤＣ四型という四発機。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
