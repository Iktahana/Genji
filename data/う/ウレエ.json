        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "憂えも怒りも心の戦いもやみて、暴風一過、かれが胸には一片の秋雲凝って動かず。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな危険に陥った場合でも、彼はただ、今自分のしている仕事（妖怪を退治するなり、三蔵法師を救い出すなり）の成否を憂えるだけで、自分の生命のことなどは、てんで考えの中に浮かんでこないのである。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に知られざることを憂えぬ蘇武を前にして、彼はひそかに冷汗の出る思いであった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは伯父自身がいう如く、国事を憂えて、というよりも、単に、そのロマンティシズムにエグゾティシズムにそそられたためといった方がいいのではないかと、高等学校時代の三造は考えていた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の作物の時局性の薄いことを憂えて取って付けた様な国策的色彩を施すのも少々｜可笑しい。",
              "citation": {
                "source": "章魚木の下で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "願文は武井入道｜夕菴に命じて作らしめたと伝うるもので、「現今の世相混沌たるを憂えて自ら天下を平定しようと考えて居ます処、義元横暴にして来り侵して居ます。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信綱は徒らに兵を損ずるを憂えて、諸軍に令して、各々占拠の地に陣を取り、夜明けを待つことを命じた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう社会に住んでいれば、怠け者でない限り、狡い者で無い限り、王者を敬うものである限り、終生生活の不安も無く職を失う憂えも無く生きられるのだが、などと彼は考えた。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれ、魂を迎うべく、天使｜来る矣、と憂えたのである。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "李朝三代目の王、太宗は一四〇三年、朝鮮に書物が少ないことを憂えて、数百万個の銅活字の鋳造を数か月で一挙に行わせたといいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい人の憂えてる顔はかわいそうでたまらないものである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は衣食の闕乏を憂えない。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じように、余所目には痩せて血色の悪い秀麿が、自己の力を知覚していて、脳髄が医者の謂う無動作性｜萎縮に陥いらねば好いがと憂えている。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は胸に秘密を蓄え、弟は憂えばかりを抱いているので、とかく受け応えが出来ずに、話は水が砂に沁み込むようにとぎれてしまう。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂えれば血圧は低くなる。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂悒の義の「いぶせし」は気噴狭しの意で、憂える者の気噴が伸びやかでない様の実際に副っている。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "器量小さく才知乏しい者は、思い取って、味わい知ることの出来ない事を、憂えるが善いのである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「名も知られず、世に追われても、思い悩むことなく、是とされなくとも悶うることなく、道の行われる世には、出て楽しんで之を行い、道の行われない世では、憂え避けて之を行わない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に名を成すこと無く、世と交渉無く孤立して、或いは時に発現すれども是とされない、だが思い悩むこと無く、我が心楽しければ則ち之を行い、我が心憂えれば則ち之を行わず、確固として揺るがないことは、真に優れた人格を備えずには出来ない事である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また何を憂えること有ろうか、人各々自ら守るところを尊ぶのみ、守るものあれば何で慍ることがあろうかと。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の状態は実にこのようであり、我を知る者が稀である時我は貴い、どうして憂えることがあろう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さては病馬かと言うと、掌馬人かの馬決して病まずと答え、厩へ往きて馬に対い、汝は瓦師方にありて碌に食料をくれず骨と皮ばかりに痩せて困苦労働したるに、今国王第一の御馬に昇進しながら何を憂えて物を食わぬかと問うた。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にも『書紀』二五、大化改新の際朝廷に鐘を懸け、匱を設け、憂え諫むる人をして表を匱に納れしめ、それでも聴き採られざる時は憂訴の人、鐘を撞くべしと詔あり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "シワの妻｜烏摩后、子なきを憂え、千人の梵士を供養してヴィシュヌに祈り、美妙の男子を生み諸神来賀した。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼からは今まであったものが失われて、見たところ貧しくはなるけれども、その為めには彼は憂えないのみか、却って欣喜し雀躍する。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去を追わず、未来を憂えず、その日の仕事を、一所懸命にやったまでじゃ」　草履とりは草履とり、足軽は足軽、侍大将は侍大将、それぞれその「分」に安んじて、その分をりっぱに生かすことによって、とうとう一介の草履とりだった藤吉郎は、天下の太閤秀吉とまでなったのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "クルベーの厚い情愛で、長い病褥中行きとどいた看護と金目を惜しまない手当を受けながら、数年前に死んで行った老母が「そんなことをしてよく殺されもしないものだ」と言って、彼女の成行きを憂えたくらい、彼女は際どい離れ業をして来たのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの子供たちが、一年東京に働いた後に健康を害する率の多いことは、既に一般から重大な関心をもって視られているし、工場や雇われ先での明け暮れに稚い若い心の糧の欠乏していることの害悪も、やはり人々を憂えさせている事実である。",
              "citation": {
                "source": "国民学校への過程",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私の才気と、アムビションと、贅沢とを憂えられた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "指痛（腫物にて）をうれえしきこれが薬法をたずねしに、某の木と某の草とを調合して服用すべしと教えたり。",
              "citation": {
                "source": "甲州郡内妖怪事件取り調べ報告",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
