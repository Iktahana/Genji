        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "フラフラと立ち上って、足許定まらず壁に凭れて項垂れる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと強く抱いて、と息をつめて哀願するところもよかったし、あたしは、だめだわと言って、がくりと項垂れるところなど、実に乙女の感じが出ていました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　錦子が、はずかしがって項垂れると、頸から背中の生毛が金色に覗かれた。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "椰子の葉は勝利の章、中空高く、梢の敷桁となつて、光明の中に搖動きつつ廣がり、しかも其自由の重みに項垂れる。",
              "citation": {
                "source": "椰子の樹",
                "author": "ポオル・クロオデル　Paul Claudel",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸や悲惨の前に無力に首をうなだれる吉田ではなかった。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何故とも知らぬ哀愁を感じてうなだれる。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待（うなだれる）（農民等　黙然）農民二（ややあって）「いま、もぐり歯医者でも懲役になるもの、人｜欺して、こったなごとしてそれで通るづ筈なぃがべじゃ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこいらを見まわしながら眼を白黒さしていたが、やがてグッタリとうなだれると床の上にペタリと坐り込んだ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはならぬと、あわてて膝を固くして、うなだれると、意気地が無いと言って叱られる。",
              "citation": {
                "source": "一燈",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　相手の激しさに、新子はいよいようなだれるばかりであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山裾はどこも急な崖で　岸辺もなく海へと突き入る、　海は落ちも着かずに高波なして　雷火の空にうねっている、　湖も終わりなく広げている　その何もない水面を――無に死に――　その動きない水面を――静に冷に　うなだれる純白の百合を一面に。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではもう、それではもう……」　じり、じり、と、なにものかに押しつけられでもしたかのようにうなだれると、お秋ははらはらと、そのひざへしずくをはうりおとしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きな、大きな門……」彼は低く低くうなだれるように応えた。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "おききなさい、今も今とて　ふくろふの笛は足ずりをしてあをいけむりのなかにうなだれるお前のからだをとほくへ　とほくへと追ひのける。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わずゾッとしながら自分の罪の姿の前にうなだれる事になる……こんな事が度重なるうちに、とうとう遣り切れなくなって、この秘密室をタタキ破って、人の前にサラケ出す。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その肩は落ち、腰は砕けて、よろよろとよろめいて室の隅にたおれかかって、斜にずるずると半分ばかり傾いて、頭をがっくりとうなだれると、支那産の絨毯の上に手と足を投げ出したまま、森閑と動かなくなった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから如何にも面目無い恰好でグッタリとうなだれる拍子に、思わずヨロヨロとよろめいて横の壁にドシンと背中を寄せかけると、あとからＴ刑事がツカツカと近寄って来て、チョットお辞儀をするように私の顔を覗き込んだ。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、無能の標本みたように、火鉢のふちに曝し物にされている自分自身を顧みて、力なくうなだれるばかりであった。",
              "citation": {
                "source": "老巡査",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シッカリ閉じた両眼から涙をハラハラと流してうなだれると、前よりも一層固く口を閉じてしまった。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をアングリと開けて棒立ちになっていたが、やがてクシャクシャ頭をガックリとうなだれると、涙をポトポトと落しながら口籠もった。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ、どういう風にしていっしょになったかとか、新吉の月々の収入はどの位だとか、立入った質問を受けると、おときは顔をあかくしてうなだれる外に活路を見出せなかった。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼は萎れる花のようにうなだれる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、女の前ではどんなに気を張ってもうなだれる自分の心をいかにもはかないものに思った。",
              "citation": {
                "source": "お女郎蜘蛛",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だめです」　キシさんがうなだれると、チヨ子はまた泣きだしました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "志岐　　（うなだれる）部隊長　　（調子を変へ、ゆつくり）志岐、わしはなあ、かうしてお前の顔を見てゐると、ちよつと腑に落ちんところがあるんぢや。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗拾いの子供らが、分け行く山路の草には、もう水霜が降りて竜胆の葉がうなだれる。",
              "citation": {
                "source": "木の葉山女魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "みると、こんどはその街道をやはり板橋のほうへ向かって、一匹の牝山羊をつれた女が、こう、すこし首をうなだれるようにして歩いてゆく。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸一分、一寸二分、一寸三分とうなだれる。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜口　（腕組みをして深くうなだれる）一郎は死んだか。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は、もう直ツたんですもの……だが、お姫様の病気がよくなツたらあなたは御前の方へいらツしやらないもの、どうしてもあやしいわ」と三ツ輪の頭をうなだれる。",
              "citation": {
                "source": "五大堂",
                "author": "田澤稲舟",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
