        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それはわたしへ死のように悠久な憩いを与え、底知れずあたゝかく甘い眠りを誘うふだんのわたしから見ればちょろ／＼して、ぴんと弾ねて、ころ／＼笑ってばかりいる何とも目まぐるたくて手に終えない倶楽部の娘が、一たん胸を据えてわたしを受け止めるとき、またどうしてこんなに深味も厚みもある女になるのであろう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の問題を択び分け受け止める綱である。",
              "citation": {
                "source": "文芸評論の方法について",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は団子の様に固まって……」　父は据えきった眼をギロッギロッと人々の上に流して行ったが、突然、恰も空から落ちかかる何物かを受け止める様に、両手を高々と翳して、一語一語に永い尾を引かせて叫けんだ。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁科は焦つてムキになつて画論をふりかざしてくるのであるが、谷村はまともに受け止めることがない。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "下まで落ちて来る間に手拍子を丁と一つ打って、その手で受け止めると、右の手で水返しのあたりを掴んで、十文字を外輪にして、自分の身体を心棒に、独楽のようにブン廻しをはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うことによって、私は辛うじて自分を受け止める。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台は再び明るくなり、白のクイーンの肩掛けがアリスの方に飛んできて、アリスはそれを受け止める。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず初めに「ありゃビルだ」の大がっしょう、それからひとりウサギの声、「受け止めるでおじゃる、生けがきのそばぞ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず初めに聞こえたのが「ありゃビルだ」の大がっしょう、それからひとりウサギの声――「受け止めるでおじゃる、生けがきのそばぞ！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはブレイクの日記を額面通りに受け止める傾向があり、疑いなく真正な教会の古い埋葬記録や、非正統的で反感を買っていた星の智慧教派が一八七七年まで確実に存在したこと、エドウィン・Ｍ・リリブリッジ(*3)という名の詮索好きな記者が一八九三年に失踪した記録といった幾つかの事実に重きを置きたがっている。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけわかりやくするためか、排水管の出口で、手で水を受け止めるような真似をした。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌はそれを両手で受け止めると、綴じ込みの片端が眼に入って、涙が出たほどなのに、きちんと両脚をそろえて、手を帽子にあげたまま礼をいうじゃないか。",
              "citation": {
                "source": "鉄道事故",
                "author": "DAS EISENBAHNUNGLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉お玉は三味線の撥で客の投げた銭を受ける、米友はいま持っていた竿、竿の先の五色の網の袋で客の投げた銭を受け止めるのが商売で、それを「網受け」と申します。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の偏屈な市民ほど、静かに驚くものだし、冷静な態度で英雄行為を受け止めるものだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "大魔王ミノスはそれを両刃の斧でしっかりと受け止める。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "より強い陣痛が始まると女性は半分２つ折れの姿勢をとって木の盥を下に置いて子供を受け止める。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "情事とはお互いがお互いの中に快楽を認めあうことだろう、与えることと受け止めることのよろこびではないか。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうときに、啓三の受け止める感受性はみごとなものだ。",
              "citation": {
                "source": "ばちあたり",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わば突然目をさましたようなものだったが、ジャン・ヴァルジャンは危急になれており、意外の打撃をも瞬間に受け止めるように鍛えられていたので、直ちに冷静に返ることができた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかには、幻を作る力があれば、現実を受け止める力もある。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法則を知っているからこそ、私はどんな理不尽をも、ありのまま穏やかな心で受け止める。",
              "citation": {
                "source": "朝に想い、夜に省みる",
                "author": "MORNING AND EVENING THOUGHTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつい内容になりますが、あなたは男らしくそれを受け止めると信じていますよ。",
              "citation": {
                "source": "親友たち",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士は巻煙草の広告のやうに婦人連は百貨店の衣裳の宣伝ビラをうけとめるように至極悠長な受け渡しだ。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、俺は斯う見えても満洲に渡つて大喧嘩をした時には、ピストルを放されたが、笑ひながらビール壜でその弾丸をうけとめると一処に敵手の頭を張り擲つて悶絶させてやつたが、あの時は実に痛快だつた、あんな喧嘩ならば毎日でも欲しい！",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、日本の現実には安定をもとめている多くの人々の感情をおだやかにうけとめることのできるような社会的条件が生れていません。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "存八は逃げるばかりが能ではなくなり、いくらかは身をかわすことも、太刀をうけとめることもできるようになっている。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性的なやわらかさであったが、彼はそれをマトモにうけとめることが出来なかった。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをマトモにうけとめるには必死の努力がいるのであった。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八という年齢が、それをうけとめるだけスレていなかったのである。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はいつも、自分の全部のものを投げだして訴えていたのだが、それをうけとめるに足る男がいなかったのだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
