          ],
          "literary": [
            {
              "text": "坂田はんをこんな落目にさせたのは、もとはといえば皆わてからやと、かえって同情してくれて、そしていろいろあった挙句、わてかてもとをただせばうどん屋の娘やねん。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、同じやるなら、今まで東京になかった目新しい商売をやって儲けようと、きつねうどん専門のうどん屋を始めることになった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京のけつねうどんは不味うてたべられへん、大阪のほんまのけつねうどんをたべさしたるねんと、坂田は言い、照枝も両親が猪飼野でうどん屋をしていたから、随分乗気になった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生街なら、たいして老舗がついていなくても繁昌するだろうと、あちこち学生街を歩きまわった結果、一高が移転したあとすっかりはやらなくなって、永い間売りに出ていた本郷森川町の飯屋の権利を買って、うどん屋を開業した。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎はうどん屋の出前持ちであったが、兄の商売の秘法を教えられ、生玉町に一戸を構えて、口金商を始めた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎と二人で借りていた玉造のうどん屋の二階をひき払って、一泊二十銭の千日前の安宿に移った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うどん屋の二階に居れば、階下の商売が商売故、たまには親子丼、ならいゝが酒もとる。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、銭湯の帰り、うどん屋でラムネ一杯のまず、存外律儀者であった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "半月ほど後に、私は河堀口の米屋の二階から今里のうどん屋の二階へ移りました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはトキワ会が近くて絵を借りに行くのが便利だったのと、階下がうどん屋だから、自炊の世話がいらなかったからです。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのうどん屋では酒も出すので、寒い夜道を疲れて帰った時などつい飲みたくなる。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "南座の横のうどん屋へはいって、鯡うどんを食べた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店へ二回、うどん屋へ二回はいり、そこら辺当もなく、逍遙い歩いている内にだんだん夜が更けて来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "野には明るい日が照り、秋草が咲き、里川が静かに流れ、角のうどん屋では、かみさんがせっせとうどんを伸していた。",
              "citation": {
                "source": "『田舎教師』について",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草屋、うどん屋、医師の大きな玄関、塀の上にそびえている形のおもしろい松、吹井が清い水をふいている豪家の前を向こうに出ると、草の生えた溝があって、白いペンキのはげた門に、羽生分署という札がかかっている。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "村のうどん屋が朝から非常に賑はつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから同志の二三人と一緒に外へ出、同志たちは近くのうどん屋でうどんをごちそうしたのであるが、そこへ腰をおろすと彼女ははじめてふところから手ぬぐひを取り出し目をおほひ、聲を立てずにさめざめと泣いたといふ。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もううどん屋なんぞも起きちやをらんやらうし、熊吉、なんか食ふものはないかなあ。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は眼についたうどん屋へ入つて行つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、縫物をしてゐるところへ、Ｆさん来訪、新聞経営の話いろ／＼（彼は小さい郷土新聞を一人でやつてゐる）、誘はれてうどん屋で御馳走になる、酒二本しつぽく二杯、Ｆさんには気の毒だつたけれど、私はうれしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には「うどん屋」という落語がある。",
              "citation": {
                "source": "「うどんくい」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯屋の看板に『一浴心広体胖』、大盛うどん屋の立額に『はたらかざる人はくふべからず』。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "うどん屋の出前持になつて居るとも言はれたし、新町の或る芸妓屋の箱屋になつて居るとも言はれたし、また無頼漢の仲間に入つて居るとも噂された。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして獲たものであるか誰にも話さなかつたが、彼は間もなくそれを資本に停車場前にうどん屋を始めた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋並の低い徳島の町も、寒くなるにつれて、うどん屋のだしを取る匂いが濃くなって、町を流れる川の水がうっすらと湯気を吐くようになった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うどん屋の天幕の裾から、小雪まじりの冷い風が吹きぬけて来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広場を囲んで、露店のうどん屋が鳥のように並んで、仲士達が立ったまま、つるつるとうどんを啜っていた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋並の低い徳島の町も、寒くなるにつれ、うどん屋のだしを取る匂いが濃くなって、町を流れる川の水がうっすらと湯気を吐くようになった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ヶ月分の金があずけてあって、夕方になると私はそのうどん屋の細長い茶向台で御飯をたべた。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夕方、私は御飯をたべてこのうどん屋から出かけると、ちょうど遅く学校から帰って来ていた校長に逢った。",
              "citation": {
                "source": "私の先生",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
