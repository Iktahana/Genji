    "definitions": [
      {
        "index": 1,
        "gloss": "to create",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この事実はトーキー製作者の利用のしかたによっては、いろいろの可能性を生み出すであろう。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その世界では「作り出す」「生み出す」ということだけが意義があり、それが唯一の生きて行く道であるように見えた。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、以上の空想はまた次の空想を生み出す。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう考察を進めて行けば、その結果は、ニュース映画の将来の発展に対して、少なくもなんらかの指針となるべき暗示を生み出すであろうと想像される。",
              "citation": {
                "source": "ニュース映画と新聞記事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう理屈はいっさい抜きにして、あの陶工の両手の間で死んだ土塊が真に生き物のように生長して行く光景を見ている瞬間には、どうしても人間のものを生み出す創作能力の尊さを賛美しないわけには行かないのであった。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学はやはり不思議を殺すものでなくて、不思議を生み出すものである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社のニュースの種取り競争が生み出す喜悲劇はこれにはとどまらない。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「能はそうした表現を生み出すために存在しているのだね」と。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを、詩人が一本の万年筆と一束の紙片から傑作を作りあげ、画家が絵の具とカンバスで神品を生み出すのと比べるとかなりな相違があるのを見のがすことはできない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は結局エイゼンシュテインが視覚的｜陪音と呼び、あるいはむしろ視覚的｜結合音と呼ばるべきものを生み出すにあるのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちはこの友人の死に値いするだけのりっぱな芸術を生み出すことを誓う。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧き生から新しき生を生み出すときには、必ず苦悩があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚕が桑を食べて充分にそれらを自分のものとしてから徐にすずしい絹糸を生み出すやうなものである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎の子が飛んでもない悲劇を生み出すことになったが、それでも其の秘密は世間に洩れなかったと見えて、友蔵の小屋は相変らず繁昌していると、ここにまた一つの事件が起った。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "司馬遷個人としては、父の遺嘱による感激が学殖・観察眼・筆力の充実を伴ってようやく渾然たるものを生み出すべく醗酵しかけてきていた。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーが地上に残したモノスゴイ薬品のにおいに対して、乱歩氏が生み出すオドロオドロしい黒砂糖の風味が存在している事を、生れて初めて教えられたのでした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそうした諸般の演出物は、或は芸術的の迷妄に陥り、又は民衆に媚びて堕落し、又は儀礼的に高踏し過ぎて、芸術的の迷妄や行き詰りに陥りつつも、何かしらより高尚な、より充実した……或るタマラナイ表現慾を満足させ得べき芸術……すなわち能を生み出すべく、生みの悩みを続けていたものらしい。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十八歳の老齢で、九四歩などといふ天馬の如き溌剌とした若々しい奇手を生み出す坂田の青春に、私はぴしやりと鞭打たれたやうな気がし、坂田のこの態度を自分の未来に擬したく思ひながら、その新聞を見ることが、日日｜愉みとなつたのである。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十八歳の老齢で、九四歩などといふ天馬の如き溌剌とした若々しい奇手を生み出す坂田の青春に、私はぴしやりと鞭打たれたやうな気がし、坂田のこの態度を自分の未来に擬したく思ひながら、その新聞を見ることが、日日愉みとなつたのである。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現実とは、人の頭の生み出す何物よりも、限りなく奇妙なものなのだ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように恐怖を生み出すもととなった秘密結社のことについて、知れば知るほど恐怖は薄まるどころか、むしろ深まっていく。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "中味を書いた人に見返りを与えることは、文化の動力を生み出すエンジンにガソリンを補充することです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど電子本の技術を活用すれば、私たちが生み出すありとあらゆる文章を、〈本〉にしてしまうことが可能です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎惡も嫉妬もない其處に故意と惡評を生み出す程百姓は邪心を有つて居なかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然科学で大発明をするとか、哲学や芸術で大きい思想、大きい作品を生み出すとか云ふ境地に立つたら、自分も現在に満足したのではあるまいか。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれつきの体質にも因るがこれ等は気を洩らす方が多くて、生み出すのが間に合はないからで、渇しては飲み渇しては飲みして、辛くも支えているのなどは随分困ったものだ。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "めづらしい事件とか、不思議な事件とか、さうした題材を選んで見たところで、作者の内部が本当に新しい感動――全心全体の新しいスタイルを生み出すやうな緊張を持つてゐなければ、徒らに好奇の名を博するばかりに留つて了ふ。",
              "citation": {
                "source": "批評的精神を難ず",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐれた作を生み出す努力も結構だが、細かに部分々々について研究し、感じ、描き出すことも大切である。",
              "citation": {
                "source": "私の考へてゐる事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽の生み出す慈愛の光を、地面は胸を張り広げて吸い込んでいる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしてそれがしずまると、風の生み出す音の高い不思議な沈黙がまた天と地とにみなぎり満ちる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
