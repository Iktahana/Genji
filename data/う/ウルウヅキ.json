        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "毎六年目に閏月が一つあてはさまることにしたので一年は平均するとやはり三六五日ということになったのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故と云ふに、里恵の書には単に「閏月廿五日」としてあるが、天保四年癸巳には閏月は無く、閏月のあるは只三年壬辰の十一月のみだからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野氏に寄せた書は「閏月十日」の日附があつて、広江夫妻に寄するものに先つこと十五日である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "時日に關し、干支閏月等の記入には不都合はない。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "且毎年の日數同樣なるゆゑ、一年と定めて約條したる事は丁度一年の日數にて閏月の爲に一箇月の損徳あることなし。",
              "citation": {
                "source": "改暦辨",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此差凡二年｜半餘にして一月｜計なるゆゑ、其時に至り閏月を置き十三ヶ月を一年となし、地球の進で本の處に行付を待なり。",
              "citation": {
                "source": "改暦辨",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "閏月は即ちこの三十文の引負を一月にまとめて拂ふことゝ知るべし。",
              "citation": {
                "source": "改暦辨",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元來囘教徒の普通に使用する囘暦は純太陰暦で、大（三十日）小（二十九日）の月各六、併せて十二月を一年として閏月を置かずに、ただ約三年目毎に一日の閏日を置くのである。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を約三年毎に閏月を置く支那の太陰暦に比すると、三年毎に約一月、百年毎に約三年の相違を生ずる譯である。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生んだお君は、間違ひもなく、嫁入りしてから丸九ヶ月以上も經つた兒、その間に閏が一と月もあつたので、世間では八カ月兒だとか何んとか言ひましたが、お君は少し早産ではあつても、伊勢屋忠右衞門の子に間違ひはありません」「――」「一體、腹の中の兒は閏月などを勘定に入れるでせうか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "血塗られた祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに閏月のごときもシナの暦では当年ですけれど、チベット暦は昨年であったです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年目、四年目に閏月のある事は同じであるけれども、こういう具合に一年｜後先になって居るばかりでない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのはわたしは前から閏土の名前を聞き及んでいるし、年頃もわたしとおつかつだし、閏月生れで五行の土が欠けているから閏土と名づけたわけも知っていた。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し遲れた櫻が、三月になつても蕾がふくらみかけただけ、閏月を控へて、お祭騷ぎの好きな江戸つ兒達は、花を待つのがもどかしさうでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "眞珠太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
