[
  {
    "uuid": "cd476ce7-9557-5f01-bd0e-c92e8c8dcbb6",
    "entry": "打ち水",
    "reading": {
      "primary": "うちみず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
