    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sprinkling water (to keep down dust, cool pavements, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この石の中ほどにたしか少しくぼんだところがあって、それによく雨水や打ち水がたまって空の光を照り返していたような記憶がある。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夕方には、きまって打ち水のあまりがこの石燈籠の笠に注ぎかけられた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "短刀と十手がたがいに空を打って、二、三度入れ違ったときに、藤四郎の雪駄は店先の打ち水にすべって、踏みこらえる間もなしに小膝を突いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは息をのんで瞰下していると、捕手の同心が打ち水にすべって危うく倒れかかったので、お駒は思わず自分の草履を取って、一方の相手の顔に叩きつけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "享保三年板｜西沢一風作『乱脛三本鑓』六に、小鼓打ち水島小八郎、恩人に頼まれた留守中その妻を犯さんとして遂げず、丹波の猪野日村に旧知鷹安鷲太郎を尋ねる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝足らない眼に沁みる朝の空気は無数の針を含んでいるようで、店の前の打ち水も白い氷になっていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い釘店の往来は場所｜柄だけに門並みきれいに掃除されて、打ち水をした上を、気のきいた風体の男女が忙しそうに往き来していた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が物をいうなら考えてからいうがいい」　そういって倉地は言葉の激昂している割合に、また見かけのいかにも威丈高な割合に、充分の余裕を見せて、空うそぶくように打ち水をした庭のほうを見ながら団扇をつかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八文字にひらかれた門から大玄関まで、打ち水さえもが打ってあって、血の嵐、争闘、殺陣は元よりのこと、騒ぎらしい騒ぎがあったらしい跡もなく、不気味なほどに静まり返っているのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い前庭に敷いた石に、しっとりと打ち水がしてあって、濡れた石のいろが、かえってわびしかった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすい灯のいろが、ゆうべのように川岸の夕ぐれの中に滲んで、客もないのか、打ち水に濡れた石のいろが、格別にきょうはわびしかった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都にいた間、また、九州に来てから別府、臼杵などにいた間、塵をしずめる打ち水となる程度の降雨に会っただけで、ために予定を変えるような目には遭わなかった。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち水に濡れている暗い裏街をぬけて行く間も、彼はただ食い物を追うだけの自分を感じた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "下を見るとここにも、靴まで濡れそうな打ち水がしてあった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、打ち水してある石の上を、植込みの竹の横を、くぐりから、内玄関へ廻った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの井戸は、半分は家の中に半分は外にはみ出て、内外いずれからも使用できるようになっているので、打ち水の時などさぞ便利だろうと思われたが、奇妙なことには、部厚い板で蓋がされ、おまけに大きな釘で開かないように釘付けにされていた。",
              "citation": {
                "source": "幽霊",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸へつゞいてゐる通りはアスフアルトの上に打ち水がしてあつて海から吹いてくる風がそのまゝ街の灯にぬれながら凉しく通つてゆきました。",
              "citation": {
                "source": "影絵師",
                "author": "櫻間中庸",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、これ、そう悶えてはかえって病に負けるから、我慢していなさい』『アア痛、……』」　打ち水をした庭で、ときどき地虫の鳴くのをよそに、いよいよ圓朝は噺をすすめた。",
              "citation": {
                "source": "圓朝花火",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "小せんは、あれからじき患いこんで、翌る四月の末に死んだが、最後を秋の夜に聴いたゆえか、自分は小せんの死というと、あの若竹の秋の夜が、あの若竹の打ち水濡れし前栽が、目に泛ぶ、さらに山の手の寄席の夜らしい耶蘇の太鼓が耳につく……。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に見えるところだけでも、路地には、紙屑一つ散らばっていないようになり、どぶ板には、いつも箒の目に打ち水――以前の、大掃除のあとのようなとんがり長屋の景色からみると、まるで隔世の感がある。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵前の大通りには、家々の前にほこりおさえの打ち水がにおって、瑠璃色に澄み渡った空高く、旅鳥のむれがゆるい輪を画いている。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち水、蚊やり……と世間さまは暑熱と闘うに忙しいのだが、この長庵の宅と来たら、これはまた恐ろしく涼しい限りで、家具と名のつくものは愚か、医者の道具らしい物も何一つもなく、まことにサッパリと夏向きである。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間には打ち水をして、菊の香が清々しい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "小鰭の鮨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこ此処に打ち水の爽やかな気配がし、店にはちらほらと灯もはひつて、宵の鋪道は彼には住み馴れた東京の魅力であつた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の店さきなどに打ち水がされている牛込のせまい通りを、白地に秋草の染めだされた真岡の単衣を着て、板じめちりめんの赤い帯をしめ、白足袋をはいた伸子が歩いていた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店先に打ち水の空手桶をさげてぼんやり立っているのは女中一人。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、邸はいつもの通り穏かなもので、下男の久助が打ち水をしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の桟に、ほこりもとどめず、庭には涼しく打ち水をして、三度の食前には、しずかにお茶をたしなんでいた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち水した書斎の縁先に、仄かな室内の灯が流れている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
