        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "頑丈な木造りの二三の椅子と卓子とが蹲る侏儒のやうにあるべからぬ所に散らばつてゐた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……で、頭を下げて赤熊は橋の上に蹲る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、さすがの少年が目に暗涙を湛えて、膝下に、うつぎの花に埋もれて蹲る清い膚と、美しい黒髪とが、わななくのを見た。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "農家の娘の寝室の軒の下に蹲る頬冠りの男には、ひいて来た猛犬を襲いかゝらした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）阿闍梨『これ待て、一同』（源右衛門、法師等、そこへ蹲る。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洋装美人の女賊○○署の手に捕わる」　彼女はベッドの上に蹲るようにして、恐怖に衝き揺られながら、驚きの眼を※ってその記事を読んだ。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（財布と一所に懐中に捻じ込みたる頭巾に包み、腰に下げ、改って蹲る）はッ、静御前様。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜が板の間の中央に蹲ると後ろの幔幕の際に居た男が金烏帽子をかぶせた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に蹲るのがライオン岩、深巌とした赭黒である。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風鈴草、色つぽい音の鈴、春ここにちりりんと鳴る、榛の樹が作る筋違骨の下に蹲る色よい少女。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやどうも、ジツに恐ろしい結末ですなァ……」　すると、まだ「トントン」の屍骸の前へ蹲るようにして、頻りにその柔かな両足の裏をひねくり廻していた博士が、不意に顔をあげた。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、少女も元の場所へ帰って蹲る。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏口へ來て向うを望むと、曇つた空の下に低く蹲る山の木々は、針葉樹と濶葉樹が半々で、濶葉樹は白つぽい葉の裏を見せながら絶えず小さくざわざわと搖めいてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、宛然蹲る大獣のように物凄い黒色が仄明るい空を画ると、漸々その極度の暗黒を破って、生みたての卵黄のように、円らかにも美くしい月が現われるのでございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうよかろう」「うんよかろう」　二人の蹲る気勢がした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるがんはこの悪魔が、或は塔の九輪の上に手を拍つて踊り、或は四つ足門の屋根の下に日の光を恐れて蹲る恐しい姿を度々見た。",
              "citation": {
                "source": "悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤屋氏のピエル・フォンは、道了と猿山の森を分つ鋸型の谿谷に従って径を見出し、登ること三里、ヤグラ嶽の麓に蹲る針葉樹の密林に囲まれた山峡の龍巻と称ばるる、五十戸から成る小部落で、幽邃な鬼涙沼のほとりに封建の夢を遺している。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校に通う子供三人が、円陣を作って遊んでいると、猫はその真中にはいって蹲る。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして室の別々の隅に蹲る。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "由兵衛が「何だ」と云ふと「お楽み」といひて蹲る処は受けたり。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝説の豊富な点で、文学的にも興味があるが、文学は文学として置いて、辺鄙な漁村の、炉辺に蹲る老婆などの口から、奇怪な物語を聞かされる面白味は、また格別である。",
              "citation": {
                "source": "ブルタアニュの伝説より",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（さう云ひながら、火鉢のそばに蹲る）一寿　　ねえ、おい、今の境遇ぢや、さうさうは困るよ。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "千曲川の水は黄緑の色に濁つて、声も無く流れて遠い海の方へ――其岸に蹲るやうな低い楊柳の枯々となつた光景――あゝ、依然として旧の通りな山河の眺望は、一層丑松の目を傷ましめた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のいわゆる「蹲る」ことに対してさんざん毒づいた後に、彼は小ジェリーを連れて銀行へ御出勤になり、大小二匹の猿のように銀行の前に陣取る。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蹲る）女優Ａ′　　当り前ぢやないか。",
              "citation": {
                "source": "職業（教訓劇）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一歩前に出かけて、そのままそこに蹲る）倉子　　（この間やや激しくピアノを鳴らす）水垣　　駄目だ。",
              "citation": {
                "source": "傀儡の夢（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々｜磴の上に蹲る。",
              "citation": {
                "source": "チチアンの死",
                "author": "ホーフマンスタール　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉り餌をやると、自分たち同類の鳥が巣を作る、至極あつらえ向きの捏土だと思いこんで、ただ本能的にその上に蹲る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の障子をあけると、私は母の枕頭に蹲る黒い影を認めた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "10810　　　　はやえ（蹲る。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
