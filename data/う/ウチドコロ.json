[
  {
    "uuid": "da26fe86-4fef-59b6-8a72-cf7a7cef2380",
    "entry": "打ち所",
    "reading": {
      "primary": "うちどころ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
