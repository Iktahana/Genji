[
  {
    "uuid": "0f6ff665-3c04-5161-b5e8-82afe7a29c46",
    "entry": "鬱積",
    "reading": {
      "primary": "うっせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
