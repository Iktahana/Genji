    "definitions": [
      {
        "index": 1,
        "gloss": "floating island (mass of floating aquatic plants)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "落葉が水上で朽ちて小さな浮島のように処々にかたまっていた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水神の社地を浮島といひて、洪水にも浸さるゝことなき由をもて名あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "島は、浮島、八十島。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青疊徒らに廣くして、大卓は、浮島の體である。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君聞かずや、むかし彌次郎と喜多八が、さもしい旅に、今くひし蕎麥は富士ほど山盛にすこし心も浮島がはら。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで主人の云ったのは、それは浮島禅師、また桃園居士などと呼ばれる、三島沼津を掛けた高持の隠居で。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、内々で、浮島をかなで読むお爺さん――浮島爺さんという渾名のあることも、また主人が附加えた。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに辷って行く灯を眼で追っていると、小さな浮島の陰に隠れてしまった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、浮島の反対側の端から姿を現わすだろう、そうしたら、宿に帰えろう、とぼくは決めた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、漁火の速度で浮島の大きさを割る計算を始めた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "田野には低く夕靄が匍って離れ離れの森を浮島のように漂わした。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手に家の在る女学校時代の友達から、卒業と共に比較的智識階級の男と次ぎ次ぎに縁組みして行く知らせを受けて、鈴子は下町の而も、辺鄙な深川の材木堀の間に浮島のように存在する自分の家を呪った。",
              "citation": {
                "source": "晩春",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶杓が膿んだ襤褸の浮島に刺さって居た。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いでや浮島のヱネチアに往かん、わたつみの配てふヱネチアに往かん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩※峠などを含む由比蒲原あたりの裏の山脈は富士川の西岸で盡き東の岸からは浮島が原の平野となつてずつと遠く箱根山脈の麓まで及んで居る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "駿河灣一帶の風光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二年の後には、黒い地帯を全くの浮島にして了った。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い浮島は、それと同時に、最早完全な水田ではなかった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水田には水田が続き湿地が続いて、温い水を保つためには相互扶助的な作用がなければならないのに、黒い浮島は例えば丘の上の耕地のようなものであった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　翌年の春になると、白い木製の箱樋が、赭土の窪地を乗越えて黒い浮島に渡された。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今ではその用水堰を必要とする土地と言えば、あの黒い浮島だけだった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮島を漕ぎ離れても行く方やいづくとまりと知らずもあるかな行くさきも見えぬ波路に船出して風に任する身こそ浮きたれ　初めのは兵部の作で、あとのは姫君の歌である。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮島に風光を賞し、潮來出島にあやめを看、鹿島、香取、息栖の三祠に詣で、大利根川の下流に浮んで銚子に下る船中、富士迎へ、筑波送る。",
              "citation": {
                "source": "常磐の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞ヶ浦、信田の浮島、手に取る如く見ゆ』と。",
              "citation": {
                "source": "北總の十六島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに今の東海道の通じてゐる辺は昔は現在の浮島村附近の如く一帯に深い沼沢地であつて道路など造れなかつたものであらう。",
              "citation": {
                "source": "沼津千本松原",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは右に出した漢文と殆ど同意義で首里に在す王が浮島を築港して唐南蛮の船舶の寄合う那覇港となした、という意である。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その昔、首里人が那覇を見おろして浮島と呼んだのも無理はない。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが直ぐに、意味あり気に解釈しようとするのは惨めなわけだ、と気づいて「ずつと向方に見ゆる島は、浮島といふんださうだ、三｜哩しかないといふ話だ。",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」浮島11・６（夕）　洪水といふものは、色々な珍しい事を人間に教へて呉れるもので、ずつと往昔は江戸の両国川には鯰といふものは一｜尾も棲むでゐなかつたのを、いつの年か大水が出て、それから後は鯰があの川で捕れるやうになつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、三島郡の三宅村鶴野といふところに不思議な浮島があるといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、しよりおわるてだこが　うきしまはげらへて　たう　なばんよりやうなはとまり　ぐすくおわるてだこが　〔十三―八〕というオモロを見出すであろう。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
