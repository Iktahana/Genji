        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すなわち遠からざる将来において、船には蒸気機関のような重い場ふさげなものは入らなくなり、ナイアガラ辺で起した強大な電力を無線電信で洋上の船に送り、軽少な器械で巨船を動かすような事になるだろう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも身動きも出来ないやうな重病人にとつて、かうした性慾の発作が何にならうぞ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シェークスピアとかドストエフスキーとかイブセンとかいう人々は、人間生死の境といったような重大な環境の中に人間をほうり込んで、試験檻の中のモルモットのごとくそれを観察した。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしているうちに、初めには予期しなかったような重大な結果にぶつかる機会も決して少なくはない。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女の人などが、すつかり上氣せ上つて、頬を眞赤にして、眼までうるませてゐるのを見たりすると、籠り切つたやうな重苦しい春の重壓が私の精神をまで襲つて來る。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――淺草邊へ病人の見舞に、朝のうち出かけた家内が、四時頃、うすぼんやりして、唯今と歸つた、見舞に持つて出た、病人の好きさうな重詰ものと、いけ花が、そのまゝすわつた前かけの傍にある。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟に沁む山風に吹き醒まされて、少しく正気に復って見ると、自分の白い手は人か山※か判らぬような重太郎に掴まれていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が注いて見ると、自分の手は獣のような重太郎に握られていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十五）　獣のような重太郎と相対しているお葉は、頗る危険の位置にあると云わねばならぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、あのような重い太鼓をかつがせ、その上、男どもは、だいぶ女連にやられていたようで、気の毒に思っている。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図の上では細い筆の軸にも隠れて了ふ程の二つの村にもさうした相違のあるといふ事は、若い准訓導の心に、何か知ら大きい責任のやうな重みを加へた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度女達は咽喉をつめられて声の出せないような重苦しい状態の下に長くは我慢して居なかった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の暗雲のような重圧にも拘わらず、外には依然陽が輝き青空には白雲が美しく流れ樹々には小鳥が囀っていることを、彼は十年この方始めて発見したように思った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の底空の果てから聞こえて来るような重々しい響きが腹にこたえて、昼間読んだ悲惨な小説や、隣の「青葉しげれる桜井の」やらが、今さらに胸をかき乱す。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってこのような重大な現象を無感覚に観過させないまでもそれを直視させるのをしいて避けるのもどんなものであろうか。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬二郎の心臓は裂けるほど激しく、湯のような重い熱を伴って弾みだした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のやうな重い、しつかりした跫音が、わたしの耳に聞えた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の一生のうちに、その人の一切の事情を、一撃の下に転倒させるような重大な事件があり、社会においては、全社会を聳動せしめるような大事件がある。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓石の前で欷歔してゐた間のその悲しみも、あの突然の死を耳にした時のやうな鉛のやうな重苦しいものではなく、むしろ明るい快感を伴つたものであつたことを百合子は繰返した。",
              "citation": {
                "source": "百合子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざぶり‥‥ざぶり‥‥寒気のために比重の高くなった海の水は、凍りかかった油のような重さで、物すごいインド藍の底のほうに、雲間を漏れる日光で鈍く光る配縄の餌をのみ込んで行く。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の写真屋を初めるというのも、一人の女に職業を与えるためというよりは、救世の大本願を抱く大聖が辻説法の道場を建てると同じような重大な意味があった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　村川は、引きずられるような重くるしい心持で電話口に出た。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚堂禅師の筆は、石のような重みをもって客人達の上に落ちかかって来た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言葉の調子は低かったが、石のような重みと、石のような冷さとをもって、甚斎のひしがれた心の上に落ちかかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔細が無くて、只無暗にこのような重宝なものを悪魔だと定めるわけはあるまい。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間のように見もせぬ夢を見たろう等と尋ねたり、又はこのような重宝なものを俺から奪い取って、罪も無い鸚鵡を殺そうとしたり、又は大勢の者が生命を棄てて拾い上げてくれたこの貴い鏡を打ち壊そうとする。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董品のやうな重味を持つた立派やかな太鼓で、胴には朱色の房が結ばれ、皮には金泥に漆黒の巴印の紋章が浮んでゐた。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの問屋場の役人たちも三島の宿とおなじような重忠揃いなら仔細はないが、万一そのなかに岩永がまじっていて野暮にむずかしい詮議をされたら、あべこべにこっちが大恥をかゝなければならない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、同じような重病患者の寄りあい世帯のような索敵戦隊に何が望めるというのだろう。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　隱岐は、大した六つかし氣な知識でも吹聽するかのやうな重々しい口調で、世にも愚かなことを呟きながら、水のやうな空に浮いてゐる凧を見あげて、何といふこともなしに太い吐息を衝いた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
