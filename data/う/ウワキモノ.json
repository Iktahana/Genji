        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「藤さんは浮気者だから、ここの家へ来るなんて旨いことを云って、どっかへしけ込んでいるんじゃありませんかえ」と、お新は笑っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "無暗に食い散らしをするような浮気者じゃあるめえね」「それがどうも判りませんの」と、お登久は妬ましそうに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ふと下を向いて、丁度そこへ運ばれて来たしるこをすすったが、やがて急に顔を上げると、「――そんな浮気者とは知らなんだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルは浮気者だったので、（斯ういう時に「けれども」という接続詞を使いたがるのは温帯人の論理に過ぎない）又、大の嫉妬家でもあった。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今隣へはいりかけたんだよ」「浮気者！",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、其蝶がいつも仲裁役をつとめているうちに、根が浮気者のお葉ですから、そんな折檻にも懲りないで、其蝶に色目を使うようになって来たんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮気者」と、豊は反り返って手をうった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにも男が恋しいものかね」「浮気者にゃあ判らねえことさ」「知らないよ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "みーさん以上の浮気者があるかって？",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ところが、この法師が浮気者であったとみえ、近頃は同じ遊女仲間の一人に、心をうつして、しげしげ通っているという噂が、お兼の耳に伝わって来た。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴郎、どうしたんですよ、このごろは」「だッてしかたがない、忙しいからナア」「ちゃんと種は上がってるよ、そんなこと言ったッて」「種があるなら上げるさ」「憎らしい、ほんとうに浮気者！",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貞淑無類、珍しいほどで」「いやいや拙者の考えでは、浮気者の大莫連。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうしてね、まだ私の事を浮気者だなンぞッて」「ほんとにそんな事も云たそうですがね、なにも、そんなに腹がたつなら、此所の家に居ないが宜じゃ有りませんか。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのお猿さん、相当の浮気者だわ……」「さうかね……」「あら、さうかねつて、貴方は、何時でも女にはよそよそしくしてゐて、女をちやんと掴んでしまふンだから……」「別に、あのお猿さんを掴んぢやゐないぜ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡は、昔、ゆき子に、君はどうせ練馬大根の産地で生れたのだらうと、毒舌を吐いた事があつたが、締りのない寝顔が、浮気者らしく見えた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、軍右衛門の女房は浮気者であったらしく、別腹の弟九郎右衛門といい仲に成ってしまった。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、某から頼みたいこともあり、とにかく、庄吉の身の上は、益満がしかと引受けるから、黙って、化粧でもして――さ、気を浮立たせて、久し振りに三日月さまかや、ちらと見た細身の刀は、主かいな小唄｜吟みで、辻斬りの前髪若衆の、色袴　富士春、お前のように浮気者にも操があるように、庄吉にも、真心があるぞ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は軽薄で、嘘つきで、浮気者で、信用のない兵六玉よ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の口の端に浮気者よと蔑みを受け、恐らくたのむ男にもやがて捨てられてしまふであらう文子。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくやがて浮気者よと文子を蔑むであらうところの人々に、左門はすでに沸々とたぎる忿怒を覚えずにゐられなかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時ならぬ時に、神楽師の一行が、つれづれな温泉宿に舞い込んだという噂を聞いて、浮気者の後家婆さんはいたく喜んで、早速、明朝になったら、ひとつやらせて楽しみましょう……と、お湯の中でお雪に話しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは路地を右へ曲ったり、左へ折れたり、ひや合いを抜けたり、軒の下をくぐったり、足の向くまま歩いて行く中、一度通った処へまた出たものと見えて、「あら、浮気者。",
              "citation": {
                "source": "寺じまの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江は新に好きな男ができると忽ち熱くなって忽ち冷めてしまうという、生れついての浮気者なので、翌日も夕方近くまでいちゃついていたが、離れるのがいやさにカッフェーもそれなり休んで、井の頭公園の旅館に行き次の夜は丸子園に明して三日の後、市ヶ谷の貸間まで一緒に来てやっとわかれた。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "（浮気者らしかったお浦、俺のことなど忘れてしまったのかも知れない）　時が経って行った。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄りで醜婦で惨忍で、そうして綺麗な男さえ見れば、ベタベタして後ばかり追っかける、好色で度のない浮気者でもある。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、セリョージャ、あたしの言うことをお聞き」と、カテリーナ・リヴォーヴナは、暫くしてまた言いだした、「お前さんのことというと、みんなきまって浮気者だというのは、一体どうしたわけなんだろうね？",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
