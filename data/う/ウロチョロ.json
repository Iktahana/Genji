        "examples": {
          "standard": [
            {
              "text": "あの男がうろちょろしているのが不安だ。",
              "source": "幻辞"
            },
            {
              "text": "裏口でうろちょろする人たちを見かけた。",
              "source": "幻辞"
            },
            {
              "text": "うろちょろするのはやめなさい。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "８ビットのベーシック・マシンから触りだして、この野外本がでたころにはパーソナルコンピューターが飯の種にならないかと、オレ自身うろちょろしていた時期だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして　うろちょろ　しはじめましたが、　とぼとぼ　――　とぼとぼ　――　ゆっくりと　あるいて　きょろきょろ。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "また　あるひは　ちいさな　おばあさんが　みずたまもようの　あかい　ケープを　はおって　うろちょろしておりました。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリスは目を開けると、何が何だか分からないというふうに、あたりをうろちょろする。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ら自身に似た人々が大道をうろちょろしているだけでした。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえも、うろちょろ、ダイマク（つける）のはよせ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
