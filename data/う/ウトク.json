        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それはとにかく、この老人はこの煙管と灰吹のおかげで、ついぞ家族を殴打したこともなく、また他の器物を打毀すこともなく温厚篤実な有徳の紳士として生涯を終ったようである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の公卿方の者で、それは学問諸芸を堺の有徳の町人の間に日頃教えていた者だったということが知られた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も不二の観望第一なる有徳の間の朝夕は我をして感懐禁ぜざらしむ。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の名音は、最初｜泉の某と云う庵にいて有徳の住持に事えていた。",
              "citation": {
                "source": "法華僧の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷章は南のそうするのは賤しい身分の者にも隔てをおかない有徳な人となりの致すところだと思って酷く感激した。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周公は成王に教えて、殷の中宗・高宗・祖甲と周の文王とが、民人に臨んだ用意と実行を説明して云う、「この四王は皆｜有徳有道の君主であった。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる有徳の人の後にこんな奇態な皇后が出来、あろう事か妖巫といわゆるお姿夫婦（『傾城難波土産』四の二）の語らいから帝室の威厳を損ずる大騒ぎを起したは何たる事ぞ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗房より二つばかり年上であった大阪生れの西鶴は、通称を平山藤五と云い、有徳な町人であった。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすでに傷ついたところの不幸な魂に深い慰安を与えるような有徳の君子になりたいのですけれど。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい誰が取らないでただ與へるばかりであり得るほど有徳或ひはむしろ有力であり得るであらうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆にいつたい誰が與へないでただ取るばかりであり得るほど有力或ひはむしろ有徳であり得るであらうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、首府よ、お前は無謀な乱暴者の希望は伸すくせに、臆病な有徳の士の希望を断つのか！",
              "citation": {
                "source": "氷花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今西村に兵右衛門と云へる有徳なる百姓ありけるが、かの家にめし使ふ女、みめかたち人にすぐれ、心ざまもやさしかりければ、主の兵右衛門おりおり忍びかよひける。",
              "citation": {
                "source": "案頭の書",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘇東坡は茶の清浄｜無垢な力について、真に有徳の君子のごとく汚すことができないと書いている。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "病身なる父母は健康なる児を生まず、不徳の家には有徳なる子女を見ず。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち天子親しく大學にのぞみ、天下の有徳の老人を選んで三老・五更となし、三老を父に擬し、五更を兄に擬し、之に對して子弟の禮を執るべく、萬人環視の中に、天子の尊を屈して、親しく酒を勸め魚を侑める。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗有徳」（『書經』無逸篇疏及び『漢書』孝景本紀元年詔）とある如く、天子の中でも、特に功徳高き方に限つて有すべきもので、普通の天子は廟號をもたぬ。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "而古者祖有功宗有徳之義微乎（『資治通鑑』唐紀十五、貞觀二十三年の條）。",
              "citation": {
                "source": "支那の孝道殊に法律上より觀たる支那の孝道",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい誰が取らないでただ与えるばかりであり得るほど有徳或いはむしろ有力であり得るであろうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆にいったい誰が与えないでただ取るばかりであり得るほど有力或いはむしろ有徳であり得るであろうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "有徳の人も、働かない場合、ただ可能的に徳があるといわれるのであって、現実的に徳があるとはいわれないのである。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のような有徳の君子は貧乏だし、彼らのような愚劣な輩は、人を苦しめるために金銭を使っているし、困った世の中だなあ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり芸妓は有徳な人だからああ云う贅沢ができる、いくら学問があっても徳の無い人間、人に好かれない人間というものは、ニッケルの時計ぐらい持って我慢しているよりほか仕方がないという結論に落ちて来る。",
              "citation": {
                "source": "道楽と職業",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯爵を除いてはこの小説の総ての人物は皆有徳の人物で、また異常な美徳さへもつてゐます。",
              "citation": {
                "source": "精神のへど",
                "author": "――手帳より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が言ふには、私は狸ですが、誤つて有徳の学者をなぶり、お書きなさいました文字の重さに帰る道が歩けない、文字を落して下さいませといふのであつた。",
              "citation": {
                "source": "日本の山と文学",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗旨は眞言宗で、住職の法印は可なり有徳の老僧でありました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤つて有徳の沙門を嬲り、お書きなさいました文字の重さに、帰る道が歩けませぬ。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはこれ、有徳院様お代替りの延享四年十月十五日のことでございました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈鎮和尚といい妙香院の僧正といい何れも名門の出であり、一代の有徳であり、その一代の行業は伝うべきもの甚だ多いが是等の大徳が帰敬し崇敬した法然の器量が思いやられる。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉大で有徳な人になることは、心あるものに与えられる最高の名誉のように見えたし、ものの本にたくさん出てくるように、下劣で悪徳にみちていることは、いちばん下等な堕落、つまり盲のもぐらや毒にも薬にもならない蛆虫にも劣る卑しい状態のようにおもわれた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
