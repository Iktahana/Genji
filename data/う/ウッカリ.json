    "definitions": [
      {
        "index": 1,
        "gloss": "carelessly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            },
            {
              "text": "うっかり約束を忘れてしまった。",
              "source": "幻辞"
            },
            {
              "text": "スマートフォンをうっかり落とした。",
              "source": "幻辞"
            },
            {
              "text": "うっかり秘密を他人に話してしまった。",
              "source": "幻辞"
            },
            {
              "text": "仕事をうっかり間違えた。",
              "source": "幻辞"
            },
            {
              "text": "帰り道をうっかり間違えた。",
              "source": "幻辞"
            },
            {
              "text": "ドアをうっかり閉め忘れた。",
              "source": "幻辞"
            },
            {
              "text": "電車で荷物をうっかり置き忘れた。",
              "source": "幻辞"
            },
            {
              "text": "メールをうっかり違う人に送ってしまった。",
              "source": "幻辞"
            },
            {
              "text": "うっかりテスト日程を見落とした。",
              "source": "幻辞"
            },
            {
              "text": "食べ物をうっかり腐らせてしまった。",
              "source": "幻辞"
            },
            {
              "text": "大事な書類をうっかり破いた。",
              "source": "幻辞"
            },
            {
              "text": "誕生日をうっかり祝い忘れた。",
              "source": "幻辞"
            },
            {
              "text": "約束の時刻をうっかり間違えて覚えた。",
              "source": "幻辞"
            },
            {
              "text": "薬をうっかり二重に飲んだ。",
              "source": "幻辞"
            },
            {
              "text": "大声でうっかり他人の秘密をばらした。",
              "source": "幻辞"
            },
            {
              "text": "うっかり信号を見落とした。",
              "source": "幻辞"
            },
            {
              "text": "レシートをうっかり捨ててしまった。",
              "source": "幻辞"
            },
            {
              "text": "うっかり友人に怪我をさせてしまった。",
              "source": "幻辞"
            },
            {
              "text": "宿題をうっかり忘れて学校に行った。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "うっかりしている間に学年試験が目の前に来ていたり、借金の返済期限がさし迫っていたりする。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い、逞ましい喬木でも、心が朽ちているから、うっかり捉ると枝が折れて、コイワカガミや、ミヤマカタバミの草の褥へ俯ったりする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に喬木の森林に入った、白く光る朽木は、悪草の臭いや、饐えたような地衣の匂いの中に立ち腐れになっている、うっかり手が触れると、海鼠の肌のような滑らかで、悚然とさせる、毒蚋が、人々の肩から上を、空気のように離れずにめぐっている、誰も螫されない人はない、大樺池を直ぐ眼の下に見て、ひた下りに下る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "石は人の手入れを経ない、全くの自然石で、不思議にも中はおのずと、コ字形に刳ぐられていて、濶さは一坪半ぐらいはあろう、四人ぐらいは潜れそうであるが、うっかり立てば頭を打ちつけるほどに低い。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雪田もズッと裾の方へ行くと、雪の穹門から水が滾々と湧き出ていて、洞内に高山植物などが美しく咲いている、但し夏日うっかり奥まで深く這入ると、雪がくずれて圧倒する危険がないとも限らぬ。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だものだから、ついうっかり、奴さんの云う事を飲み込もうとした。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり「地震による碑石の廻転について」といったような論文の材料にでもして故事付けの数式をこね廻しでもすると、あとでとんだ恥をかくところであった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が他の一人に、うっかり商売気を出して仲間にまで色眼はお使いでないよと頬を打つ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では海水浴場の岩角にこの烏貝が群っていて、うっかり踏付けて足の裏を切らないよう用心しなければならない。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は〔ひ〕るすぎうっかりしてこうしの柵をあけて置いたもんですから大将早速親牛のところへ行って半分ばかり呑んでしまひましてね……」その人はわらひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのをうっかりフロイドにでも聞かせると、とんでもないことになるかもしれないという気もするのである。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は雑巾がけをしてからうっかり忘れてしまって、蓆を入れずに野へ出た処、間がわるくその日雨が降ったから、その蓆十枚ばかりを濡らしてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし全体の合成的効果が灰色であるという事は、それを分光器で分析した時に色彩の現れないという事にはならないと同様に、日本画部に傑作がないという事はうっかり云われない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを考えると、うっかりマスクを人にすすめることも出来ない。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしていました。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が減ると饑えは充分感じるのだが、うっかり喰べる気はしなかった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不味いものを食うくらいならいっそ、くたばった方がいい」　これは、美味のないとき、膳の上の食品を罵倒する敬蔵の云い草だが、ひょっとすると、それが辛辣な事実で父娘の身の上の現実ともなりかねない今日この頃では、敬蔵もうっかり自分の言葉癖は出しにくかった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり打ちあけられるものではない……。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居裏の二枚看板、ちゃちなぽん引にうっかりつれこまれようとして、あわてて羽織｜芸妓の裾のもとをかいくぐって、食傷路地に出てくると、鶴源の板前が瑪瑙色に塗った魚類の食楽地獄だ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うっかり途中でやめさしたら、どっちつかずの生れ半着で、これまで折角銭を入れたんが何んにもなるまい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "末梢的と言ってもうっかり見過ごせない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして下車する時にうっかり間違えて鋏を入れないのを二、三枚交ぜて切って渡したらしい。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとも知らず次に乗車した時にうっかり切符を渡すとこれは鋏が入っていますよと注意されてはなはだきまりの悪い思いをしたそうである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしていると、今に世界の方々の隅から秋風が来る。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誘惑にはうっかり乗れない。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯉はかれの両袖にかかえられて、おとなしく運び去られるのを、女房は唯うっかりと眺めていると、女は帰るときにお徳に云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり逆らったらどんな祟りを受けたかも知れない」　禁断の魚を捕るということがすでに逃がれがたい罪である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい声で近所の人を呼んで、なんとか又、工夫のしようもあるんだが、なにをいうにも場所が悪い、うっかり大きな声を出してみろ、こっちの身の上にもかかわることだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり油断はできねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、おい、そんな詰まらないことをうっかり云わない方がいいぜ」と、半七は制した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
