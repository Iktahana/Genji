[
  {
    "uuid": "edd3ce5c-218b-5f73-9b45-4ac05bac32e1",
    "entry": "海千山千",
    "reading": {
      "primary": "うみせんやません",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
