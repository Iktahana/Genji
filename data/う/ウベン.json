          ],
          "literary": [
            {
              "text": "車の羽弁が五色に塗ってある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今それらを列挙すると、『続後拾遺集』、『殷富門院大輔集』、『樗散集』、『道因法師集』、『寂然法師集』、『鎌倉大納言家五十番詩歌合』、『北院御室御集』、『伊勢大輔集』、『出羽弁集』、『康資王母集』、『四条宮主殿集』で、これらの多くは伝奏たる広橋家を通じての武家からの注文であった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうべん小僧――ここでいうマネケンである。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の非常な人気者で、四、五年まえ或る老婦人は遺産一千｜法をそっくりしょうべん小僧の維持費に寄附して死んだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔も洗わないで、私は木の香のぷんと匂うべんとうを食べる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じょうべんがじたい」　「小便だなよしよし。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じょうべんがじたい」「小便だなよしよし。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君、君なんかには絶対に関係ないことだ」　伯爵は、口ごもりながら、そうべんかいして、玉太郎をぐっとにらみつけた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しょうべんたれの、うんこたれなの。",
              "citation": {
                "source": "戦争はぼくをおとなにした",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえら、それで生きているのか、性があるのか」「な、なんですか、一向にどうも……」「ざまア見ろ、そんなすッ恍けたことを言ってやがるから、しょうべん組などに出しぬかれるのだ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "ねずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山へ仕事に行とってしょうべんしとうなったら、どんな遠うても、わが家の畑までしにいく人じゃもん」　わあとみんなが笑った。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつのばあいも、腹話術というべんりなものが、人間わざではできないような、ふしぎを、つくりだしたわけだね。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、中川駅まで同車して、大阪行に乗り換えた海潮音氏は、降りる間際まで「しょうべん、忘れては、あきまへんぞ、しょうべんを」といいつつ降りた。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの旧句に、せうべんの先を曲げるよ春の風　というのがある、これを旅先から色紙にでも書いて送ってよこせという御註文なのだ。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ、ほんまに、しょうべんをしよった」と名古屋の海潮音氏が、紙面の海潮音の欄で毒筆をふるわないうち、先にこっちで書いておく。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
