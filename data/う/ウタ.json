        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "例へば夏休みも近づかうといふ暑い日に、唱歌教室で先生が、オルガン弾いてアーエーイーすると俺としたことが、笑ひ出さずにやゐられなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別、先生の口唇が、鼻腔が可笑しいといふのぢやない、起立して、先生の後から歌ふ生徒等が可笑しいといふのでもない、それどころか、俺は大体、此の世に笑ふべきものがあらうとは思つちやゐなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はもはや歌はうとも叫ばうとも描かうとも説明しようとも致しません！",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお恵みが下ります時には、やさしくうつくしい夜の歌と櫂歌とをうたはうと思つてをります……（一九二九・一二・一二）",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "……２恋人よ、その哀しげな歌をやめてよ、おまへの魂がいらいらするので、そんな歌をうたひだすのだ。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまへはわがままに親しい人だと歌つてきかせる。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経的、或は潔癖精神的に幻想のげにも脆い臍の緒を掴へることによつて、心境の一断想を歌ふばかりである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と聞くたびに、海を見るたびに、この歌を思ひ出すから、以下私は此の詩を辿り乍ら、「海の詩」といふ課題を果さう。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああかくてもこの故郷に育ちて父母のめぐみ戀しやと歌ふなり。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨新短歌は、既に新しい様式として存在してゐるか？",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その成績を今問はないこととするならば、新短歌は、どうやら詩歌の新しい様式として、既に存在してゐるやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが短歌より出て来たものだとしても、既に短歌と訣別して、新しい領土に立つてゐることも恐らく間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新短歌が、短歌から出て来たものと考ふべきか、全然別個に発生したものと考ふべきかは甚だ疑問であるけれども、短歌にもはや発展の余地がないと思つた人々によつて工夫されたものであることは慥かである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "では短歌に発展の余地が残されてゐないといふことは事実であらうか？",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく現に生存してゐる歌人諸氏が、最後的のものであらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてかういふことは、判然と示証することは出来ないけれども、短歌を作りたいといふことが、今後とも人々に全的な希望、全的な仕事として考へられることはあり得ないやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々此の短歌なるものは、生活の傍に生じた芸術といふ感じの強いものであつて、短歌が、一人の人間の全生命となるといふ風のものではなかつた。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何も人々が短歌に不熱心であつたといふやうなことではなく、短歌様式そのものが本来さうしたものであるやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "では新短歌が短歌に交代するものであらうか？",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、するどき薄刃をさげ、左手をもつて敵手に揖す、はや東雲あくる楢の林に、小鳥うたうたひ、きよらにわれの血はながれ、ましろき朝餉をうみなむとす。",
              "citation": {
                "source": "決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "めざめよ、み空の金鑛、かなしくうたうたひ、なみだたれ、われなほ土地を掘らんとす。",
              "citation": {
                "source": "鑛夫の歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああこのばうばうたる白日の野邊を訪ねて行つてもむかしの失はれた幸福に出逢ひはしない。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の意志や感情やを、真によく対手に呑み込んでもらうためには、対手が自分の親友｜知己であり、自分の心持ちや性格やを、充分によく知っているものでない限り百万言を費して無駄になる場合が多い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時ヘルンから万葉集の歌を質問され、答えることができなかったので、泣いてその無学を詫び、良人に不実の罪の許しを乞うた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
