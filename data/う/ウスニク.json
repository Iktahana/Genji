        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "闇の庭は電燭の光りに、小さな築山や池のおも影を薄肉彫刻のように浮出させ、その表を僅な霰が縦に掠めて落ちている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う岸の橋詰に榕樹の茂みが青々として、それから白い尖塔が抽んでている背景が、橋を薄肉彫のように浮き出さすためであろうか。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのハレーションに薄肉色のもあるし、黄薔薇色のもある。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいてみると、その白い表面に薄肉彫りに彫ったかのように、巨大な猫の姿が見えた。",
              "citation": {
                "source": "黒猫",
                "author": "THE BLACK CAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "同氏の出品は薄肉の額で、同氏得意のもので、世評も大したものであったらしく、私が見ても牙彫界恐らくこの人の右に出るものはなかろうと思いました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "石川光明氏と心安くなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は博覧会の薄肉の額を見た時から、すっかり敬服しているんだ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "石川光明氏と心安くなったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄肉とか半肉とかで、此所はこうと一ヶ所｜極まり処を教えると、一を聞いて十を知るという方で、その次に同様の趣の処はちゃんと前例によって旨くやってある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "谷中時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄肉で横二尺以上、縦四尺以上でなかなかよく出来ました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "谷中時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車は、濃い鼠色をした、やはり木造の一階建の家の前に停ったが、その家の窓の上には白い薄肉彫がほどこしてあり、窓の前には、長の高い木の四つ目垣をめぐらした、小さな植込があって、その四つ目垣のなかの細い樹々は、しょっちゅう町の埃をかぶるので、真白になっていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔は八菱形の四方の凹所に仏像が篏入され、また凸出した側面毎に薄肉彫刻の仏像が仰がれる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に薄肉がうまく、石川先生は絵の心得があるから煙管の筒など彫ると非常に名人で、自分など到底及ばないと言った。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物は兆殿司の羅漢の粉本をやるのであるが、他の画家の羅漢は余り彫刻にならないが兆殿司のはそのまま薄肉になるのは、恐らく余程立体的なのであろう。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概なさかなは、この腹の薄肉というのが美味いものである。",
              "citation": {
                "source": "西園寺公の食道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスを送るゴム管は軟かい薄肉のものでないと、取扱いに不便である。",
              "citation": {
                "source": "実験室の記憶",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "透き通るやうな青白い額、白粉つ氣も何にも無いのですが、仕樣ことなしにニツと苦笑すると、引きしまつた薄肉色の唇の曲線が、少しばかり上弦に緩んで、非凡の媚が湧くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女御用聞き",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無理もないよ南条、武士たるものが、許嫁の女を横取りされて、指を銜えて見て居るという法は無い、たとい相手は主君だろうが、殿様だろうが――」　というのは、堤軍次という浪人者、三十二、三の妙に人摺れのした薄肉の細面に、相手をいら立たせずに措かないと言った、皮肉な微笑を浮べて、左馬之助を仰ぐのでした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄肉で、蒼白くて、榮養はよくありませんが、その清らかさは、全く非凡でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蔵の中の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白の華奢な方で、身体も手足も細く、薄肉で眼鼻の無暗に大きいところや、顎のあたりが歪んでいる様子は、肉体的にも性格的にも、畸形な感じを抱かせるに充分です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "色白の華奢の方で、身體も手足も細く、薄肉で眼鼻の無暗に大きいところや、顎のあたりが歪んでゐる樣子は、肉體的にも性格的にも、畸型な感じを抱かせるに充分です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "戀患ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな午後の横町の下宿の室でかすかにパンジーの花束がにおう炉棚の下にたたずみ、伸子はあれからこれへと心の小道をたどりながら、半ば無意識に、そこの小テーブルの上に立ててあるモツァルトの薄肉浮彫の飾りメダルを手にとった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーン名物の薄肉浮彫の金色の面に、こころもち猫背で、というより鳩胸のような肩つきで、円い形のかつらをつけたモツァルトの横顔が浮き出ている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八日には建築士会の中條精一郎君記念事業会から、父の肖像（薄肉彫・ブロンズ直径三尺近いもの北村四海氏作）をおくられました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハワイからかえった人が今の主人で、薄肉色のソフトなんかかぶって、麦かりをしているお爺さんです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙と消えた一代の作彫刻の名人石川光明翁の災厄　明治彫刻界の泰斗石川光明翁、牙彫にかけては当時随一、木彫も立派な腕前、特に薄肉を得意として数々の大作を遺した。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉は秀才がた、鼻骨はたかく、唇もとのしまりよく、愛嬌のこぼるるようなところがあり、面、肩の肉、背丈など、一体に薄肉のたちである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
