    "definitions": [
      {
        "index": 1,
        "gloss": "athletic meet (esp. at a school)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "運動会の風景葉山嘉樹-------------------------------------------------------【テキスト中に現れる記号について】：入力者注　主に外字の説明や、傍点の位置の指定（例）増産競技であった。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月三日の明治節の国民運動会の日である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は稲扱きの小閑を盗んで村民運動会である。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会の終了後は、賞と書いた胴巻きのある酒瓶を中心に、各区の集会所で一同持ち寄りの懇親会が開かれた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでまた、運動会の話で持ちきつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は運動会だから、決して寝ぼけずにちゃんと自分で支度をして、みんなを驚かしてやろうとかたく決心をして寝ました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝大へん早く起きたものがありますから、太郎さんは飛び起きますと、お母さんが坐って、「太郎さん、今日は雨がふって運動会がお休みになったのだよ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎さんは昨日先生が「雨が降ったら運動会はおやめ」と言われた事を思い出して、安心して眠りました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会があるよ」　太郎さんは、寝ぼけてはならぬと、寝床の中で考えはじめました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに太郎さんは起き上って、御飯を食べて袴をはいて新しい靴下と白足袋をはいて、それからもし運動会がなかった時の用心に昨日次の日の時間割に合わして本を詰めて置いた鞄を荷いで、学校に行きました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会がお休みの時の用心に鞄をちゃんと持って行ったんだ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会がなければ学校はお休みですよ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんが運動会があると言ったのがわるかったのね」　太郎さんは恥かしさと口惜しさにとうとう泣き出しました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ある大学の運動会では余興の作りものの中にやはりこの煙突男のおどけた人形が喝采を博した。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか二年のときであったと思うが、ある日、運動会のあった翌日だからというので、先生がたに交渉して休みにしてもらおうとした。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この間、運動会の前の日まで雨が降っていたでしょう。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと前から、自分は一高の運動会やその他の機会で、秋元子爵の令息をよく知つてること。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は変り者だった、碁を打ちに出るときは数日も家に帰らないが、それよりも春秋の頃おい小学校の運動会が始り出すと、彼はほとんど毎日家に居なかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく家へは帰らないが、拓本職人の親方の老人は相変らず、小学校の運動会を漁り歩き遊戯をする児童たちのいたいけな姿に老いの迫るを忘れようと努めているであろうか。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の運動会の時の、応援などにも、これと同様の気持を味いました。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの痩せこけたおばあさんは、運動会へ行つたんだらう、と事もなげに答へた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は勢ひ込んで、「それで、その運動会は、どこでやつてゐるのです。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この路をまつすぐに行くと田圃に出て、それから学校があつて、運動会はその学校の裏でやつてゐるといふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会のすむのは四時頃か。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふは内の者がみな運動会へ行つてゐるので、何も出来ませんと病人らしいおかみさんが、奥の方からちらと顔をのぞかせて冷い返辞をしたのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「運動会で走つたか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、すぐにその硬直の姿勢を崩して、さりげないやうな、へんに、あきらめたやうな弱い口調で、「さ、はひつて運動会を。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を投げ出して、ぼんやり運動会を見て、胸中に、一つも思ふ事が無かつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、いつまでも黙つてゐたら、しばらく経つてたけは、まつすぐ運動会を見ながら、肩に波を打たせて深い長い溜息をもらした。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇は荐りに点頭いて、「運動会」「そのうんどうかいとか蕎麦買いとかをするからもう五十銭くれろッてネ、明日取りにお出でと云ッても何と云ッても聞かずに持ッて往きましたがネ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
