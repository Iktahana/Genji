[
  {
    "uuid": "eb2e0fbe-15d4-5e84-b68c-e9d6478cf2e3",
    "entry": "売り込む",
    "reading": {
      "primary": "うりこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
