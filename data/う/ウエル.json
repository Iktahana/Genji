    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to starve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "漢朝に対する忠信という点から考えるなら、いつまでも節旄を持して曠野に飢えるのと、ただちに節旄を焼いてのち自ら首｜刎ねるのとの間に、別に差異はなさそうに思われる。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子が軽井沢へ行くとき「今ウカウカしていると、親子四人で飢えるようなことになることよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しあわせに近所じゅういったいに樹木が多いので、それが背景になって樹木の緑にはそれほど飢える事はない。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧民いかに正直なりともおのれが飢える飢えぬの境に至って墓場の鴉に忠義だてするにも及ぶまい。",
              "citation": {
                "source": "墓",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠然として飢えるか！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社に籍を置いてからも原稿の仕事は続けてきたし、技術的なコンサルタントを引き受けているところもあり、仕事に飢える不安はなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい飛び散るようなその詩を聞いていると、私一人の飢えるとか飢えないとかの問題が、まるでもう子供の一文菓子のようにロマンチックで、感傷的で、私の浅い食慾を嘲笑しているようである。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ツしかなかったら、二ツに割って食べればいいだろう、何もなかったら、二人で飢えるさ」　これは、素敵にいい言葉であった。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く食えないんだから……」「食わなくったって、溺れていた方がいいじゃないの……」「君はいったい何日位飢える修養が積ンであるのかね、まさか一年も続くまい」　　　　　八　清朗な日が続いた。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが飢える日が鎖のように続いた。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい飛び散るような、その詩を聞いていると、私一人が飢えるとか飢えないとかの問題が、まるで子供の一文菓子のようにロマンチックで、感傷的で、私は私の食慾を嘲笑したくなった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はぼんやりさびしいのが、後には飢えるようにさびしくなるかもしれない。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで玉汗が言うに、三人でここでこうしていたのでは、近く飢えるにきまっている。",
              "citation": {
                "source": "酒徒漂泊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒に自然に対していれば私の心は決して飢える事はありません。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして結局飢えることもなく渇くこともなく、風邪もひかずに、平安な一生を送った。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私らは飢えることを免れた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国ですと身体に故障のない限りは決して飢えるという恐れがありません。",
              "citation": {
                "source": "監獄署の裏",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺を信ずる者は渇かないだろう』ではお前へ行かない者は飢えるということになるのだな。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし外人がより良い農業制度を導入するのでなかったならば、彼ら自身が飢えるか、またはより多くのスウェーデン人を飢えさせるかのいずれかであろう。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は、「文学者というものは、だれから頼まれたわけでもないのに、自分から好んで、だれに必要でもないものを作りだそうとしている人間だから、貧乏し飢えるのもしかたがない」といったようなセンチメンタルな考えには賛成できないのです。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飢えてはならぬし、飢えるべきではない。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての苦しむ者は今秩序に向って飢える。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "工藝界は今やよき指導者に飢える。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛に飢える人情がこの世の家庭を作るのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これほど人情に飢える吾々に答える人情はないのであろうか」と咏嘆の声が聞えてくる。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は飢える想いで読み耽ったのです。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の音楽に飢える人は、琉球に来て最大の歓喜を覚えるでしょう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が煙突の頂上に飢えるのを、黙って見ているような世間でないことを、彼はよく知りぬいている。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あの人たちは、わたしをうえることができない。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドワードにぶたの疱瘡のうみをうえると八日目にできものが生じました。",
              "citation": {
                "source": "ジェンナー伝",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
