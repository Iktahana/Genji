          ],
          "literary": [
            {
              "text": "お静は田町へ行って綾衣の生まれ月日を言うと、占い者は又もひたいに皺を寄せて、この女には剣難の相があると言った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子は高杉と生まれ月までおなじ同年齢だ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに高村さんは美代子さんとおなじ年齢です」　日比谷の説明を受けて、「お生まれ月は？",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "高村恵子の生まれ月は、後藤美代子のそれと同じだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかがってみるとおなじ年齢で生まれ月がおなじで、背丈もおそらく五ミリと違わないでしょう。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
