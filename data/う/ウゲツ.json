    "definitions": [
      {
        "index": 1,
        "gloss": "being unable to see the (harvest) moon because of rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを日本の上田秋成が飜譯して、題も夢應の鯉魚と改め、雨月物語卷の二に收録しました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はせつない生活をしてゐた期間にこの雨月物語をよみました。",
              "citation": {
                "source": "魚服記に就て",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は讃岐の産れで、国には崇徳上皇の御陵のある白峰という阜陵がある、上田秋成の『雨月物語』や、露伴氏の作として、かなり評判のあった『二日物語』は、この白峰に取材がしてあるが、まさか、あの白峰じゃあなかろうと、真面目になって考えこんだものである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "史邦の句三十八ばかりを書き抜いてすぐ気のついたことは「雨月」複合の多いことである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "總角より教外の旨をあきらめ給ひて、常に身を雲水にまかせ給ふ……　殆ど暗誦した雨月物語の青頭巾の全章を、雪にむせつゝ高らかに朗讀した。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを雨月物語式に綴れば、範頼の亡霊がここへ現れて、「汝、見よ。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上田秋成の「雨月物語」のうちに「蛇性の婬」の怪談のあることは誰も知つてゐるが、これは曲亭馬琴が水戸にいた人から聞いた話であるといふことで、その趣がやゝ類似してゐる。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上田秋成の雨月物語に至つて「朧」の美は極致に達する。",
              "citation": {
                "source": "朧",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにあつた安永五年刊の雨月物語を取つて鉢の蓋にした。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『雨月』『春雨』の二草紙はいはばその欲情の血膿を拭つたあとの故紙だ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、三十五歳、彼の遊蕩生活が終りを告げるころ、彼は突如として雨月物語を書いた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の造詣の深さを証拠立てる事は彼が三十五歳雨月物語を成すすこし前、賀茂真淵直系の国学者で幕府旗本の士である加藤｜宇万伎に贄を執つたが、この師は彼の一生のうちで、一番敬崇を運び、この師の歿するまで十一年間彼は、この師に親しみを続けて来たほどである。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草仮名揉銀の消ししつやゆゑ墨のいろよくうつるらし、時雨月、かかるひと夜は草仮名に心ゆくなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『蛇性の婬』の話は、上田秋成の『雨月物語』の中でも最も傑出したものとせられているが、しかし、これは秋成の創作でなしに支那の伝説の翻案である。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に私は不勉強で英語が出来ませんでしたので、外国の探偵ものを探して読む勇気もなく、棠陰比事や雨月物語なぞの存在も知らないままに又もイライラを続けておりますと、そのうちにフトした動機から宗教に凝りはじめました。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年、熊本の友枝三郎翁が、「雨月」を舞い終ると同時に楽屋で急逝したことは心ある人々の讃嘆するところであった位だから。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "編中の物語は、創作、半創作、伝説、筋書などで、大正の雨月とするには、まだまだ段階の多いのを恥ずる次第である。",
              "citation": {
                "source": "『黒影集』の序詞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はてな、」机に凭りかかった胸を正しく、読んでた雨月物語から目を放して、座の一方を見たのは、谷中｜瑞林寺の一間に寓する、学士神月梓である。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梓はト胸を突いた様子で、「希代なことがあるんですよ、お上人、読んでいましたのは御存じの雨月なんですが、私もなぜか自分の声に聞き惚れるほど、時々ぞッぞッとしちゃあその度に美しい冷い水を一雫ずつ飲むようで、唾が涼しいんです。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（弥平兵衛宗清、四十余歳、今は仏門に入りて雨月という。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雨月　これ、これ、平家蟹とは……。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雨月　この蟹をなぜ平家と云うのか。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（指さし示せば、雨月はつくづく視て、思わずぞっとする。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雨月　おお、なるほど蟹の甲にはありありと人の顔……。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨月　白きは源氏……赤きは平家の旗の色……。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（雨月は黙して蟹をながめている。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雨月　これ、子供よ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨月　おお、聞き分けのよい児じゃ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨月　それは糒というもので、水か湯にひたしてたべるのじゃ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）雨月　この後もあの蟹を捕えてはならぬ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
