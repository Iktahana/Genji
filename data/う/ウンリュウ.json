        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山神咏じて曰く、わけ行けば奧より奧に奧ありて　　果てしも見えぬ梅の花園『雲龍』と稱する老木、一茅屋の前に在り。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の信綱はその日の記念として、雲龍の図を探幽に求めました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲龍の図だというので、墨汁は家来たちの手でたっぷりと用意せられました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "探幽は顫える手に絵筆を取り上げて、画絹と掴み合うような意気込で、雲龍の図にとりかかりました。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか火事｜頭巾の如きものに雲龍の刺つ子と云ふ出立ちである。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また普通の凧の絵は、達磨、月浪、童子格子、日の出に鶴、雲龍、玉取龍、鯉の滝上り、山姥に金太郎、或いは『三国志』や『水滸伝』の人物などのものがある。",
              "citation": {
                "source": "凧の話",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、雲龍寺の暴行　館林警察署長は巡査を引率して、再び雲龍寺に来れり。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲龍寺とは、鉱毒被害民の事務所となせる所にして、渡良瀬村字早川田に在り、栃木県の被害民等は帰途また此の事務所に立ち寄れるもありき。",
              "citation": {
                "source": "鉱毒飛沫",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十三年二月十三日、議会へ請願の最後の覚悟を決めた被害民は、渡良瀬村の雲龍寺を出発し、館林を過ぎて、利根川まで進んだ。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、本件犯罪地、即ち雲龍寺より館林、川俣地方の臨検。",
              "citation": {
                "source": "政治の破産者・田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "佃島の漁夫が雲龍の半纏に黒股引、古式の侠な姿で金棒突き佃節を唄いながら練ってくる。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銀五色の色糸で雲龍を織出した金襴の大段通を背中に掛け、四本の脚の中へ人間が一人ずつ入って肩担いに担ってゆく。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるひは紫雲龍であるとか、小常陸であるとか、稲瀬川、司天龍、黒瀬川、大鳴門等々。",
              "citation": {
                "source": "両国今昔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらつしやい、御當所名題の地獄極樂活人形、作人の儀は、江戸の名人｜雲龍齋又六、――八熱八寒地獄、十六別所、小地獄、併せて百三十六地獄から、西方極樂淨土まで一と目に拜まれる。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下手人は」「手前だけに言つて置くが、あの肥つちよの、ニヤニヤした野郎だよ」「えツ、雲龍齋又六？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄極樂の小屋の者は、巳之吉初め一人殘らず調べ上げた上、お倉の母親から、雲龍齋又六の動き、一刀齋勘兵衞の家まで、念には念を入れて搜し拔きましたが、その晩、お倉の家へ勘兵衞らしい男が訪ねて來ると、お倉は母親を原庭の叔母のところへ泊りにやつた――といふ以外には、何にも得るところもなかつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖した木戸を開けさして、眞晝乍らなんとなく薄暗い小屋の中へ入ると、彫物師の雲龍齋又六は中二階の揚幕の蔭、丁度、普賢菩薩を見張るやうな位置に、仰向になつてこと切れて居るのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あの佛像の臺座を見ると、銘を削つて書き變へた跡があるんだ」「へエ、――驚いたなア、何うも」「雲龍齋又六は、高慢に構へて居るが、あれは下手つ糞だよ」「すると、あの佛像は誰の作でせう」「それが解らぬ」「此間殺された勘兵衞ぢやありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の夫一刀齋勘兵衞を殺し、續いて、主人の雲龍齋又六を殺したとすれば、磔刑か火焙りは免れぬところでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉本には勿體ないが嫁のお倉を使つて、素木のまゝ死んだ女房の供養に、菩提寺に納める積りでしたが、フトした手違ひから、雲龍齋又六に横取りされたので御座います」「矢張りさうか」「又六は伜の銘を削つた上、神々しい素木の佛樣へ、見世物向きに、あんな下品な彩色をして了ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十前後の小柄な好い男で、素袷に銀鎖の肌守り、腕から背中へ雲龍の刺青がのぞいて、懷中には鞘のまゝの匕首が、無抵抗に殺されたことを物語つてをります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "小便組貞女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰です、その下手人は」「手前だけに言っておくが、あの肥っちょの、ニヤニヤした野郎だよ」「えッ、雲龍斎又六？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄極楽の小屋の者は、巳之吉初め一人残らず調べ上げた上、お倉の母親から、雲龍斎又六の動き、一刀斎勘兵衛の家まで、念には念を入れて捜し抜きましたが、その晩、お倉の家へ勘兵衛らしい男が訪ねて来ると、お倉は母親を原庭の叔母のところへ泊りにやった――という以外には、何にも得るところもなかったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎖した木戸を開けさして、真昼ながらなんとなく薄暗い小屋の中へ入ると、彫物師の雲龍斎又六は中二階の揚幕の蔭、ちょうど、普賢菩薩を見張るような位置に、仰向けになってこと切れているのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あの仏体の台座を見ると、銘を削って書き変えた跡があるんだ」「ヘエ、――驚いたなア、どうも」「雲龍斎又六は、高慢に構えているが、あれは下手っ糞だよ」「すると、あの仏体は誰の作でしょう」「それが解らぬ」「この間殺された勘兵衛じゃありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の夫一刀斎勘兵衛を殺し、続いて、主人の雲龍斎又六を殺したとすれば、磔刑か火焙りは免れぬところでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "粉本には勿体ないが、嫁のお倉を使って、素木のまま死んだ女房の供養に、菩提寺に納めるつもりでしたが、フトした手違いから、雲龍斎又六に横取りされたのでございます」「やはりそうか」「又六は倅の銘を削った上、神々しい素木の仏像へ、見世物向きに、あんな下品な彩色をしてしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "歎きの菩薩",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥を下りて渡良瀬川の舟橋をわたり、しばらく岸辺にたたずんで小川渦紋のながれやまぬ川面をながめ、それから何か独りごとをいいつつ雲龍寺の苔生した山門を入った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはこれから渡瀬村へいって今夜は雲龍寺に厄介になる。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
