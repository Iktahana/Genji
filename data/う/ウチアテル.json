    "uuid": "25d30d64-639a-518f-b207-598fe510924e",
    "entry": "打ち当てる",
    "reading": {
      "primary": "うちあてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
