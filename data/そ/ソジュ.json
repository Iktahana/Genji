        "examples": {
          "standard": [
            {
              "text": "物語では、裏切り者には祖神の恐ろしい詛呪が下されると語られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、絶望のあまり、相手に呪いの言葉（詛呪）を吐きかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "魔女は、勇者に永遠の苦しみを与える詛呪をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
