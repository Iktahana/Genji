    "definitions": [
      {
        "index": 1,
        "gloss": "integrated science (i.e. collaboration of various sciences and arts)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
