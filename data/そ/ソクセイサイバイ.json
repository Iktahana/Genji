        "examples": {
          "standard": [
            {
              "text": "促成栽培により、冬でも新鮮なトマトを食卓に並べることができるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この果樹園では、促成栽培技術を導入し、収穫時期を早めることで、より多くの利益を得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "促成栽培された野菜は、味が薄いという意見もあるが、手軽に入手できるのが利点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "至つて開けぬ所ださうで、湯の量は非常に多く、浴用よりそれを使つて野菜の促成栽培をやつてゐるとか聞きました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊促成栽培を馬鹿にするな。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊富な読書によって、新式の電気促成栽培方法を知り、やってみようと決心した。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
