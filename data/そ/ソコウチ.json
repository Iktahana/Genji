        "examples": {
          "standard": [
            {
              "text": "株価は一時期低迷したが、ようやく底打ちして反発の兆しを見せている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不動産市場は昨年から底打ち感が強まり、回復への期待が高まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "生産量の底打ちが見られ、経済指標も徐々に改善傾向にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼らは、その潮流と、その風とに到底打ち克つことができないということをさとると、ぐっとその能率を引き下げた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒には堪えられても、口に云えないこの淋しさには、到底打ち勝てそうにもない気がします。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝も熟知するとおり、われ等は到底打ち勝ち難き、不利な条件に縛られて居る。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
