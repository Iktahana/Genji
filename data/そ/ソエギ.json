        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "骨折した腕には、医師が丁寧な添え木をして、固定してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭師は、折れそうな枝を支えるために、木に添え木を施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "応急処置として、怪我をした指に、細い棒を添え木のように当てて応急処置をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "添え木――わしが付いている。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄畑La Vigne　どの株も、添え木を杖に、武器携帯者。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "添え木――わしがついている。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶどう畑　どの株も、添え木を杖に、武器携帯者。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大佐の杖と折り取った枝とで添え木を作り、馬用ムシロを担架代わりにして「グレイロック」まで担ぎ込みベッドに寝かせた。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
