    "definitions": [
      {
        "index": 1,
        "gloss": "hiring a number of geisha for an entertainment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
