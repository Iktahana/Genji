          "standard": [
            {
              "text": "世界的に有名な組織学者が、新しい細胞の発見に関する画期的な論文を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、長年の経験を持つ熟練の組織学者として、難病の診断に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「わぁ、あの組織学者、テレビで見たことある！すごい人なんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "結核を患いながらも臨床医、博物学者、人体組織学者、化学者、衛生学者、として活躍した彼の忙しい一生の物語は興味深い。",
              "citation": {
                "source": "食品とその混ぜ物処理",
                "author": "FOOD AND ITS ADULTERATIONS; ANALYTICAL SANITARY COMMISSION OF \"THE LANCET\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "第３版には神経組織学者カハール、大脳生理学者パブロフ、神経外科医カッシング、およびシゲリストの恩師の内科医ミュラーと外科医ザウエルブルフが加えられている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
