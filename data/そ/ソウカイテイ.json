        "examples": {
          "standard": [
            {
              "text": "掃海艇は、海底に沈む機雷を探し出し、安全に処理する重要な任務を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新技術を搭載した掃海艇が、日本の沿岸防衛に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "掃海艇の乗組員たちは、日々厳しい訓練を重ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "博士の右隣には、博士の信任の篤いオーキー学士が、水中電話機を背負って、たえず水面に待機している掃海艇サンキス号と電話で連絡をとっている。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかいていたのはチェホフの妻であったオリガ・クニッペルだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかいているとき震えた蕗子の唇が感じられた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
