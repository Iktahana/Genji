        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "町内会の福引で、買ったくじが全部当選するという奇跡的な総当たりを経験した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "まさか十枚の宝くじが全て当たりくじだったなんて、まさに総当たりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの店の懸賞は当選確率が高く、友人は五回引いて総当たりだったと喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
