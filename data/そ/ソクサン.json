        "examples": {
          "standard": [
            {
              "text": "彼はそろばんの段位を持っており、三桁の掛け算くらいなら速算であっという間に解いてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レジで会計を待つ間、カゴの中の商品代金を速算して小銭をぴったり用意しておくのが私の特技だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "数学の競技会で、複雑な数式をいかに正確かつ速算で処理できるかを競い合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近々書記に出世さして貰うのを樂みにしてゐる重吉といふ頭髮を綺麗に分けた小使も加はつて、一しきり速算が續いた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねこは、さっそくさんせいして、いっしょに出かけました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いいますと、犬もそこへ行ったら、骨の一、二本、ことによると肉の香ぐらいかげようかとおもって、さっそくさんせいしました。",
              "citation": {
                "source": "ブレーメンの町楽隊",
                "author": "DIE BREMER STADTMUSIKANTEN",
                "note": "青空文庫"
              }
            }
          ]
        }
