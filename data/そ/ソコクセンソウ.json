        "examples": {
          "standard": [
            {
              "text": "ロシアでは1812年の戦いを祖国戦争と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖国戦争の記憶は、今もロシア国民の心に深く刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの犠牲者を出した祖国戦争は、歴史の大きな転換点となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこには、一九二七―三〇年のモスクワでないモスクワが描かれているし、反ナチの祖国戦争で、ソヴェトの人々が人類の平和のためにどれだけかけひきぬきの犠牲をいとわなかったか、その巨大な破壊とそこからの回復のためにいかに奮闘しているかということを、スタインベックは、あたたかくわれわれにつたえている。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
