        "examples": {
          "standard": [
            {
              "text": "逃げ場のない状況に置かれ、彼は俎上の鯉のように、ただ運命を受け入れるしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "権力者の前では、一般市民はしばしば俎上の鯉となり、なすすべもなく従うしかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "もうどうすることもできない、私はただの俎上の鯉だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "貴殿の態度は俎上の鯉、尾鰭をたたんで静まったというもの。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俎上の鯉となりましょう。",
              "citation": {
                "source": "無法者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
