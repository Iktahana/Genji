        "examples": {
          "standard": [
            {
              "text": "彼女は、花柄の総柄ワンピースを涼しげに着こなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この壁紙は、幾何学模様の総柄で部屋の印象を明るくする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若者たちの間では、大胆なプリントの総柄シャツが流行している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あの人はかわいそうな人のくせに、かわいそうがられるのがきらいらしいから」「僕には結局葉子さんが何がなんだかちっともわからない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "等と心から淋しそうに云って居るのを見ると、幾分の甘えと我儘の含まれて居る事は分って居るのですけれ共可哀そうがらずには居られなく成りました。",
              "citation": {
                "source": "二月七日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "村にも遠いし、人もいないし――彼奴は可哀そうだが――今、もし、彼奴を討って江戸へ戻らなかったら、俺が人から可哀そうがられるだけだ。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と三次は辺りを睨めつけて、「蜻蛉蜻蛉ってそうがらに言うねえ。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀そうがられるために、自分の年も二つ三つは多く云っているとさえ噂されているのである。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀そうがられるべきだと云われつつ、気の毒な人が堪らないような辱しめを蒙らなければならないのを知った。",
              "citation": {
                "source": "地は饒なり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
