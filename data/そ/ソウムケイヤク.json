        "examples": {
          "standard": [
            {
              "text": "売買契約は、売り手が商品を引き渡し、買い手が代金を支払うという典型的な双務契約である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "双務契約においては、一方が義務を履行しない場合、もう一方も履行を拒むことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "賃貸借契約を結ぶ際は、それが双務契約であることを意識して条項を読み込む必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "聖書の「約束」または「契約」と言う語は、神と人とが対等の立場で取り引きする意味の双務契約ではない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
