          "standard": [
            {
              "text": "税務署の監査に備えて、過去数年分の総勘定元帳を整理しておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会計ソフトを使えば、日々の仕訳から自動的に総勘定元帳が作成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "総勘定元帳を確認することで、各勘定科目の残高を一目で把握することができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "会計用のアプリケーションには汎用のもののほか、総勘定元帳、賃金台帳、支払勘定、受取勘定、在庫表、受注、現金支払い、現金受け取り、個別原価計算、固定資産勘定などじつに細かな分野にまで踏み込んだ専門性の高い製品が並んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
