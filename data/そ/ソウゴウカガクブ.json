        "examples": {
          "standard": [
            {
              "text": "彼は文学部ではなく、あえて総合科学部を選んで入学した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "総合科学部では、文理の枠を超えた学際的な研究が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "将来の夢がまだはっきりしない高校生にとって、総合科学部は魅力的な選択肢かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "社会の枠組みからの逸脱と取り込みという考え方は、広島大学総合科学部助手の杉本厚夫さんに示唆していただきました。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
