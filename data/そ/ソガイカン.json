        "examples": {
          "standard": [
            {
              "text": "都会で一人暮らしを始めてから、時々疎外感を感じることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラスの中で馴染めず、彼は強い疎外感を抱いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テクノロジーの進化が、人々の間に疎外感を生み出すこともある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五郎は疎外感を感じながら思う。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（プラトン）　人々をおたがいにひきはなし、愛のもっとも薄味なものしかあたえないことに繁栄の土台をおいている社会に対する強烈な疎外感をきっかけに自分たちの生活を根本からつくりなおそうとする若者のムーヴメントと切りはなしてロック音楽を考えることはできない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種の無関心には個々の立場によって生じた疎外感が入り混じっている。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
