        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "乾燥した木材の端が、縦に削げてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "割れた瓦の断面が鋭く削げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "力を入れすぎたため、竹ひごが途中で削げてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此時はじめて分つたが霙といひたい位な、目にも見えぬ薄い細かい吹雪が汽車の進行する前方から、眞つ直ぐに吹きつける烈風に送られてやつて來て、それが眼と言はず、鼻と言はず叩きつけ、頬邊を削げるやうに冷たく濕してゆく。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その縫える衣の一針ごとに、あとはなけれどまさしくそそげる千｜行の涙を見ずや。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄狐色のおこげの皮に、塩をばらっとふって、しゃもじでぐいとこそげると、いかにもおいしそうな、おこげがとれてくる。",
              "citation": {
                "source": "おにぎりの味",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to become sunken (e.g. of cheeks)",
        "register": "standard",
