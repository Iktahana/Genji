        "examples": {
          "standard": [
            {
              "text": "一度捕らえられれば、もはや俎上の魚であり、成す術はない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、敵の罠にはまり、まさに俎上の魚となってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この状況では、我々はただ運命に翻弄される、俎上の魚に過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "文字通り俎上の魚である。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は俎上の魚となった以上敢て逃げ匿れはしない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その六　暗い哉　東洋よ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
