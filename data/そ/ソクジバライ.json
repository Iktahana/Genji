          "standard": [
            {
              "text": "この取引では、商品の引き渡しと同時に即時払いが行われる条件となっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "個人間取引のプラットフォームでは、安全のため即時払いが推奨されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「即時払いなら、すぐに入金されるから安心だね！」と、フリーランスのAさんは話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "わたくしは即時払いの報酬を――つまり自分への賞賛と、愛に対する愛の報酬を要求いたしておるのでございます。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "万が一不幸が起こったら、保険金は即時払いだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
