        "examples": {
          "standard": [
            {
              "text": "事故現場の交通整理のため、道路上にパイロンが並べられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが、駐車場に置かれたパイロンを障害物競走のように飛び越えて遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「すみません、このパイロンを少しずらしていただけますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
