        "examples": {
          "standard": [
            {
              "text": "そのバンドのボーカルは、圧倒的な歌唱力と存在感を持つパフォーマーだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は多才なパフォーマーとして、様々な舞台で活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サーカスのパフォーマーたちは、観客を魅了する素晴らしい技を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "パフォーマーは、同社の関澤義専務取締役。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このパフォーマーが、客を楽します楽します。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社のトッテン社長がじつに稀代のパフォーマーであり、オレがここの新製品発表会をほとんど『たま』のコンサートに向かう乗りで楽しみにしていることも書いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも高座に上がるのは、稀代のパフォーマーときている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマーク・キャンター、富士通との提携を発表するに当たっては右手を握ってラッパを作り「トラタタッタタ〜」と壇上でイントロを入れて稀代のパフォーマーぶりを発揮。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
