        "examples": {
          "standard": [
            {
              "text": "彼は本当に面白いパーソンで、話しているといつも笑いが絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その会議には、各分野の専門家であるキーパーソンたちが集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は仕事もプライベートも充実している、まさに魅力的なパーソンだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "会場内で、これはと思われる重要そうな展示物や、シンポジウム運営のキー・パーソンに話しかけてみる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "また後の汽車でドクタア・マレーとパーソンス教授が応援に来たので、この多人数で我々は、多くの溝や、深い壕を掘った。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソンス教授は、大久保伯爵家から贈物として、背の高い、純白の松のお盆に、種々な形と色の糖菓を充したものを贈られた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんパーソンの発言は年齢が若いという理由で、と言っても50歳未満だが、ほかの人より重要視されなかった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
