    "definitions": [
      {
        "index": 1,
        "gloss": "punch (with the fist)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は渾身の力で相手の顎に右パンチを叩き込み、一気に試合を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シャドーボクシングで、空を切るような鋭いパンチを何度も繰り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「不意にパンチをもらって、一瞬だけ目の前が真っ白になったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いままでソファの底に沈んで、情婦のつくってくれたあたたかいラム・パンチをのんでいた田村英介氏は四家フユ子のデコルテの紊れに強い感情を乱されて、――おまい、僕と別れたいんだろう――――ノン、あなたが妾を囲いものにするからさ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてパンチを入れた分を割き取って左手の指先でつまんだままで乗って行った。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｚ町の停留場で下りようとして切符を渡すと、それをあらためた車掌が、さらにもう一つパンチを入れてそれと見較べて「これはちがいます、私のよりは穴が大きい」と云った。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、結城孫三郎やダークのマリオネット、ないしはギニョールのパンチとジュデーなどに対する独特の地位を全然喪失してしまうことは明白である。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫はその二人の神が何者であつたか少しも知らなかつたが、実はその二人はシヴアとパンチヤーナナといふ「破壊」を司る恐ろしい神なのである。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬肉が入ってたら、食わないのかよ」　高志が、慶一のひざを枕にして、「平凡パンチ」をパラパラやりながらこたえる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の勉強机におかれているはずの、卓上ランプがふたつ、「壁」と「天井」のあいだから吊るされているので、いちおう、コンビーフと大和煮の区別はつくが、「平凡パンチ」のグラビアを見ても、乳首と目玉の区別がつくかは、さだかではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかげんで、ほかのにしろよ」　顔のまえにかざしていた「パンチ」をかたわらにおき、高志が慶一を見ていう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、しようがねえな」　そういって、高志は「パンチ」をマットレスの下に押しこみ、上体を起こした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は振子の響きに合してカタカタと場所を変えて行くパンチと云う人形に過ぎぬのか。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は逃げるのも業腹だと気づいて、立ち直るや満身の力を込めた右腕で唸りをはらんだ半円を切ると奴の横面に稲妻のやうなパンチを喰はせた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず五蘊という語からお話しいたしますと、このことばは、梵語のパンチャ、スカンダーフという語を、翻訳したものでありまして、パンチャとは、五つという数字です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはシヤルパンチエーといふ名で、結構な名前だが、このシヤルパンチエーは英語でいふと、カアペンタア、言霊の幸はふ日本語では、「大工」といつて、朝から晩から金鎚を叩いて暮してゐる、紺の法被に鉢巻をした男の事である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西語でシヤルパンチエーといふのは、天にも地にも自分一人のために拵へられた固有名詞で、普通名詞として燕のやうな紺の法被を着た大工を呼ぶなどは、以ての外だと思つてゐるのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボード、プリンター、紙テープパンチ、紙テープリーダーを一体にまとめたＡＳＲ―33は、本来の用途以外にも、比較的小型のコンピューターシステムの入出力機器として使われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューターの代表的な入力方式である、パンチカード。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが光を電気に変えることで電気的にものを〈見る〉ことを可能にする光電セルや写真技術、音声タイプライターなどを統計処理分野で使われているパンチ・カード・システムのような情報処理機械と組み合わせることで、広大な知識と経験の海を発想のおもむくままに滑る道具が作れるだろうとブッシュは予測した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレックスの開発作業はＡＲＰＡの援助を受けて進められ、ケイは操作用にキーボードは付いているけれど、プログラミングにはパンチカードを使うしかなかったＩＢＭの１１３０というコンピューターで作業を進めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューターでは、仕事の手順やデータを紙のカードに穴を開けて表現し、これを機械に読ませて処理を行わせるパンチ・カード・システムが広く使われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ＩＢＭはそこで、技術提携に対するロイヤリティーとして送金するという手で外資法をすり抜けようと考えたが、通産省はこれを認める条件として、特許の公開と日本ＩＢＭの製造機種をパンチカードマシンに限定するように迫った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭがパンチカードの代わりとして開発したフロッピーディスクがマイクロコンピューターを使ったシステムで利用できれば、ミニコンピューターに頼らずに、プログラムが簡単に書けるようになるとキルドールは考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カードに穴をあける穿孔機（パンチ）、穴によってカードを仕分けする分類機（ソーター）、そしてカードに記録されたデーターを計算処理する作表機の三つの要素からなるパンチ・カード・システムを、ＩＢＭはレンタル制で供給し、保守やカードの販売でも収益を上げていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五二年には再び連邦政府に告訴された経緯が示すとおり、相変らず作表機の市場を独占し続けていたＩＢＭは、大企業や大組織のデータ処理の仕事をパンチ・カード・システムに載せて処理するノウハウを蓄積しており、ユーザーの要求を吸い上げる確固たる営業、技術体制を確立していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はフォートランでプログラムを書くことを覚え、パンチしたカードをリーダーに読みとらせてコンピューターを動かすチャンスを与えられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装と云い、態度と云い、すべてが、パンチの挿絵を切抜いて、そのままそれを、この停車場の人ごみの中へ、立たせたとしか思われない。",
              "citation": {
                "source": "父",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふのは、自分は乗客の手と切符のみ注目してパンチを入れながら、未だ一瞥も与へぬうちに乗客の顔がちやんと分つてゐることに気付いたからである。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて然らば自分の特殊な能力は入院後だうであつたかと言へば、病院は鉄道の駅ではないから自分はもとよりパンチを所有する筈がないし、かりにパンチがあつたとしても患者を乗客に仕立てて切符を切るといふわけにはいかない。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
