        "examples": {
          "standard": [
            {
              "text": "提出する書類の左端に、ファイリング用のパンチで2つの穴を開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このパンチは一度に30枚もの紙を貫通させることができるので、仕事が捗る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ベルトの穴が足りなかったので、専用のパンチを借りて新しく1つ追加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
