    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テレビカメラマンは、被写体を捉え続けるために、ゆっくりとカメラをパンさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この映画のオープニングは、壮大な風景を映し出すための長尺のパンで始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "指示が出ると、カメラマンは素早くパンして次のターゲットにフォーカスを合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なまなか伝説的存在にされてあゝ、この言語玩弄者達の世に、なまなか伝説的存在にされて、（パンを奪はれ花は与へられ）あゝ、小児病者の横行の世に！",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎なぞに感動してはをれぬといふ人があるかも知れぬが、お望みとならパンにでもルンペンにでも感動するがいい。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感動したらその感動がやがて芸術であり、何もその感動の誘因となつたパンが芸術でもなければルンペンが芸術でもない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンセのないものは詩人ではない。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しパンセは起るものとして自己を益し、パンセしようとしてすれば良く行つて歴史家の知にしかならないものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンセは詩ではないが詩はパンセする人から生れる！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してパンセとは現象に対する忠実さの過剰と言へる。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し自分自身の言語或ひは心象でパンセされて出来た主義なら、その主義は彼自身なのだから、その主義を守るも守らないもないものだ！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は土産に上等のシャンパン酒を置いて歸つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今から考へると、このシャンパン酒は彼の生前の形見だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠にパンセは言葉にたよる他、仕方ないものなのか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつうのパンフレットです」「すぐそんなことを言うからな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服のときはゴルフパンツである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新郎はネクタイをほどきながら、「ついでに君、新しいパンツが無いか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文房具と、正午にはパンと牛乳を支給してゐた校内の売店は、「学生が学生の武器である文房具を、学校に来てから整へるやうなことでは不可ない」といふ理由の許に廃された。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の玄関の左側にはちょっとした売店があって文具や、それから牛乳パンくらいを売っていたような気がする。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはほんとうにバッカスの酒宴で、酒は泉とあふれ、肉は林とうずたかく、その間をパンの群れがニンフの群れを追い回すのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あけてはならぬ」と言はれると、なほ、あけて見たい誘惑を感ずると云ふ人間の弱點は、この浦島の物語に限らず、ギリシヤ神話のパンドラの箱の物語に於いても、それと同樣の心理が取りあつかはれてゐるやうだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あのパンドラの箱の場合は、はじめから神々の復讐が企圖せられてゐたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あけてはならぬ」といふ一言が、パンドラの好奇心を刺戟して、必ずや後日パンドラが、その箱をあけて見るにちがひないといふ意地惡い豫想のもとに「あけるな」といふ禁制を宣告したのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの龍宮のお土産も、あの人間のもろもろの禍の種の充滿したパンドラの箱の如く、乙姫の深刻な復讐、或ひは懲罰の意を祕めた贈り物であつたのか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに依つて、パンドラの蒼白の頬にも、幽かに血の色がのぼつたといふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尤も私達の所では、男の人が娘に取入らうとする時には、先づ最初に贈物をするのが普通だね、くるみか香料入りのパンか何か買つて来るのが。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの、パンだとか、魚の切身だとか、巴焼だとかの包み紙の、古新聞が、風に捲かれて、人気の薄い街を駆け抜けた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジグスのやうに、パンのし棒でのされるにしても、あのやうに朗に飲めるのならば、酒は確かに百薬の長だが。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "七重の瀧の茶店で「燒饅頭」と貼札したものを試みに注文したら、丸いパンのやうなものに味噌※を塗つたものであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は女達には知らん顔で律儀に焼パンと紅茶を誂えた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "panning (a camera)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ドラマのクライマックスシーンでは、登場人物の表情に寄る前に、カメラは一度パンして状況を説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ライブ中継では、観客の熱狂を伝えるために、ダイナミックなパンとズームが多用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ドキュメンタリーでは、固定カメラからのパンで、現場の臨場感を巧みに表現していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
