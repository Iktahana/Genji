        "examples": {
          "standard": [
            {
              "text": "ホテルの朝食会場で、パン皿を手に取り焼きたてのクロワッサンを盛り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テーブルマナーでは、パン皿はメインディッシュの左側に置くのが決まりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "結婚祝いに、シンプルで上品なデザインのパン皿のセットを贈ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "煤がふります、パン皿に、紅茶茶碗に、樽柿に。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の歌舞伎と現代もののちがいみたいなちがいは、よその国にはなかろうと思うんです」「考えてみると、日本てところは大変な国だなあ」　からのパン皿のふちへタバコをすりつけて消しながら素子が云った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
