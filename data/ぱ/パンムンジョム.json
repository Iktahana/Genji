        "examples": {
          "standard": [
            {
              "text": "板門店は、朝鮮半島の分断を象徴する場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の教科書で、板門店での会談について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつて板門店を訪れた際、緊張感のある雰囲気に圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その下宿で暮したのは、四月の半ばから夏にかけてだったが、たしか朝鮮での戦争が、さんざん難渋した板門店での調印で、やっとケリがついた年だったと思う。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
