        "examples": {
          "standard": [
            {
              "text": "彼女は深いパープルのドレスを身につけ、パーティーで注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕焼け空がオレンジからパープルのグラデーションに染まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しく買った筆箱は、お気に入りのパープル色だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "レッドツェッペリンやディープパープル、グランド・ファンク・レイルロードなどのビートのきいたロックを愛した藤井は、仲間たちと組んだバンドでギターを弾いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディープ・パープルをやって下さい」　歯切れよく澄んだ声でいった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディープ・パープル」はスロオだった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ディープ・パープル」癖なのかすこし首を曲げて、女は伍長に腕をとられながら黄色い服の女をみた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき舞子さんは、なにを弾いたのですか」「ディープ・パープル」「はあ」「しばらくソロで弾いて、やがてリズムが入ってきて、あるときいっせいに、トゥティになるの。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜のことを思い出した彼は、「ディープ・パープル」　と、答えた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
