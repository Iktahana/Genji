    "definitions": [
      {
        "index": 1,
        "gloss": "packing (items in a suitcase, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "旅行の準備で、スーツケースへのパッキングに時間がかかってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越し業者に依頼したので、荷物のパッキングは全てお任せだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "効率的なパッキングのコツを学んで、もっとスマートに旅行したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――出来上った罐とこの空箱が倉庫の二階のパッキング・ルームに落ち合って、荷造りされるわけである。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッキングされた函は、二階からエスカレーターに乗って、運河の岸壁に横付けにされている船に、そのまゝ荷役が出来る。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じパッキングにいる温しい女工が、浮かない顔をしていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の間の抜けた可笑しい質問　十三、ホテルで三人で食事をし、夜は父のパッキングを手伝う。",
              "citation": {
                "source": "「伸子」創作メモ（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は国産で初めての両面段ボールを使って、見よう見まねの製作にかかり、これを仕上げたが、これが日本でのいわゆるパッキング・ケースの最初のものとなった。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッキング・ケースは、アメリカではいまや自動車と同様、経済のバロメーターといわれるほどの普及ぶりである。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすべての品物をみんなパッキング・ケースに入れてみせるつもりだ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "packing (material for protecting packed goods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "精密機器の輸送には、衝撃吸収材を使った丁寧なパッキングが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壊れ物を送る際は、適切なパッキング材でしっかりと固定してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引越しでは、食器一つ一つをプチプチでパッキングする作業が大変だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "packing (material for sealing a joint)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "水漏れを防ぐために、蛇口のパッキングを新しいものに交換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エンジンのオイル漏れは、パッキングの劣化が原因であることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自転車のタイヤのバルブに、小さなパッキングが使われているのを知った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
