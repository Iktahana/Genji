        "examples": {
          "standard": [
            {
              "text": "このパン切りナイフは、刃がギザギザになっているので、どんなパンでも綺麗にスライスできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パン屋さんは、注文されたパンをパン切りナイフで素早く、均一な厚さにスライスした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "食卓には、焼きたてのバゲットと、それに添えるパン切りナイフが用意されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "パン切りナイフなんぞ使うからだ！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、だがパンくずがまじったにちがいない、」とグチるぼうし屋、「またぞろパン切りナイフなんぞ使うからだ。",
              "citation": {
