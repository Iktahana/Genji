        "examples": {
          "standard": [
            {
              "text": "イギリスのパーラメントは、世界でも最も古い議会の一つとして知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "与党はパーラメントで過半数の議席を確保し、法案を可決させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の政策決定は、パーラメントでの激しい議論の末に採択された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで少年はロビンソン・クルーソーのように自給自足で逞しく生きるんだ」「ふうん」　隼人はおもむろにパーラメントをくゆらした。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私は絶対空を飛べる』」「ますます気味悪いなあ」　隼人はパーラメントを一本取り出して口にくわえ、ライターで火を点けた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから依然として独我論はわれわれを懐疑の無限級数へ陥れる」　浩は自分の話をもうほとんど聞いていない様子だったので、隼人は話すのをやめて二本目のパーラメントをくゆらした。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホワイトホールとパーラメント通りの下手、ウェストミンスター橋そばの損害は甚大だった。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
