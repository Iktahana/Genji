        "examples": {
          "standard": [
            {
              "text": "レース直前のパドックでは、馬の毛並みや歩き方をチェックして調子を見極めるファンが集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、パドックを見て！あの5番の馬、今日はすごく気合が入っているみたいだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サーキットのパドックには、出走を控えたレーシングカーとメカニックたちの緊張感が漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "５５３はあめりかのパドック。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本へも来たことのあるパドックだのシムプソンの頃までは、そうだった。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙だったのは、パドックをうろつき、計量室のそばに行き、観覧席に立ち、肩を擦れ合う多くが、昔の知人だったことだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘同士が行ったので、少佐はパドックへ行き、そこでフィリップスに気づいた。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンピオン・ステークスが始まる半時間前に、パドックにいるラッフル爺さんの所へ行った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後二時になるとフィールデンはパドックを離れ、ジョージ卿とメイとカーディン嬢の所へ行った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
