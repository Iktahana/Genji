        "examples": {
          "standard": [
            {
              "text": "小さなパケットに入ったお菓子は、ちょっとしたお土産にちょうどいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のポケットには、使いかけのティッシュのパケットが入っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その研究室では、微細な粉末をパケット状にして保管していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
