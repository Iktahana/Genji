        "examples": {
          "standard": [
            {
              "text": "世界中で栽培されている小麦の多くは、パンや麺に適したパン小麦という品種だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地域では、寒暖差の激しい気候を活かして良質なパン小麦を生産している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "パン小麦の輸入価格が上がると、パン屋さんの経営に直接響いてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "普通のサヤインゲンおよびエンドウ豆もしばしばロンドンのパン小麦粉の中にすり潰される。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "５ブッシェルの小麦粉の入った袋からパンを作るための次に記す記載は、Ｐ．マーカム博士の「パン小麦粉とパンの混ぜ物処理で使う成分についての考察」21ページよりの引用である。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン小麦およびパン小麦粉の良さを判定する易しい方法　粉屋はパン小麦の質の良さを穀粒が作る籾の質によって判断する。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
