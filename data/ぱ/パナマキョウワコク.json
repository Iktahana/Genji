        "examples": {
          "standard": [
            {
              "text": "パナマ共和国は、太平洋と大西洋を結ぶパナマ運河の通航料が国の重要な収入源となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「パナマ共和国へ旅行に行くなら、あの有名なパナマハットをお土産に買いたいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中米の細長い国土を持つパナマ共和国は、豊かな自然と近代的な都市が共存している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは今から十五年まへに出来上つたのですが、最初アメリカ合衆国政府が、パナマ共和国に同意させて、あのほりわりをひらく計画をたてたのは五十年もまへのことで、かねてスヱズの運河を作り上げた、ドゥ・ルッセといふフランス人の技師をやとつて着手させたのでした。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
