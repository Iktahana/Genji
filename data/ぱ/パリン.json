        "examples": {
          "standard": [
            {
              "text": "硬い殻をパリンと割って、中の実を取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "枯葉が積もった道をパリン、パリンと踏みしめながら歩く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー！またお皿、パリンて割っちゃった…！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ダンフォースの意見では、これらは彫り直されたものだ――パリンプセストのように、これまであった彫刻を削り落として新たに彫ったのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に茶わんが床に落ちてパリンと破れる。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床は気温の変化に伴って、パリンパリンといい、時に地震があると屋根がきしむ。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは」「でもわたくし、―――」と、今度は綺羅子が引き取って、「ホイスパリングも悪くはないと存じますわ。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
