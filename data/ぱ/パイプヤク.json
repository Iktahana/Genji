        "examples": {
          "standard": [
            {
              "text": "彼はプロジェクトチームと経営陣のパイプ役として活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域の交流を深めるため、NPOがパイプ役を務める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "両社の提携が成功したのは、彼のパイプ役としての尽力があったからだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてアメリカと日本を結ぶパイプ役となることは、けっして難しい話ではないのだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度目の訪米で本場の熱気に触れ、日米のパイプ役となるビジネスの可能性に目を開かれるとともにライター稼業に首を突っ込んだ古川にとっても、アメリカで暮らすことは魅力的な選択肢だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
