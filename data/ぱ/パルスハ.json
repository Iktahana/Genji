        "examples": {
          "standard": [
            {
              "text": "レーダー探知機は、反射して戻ってきたパルス波を解析して対象物との距離を測る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "物理学の授業で、パルス波が媒質中を伝わっていく様子をシミュレーションした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "心電図のモニターには、心臓の鼓動に伴う規則的なパルス波が表示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "実顕地内のさまざまな物事に目がとまり、それがきっかけとなって神経回路をめぐるパルスはますます加速された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前319年にコルネリウス・ヒスパルスはカルデア人たちを追放し10日以内にイタリアを退去するように命令した。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "セム人、ハム人、モンゴル人と同じように、生まれながらの天分はギリシャより悪くはなかったが、知的なインパルスはアーリアン・ヒンズー人種には不足していた。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
