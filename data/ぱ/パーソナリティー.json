        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の明るいパーソナリティーは、周囲の人々を惹きつける魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームをまとめるためには、リーダーのパーソナリティーが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の小説は、登場人物のパーソナリティーが細やかに描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いよいよ進めばいよいよ哲学者のいわゆるパーソナリティー（わが国で普通にいう人格とは違う）の大を知る。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナリティーそのものだ。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜというにベルグソンの哲学に於てもＷ・ジェームズの心理学に於ても、問題は元来パーソナリティーにあったのであって、Ｊ・ジョイスやＭ・プルストにパーソナリティーのモラルを求めることは当然で又容易いことではないかと思えるからだ。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
