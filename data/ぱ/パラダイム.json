        "examples": {
          "standard": [
            {
              "text": "科学史におけるパラダイムシフトは、世界観を根底から変える出来事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この新しい技術は、従来のコンピューティングのパラダイムを覆す可能性を秘めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、物事を捉えるパラダイムが自分とは異なると感じ、議論が噛み合わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "だから逆に言えばロックが一番可能性を秘めたジャンルだと言えるわけで、音楽という観念のパラダイムを根本から破壊するような、そういう新しいサウンドがあたしたちに創造できたら最高ですね。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひょっとしたら今まで自分が疑うことなく信じてきた常識だとか世界観だとかパラダイムだとか、とにかくそういう類のものが全部偽物なのかもしれない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "に関するパラダイムについて、君は一体どう受けとめているのだろうか……。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、私は新しい土地を切り開いて他の研究を刺激したようなトピック（＊：パラダイム・シフト参照）を選ぶことにした。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
