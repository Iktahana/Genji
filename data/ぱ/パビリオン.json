        "examples": {
          "standard": [
            {
              "text": "万博会場には、各国が趣向を凝らしたパビリオンが立ち並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭園の中に立つ小さなパビリオンで休憩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その美術館には、期間限定で特別なパビリオンが設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ついに大パビリオンの端にたどり着いた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "パビリオンの中央にぽつんと立った私は、あの悍しい獣どもやそれらのじっとりとした視線から逃れられたことに胸を撫でおろした。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、パビリオンの壁に文字が現れた：――「これが我らが世界の歴史である。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
