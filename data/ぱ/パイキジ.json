        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "パイ生地（pie dough）を冷蔵庫で冷やし、バターが固まるのを待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、サクサクとした食感のパイ生地（pie dough）を作るのが得意だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このレシピでは、冷たい水とバターを使って、層状のパイ生地（pie dough）を作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "うっとりするほどの　パイきじ。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「パイきじの　かたくずれを　ふせぐ　やきがたが。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "上のオーヴンの　とびらを　あけると、　もくもくと　出てきたのは　こうばしい　子牛と　ブタももの　かおり、　みごと　きつね色の　パイが　のっかっていて　――　パイきじの　てっぺんに　あいた　あなから　ちいさな　かなものの　やきがたが　ちらり！",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "３わの　カラスが　パイきじを　もぐもぐ、　カササギが　やきがたから　肉じるを　じゅるり。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            }
          ]
        }
