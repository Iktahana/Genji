        "examples": {
          "standard": [
            {
              "text": "顧客体験を向上させるため、ウェブサイトのコンテンツのパーソナル化を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このサービスはユーザーの利用履歴に基づいて、情報のパーソナル化を図っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マーケティング戦略として、個々の顧客に合わせたメッセージのパーソナル化が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "端末はこれまでなかなか一人一台とはいかなかったが、小型化と低価格化を推し進めてパーソナル化を実現すれば、オフィスの作業効率をいっそう高めることができるだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型コンピューターを実際に使い、そして学びながら、パーソナルからコンピューターに出合ったタケシは面白い発見をしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
