        "examples": {
          "standard": [
            {
              "text": "その映画は濃厚なベッドシーンが話題になり、公開前から注目を集めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "リビングで家族と一緒に映画を見ていたら突然ベッドシーンになり、気まずい空気が流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "主演俳優はインタビューで、あのベッドシーンの撮影はとても緊張したと語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それはまあ一般に言えば人の秘密を盗み見るという魅力なんですが、僕のはもう一つ進んで人のベッドシーンが見たい、結局はそういったことに帰着するんじゃないかと思われるような特殊な執着があるらしいんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は今はもう実際に人のベッドシーンを見るということよりも、そんな自分の状態の方がずっと魅惑的になって来ているんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると次は秘密のなかでもベッドシーンの秘密に興味を持ち出した。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから秘密のなかでもベッドシーンの秘密が捜したくなって来る。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
