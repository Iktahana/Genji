        "examples": {
          "standard": [
            {
              "text": "「彼はベジタリアンだから、ディナーのメインは魚か野菜に変更してもらえる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ベジタリアン向けのメニューが充実しているレストランは、海外からの観光客にも人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "卵や乳製品は食べるタイプのベジタリアンとして、無理なく食生活を楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こうなったら　ベジタリアンにでも　なって　自分の　しっぽでも　かじるしかないわいな！",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間じゅうバター、チーズ、ミルクといった動物由来の食物を摂取していたため「ベジタリアン」というわけではなかったが。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
