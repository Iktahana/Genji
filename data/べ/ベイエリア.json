        "examples": {
          "standard": [
            {
              "text": "横浜のベイエリアは、夜になると観覧車や高層ビルのイルミネーションが美しく輝く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "若者に人気のレストランやカフェが立ち並ぶベイエリアは、週末はいつもデートを楽しむカップルで賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "シリコンバレーを含むサンフランシスコ・ベイエリアには、世界中からIT企業が集積している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "クパチーノ学区の科学展にこの一〇ビット並列加減算器を出品したウォズニアックは一等を獲得し、そのあとに開かれたベイエリア科学展では、年上のライバルたちに伍して三等に食い込んだ★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
