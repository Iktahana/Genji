        "examples": {
          "standard": [
            {
              "text": "アールグレイティーの独特で優雅な香りは、ベルガモットの皮から抽出されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "リラックスしたい夜には、ディフューザーにベルガモットのエッセンシャルオイルを数滴垂らす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女が愛用している香水は、トップノートに爽やかなベルガモットが香る大人の雰囲気のアイテムだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
