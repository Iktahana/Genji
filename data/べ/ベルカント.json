        "examples": {
          "standard": [
            {
              "text": "彼女が歌うオペラのアリアは、見事なベルカント唱法で観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "イタリアの音楽院に留学し、伝統的なベルカントの発声法を一から学び直す決意をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先生から「もっと喉を開いて、ベルカントの流麗なメロディラインを意識しなさい」と指導された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本で始めてイタリーのベルカント唱法を教えたのはサルコリィでした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュワルツの発声法は、ベルカント風にドイツ風を加味したもので、イタリー、フランスのオペラにもよかったが、ワーグナーにもまた我らが想像し得る最高の美しい表現を与えた。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
