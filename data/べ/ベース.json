    },
    "definitions": [
      {
        "index": 1,
        "gloss": "base",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この料理のスープのベースになっているのは、じっくり煮込んだ鶏ガラとたっぷりの香味野菜です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の小説は、実際にあった未解決事件をベースにして書かれているため、非常にリアリティがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "マヨネーズをベースに、ケチャップと少しのマスタードを混ぜて特製のオーロラソースを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ベースボール」は「野球」に完全に駆逐されてしまった。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソプラノがベースに聞こえたりうぐいすの声が鵞鳥のように聞こえるのでは打ちこわしである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールは定めて間だるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾をはたき落す猫を羨み讃歎する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば相対性原理とはどんな事か、マルキシズムとは何か、バロック芸術とは何、ベースボールとは何、ジャズとは何、そういうことが望みのままに早分りがすれば甚だ便利であり、また時代に適応する所以であるかもしれない。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる基線（ベースライン）が土台になって、その上にいわゆる一等三角点網を組み立てて行く、これが地図の骨格となるべき鉄骨構造である。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大将「いいか次はベース。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベース、一、の号令でこの形をつくる。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "果樹整枝法その二、ベース一。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエーベンタールのベースとちがう所は手とからだとが一平面内にあることにある。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベースピラミッド　カンデラブルまたパルメット　エーベンタールことにも二つの　コルドンと棚の仕立に　　　いたりしにひかりのごとく　降り来し天の果実を　　　いかにせん。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では仙台にこの人形を売る店が二軒位しかないそうですが、そこへ行ってみると、水兵だとか、ベースボールのバットを持っているものだとかいうものばかりで、一向面白くない。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ光線　電車会社の大きなベースボールグラウンドが、村外れの松原を切り開いて出来た。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本物のベースボールというものは、戦争みたように恐ろしいもので時々｜怪我人が出来る。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "松浦先生は……しかしベースボールの方が気にかかっていたかして、そのまま自転車に乗って大学を出たらしかった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにまた遠く、遠方からの喇叭のやうに、錆ある朗らかのベースは鳴りわたる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにかの物倦げなベースは夢を語る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他運動と云っても、当時は未だベースボールもなく、庭球もなかったから、普通体操位のもので、兵式体操はやらなかった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十歳まで大学に通ってベースボールをやる必要なんか無論ないよ」「其日庵という俺の雅号の由来を知っているかい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新文化の最も目ざましい表象として維新時代の夢のまださめ切らなかった生徒たちの心に強い印象と衝動を与えたものはベースボール、フートボール、クリケット、クロケーそれからボートレースなどの新遊戯であった。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まいた種のうちでもクリケットやクロケーは風土に合わなくてじきにしおれて枯れてしまったが、ベースボールとボートレースはのびのびと生長した。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベースには蓆の切れ端やぞうきんで用が足りた。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして過去のベースを逆回りして未来のホームベースに到着する夢を見ていることであろう。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールはさだめてまだるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛾をはたき落とす猫をうらやみ賛嘆する心がベースボールのホームランヒットに喝采を送る。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "参考図書の類を作る際は、紙ベースでもいち早くコンピューターの利用が進んだとはいえ、データを電子本の形式に整える際には手間がかかったでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、ハイパーカード二・一をベースに開発された Expanded Book は、紙の本のイメージを忠実になぞったものとなった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "base (e.g. military)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "沖縄には大規模なアメリカ軍のベースがあり、周辺には英語の看板を掲げた店が多く並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "南極観測隊は、昭和基地をベースにして内陸部の氷床調査へと出発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "戦闘機は任務を終えると、速やかに所属するベースへと帰還していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "base",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "野球のルールでは、ランナーは必ず一塁から順番にベースを踏んで回らなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "際どいタイミングだったが、ランナーの手が先にベースに触れていたので判定はセーフだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は盗塁を成功させるため、投手のモーションを完全に読み切って次のベースへ向かって走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
