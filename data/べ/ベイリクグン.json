        "examples": {
          "standard": [
            {
              "text": "彼は高校を卒業した後、米陸軍に志願してパラシュート部隊に配属された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "米陸軍の最新鋭の戦車が演習場を走行する様子は、圧倒的な迫力があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ジョージア州には米陸軍の広大な訓練施設があり、日々多くの兵士が厳しい訓練に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方ペンシルベニア大学のジョン・Ｗ・モークリーとＪ・プレスパー・エッカートは、米陸軍弾道研究所の依頼を受けて、一九四三年から真空管を使った計算機の開発に着手し、一九四六年にＥＮＩＡＣの稼働にこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリッピンの米陸軍軍医団に勤めていた医師たちも同様な観察をした。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
