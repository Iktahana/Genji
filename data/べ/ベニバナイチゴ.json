        "examples": {
          "standard": [
            {
              "text": "高山の登山道脇で、可愛らしい紅花苺の赤い花が咲いているのを見つけて写真を撮った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "夏の終わりに山へ入り、甘酸っぱく熟した紅花苺の実を少しだけ摘んで味わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "高山植物の図鑑で、先週のハイキングで見かけた花が紅花苺だったことを確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "紅花苺や大桜草の紅い花、虫取菫の紫の花など、彼を見此を眺めて時の移るを知らず、或は初めて雪渓を辿る面白さに、脇目もくれずひた上りに上って行く人もある。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い紅の花を持った大桜草やベニバナイチゴの群落が、晴れの饗宴を飾る卓上の花のように私達の石の食卓を飾って呉れる。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
