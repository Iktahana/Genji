        "examples": {
          "standard": [
            {
              "text": "息子がまだ靴紐を結べないので、ベルクロのついたスニーカーを新調してあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "キャンプ用のテントの入り口は、ジッパーだけでなくベルクロでも留められるようになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "フリースジャケットの袖口にあるベルクロをきつく締め、冷たい風が入り込むのを防いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『失礼ですが、あなたはツベルクローゼじゃありませんか』　私は、『え』　と詰って、『まさか、――私が肺病に見えますか』　と、聊さか憤然として答えた。",
              "citation": {
                "source": "腐った蜉蝣",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツベルクローゼの如く見よ。",
              "citation": {
                "source": "夜の道づれ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
