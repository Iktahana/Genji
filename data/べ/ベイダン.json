      {
        "index": 1,
        "gloss": "Heian-period pastry made of duck or goose eggs mixed with vegetables boiled and wrapped in mochi which is then cut into squares",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
