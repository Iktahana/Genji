        "examples": {
          "standard": [
            {
              "text": "高知の宴席に招かれた際、底が尖っていて飲み干すまで下に置けないべく杯を渡されて焦った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お座敷遊びの罰ゲームとして、なみなみと注がれたべく杯を一気に飲み干す羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "土産物屋で、天狗やおかめの顔が底に彫られた面白い形のべく杯を見つけて思わず買ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お十夜は何をおかしく感じたか、周馬の顔をみて苦笑をもらし、それを隠すべく杯をさした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
