          "standard": [
            {
              "text": "バーベキューの火の中にアルミホイルで包んだジャガイモを入れ、ホクホクのベイクドポテトを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ステーキの付け合わせとして出てきたベイクドポテトに、たっぷりのサワークリームを添える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプの夜、焚き火で焼いたシンプルなベイクドポテトが何よりも贅沢なご馳走に感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "駅を降りるとウエンディーズに寄ってベイクドポテトを食べた後、『テアトル新宿』のビルに入って四方が鏡になっている洒落たエレベーターに乗った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
