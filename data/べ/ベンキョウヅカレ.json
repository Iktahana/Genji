        "examples": {
          "standard": [
            {
              "text": "娘はひどい勉強疲れのようで、夕食を食べるなりソファに倒れ込んで眠ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "受験のストレスと勉強疲れからか、最近彼は些細なことでもすぐにイライラするようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "勉強疲れを癒やすために、今度の週末は思い切って参考書を置いて温泉にでも行こう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "勉強疲れで過敏になっている草川巡査の神経の末梢に、一知青年の叫び声は、あまりに手強く、異常に響いたのであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
