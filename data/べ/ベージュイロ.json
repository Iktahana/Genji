        "examples": {
          "standard": [
            {
              "text": "新しいソファは、どんな部屋のインテリアにも馴染みやすいベージュ色を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "泥はねが目立ちにくいかと思って買ったベージュ色のズボンだが、かえって汚れが気になってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "愛犬の毛並みは、太陽の光に当たると柔らかいベージュ色に輝いて見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　そして、ベージュ色に細い赤線をあしらった地味なスウェータアに包まれている宏子の胸のあたりを眺めまわした。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏子は、ベージュ色のスウェータアの下のところを、組み合わせた手へ巻き込むような工合にして、頭を下げ板の目かずを数えるように靴下の上にソックスを重ねてはいた自分の足のたけだけを一直線の上にかわるがわる踏んで狭い場所をゆきつ戻りつしている。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベージュ色に輝いている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
