        "examples": {
          "standard": [
            {
              "text": "彼女は本当に勉強熱心で、分からないことがあればすぐに自分で調べてノートにまとめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "勉強熱心な新人のおかげで、部署全体に「もっと新しい知識を吸収しよう」という良い空気が生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はスポーツだけでなく、戦術の分析や栄養学の知識を取り入れることにも勉強熱心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "勉強熱心な彼は、「是非私に庖丁を持たせてくれ」　と懇願するので、「ではお願いしましょう」　と料理方を頼んだ。",
              "citation": {
                "source": "山椒魚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
