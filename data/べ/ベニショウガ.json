        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "牛丼屋に入ると、必ずたっぷりの紅しょうがを乗せてから食べるのが私のこだわりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "屋台で買ったたこ焼きには、青のりと一緒に刻んだ紅しょうがが散らしてあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "冷やし中華の彩りと酸味のアクセントには、やはり紅しょうがが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "黄色く押しのかかった古漬の沢庵や、浅漬のかぶや、つかりすぎて酸っぱい胡瓜や、紅しょうがや、時には中国料理で使う唐がらし漬のキャベツまでも入れる。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりに自分で作った弁当、いり玉子にハムのきざんだの、配給のアミの佃煮を煮なおし、とろろこんぶと小蕪の漬物、紅しょうがもそえた。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
