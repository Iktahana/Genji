        "examples": {
          "standard": [
            {
              "text": "庭のフェンスに紅花隠元の種を蒔いたら、夏には見事な赤い花のカーテンができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "秋に収穫した大きく育った紅花隠元の豆を使って、甘い煮豆を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "農業高校の実習で、つるがどんどん伸びる紅花隠元の支柱立ての作業を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこでその富士川って学士も念のために、わざわざ清滝の切支丹寺まで行って調べて来たんだそうだが、すっかり野生になっているので、いよいよ紅花隠元に似ていたという。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから今の紅花隠元を蒔くふりをして実は普通の隠元豆を蒔いといたんだよ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
