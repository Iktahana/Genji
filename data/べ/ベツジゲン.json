        "examples": {
          "standard": [
            {
              "text": "プロのスポーツ選手の動きは、私たち素人とは別次元だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼の数学的才能は、クラスの誰とも比較にならない別次元のものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの高級レストランのサービスは、ファミレスとは全くの別次元で驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "部屋のなかにあるものをひとつひとつ観察していくと、そのひとつひとつから、もはやどうにも取り返しのつかないほどに遠い別次元の時間の奥から、かつてここにいた自分の面影が霊気のように立ちのぼり、部屋のなかを満たしていくのをホミは茫然と見守った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
