        "examples": {
          "standard": [
            {
              "text": "ハワイやグアムを離れ、米本土へ向かう飛行機は、広大な太平洋を何時間もかけて横断する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "巨大なハリケーンがフロリダに上陸し、米本土の広範囲に甚大な被害をもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は米本土の大学に留学し、4年間カリフォルニアで建築学を基礎から学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大気の汚染は広い範囲にわたるもので、アフリカの埃が米本土に飛ぶことがしばしばある。",
              "citation": {
                "source": "ハワイの色",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三八年にオルソン・ウェルスが〈火星人の米本土侵入〉というラジオ・ドラマを放送したが、あまり効果がありすぎて、卒倒したり窓から飛降りたりしたひとがあってたいへんな騒ぎだったそうだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
