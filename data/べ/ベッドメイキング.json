        "examples": {
          "standard": [
            {
              "text": "ホテルにチェックインしたら、完璧なベッドメイキングに思わず感心してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "毎朝起きたらすぐにベッドメイキングをするのが、彼なりの一日の始まりの儀式だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は客室清掃のアルバイトをしていて、ベッドメイキングのスピードがとても速い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "即座に洗面、着替え、ベッドメイキング。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "カメラ位置を変えてのクロースアップ、ベッドメイキングの絵などが撮られた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
