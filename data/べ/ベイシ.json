        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨日の米紙の一面で、日本発の新しい技術が大きく取り上げられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "米紙の記者が、都内のスタートアップ企業に密着取材を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は毎日、インターネットを通じて米紙に目を通し、世界の動向をチェックしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小初は子供のうち甘いものを嫌って塩せんべいしか偏愛して喰べようとしなかった自分を思い出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『でもな、國へ行けば、娘衆もあるしな、親類もあんべいし……死んだものをいくら考へたッて仕方がねえだでな。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
