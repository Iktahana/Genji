        "examples": {
          "standard": [
            {
              "text": "彼は、昔気質のべらんめえ口調で、周りを圧倒する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "落語家が、登場人物のキャラクターを出すためにべらんめえ口調を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "現代では、べらんめえ口調を聞く機会は少なくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あれで巴里歸りだなどゝ片腹痛いといふ樣なことが幾分職人肌のべらんめえ口調が交りつゝ語られた。",
              "citation": {
                "source": "記憶のまゝ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "主旨賛成、但、彼女の粗野なべらんめえ口調にはほとほと参ってしまった。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
