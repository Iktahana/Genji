        "examples": {
          "standard": [
            {
              "text": "近所のコンビニで働いているベトナム人の青年は、いつも笑顔で丁寧な接客をしてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "技能実習生として来日したベトナム人の若者たちが、建設現場で一生懸命に働いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私のクラスには、真面目で努力家なベトナム人の留学生が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だから私たちも、ここにいる間は別に中国人やベトナム人を装う必要なく、わたし達は、日本人だぞと大ぴらに本国の国籍を表明していて一向さしつかえないのであった。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
