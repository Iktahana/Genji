          "standard": [
            {
              "text": "古文書は、羊皮紙ではなく、上質なベラムに記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の聖書は、ベラムに書かれ、美しい挿絵が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このノートは、表面が滑らかなベラム紙を使用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この本の最も新鮮で美しいコピーはベラム紙のもので以前はミード博士の所有であったが今では大英博物館にあり、この絵はそれから撮影したものである。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのテーブルには古い手稿やベラム革のカバーのついた化石じみた古書が所狭しと散らばっていた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
