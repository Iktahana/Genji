        "examples": {
          "standard": [
            {
              "text": "米州連合の創設は、南北アメリカ大陸の国々が連帯を深める重要な第一歩となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "現在の米州機構は、かつての米州連合を前身として発展してきた組織である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その歴史的な条約は、ワシントンにある米州連合の本部ビルで署名された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ラテン・アメリカの諸国は人種的にも経済的にも概して合衆国よりも欧州大陸と親善の気持を持っているにも拘らず、第一次欧州大戦以後は急速に米州連合体の成立に向いつつある事は即ち歴史の必然性である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
