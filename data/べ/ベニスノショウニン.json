        "examples": {
          "standard": [
            {
              "text": "高校の文化祭で、演劇部がシェイクスピアの「ベニスの商人」を現代風にアレンジして上演した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "シャイロックの裁判のシーンは、「ベニスの商人」の中でも最も緊張感が高まる場面だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "英語の授業で、「ベニスの商人」の有名な台詞の暗唱テストがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ましてやその他の月卿雲客、上臈貴嬪らは肥満の松風村雨や、痩身の夷大黒や、渋紙面のベニスの商人や、顔を赤く彩ったドミノの道化役者や、七福神や六歌仙や、神主や坊主や赤ゲットや、思い思いの異装に趣向を凝らして開闢以来の大有頂天を極めた。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベニスの商人、史上有名な貯蓄の才は、あながちシャイロックのみではあるまい。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塗りの胴に、白銀の船首を飾った華奢なゴンドラは、ベニスの商人の豊かな日を偲ばしめる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ベニスの商人」のポーシャ。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は死んじまう……」「ははあ、察するところあなたは“ベニスの商人”の物語に読み耽けられたんだな。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつしはいままでに舞台を踏んだ中じや一番みごとなチューバル（「ベニスの商人」に登場する端役）だつたぜ。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
