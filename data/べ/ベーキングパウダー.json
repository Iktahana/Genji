        "examples": {
          "standard": [
            {
              "text": "パンケーキをふわふわに膨らませるには、ベーキングパウダーが欠かせません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "賞味期限切れのベーキングパウダーを使うと、スポンジケーキがうまく膨らまない原因になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "小麦粉とベーキングパウダーを合わせて、ダマにならないようにしっかりふるっておいてね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "粉が大サジ六杯だと砂糖が中匙六杯さ、それに塩が小匙一杯にベーキングパウダーが小匙二杯さ」大原「ベーキングパウダーとは何だね」小山「即ち焼粉さ、西洋菓子の膨らんでいるのはこの粉が入るからだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ジンジャービスケットは玉子三個、砂糖四杯、バター大匙三杯、を能く掻混ぜ生姜粉大匙一杯半、メリケン粉大匙十杯、ベーキングパウダー茶匙二杯、モラッセス即ち砂糖蜜大匙四杯を加えて能く混ぜ牛乳を入れて好い加減にこね展し棒にて延ばし前法の如くに焼くなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に篩の中へメリケン粉を大匙五杯にベーキングパウダー即ち焼粉を大匙一杯｜入て篩出します。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
