        "examples": {
          "standard": [
            {
              "text": "地元の有力政治家が、知り合いの業者が公共事業を受注できるよう便宜を図ったという疑惑が浮上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "車椅子の利用者がスムーズに移動できるよう、主催者側が優先エレベーターの使用など特別な便宜を図ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "留学生が日本の生活に早く馴染めるよう、大学のサポートセンターがあらゆる面で便宜を図っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私としては出来得るかぎりの御便宜を図るでありましょう。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはなんなりと四郎……君のために便宜を図るを厭わぬつもりじゃ。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、所長は看守長をよんで、明智をひきあわせ、できるだけ、べんぎをはかるように言いつけ、看守長は、さっそく、明智を、四十面相の独房へ、あんないしました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
