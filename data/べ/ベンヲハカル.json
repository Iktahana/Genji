        "examples": {
          "standard": [
            {
              "text": "新しい駅ビルには、車椅子利用者の便を図るためにスロープと多目的トイレが設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通勤客の便を図るため、鉄道会社は朝のラッシュ時に増便を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光客の便を図り、主要な観光スポットを巡る無料シャトルバスの運行が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "右の村名は現在多くその称を異にし、或いは分合しているのもあるが、前後対照の便を図る為と、一つは現在の名をわざわざ吹聴するの必要を認めぬのとより、ことさらに旧名を掲げておいたのである。",
              "citation": {
                "source": "特殊部落の人口増殖",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年かする内に、私は自分の経験を――類似症例及び関連する民間伝承と共に――明確に総括して出版し、以て真摯な学究の便を図るべきではないかと思うようになった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
