        "examples": {
          "standard": [
            {
              "text": "ベルリン陥落により、第二次世界大戦におけるヨーロッパ戦線は終結へと大きく舵を切ることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史ドキュメンタリー番組で、1945年のベルリン陥落時の緊迫した街の様子を映した映像が流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "将軍たちは地下壕に立てこもり、ベルリン陥落が避けられない事態であることを悟って絶望した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この空襲と宮本の網走行の異常な伴奏として五月二日のベルリン陥落、つづいてドイツ無条件降伏が伝えられた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯ベルリン陥落乃至はドイツ休戦申入れをめぐって、英米ソの間にまた一波瀾ありそうだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
