        "examples": {
          "standard": [
            {
              "text": "戦後の日本において、食生活やライフスタイルの米国化は急速に進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "グローバル化に伴う世界の米国化に対し、伝統文化を守ろうとする反発の動きも各地で見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若者の間で英語交じりの会話が増えている現状を、言語の米国化だと嘆く知識人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "痛ましくも米国化すべし。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
