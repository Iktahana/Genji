          "standard": [
            {
              "text": "健康診断でビール腹（ビールばら）を指摘され、食生活の改善を決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昔からのビール腹がなかなか引っ込まないと嘆いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "見て、彼もすっかりビール腹になっちゃったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お尻の丸味を床几の上に、どつかと据ゑてるブルジョワは、はでな釦を附けてゐるビール腹したフラマン人、オネン・パイプを嗜んでゐる、ボロリボロリと煙草はこぼれる、――ねえ、ホラ、あれは、密輸の煙草！",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            }
          ]
        }
