        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昭和の時代、丸の内界隈を颯爽と歩くＢＧたちは都会で働く女性の憧れの的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母が若い頃は「ＢＧ」という言葉が一般的で、その後「ＯＬ」という呼称に変わったらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ドラマの中で、レトロな制服を着たＢＧたちが給湯室で噂話に花を咲かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三日後、ニューヨークは五番街のティファニイで日本人ギャルの「ウッソー、ホントにー」をＢＧＭに、慶子ちゃんの品定めに付き合っているうちに、突如体中のリンパ腺がトラフグを怒らせたように膨れ上がり、猛烈な悪寒とともに下腹が鳴り始める。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジョンは、ＢＧＭにはしないんだ」「ジョンて、ジョン・レノンのことですか？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "５秒前、４秒前、３、２、１、キュー」　サイバネティック・スキゾイドの『インビジブル・スレッド』がＢＧＭに流れてくる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "５秒前、４秒前、３、２、１、キュー」　ＢＧＭに『インビジブル・スレッド』。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の顔が画面に入るか入らないかぐらいのときにＢＧＭスタートだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変わらずＢＧＭはボリュームいっぱいにかけてあるにもかかわらず、とても静かな店だと隼人は感じた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上一流ミュージシャンの演奏による数億種類ものＢＧＭの中から、コンピュータがその場にふさわしい曲を適宜に選択するので、気分はもうファンタジーランドの主人公！",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、このＢＧＭは何なのだ。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの間にかＢＧＭは聞き慣れた軽快なテンポの音楽に変わっている。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからともなくロマンチックなＢＧＭが流れてくる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついさつきまでランチ・タイムを愉しんでいたＢＧやホワイト・カラー達もみんな今は引き揚げていつてしまいあとには濡れ手で銭勘定の貸ボート屋ののどかな浮世哲学。",
              "citation": {
                "source": "水の上",
                "author": "安西冬衛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
