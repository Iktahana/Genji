        "examples": {
          "standard": [
            {
              "text": "彼は自らをビートニクと称し、定職に就かず詩を書きながら各地を放浪している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな古いヒッピーやビートニクみたいな格好して、どこへ行くつもりだい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒を離れ、ビートニクのように自由な精神で生きることに憧れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジャニス・ジョプリンは、自分のことをビートニクだと信じている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女によると、ヒッピーは、世の中を改良していこうとしている人たちであり、ビートニクは、世の中とは関係なく、フィーリングの解放によってその瞬間を楽しむ人たちなのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
