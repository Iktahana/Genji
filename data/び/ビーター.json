        "examples": {
          "standard": [
            {
              "text": "卵白を泡立てるには、ハンドミキサーのビーターを高速で回すのが一番早い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洗ったばかりのビーターを本体にカチッと差し込み、ケーキ作りを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あら、ビーターに生地がたっぷり付いたままじゃない。もったいないわよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ではアルファー」「アルファー」「ビーター」「ビーター」「ガムマー」「ガムマーアー」「デルター」「デールータァーアアア」　実に不思議です。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーターミンＡがどうのＢがどうのもあるものかい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
