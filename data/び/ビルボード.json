        "examples": {
          "standard": [
            {
              "text": "幹線道路沿いに設置された巨大なビルボードには、最新の広告が掲示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自分のデザインした広告がビルボードに掲載されることを夢見ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あのビルボード、すごく目立つね！」と、街を歩く人が感心していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "『ザ・ブリティシュ・インヴェイジョン』なんていう四巻ものとか、ずばり『ビルボード・トップ40』なんてオムニバスもあります。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ビルボード』誌が一九四九年にリズム・アンド・ブルースをレイス・ミュージック（黒人音楽）と呼ぶことをやめた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
