        "examples": {
          "standard": [
            {
              "text": "その巨大プロジェクトには、総額で5ビリオン（50億）ドル以上の予算が投じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界人口が8ビリオンを突破し、食糧不足への懸念がさらに強まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のYouTubeチャンネルの総再生回数は、ついに1ビリオンを記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ついに大パビリオンの端にたどり着いた。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "パビリオンの中央にぽつんと立った私は、あの悍しい獣どもやそれらのじっとりとした視線から逃れられたことに胸を撫でおろした。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、パビリオンの壁に文字が現れた：――「これが我らが世界の歴史である。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
