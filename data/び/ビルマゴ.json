        "examples": {
          "standard": [
            {
              "text": "ミャンマー（旧ビルマ）を旅行するなら、簡単なビルマ語の挨拶を覚えておくと良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、ビルマ語の辞書を片手に、古文書の解読を試みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館で、古代ビルマ語で書かれた石碑を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "またビルマ語で「コーンダーン」は小さき山脈。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英独仏伊西の各国語に通じ、少しくビルマ語をも解す。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
