        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ロンドンの象徴であるビッグベンは、夜になると美しくライトアップされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ビッグベンの鐘の音は、ロンドン市民に時を告げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ビッグベンの近くで観光客が写真を撮っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時頭の上でビッグベンが厳に十時を打ち出した。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大柄で赤ら顔の扇動家が膨れ上がった無言の群衆を見渡し、ビッグベンの明かりを指差した。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
