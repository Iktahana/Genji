        "examples": {
          "standard": [
            {
              "text": "オープンソースのオペレーティングシステムとして、BSD（ビー・エス・ディー）系のOSが知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くのサーバーで、安定性の高いBSD（Unix系OS）が採用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "BSDって、FreeBSDとかNetBSDのことかな？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たくさんの方言の生まれたＵＮＩＸの中で、本家のＡＴ＆ＴのシステムＶとカリフォルニア大学バークレー校で育ったＢＳＤは二大勢力となっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが技術屋にはＢＳＤの評価が文句なく高いことからこちらを取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多くの方言が生まれていたＵＮＩＸに関しては、カリフォルニア大学バークレー校のＢＳＤと本家であるＡＴ＆ＴのシステムＶ、さらにマイクロソフトがパーソナルコンピューター用に開発していたＸＥＮＩＸを統合して決定版を作る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
