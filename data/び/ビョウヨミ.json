        "examples": {
          "standard": [
            {
              "text": "ロケット発射の秒読みが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験の開始まで、もう秒読み段階に入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ゴールまで残りわずか、選手たちは秒読みの状態でラストスパートをかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "発射の準備が全部完了して、いよいよ最後の秒読みにとりかかった。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時を刻む秒読みのような音であり、色であり、文字であって、人は最後の列車に乗りそこなうのではないかというようなせかせかした不安定な気分にとらわれるのである。",
              "citation": {
                "source": "年の瀬の音",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをもし舞文曲筆だなどという人があったら、その人こそ年末の秒読みを感ずることのない、幸福なしかし恵まれざる楽天家というほかはないでしょう。",
              "citation": {
                "source": "年の瀬の音",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
