        "examples": {
          "standard": [
            {
              "text": "ランチに、揚げたてのビーフカツレツ定食を食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母が作るビーフカツレツは、いつもジューシーで柔らかい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この洋食屋さんのビーフカツレツは、デミグラスソースとの相性が抜群だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "隣の席に、七十余りのおばあさんが、これは皿の中のビーフカツレツらしいものを、両手に一つずつ持った箸の先で、しきりにつっついているが、なかなか思うようにちぎれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルバー地下へ、ビーフカツレツにする、不味。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
