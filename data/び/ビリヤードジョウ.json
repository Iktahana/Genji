        "examples": {
          "standard": [
            {
              "text": "昔ながらのビリヤード場には、独特の静寂とチョークの粉の匂いが漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "放課後、学校の近くのビリヤード場に集まって時間を潰すのが日課だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのビリヤード場は最新のテーブルを完備しており、プロの大会も開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方ノーラン・ブッシュネルはミニコンピューターではなく、ボーリング場やビリヤード場の隅に置けるような小さなシステムにこうしたゲームを収めたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サニーベイルのビリヤード場にピンボールのマシンと並べてためしに置かせてもらうと、ポングには順番待ちの列ができ、コインボックスはたちまち硬貨でいっぱいになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
