          "standard": [
            {
              "text": "駅前で塾のビラ配りのアルバイトを始めたが、受け取ってもらうのは意外と難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は通行人の邪魔にならないよう配慮しながら、丁寧にビラ配りを行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "選挙期間中ということもあり、至る所で候補者の支援者がビラ配りをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あすこの角の所に、まだ人通りも少い朝っぱらから、真赤なとんがり帽に道化服の、よく太った広告ビラ配りが、ヒョコンと立っていたのです。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
