        "examples": {
          "standard": [
            {
              "text": "結局、面倒な仕事は彼が貧乏くじを引くことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「なんで俺ばっかり貧乏くじを引くんだよ！」と彼は不満を漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のプロジェクトでは、私は完全に貧乏くじを引いた気分だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今まで新官僚のせいだと思っていた政友会のメンバー達は、今度は鈴木総裁のせいで貧乏くじを引くのだと気がつき始めた。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう席で一人早く座を立つのは貧乏くじを引くようなものである。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
