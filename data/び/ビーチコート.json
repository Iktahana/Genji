        "examples": {
          "standard": [
            {
              "text": "水着の上にビーチコートを羽織れば、そのまま街中の売店まで歩いていける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風の強い海辺では、防風性の高いビーチコートが一枚あると重宝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このビーチコート、パイル地だから濡れた体で着てもベタつかないんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "色の褪めたビーチコートを引っかけた青年団員が飛んで来て、『すみませんが、この辺にいられた方は暫くお立ちにならないで下さい』　と、引止められた。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この杉林の端を真直によこぎって台所の方から海へゆく白と水色の太いしまのビーチコートが見え、美しい色に輝いた肉づきのいい脚が見えた。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
