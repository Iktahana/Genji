    "definitions": [
      {
        "index": 1,
        "gloss": "miso soup with pork or chicken (originally boned chicken chunks) with daikon, carrots, great burdock or sweet potatoes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い冬の朝、温かいさつま汁を飲むと体が温まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "故郷の母が作ってくれたさつま汁の味が懐かしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このさつま汁は、豚肉と野菜の旨味がしっかり出ていて美味しい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "月々貰っていた五円の小遣いから、毎日の電車賃と、閲覧券の費用とを引いた残りで、時々食っていた図書館の中の売店の六銭のカツレツや三銭のさつま汁のことまで、頭の中に浮んだ。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "海辺の人から浅蜊の乾したのを送つて貰つた時、さつま汁の豚肉代りにしたり、豆腐と煮たこともあつて、浅蜊はこんなにおいしい物かと思つてその一袋をたのしみながら食べた。",
              "citation": {
                "source": "ともしい日の記念",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ごちそうはさつま汁だった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごちそうはあたたかいさつま汁だった。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
