        "examples": {
          "standard": [
            {
              "text": "この浮世絵は三枚絵になっていて、並べると迫力ある情景が広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "壁に飾られた三枚絵の構図が、部屋全体に洗練された印象を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は貴重な江戸時代の三枚絵を、オークションで見事に落札した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "黒船渡来と浦賀の海防｜並に異人上陸接待の状を描ける三枚絵は髷と髯との対照、陣笠陣羽織と帽子洋服との配列｜寔にこれ東西文化最初の接触たり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弦楽のための三枚絵」はベイリー指揮カーティス室内楽団演奏（ビクターＪＨ七一―二）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
