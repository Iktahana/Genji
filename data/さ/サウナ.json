        "examples": {
          "standard": [
            {
              "text": "一日の疲れを癒すため、彼は週に一度はサウナに行く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サウナで汗を流した後は、冷たい水風呂に入るのが最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近は、自宅にプライベートサウナを設置する人が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "トコロガ、ミンナト　ハナレテ、オカアサンヲ　ナクシタ　カアイサウナ　コドモガ　ヘイニ　モタレテ　ヰマシタ。",
              "citation": {
                "source": "ウグヒスブエヲ　フケバ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ト、フシギサウナ　カホヲ　シマシタ。",
              "citation": {
                "source": "ミチコサン",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツモダト私ハ知ラズ知ラズ、気ガ遠クナツテシマフノデスガ、今夜ハサウナラナイ内ニ、ワザト魔法ニカカツタ真似ヲシマス。",
              "citation": {
                "source": "アグニの神",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "プクントフクレテ、オハナヲナラシ、今ニモナキサウナノデス。",
              "citation": {
                "source": "アヒルサン　ト　オネコサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カナシサウナ　チビスケハ　クビヲ　タレタママ、ジヨンノ　アトカラ　ツイテユキマシタ。",
              "citation": {
                "source": "こいぬ　の　ちびすけ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
