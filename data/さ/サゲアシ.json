          "standard": [
            {
              "text": "株式市場の「下げ足」が止まらず、投資家たちの間で悲観的な見方が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "不動産市場でも「下げ足」が見られ、住宅価格は徐々に下落している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "原油価格の「下げ足」は、産油国の経済に大きな影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして対手のことばが終ると、相手の誠意に対して下げ足りないような気持をもってふかく頭を下げて、『――御高義のほど』　と低い声でいう。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
