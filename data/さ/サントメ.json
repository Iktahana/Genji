        "examples": {
          "standard": [
            {
              "text": "サントメ島はギニア湾に浮かぶ火山島で、豊かな熱帯雨林とカカオの栽培で有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サントメの空港に降り立つと、湿り気を帯びた花の香りと潮風が同時に漂ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はサントメの小さな村で、地元の人々と一緒に伝統的な魚料理を囲んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "只今は聞かぬが吾輩幼時迄、サントメといふ綿布が有た。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "惟ふに外國から渡つたサントメ乃ち奧縞に擬して和製のサントメ乃ち京奧縞を作り出した時、サントメの留めに對して遣れなる動詞を用ひ、サンヤレ織と稱へたで無らうか。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
