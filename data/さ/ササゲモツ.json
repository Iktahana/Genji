        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "神主は、供え物を丁重に捧げ持つと祭壇に置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供は、もらった誕生日プレゼントを両手で大切に捧げ持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "優勝トロフィーを捧げ持つ選手の顔には、達成感が満ち溢れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さつきから捧げ持つてゐた鹿のフイレエ肉を、割合に調子好く手に載せて、滑かな床板の上を旨く歩いて来るのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "香炉を捧げ持つ手がわなわなとふるえた。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女王」といふのは毎歳の村祭に、山車の上に乗さつて花輪を捧げ持つ、子供達の王様を謂ふのでした。",
              "citation": {
                "source": "女王",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると目のところへ捧げ持つてお盆のフチを鼻柱へくッつけて静々と徐行してくる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろあなた、後向きでもお客様の鼻くそをほじる音まで聞き分けるてえ驚きいつた天才でさア」　酔客のケンケンガクガクずらりと並んだあちら側を、首だけだしたオバサンがお盆を目の高さに捧げ持つてナメクヂの速度で往復してゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
