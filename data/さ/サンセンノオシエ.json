        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "孟母三遷の教えは、親として常に心に留めておきたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が教育熱心なのは、三遷の教えを実践しているからだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会においても、三遷の教えが持つ意味は大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "氏より育ち、とか、孟母三遷の教えとか、人間は、環境に支配されるとか、朱に交わればとか、教育は第二の天性とか――いろいろの言葉があるが、私は、一体、大阪人なのか、東京人なのか？",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "親も、本心はこの生活の気楽を愛していたが、孟母三遷の教えを気にする面もあった。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
