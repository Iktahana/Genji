        "examples": {
          "standard": [
            {
              "text": "海外旅行に行きたいが、先立つ物がなくて困っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夢を実現するには、情熱だけでなく先立つ物も必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事業を始めるには、先立つ物としてまとまった資金が必要になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "而も、警察の手を遁れようと必死になつて、海の彼方コペンハアゲンの或るホテルに妻との部屋の豫約までしてあつたが、先立つ物は何より金、結局若男爵夫妻は父の金を盜出さうとした。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "轟　だけど、なにしろ先立つ物が無くっちゃ――。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
