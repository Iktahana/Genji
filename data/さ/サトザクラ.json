        "examples": {
          "standard": [
            {
              "text": "公園には様々な種類の里桜が植えられていて、春には美しい花を咲かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "里桜の並木道は、春の散歩にぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は里桜の可憐な姿を写真に収めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "荒川堤の桜の名所を如何にすべきか　東京の北郊荒川の堤には沢山な桜の樹が植わって居って、今日では里桜の唯一の名所となって居る。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山桜でない里桜の山奥に咲いていたのが、とくに珍しく感じられたわけである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
