        "examples": {
          "standard": [
            {
              "text": "中野サンプラザは多くの伝説的なコンサートが行われた聖地として、ファンの間で愛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駅前のサンプラザにあるカフェで、友人とお喋りをしながら午後のひとときを過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サンプラザの屋上から眺める夜景は隠れた名所になっていて、デートスポットとして人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "中央線に沿って進むとやがてサンプラザの白いビルが見えてくる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人はバイクを公園に停めて中野ブロードウェイに入り、本屋で立ち読みしたり喫茶店でコーヒーを飲んだりして時間を潰したが、ふとした気まぐれから中野通りを渡ってサンプラザの前を通ると“サイバネティック・スキゾイド”のポスターがたまたま目に入った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備室でさんざん注意を受けた後、隼人はサンプラザを出て四谷のアパートに戻った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
