        "examples": {
          "standard": [
            {
              "text": "カナダの国旗には砂糖楓の葉が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂糖楓から採れる樹液がメープルシロップの原料になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "秋には砂糖楓の葉が鮮やかな赤に色づく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "試みに砂糖楓の幹にナイフで傷をつけると、見る／＼血液のやうに樹液が滴り落ちる。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからさらに一層容易にそれをうるためには数本の砂糖楓を植えつけさえすればよく、それがそだつあいだのつなぎには今あげた品のほかのいろいろな代用品を用いることができるのを知った。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
