        "examples": {
          "standard": [
            {
              "text": "餅に砂糖醤油をつけて食べるのが、昔からの私の好物です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂糖醤油で味付けした団子は、素朴な甘さが魅力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は隠し味に砂糖醤油を使うと料理が美味しくなると言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "堺屋のおふくろは、焼いた掻餅を普通に砂糖醤油につけて僕に与えました。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横合より顔を出す伯母「満の処から何といって来たの」○胡桃餅は奥州の名物にて鬼胡桃の実をよく摺り豆腐を交ぜ水に溶きて砂糖醤油を交ぜその中へ搗いたばかりの餅を入れたるなり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
