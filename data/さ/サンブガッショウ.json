          "standard": [
            {
              "text": "中学校の合唱コンクールで、私たちは難易度の高い三部合唱の曲に挑戦することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ソプラノ、メゾソプラノ、アルトが重なり合う三部合唱のハーモニーが礼拝堂に響き渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一人一人の声は小さくても、三部合唱として合わせると厚みのある美しい音楽になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その後でまた他の唄を歌い、なお次に、友情と音楽と葡萄酒とに関するものを、三部合唱で歌った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
