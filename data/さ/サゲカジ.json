        "examples": {
          "standard": [
            {
              "text": "操縦士は、飛行機を急降下させるために「下げ舵」を強く効かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "船長は、波に逆らって進むため、「下げ舵」で船首を下げさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パイロットは、緊急着陸の準備として、慎重に「下げ舵」を操作した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "途端に、彼の乗っている司令機は、下げ舵をとって、静かに機首を左へ廻したのだった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、あそこに見える海底の丘かげへ、このメバル号をつけて、ゆっくり話をするとしよう」　カビ博士は、下方に見える乳房の形にこんもりもりあがった白い丘陵へ向け、下げ舵をとった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
