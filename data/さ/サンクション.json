        "examples": {
          "standard": [
            {
              "text": "国際社会は、核実験を強行した国に対し、経済制裁（サンクション）を科した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国連は、人道支援の妨げとなる行為に対し、厳しいサンクションを発動した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は会社の規則を破ったため、上司からサンクションを受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "個人が個人生活又は社会生活上の必要から獲得した習慣が、社会生活に於て、大体のサンクションを得ると夫が習俗になる。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日では法王に代って、このブルジョア大学の総長の印璽が神聖哲学や神聖科学にサンクションを与える。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
