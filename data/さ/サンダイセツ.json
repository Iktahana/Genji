        "examples": {
          "standard": [
            {
              "text": "戦前の日本では、四方節、紀元節、天長節の三大節には、学校や役所で厳かな式典が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "三大節の日は祝日として扱われ、街中には国旗が掲げられ、お祝いのムードに包まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔の三大節では、紅白の饅頭が配られたのが一番の楽しみだったよ」と曾祖母が懐かしそうに話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三大節、歌留多会、豆撒き、彼岸、釈迦まつり、雛と幟の節句、七夕の類、クリスマス、復活祭、弥撒祭なぞと世界的である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
