        "examples": {
          "standard": [
            {
              "text": "西日が眩しくて運転しづらかったので、サンバイザーを下ろして視界を確保した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゴルフに行く時は、日焼け防止と眩しさ対策のためにサンバイザーを愛用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そのサンバイザー、今日のテニスウェアにすごく似合っているね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ハイミスのミショノーは彼女の疲れた目をかばって、緑のタフタの汚らしいサンバイザーを着けていたが、それにくっついている真鍮の輪を見れば、天使も哀れさを感じながら遠のいてしまうように思われた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
