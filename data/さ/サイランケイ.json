        "examples": {
          "standard": [
            {
              "text": "採卵鶏は、効率的に卵を産むように品種改良されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の農場では、健康な採卵鶏を育てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "採卵鶏の飼育環境を改善することが、卵の品質向上につながる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それに対しヤマギシでは、ブロイラーも採卵鶏も、放し飼いに近い「平飼い」にされる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏舎は二五平方メートルずつに金網で区切られ、採卵鶏では一区画に一〇〇羽あまりの雌と四、五羽の雄を入れる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
