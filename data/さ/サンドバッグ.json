        "examples": {
          "standard": [
            {
              "text": "ストレス解消のために、毎晩サンドバッグを叩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボクシングジムには、様々な重さのサンドバッグが吊るされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はサンドバッグを相手に、シャドウトレーニングを繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と、また、男達のほうでも、ボクサアは、喰いつきそうな形相で、サンドバッグを叩いていますし、レスラアは、筋肉の塊りにみえる、すさまじさで、ブリッジの練習。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ軍の建物は、ひとつのこらず、鉄条網でかこわれ、サンドバッグがつまれ、歩哨が立てられていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
