        "examples": {
          "standard": [
            {
              "text": "議題について、賛成か反対か、皆の意見を聞かせてほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "住民投票では、その計画への賛成か反対かが問われることになるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は質問に対し、賛成か反対かを明確に答えなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんどの憲法でも、たとえばこの憲法をかえるときは、國会だけできめないで、國民ひとり／＼が、賛成か反対かを投票してきめることになっています。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこんどの憲法では、憲法を改正するときは、國会だけできめずに、國民が、賛成か反対かを投票してきめることにしました。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこれを國民に示して、賛成か反対かを投票してもらいます。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
