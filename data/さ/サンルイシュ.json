        "examples": {
          "standard": [
            {
              "text": "守備では、ショートが捕球した打球を正確に三塁手へ送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は強肩なので、三塁手としてチームに貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "三塁手は、ゴロやフライの処理はもちろん、ランナーの牽制も重要な役割だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「おれもゆく」「おれも……」　後藤という投手と浜井という三塁手はすぐにつづいた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "三塁手にはどんな球でもかならず止める橋本というのがある、かれはおそろしい勢いで一直線にとんできた球を鼻で止めたので後ろにひっくりかえった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一番に三塁手がミスする、ついでショートの青木、これもみごとにミスする、やりなおす、またミスする、三度、四度！",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
