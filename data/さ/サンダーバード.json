    "definitions": [
      {
        "index": 1,
        "gloss": "thunderbird (North-American indigenous mythical spirit bird)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "先住民の伝説に登場するサンダーバードは、羽ばたきで嵐を起こすと信じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の入り口に、巨大なサンダーバードの木彫りが守り神のように鎮座している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "北米の空高く舞うサンダーバードの姿を描いた神話は、今も語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「この島の友人が、こんな怪物を貸してくれたのよ」　一九五〇年代なかばの、フォード・サンダーバードのオープンだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイウエイが行きどまりになるところまで走りきり、崖の上にサンダーバードを停めた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
