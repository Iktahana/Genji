        "examples": {
          "standard": [
            {
              "text": "昔、この辺りは花街として栄え、三業地と呼ばれていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三業地には料亭や芸者置屋が軒を連ね、夜な夜な賑わいを見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_": "その建物は、かつての三業地の面影を今に伝える貴重な存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし工場の在る処へ、ほとんど埋立地に等しい少しばかりの土地を、数年かかってそこを地盤としている有名な代議士の尽力で許可してもらい、かさかさした間に合わせの普請で、とにかく三業地の草分が出来たのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある、三業地のカフエーで飲んだあと、人通りの少い待合の通りへ、足を踏み入れた時であつた。",
              "citation": {
                "source": "悪夢",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
