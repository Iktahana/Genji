        "examples": {
          "standard": [
            {
              "text": "顧客ニーズの多様化により、市場の細分化が進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "タスクを細分化することで、作業効率が向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "専門分野の細分化が進み、より専門性の高い知識が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "社会と個人との関係の追求の方向においても、ソヴェト文学以外のヨーロッパ文学の大勢は、第一次大戦後は益々個的細分化の方向しか辿れなくて、潜在意識の中に自己存在の核をさぐったり、主体的決定の放棄、自我の実践が空白の状態に実存を見ようとしたりすることしか不可能になった。",
              "citation": {
                "source": "「道標」を書き終えて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々たる建築、装飾の天才、芸術的表現における自然への忠誠、驚くべく進歩した化学技術、あらゆる種類の構造に見られる初期に発展した数学的および幾何学的センス、宗教の哲学に細分化した大量の文献、純粋科学および詩――全てこれらは起源が古代の霞の中にあることを考慮すればするほど、期待を大きく超える。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
