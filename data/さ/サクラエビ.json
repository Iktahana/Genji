        "examples": {
          "standard": [
            {
              "text": "駿河湾で獲れる桜海老は、春の味覚として有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "桜海老のかき揚げは、香ばしくてお酒によく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新鮮な桜海老を使ったパスタは、海の香りが口いっぱいに広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは鬼だが、顔の皮膚が丁度皮をむいた桜海老の通りの色をしている、へんに生々しい感じである。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が少しはだけているがその皮膚はやはり顔と同様桜海老である。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "細くそろってたえず銀色の光をはなして居るうろこをしっかりとまとって、赤いさんごの林の間、青こけのむした大岩の間、うす紅の桜海老、紫に光る海魚等の間を黒髪を長く引いて遊んで居る様子はこの内海をかざる花でした。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
