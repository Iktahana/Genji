        "examples": {
          "standard": [
            {
              "text": "旧暦の桜月には、各地で様々な春の行事が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "桜月は、桜の花が咲き誇る美しい季節だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は桜月に生まれたので、桜に特別な思い入れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海外の歌　　　　　　　　一「桜月夜で明るいじゃアないか！",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜月といううちでしることぞうにをたべた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "物がみんな銀鼠に見えるような、朧の桜月夜、女の悲鳴が聞えなくとも、何となく怪談めかしい道具立です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "殺され半蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「神田の平次だ」「あッ、銭形の――」　徳之助とお富は、死ぬはずの身を忘れて、町の家並に傾く桜月の薄明りの中に、江戸第一番の御用聞と言われた平次の顔を見直しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巾着切りの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは大山の麓といっていいほどだが、その大山の影も見えない夜霞が館の灯から物音までも朧にしていて、世間の耳目をそらすにはまたとないような桜月夜の――また“春眠暁ヲ知ラズ”の時刻だった。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
