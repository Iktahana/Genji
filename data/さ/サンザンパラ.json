        "examples": {
          "standard": [
            {
              "text": "彼は散々ぱら文句を言ったが、結局は従わざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "散々ぱら遊びまわった結果、宿題をやる時間がなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ああ、散々ぱら探したのに、鍵が見つからないよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "締めて十七か……ヤレヤレ……」「……様と一緒なら天国までも……って連中ばかりだ」「惜しいもんだなあ……ホントニ……おやじせえウンと云えあ、布哇へ着くまで散々ぱら蹴たおせるのになア」「馬鹿野郎。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々ぱら悩まされた五芒星呪文の正体が、ものもあろうに、ルイ十三世朝｜機密閣史の中から発見されたのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこたあさんざんぱら考えていらあ。",
