  {
    "uuid": "2139653e-25a7-5eff-8fb5-d4246f9b4693",
    "entry": "作字",
    "reading": {
      "primary": "さくじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
