        "examples": {
          "standard": [
            {
              "text": "シカは秋になると盛りがつき、雄同士が角を突き合わせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発情期に入り、盛りがついた動物たちは繁殖行動を始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "盛りがつく時期のオスは、特に攻撃的になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さかりがつくと彼は所かまわず尿水を飛ばして襖や器具をよごした。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この春まで犬を飼って居りましたが、さかりがつくと、どんなに厳重に繋いで置いても、綱を噛み切って、塀を押し破って飛出してしまいます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この春までは犬を飼つてをりましたが、さかりがつくと、どんなに嚴重に繋いで置いても、綱を噛み切つて、塀を押し破つて飛び出してしまひます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "戀患ひ",
                "note": "青空文庫"
              }
            }
          ]
        }
