        "examples": {
          "standard": [
            {
              "text": "彼の誕生日のお祝いに、私が彼に杯を差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司が部下を労って、静かに杯を差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「どうぞ、私に杯を差させてください。」と彼は丁寧に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は羽織の紋に杯を差すものがあろうとは思い掛けなかったのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて主人もご挨拶に罷り出でますでござりましょう」　二人の腰元はこう云って右門と山尾へ杯を差す。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（杯を差す）修　えゝ……（困つて人々の顔を見まはす）ミル　よしなさいよ、飲めやしない。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（杯を差す）お辻　私は、どうも鉄造が、怪しいと思つてゐるんですよ。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
