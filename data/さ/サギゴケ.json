        "examples": {
          "standard": [
            {
              "text": "日当たりの良い庭の片隅に、可愛い鷺苔が群生していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鷺苔の小さな花が、地面を覆うように咲いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "湿り気のある場所を好む鷺苔は、日陰でも元気に育つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お玉杓子が湧き、ちゃくとり――油虫の成虫――がわやわや云いながら舞いさわぐ下の耕地にはペンペン草や鷺苔や、薄紫のしおらしい彼岸花が咲き満ちて、雪解で水嵩の増した川という川は、今までの陰気に引きかえまるで嬉しさで夢中になっているようにみえて来る。",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけび、ぐみ、さぎごけ、きんぽうげ、じゅうにひとえ、たけにぐさ、きじむしろ、なんてんはぎなどを野からとって来て花壇に移した。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
