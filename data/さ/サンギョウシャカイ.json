          "standard": [
            {
              "text": "高度経済成長期を経て、日本は農業中心の社会から産業社会へと変貌を遂げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "産業社会においては、工場での生産活動が経済の中心となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "情報化社会の到来により、これまでの産業社会とは異なる価値観が生まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "六十六　商業社会や産業社会で、日頃｜大達者と立てられてその名前は家々の守護神の様に人の口に膾炙している大紳商、大紳士も、様は無い。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            }
          ]
