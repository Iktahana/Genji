        "examples": {
          "standard": [
            {
              "text": "満塁のピンチで、見事な三重殺が決まってチームは危機を脱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "野球の試合で三重殺を見るのは稀で、観客は大いに盛り上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「信じられない！まさかこの場面で三重殺が出るとは！」解説者が叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最近では新青年に訳載された「鼻欠け三重殺人」で、作そのものより作者のいっている言葉「解決は只一つあり、而してそれのみが可能なり」という一節に敬服した。",
              "citation": {
                "source": "ドイルを宗とす",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
