        "examples": {
          "standard": [
            {
              "text": "複数の候補者が乱立した結果、投票は散票となり、当選者がなかなか決まらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の選挙戦略は、特定の層だけでなく幅広い有権者から散票を集めることだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "野党が一本化できなかったため、散票が多く出て与党が有利になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "男の票は集まるかどうか、却つて、青年層の女を目標に、散票を集めるのがいゝぜ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学芸自由同盟の復活などが、何となく散票をかき集めるような気持がして、同盟という団体そのものの肉体的リアリティーがあまりピンと来なかったのは、ここにその原因があったと云ってよく、その復活が遂に実現出来なかったのも之によるのではないかと考えられる。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
