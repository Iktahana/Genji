        "examples": {
          "standard": [
            {
              "text": "催眠暗示によって、被験者は特定の行動をとるように誘導された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は催眠暗示にかかりやすい体質で、すぐに深い催眠状態に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "へえ、催眠暗示って、そんなに人の行動に影響を与えるものなんだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それらは常に古きものどもの催眠暗示によって制御され、可塑的で頑健な身体を時に応じて必要な手足や器官へと様々に変形させてきた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
