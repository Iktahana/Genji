        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "国歌に出てくる「さざれ石の巌となりて」は、長い年月を意味する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園には、悠久の時を経て形成された大きなさざれ石が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方の地層からは、珍しいさざれ石が発見されることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
