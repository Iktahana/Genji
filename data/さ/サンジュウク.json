    "definitions": [
      {
        "index": 1,
        "gloss": "triple handicap (esp. blindness, deafness and mutism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は幼い頃に三重苦を抱えながらも、懸命に学び、多くの人々に勇気を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヘレン・ケラーは三重苦を克服し、世界に希望のメッセージを伝えた偉人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三重苦の少年が音楽と出会い、新しい世界を切り開いた感動的な物語だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この病気は、私の経験からいつても、またひとの場合をみてゐても、常に、二重苦、三重苦によつて、その不幸が倍加されてゐるやうに思ふ。",
              "citation": {
                "source": "述懐",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "女史は目・耳・口が不自由で、新聞などは彼女を「三重苦の聖女」と呼びました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女史がその信頼するミス・タムスンの指、もしくは唇に軽く手を触れて莞爾として立つのを見る時、彼女は「三重苦の聖女」ではなくて「三重喜の聖女」でありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
