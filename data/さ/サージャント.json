        "examples": {
          "standard": [
            {
              "text": "サージャントの厳しい声が響き渡り、新兵たちは一斉に姿勢を正した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はサージャントとして、前線での補給作戦を指揮している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い映画に出てくるサージャントのような、厳格な上司に憧れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "トータル・アルバムなどということばは、『サージャント・ペパーズ』以後に生まれたものなので、このときは、だれもそんなふうには呼ばなかったが、だれの耳にも、アルバム全体を流れる、ある種の統一感が伝わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年からサロンにもステレオがおかれ、いまもビートルズの新作『サージャント・ペパーズ・ロンリー・ハーツ・クラブ・バンド』を流している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
