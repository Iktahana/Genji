        "examples": {
          "standard": [
            {
              "text": "山椒の皮を乾燥させて細かく刻み、薬味として使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方では、山椒の皮を使った独特の漬物が名物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山椒の皮には、香りと辛味のもとになる成分が豊富に含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "山椒の皮を春の午の日の暗夜に剥いて土用を二回かけて乾かしうすでよくつく、その目方一｜貫匁を天気のいい日にもみじの木を焼いてこしらえた木灰七百匁とまぜる、それを袋に入れて水の中へ手でもみ出すことです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと山椒の皮の粉のことだよ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの家の山椒の皮もはがれましたし、それに魚が、たびたび死んでうかびあがるというではありませんか。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒の皮を春の午の日の暗夜に剥いて土用を二回かけて乾かしうすでよくつく、その目方一貫匁を天気のいい日にもみじの木を焼いてこしらえた木灰七百匁とまぜる、それを袋に入れて水の中へ手でもみ出すことです。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山椒の皮を粉末にしたのに、胡椒と石灰と、灰と何やら得體の知れぬ南蠻物らしい藥品を混ぜ、大人の拳固ほどの一丸にして、雁皮に包んだのを相手の面上に叩き付け、たじろぐところを巧みに姿を隱すのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            }
          ]
        }
