        "examples": {
          "standard": [
            {
              "text": "インフレへの懸念から、多くの投資家が金に先物買いを入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は先物買いで成功し、短期間で財産を築き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "株式市場の先物買いが活発になり、株価が上昇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「これは」と思った人物が、事実人気者になってくると嫉妬に近い感情を抱くという先物買いのファン心理かとも思ったが、どうもそれとも違う。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
