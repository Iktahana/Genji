        "examples": {
          "standard": [
            {
              "text": "ドキュメンタリーを制作するため、撮影隊はアマゾン奥地へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "緊急取材のため、報道カメラマンの撮影隊が現地に派遣された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "撮影隊は、過酷な環境下でも粘り強く映像を記録し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ソブキノの撮影隊はカメラをもって、「トルクシブ鉄道」布設工事の現場へ、ヴォルガ地方の集団農場へ、バクーの油田へ、出かけて行く。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリウッドの撮影隊は、ワイメアに連日、カメラを据えつけている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影隊がハワイ島でも時間をかけて撮影するので、そのための最終的な調整に、僕は出かけていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "優子は撮影隊の宿泊している旅館へ戻る。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
