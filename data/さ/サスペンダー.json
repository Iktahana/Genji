        "examples": {
          "standard": [
            {
              "text": "ズボンがずり落ちないようにサスペンダーを使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はイベントで、カラフルなサスペンダーをアクセントにしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の映画に出てくる紳士は、よくサスペンダーを着用していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "水中花、ナフタリンの花、サスペンダー、ロシヤパン、万能大根刻み、玉子の泡立器、古本屋の赤い表紙のクロポトキン、青い表紙の人形の家。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の寝台からは縄のようになったサスペンダーと、大きな手がぶらさがっている。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を洗いに行って帰って来ると、娘さんは起きて着物を着替えていたが、わたしの上の寝台からは、まだサスペンダーがぶらさがっている。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
