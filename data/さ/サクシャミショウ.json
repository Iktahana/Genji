        "examples": {
          "standard": [
            {
              "text": "図書館で借りた古い物語は、作者未詳と書かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この詩は、作者未詳でありながら、時代を超えて読み継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターネット上には、作者未詳の素晴らしい作品がたくさんあるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに島津齊彬の命をうけて木村嘉平が作つた活字の最初のが歐文であつたと謂はれ、その他私には作者未詳の「八王子の活字」や、江戸で作られた「オランダ單語篇」がまたさうだつたといふことなど、考へあはせると、洋學と近代活字とは切つても切れぬ關係があらう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ作者未詳のもの、子供そのものの声が混入しているにちがいない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
