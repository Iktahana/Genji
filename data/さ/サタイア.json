        "examples": {
          "standard": [
            {
              "text": "彼の小説は、現代社会を痛烈に風刺したサタイアとして高く評価されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治家を揶揄するサタイア番組は、視聴者から絶大な支持を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この映画は、ブラックユーモアに満ちたサタイアだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "充分に達しなかったというのは、サタイアになったからだ。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "サタイアをもユーモアをも適宜に備ふるものは多くあれど、情熱を欠くが故に真正の詩人たらざるもの挙て数ふべからず。",
              "citation": {
                "source": "情熱",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "情熱なきサタイアリストの筆は、諷刺の半面を完備すれども、人間の実相を刻むこと難し。",
              "citation": {
                "source": "情熱",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春子』『怪物』『獅子』『親切な機械』『孝經』『頭文字』……擧げだしたら限りがないが、彼の作品には、きらきらしたサタイアと鮮やかな殺人美とが氾濫してゐると言へよう。",
              "citation": {
                "source": "三島由紀夫",
                "author": "ナルシシスムの運命",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
