        "examples": {
          "standard": [
            {
              "text": "あの鳥は山椒喰だ。可愛らしい声でさえずっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山椒喰は昆虫や木の実を食べる雑食性の鳥だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バードウォッチング中に、珍しい山椒喰の群れに遭遇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――そう思って、私はその頃自分の孤独をいたわるようにしながら一人歩きをしていたあの谷、この谷と思いをさまよわせているうちに、急に私は何かに突きあたったかのように、ついそこの谷の奥で山椒喰のかすかに啼いているのを耳に捉えた。",
              "citation": {
                "source": "朴の咲く頃",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
