        "examples": {
          "standard": [
            {
              "text": "家のカーテンを新調するために、インテリアショップで生地のサンプルブックを借りてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "壁紙のサンプルブックをめくりながら、リビングに合う色を家族で話し合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このサンプルブックの24ページにある青いタイルが、浴室のイメージにぴったりです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＣＤ−ＲＯＭの中には、『マルチメディアサンプルブック』（Mmbook）も入っている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ『本の未来』、『サンプルブック』とも、電子本の制作自体は私一人でやった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『サンプルブック』の中では、文中で触れている同窓会のスライド上映のために集められた写真を使った。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『サンプルブック』九ページの『陽の光は躍る』は、ちょうど四半世紀前に青戸高さん（ヴァイブ）、高野麻由美さん（ヴォーカル）、塚本俊明さん（ギター）とやったものだ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
