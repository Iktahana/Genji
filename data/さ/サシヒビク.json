        "examples": {
          "standard": [
            {
              "text": "彼の発言は、会議全体の雰囲気に大きく差し響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経営者の判断は、会社の未来に直接差し響くものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親の教育方針は、子供の成長に深く差し響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "田舎の自動車は遅いなんて悪口を書かれると早速営業に差し響くからね」「気を廻したもんだね。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に成績をあげるやうなことをすると、自分の芸術上の仕事にもさしひびくし、体力をも酷使するやうになるに違ひないので、その範囲を明かに判断してかかつてゐる。",
              "citation": {
                "source": "開墾",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその部下の職業が賤視されてみると、自然その部長の身分にもさしひびく。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦乱のために湯の客が少なくなっても、直ちに生活にさしひびくというようなことはないが、弱らされるのは天誅組の余類が、この竜神村のどこかに隠れているという嫌疑で、昨夜から引続いて、探索のあることであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "竜神の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
