        "examples": {
          "standard": [
            {
              "text": "朝日を浴びながら、差し潮がゆっくりと海岸に押し寄せてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師たちは差し潮の時間に合わせて、網を仕掛ける準備を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この湾では、一日二回差し潮が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "特にこの辺りは川幅も濶くかつ差し潮の力も利けば、大潮の満ち来る勢に河も膨るゝかと見ゆる折柄、潮に乗りて輾り出づる玉兎のいと大にして光り花やかなるを瞻る、心もおのづから開くやう覚えて快し。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
