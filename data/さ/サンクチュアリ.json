        "examples": {
          "standard": [
            {
              "text": "都会の喧騒を離れ、自然豊かな場所で心のサンクチュアリを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この森は絶滅危惧種の鳥たちのサンクチュアリとして保護されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私にとって、この静かな書斎こそが最高のサンクチュアリだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "僕ハフォークナーノサンクチュアリヲ読ミカケテイタノデ、チョット挨拶シテ書斎ニ上ッタ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
