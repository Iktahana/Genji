    "entry": "差し違える",
    "reading": {
      "primary": "さしちがえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
