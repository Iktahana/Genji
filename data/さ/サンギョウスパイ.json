        "examples": {
          "standard": [
            {
              "text": "ライバル企業に産業スパイが潜入し、機密情報を盗み出そうとした事件が発覚した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新技術の開発競争が激化する中で、産業スパイの脅威は増している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は産業スパイとして他社の技術情報を不正に入手しようと企てたが、未遂に終わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "＊ＩＢＭ産業スパイ事件を体験していたら、池田敏雄さんは次に何をやろうと言い出したろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二年のＩＢＭ産業スパイ事件は、見ることなく終わった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂村さんの舞台は、ＩＢＭ産業スパイ事件の後に回ってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のコンピューター界に現われた鬼才二人は、コンピューターのメディアへの変質とＩＢＭ産業スパイ事件という歴史の転換をはさんで、標準と独創を百八十度入れ替えて対置した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＢＭ産業スパイ事件以降、我々はこの問いに答えよと迫られている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとするとこの男はライバル会社の産業スパイかも知れない。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
