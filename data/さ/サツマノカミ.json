    "definitions": [
      {
        "index": 1,
        "gloss": "traveling while deliberately not paying a fare (travelling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
