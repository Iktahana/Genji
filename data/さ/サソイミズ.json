        "examples": {
          "standard": [
            {
              "text": "経済活性化のための政府の政策は、まさに誘い水のようなものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このイベントは、地域観光への誘い水となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の成功が、後進の技術者たちにとっての誘い水となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "抗議集会を開いて、みんなで暖まろうと、誘うことすらできません」　ガイ牧師が誘い水。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌が焼けるように感じたが、それが誘い水になって、少しばかり唾液が湧いた。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても温かい日だな、イーライ」　とエリクソンが誘い水。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
