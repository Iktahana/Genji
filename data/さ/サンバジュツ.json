        "examples": {
          "standard": [
            {
              "text": "ソクラテスは、問答によって相手の思考を助ける方法を産婆術と名付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "産婆術を用いた授業では、教師は答えを教えず、生徒に気づきを促す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼のコンサルティング手法は、まさに現代版の産婆術と言えるだろう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この意味でソクラテスやプラトンの哲學はポリス的教養人を作るための産婆術であり、教育技術學であったということができるであろう。",
              "citation": {
                "source": "心理學",
                "author": "矢田部達郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて、弁信は、ソクラテス流の産婆術を以て、米友を苦しめんがために検問をかけたのではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
