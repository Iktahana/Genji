        "examples": {
          "standard": [
            {
              "text": "新しい技術の導入において、彼は常に他社に先んじる姿勢を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代の変化に先んじることで、企業は競争力を保つことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ライバルに先んじるため、私たちは秘密裏に開発を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天象風土に直接関係ある建築の方がかかる点に於て一歩先んじるようになるのは当然であるかもしれぬが、彫刻に於てはその様式踏襲の間にまがう方もなく日本的特質として現れて来る第一のものがまず仏像の骨相であった。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に研究していれば、他より一歩先んじることが出来ると思う。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
