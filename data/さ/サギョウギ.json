        "examples": {
          "standard": [
            {
              "text": "汚れ仕事をするので、今日は作業着に着替えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作業着はペンキだらけで、一生懸命働いた証拠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農業体験では、汚れてもいい作業着を用意するよう指示があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "本家は十六才の子供に、住みこみで年に十四俵の米に作業着一切をもつという前代未聞の高賃銀を約束することで、別家の源治を沈黙させてしまつた。",
              "citation": {
                "source": "押しかけ女房",
                "author": "伊藤永之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッと思いだしたのはこの邸宅に入った時迎えたフェンウィックの着ていた服がそろいの青い作業着、機械仕事をする人が着るものだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたこの一〇ポンド紙幣で質素な作業着を買いに行き、自分用と言いなさい。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
