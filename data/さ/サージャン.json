        "examples": {
          "standard": [
            {
              "text": "若きサージャンは、長時間に及ぶ難手術を見事にやり遂げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はトップクラスのサージャンとして、多くの命を救ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サージャンには、極限状態でも冷静さを保つ精神力が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "トータル・アルバムなどということばは、『サージャント・ペパーズ』以後に生まれたものなので、このときは、だれもそんなふうには呼ばなかったが、だれの耳にも、アルバム全体を流れる、ある種の統一感が伝わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年からサロンにもステレオがおかれ、いまもビートルズの新作『サージャント・ペパーズ・ロンリー・ハーツ・クラブ・バンド』を流している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
