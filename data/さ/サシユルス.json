        "examples": {
          "standard": [
            {
              "text": "上司は渋々ながら、彼の残業申請を差し許した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回は特別に、彼の無礼を差し許すことにしよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厳しかった父が、私が海外へ行くことを差し許してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "狂人の所業とみなしてこのたびは差し許す、重ねてかようなことをいたさんよう自ら身分を尊び……ではない、第一に法をたっとばんければいかん。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから賦割、利足、献納物、道銭、租金、税金から、塩や鉱産物の専売、貨幣の鋳造まで、皆差し許す。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに検事総長が、犯人の無信仰についての一場の演説のあとで、反証の供述を差し許すと、もう一度、法廷は混乱に陥り、そしてもう一度ベエコンは中心的争点に注意を集中さすべく立ち上がった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
