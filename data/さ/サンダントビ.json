        "examples": {
          "standard": [
            {
              "text": "助走のスピードを殺さずに三段跳びのステップを踏み、自己新記録を更新した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホップ、ステップ、ジャンプという三段跳びのリズムを掴むのは非常に難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "陸上大会の三段跳びで、選手が砂場に深く着地するたびに歓声が上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ルキーンは二三段跳び上って、「アッ、影が動きましたぜ。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この登攀がまた、三段跳びをなしている。",
              "citation": {
                "source": "高千穂に思う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは一直線には飛ばないで、ぶるんぶるんと三段跳びみたいな飛び方を空中でしていた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツでボクがやったのはジャンプ――三段跳び、走高跳び――水泳、それから柔道、これは割に強くて段つきになったが、立業では敗けたことがない。",
              "citation": {
                "source": "スポーツ・文学・政治",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
