        "examples": {
          "standard": [
            {
              "text": "怪我の後遺症で、彼は作業療法のリハビリを受けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "作業療法は、身体機能だけでなく精神面にも良い影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高齢者のQOL向上に、作業療法は大きな役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "要するに初め絶對臥蓐法により、一方には身體的疲勞を恢復し、他方には精神的煩悶を破壞して、次に作業療法により、小兒に生れ變りたるやうな氣持になり、身心機能の自發的活動を促がし、之を助長善導して、身心を訓練するといふ所謂自然療法である。",
              "citation": {
                "source": "神經質に對する余の特殊療法",
                "author": "森田正馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "作業療法による複雜なる精神の活動を促がし、從つて身體全部機能の自然的活動を盛んにし、人生の實際に觸れて知らず識らずの間に精神統一し、勞作の所謂三昧に入る事の出來るといふ事に比すべきものでないと思ふのである。",
              "citation": {
                "source": "神經質に對する余の特殊療法",
                "author": "森田正馬",
                "note": "青空文庫"
              }
            }
          ]
        }
