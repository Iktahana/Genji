        "examples": {
          "standard": [
            {
              "text": "かつて、薩摩閥（さつまばつ）は政界に大きな影響力を持っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その組織は、薩摩出身者を中心に形成された薩摩閥だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今でも、薩摩閥の人間関係が、ビジネスに影響を与えることがある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その九月、伊藤内閣辞職の後を受けて、松方正義を総理大臣に、大隈重信を外務大臣に、所謂薩摩閥と進歩党との聯合内閣が出来た。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
