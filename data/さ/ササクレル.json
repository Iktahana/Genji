        "examples": {
          "standard": [
            {
              "text": "乾燥した板は、時間が経つと端からささくれることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い木の扉がささくれていて、開閉するたびに木屑が落ちる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研磨が不十分だと、木材の表面がささくれてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "キリストを恋い恋うて、夜も昼もやみがたく、十字架を編み込んだ美しい帯を作って献げようと一心に、日課も何もそっちのけにして、指の先がささくれるまで編み針を動かした可憐な少女も、その幻想の中に現われ出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
