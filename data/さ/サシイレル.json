        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "親は、子供の面会時に、温かいスープを「差し入れる」ことも許された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ボランティアは、刑務所へ書籍や衣類を定期的に「差し入れる」活動をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「暑い中働いている皆さんへ、冷たい飲み物を「差し入れ」ました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
