        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "休憩時間に合わせて、現場監督が作業員たちに飲み物を「差し入れる」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "コンサートの合間、出演者への労いとして、楽屋へフルーツの「差し入れ」があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっとでも休めるように、温かいお茶でも「差し入れ」ようか。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
