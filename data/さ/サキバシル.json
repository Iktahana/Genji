        "examples": {
          "standard": [
            {
              "text": "彼はいつもチームの決定を待たずに先走ってしまう傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議では発言のタイミングが重要だから、先走らないように気をつけよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "計画もなしに先走ると、後で大変なことになるぞ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アア、期待が先走るために頭が混乱してしまう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから爲三郎を殺して、雨戸を外して外から入つた泥棒のせゐにしようと企らんだわけですね」「又先走るな、爲三郎は殺されたのぢやない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御時計師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの曲は不吉で嫌いなんですって――」　先走る貴美子夫人の口を押えるように、「そんな人聞きの悪い事を言っちゃいけない――昨夜遅くまで麻雀を付き合って、寝が不足のせいだろう、頭痛がして敵わないんだ」「それは惜かったネ、素晴らしい葬送行進曲だったよ。",
              "citation": {
                "source": "葬送行進曲",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には何の関係もないのだから、どうも先走る気になれないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
