      {
        "index": 1,
        "gloss": "1932 Theses (Comintern policy documents urging overthrow of Japan's imperial and metayage systems)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
