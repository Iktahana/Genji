        "examples": {
          "standard": [
            {
              "text": "今日は雲一つない青空で、絶好の散歩日和になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こんなにいい散歩日和なんだから、外に出ないともったいないよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "散歩日和の昼下がり、公園のベンチでのんびりと読書を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十月十三日まことに秋晴、散歩日和、運動会日和だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩の季節、散歩日和であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴、散歩日和、ちよいと旅がしたいな、おとなしく洗濯、読書、何やかや、なんぼでもすることがある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
