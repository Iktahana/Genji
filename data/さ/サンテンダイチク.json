        "examples": {
          "standard": [
            {
              "text": "易経の山天大畜の卦は、大きな蓄えと成長を意味するとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は人生の転機に、山天大畜の教えを胸に刻んで進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この書物には、山天大畜の解釈に関する詳細な解説が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大畜の卦は元來乾下艮上大畜とも、山天大畜ともいひ、天を代表する乾と、山を代表する艮との二單卦を重ねたものである。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅花堂流の心易で、ちょッとこう胸に算木を置いてみるならば……ウムと……山天大畜の二｜爻変、浅き水に舟をやるの象――君子徳を養うの意というところだ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
