        "examples": {
          "standard": [
            {
              "text": "和歌山特産の三宝柑は、デコポンのような突起がある見た目と、爽やかな香りが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「三宝柑の皮を器にして作ったゼリーは、見た目も上品で贈り物に喜ばれるんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冬の冷たい空気の中で、庭の三宝柑が鮮やかな黄色に色づき、収穫の時期を告げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は鈍感なのか、三宝柑をたべるのに夢中になっているのか、それに気が付かない様だった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
