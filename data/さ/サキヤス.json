          "standard": [
            {
              "text": "来月の株式市場は、先安の見方が強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "為替相場は円高ドル安で、先安傾向が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の土地価格は、先安感から買い控えが起きている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は薄田氏の返電にほっと一先安心しながら、しかも紀行の筆を執るべき私の義務を考えると、愈心細がらずにはいられなかった。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先安永天明の交蜀山人と相並びて才名を馳せたる平秩東作、朱楽菅江、唐衣橘洲、手柄岡持ら皆世を去り、狂歌の盛衰は浅草庵市人、鹿都部真顔、宿屋飯盛、奇々羅金鶏らの手に依托せられぬ。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
