        "examples": {
          "standard": [
            {
              "text": "今朝は一面の里雪で、子どもたちは大喜びで雪遊びを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬になると、里雪が降り積もり、しんとした静寂が村を包む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "里雪の日は、温かい囲炉裏を囲んで家族団らんするのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女は大脳の棚の下をそゝくさとゆきゝして幾品かの食品をとりおろす。",
              "citation": {
                "source": "大脳は厨房である",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいふうをした女や、男は道ばたに、こうして、哀れな女が、救いを求めているということを、見向きもせずに、さっさとゆきすぎてしまったのです。",
              "citation": {
                "source": "ある冬の晩のこと",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の優雅さとゆきとどいた巧緻さというものは、おどろくようなときがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
