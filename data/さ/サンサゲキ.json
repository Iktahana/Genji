        "examples": {
          "standard": [
            {
              "text": "海の神ポセイドンは、強力な三叉戟を携えていることで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館で、古代の戦士が使ったとされる三叉戟が展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神話の中で、英雄が三叉戟を振るって怪物と戦う場面が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "心霊的な事柄では概して楯と三叉戟との姉妹国★ほどに恵まれていなかったフランスは、紙幣を造ってはそれを使い果して、素晴しい勢で下り坂を転げ落ちていた★。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "楯と三叉戟との姉妹国　　イギリスをさす。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楯と三叉戟」は海神ネプテューンの標章であり、イギリスの紋章ではブリタニアをあらわす女人像が海の女王の象徴として楯と三叉戟とを持っているのである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
