        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "食卓には、採れたての新鮮な三度豆が並んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三度豆は、さっと茹でてサラダに加えると美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、畑で三度豆を収穫するのが楽しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ワキギ、三度豆、ナンキンなどの畠ありて後は竹藪なり。",
              "citation": {
                "source": "わが幼時の美感",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩昆布、キャラ蕗、芹の味噌漬、小魚や三度豆の佃煮、でんぶ、鰹節などですが、豆をあまく煮つめたものなども、意外に歓迎されます。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
