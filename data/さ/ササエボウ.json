        "examples": {
          "standard": [
            {
              "text": "風で倒れそうな木に、太い支え棒を立てて補強した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テントを設営する際、丈夫な支え棒を使ってしっかりと固定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い建物の傾きを防ぐため、応急処置として支え棒が設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "長い雨風で、ボロボロに腐れ切ったヨロヨロの藁小屋で、風が強いと危いので、丸太二三本を家の後へ支え棒にしていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼は死骸から取った黒い着物を着け、調査間に発見した所の古るい法衣でそれを包んだのじゃ、それからわしが述べたように珠数やそして木の支え棒を手配して、それを棺の中に入れたわけじゃな。",
              "citation": {
                "source": "金の十字架の呪い",
                "author": "チェスタートン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はほとんど無意識のうちに足元にころがっていた雨戸の支え棒を拾いあげた。",
              "citation": {
                "source": "本所松坂町",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
