          "standard": [
            {
              "text": "19世紀は、産業資本主義が世界中で拡大していった時代だと言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "産業資本主義の進展は、都市化と労働者階級の形成を促した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日のグローバル経済は、産業資本主義が高度に発展した結果である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五　「和親」条約　旧市場の拡張と新市場の獲得とが問題のいっさいだった産業資本主義発展期の当年にあって、かりそめにも、「和親」はするが貿易はおことわりだといった種類の条約が、足掛五年も続いたというのはどうしたことか！",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "工業はなんとしてでも発展させなければならず、南北戦争を通過すると、独占のかたちで、産業資本主義が広がっていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五〇年代に入るまでに、アメリカは、世界一の産業資本主義国になった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
