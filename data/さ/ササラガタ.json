        "examples": {
          "standard": [
            {
              "text": "美術館で見た古い器には、細形の見事な装飾が施されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "細形の刺繍が施された布は、職人の技の結晶だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は細形模様の描かれた扇子を大切にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "古藤は自分の帽子を部屋のすみにぶちなげて置いて、払い残された細形の金鎖を片づけると、どっかとあぐらをかいて正面から葉子を見すえながら、「行って来ました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしお染の横きりの細形の体にはたまらなく似合うのを着てまっかな帯をダラリと猫じゃらしに結んでチャンと御化粧がしてあった。",
              "citation": {
                "source": "ひな勇はん",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小紋のかたあるいは「ささらがた錦のひもを…………」などは型である。",
              "citation": {
                "source": "うつす",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
