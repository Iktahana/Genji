        "examples": {
          "standard": [
            {
              "text": "彼の不運は、三世因果の報いだと老僧は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三世因果という考え方は、東洋思想の根底にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、今生の行いが来世に影響すると、三世因果を信じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "仏教の三世因果の教えも社会に深く浸潤して居りました。",
              "citation": {
                "source": "馬琴の小説とその当時の実社会",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此派の作者は俗にいへる三世因果の説を理想とし、若くは天命の説を理想とするなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
