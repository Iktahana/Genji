        "examples": {
          "standard": [
            {
              "text": "そのドキュメンタリー映画の撮影監督は、光の使い方が非常に巧みだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "撮影監督の指示のもと、カメラマンたちは息を合わせて映像を収めていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、長年の経験を持つベテランの撮影監督だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その男は、撮影監督の助手をつとめていた。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚越は或る映画会社の有名な撮影監督であつた。",
              "citation": {
                "source": "塚越の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの撮影監督は又これに裏書して曰く、「まったくです。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒険｜救助作業　撮影監督のケンもカメラマンのダビットも、撮影ちゅうししてそばへとんできた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の男女優が、いろいろの服装をして、シャツ一枚の撮影監督の指揮に従って、あっちへ行ったり、こっちへ来たりしていた。",
              "citation": {
                "source": "獏鸚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "演出と撮影監督の傑出した才能が、つねにすべてをくるんで仕上げをしていた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十二本のうち九本までが、同一の監督そして撮影監督による作品だった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
