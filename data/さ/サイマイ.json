        "examples": {
          "standard": [
            {
              "text": "砕米は、米粉の原料や家畜の飼料として利用されることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "精米の過程でどうしても砕米が発生してしまうのは避けられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このお酒、砕米を原料にしてるから、ちょっと変わった風味がするんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ミケ　肥前｜上五島でミケというのは砕米のことである。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "つきべりが多いのは砕米が多いからです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして砕米が多いのは、ついて行くうちに米がまさつ熱でぼうちょうするのに、その米のはいっている筒の中の空間が固定しているからです。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "砕米薺に似たいく種かの水草もあった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
