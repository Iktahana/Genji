        "examples": {
          "standard": [
            {
              "text": "古来より、富士山、立山、白山は「三霊山」として崇められてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの巡礼者が、この三霊山を訪れ、その霊験にあやかろうとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「日本三大霊山の一つである立山は、神秘的な雰囲気に満ちていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "滅びた江戸時代には芝の増上寺、上野の寛永寺と相対して大江戸の三霊山と仰がれたあの伝通院である。",
              "citation": {
                "source": "伝通院",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
