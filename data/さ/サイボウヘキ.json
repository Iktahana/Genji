        "examples": {
          "standard": [
            {
              "text": "植物細胞には、動物細胞にはない強固な細胞壁が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "細菌の細胞壁は、ペプチドグリカンという物質で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この抗生物質は、細菌の細胞壁合成を阻害することで効果を発揮する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さてどう云うわけで植物性のものが消化がよくないかと云えば蛋白質の方はどうもやっぱりその蛋白質分子の構造によるようでありますが脂肪の消化率の少いのはそれが多く繊維素の細胞壁に包まれている関係のようであります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
