          "standard": [
            {
              "text": "今回のリフォームでは、材料費よりも作業費の方が高くなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は作業費を節約するため、自分で庭の手入れをしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "見積もりには、詳細な作業費の内訳が記載されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それに要する作業費が二三千円であるが、地形図の基礎になる三角測量の経費をも入れて勘定すると、一枚分約一万円ぐらいを使わなければならない、そのほかにまだ計算、整理、製図、製版等の作業費を費やすことはもちろんである。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
