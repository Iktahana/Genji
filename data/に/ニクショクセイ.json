        "examples": {
          "standard": [
            {
              "text": "植物の中には、ハエトリグサのように虫を捕食する肉食性を持つものがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その恐竜は歯の形状から、非常に攻撃的な肉食性であったと推測されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "野良猫は家猫になっても、獲物を狩るという肉食性の本能を完全には忘れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "白亜紀の肉食性の獰猛な種類、……禽竜とか恐竜とかがいるはずなのです。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる時代の既知の捕食性ないし肉食性動物に起因せず。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
