        "examples": {
          "standard": [
            {
              "text": "母が作ってくれる肉じゃがは、少し甘めの味付けで、ジャガイモがホクホクしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初めての自炊で肉じゃがに挑戦したが、火加減を間違えて焦がしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居酒屋のお通しで出てきた肉じゃがが思いのほか美味しくて、ついついお酒が進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「死肉じゃが、久しぶりにためし斬り――」　これはたまらない。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
