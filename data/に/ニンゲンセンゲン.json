        "examples": {
          "standard": [
            {
              "text": "昭和天皇の人間宣言は、戦後の日本社会に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人間宣言は、天皇の神性を否定し、象徴天皇制の基礎を築いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で、人間宣言が発表された背景について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "せっかく、陛下からありがたい人間宣言のお言葉が発せられる時に、この点に触れて頂いたらという考えがあったことは否めないのである。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            },
            {
              "text": "世上にはあの人間宣言はマッカーサー司令部の命令で行われたものとの説が流布されているが、私の知る限りではさような事は少なくとも直接にはなかったということが断言できる。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            }
          ]
        }
