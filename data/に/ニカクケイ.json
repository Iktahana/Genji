        "examples": {
          "standard": [
            {
              "text": "幾何学において、二角形は二つの頂点と二つの辺で構成される図形だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地球上の二点間の大円距離は、二角形として表現できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "概念的な図形として、二角形は数学の基礎で扱われることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "兩側には老樹が茂り、城の前庭に達するまで深い森林を分けて行くやうな感じで、前庭からは、左に圓筒形のシーザーの塔（高さ一四七呎）、右に十二角形のガイの塔（高さ一二八呎）が仰がれ、どちらも十四世紀の塔で、塔と塔の間は高い石塀でつなぎ、その中間に大手ともいふべき二重の塔門が立つてゐる。",
              "citation": {
                "source": "ウォリクの城",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
