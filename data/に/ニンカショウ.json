        "examples": {
          "standard": [
            {
              "text": "新しい事業を始めるには、関係省庁からの認可証が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レストランの営業には、食品衛生の認可証が必須だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "認可証の更新手続きを忘れないようにしなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから我々は再び家の裏口に戻つて、ベルを鳴らして警察の認可証を見せた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場の吏員か警察署員を誘うて、偽の埋葬認可証を出してもらって、村人たちを欺いて、母の偽の葬式を営んだのでしょう。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
