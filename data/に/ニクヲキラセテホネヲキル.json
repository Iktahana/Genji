        "examples": {
          "standard": [
            {
              "text": "交渉では、時には肉を切らせて骨を切る覚悟も必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はあえて一歩引くことで、肉を切らせて骨を切る戦術をとった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「肉を切らせて骨を切る」とは、短期的な損失を覚悟して長期的な勝利を目指すことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "空掛け声は預けて置いて肉を切らせて骨を切るという実質一方の構えである。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉を切らせて骨を切るのだ。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然体に隙がない、皮を切らせて肉を切り、肉を切らせて骨を切る、この意気でジリジリと付け廻わした。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
