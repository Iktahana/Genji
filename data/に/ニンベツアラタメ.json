        "examples": {
          "standard": [
            {
              "text": "江戸時代の村役人は、五人組ごとに人別改を行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人別改の日は、村人たちが一斉に集まり、身分を確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "記録に残された人別改の帳簿からは、当時の人々の暮らしぶりが窺える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ちげえねえとするなら、まず事のはじめに三人のやつらの家族調べ、人別改めをやって、下手人とにらんだ若い女のあるやつはどこのどれか、その眼をつけるが先じゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ、まず四ツ谷から手始めに太田五斗兵衛のだんな寺へ押しかけて、やつに娘があるか、若い女の身寄りがあるか、その人別改めをするというのに、なんの不思議があるかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も同家に元禄十二年の宗門人別改帳を伝えているが、それには賀茂郷立本寺裏町治右衛門屋敷というのがあって、自分もそこに住んでおったばかりでなく、彼は数戸の貸家を有し、その借家人には数多の市人が住んでおったのである。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その年の暮に人別改め（戸籍調べ）があった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
