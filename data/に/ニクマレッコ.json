        "examples": {
          "standard": [
            {
              "text": "彼はクラスの憎まれっ子だったが、なぜか皆に一目置かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "憎まれっ子ほどよく育つというが、本当にそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お前は本当に憎まれっ子だな」と、いたずらをした弟に母が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おれが風邪ひくと、どうなるか知ってるか」「憎まれっ子のことは、だれも気にしない」「ハズレ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子なんぞに負けないので憎まれっ子でもあった。",
              "citation": {
                "source": "源泉小学校",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎まれっ子、世にはばかるって、この事でございますよ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と後家さんがカーチャに飛びかかって行くのが聞える、「憎まれっ子世に憚る、ってお前さんのことだよ！",
              "citation": {
                "source": "天才",
                "author": "ТАЛАНТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この根性曲りの憎まれっ子。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年生の岡村と云えば、校内誰一人として知らぬ者のない憎まれっ子になって了い、生徒も憎めば先生も憎み、友達は愚か近づく人もないくらいで、唯私だけが親密にして居ました。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「憎まれっ子世に憚る、ヴァルデグラスにパンテオン、ショセダンタンにサンジェルマン、チャラチャラ流れるセーヌ川、粋な姉ちゃん立小便、買った買ったさあ買った、カッタコト音がするのは若い夫婦の箪笥の菅だよ」[64]「まあ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
