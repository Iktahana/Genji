        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "被告は裁判で、原告の主張をすべて認諾した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "紛争解決のため、相手側の提案を不本意ながら認諾する形となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "契約内容を精査した結果、私たちはその条項の認諾を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ジエンナロは手を拍ちて激賞し、公子夫妻はわが多少の情あるを認諾せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はよくも考へずに認諾を与へてしまひました。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
