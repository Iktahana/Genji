[
  {
    "uuid": "d70e5b98-1d5b-544a-9110-1f01d69c8ffb",
    "entry": "逃げる",
    "reading": {
      "primary": "にげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
