        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雨に濡れた沈丁花の花が、夜の闇の中でいっそう強く匂い立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "淹れたてのコーヒーが匂い立つリビングで、ゆっくりと朝食を摂る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "満開のキンモクセイの下を通ると、秋が匂い立つような感覚を覚える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "空を白くぼッと染め春の支度に忙しそうな速さの風も、蕾のあたりは、一面匂い立つように霞んで過ぎた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺な夏の風景が実に匂い立つばかりです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき巨大なバラが地上に傾き、一輪の匂い立つ赤く巨大な花で頭を叩かれ、再び正気に戻った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "もったいないこと」　そろそろ巧雲の沸る思いは姿態にもなって、眼もともとろり、肌の凝脂も匂い立つ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
