  },
  {
    "uuid": "14542e62-5962-58e7-b634-98ac1570ce1b",
    "entry": "ＮＥＥＴ",
    "reading": {
      "primary": "ニート",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
