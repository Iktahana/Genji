        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この寿司屋の握り手は、ネタの鮮度とシャリの加減が絶妙だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初めて握り寿司を作る体験教室で、私も握り手気分を味わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ベテランの握り手が、次々と美しい寿司をカウンターに並べていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
