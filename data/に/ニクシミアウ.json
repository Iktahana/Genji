        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "些細な誤解から始まった喧嘩がきっかけで、兄弟は十数年も憎しみ合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦争は、罪のない人々が互いに憎しみ合う悲劇を何度も繰り返してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "同じ目標を持つ仲間だったはずなのに、いつの間にかライバル視して憎しみ合うようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "善人どうしは、とかく憎しみ合うもののようである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のコバルト行きはこの男に会い、この男と睨み合い憎しみ合うことで患者という弱りはてた世界から、縋りついた人間くさい物をたよりにしていたので、彼に会わないというあての外れたことは大きかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたしたちが、やつらに誤解の種をちょっと植え付けてやる、そうすれば、すべてのロボットが、違う工場のマークがついているロボットを憎しみ合うような時代がやってくるというわけだ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
