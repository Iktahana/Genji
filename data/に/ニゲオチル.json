        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "落武者たちは山中を彷徨いながら、かろうじて隣国へと逃げ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦火を逃れた難民たちは、命からがら国境を越えて安全な地へ逃げ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "城が陥落する寸前、家臣たちは幼い姫を連れて秘密の通路から逃げ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わめき叫びながら逃げ落ちる兵たちは、京の街路を必死に駆けた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　丈吉が大阪にいる友人をたずねて東京を逃げ落ちる決心をしたのはあくる日の朝だった。",
              "citation": {
                "source": "菎蒻",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わが君に戦意がないものを、どうしようもあるまい」　と、ほかの幕将たちは、張飛や関羽をなだめて、評議は、逃げ落ちることに一決した。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに、足利｜直義は、ささえきれず、鎌倉をすてて西へ逃げ落ちる腹をきめた。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "何じゃこれは」「されば、これはみなわが白旗城を包囲していた敵が、攻め口を解いて逃げ落ちるさい、道の諸所にあわてて捨て去った差物にござります」「ほ。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
