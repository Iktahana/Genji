      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ushnisha (protrusion on the top of a buddha's head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鎌倉の大仏の頭部を仰ぎ見ると、知恵の象徴とされる肉髻がはっきりと確認できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仏像の髪型は螺髪が一般的だが、その頂点にある盛り上がりが肉髻と呼ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美術史の授業で、インドから伝わった仏像様式における肉髻の変遷を調査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "後ろなるは、頭に宝珠瓔珞を纏い、頂に肉髻あり、妙相端厳、仄かに円光を負うておられるは、何さま尋常人ならずと見えた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
