        "examples": {
          "standard": [
            {
              "text": "貨物引換証には、荷受人として取引先の社名が明記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "荷受人が不在だったため、宅配便のドライバーは不在連絡票を置いていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "貿易実務において、荷受人は貨物の到着を確認し、受け取る権利を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、この下の処に、Ｔ・Ｗ・Ｗ――としてあるのが、荷受人のサインです。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
