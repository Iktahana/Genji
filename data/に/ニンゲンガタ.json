        "examples": {
          "standard": [
            {
              "text": "子供たちは、人間型のロボットが動く様子に目を輝かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その未来の街には、人間型の案内ロボットがあちこちに立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は人間型のロボット開発に情熱を注いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "恋愛は相互に孤立しては不具である男・女性が、その人間型を完うせんために融合する作用であり、「を味う」という法則でなく、「と成る」という法則にしたがうものであり、その結果として両者融合せる新しき「いのち」が生誕するのだ。",
              "citation": {
                "source": "学生と生活",
                "author": "――恋愛――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たれか親切な知人がこれを克明に分析してみたら實におもしろいそして偉大な“人間型”のひとつであらうとおもふ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
