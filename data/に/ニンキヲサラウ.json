        "examples": {
          "standard": [
            {
              "text": "新人アイドルが、登場するやいなや、世間の人気をさらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その映画は、公開後すぐに大ヒットし、すべての話題と人気をさらっていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年のオリンピックでは、あの若い選手が予想外の人気をさらったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "マルチメディア国際会議の人気をさらうと同時に、この会議が米コンピューター界のスターの顔見せの場にとどまらず、日米の業界人の出会いによって何か新しい動きが生まれる舞台となっていることを強く印象づけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ことによると江戸中の人気をさらうぜ、おいらとおめえと」　その、がたぴしいう藤代町の安宿の二階で、おじいさんの浴衣を着たお駒ちゃんに不思議な振り付けがはじまった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの縹緻を持てば、その頃の道徳と通念では、歌舞の菩薩と思われた、遊女の群に入ったら、名ある太夫を蹴落して、一気に全吉原の人気をさらうことも出来るでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "一と目千両",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
