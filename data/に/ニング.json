        "examples": {
          "standard": [
            {
              "text": "博物館には、昔の忍者が使っていた忍具が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、手裏剣のような珍しい忍具を収集している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アニメで見た忍具に憧れて、子供の頃はよく真似をして遊んだものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ふつさりと柔かい髪の毛を真中からきれいに左右に分けて、細目のずぼんの縞のもうにんぐを行儀よく着こなし、すらりとした身体を鷹揚に運んで居る処は、寔に上品な紳士である、否さながらの貴公子である。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、そんなに僕が身装のことを気にするのなら帰りがけに小田原の町にある僕の生家を訪れて、講演会に出席するために要用と偽り、親父のもうにんぐこうとを持ちだして来てやらうと、倉造が点頭いてゐたことなどをつけたした。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
