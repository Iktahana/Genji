        "examples": {
          "standard": [
            {
              "text": "プロタゴラスの「人間は万物の尺度である」という言葉は、相対主義の思想を象徴している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、ソクラテスの影響を受け、「人間は万物の尺度である」という思想を展開した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「人間は万物の尺度である」という考え方は、個人の価値や認識の重要性を示唆している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "＊72「人間は万物の尺度である」　この一ギリシャ人の箴言はヨーロッパ文明を花咲かせるとともに、その桎梏ともなった。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「強力な賢い男」とソクラテスに呼ばれたプロタゴラスは「人間は万物の尺度である」という金言にたいして責任があり、人間全体にこの基準を置くことの愚行を最初に認めた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
