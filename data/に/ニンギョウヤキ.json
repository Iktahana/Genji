          "standard": [
            {
              "text": "浅草に行ったら、人形焼は絶対に買わなくちゃね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お土産に人形焼をもらったけど、あんこが甘くて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焼きたての人形焼は、香ばしくて最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――わたしの記憶にもしやあやまりがなければ、いまから十五、六年まえのことである……観音堂附近（一）　それはただ在来の人形焼……で思い出したが、そのずっと以前、広小路の、「ちんや」のならびにそれの古い店があった。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その人形焼を、提灯、鳩、五重の塔、それ／″＼「観音さま」にちなみあるものに仕立てたにすぎなかったが、白いシャツ一つの男が店さきで、カン／＼熾った火のまえにまのあたりそれを焼いてみせるのが人気になったのである。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
