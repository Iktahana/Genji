        "examples": {
          "standard": [
            {
              "text": "この小さなカフェには、様々な客の人間模様が日々繰り広げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年勤めた会社を辞める時、職場の人間模様が走馬灯のように思い出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のドキュメンタリー映画は、過疎の村に生きる人々の複雑な人間模様を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "我々の骨にからみついた人間模様と性慾のあの世界だから。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしあたり興味のあったのが人間模様であり、ミリアムとルースの手助けと奉仕に感謝しっぱなしだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二六・五・六）　　　　　　　＊　戦乱中の人間も異様ですが、その直後、平和の中の人間模様も、世さまざま人さまざま、種々、めずらしい風聞を撒くこと、古今のちがいもないようです。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
