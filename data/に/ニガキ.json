        "examples": {
          "standard": [
            {
              "text": "苦木は独特の苦味があり、薬用として使われることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山道を歩いていると、珍しい苦木の木を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "苦木の樹皮から抽出される成分には、健胃作用があるとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "同地では大分県教育会が主となり、同国の臼杵町、佐伯町を中心として四日間植物の採集会が催されたので、ヘツカニガキの大木ある四浦村久保泊にも行き、またショウベンノキ、モクタチバナ、ヒゼンマユミ、スナゴショウ、クルマバアカネ、イワガネなどのある津久見島へも行った。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシア（quassia：ニガキ）の抽出物およびリコリス（liquorice：甘草）の汁からなる他の物質は技術の上ではマルタム（multum：増量剤）と呼ばれて、不正な醸造者はモルト（麦芽）およびホップを節約するのに使っている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "命があぶないね」と言って、俺はニガキス（ビール）を飲んだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
