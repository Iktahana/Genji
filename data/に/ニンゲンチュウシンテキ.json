        "examples": {
          "standard": [
            {
              "text": "彼の設計は、あくまで人間中心的な視点から、使いやすさを追求したものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "科学技術は、人間中心的な発展を目指すべきだと彼は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代の多くの社会システムは、人間中心的な発想で作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "歴史はひとつの人間的なる、人間中心的なる世界である。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くべき大胆さをもって考える原子は、自分自身を宇宙の永遠な目標の人間中心的な軸と考えている。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
