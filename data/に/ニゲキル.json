    "definitions": [
      {
        "index": 1,
        "gloss": "to make good one's escape",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "執拗なストーカーの追跡を振り切り、彼女はタクシーで逃げ切ることに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "証拠を隠滅しきれば、今回の不祥事もなんとか逃げ切れると考えているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サスペンス映画の主人公が、迷路のような廃ビルで追っ手から必死に逃げ切る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「小早船じゃ、かなわねえ」　庄兵衛は音をあげたが、どうでも逃げ切るつもりらしく、うるさく帆形を変えて間切りだした。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネコは一本しか持たず、逃げ切る。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしば不人気馬が重賞を制することがあるけど、全く無名の馬が二十馬身も先頭で、判定席の前を逃げ切る番狂わせは、そうあることじゃない。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "トビウオが逃げ切る見込みはほとんど無いな。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが初めから、逃げられたら、逃げ切る。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
