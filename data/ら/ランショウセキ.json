        "examples": {
          "standard": [
            {
              "text": "藍晶石特有の美しいブルーの結晶は、見る角度によって色が微妙に変化する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鉱物採集の最中、岩の割れ目から鮮やかな藍晶石の破片が顔を出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "藍晶石は耐火物やセラミックスの原料としても産業界で広く利用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その黄金いろのまひるについで、藍晶石のさはやかな夜が参りました。",
              "citation": {
                "source": "まなづるとダァリヤ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが半分すきとほり、青くて堅くて、藍晶石より奇麗です。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
