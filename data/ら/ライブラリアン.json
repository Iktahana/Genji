        "examples": {
          "standard": [
            {
              "text": "困っていると、経験豊富なライブラリアンが適切な資料を見つける手助けをしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は子供の頃から本が好きで、将来はライブラリアンになるのが夢だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学のライブラリアンは、研究者の情報収集に欠かせない存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "時には歴史科を受持つ頭の禿げた亜米利加人の教授が主任のライブラリアンとして見廻りに来る。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょん髷を剪ったばかりのライブラリアンは、いろは順もＡＢＣ順も、書類の正確な系統さえ念頭に置かなかったように見える。",
              "citation": {
                "source": "蠹魚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央アジアの研究に趣味を持って居るらしく相当に絵画の理解もありライブラリアンらしいもの知りである。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
