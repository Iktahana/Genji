        "examples": {
          "standard": [
            {
              "text": "この企画の最終決定は、来週中に下される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来週中に一度、打ち合わせの時間を設けたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来週中に引っ越しを完了させるため、忙しい日々を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "来週中はせわしいであろう。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "来週中せわしい思いをしなければならない事を思うといやになる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "来週中の英語を少しかたをつけて置こうと思って misunderstood 丈はすっかりやって、会話の材料も大抵はまとめて置いた。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "営養読本は、来週中にかえして貰います、かりたひとは先をうつして返すのですからすこしゆとりをつけました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
