        "examples": {
          "standard": [
            {
              "text": "活版印刷の歴史において、ライノタイプは新聞制作のスピードを飛躍的に向上させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い印刷所の片隅に、かつて活躍していた巨大なライノタイプが展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライノタイプは一行ごとに鉛を鋳造するため、非常に重厚な機械音が響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが一九八五年一月のレーザーライタの発表に合わせて、アドビは組版システムの専業メーカーであるライノタイプ・ヘル社と共同で、ポストスクリプトに対応した印刷用機器をお披露目します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリルの外側には金属製の自在管があり、隙間にライノタイプ溶融物を流し込んで、固めることができる。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
