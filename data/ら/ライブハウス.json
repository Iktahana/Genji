        "examples": {
          "standard": [
            {
              "text": "週末、友人たちと馴染みのライブハウスに行って、熱いバンドの演奏を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつか自分のバンドで、有名なライブハウスのステージに立つことを夢見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この街には、若手ミュージシャンを応援する小さなライブハウスが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "受付をすませ、広めのライブハウスほどの会場に入ろうとした記者や業界関係者は、のっけからビールやウイスキーを手渡された。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
