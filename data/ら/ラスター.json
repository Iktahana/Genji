        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "写真のような複雑な画像は、ラスターグラフィックスとして扱われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラスターデータはピクセルの集合体なので、拡大すると画質が粗くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "Webデザインでは、ラスター画像とベクター画像を適切に使い分ける必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
