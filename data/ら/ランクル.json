        "examples": {
          "standard": [
            {
              "text": "彼はアウトドア派で、愛車のランクルでよくキャンプに出かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雪道でも頼りになるランクルは、北国の住民に人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新型のランクルは、さらに堅牢なフレームと洗練されたデザインが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二冊のうちの一つは、悪魔の変化についてというドランクル議長の有名な著述であって、も一つは、ヴォーヴェルの悪鬼とビエーヴルの妖鬼とに関してというムュートル・ド・ラ・リュボーディエールの四折本であった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、恐ろしい歯をそなえて、ファリナッキやヴーグランを、ドランクルやイザーク・ロアゼルを、オペードやマショーをむさぼり食う、恐ろしい正義の神テミスも、健康が衰えてき、痩せ細っている。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            }
          ]
        }
