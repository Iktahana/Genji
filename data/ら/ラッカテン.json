        "examples": {
          "standard": [
            {
              "text": "ボールの落下点を正確に予測し、見事にキャッチした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隕石の落下点が予測され、周辺住民に避難勧告が出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この雨粒の落下点、面白い動きをしてるね」と子供が窓の外を眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "喬介は眉根に深い皺を刻まして首を傾けながら、屋上の隅から隅へ鋭い観察を投げ掛けていたが、やがて私を促して死体の落下点と思われる東北側の隅へやって来ると、拡大鏡を振り廻して先程よりも一層綿密に鉄柵や植込みを調べ始めた。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "司法主任は、それらの雫の特異な落下点を指差しながら、機関車が給水のため此処で停車していた時に犯行が行われたに違いない、と附け加えた。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "落下点を頭に刻みつつ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
