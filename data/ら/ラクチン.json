        "examples": {
          "standard": [
            {
              "text": "「このアプリを使えば、毎月の家計簿付けも驚くほど楽チンだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お掃除ロボットを導入してから、床掃除が本当に楽チンになったわ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「下準備済みのミールキットなら、忙しい日の夕食作りも楽チンだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "泣く子と地頭には勝てないと思いきわめ、三匹の猿になる修練に何十年心をうちこむ修養を要したにしても、まさしくその一生は一酔一夢というような楽チンきわまるものである。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
