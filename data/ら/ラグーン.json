        "examples": {
          "standard": [
            {
              "text": "エメラルドグリーンのラグーンに囲まれたその島は、まさに天国のような美しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シュノーケリングをすると、穏やかなラグーンの中で色鮮やかな熱帯魚たちが泳いでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "干潮時に姿を現したラグーンの砂州を歩きながら、沈みゆく夕日を眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "万々　「メム」は沼またラグーン。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実から推せば、ガタは英語のラグーンに宛ててよろしい語である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
