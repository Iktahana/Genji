        "examples": {
          "standard": [
            {
              "text": "東京タワーは、今も昔も変わらない東京のランドマークだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "旅行先では、まずその街のランドマークを目指して歩くことにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「駅前の大きな時計台をランドマークにしてください」と道案内で伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "これはフィアンセーユ時代、山田さんが奥さんに買ってやったので、二人にとっては結婚生活の一つの重大なランドマークになる性質のものであった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレイワのランドマークとなって久しい。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスの医学統計学者ホグベンはこの論文を人類遺伝学のランドマークとしている。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            }
          ]
        }
