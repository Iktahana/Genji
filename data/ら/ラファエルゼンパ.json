        "examples": {
          "standard": [
            {
              "text": "ラファエル前派の画家たちは、細密な描写と鮮やかな色彩を追求した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ミレイの『オフィーリア』は、ラファエル前派を代表する傑作の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はラファエル前派の、神秘的で少し耽美的な世界観が大好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "出版してから三年ばかり後のこと、ラファエル前派の詩人ロゼッテイの二人の友人が、散歩の途次偶然、埃に埋もれたこの珍しい本を発見して、彼にその話をした。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色のきたない雨漏りの條のいくつもついてゐる部屋の壁には、去年の大晦日の晩に一高前の古本屋で買ひ求めた、ラファエル前派の代表作者バアーンジョンの「音樂」が深い埃を被て緑色の長紐で掛けてあつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝにもあのラファエル前派の蘭のにほひが幽かに顫へてゐるらしい。",
              "citation": {
                "source": "仙人掌と花火の鑑賞",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも私の知る範囲において彼の工藝品はあまりにラファエル前派の絵画的束縛を出ない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは「ラファエル前派」とはいうも、充分にゴシックの精神に帰っていたのではない。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラファエル前派」とは称しているが、まだ充分にゴシックに帰ってはいない。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
