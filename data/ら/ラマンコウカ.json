    "definitions": [
      {
        "index": 1,
        "gloss": "Raman effect (of inelastic photon scattering)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
