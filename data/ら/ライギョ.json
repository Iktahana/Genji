    "definitions": [
      {
        "index": 1,
        "gloss": "blotched snakehead (Channa maculata)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "雷魚は非常に貪欲な肉食魚で、水面のカエルや小魚を一気に飲み込んでしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "釣り上げた雷魚の背中には、美しい蛇のような模様がはっきりと刻まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、近所の池で巨大な雷魚を釣り上げようと奮闘した記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "雷魚売りの呼び声が喧ましくなるのも、もう、直ぐである。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウナギ、ナマズ、雷魚などは、ドバというハネミミズがよく、フナにはシマにアズキ、手長エビにはシマを針いっぱいに切って使う。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フナの乗っ込みに雷魚の三寸から五寸ぐらいのが十尾ばかり釣れたので、家へ持って帰ると、家内が「これは何という魚ですか」という。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "northern snakehead (Channa argus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
