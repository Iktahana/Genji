        "examples": {
          "standard": [
            {
              "text": "極寒の地で暮らすラップ人の知恵は、過酷な自然環境を生き抜くためのものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "色鮮やかな民族衣装を身にまとったラップ人の祭りに、多くの観光客が訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ラップ人の伝説に登場する太陽の物語は、どこか神秘的な響きがあるね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "遊牧民のラップ人がすむ。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "）北極も今や間近くなりぬらん、夜昼かけて日そ照しける四〇、ラップ人種の生活状態　二十七日、快晴。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "渓にそいて山隈に入ること十四、五町にして、ラップ人種の部落に達す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
