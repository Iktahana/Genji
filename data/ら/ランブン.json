        "examples": {
          "standard": [
            {
              "text": "お忙しいところ乱文にて失礼いたします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書いた報告書は乱文が多く、要点が分かりにくかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の訃報に驚き、乱文になってしまったことをお許しください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それでは悪筆乱文お許し下さいませ、さよなら。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして乱文斜文をつくり、暗濁昏瞑に致しましょう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り急ぎますままに乱文の程お許し下さいませ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒乱筆乱文御許し下さいませ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
