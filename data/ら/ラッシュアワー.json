        "examples": {
          "standard": [
            {
              "text": "ニューヨークのラッシュアワーは、想像を絶する混雑ぶりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラッシュアワーを避けて、少し早めに家を出ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラッシュアワーの電車内は、毎日が戦場だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこのような訓練が実際上現在のこの東京市民にいかに困難であろうかという事は、試みにラッシュアワーの電車の乗降に際する現象を注意して見ていても直ちに理解されるであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家からごく近いし人数もやたら多くないし、三月からならあたたこうなって丁度よい、というし、ラッシュアワーで又バスがひっくりかえったなどと云うのも楽ではないし、きいてよかった、これにしようということになりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "社のＹ氏、Ｈ氏などと、ラッシュアワーの中で、やっと出会う。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
