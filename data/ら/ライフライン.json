        "examples": {
          "standard": [
            {
              "text": "地震の後、電気、ガス、水道のライフラインが完全にストップしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台風に備えて、非常時のライフライン確保の準備をしておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高齢者の一人暮らしでは、災害時のライフラインの寸断が特に心配される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "デッキには、ハッチの上を通るように、ライフライン（命綱）が張られた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
