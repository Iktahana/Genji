        "examples": {
          "standard": [
            {
              "text": "牛乳やチーズ、ヨーグルトなどの酪製品は、カルシウムが豊富だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はアレルギーがあるので、酪製品を避けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近は植物性の酪製品も増えてきて、選択肢が広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この居室でパンと酪製品との御馳走をされながら聞いた話のうちで、一番面白かったのは、男の子の沢山ある人がアタマンになるという話であった。",
              "citation": {
                "source": "永久凍土地帯",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで外国における酪製品の生産如何によって、日本の酪農が左右されては、これは重大な問題である。",
              "citation": {
                "source": "北国の春",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
