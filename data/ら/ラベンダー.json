        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女が選んだドレスは、上品なラベンダー色でとても素敵だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夕焼け空が、刻一刻とラベンダー色に染まっていく様子は息をのむほど美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このラベンダー色のセーター、あなたに似合うわよ」と店員が勧めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
