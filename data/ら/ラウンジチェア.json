        "examples": {
          "standard": [
            {
              "text": "窓際に置かれたラウンジチェアに座り、読書を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このラウンジチェアは、デザイン性と座り心地を両立している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バルコニーにラウンジチェアを置いて、夕焼けを眺めるのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四体に男を上手にそそるような女っぽいロシア語を話させる自信がなかったので、火星人はそれらを物質化させる際ラウンジチェアーを用意して、全員その上に眠らせることにした。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ラウンジチェアの上でちんまりと眠たままのロシア美女の方を指差した。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
