        "examples": {
          "standard": [
            {
              "text": "祖父はシベリアのラーゲリに抑留されていた当時の過酷な体験を、晩年になってようやく語り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "凍てつく寒さの中、ラーゲリの収容者たちはわずかな黒パンだけで重労働を強いられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ソルジェニーツィンの著作を読み、ラーゲリでの非人道的な生活の実態に強い衝撃を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのころ、あなたのラーゲリでは音楽グループは、どんなことをしていたでしょう。",
              "citation": {
                "source": "結論をいそがないで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月九日　水「ラーゲリ・バウマニェツ」へ出かけて、十二時頃から夜七時頃までぶらついた。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラーゲリ（野営地）で有名なんです」と口答えして笑ったが、敏感に限度を察して、それきりさわぐのをやめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
