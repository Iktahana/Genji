        "examples": {
          "standard": [
            {
              "text": "仏殿の須弥壇の両脇には、美しい装飾が施された来迎柱が立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来迎柱には、極楽浄土へ導く仏様の姿が彫刻されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "修復された来迎柱は、創建当時の姿を今に伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "寺の本堂の来迎柱の前に控へたやうで、蝋燭のはためく儘に、部屋の四壁へ明暗定まりなき影が浮ぶ。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
