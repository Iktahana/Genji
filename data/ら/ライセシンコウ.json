        "examples": {
          "standard": [
            {
              "text": "古代の人々は、来世信仰に基づいて埋葬の儀式を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の心の支えは、来世信仰にあると言っても過言ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来世信仰は、多くの宗教において重要な教義の一部をなしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十四章十四節においては「人もし死なばまた生きんや」との来世問題を一の疑問として提出せし有様であったが、再生の要求彼に根深くして、遂に十九章に至っては二十六節の如き明白なる来世信仰を抱くに至ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            }
          ]
        }
