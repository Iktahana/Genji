        "examples": {
          "standard": [
            {
              "text": "一度でも嘘をつくと、この街では嘘つきの烙印を押されて生きていくことになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は過去の失敗のせいで、社内で無能の烙印を押され、不遇な日々を過ごしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「一度のミスで落伍者の烙印を押されるなんて、あまりにも厳しすぎる社会だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "せっかくの研究が「いかもの」の烙印を押されるような気味が感ぜられるからである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の定説が破れなければ、妻は不貞の烙印を押されるのです。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていの夢は、それが常になく鮮明かつ明晰であっても、行動の統一性や、細部および ｜dramatis personae における一貫性に不足する点があり、故に不完全ないし分裂した大脳機能の所産という烙印を押されることになる。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の過去の生活に關する話が、その人の口から洩れゝば、もう私は永久に惡い子供として烙印を押されることになるのだから。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
