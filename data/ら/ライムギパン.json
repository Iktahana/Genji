        "examples": {
          "standard": [
            {
              "text": "朝食には、クリームチーズを塗ったライ麦パンが定番です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "しっかりとした食感のライ麦パンは、食べ応えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このサンドイッチはライ麦パンで作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、みんないっしょに、ライ麦パンとミルクかスープのごはんを食べ、大草原に長く伸びる影を眺めたり、美しい大聖堂の尖塔にかかるたそがれのとばりを眺めたりします。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "中を調べてみると、瓶入りの山羊のミルクが三本とブリキの容器に入ったライ麦パンが六斤あった。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
