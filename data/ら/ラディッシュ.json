        "examples": {
          "standard": [
            {
              "text": "お弁当の彩りが少し寂しかったので、ベランダのプランターで育てた小さな赤いラディッシュを丸ごと一つ添えてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スライスしたラディッシュを塩揉みして甘酢に漬け込むと、鮮やかなピンク色に染まって見た目も美しいピクルスが完成する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "サラダバーのコーナーで、彼女はレタスの上に薄切りのラディッシュとベビーリーフをたっぷりと盛り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "４日目に新生児の臍帯の上にモクサを載せるか、ホースラディッシュで焼灼する。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホースラディッシュは附いていたが、ヨークシャープディングは添えてない。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ヨークシャープディングと迄は行かず、ホース・ラディッシュのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
