        "examples": {
          "standard": [
            {
              "text": "明日は取引先を招いて、ホテルでランチョンを開く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "チャリティーイベントの一環として、簡単なランチョンが用意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "受賞者を祝うためのランチョンが、和やかな雰囲気の中で行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "乾葡萄入りのランチョン。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして頭のとおいところで、ランチョンの中にあるアメチョコの甘さを考えて居た。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角いあの缶を開き、ナイフを斜めに突き立ててランチョン・ミートの固まりをなかば引出し、一センチほどの厚さで三枚、バターを敷いたフライパンにスライスする。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
