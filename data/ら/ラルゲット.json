        "examples": {
          "standard": [
            {
              "text": "ピアノソナタの第二楽章はラルゲットの指示があり、少しゆったりとしたテンポで優美に弾き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "指揮者はタクトをゆっくりと振り下ろし、弦楽器にラルゲットの穏やかなテンポを提示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "悲しげな主題が、ラルゲットの速度でオーボエからフルートへと静かに受け継がれていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの全曲は、次の曲たるラルゲットのために書かれたものであった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
