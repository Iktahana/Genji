        "examples": {
          "standard": [
            {
              "text": "引退を表明した名選手に対し、ファンからは連日熱いラブコールが届いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新進気鋭の若手俳優に、複数の映画監督から出演のラブコールが送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君が必要なんだ」という社長直々のラブコールに、彼はついに移籍を決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "phone call to a loved one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
