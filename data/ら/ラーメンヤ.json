        "examples": {
          "standard": [
            {
              "text": "飲み会の締めはやっぱり、昔からある駅裏のあの古いラーメン屋に行くのがお決まりのコースだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「頑固親父のいるラーメン屋で、スマホをいじりながら食べていたらこっぴどく怒られたよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は脱サラして、念願だった自分のラーメン屋台を引いて夜の街を歩き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マンハッタンでサッポロラーメン屋がつぶれたって、だれも気づきもしませんよ」　ワラが、もうひとつのプレイヤーをスタートし、おなじ手順で、ゲートに入った馬のように、いまにも走りだしそうなディスクの手綱を握った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "店に入るとラーメン屋でありながらジャズが流れているというアンバランスさにちょっと驚いたが、この向うの新宿通りにいつもボリュームいっぱいにロックをかけている弁当屋があるのを思い出し、特にこの店だけが変わってるわけじゃないんだなと独りごちて浩は苦笑した。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
