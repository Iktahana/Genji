        "examples": {
          "standard": [
            {
              "text": "卒論を書くために、新しくラビーのノートパソコンを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やっぱりラビーはキーボードが打ちやすくていいよね」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "故障したラビーを修理に出すため、サポートセンターに連絡を入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "むしろエジプトの敗将、セイロン島の遷客たるアラビーパシャに倣い、日本の将来はただ上帝これを知るのみと安着するにしかざるべし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二個中隊のうちの一個中隊はカラビーヌ銃を持っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど畑の作物が高く伸びている時期であって、高地の縁には、ケンプト旅団の一隊第九十五連隊が、カラビーヌ銃を帯びて高い麦の間に伏してるのだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼は右にドイツの軽騎兵を指揮してるドルンベルグを有し、左にはベルギーのカラビーヌ騎兵を指揮してるトリップを有していた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
