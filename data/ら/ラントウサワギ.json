        "examples": {
          "standard": [
            {
              "text": "忘年会の二次会で、些細なことから両グループの間で乱闘騒ぎになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "応援していたチームが負けたことに腹を立てたサポーターが、スタジアムの外で乱闘騒ぎを起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あの温厚な彼が乱闘騒ぎに巻き込まれたなんて、信じられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "――だが、聴衆は場外にあふれて、所々に乱闘騒ぎを起した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
