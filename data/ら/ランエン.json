        "examples": {
          "standard": [
            {
              "text": "このテーブルは珍しい卵円の形をしていて、部屋のアクセントになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の描く顔の輪郭はいつも優雅な卵円形だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "卵円の窓から差し込む光が、部屋全体を柔らかく包んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "医学博士押鐘童吉は五十代に入った紳士で、薄い半白の髪を綺麗に梳り、それに調和しているような卵円形の輪廓で、また、顔の諸器官も相応して、それぞれに端正な整いを見せていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし下方の者は卵円形で葉柄がある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
