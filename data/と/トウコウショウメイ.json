        "examples": {
          "standard": [
            {
              "text": "夜間の工事現場では、投光照明が作業員の安全を確保していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スタジアムの投光照明が点灯し、試合開始の合図となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館の壁には、絵画を美しく見せるための投光照明が設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二階部分の工事に入った、新寮の工事現場からの投光照明が、異様に明るい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感じは、丘が紫に暮れ、ランプの灯がともる黄昏となり、裁判所の投光照明とインダストリアル・トラスト社(*7)の赤く燃える航空標識が夜をグロテスクに染めた後まで長く残った。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
