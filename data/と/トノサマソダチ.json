        "examples": {
          "standard": [
            {
              "text": "彼は殿様育ちだから、自分でお茶を淹れることさえ知らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "殿様育ちの彼にとって、安アパートでの一人暮らしは過酷な試練だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "苦労知らずの殿様育ちとはいえ、彼の性格は至って温厚だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "賢明と云っても、殿様育ちにすぎん。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに殿様育ちのお坊ちゃんで、世間というものを、まるで知らなかった。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
