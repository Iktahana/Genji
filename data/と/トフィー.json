        "examples": {
          "standard": [
            {
              "text": "お土産にいただいたトフィーは、バターの香りが濃厚でとても甘かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トフィーを食べていたら、詰め物が取れてしまったので歯医者に行かなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は手作りのトフィーを小さな袋に入れて、友人たちに配って歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一七四三年にコットン博士の丘の教会と決裂したホワイトフィールド一派がグレート・ブリッジの向かいにディーコン・スノー教会を創立したとき、カーウィンは一緒にそちらに移った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーカス・カアイラウの右隣に、ダナ・ホワイトフィールド。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーカス・カアイラウやダナ・ホワイトフィールドのギターは、風だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダナ・ホワイトフィールドに、彼とよくデュエットで歌う女性、ダイアナ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
