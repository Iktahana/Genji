    },
    "definitions": [
      {
        "index": 1,
        "gloss": "honest and homely",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は飾らない敦朴な人柄で、多くの人から信頼されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書く文章には、人柄の敦朴さがよく表れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの老夫婦は敦朴な生活を送っており、質素ながらも幸せそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かつその地都会と異なり、人情敦朴にして、諸事に深切なり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんぼくはえてきた親つばめ子つばめあをむけば蜘蛛のいとなみ　七月三十日晴、晴、晴、一雨ほしいなあ！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
