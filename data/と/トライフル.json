          "standard": [
            {
              "text": "スポンジケーキとフルーツを層にしたトライフルは、イギリスの家庭で愛される定番のデザートだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ガラスの器に盛り付けられた色鮮やかなトライフルは、見た目も華やかでパーティーにぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "余ったケーキの端切れを使って、手軽で美味しいトライフルを作るのが母の得意料理だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かような触角が若し才智や、学識であるのなら、自分はどんなトライフルな描写の反復をも、一文不知の人々のために労を惜まぬであろう。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
