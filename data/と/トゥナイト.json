        "examples": {
          "standard": [
            {
              "text": "トゥナイトは友人とレストランで食事をする予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "トゥナイトは早く寝て、明日に備えよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テレビでトゥナイト放送されるドラマが楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「ウェル、ゴナ・ビー・ザ・ラスト・ソング・フォー・トゥナイト……ウー、ベイビー、アイ・ラヴ・オンリー・ユー、〈ユー・ベイビー〉」　ワラが、ドラムとスレイ・ベルをバックにささやく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の部で彼は『グッド・ロッキン・トゥナイト』と『ザッツ・オールライト、ママ』を歌った。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
