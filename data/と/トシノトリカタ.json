        "examples": {
          "standard": [
            {
              "text": "彼女のように、いくつになっても好奇心を失わない素敵な年の取り方をしたいものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「人によって年の取り方は様々だけど、君はいつも若々しくていいね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "規則正しい生活と適度な運動が、健康的な年の取り方の基本だと言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "老人には老人の云ひ分があらうけれども、若いもののひとしく心の中で呟く言葉は、「あゝいふ年の取り方はしたくない」であらう。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんとに、女もさうですけれども、人間の年の取り方つて不思議なものですわ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
