        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ワールドカップは、勝ち抜き方式のトーナメントで優勝が決まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このボクシング大会は、一発勝負のトーナメント形式だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もしトーナメントの初戦で負けてしまったら、次のチャンスはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
