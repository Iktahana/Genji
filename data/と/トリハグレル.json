        "examples": {
          "standard": [
            {
              "text": "「倒産した会社からの売掛金を、結局最後まで取りはぐれてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「配給の列に並ぶのが遅れて、今日の分の食料を取りはぐれた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ギャンブルに負けて、せっかくの勝ち分さえも取りはぐれる羽目になった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これまでどおり、メーカーやディーラーの注文を受けて開発作業を請け負っている限り、少なくともかけた手間に見合った報酬を取りはぐれる恐れはなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
