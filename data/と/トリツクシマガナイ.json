    "definitions": [
      {
        "index": 1,
        "gloss": "left utterly helpless (e.g. by a curt reply or refusal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "借金の相談に行こうとしたが、玄関先で「二度と来るな」と怒鳴られ、取り付く島がなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仲直りしたくて電話をかけたものの、冷たくあしらわれてしまい、取り付く島がない状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "交渉のテーブルについても、相手側は一切の妥協を許さず、取り付く島もなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　その人も取り付く島がないので引き退がった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その人も取り付く島がないので引きさがった。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは取り付く島がない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそれかといって、冷くすましていられるのもとりつくしまがない。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
