          "standard": [
            {
              "text": "限定販売のスイーツは、開店と同時に飛ぶように売れて一時間で完売した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猛暑の影響で、家電量販店ではエアコンが飛ぶように売れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その作家の最新刊は、書店に並ぶやいなや飛ぶように売れて重版が決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その書置きが絵端書になって飛ぶように売れる。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽が生えて飛ぶように売れる。",
              "citation": {
                "source": "落語・教祖列伝",
