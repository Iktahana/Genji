        "examples": {
          "standard": [
            {
              "text": "東宮職は、皇太子の公務や私的な生活を支える重要な役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は東宮職の一員として、皇室の伝統を守るために尽力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東宮職の職員たちは、常に細心の注意を払って職務にあたっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "東宮職の方で君に殿下へ雪の御進講を希望しておられるが、都合はどうかという問合わせである。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三　東宮殿下は小金井の東宮職の中に起居され、学習院の生徒たちと同じ教育を受けておられる。",
              "citation": {
                "source": "雪今昔物語",
