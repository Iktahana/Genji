        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この夏は、トリコロールのストライプ柄のシャツが爽やかなマリンスタイルとして流行している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はトリコロール配色のスニーカーを履いて、スポーティーなコーディネートを楽しんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しく購入したマグカップは、赤と青のラインが入ったトリコロール風のデザインで気に入っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
