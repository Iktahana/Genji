        "examples": {
          "standard": [
            {
              "text": "昔の映画の特撮技術は、現代のものと比べて素朴だが、温かみがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新のハリウッド映画は、CGを駆使した迫力ある特撮で観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの監督の作品は、リアルな爆破シーンの特撮がいつも素晴らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "みればぐにやぐにやした内臓がくさりかかつて居るらしい、それゆゑ哀しげな晩かたになると、青ざめた海岸に坐つてゐて、ちら、ちら、ちら、ちらとくさつた息をするのですよ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みればぐにやぐにやした心臟がくさりかかつてゐるらしいそれゆゑ哀しげな晩がたになると青ざめた海岸に坐つてゐてちら　ちら　ちら　ちら　とくさつた息をするのですよ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その時直に思ひ浮んだのは、くさふるふとくさつゝみとの関係です。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はちよつとくさつて、くるりと向うをむいた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
