        "examples": {
          "standard": [
            {
              "text": "朝のトワレの時間は、彼女にとって気分を整える大切な習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デパートの香水売り場には、様々なブランドのオードトワレが並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は普段から香水をつけず、ほんのり香るトワレを好んで使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "家郷追放、吹雪ノ中、妻ト子トワレ、三人ヒシト抱キ合イ、行ク手サダマラズ、ヨロヨロ彷徨、衆人蔑視ノ的タル、誠実、小心、含羞ノ徒、オノレノ百ノ美シサ、一モ言イ得ズ、高円寺ウロウロ、コーヒー飲ンデ明日知レヌ命見ツメ、溜息、他ニ手段ナキ、コレラ一万ノ青年ヲ思エ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンが、トワレの扉を閉めた刹那だった。",
              "citation": {
                "source": "ジャンの新盆",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
