    "definitions": [
      {
        "index": 1,
        "gloss": "to grow old",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「年がいけば、些細なことで涙もろくなるのは仕方ないさ」と祖父がハンカチを拭った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年がいってから始めた油絵が、今では個展を開くほどまでに上達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若いうちは反発ばかりしていたが、年がいって初めて親が注いでくれた愛情の深さが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このカタツムリたちは、自分たちの年がいくつか知りませんでした。",
              "citation": {
                "source": "幸福な一家",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮沢賢治という人は何処の人だか、年がいくつなのだか、なにをしている人なのだか私はまるで知らない。",
              "citation": {
                "source": "惰眠洞妄語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ年頃の不良少年がいくらも居た。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊りはうまいが、芝居は下手というようなのは、年がいくと共に腐って、やめてしまう。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to pass (of a year)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日々の忙しさに追われているうちに、やりたいことを残したまま、あっという間に年がいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今年もこうしてどんどん年がいくねえ」と、近所の人と年末の挨拶を交わす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "着々と準備を進めておかないと、何の結果も出せないうちに無情にも年がいってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
