        "examples": {
          "standard": [
            {
              "text": "狭い土地でも快適に暮らせるよう設計された、屋上庭園付きの都市型住宅が注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事帰りに手ぶらで寄れる都市型バーベキュー場が、若者たちの間で流行している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都市型災害への備えとして、大規模な地下シェルターの設置計画が検討されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自慢ではないがオレは広島産の山猿で、常設の小屋で演じられるのが本筋の落語や芝居といった大都市型文化にはまるで弱い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マレー半島では都市型および農村型の熱帯発疹チフスがあってやはり散発的であり集団感染を起こすことは稀である。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十三で死んで、私は子供心には、そのとしがたいへんな老齢のやうに感ぜられ、まづ大往生と思つてゐたのだが、いまは五十三の死歿を頽齢の大往生どころか、ひどい若死にと考へるやうになつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰をはりて後あるじがいふ、茶の間の旦那秋山のことばに人を敬して茶の間の旦那といふ、茶の間をももちし人といふ事にやどつふりに入らずといふ、此ことばさとしがたくて案内に問へば、居風呂に入り玉へといふ事也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
