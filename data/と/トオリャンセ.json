        "examples": {
          "standard": [
            {
              "text": "子供たちが手をつないで「通りゃんせ」を歌いながら遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「通りゃんせ、通りゃんせ」の歌が、懐かしい記憶を呼び覚ます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのメロディーは、日本の童謡「通りゃんせ」だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここは何処の細道じゃ／＼天神様の細道じゃ／＼ちっと通してくださんせ／＼御用のないもな通されぬ／＼天神様へ願かけに／＼通りゃんせ、通りゃんせ。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
