        "examples": {
          "standard": [
            {
              "text": "「その教会では、父と子と聖霊のトリニティーについて教義を説いている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「SF映画のヒロイン、トリニティーの華麗なアクションに目を奪われた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「三つの要素が調和したその製品は、まさに完璧なトリニティーと言える。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "当時取りかかっていた仕事は、アメリカのボイジャーからこの年の八月に刊行された、『ザ・デイ・アフター・トリニティー』というＣＤ―ＲＯＭの翻訳でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "平岡敬広島市長の陳述『ザ・ディ・アフター・トリニティー』日本語版の発売開始は、一九九六（平成八）年二月のマックワールドエキスポを目標に据えていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "原子爆弾開発プロジェクトの中心となった物理学者、ロバート・オッペンハイマーの軌跡をたどったドキュメンタリー映画、『ザ・デイ・アフター・トリニティー』を中心に据えたタイトルだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に『ザ・デイ・アフター・トリニティー』を紹介しようとするのなら、この作品がもっぱら片側の声のみを拾ったものであることを自覚するべきだと、しだいにそう思うようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダブリン（Dublin）はアイルランド第一の都会なれば、博物館、図書館、動物園、植物園等、ロンドンに次ぎての壮観を極め、トリニティー大学（Trinity College）のごとき、ケンブリッジ大学、オックスフォード大学に接踵する勢いあり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始の森に近い田舎に育ちトロントのトリニティー・カレッジに入学した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
