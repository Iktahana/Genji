        "examples": {
          "standard": [
            {
              "text": "年改まるにあたり、心機一転してこれまで避けていた難関資格の勉強を始める決意をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年改まる佳き日に、皆様の益々のご健勝とご多幸を心よりお祈り申し上げます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古いカレンダーを真新しいものに取り替え、年改まる厳かな空気の中で身を引き締めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "年改まるごとにいま母に対するの観念と、および実行が幼少のときの思想とどれほど一致するか。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "年改まるごとに、今日のわがなすことが、この点においてどうであろうと対照してみる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い海の彼方なる常世の国に鎮る村の元祖以来の霊の、村へ戻つて来るのが、年改まる春のしるしであつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
