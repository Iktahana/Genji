        "examples": {
          "standard": [
            {
              "text": "軍艦巻きの上に乗った鮮やかなオレンジ色のとびっこが、口の中でプチプチと弾ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彩りを添えるために、海鮮サラダのトッピングとしてとびっこを贅沢に散らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちは、いくらよりも小粒で食べやすいとびっこの手巻き寿司を喜んで食べる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "画かきはあっはは、あっははとびっこのような笑いかたをしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心持ち右と左とびっこの眼で、何処からかじっと見られてる心地がした。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（言いながら、ステッキを突きヨロヨロとびっこを引いて絵の方へ行く）……なんだ、もう出来あがってる。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
