        "examples": {
          "standard": [
            {
              "text": "会社の決算で、予期せぬ地震による工場の損壊が特損として計上された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リストラ費用など、通常の経営では発生しない損失を特損と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "株価は、企業が特損を計上したというニュースを受けて大きく下落した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "原の城にこもった一揆の中の、幹部と称される連中は、ことごとくそんなように思っていたらしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世間のことごとくが、必ずしもそんな冷酷な心のもののみではなく、改善融和の運動家がことごとくそんな卑しい根性のもののみではありません。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は秘密な事を見、あるいはいろいろの事を聞きたいために、他の僧侶のごとくそんなにお経を読み、かつ茶を飲みに行くためには行かなかった。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "心して用いられよ」　と、平常のごとくそんなことを語ったりしていた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
