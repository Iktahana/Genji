          "standard": [
            {
              "text": "春先や秋口になると、ベージュのトレンチコートを着た人を街でよく見かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父から譲り受けた使い古しのトレンチコートは、どこか威厳を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨の日でも出かけられるよう、撥水加工が施されたトレンチコートを新調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "晴れても降っても、白茶けたトレンチコートの学生群が、舗道の上を右往左往するだけの街になった。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝巻の上へ大きなトレンチコートを着て煙草を喫いながらゆっくりとこっちへやってくる。",
              "citation": {
                "source": "キャラコさん",
