        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "来月公開される新作映画のトレーラーが解禁され、ファンの間でネット上の期待が高まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゲームの公式トレーラーには、初出しの戦闘シーンや新キャラクターが数多く盛り込まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "YouTubeで映画のトレーラーを見ていたら、あまりの迫力にどうしても映画館へ行きたくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
