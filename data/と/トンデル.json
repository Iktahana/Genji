        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女のファッションセンスはいつも翔んでて、個性的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのバンドの音楽は翔んでて、若者に人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の発想は翔んでるけど、たまにそれが成功するから面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いかにも翔んでるという感じの、金髪の美人だ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に吹かれて横にとんでるかと思うと、風がちょっと息をする間、まっすぐに落ちます。",
              "citation": {
                "source": "風ばか",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、蝶々がとんでるわ。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい太陽、蝶もとんでる。",
              "citation": {
                "source": "安吾巷談",
                "author": "教祖展覧会",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に河内が帰っているから、社内にはすでに噂がとんでるだろうが、せつ子はハラをきめたから、平静を失わなかった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、すぐそこを、すいすいととんでるじゃないか。",
              "citation": {
                "source": "あたまでっかち",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「枕許に血がとんでるな」と町役の一人が云った。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
