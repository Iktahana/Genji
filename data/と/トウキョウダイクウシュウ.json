          "standard": [
            {
              "text": "東京大空襲は、第二次世界大戦末期に東京が受けた壊滅的な空襲だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で、東京大空襲の悲惨さについて学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "東京大空襲の経験者が語る話は、心に深く刻まれるものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、この子はあの三月十日の東京大空襲のさい、女學校から女子挺進隊にとられてゐて私のそばにも居られませんで、つひに戰災のもとに死なせてしまひました。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
