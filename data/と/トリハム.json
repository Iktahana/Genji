        "examples": {
          "standard": [
            {
              "text": "ヘルシーな夕食にしようと思って、鶏胸肉で自家製の鳥はむを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この鳥はむ、しっとりしてて美味しいね。どうやって作ったの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お弁当の隙間を埋めるのに、作り置きしていた鳥はむが重宝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小鳥はむなしく啼泣しているのみである。",
              "citation": {
                "source": "庭の眺め",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……といつたら、あるひは人は、やきとりはむかしからある、さういつてわたしをわらふかも知れない。",
              "citation": {
                "source": "夜店ばなし",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
