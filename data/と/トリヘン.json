        "examples": {
          "standard": [
            {
              "text": "「鶴」や「鶏」という漢字には、右側に鳥偏がついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "書道の先生から、鳥偏をバランスよく書くための筆の運び方を教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漢和辞典で鳥に関する漢字を探すときは、まず鳥偏のページをめくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
