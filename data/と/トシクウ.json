        "examples": {
          "standard": [
            {
              "text": "あんなに小さかった隣の家の子がもう就職だなんて、私も相当年食うわけだと実感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつの間にかこんなに年食っちゃって！」と同窓会で再会した友人たちと笑い合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年食うほどに、若い頃のような無茶はせず、自分のペースを大切にする生き方に変わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "武士族の尊いお方をも、いやしい穢多をもひとしくうやまいます。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくいひて眺めつゞくるあひだに、ゆくりなく風吹きてこげどもこげどもしりへしぞきにしぞきてほとほとしくうちはめつべし。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "盟主をうしなった天下の群雄は、ひとしくうろたえまよった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
