        "examples": {
          "standard": [
            {
              "text": "「急いで電車に乗ったせいで、ホームに大切な傘を取り残してしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「急速なデジタル化の波は、一部の高齢者を社会から取り残す懸念がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「大雨で道が寸断され、数名の登山客が山頂の小屋に取り残された。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分が死んだ後、この孤独な母を、たった一人｜伽藍堂のわが家に取り残すのもまた甚だしい不安であった。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまた、その奔流は引き去って、われわれを乾燥した河床の中に取り残す。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋をとりのこすためには約千円位調達の必要あり。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
