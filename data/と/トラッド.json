        "examples": {
          "standard": [
            {
              "text": "紺のブレザーにチェックのパンツを合わせたトラッドな装いは、時代を問わず清潔感のある印象を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年の秋冬は、クラシックな英国調のトラッドスタイルがトレンドとして再注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父から譲り受けた質の良いトラッドなネクタイを締めると、背筋が自然と伸びるような気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから一週間ほどたって、私は例のストラッドフォード・オン・アヴォンに沙翁の故郷をたずねることになりました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
