        "examples": {
          "standard": [
            {
              "text": "有名な陶芸家の作品展を見に美術館へ行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は無口だが、その手から生み出される作品は陶芸家の情熱を物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若手陶芸家が伝統技法に新しい感性を加えて注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かように行きますとき、その絵画を見ただけで、どの程度の陶芸家であるかがわかります。",
              "citation": {
                "source": "陶芸家を志す者のために",
                "author": "―芸術における人と作品の関係について―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今申し述べましたように、すべての陶芸家が土をいじる前に、まず絵画をもって陶器を作る……を第一義とし、それが相当成功した上で、土の仕事にかかられても決して遅くはないと確信しております。",
              "citation": {
                "source": "陶芸家を志す者のために",
                "author": "―芸術における人と作品の関係について―",
                "note": "青空文庫"
              }
            },
            {
              "text": "（陶芸家）　仁阿弥道八（江戸後期）……これより職人芸はじまる。",
              "citation": {
                "source": "私の作陶体験は先人をかく観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の陶芸家から見て、美術学校の板谷波山氏あるいは大倉陶園のように、いたく瑕瑾を厭うこれら当事者たちは、生涯カイラギの妙味、または釉掛けの火間と称するうま味、焼き曲りの妙などは到底わかろうはずがないのである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
