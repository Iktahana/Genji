        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ゴルフ界期待の飛ばし屋として注目され、彼は連日メディアに取り上げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛ばし屋の彼が放つ打球は、ピンまで最短距離で一直線に飛んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛距離だけが武器ではないが、やはり飛ばし屋はギャラリーを沸かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "朝眼が覺めるとばしや／＼といふ雨の音である。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜十　うう、俺あ、へえ、どんな悪いことばしやした？",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車が混雑しなくなれば誰も押しとばしやしない。",
              "citation": {
                "source": "現代の詐術",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
