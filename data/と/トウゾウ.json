        "examples": {
          "standard": [
            {
              "text": "目の網膜には、物体が「倒像」として映し出されているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顕微鏡を使うと、視野の中の像が「倒像」になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カメラのレンズを通すと、光が屈折して「倒像」を結ぶんだよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ねえ光子さん、お祖母さまはどうして何故に、黒頭の笄の下向きを怖れられていたのでしょうか」　それに依るとお筆の急死は、瞬間現れた倒像に駭いての、衝撃死に相違いなかった。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意して見ると、最も高く真像、その下に倒像、その又下に水平線がある。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち真像は勿論倒像迄上に釣り上つて居るのである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
