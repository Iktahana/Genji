        "examples": {
          "standard": [
            {
              "text": "高価な漢方薬として知られる冬虫夏草は、健康食品としても注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬虫夏草は、昆虫の幼虫に寄生して成長する珍しいキノコだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究者たちは、冬虫夏草の持つ薬効成分について詳しく調べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "樺太の日露国境の辺で採収して新に命名された紫のサカイツヽジ、其名は久しく聞いて居た冬虫夏草、木の髄を腐らす猿の腰かけ等。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
