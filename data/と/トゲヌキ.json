        "examples": {
          "standard": [
            {
              "text": "指に刺さった小さな刺を抜くために、救急箱からとげ抜きを取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "おじいちゃんは眼鏡をかけ直し、真剣な表情でとげ抜きを操っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ピンセットじゃなくて、専用のとげ抜きを使った方がいいよ」と教わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "カヨの祖母にあたるひと、白木家の長命なお婆さんが、巣鴨のとげぬき地蔵様をたいへん信仰して、そのお札を一万枚、供養のため、両国橋の上から大川に流したことがある。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不動様も、とげぬき地蔵様も、実印の一件に重みをつける役に立ったのである。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が災後も恐らく全いであらうとげぬき地蔵へ行く道の一角に安置されてゐたあの濡れ仏である。",
              "citation": {
                "source": "巣鴨菊",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、女房と輪飾り、門松などとげぬき地蔵の方へ買いに行く。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
