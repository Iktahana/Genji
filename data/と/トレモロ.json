        "examples": {
          "standard": [
            {
              "text": "ギターのトレモロアームを使うと、音に独特の揺れやビブラートを加えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のヴァイオリン演奏は、繊細なトレモロが聴衆を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ピアノのトレモロ奏法は、高速で鍵盤を交互に叩き、音を震わせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この私の弱い骨を、暖いトレモロで満たして下さい。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、同じ北斎が自分の得意の領分へはいると同じぎざぎざした線がそこではおのずからな諧調を奏してトレモロの響きをきくような感じを与えている。",
              "citation": {
                "source": "浮世絵の曲線",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅毛人の言葉を借りれば、芭蕉の情調のトレモロを如実に表現した詩語である。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に歌ふトレモロ――秋の初風。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけなく藪陰から提琴の好い音が響いたり、気どったトレモロが聞こえたりします。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高音部のトレモロ、マイナーのアルペジオ。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドン・ホアンにとつては、その愛する者は、嚴密な倫理的意義から云へば、人格ではなくて唯彼の魂にトレモロを準備するための器械である。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
