        "examples": {
          "standard": [
            {
              "text": "長引いた相続争いは、親族間での解け合いによってようやく円満に解決した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "相場が急変した際、取引所が介入して解け合いを行い、混乱を最小限に抑えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑に絡み合った利害関係を、第三者の仲裁による解け合いで整理することに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして私はこんなにまで私と打ち解け合いだしているこの少女を振り棄てて、自分ひとりこの村を立ち去るなんぞということは、到底出来そうもないと考え出していた。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの当時の苦しみやたのしみは、今になって考えてみると、それが苦楽相半ばして一つの塊りとなって、芸術という溶鉱炉の中でとけあい、意図しなかった高い不抜の境地をつくってくれている。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルロ・ナインも起して連れて来てもいい……ほかはちょんの間に寝かしとけあいい。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ旅支度のまんまで入院したんだから、宝石だけでも大変なもんですってサア」「そんな物あ病院の金庫に入れとけあいいのに……」「それがね。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
