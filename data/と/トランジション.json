        "examples": {
          "standard": [
            {
              "text": "動画編集アプリを使って、カットの繋ぎ目に滑らかなトランジション効果を加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学生から社会人へのトランジションは、精神的に大きな負担がかかる時期だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バスケの試合で、ディフェンスからオフェンスへのトランジションが非常に速かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（ベケットと云ふ人のことは少しも知らないが、聞けば「トランジション」などによく詩を出してゐるイギリスの若い詩人ださうである。",
              "citation": {
                "source": "續プルウスト雜記",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、モンテーニュ自らがそうしたトランジションを改行によってすら示さなかったというのは、単なる偶然とも無頓着とも思われないので、訳者もなるたけ目立たないように、単に行間に間隙を設けるだけにとどめ、別に註の中に各部に対する簡単な仮題を示した。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
