        "examples": {
          "standard": [
            {
              "text": "ナポレオン戦争の帰趨を決めたトラファルガーの海戦で、ネルソン提督率いるイギリス艦隊は劇的な勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トラファルガーの海戦の結果、フランスによるイギリス本土上陸の脅威は完全に払拭されることとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史ドキュメンタリーで、当時の軍艦の布陣を再現しながらトラファルガーの海戦の戦術を詳しく解説していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ネルソンはトラファルガーの海戦には、片手をもぎとられても、なほ艦隊運動の命令を下しつゞけ、命をなげ出して指揮をしました。",
              "citation": {
                "source": "青い顔かけの勇士",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
