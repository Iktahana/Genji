          "standard": [
            {
              "text": "この地域は冬の間、凍結融解を繰り返すため、道路が傷みやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "生物学の実験で、細胞の凍結融解を慎重に行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "凍結融解を繰り返すと、食品の品質が低下することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それと同時に、泥炭地の地中温度および水分の分布と、その季節による変化、特に凍結融解の際の熱の伝達と水の移動の状態とを、天然の泥炭地について、気象学的測定と並行して通年行う必要がある。",
              "citation": {
                "source": "泥炭地双話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
