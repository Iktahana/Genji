        "examples": {
          "standard": [
            {
              "text": "悪戯が見つかった猫が、なんとも可愛らしいとぼけ顔をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は怒られている最中もとぼけ顔を崩さず、火に油を注いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「知らないよ」と言わんばかりのとぼけ顔に、思わず笑ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あまりみごとなとぼけ顔にぼんやりして了うのです。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこはかとなく、待てる時節が来ているとは思しめさぬか」「どういう時節が」「これはまた、あっぱれな、おとぼけ顔ではある」　打ッちゃられたように、左近はツギ穂を失って、どぎまぎしたが、その反動をこめて、また。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
