    "definitions": [
      {
        "index": 1,
        "gloss": "formal, usually black, kimono with designs along the bottom of the skirt worn by married women on ceremonial occasions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "妹の結婚式で、母は五つ紋の黒留袖を凛々しく着こなしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いつか自分も留袖を着る日が来るのかな」と、鏡の前で着物をあててみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "留袖の裾に描かれた華やかな模様が、披露宴の会場でひときわ目を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "最初は上品な丸髷に結った新夫人を、渋い好みの人にして描くつもりで、丸髷にして写生をはじめたのでしたが、舞の二段おろしになりますと短い留袖では袖が返りません。",
              "citation": {
                "source": "作画について",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "京町とか、しののめとか書いた提灯散らしの模様をいっぱいに染め出した留袖。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
