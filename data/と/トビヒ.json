    "definitions": [
      {
        "index": 1,
        "gloss": "leaping flames",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "隣町の火災から強風に乗って飛び火が発生し、川を挟んだこちらの民家まで燃え移ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "消防団の人たちは、飛び火を防ぐために周囲の家の屋根に必死で放水を続けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バーベキューの炭火の後始末を怠ったせいで、周囲の枯れ草に飛び火して山事態を招いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただしかし、近所へ迷惑かけてはならんからな、飛び火だけは気をつけるがよいぞ」　言いすてると、急に気の強くなった伝六になわじりをとらして、さっそうとしながら引き揚げてまいりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "この海港にある邦人紡績会社のほとんど全部の工場は、今は飛び火のために苦しみ出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが上海へ直ちに飛び火して蒋介石の勃興となり、彼の共産軍反撃となって全支那の独裁権の掌握となったが、それから十三年再び同様の戦いが起って来た。",
              "citation": {
                "source": "静安寺の碑文",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の口から出た言葉は、群衆という群衆、紳士、馬番、女中、身なりのいいのも悪いのも、次々と飛び火し、皆が「火事だ！",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "紛争の炎は地方の大学へ、そして高校生へと飛び火し、学生たちの揺れは総体として見ればますます大きなものとなっていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "全共闘運動が日本全国に飛び火し、東京大学と東京教育大学が入学試験の中止に追い込まれた一九六九（昭和四十四）年、浮川は愛媛大学工学部に入学した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾軒かの建物へ飛び火した。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人家に飛び火して大事にならないとも限らない。",
              "citation": {
                "source": "ものの影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "多胡碑の里から火事がでて馬庭へ飛び火したこともあるそうだ。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省は仏蘭西大使館からの飛び火で、土蔵一つ残して全焼したのだ。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝮酒屋から飛び火して、七ツ寺界隈一円に、どうやら火事が拡がったらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社、仏閣、貴族の邸宅をみるみるうちになめつくし、京の街々を、はいずり廻った火は、その勢で御所に向い、朱雀門に先ず飛び火し、またたく間に、全｜内裏中を焼きつくしてしまった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを飛び火とばかり解繹して、何んの詮索もしなかつたのは迂遠で、その後夜毎の火事にしても、江戸の諸方から一度に火の手の擧がる樣子は、どう考へても、多勢の者が連絡して、八方から火を放つとしか思はれず、この關係に氣が付いて、橋や堂宮の落書に連絡を見出したのはさすがに平次の手柄でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "火の呪ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『飛び火です』『飛び火？",
              "citation": {
                "source": "社長秘書",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを飛び火とばかり解釈して、なんの詮索もしなかったのは迂遠で、その後夜ごとの火事にしても、江戸の諸方から一度に火の手の挙がる様子は、どう考えても、多勢の者が連絡して、八方から火を放つとしか思われず、この関係に気が付いて、橋や堂宮の落書に連絡を見出したのはさすがに平次の手柄でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりしたら江戸へも飛び火じゃぞっ！",
              "citation": {
                "source": "脚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき金杉の店も飛び火で焼けたのだが、彼はそれさえも知らなかった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "むじな長屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び火はせず、その武家屋敷だけで済んだらしい。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに飛び火らしい、元の火先は西へ靡いているのに、それとは方角の違う然もずっとこちらへ寄ったところに、新しい橙色の明りが立ちはじめた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬研堀から矢の倉へかけて、橙色のすさまじい火が、上から抑えつけられたように横へ広くひろがっている、そしていつ飛び火がしたものか、本所河岸もすでに炎々と燃えていた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……思い上がったやつだ」「ハハハハ、よそう、ここでまた、其許たちと、試合の飛び火をこしらえても始まるまい。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがニューヨーク市場に飛び火してロンドン市場に跳ね返った時、何が起こるか誰も分からない。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "摩訶不思議なことに、インド大反乱を呼びこんだ狼煙のように、辺りに飛び火し、パブが急襲された。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ幸いな事は、火は、飛び火によるものらしく、敵勢の影は、まだここまでは侵入していなかった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや一時、文※の住居の方へ、飛び火したかと見えたときは、町の者でもない家人でもない不思議な人数が、一方の襲撃をやめて、そこの消火に努めたりしていたのだから、町民たちは明け方にいたって、「いったい、あの降ッて湧いたような人数は、どこから来てどこへ消えてしまったのか？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあなたの火悪戯は、あなたと信長のあいだに止まらず、国々へ飛び火する。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦火は彼らのもっとも身近な、しかも致命な所に、飛び火していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はいよいよ吹き荒んで、見る見るうちに、辺り二十七家の組屋敷から、町つづきの鈴木町、紅梅坂の武家屋敷の、ここかしこに飛び火した。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若宮小路にはまだ敵影を見ないから、飛び火にちがいあるまいが、柳営の一角からさえ、すでに煙の渦を噴き、真ッ赤な舌が、めろと、小御所の棟木をなめている。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりをたっとびひとりをいやしみません。",
              "citation": {
                "source": "手紙　二",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
