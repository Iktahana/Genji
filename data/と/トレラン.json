        "examples": {
          "standard": [
            {
              "text": "最近、健康のためにトレランを始めたら、すっかりその魅力にはまってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は、地元の山で開催されるトレランの大会に参加する予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "トレランは、全身運動になるだけでなく、美しい景色の中を走る爽快感も味わえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私が父につれられ亭劇に、セシル・Ｂ・デミルの「イントレランス」を見た時には、まったく、そのローマのセットの偉大なのには子供心に驚異を感じ、それより増しておどろいたのはその入場料がたしか五円か七円だったと思う。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人類の歴史』などというと、昔帝劇で十円の入場料をとって見せた『イントレランス』を連想されるかたがあるかもしれない。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前章で政治上の寛容（トレランス）が詳述された後をうけて、ここに道徳上の寛仁（クレマンス）が語られるのは、例によってなかなか配列の妙をえている。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
