        "examples": {
          "standard": [
            {
              "text": "巨大なトルネードが村を襲い、多くの民家がなぎ倒される甚大な被害が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はトルネードを追いかける「ストームチェイサー」として、全米を駆け巡っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "投手から放たれたボールは、まるでトルネードのような鋭い回転を伴ってミットに吸い込まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "メロンが出て、ポタアジュ、お代りをして、次スッポンのクリームソース、こいつを三つも食ったので、こたへた、鴨のジェリー、トルネードはお代りの元気なし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルネードも充分凝ったもので、うまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回の終り、又アラスカへ一人で行き、今日は、ポタアジュに、トルネード、椎茸のオムレツ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルネード、うまからず、ドレッシングがうまくてサラダ美味し。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田を連れて、アラスカへ行き、オルドヴル、ポタアジュ、トルネード・グランドホテル等、二人で九円は高い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の食事、キャビアその他オルドヴル中々よろしい、冷コンソメ、次にトルネードにドライカレー付、レタスとトマト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
