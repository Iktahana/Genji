        "examples": {
          "standard": [
            {
              "text": "仮想通貨市場は投機熱に煽られ、短期間で価格が乱高下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不動産バブルの時代、国民の間に投機熱が広がり、多くの人々が住宅購入に走った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新興企業の株に投機熱が集まり、冷静な判断が失われがちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "むろん私は世間で投機熱がいかに流行しても、株に手を出すなどということはなかったから、好景気に際して厘毛の利益も得なかった代り、この急落によって少しも打撃を被ることもなく、したがって中村屋は安泰であった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たび某処に一大利益が見ゆるとなると、俄に非常なる投機熱が起り、為に欧州の市場を攪乱した事は屡々ある。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
