        "examples": {
          "standard": [
            {
              "text": "おじいちゃんが大切にしているトランジスターラジオからは、いつも競馬中継が流れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "停電に備えて、電池で動く小型のトランジスターラジオを防災袋に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「トランジスタ・ラジオ」というRCサクセションの名曲を聴きながら、夜道を散歩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アマチュアのパイロットの資格を持っていたドンピアは、低い周波数の電波を受信できる小さなトランジスターラジオで天気情報を聞きながら、入力した数値を大小の順に従って並べ替える、ソートと呼ばれる作業のためのプログラムをスイッチから入れていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "百科事典を数冊重ねたほどの箱形のアルテアの上に載せられたトランジスターラジオが、その瞬間、うなるような歪んだ音を立てはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
