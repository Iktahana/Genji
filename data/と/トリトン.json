        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海王星の衛星トリトンは、惑星の自転とは逆方向に公転するという非常に珍しい特徴がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "NASAの探査機ボイジャー2号が、トリトンの表面に噴火の跡があることを発見した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天体望遠鏡で夜空を観測したが、海王星の衛星であるトリトンまでは肉眼では見えなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
