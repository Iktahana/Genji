        "examples": {
          "standard": [
            {
              "text": "引退間近の特急列車を撮影しようと、線路脇には全国から撮り鉄が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は熱心な撮り鉄で、週末になるとカメラを担いで始発列車で遠出をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マナーを守って撮影を楽しむ撮り鉄が多い中で、一部の心ない行動が問題視されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "埴とりてつくれる型。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらばこの笛のつくりあしきは證されたり――　こはこれつくりあしき笛一竿、されどこの日おのれそをとりてつつしみひざまづきて、いまはなき　萩原朔太郎先生の尊靈のみまへにささげまつらんとす。",
              "citation": {
                "source": "朝菜集",
                "author": "三好達治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
