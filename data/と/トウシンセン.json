        "examples": {
          "standard": [
            {
              "text": "海底地形図には、等深線が細かく描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "等深線の間隔が広い場所は、海底の傾斜が緩やかであることを示す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この海の等深線を見ると、深い海溝が走っているのがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もしそうだとすれば鳥の群れの写真から湖底の等深線の一つがわかるはずである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海底の深さをあらわす等深線。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
