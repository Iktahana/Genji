        "examples": {
          "standard": [
            {
              "text": "昔の怪獣映画では、ピアノ線やミニチュアセットを駆使したトリック撮影が主流だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "CG技術が普及する前は、カメラのレンズに半分フィルターをかけるようなアナログなトリック撮影が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "SF映画のメイキング映像を見ると、宇宙空間のシーンがいかに緻密なトリック撮影で作られたかがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "このように映像が二次元的であることから生じるいろいろな可能性のうちにはいわゆるトリック撮影のいろいろな技巧がある。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の場合は、ふわふわと宙に浮いていて、いかにもきらくそうに見えたが、あれはもちろんトリック撮影である。",
              "citation": {
                "source": "高度八十マイル",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
