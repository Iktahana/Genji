        "examples": {
          "standard": [
            {
              "text": "彼は膨大な量の事務作業を一人で手際よく取り捌き、周囲の同僚たちを驚かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑な利害関係が絡み合った相続問題を、ベテランの弁護士が中立的な立場で公正に取り捌いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この混乱した状況をどう取り捌くかが、リーダーとしての君の腕の見せ所だ」と励まされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本経済復興をだしに武器製造から繊維の儲けに移った業者と腹を合わせた社会党の政府が、この課題を人民の目の前でどうとりさばくか。",
              "citation": {
                "source": "その檻をひらけ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女が品物を送って行って、よし途中で間違いがあっても、何んとかうまくとりさばくであろう。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
