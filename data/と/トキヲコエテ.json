        "examples": {
          "standard": [
            {
              "text": "この古い手紙は時を越えて、私たちの家族の歴史を語りかけてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "音楽は時を越えて人々の心に響く力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その伝説は時を越えて語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夜十時を越えて起きていることもまれで、朝食は欠かさないし、私が起床する前に出かけていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンマルトルの中心と云はれる大通は十二時を越えて不夜城の明るさを増すと云ふ巴里唯一の遊楽街だが、此酒場のあるのは大通から四｜町程｜入込んだ高地で、昼間さへ余り人通が無いのだから、未だ宵の口だのに最う深夜の感がする程｜灯火も人気も少い。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日一日と修復作業は進み、長い忘却の時を越えて線と影が次第に姿を現してくるのを、チャールズ・ウォードは傍らから募り行く興味とともに眺めた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
