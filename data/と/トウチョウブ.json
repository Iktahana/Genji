        "examples": {
          "standard": [
            {
              "text": "帽子をかぶっていたので、頭頂部は日焼けしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の髪の毛は、頭頂部が少し薄くなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鳥は、頭頂部に鮮やかな色の羽を持つ種類が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自ら架空の計劃をたてて愚友を欺すといふほどの奸智はなかつた、頭頂部が台のやうに平らで、頤にかけて三角的につぼんでゐる栗のやうな顔がそれを証明してゐた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭蓋骨は特異な状態だった――黄染し、頭頂部には焦げた穴が開いていて、あたかも何か強力な酸が硬い骨を溶かして食い込んだようだった。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガウクの死んだような目に見つめられながら、彼はラゴーフの頭頂部の髪の毛を、四平方センチメートルの広さに剃った。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
