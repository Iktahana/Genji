    "definitions": [
      {
        "index": 1,
        "gloss": "to set aside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "気に入った靴のサイズがなかったので、他店から取り寄せてもらって取り置く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "給料日になったら買いに来るので、このバッグを数日間だけ取り置いてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特別なお客様のために、ヴィンテージのワインを一本だけ奥に取り置いてある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また買い手はその馬生子に適する旨と、その体のどの部分をも要求すべき権利ある者一人もなき由の保証を取り置くべし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀造がひとりおくれて駈けていたのは、実は逃げる意志を持っていなかったからだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの事務所の少女が、みなからひとりおくれて、松葉杖をついて歩いて来るのです。",
              "citation": {
                "source": "東京だより",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなの弁当の支度に手間どって、ミネはひとりおくれて出かけた。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶっそうだから」　曠野にさまよう子供と見て、その足軽は、さきへ青竹をつんでいった車やつれの人数からひとりおくれて、こまごまと、十｜字路の方角や里数をおしえてくれている。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to preserve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
