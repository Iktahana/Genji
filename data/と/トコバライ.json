    "definitions": [
      {
        "index": 1,
        "gloss": "recovery from an illness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大病を患っていた父の床払いのお祝いで、近親者が集まって食事をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "床払いしたばかりだからといって、無理な運動は禁物だと医者に釘を刺された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "快気祝いの品には、床払いしてすっきりしたという意味を込めて洗剤を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "九月になって、かれはもう床払いをするようになったので、早速新屋敷へたずねて行って見ると、見おぼえのある古屋敷はそこにあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "一つ目小僧",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の末、十一月下旬、高時の子、万寿麻呂の出生があって、その祝いはあったが、お床払いとは、ついに聞えず仕舞いであった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　伊兵衛は九月の下旬にとこばらいをした。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊兵衛がとこばらいをしてから、おたみのようすがどことなく変ってきた。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の云ったとおり正篤の病気は順調によくなり、五月中旬にはとこばらいをした。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
