        "examples": {
          "standard": [
            {
              "text": "朝市で買った取れたての野菜は、新鮮で瑞々しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁港の食堂では、取れたての魚を使った海鮮丼が名物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このジャムは、自家農園で取れたてのイチゴで作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "＊あゆの産地ではめいめいお国自慢をしているが、結局はだいたいとれたての新鮮なのをすぐ食べること。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかめに　りすたちが　みついだのは、　とれたての　はちみつだんご。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とれたてで眼など生きてるようだ。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
