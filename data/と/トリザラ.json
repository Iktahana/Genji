        "examples": {
          "standard": [
            {
              "text": "大皿料理が運ばれてくると、幹事が手際よく全員分の取り皿を配り、料理を分けて回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すみません、取り皿をもう一枚いただけますか？」と店員に頼んで、汚れたお皿を新しいものに替えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居酒屋では、テーブルの端に清潔な取り皿が何枚も重ねて置かれているのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "世津子さんは、お取り皿とフオーク、お盆のまま運んでちやうだい」　といふあんばいに、滞りなく持つていつた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティーカップには　白に　ピンクのバラが　あしらってあり、　とりざらは　白地に　青。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルを　ととのえた　リービは、　水さしと　とりざらを　手に、　野原を　くだって　まきばへ、　ミルクと　バターを　とってくるのです。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            }
          ]
        }
