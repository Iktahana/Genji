        "examples": {
          "standard": [
            {
              "text": "芝居小屋の前は、看板を見上げようとする見物客で堵の如しであった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大通りに面した場所で事故が起き、集まった野次馬は堵の如き有様だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祝賀のパレードを一目見ようと、沿道には堵の如く人が溢れかえった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ほとんど大人と小児とのごとし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "人身の受くるところ、二気と魂魄とは、なお陰陽と鬼神とのごとし。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の呼と吸とのごとし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "雁中に一雁ありて所為衆これに随ふ、大将と士卒とのごとし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "火浣墨を以て火浣紙に物をかき、烈火にやけて火となりしをしづかにとりいだし、火気さむれば紙も字ももとのごとし。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
