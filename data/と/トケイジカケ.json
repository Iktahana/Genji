        "examples": {
          "standard": [
            {
              "text": "その精巧な時計じかけのオルゴールは、ネジを巻くと優雅なメロディを奏で始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の人生は、まるで時計じかけのように規則正しく、寸分の狂いもなく進んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔のおもちゃは電池ではなく、時計じかけの歯車で動くものが多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ちょうど時計じかけで拍子を合わせた二つの器械のように見える。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし無いというのなら、私の発明になる時計じかけの毒瓦斯を会社の中に仕掛けてゆきます。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
