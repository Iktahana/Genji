    "definitions": [
      {
        "index": 1,
        "gloss": "to let fly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "広い公園で、子供たちが一生懸命に紙飛行機を飛ばして遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弓を引き絞り、鋭い矢を的のど真ん中に向かって飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風船を空へ飛ばすと、色とりどりのゴムが青空に溶け込んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "天井からは糸ゴムで飛ばす飛行機が六機もブラ下つてをり、机の上には「綴り方教材集」なぞといふ本が置いてある。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「突く」というのは投槍のように網を突き飛ばす操作をそう云ったものではないかと思う。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、北風が強くて、雪を南に吹き飛ばすからである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人の酔ッ払いがどんな与太を飛ばすだろうかと思うと今から旅が楽しみです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と肩にかついで投げ飛ばす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみならず暇さえあればあと足を上げては何かを振り飛ばすような動作をする。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひところはやった玄米パン売りの、メガフォーンを通して妙にぼやけた、聞くだけで咽喉の詰まるような、食欲を吹き飛ばすようなあのバナールな呼び声も、これは幸いにさっぱり聞かなくなってしまった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日のよくあたる風の吹く、ほどよい湿度と温度が幸いする日、杉林が一斉に飛ばす花粉の煙であった。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、かみつく、引っかく、振り飛ばすというのである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物の果実のことだけを詳しく取り扱ったいわゆるカルポロジーの本を読んだときに、乾燥すると子房がはじけて種子をはじき飛ばすものの特例の一つとして Impatiens noli-tangere というものが引き合いに出ていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また学校では、受持の沢田先生が、綴方のお時間にあの雑誌を教室に持って来て、私の「春日町」の全文を、黒板に書き写し、ひどく興奮なされて、一時間、叱り飛ばすような声で私を、ほめて下さいました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅうひゅうひゅう、ひゅひゅう、降らすんだよ、飛ばすんだよ、なにをぐずぐずしているの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砕いちまへ、砕いちまへ、はね飛ばすんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砕いちまえ、砕いちまえ、はね飛ばすんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小紋まがいの裾を引擦った突かけ草履の脛も露わに、和尚と良助を突飛ばすようにして死骸の傍に走り寄ると……ワッ……とばかりに取縋って泣出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "内弟子の末輩とムキになって喧嘩したり、芸の上の議論でズブの素人と口角泡を飛ばす位の事は日常茶飯である。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と自分は少女を突飛ばすと、少女は仰向けに倒れかかったので、自分は思わずアッと叫けんでこれを支えようとした時、覚れば夢であって、自分は昼飯後教員室の椅子に凭れたまま転寝をしていたのであった。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、其の筈で、いけずな奴が、燒團子のばた／＼で、七輪の尉を飛ばすこと、名所とはいひがたく雪の如しであつたから。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝血迷ったかといって、役僧め、媼を取って突飛ばすと、人の天窓の上へ尻餅を搗いた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車に乗って二里の道程を飛ばすこととした。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れじゃとても青年角力の大関を投げ飛ばすことは難かしい」　註に曰く、大村とは天狗倶楽郎の大関、工学士大村｜市造（横田注・一蔵）君で、未醒子、番付は天狗倶楽部の三段目なり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物は一頭の馬を雇ってこれにのせ、四人は身軽になって鉄脚を飛ばす。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "つゞいて飛込まんとする獅子を目掛けて、私は一發ドガン、水兵は手鎗て突飛ばす、日出雄少年は素早く身を跳らして、入口の扉をピシヤン。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがガスがいよいよ最後の岩の皮をはね飛ばすまでには、そんな塊を百も二百も、じぶんのからだの中にとらなければならない。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆうひゆうひゆう、ひゆひゆう、降らすんだよ、飛ばすんだよ、なにをぐづぐづしてゐるの。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狂女め、と振払う、むしゃぶりつくを突飛ばす。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車に相乘して、堂々と、淺草、上野、銀座を飛ばす、當今の貴婦人紳士と雖も、これを見たら一驚を吃するであらう。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古典な能の狂言も、社会に、尖端の簇を飛ばすらしい。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのがつしりした鉄のやうな腕は、すべての不健全なもの、非人倫的なもの、神秘的なもの、病感的なもの（もちろんその中には私の詩にみるやうな哲学も含んで居る）及び人生の幸福に有害なる一切の感情を弾きとばすことに熱して居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来た刀屋の主人徳兵衛が子供を叱りとばす。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to skip over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "難しい専門用語が続く章は一旦飛ばして、先に結論を読み進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前置きが長いので、ビデオの再生速度を上げて余計な部分を飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "司会者は時間の都合上、予定していた質疑応答のコーナーを飛ばすと宣言した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to run fast",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "待ち合わせに遅れそうだったので、タクシーの運転手に飛ばしてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "真夜中の高速道路を、スポーツカーがエンジン音を響かせて飛ばしていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自転車で坂道を一気に飛ばし、風を切る感覚を楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "to spray",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "勢いよくくしゃみをした拍子に、コーヒーのしぶきを机に飛ばしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥道を走るトラックが、歩行者の服に泥水を飛ばして走り去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "噴水の周りでは、子供たちが水しぶきを飛ばし合いながらはしゃいでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 5,
        "gloss": "to say without reservation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "酔った勢いで、上司に対して辛辣な毒舌を飛ばしてしまったことを後悔している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は会議の冒頭から鋭い皮肉を飛ばし、周囲を緊張させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "客席からは、お気に入りの選手に向けて威勢のいい野次が飛ばされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 6,
        "gloss": "to spread (e.g. a rumour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "根も葉もない噂を飛ばして、ライバル企業の評判を落とそうとする手口だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "誰がそんなデマを飛ばしたのか、社内は疑心暗鬼に陥っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はSNSを利用して、巧妙に偽情報を飛ばすのが得意な男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 7,
        "gloss": "to transfer (to a less important post)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不祥事の責任を取らされる形で、彼は地方の閑職へと飛ばされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本社のエリートコースから外れ、子会社へ飛ばされることが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "派閥争いに敗れた彼は、辺境の営業所へと飛ばされてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 8,
        "gloss": "to dispatch quickly (e.g. a reporter)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "特ダネの情報を掴んだ編集長は、すぐに現場へ記者を飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "火災現場の惨状を確認するため、テレビ局はヘリを飛ばして空撮を試みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "急患の連絡を受け、病院はドクターカーを現場へ飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 9,
        "gloss": "to get rid of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "洗浄液の刺激臭を飛ばすために、窓を全開にして換気を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "料理に深みを出すため、ワインのアルコール分を強火で飛ばす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "濡れた書類をドライヤーの温風で乾かし、湿気を飛ばした。",
              "citation": {
