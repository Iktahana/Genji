    "definitions": [
      {
        "index": 1,
        "gloss": "training pants (for toddlers to transition from diapers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "息子が2歳になったので、おむつを卒業するためにトレーニングパンツを買い揃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、かっこいいトレーニングパンツを履こうか」と誘うと、子供は喜んで着替えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外出先で漏らさないか心配だったので、吸水性の高い6層構造のトレーニングパンツを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "白いトレーニングパンツをはいておしまい頃には靴下はだしになって広い地面を踏みしめながら楽しんだ。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
