        "examples": {
          "standard": [
            {
              "text": "巨大なプレス機が、廃車となった自動車を無残に取り拉いでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は怒りに任せて、空き缶を片手で軽々と取り拉いでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事故の衝撃で、車のボンネットが原型を留めないほどに取り拉がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さればその日の糧を猟らうにも、鹿熊なんどのたぐひをとりひしぐは、指の先の一ひねりぢや。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時もし私に彼らをとりひしぐだけの力があつたならば彼らを数珠つなぎにして雀の餌にしたであらう。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
