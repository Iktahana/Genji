        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの宿屋で、泊り賃を先払いして部屋に入った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅の予算を抑えるために、なるべく泊り賃の安い宿を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泊り賃には朝食代も含まれているので、かなりお得だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それで御泊り賃はたった百文、いかがでござります。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴石が帳場へ行つて、泊り賃を払つてきてくれた様子で、案外こざつぱりした夜具が三枚運ばれてきた。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "袋田の泊り賃も其時は二十銭であったが、今頃はさぞ変っていることであろう。",
              "citation": {
                "source": "四十年前の袋田の瀑",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし有っても一夜の泊り賃がごく安いので六十ルピー、高いのは百五十ルピーもするという。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊り賃が安いので、武蔵と伊織はそこへ泊った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
