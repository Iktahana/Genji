          "standard": [
            {
              "text": "トンキン湾事件は、アメリカがベトナム戦争に本格的に介入する契機となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高校の歴史の授業で、トンキン湾事件の背景と影響について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "トンキン湾事件を巡る情報操作が、後に大きな問題となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一九六四年といえば、偉大なる社会やトンキン湾事件をぼくでも思い出すが、そんなこととはまったく関係がないような、まるで反対の方向へ底抜けに徹底したようなコマーシャルだった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの軍部は独占資本のいいなりだから、朝鮮動乱のきっかけやトンキン湾事件のような、戦争のでっちあげですら、自由にできるのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
