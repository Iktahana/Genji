        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "警察は家宅捜索のため、頑丈な戸を破って内部に突入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暴漢は斧を振り上げ、力任せに玄関の戸を破ろうとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は怒り任せに壁を殴り、やがて目の前の戸を破る勢いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "猩々は人々が外から部屋の戸を破る時窓へ逃げて来て、外へ飛び出して跡の戸を撥ね返したものと見える。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戸を破るより仕方がない」そこで彼は全力を集め、裏戸へ体をぶっつけた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒が兇器で板戸を破る、その音の表現に、ベリバリ、ボリ。",
              "citation": {
                "source": "初代桂春団治研究",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も戸を破る烈しい音が、二人の耳へ聞こえてきた。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある指物師らは、「戸を破るため」に仕事台の鉤金を持ち出した。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に何者が潜んでいるにせよ、憲兵さんに立会って貰って、戸を破る外はありませんね」　南博士がうなずくと、新一はそのままどこかへ立去ったが、間もなく一人の憲兵を伴い、金挺を持って帰って来た。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官はその戸を押し試みて、ちょっと考えていたが、なにか自信ありげな口調になって、「この板戸を破るのはわけないですが、裏口もしまっていたら、手間がかかって仕方がない。",
              "citation": {
                "source": "月と手袋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
