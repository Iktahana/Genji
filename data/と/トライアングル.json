        "examples": {
          "standard": [
            {
              "text": "合奏の最後に一度だけ鳴らされるトライアングルの澄んだ音色が、ホールに美しく響いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "音楽の時間にトライアングルを担当することになり、リズムに合わせて叩く練習に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は優しくトライアングルを叩き、静かなメロディーに繊細なアクセントを添えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夜、鈴木澄子氏来、トライアングル love についての苦しさの話。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジングルベルを、タンバリンやカスタネットや大鼓やトライアングルで合奏した。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
