    "definitions": [
      {
        "index": 1,
        "gloss": "one's own bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忙しい一日の終わりに、お気に入りの入浴剤を入れた留め湯に浸かるのが至福の時だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日はお湯が熱いから、留め湯に入る時は気をつけてね」と妻に言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "旅行先でも、大浴場より部屋にある留め湯のほうが落ち着いて入れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ほかに「留め湯」とか「月留め」とかいう制度があって、毎日かならず入浴する人に対しては割引をする。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のあなたに空遠くさいわい住むと人のいうああわれひとりとめゆきて涙さしぐみ帰りきぬ山のあなたになお遠くさいわい住むと人の言うこの歌を歌いましたわ。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、かつて一般に行うたらしい痕跡は、妻覓ぎに該当する「とじ・かめゆん」（妻捜す）「とじ・とめゆん」（妻｜覓る）などいう語で、結婚する意を示すことである。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になつて壻が大勢の友人と嫁を捜すのをとじとめゆん即｜嫁さがしと称する。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其にも拘らず、曾て一般に行うたらしい痕跡は、妻覓ぎに該当する「とじ・かめゆん」（妻捜す）「とじ・とめゆん」（妻覓る）など言ふ語で、結婚する意を示す事である。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこをかもとめゆく、この時、船の帆よ、徐に、彼方へ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸か船、帆じるしは判たね、いづこをかもとめゆく、この時。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "(reusing) yesterday's bath water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "節約のために、昨日の留め湯を洗濯機に移して再利用することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もったいないから、その留め湯は庭の水やりに使って」と母が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "留め湯がまだ温かかったので、そのまま追い炊きして入ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "monthly pass for a public bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "銭湯の番台で、来月分の留め湯を購入して、いつもの札を受け取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「留め湯を持っているから、毎日通わないと損なんだよね」と笑いながら話した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔は、多くの常連客が留め湯を利用して、銭湯を社交場にしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
