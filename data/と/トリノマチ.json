        "examples": {
          "standard": [
            {
              "text": "「酉の待の宵宮には、境内にたくさんの出店が並んで活気に溢れる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「昔懐かしい酉の待の風景を求めて、遠方から多くの観光客が訪れる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「太鼓の音が聞こえてくると、いよいよ酉の待が始まったという実感が湧く。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人々も酉の市をとりのいち、歳のいち（市）と混じて怪しむものなく、遂に「とりのまち」引いては「二のまち」などのこの土地の言葉は衰亡せしものと考へる。",
              "citation": {
                "source": "東京の風俗　序",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十年代にはその全盛に及んで、そのころ年々のとりのまちに店員全部が隊を組んで大鷲神社へ練り込んだことは、ぼくもその行列に連なつておぼえがある。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            }
          ]
        }
