        "examples": {
          "standard": [
            {
              "text": "ユダヤ教徒にとって、トーラーは神聖な教えが記された経典である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "シナゴーグでは、トーラーを読み上げる儀式が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、幼い頃からトーラーの教えを学んで育った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「言い伝え」（ハラカー Halachah）というのは、モーセの律法（トーラー Torah）の解釈や細則をば古来の教法師たちが決定して言い伝えてきたものです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "トーラーが成文法典であるに対し、ハラカーは不文律でいわば判例集のごときものでありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてハラカーはトーラー同様に、否トーラー以上にさえ重要なものとなされたのです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
