        "examples": {
          "standard": [
            {
              "text": "最新の金庫は、優れた盗難防止機能が備わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、自転車に複数の盗難防止ロックを取り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このマンションは、防犯カメラやオートロックなど、盗難防止対策が徹底されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから二週間後、特許を取った改良型盗難防止用金庫が、ローガンズポートでただの包装みたいにあっさり開けられて、今度は現金一五〇〇ドルも盗まれた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベン・プライスがこの逃げ回る金庫破りの足跡を追っていると公表されると、盗難防止用金庫を持っている人々もほっとすることができた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            }
          ]
        }
