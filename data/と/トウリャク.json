[
  {
    "uuid": "c2d1a013-890f-5f5c-81cd-8b7e4e76c8f7",
    "entry": "韜略",
    "reading": {
      "primary": "とうりゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "strategy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "孫子の兵法は、古今東西の韜略の基本とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、敵の動きを読み解く韜略に長けていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の作戦は、彼の韜略が光るものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "論武有孫呉韜略之兵法。",
              "citation": {
                "source": "日本文化の獨立",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は深く韜略に通じ、兵を用うるに卓絶し、機を見ること敏なり。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
