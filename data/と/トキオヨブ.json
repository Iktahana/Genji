        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "話が本筋から離れて、彼は以前の失敗にまで説き及んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "講演の中で、彼は未来の技術の可能性に説き及んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "議論が白熱する中で、個人的な感情にまで説き及ぶのは避けるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "丁度其れと同じやう、現代の年少詩人が日本にも随分古くからある天竺牡丹の花に殊更ダリヤといふ洋語を応用し、其の花の形容から失へる恋、得たる恋の哀楽を叙して、忽ち人生哲学の奥義に説き及ぶが如き、亦よく吾々の時代思潮を語るものでは無からうか。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもたまたま両者が同じき徳の問題に説き及ぶと、両者の説くところはその中核において常に一致するのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことについてはかつて「文化史上より見たる日本の数学」の篇中にも説き及ぶところがあった。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこゝではそんなに深く説き及ぶ迄もないのであるから、たゞ順序として、物語の進行に必要な面にだけ触れて置こう。",
              "citation": {
                "source": "少将滋幹の母",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
