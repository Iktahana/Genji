        "examples": {
          "standard": [
            {
              "text": "地下水の流れを追跡するため、無害な染料をトレーサーとして井戸に投入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夜空に放たれたトレーサー弾が、光の筋となって目標へと吸い込まれていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医療現場では、放射性同位元素をトレーサーに用いて体内の異常を調べる検査が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "測量の簡素化を狙って開発され、プロファイルトレーサーと名付けられたこの装置の外見は、手押し式の二輪車である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
