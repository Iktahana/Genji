        "examples": {
          "standard": [
            {
              "text": "バックパック一つで世界中を旅するトラベラーたちが、安宿のロビーで情報交換をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ビジネス向けの高級ホテルだが、週末は観光目的のトラベラーで賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元の市場を訪れると、珍しい食材に興味津々な外国人トラベラーの姿があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "紅と白の派手なだんだら縞を染め出した大檣帆の裾は長い檣柱の後側から飛び出したトラベラーを滑って、恰度カーテンを拡げたように展ぜられ、船首の三角帆と風流に対して同じ角度を保たせながらロープで止められたままになっている。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            }
          ]
        }
