        "examples": {
          "standard": [
            {
              "text": "映画館のイベントで、当選者に特待券がプレゼントされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この遊園地の特待券があれば、並ばずにアトラクションに乗れるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は会社の福利厚生で、提携ホテルの特待券をもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "切手は十念を受ける時、座敷に通す特待券である。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思いついたのが開業満五周年記念として、一割引の特待券を進呈することであった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
