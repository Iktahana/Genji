          "standard": [
            {
              "text": "創業社長の引退後、会社は実力のある3人の副社長によるトロイカ体制で経営の安定を図ることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政権運営を円滑に進めるため、幹事長、政調会長、総務会長によるトロイカ体制が確立された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロジェクトを強力に推進するには、リーダー一人に頼らず、三位一体のトロイカ体制が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "パソコン創世記の終章を飾るアップル＝ＩＢＭの提携とアスキーのトロイカ体制の崩壊　アップルとＩＢＭが提携すると言いだしたかと思うと、西和彦さんといっしょにアスキーを引っ張ってきた郡司明郎さんと塚本慶一郎さんが辞めてしまった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
