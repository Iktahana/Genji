        "examples": {
          "standard": [
            {
              "text": "土地の所有権を確認するため、彼は法務局で登記簿を閲覧した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "登記簿には、その建物の築年や所有者の情報が記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不動産取引においては、登記簿の内容を必ず確認することが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "内陣の西の隅のガラス箱に三百年前の教区登記簿が保存されてあり、係りの老人が大事そうにそれを開けて見せた。",
              "citation": {
                "source": "シェイクスピアの郷里",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は頭の中に、ちやうど登記簿のやうに、この界隅の總ての水夫等の名前をとゞめてゐるので、彼女はそれ等の人物の善惡から、稼ぎ高から、腕前まですつかり知り拔いてゐる。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
