        "examples": {
          "standard": [
            {
              "text": "甘辛いタレで煮込んだ鶏肉とごぼうがたっぷりのった鳥飯は、この地方の名物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "運動会の昼休み、母が作ってくれた鳥飯のおにぎりを頬張るのが何よりの楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "駅弁で人気の鳥飯を買って、車窓の景色を眺めながらのんびりと旅を楽しむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "第三十五　鳥飯　は鶏の肉を細かく切って椎茸や糸蒟蒻や外に時の野菜物を何でも皆んな小さく切って味淋と醤油でよく煮てそれを炊きたての御飯へ混ぜたものです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坂富貴の里の、とりめし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
