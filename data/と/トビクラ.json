        "examples": {
          "standard": [
            {
              "text": "子供たちが公園の砂場で、誰が一番遠くまで跳べるか飛び競をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "運動会の種目に飛び競があれば、僕は絶対に自信があるんだけどな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔は村祭りで、若者たちが力自慢として飛び競を披露したそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで、さっそく、世界じゅうの人々に招待状を出して、このすばらしいとびくらべを見たいと思う人は、だれでも、呼んであげることにしました。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、わしには、自分のやりかたもあるし、自分の考えもあるのじゃ」　いよいよ、とびくらべが、はじまりました。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
