        "examples": {
          "standard": [
            {
              "text": "ビルの当直員が、夜間の巡回を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "火災報知器が鳴った際、当直員がすぐに現場へ駆けつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、施設の安全管理を担当する当直員の一人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どうせ怪しい奴のいうことだ、ろくなことではあるまい」　出入口当直員は、耳をすまして、扉のむこう側の声を聞きとろうとした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "交替の当直員が来た。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店では毎晩、番頭、少年店員、警務さん、鳶のものなど、数十人の当直員を定めて、広い店内を隅から隅まで、徹宵見廻らせることになっていた。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
