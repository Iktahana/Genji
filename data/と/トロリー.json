        "examples": {
          "standard": [
            {
              "text": "空港では、荷物を運ぶためのトロリーがあちこちに用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スーパーマーケットでは、買い物かごを載せるトロリーが便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場内では、部品を運搬するために電動トロリーが使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たくさんの人夫小屋、トロリー軌道、ちょっとした畑、物干しの赤い色彩、犬のほえる声などはたくましい伐木の進捗を明示する行進曲で、秘渓の中に生活の侵略を看取することが出来る。",
              "citation": {
                "source": "二つの松川",
                "author": "細井吉造",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロリー道は山腹をほとんど勾配もなく進んでいる。",
              "citation": {
                "source": "二つの松川",
                "author": "細井吉造",
                "note": "青空文庫"
              }
            },
            {
              "text": "区役所の南側をとおってトロリー・バスの走る道路へと抜けていく道だ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてのトロリー・バスはもう走ってはいなかった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
