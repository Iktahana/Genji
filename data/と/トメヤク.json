        "examples": {
          "standard": [
            {
              "text": "意見の対立が激しい会議の中で、彼は冷静な留め役として場をコントロールした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君が留め役をやってくれないと、このプロジェクトは空中分解してしまうよ」と頼まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "留め役という立場は、双方の面目を保ちながら妥協点を探る難しい役割だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わしは生首を調達しようとするような若しそういう不心得ものも此のあたりにあらば、そちに留めて呉れいと、留め役を言い付けに来たのだ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "留め役でござりますると』おさき『開山聖人さま御正忌会のお※夜も近々。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたはずみからか、と言って見ることもできなかったが、留め役にはいったお民のさしている細い銀のかんざしが飛んで、彼女が左の眉の下を傷つけたのもその際である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「その御難場へ飛び出して、留め役を買って出たのは、沢屋の一人娘、日本橋小町と言われた、お琴だとしたらどんなもので」　八五郎は話題が綺麗な娘になると、急に元気づいて威勢が良くなります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋の上の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "留め役の俺は、これじゃてんでクダマ（阿呆）みたいだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
