        "examples": {
          "standard": [
            {
              "text": "かつて地中海貿易の拠点として栄えたトリポリの旧市街には、歴史的な建物が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出張でリビアの首都トリポリを訪れ、現地の文化や習慣に直接触れる機会を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トリポリの市場は活気に溢れ、スパイスの香りと人々の話し声が絶え間なく響いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "従ってエジプトやコンスタンチノウプルの如きでは毎年来襲し、トリポリやアレッポの附近の如きでは、四、五年に一度来襲し、英蘭の如きでは十、十二、または十三年に一度来襲するかしないかである、ノルウェイ及び北方諸島の如きでは二十年以内には来襲しない。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして教祖の死後十年には既に西アジア全体とエジプトとをトリポリタニアまで征服した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようにして我がレーモン・ド・トリポリ伯も、その城内において殺されたのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
