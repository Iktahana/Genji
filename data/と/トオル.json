    "definitions": [
      {
        "index": 1,
        "gloss": "to go by",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日、たくさんの車がこの道を通り過ぎる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも同じ時間帯に店の前を通る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風が窓から心地よく通り抜ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "俺は風のよく通る廊下で、随分淋しい思ひをしたもんだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も通るものはなかつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その廊下を歩く限りの人が、その条の右か左かを通るんだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この道をも私は通る」以下の詩、及び淫売婦に贈つた数篇の詩篇をよむものは、どんなに長い間、彼が霊的に苦しんで居たか、そして今の彼がどんなに健全で高潔な愛の信仰の上に立つて居るかを知るであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが新しき季節は來り、氷は解けそめ、再び人々はその麓を通るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はよくここにこうして坐りこみながら眼のまえをぞろぞろと歩いて通る人の流れを眺めているのだが、はじめのうちは堪忍できなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしおなかが空いたの――」　兄が傍を通る時に、畳の座板がひわるのが、良子の重ね合せて坐つてゐる足に感じられた、彼女は悲しい気持になつてゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母が死んだ子を褒めて耕二を悪く母に言つてゐたのであらう、そして父が母を呼んだのはその話の終り切らない時だつたのだらう、兄が自分の部屋にゆく途中、茶の間を通ると祖母にその話の余波をまはされたから。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食の直ぐ前頃だし田舎道を通るものなんて殆どなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙燭して廊下通るや五月雨　降り続く梅雨季節。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月光の下、ひとり深夜の裏町を通る人は、だれしも皆こうした詩情に浸るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後の壁には乾鮭がさがり、戸外には空也念仏の声が通る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の休みで、外には誰も通る人がない。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の左上から右辺の中ほどまで二条の並行曲線が引いてあるのが上野の麓を通る鉄道線路を示している。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時再び家を動かして過ぎ去る風の行えをガラス越しに見送った時、何処とも知れず吹入った冷たい空気が膝頭から胸に浸み通るを覚えた。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ敷いてから間もないと思はれる銀べりの青畳がその光に反射して、しき通るやうな、スガ／＼しい色合を見せて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "膚の細い、黄い石や、黒い石の上を辷ると、思いなしか、沈んだ、冴えた声をして、ついと通る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "潭石の下には、大さ針の如くなる魚が、全身、透き通るように、青く染って、ぴったりと、水底に沈んでいる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍ヶ岳以北は、見えなかったが、木曾駒ヶ岳は、雪の荒縞を着ながらも、その膚の碧は、透き通るように柔らかだ、恵那山もその脈の南に当って、雄大に聳えている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の通る足下では木曾川の水が白く泡を噛んで、吠えていた。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体の動揺の刹那まで、私の足の踝にジャックナイフの突き通るまでは、私にも早朝の爽快さと、溌溂さとがあった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆が除けて通るのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと颱風と名のつく程度のものまでも入れれば中部日本を通るものだけでも年に一つや二つくらいはいつでも数えられるであろう。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀に沿うて牛が淵まで行って道端で憩うていると前を避難者が引切りなしに通る。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に色んな人が通る。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気の代りに他の瓦斯を入れることもあるが、要するに稀薄な瓦斯中を電気が通る際に、その瓦斯が光を放つというだけのことである。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた直通電流を用いるのと、交番電流を用いるのと、それぞれ区別があるが、要するに炭の棒の隙間を電気が通る時に炭の蒸気が出てこれが光る。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると水銀が蒸発して管の中はこの蒸気が充ちその中を電流が通じるようになるから管を旧位置になおし水銀を一端に返しても電流は続いて通る、この時に水銀の蒸気は強い蒼い光を出す。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人がじろじろ見て通るからしかたなしに歩き出す。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の道を通る人もないので、私は安心してその柱によりかゝつた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
