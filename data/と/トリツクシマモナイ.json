        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "真剣に謝罪の言葉を述べたが、彼女は目を合わそうともせず、取り付く島もなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの厳しい部長に企画の相談をしても、一言で却下されて取り付く島もない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "こちらが何を言っても無視されるのでは、話し合いをしようにも取り付く島もないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつもお神さんがでてきては取り付く島もないくらい、留守だとか病気だとか呆気なく玄関で断られてしまった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしとは何の関係もないように、まるで無意味で、とりつくしまもないような気がする。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにして橋をわたつてゆくこともたびたびであつたけれどこの枯木のやうな隠者にはとりつくしまもない。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
