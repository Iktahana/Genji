    "definitions": [
      {
        "index": 1,
        "gloss": "to able to enter the New Year (i.e. have work finished, debts paid, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "滞納していた税金をすべて完納し、これでようやく肩の荷が下りて安心して年が越せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この大きなプロジェクトが年内に終わらないと、とてもじゃないが年が越せないよ」と溢す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家族揃って美味しいおせちを食べながら、一年を振り返って笑顔で年が越せる幸せを噛みしめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "晴代は年が越せるか何うかもわからないやうな不安と慌忙しさの中に、春を迎へる用意をしてゐた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は襤褸のままだし、松も〆飾りも出来ないで、よく年が越せると云えたもんだね。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけあれば大きな顔して年が越せる」と喜ぶのを、「三十両ばかりじゃ、ねえやい」と叱る。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
