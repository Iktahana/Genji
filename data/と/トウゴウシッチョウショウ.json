        "examples": {
          "standard": [
            {
              "text": "統合失調症は、思考や感情の障害を特徴とする精神疾患である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "統合失調症の治療には、薬物療法と精神療法が用いられることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早期発見と適切な治療が、統合失調症の予後を改善する鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "緊張病（緊張型の統合失調症）という精神病の患者は世界から完全に超然として長いあいだ静止して暮らして行ける。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "先天的な低知能、統合失調症、躁鬱病、てんかん、ハンチントン病、先天的な聴覚や視覚の障害、いろいろな遺伝性身体異常、に悩む人たちに法律が適用された。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「精神分裂病」は現在では「統合失調症」と呼ばれています。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
