        "examples": {
          "standard": [
            {
              "text": "お皿に盛られた大量の唐揚げを、育ち盛りの子供たちが一人残らず取り切ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "床にこぼした油汚れを、強力な洗剤を使って跡形もなくきれいに取り切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "麻雀の対局で、相手の持ち点をすべて取り切って逆転トップに躍り出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "須田の子供達にもなつき、ミシンの稽古をさせて貰っていた房は、一時の休養のために、まるきり暇をとりきるのは不本意であった。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
