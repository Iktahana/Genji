        "examples": {
          "standard": [
            {
              "text": "今夜は奮発して、特上寿司を注文しよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この旅館では、特上ランクの部屋には露天風呂が付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "特上霜降り肉は、口の中でとろけるような美味しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十二月卅日　晴れたり曇つたり、徒歩七里、長尾駅前の後藤屋に泊る、木賃二十五銭、しづかで、しんせつで、うれしかつた、躊躇なく特上の印をつける。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナイチンゲール氏に特上フールスキャップ五十連。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、売場の酒は、特上、上、中、下と、四階段にもわけてあるのに、もとになる酒はほんの一種で、ただ水の割りかたをちがえてあるばかりだったし、それに、そのもとになる酒というのが、必ずしも一定した酒ではなく、始終銘が変っている、ということを発見したからである。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
