        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博多のとんこつは、濃厚でありながらすっきりとした後味が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店のとんこつは、何時間も煮込まれていて、コラーゲンがたっぷり含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒い冬の夜には、熱々のとんこつが体に染み渡るように美味しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
