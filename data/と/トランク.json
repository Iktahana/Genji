        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "キャンプ道具を車のトランクにぎっしりと詰め込み、早朝から山へ向けて出発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スーパーで買った大量の食料品をトランクに積み、ハッチバックをバタンと閉めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トランクの中にスペアタイヤが入っているかどうか、遠出の前に確認しておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
