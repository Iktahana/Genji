        "examples": {
          "standard": [
            {
              "text": "老練な時計工がルーペを覗き込み、髪の毛よりも細い部品をピンセットで調整している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "父は街で唯一の時計工として、近所の人たちの壊れた時計を長年直し続けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新のクォーツ時計全盛の時代でも、熟練の時計工の手による修理は欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ブルッセルの家では出入りする友人の中にも革命的な時計工、靴工という種類の人々が登場した。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しく時計工場が出来て、そこへ機械とともにやって来た人たちであった。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計工、宮廷音楽教師、新貴族、武器輸出業、水道事業の発案者そして、そのうえに劇作家を兼ねたピエール・カロン事ボーマルシエがその代表的な一人であり、そのボーマルシエの空想に浮んだ一英雄、伯爵お抱えの理髪師フイガロがまた、その典型の一ヴアリエーシヨンに外ならぬ。",
              "citation": {
                "source": "秘伝の名訳",
                "author": "――ボーマルシエ、辰野隆訳『フィガロの結婚』",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは精工舎という時計工場の寮のあとですよ」「ハア。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はスイスの時計工の話をきいて感心したことがある。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えても見たまい、内の工場は、さきおとどし、やっとまあ、時計工場から飛行計器の製作に切りかえて、指定工場になったばかりだ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなお前、今どき、この――友吉　時計工で、あのう、――組立てやなんか――時計屋であります。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
