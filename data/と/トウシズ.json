        "examples": {
          "standard": [
            {
              "text": "設計図を理解するため、建物の透視図をじっくりと眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このゲームでは、壁の向こうにいる敵を透視図のように見ることができる特殊能力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "複雑な機械の構造を説明するために、詳細な透視図が用意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "圧しつけるような暗い建築の陰影、裸の並樹、疎らな街燈の透視図。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方の山などは二十万分一でことごとく名前がわかり、付近の地形は五万分一と車窓を流れる透視図と見比べてかなりに正確で詳細な心像が得られる。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠なる二本の平行線が、おそろしく単調な透視図を形づくっているだけだ。",
              "citation": {
                "source": "チェーホフ試論",
                "author": "――チェーホフ序説の一部として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "永遠なる二本の平行線が、おそろしく単調な透視図を形づくっているだけなのだ。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "透視図を描いてどこまでも直線に伸びている。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピエールさんが、やさしい口調でなだめて、とうとうしずめてしまった。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
