        "examples": {
          "standard": [
            {
              "text": "ロンドンまでの通し切符を予約した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この通し切符があれば、途中の駅で乗り換えなしで済む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行代理店で、航空券と電車の通し切符を手配してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夫人はブレーメンまでの、通し切符をお持ちでいらっしゃいます」　と、知らせてくれた。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレーメンへ行くと見せかけて通し切符を買っておいて、実際はハンメルスフェーヘンへ行くとならば、汽車は西独の国境駅フレンスブルグで乗り換えなければならぬ。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
