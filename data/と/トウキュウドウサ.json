        "examples": {
          "standard": [
            {
              "text": "ピッチャーの流れるような投球動作は、見る者を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は投球動作を改善するため、毎日シャドーピッチングを繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "監督は、投球動作に無駄な動きがないか、ビデオでチェックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ゴルフの打法では足のカカトに重点を置いて身体の回転を起すことにきびしい注意をうけるが、野球における投手の投球動作でも、そのフィニッシュにおける足の爪先の方向や踏ん張りに主点をおき、そこを中心に身体の回転を起すことをきびしく注意したら、一段とスピードが加わるのじゃないかと思う。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
