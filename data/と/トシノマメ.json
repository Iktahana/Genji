        "examples": {
          "standard": [
            {
              "text": "節分の夜、「福は内、鬼は外」と叫びながら、自分の数だけ年の豆を食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃は年の豆をたくさん食べられる大人が、なんだか羨ましくて仕方なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、これが年の豆だよ」と、祖父が升に入った大豆を差し出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "中年の豆腐屋と青年等の間も面白く行つた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか馬鹿らしく滑稽で私はお湯の中で笑い出したけれど、今年の豆撒きにはイギリスとかアメリカの領事館か何かの人が裃を着て豆をまきに護国寺へ出かけたのだそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
