        "examples": {
          "standard": [
            {
              "text": "古いラジオの電源を入れるとき、カチッという感触のトグルスイッチを倒すのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛行機のコックピットには、無数のトグルスイッチが整然と並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自作の電子工作キットに、レトロな雰囲気のトグルスイッチを取り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "パネルに安っぽいトグルスイッチとランプを並べたデザインは、アルテアのルーツを思わせるそっけない作りだったが、ノバは当時としてはきわめて速かった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "報告を寄せてきた読者たちは、二Ｋバイトのプログラムをアルテアのトグルスイッチを上下させてご苦労にも入力し、いざ拡張版タイニーベーシックを動かしてみてバグを見つけ、そこからプログラムの構造を自力で解析しなおすことができたからこそ、最後のバグの修正にまでたどり着くことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガウスゴフェルはトグルスイッチを下げた。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
