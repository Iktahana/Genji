        "examples": {
          "standard": [
            {
              "text": "ベルトの留め金具が壊れてしまったので、新しいものに交換する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このバッグは留め金具のデザインが凝っていて、とても上品に見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腕時計の留め金具をカチッと鳴らしてはめると、身が引き締まる思いがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "留め金具が銀なものだから、端の所にあるミントの印がフランス共和国の法律で制定された印のように見える。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてと、どうしてこのガーターは薔薇色の絹で飾り編みしてあるんだろう――どうしてこの銀の留め金具のある絹のガーターがお前の痩せ衰えた喉のところにあるんだろう。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
