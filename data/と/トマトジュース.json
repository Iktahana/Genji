        "examples": {
          "standard": [
            {
              "text": "朝食代わりに、氷をたっぷり入れた冷たいトマトジュースを一杯飲む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飛行機に乗ると、なぜか無性にトマトジュースを注文したくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トマトジュースに少しタバスコを入れると、スパイシーで大人な味になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "トマトジュースを書き出しに、ジュースの数は、やたらに多い。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトジュース飲んでると、穂積純太郎来る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "トマトクリームスープ、こゝのは濃厚だが、まるでトマトジュースを温めたやうで、クリームスープの味はない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
