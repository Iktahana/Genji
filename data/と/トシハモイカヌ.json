        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "年端もいかぬ弟を守るために、彼は必死で泥棒を追い払った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、年端もいかぬ子が、こんなに難しい本を読んでいるなんて！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は年端もいかぬうちに両親を亡くし、親戚の家を転々として育ったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かわいそうに、年端もいかぬ少年の心を、腹いっぱいのぜんざいでとらえ、航空兵をこころざした貧しい家の少年もいた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それにしても、頬髯いかめしい、あから顔の四十いくつかの左近将監が、しきりに待ちきっていた碁のあいてというのは、こんな年端もいかぬ少年だったのでしょうか？",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうした子細で、としはもいかぬそなたたちが、こんなことをせねばならぬのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
