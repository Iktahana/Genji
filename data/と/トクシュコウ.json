        "examples": {
          "standard": [
            {
              "text": "最新の航空機には、軽量かつ高強度の特殊鋼が使用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この工具は、特殊鋼で作られているため、非常に硬く長持ちする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は特殊鋼の加工技術において、世界的に認められた職人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "死んで焼くと男と同じタダの白骨には相違ないが、女骨プラス慾念の場合には何かと何かを化合すると特殊鋼ができるような化学作用をあらわすらしいや。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩乗な特殊鋼の大容器に、廃棄物がいっぱい詰められたものが、そんな微弱な水流で流されるとは、到底考えられない。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
