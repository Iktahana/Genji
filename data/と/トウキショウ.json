        "examples": {
          "standard": [
            {
              "text": "彼の祖父は、代々続く陶器商を営んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その陶器商の店には、珍しいアンティークの皿が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は陶器商の娘と結婚し、家業を継ぐことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大きな陶器商の長男で、もうその主人だったが、未だに独身だという点に、何かの影があるらしかった。",
              "citation": {
                "source": "必要以上のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかかる簡単な礼儀を守ることによって、陶器商間に於る私の好機を、大いに高めた。",
              "citation": {
                "source": "日本その日その日",
