        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「私の豚犬が、またご迷惑をおかけして申し訳ありません。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父は照れながらも、「我が豚犬をこれからもよろしく頼む」と頭を下げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の息子を「豚犬ですが、私にとっては最高の宝物です」と紹介した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
