        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「俺はなんて豚犬なのだろう…」と彼は自分の不甲斐なさを嘆いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな豚犬のような振る舞いは、人として許されないと彼は叱責された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の学のなさを「豚犬の知識」と自嘲気味に語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかも此危険に際して、猶諸国に命じて南都の両寺を修せしめしが如き、傘張法橋の豚犬児が、愚なる政策は、此声援をして更に幾倍の大を加へしめたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人はニヤニヤ笑って美代子さんを見ておりましたが又、「けんとんけんちゅう（支那の織物の名）入りまションか」　と云いました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は又ニヤリと笑ってあたりを見まわしましたが、そのまま巾着の口を閉じて懐中へしまって、反物を担いで今度は隣家の門口へ行って知らぬ顔で、「けんとんけんちゅう入りまションか」　と呼びました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
