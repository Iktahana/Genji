    "definitions": [
      {
        "index": 1,
        "gloss": "specially appointed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は特任の役職に就き、会社全体のDX推進という重大な任務を任されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今回のプロジェクトのために、外部から特任の専門家を招いてチームを編成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特任事項として扱われるため、この情報の取り扱いには細心の注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "管内の警察官は悉く不在だつたので彼はサムエル・ブルウムを特任し、且ジョン・カッタア、ヘンリイ・ブリット、ジョオヂ・グウルド、デニス・オーキイフ、ジョン・ウエッセル、ビイ・エフ・シヨットの諸氏を選任登録した。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
