    "definitions": [
      {
        "index": 1,
        "gloss": "special approval",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学区外の学校だったが、特別な事情が認められて特認校への入学が許可された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通常は認められないケースだが、今回は理事会の特認を得てプロジェクトが進行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特認制度を利用して、地元の小さな小学校にわざわざ遠くから通っている児童もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "公認教は特認教もしくは特待教の義にして、政府がその国の歴史上に縁故あり、その人民中に勢力ある宗教は、これを特別に待遇するをいう。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
