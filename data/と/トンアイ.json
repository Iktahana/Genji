          "standard": [
            {
              "text": "精神的な苦痛の多くは、物事への貪愛から生まれると説かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は富への貪愛が強く、そのためには手段を選ばなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "仏教では、煩悩の中でも特に貪愛を断ち切ることが重要だと教える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三三九　若し人に可意の物に於て漏泄する強き三十六駛流あれば、貪愛より發する分別の浪は其の惡見者を漂蕩す。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            }
          ]
