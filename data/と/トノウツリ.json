        "examples": {
          "standard": [
            {
              "text": "桜の盛りを過ぎた頃、大納言様の殿移りが行われることとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "殿移りの準備で屋敷中が慌ただしくなり、荷物を運ぶ牛車が絶えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "以前の住まいよりも格式高い場所への殿移りは、家臣たちにとっても名誉なことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それが、今突然、実にたやすい、むしろ当然なことのうつりゆきのようにして、朝子の前に示されたのであった。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二尺あまりの振袖からは、紅梅のような裏地の色がこぼれて、白と紅とのうつりも悪くなかったが、それにもまして半蔵の心を引いたのは衣裳全体の長さから受ける娘らしい感じであった。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
