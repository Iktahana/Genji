        "examples": {
          "standard": [
            {
              "text": "「システムの更新データを取り込み中ですので、電源を切らないでください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サーバーに大容量のログファイルを取り込み中につき、動作が重くなっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バックアップデータをクラウドへ取り込み中だが、通信速度が遅くて進まない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
