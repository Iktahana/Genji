        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の肌には、まるで陶器のような透明感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この絵画は、透明感のある色彩で幻想的な世界を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若々しい俳優の透明感あふれる演技が、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ルノアールの描法は一種の硝子的な透明感があるが、それは筆触のうるささで相殺される。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝでは彼の企てた『硝子のやうな透明感』また、東洋の七宝のやうな光りのけんらんたるアラベスクを現出してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大豪放の透明感というもの、清純高潔の生き方というものを最後まで持ちつづけたかれも、時々、その反対の生き方を強いられてくると、口ごもりながら、これは何とかしなければならんと何度もムカシ好んで着た紺絣で質素と朴訥の風采を愛しようともがくのだ。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "香りによって創りだされる世界のずっと遠くまで、透明感がゆきわたっているような香りだった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぶしいほどに赤い、灼熱をとおりこして透明感すらたたえた、溶岩の滝だった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
