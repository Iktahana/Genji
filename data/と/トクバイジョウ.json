        "examples": {
          "standard": [
            {
              "text": "デパートの催事場にある特売場で、掘り出し物の冬服を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特売場はいつも混雑しているので、朝一番に行くのがコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "期間限定の特売場が開設され、多くのブランド品が安く売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三越では、それからかず枝は、特売場で白足袋を一足買い、嘉七は上等の外国煙草を買って、外へ出た。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「デパートのカレライスはうまいんだなあ」　そこからエレベーターで下りて来ると、一階の特売場で彼のアンダーシャツを一円で買った。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
