        "examples": {
          "standard": [
            {
              "text": "彼の退職は唐突千万で、社内は一時騒然とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな唐突千万な発言は、周りの人を困惑させるだけだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ええっ、唐突千万だけど、結婚することになったんだ！」と彼女は満面の笑みで告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さよう、尊敬していなければ出来ない」「それじゃア……」　ト云懸けて黙していたが、思切ッて些し声を震わせて、「君とは暫らく交際していたが、モウ今夜ぎりで……絶交して貰いたい」「ナニ絶交して貰いたいと……何だ、唐突千万な。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と嘴を挿さんでみれば、さて我ながら唐突千万！",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの唐突千万な出来事に変に感動していることを羞ずべきことではないのだと自分自身に言いきかせていた。",
              "citation": {
                "source": "白痴",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
