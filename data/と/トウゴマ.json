        "examples": {
          "standard": [
            {
              "text": "唐胡麻の種子から抽出される油は、古くから薬用や工業用に利用されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭に植えた唐胡麻が大きく成長し、独特の葉の形が目を引く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "唐胡麻の実は毒性があるため、食用にしてはいけない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たのしそうに、あちらこちらの繁みや藪かげをのぞき込みながら、「花菅は、もう終りだ」　と、つぶやいたり、「おや、唐胡麻は、きょうは元気ないの」　などといったりする。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "花菅も、唐胡麻も、眼につくようなところにあるのではない。",
              "citation": {
                "source": "キャラコさん",
                "author": "馬と老人",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論私は叔父だの叔母だのとさんざん争いましたけれども、とうとうごまかされてしまつたのです。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
