        "examples": {
          "standard": [
            {
              "text": "大事な部分を読み過ごしてしまい、テストで間違えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この本は少し難しいので、理解できないところは読み過ごしても構いません。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は新聞の小さな記事を読み過ごしてしまい、後で後悔することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "自分の文章の校正刷りを見る時に顕著な誤植を平気で読み過ごすと同じような誤謬が、不完全なレコードを完全に聞かせるに役立つ場合も可能である。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とに角一通り読み過ごすことによって読者を尤もに思わせ、納得させ、その気にならせる力を有っていることだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
