    "definitions": [
      {
        "index": 1,
        "gloss": "to be completely weakened",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
