      {
        "index": 1,
        "gloss": "Budget Committee (of the Upper and Lower Houses of the Diet)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
