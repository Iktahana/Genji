    "definitions": [
      {
        "index": 1,
        "gloss": "reading out and comparing (e.g. proofs against a manuscript)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最終原稿と校正刷りの読み合わせを行い、誤字脱字がないか確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "契約書の読み合わせは、双方の合意形成において非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生と生徒でテストの解答の読み合わせをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "下手な応募俳句を読み合わせているところへ、ぶらりと磯田が入って来た。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又世間の多くの人は、最近の博士の有名な論策のいくつかをここで読み合わせることが出来るだろう。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の東京地図」と「女作者」「虚偽」「泡沫の記録」などをよみあわせたとき、二十年前に「キャラメル工場から」を書き、プロレタリア文学の歴史に一定の業績をのこしているこの作家が、複雑な良心の波にゆすられながら、民主主義の婦人作家として自身に課している努力を理解することができる。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所属の部所が私には与えられていなかったから、タイピストは私に、コッピーのよみあわせをしてくれと頼みに来るし、営業の人は、使い走りを命令し、会計は、銀行ゆきをしてくれという。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
