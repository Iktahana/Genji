        "examples": {
          "standard": [
            {
              "text": "忙しい日のランチは、手早く吉野家で済ませることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "吉野家の牛丼は、老若男女問わず多くの人々に愛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "駅前に新しい吉野家がオープンし、いつも賑わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コムデックスの会場では早くもミップスのＲ４０００（吉野家流でスピードを稼ぐ、例のＲＩＳＣ方式のマイクロコンピューターだ）の上でＷｉｎｄｏｗｓＮＴが動いていたそうで、これはこれで実にたまげた話ではある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにＷｉｎｄｏｗｓ３・０で『うまい』が加われば、吉野家だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで出てきたのが、一段上のＲＩＳＣ（吉野家）レベルでのＩＢＭ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
