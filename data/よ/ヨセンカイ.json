        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テニスのグランドスラム大会では、本戦に出場するための予選会が開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのeスポーツ大会の予選会は、オンラインで実施され、多くのプレイヤーが参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アマチュアゴルファーがプロの大会に出場するには、まず予選会で好成績を収める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "国際聯盟婦人会の幹事改選予選会報。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は愈々予選会ぢやないか。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
