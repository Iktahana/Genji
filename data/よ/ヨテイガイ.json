        "examples": {
          "standard": [
            {
              "text": "予定外の出費が重なり、今月は家計が厳しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行中に予定外のトラブルに見舞われたが、なんとか乗り切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の予定外の訪問に、家族は驚きながらも喜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "予定外の準備が必要になったので、急がねばならない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして応召の予定外の人にて取扱い者を定めて練習せしめ、時に競技会でも行なえばただちに上達する事請合いである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定は砂丘のように変りやすいものだし、人間の一生は、非常にしばしば、予定外の生活によって、その方向を与えられるものなのである。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことも御相談しようと思ったけれど、今日は予定外の話になって長くなったから、またこの次ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そういうことです、すっかり予定外です。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、予定外だったらしい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
