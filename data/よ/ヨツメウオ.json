    "definitions": [
      {
        "index": 1,
        "gloss": "four-eyed fish (Anableps spp.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
