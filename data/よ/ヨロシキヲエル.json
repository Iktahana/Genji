        "examples": {
          "standard": [
            {
              "text": "彼は常に、仕事とプライベートのバランスが宜しきを得ていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その計画は、費用と効果の面で宜しきを得ていると評価された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "料理の味付けは、ちょうど宜しきを得た塩加減だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "袁の宜しきを得るに因るもの亦鮮からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "で今やこの徳目を覚えることが、之を学習したり暗記したりすることが、そしてこの徳目の活用宜しきを得ることが、道徳となる。",
              "citation": {
                "source": "道徳の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
