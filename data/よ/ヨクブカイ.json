        "examples": {
          "standard": [
            {
              "text": "欲深い人間は、しばしば自己中心的で、他人の気持ちを理解できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "欲深い avarice（強欲）は、人間関係を破壊する原因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は欲深い一面を持っており、金銭や地位への執着が強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ふじの花咲く国の王さまは、どちらかといえば、そんなに欲深い人ではなかったのでした。",
              "citation": {
                "source": "ひすいを愛された妃",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の中が、まちがっていることに気づかなかったばかりに、俺も、いつしか欲深い人間になってしまった。",
              "citation": {
                "source": "船でついた町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも欲深いシカゴ長者が貴族を支援する例は思い出せませんね。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鉱山発見者は妙な男で、とても欲深い性質だった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲深い狐のように獲物を物陰に隠した。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
