        "examples": {
          "standard": [
            {
              "text": "祇園祭の宵山は、提灯の明かりが美しく幻想的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宵山期間中、京都の街は多くの観光客で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎年、家族と宵山を見に行くのが夏の楽しみの一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「今ぞ始めの旅衣、よいやまかせ」にて頭巾をかなぐり捨て、糸鬢奴の仮髪を見せ、緋縮緬に白鷺の飛ちがひし襦袢の肌脱になり裾を両手にてまくり、緋縮緬のさがりを見せての見えは、眼目の場ほどありて、よい心持なり。",
              "citation": {
                "source": "両座の「山門」評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            }
          ]
        }
