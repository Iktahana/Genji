        "examples": {
          "standard": [
            {
              "text": "ローストビーフの肉汁をたっぷり吸わせたヨークシャープディングは最高の贅沢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本場のイギリスで食べた、ふわふわに膨らんだヨークシャープディングの味が忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日曜日のディナーには、手作りのヨークシャープディングを添えるのが我が家の定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ホースラディッシュは附いていたが、ヨークシャープディングは添えてない。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ヨークシャープディングと迄は行かず、ホース・ラディッシュのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
