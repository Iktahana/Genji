    "definitions": [
      {
        "index": 1,
        "gloss": "sidewise crawl (e.g. of a crab)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海岸で小さなカニが横ばいをしながら、忙しそうに砂浜を移動していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アオウミガメは、海底を横ばいでゆっくりと進むこともある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水槽の中のヤドカリが、貝殻を背負って横ばいで歩いている様子を観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ガラガラ蛇が横ばいをするのも奇妙である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その話しかたが横ばいなんだそうです。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは木の上に登ろうとしましたが、横ばいですからいくら登っても登っても落ちてしまいます。",
              "citation": {
                "source": "猿かに合戦",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "カニは、つめをふりたてて、横ばいをしながら、砂地からエモノをさがして食う。",
              "citation": {
                "source": "海の青と空の青",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "塀にピッタリ身をつけて、カニのように、横ばいをするほかはないのです。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばけガニは、八本の足で、よこばいをするのですから、とても、にげあしがはやくて、さすがの明智にも、なかなかつかまりません。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "leafhopper (insect)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "畑の葉っぱをよく見ると、小さな緑色の横ばいがたくさん付いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "稲の病害虫である横ばいは、作物の生育に深刻な被害を与えることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "害虫駆除剤の散布時期を間違えると、横ばいが大量発生してしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "sidewinder (Crotalus cerastes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "砂漠地帯では、独特の横ばいで移動する横ばいガラガラヘビに注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "横ばいの動きは、砂の上を滑るように移動するのに適した方法らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "動物園で、横ばいガラガラヘビが砂の上を横ばいで移動する様子を初めて見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "levelling off (of prices, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "株価は数日間、横ばいで推移しており、投資家たちは次の動きを注視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "景気は回復の兆しを見せず、依然として経済指標は横ばい状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長引く不況のため、多くの企業の業績は横ばい、あるいは微減にとどまっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
