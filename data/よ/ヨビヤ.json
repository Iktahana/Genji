        "examples": {
          "standard": [
            {
              "text": "有名なロックバンドの呼び屋が、来日公演の交渉を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は敏腕の呼び屋として、多くのイベントを成功させてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "呼び屋の仕事は、アーティストと会場、観客をつなぐことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かなた天路のはづれに、白衣の靡きゆららに、今宵し六日のかたわれ月、（さはあえかなる病女の夕眺めするなよびや、）さ青のまなじり伏目がちに。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そやったら、どうぞええ時およびやしておくれやす」お今さんは、そのまままた静かにさがっていった。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「警官をよびやがって、よくも裏切ったな……裏切り者め！",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
