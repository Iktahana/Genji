        "examples": {
          "standard": [
            {
              "text": "「よしなし事に気を取られて、大切なことを忘れてしまいそうだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼はよしなし事で悩むのではなく、もっと本質的な問題に集中すべきだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「「くだらないよしなし事で時間を使わないで、さっさと終わらせようよ！」」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "こんなよしなしごとを考えながら、ぶらぶらと山下のほうへおりて行くのであった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "受授が情を異にし遊んだ篷底の夢の余りによしなしごとを書きつけはしたが、もとより人を酔はさう意も無い、書かずともと思つてゐるほどだから、読まずともとも思つてゐる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おん身が場に上りしは唯だ一夜にして、假名をさへ用ゐぬれば、かゝる夢の如きよしなしごとの久しく人の記憶に殘らん憂はあらじ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
