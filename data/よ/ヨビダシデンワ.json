        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔、公衆電話が呼び出し電話として使われることが多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自宅に電話がないため、隣の商店を呼び出し電話にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "呼び出し電話のサービスは、今ではほとんど見かけなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どんなに油と蝋の利いたスキイでも、尖端に雪の山を押して折れるか、さもなければ全身埋没して動きが取れなくなる――呼び出し電話ばかり掛って来て、never どこへも行き着かない恋。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話連絡はたぶん呼び出し電話か、どこかの商店からだろう。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
