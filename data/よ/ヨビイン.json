        "examples": {
          "standard": [
            {
              "text": "大会運営のため、多くの予備員が準備に当たった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合中に選手が負傷した場合、すぐに予備員が投入される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "予備員は、いざという時のために常に待機している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また、ここにいる木村、野村の両人も、同志の手に余る敵のある時、飛び出して行って加勢仕る役割、謂わば予備員でご座る。",
              "citation": {
                "source": "『七面鳥』と『忘れ褌』",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "救護班の第一予備員の方は、至急マスクをつけて、旭市場救護所へお集り願ひます。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ　　救護班第二予備員の方は、至急佐竹子爵邸仮救護所へお集り下さい。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
