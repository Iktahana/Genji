        "examples": {
          "standard": [
            {
              "text": "職人は、繊細な絹糸に丁寧に縒りをかけていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強い縄を作るために、複数の繊維に縒りをかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この機械は、自動で糸に縒りをかけることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一方依嘱された仏師の方でも、各名人たちの製作が並んで公衆の面前に開展されることでありますから、これも腕によりをかけるという風、伎倆一杯に丹精を擬らし、報酬の多寡などは眼中に置かないという有様となる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほぐした糸に、よりをかける者。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
