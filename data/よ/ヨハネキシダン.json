          "standard": [
            {
              "text": "歴史の授業でヨハネ騎士団について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヨハネ騎士団は、中世に活躍した宗教騎士団の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マルタ島には、かつてのヨハネ騎士団の本拠地がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "面白いことに故郷で病院を監督した聖ヨハネ騎士団は白衣を着ていたが、これは古代にアスクレピアドを区別するものであった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルタンは二十五隻の艦隊を小亜細亜の海岸に送って船材を取り寄せようとしたが、ロードス島でヨハネ騎士団の襲撃をうけ、更にあらしで難破し、僅かに十隻が目的を果したのみであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
