        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "誤解されないように、事前に予防線を張っておくことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は会議で厳しい質問をされることを予測し、予防線を張るような発言をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトが遅れないよう、いくつかの予備案を用意して予防線を張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は父を怒らしてはならないと思つて予防線を張るためにその室に行つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと、私が家に帰ってから訴えるであろうところの不平を言わせまいと、まずその予防線を張るのだった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "万全を期する為二重の予防線を張ることを考えついた。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
