        "examples": {
          "standard": [
            {
              "text": "ヨーロッパ連合は、多くの国が経済的、政治的に協力する組織だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イギリスはヨーロッパ連合からの離脱を選択した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヨーロッパ連合の会議がブリュッセルで開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヨーロッパ諸国はヨーロッパ諸国だけのヨーロッパ連合をつくって、政治経済の問題を処理し、文化も守るべきであるというのがクーデンホフ・カレルギー伯の汎ヨーロッパ主義だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汎ヨーロッパ連合にソヴェト同盟は招待されていなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマン・ローランが、汎ヨーロッパ連合に勧誘されたとき、もういまは世界の諸民族の結合のために努力すべきだ、という意味から拒絶したことを、伸子は、モスクへ来たばかりだった伸子は、その古い文学新聞を大事に紙挾みの間にしまってもちつづけていたのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
