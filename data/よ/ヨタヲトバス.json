        "examples": {
          "standard": [
            {
              "text": "お酒が入ると、父はよく与太を飛ばす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真面目な話をしているのに、与太を飛ばすのはやめてほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人とくだらない与太を飛ばし合って、楽しい時間を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "八人の酔ッ払いがどんな与太を飛ばすだろうかと思うと今から旅が楽しみです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんばあの話が、Ａ氏の裡のやみがたい郷愁の語らせた作り話であるにしても、それならそれで美しいではないかとも思はれたし、またＡ氏の持つかなり観察の鋭い一面も知つてゐて、さうさう与太を飛ばす人ではないやうに思つてゐたからである。",
              "citation": {
                "source": "三つの挿話",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
