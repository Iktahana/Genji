        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の貴族にとって、嫁選びは家柄や政略が絡む重要な問題だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は理想の嫁選びに苦戦し、未だ独身だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "息子の嫁選びに口を出す親もいれば、自由に任せる親もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どんな息子にしろ、格別の感情を抱いてもいない妹の友達たち一人一人をやがての嫁選びのような目で自分にひきつけて眺められることには我慢しきれない神経をもっていると思う。",
              "citation": {
                "source": "異性の友情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "代々の祖母や母が、息子のために多くの縁談のうちから、贅沢な嫁選びをしてきたほど、幸福であったのである。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "エセックスは理想的な嫁選びをしたもので――相手はサア・フィリップ・シドニイ未亡人であり、サア・フランシス・ウォルシンガムの娘であった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、どうしてもおよめえらびをしなければならなくなったら、ぼくはいっそおまえをえらぶよ。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
