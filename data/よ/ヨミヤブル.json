        "examples": {
          "standard": [
            {
              "text": "難しい哲学書をようやく読み破り、達成感でいっぱいになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの分厚い歴史小説を一週間で読み破るとは、すごい集中力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "論文の山を読み破るには、かなりの時間と忍耐が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "思うにルクレチウスを読み破る事ができたら、今までのルクレチウス研究者が発見し得なかった意外なものを掘り出す事ができはしないかと疑う。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼の家を出てから十日の間に、早くも男の秘密を読み破る鑑識を拾って来たはずだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章を読み破る力のある人、歌の調子又そのよしあしを判別し得る人なら誰でも気がつく筈である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
