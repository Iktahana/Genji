        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古書には、「袖が汚る」といった表現が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その言葉は、彼の心を汚るように感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自らの手で汚ることを厭わなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あわれ、何しに御身の膚に汚るべき。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏の汚るゝ遊びはせぬものぞと誡め置けるに、下界の土を踏みたがることよ。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "青衫又た馬蹄の塵に汚る月明今夜消魂客。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍露だも汚るれば汝何等の恥辱ぞや！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯く塵埃に其頭まみれ汚るゝ無慚なる　405姿眺めて、恩愛の母は白髮掻きむしり、美なる面※打棄てゝ聲を搾りて泣き叫ぶ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "高徳の聖殿も長く罪悪と居を共にする時は、ついには汚るるものに御座候。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚解てよごるゝ藤の長さかな　　　　探志　何かの必要があって藤棚の竹を解いたので、そこに下っていた藤の長房が地に垂れて、花の末を汚した、という意味であろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
