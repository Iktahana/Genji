        "examples": {
          "standard": [
            {
              "text": "齢を重ねることは、決して衰えではなく、経験という宝物を増やすことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夫婦で仲良く齢を重ねていけるのは、この上ない幸せだと感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は齢を重ねるにつれ、ますます洗練された美しさを放つようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人が、真率にして齢を重ねる時、「習慣」の存在に対して次第に寛容になることは、自然なことである。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は齢を重ねるにつれてその肉体から温かみが失せてゆくものだが、それと同じように、この古色蒼然たる屋敷も、幾世紀かの年月を閲するうちに、いつしか、つめたく冷え切ってしまったように思われるのだった。",
              "citation": {
                "source": "初雪",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては一夜にして十年以上の齢を重ねることなくんば、現世において到底彼女との愛恋をさゝやき得ることは叶ふまいと、容易に私はその恋ごころをおもひあきらめてはしまつたのだつた。",
              "citation": {
                "source": "浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃年齢を重ねるに従つて、草木の花といふ花、みな深紅のものに最も眼をそばだて愛着を感ずるやうに覚えるが、これはどういふ訳であらう。",
              "citation": {
                "source": "柘榴の花",
                "author": "三好達治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
