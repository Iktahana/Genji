        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "PCにUSBメモリを挿入して、データを読み込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
