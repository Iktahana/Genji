    "definitions": [
      {
        "index": 1,
        "gloss": "to call out (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もしもし！」と、遠くにいる友人に大声で呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は子供の名前を呼んで、急いで追いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困っている人がいたら、迷わず助けを呼ぶべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わが知らぬ、とほきとほきとほき深みにて　青空は、白い雲を呼ぶ。",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "新短歌のみならずすべて一呼吸詩歌（私は短歌や俳句や新短歌を今仮りにさう呼ぶ）が、その詩歌の中に生活を見出すものでなくて、生活の傍に生ずるものとしてだけ意義を有するものであるといふことを、左にもう少し言添へよう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三丁行くと私の名前をひどく嬉しさうに呼ぶ奴がある、見るとそれは三田村なのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人たちは私を呼ぶのに佐野次郎左衛門、もしくは佐野次郎という昔のひとの名でもってした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と呼ぶにとゞまつたことであらう。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、旧約聖書の「詩篇」に於いて、「ヤーエ」と呼ぶ時に、ヤーエといふ一単語の音色が既に今では感じ切れない程の微妙な意味をも有してゐたであらうことなぞ、一応想起されたいのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、これを一と先づ「ゆたりゆたり」と呼ぶことにして、　此のゆたりゆたりが、日猶浅く大衆のものとなつてゐないので、つまり「ああいふものか」とばかり分り易いものとなつてゐないので、大衆は詩に親しみにくいのだし、詩人の方も産出困難なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝が来るたびに、隣りのタカヂアスターゼの下から三番目の子供が、「イチオー………コイマー」と何度も／＼呼ぶのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼ぶことゝ手を温ためることゝ、一挙両得といふわけである。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　生きることは老の皺を呼ぶことになると同一の理で想ふことは想ふことゝしての皺を作す。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を、私は今、「自然詩人」と呼ぶ。",
              "citation": {
                "source": "河上に呈する詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "パノラマ館には例によって人を呼ぶ楽隊の音面白そうなれば吾もまた例によって足を其方へ運ぶ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄下の溜池に海蟹の鋏動かす様がおかしくて見ておれば人を呼ぶ汽笛の声に何となく心｜急き立ちて端艇出させ、道中はことさら気を付けてと父上一句、さらば御無事でと子供等の声々、後に聞いて梯子駆け上れば艫に水白く泡立ってあたりの景色廻り舞台のようにくる／＼と廻ってハンケチ帽子をふる見送りの人々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾り気一点なきも樸訥のさま気に入りてさま／″＼話しなどするうち京都々々と呼ぶ車掌の声にあわたゞしく下りたるが群集の中にかくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨と晴れとの中にありて雲と共に東へ／＼と行くなれば、ふるかと思えば晴れ晴るゝかと思えばまた大粒の雨｜玻璃窓を斜に打つ変幻極まりなき面白さに思わず窓縁をたたいて妙と呼ぶ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人鬼、吸血鬼、などと憎むべきものを鬼と呼ぶところから見ても、これはとにかく醜惡の性格を有する生き物らしいと思つてゐると、また一方に於いては、文壇の鬼才何某先生の傑作、などといふ文句が新聞の新刊書案内欄に出てゐたりするので、まごついてしまふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、いま月下の宴に打興じてゐるこの一群の赤く巨大の生き物は、鬼と呼ぶよりは、隱者または仙人と呼稱するはうが妥當のやうなしろものなのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岩壁の脈から、左の方の低い尾根へと取れば、槍ヶ岳へ行かれるのであるが、私は穂高の峰々を片ッ端から踏んで見たくなったので、私が御幣岳（明神岳または南穂高岳）と呼ぶ三本槍状の穂高を、先へ駈けぬけるつもりで、人夫だけを別れ道に待たせて置いて、嘉代吉と二人で偃松の間をむやみに走った。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで一体、富士の神を浅間と呼ぶのは、どうしたわけであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天空に浮遊するかの如き、嶮にして美なる林道を「天の浮橋」と呼ぶそうであるが、何よりも喬木林の陰森さにおどろかされる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、森林帯に入るとさすがに涼しい、中でもシャスタ樅と呼ばれる喬木の一種は、この山、特有とまでゆかなくても、この山の産として最も名高いのであるが、富士の落葉松を、富士松と呼ぶたぐいであるかも知れない。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお登ると、俗にホワイト・バーク・パイン（白皮松）と呼ぶ喬木が出てくる、高さは二百尺位に達するのは珍らしくはない。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中村だがね、ちょっと署まで来て貰いたいんだ」――誰だい――と呼ぶ吉田の声が、鋭く耳を衝いたので、子供が薄い紙のような眠りを破られた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば悪趣味で人を呼ぶ都会の料理屋の造り庭の全く無意味なこけおどしの石燈籠などよりも、寸分無駄のない合理的な発電所や変圧所の方がどの位美しく気持がよいか比較にならないやうに思はれるのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば悪趣味で人を呼ぶ都会の料理屋の造り庭の全く無意味なこけおどしの石燈籠などよりも、寸分無駄のない合理的な発電所や変圧所の方がどのくらい美しく気持がよいか比較にならないように思われるのである。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう思い返してもこう呼ぶのがいい――が流行の波斯縁の揃いの服で、日｜覆けの深いキャフェの奥に席を取った。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは、どこか素性のいい家に生れた白痴なのだ」「そう言えば、上品だ」　町の人は、少年自身がわずかに記憶している四郎という名を聞き取って四郎馬鹿と言ったが、四郎馬鹿さんと愛称をもって呼ぶようになった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その養殖場には日蔭をつくるための樹林と湿気を呼ぶ苔とが必要である。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝蝦より稍々大きいラングスチンと呼ぶ蝦は鋏を持っている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき龍は洞の外で人の若々しい聲が呼ぶのを聽いた。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
