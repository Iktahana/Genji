        "examples": {
          "standard": [
            {
              "text": "次期社長の予定者は、社内でも優秀な人物として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の娘は、将来ピアニストの予定者だと周囲から言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいプロジェクトのリーダー予定者が、今日の会議で発表される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "廃墟の子ども　永井　隆　画　死病にかかっている父、二人の幼い孤児予定者――これが如己堂の住人である。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠一は孤児予定者です。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "日陰にかくれて、じっと涙をたたえている孤児や半孤児や孤児予定者がきっといます。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
