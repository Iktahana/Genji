        "examples": {
          "standard": [
            {
              "text": "この製品は、縦方向だけでなく横方向にも伸縮するので、使い勝手が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建物の構造を説明する際、柱の垂直方向と梁の横方向の役割を明確に分ける必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "交通渋滞を避けるため、都市部では地下鉄や高架道路などの多層的な横方向の移動手段が発達している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "登攀にあたっては横方向に畝のついた石の急斜面やあちこちにある階段代わりの傾斜した板を伝っていった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "一群のマウスに炭疽病を感染させて血液を繰り返し顕微鏡で観察して、炭疽病桿菌が長い糸状に育ち横方向に分裂して胞子を形成することを彼は発見した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
