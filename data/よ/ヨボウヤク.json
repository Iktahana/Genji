        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マラリア流行地域への渡航には、予防薬の服用が推奨される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は、特定の病気のリスクが高い患者に予防薬を処方した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この予防薬は、感染症の発生を効果的に抑えることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "病の徴候としての憂欝は、もはや、一刀両断の処置しかありませんが、恋愛をして病にまで昂じさせない予防薬は、恐らく青年としての「矜り」と「嗜み」でありませう。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞこんな病気があるからもし予防薬でも手に入つたら送つて頂けたらといふことだけは申しあげました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少の偏頭痛のためか、あるいは、近ごろの婦人たちがボンボンのようによくかじってついに頭がからっぽになる、あの頭痛予防薬のためかで、頭がぼんやりしていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説は犯罪の予防薬である　野村　わたしはね、こう思うんだ。",
              "citation": {
                "source": "探偵小説このごろ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
