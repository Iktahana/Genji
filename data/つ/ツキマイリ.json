        "examples": {
          "standard": [
            {
              "text": "亡くなった祖父の月命日には、家族で欠かさず月参りを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「月参りのついでに、門前の和菓子屋で季節の饅頭を買うのが楽しみなんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "檀家回りをするお坊さんのために、月参りの準備をして待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "祖母は伊勢｜朝長の大庄家の生れで、幼少な時、童のする役を神宮に奉仕したことがあるとかで神明様へは月参りをした。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "男｜奇異しく、怖しく思ふ程に、内野にありける十歳許なる死人を、此れ川原に持行て棄てよと責めければ、男終日長谷より歩み極じて、力なく堪へ難くて、我れ長谷に三年月参りして、結願して帰る時しもかゝる目を見るこそ、実に前世の果報の致す所なめれ。",
              "citation": {
                "source": "放免考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
