        "examples": {
          "standard": [
            {
              "text": "終業式の日に通知表をもらい、苦手な算数の成績が上がっていて一安心した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母親に成績を見せるのが怖くて、通知表をカバンの奥深くに隠してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "先生が通知表の備考欄に、私のボランティア活動を褒める言葉を書いてくれたのが嬉しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "学年末の通知表を見ると作文と体操が、〇点と〇点で落第だつた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "學年末の通知表を見ると作文と體操が、〇點と〇點で落第だつた。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験の席次は、例によって寮の掲示板に貼りだされたが、通知表には五段階評価が書かれているだけだから、そうしたくないなら、親にはいわなければよい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "通知表もらったら、笑ってばかりもいられんだろう」　といって、えびせんをひとつ、口に放りこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、あしたまで待って、通知表をもらって――」「うるさいな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
