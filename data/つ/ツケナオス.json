        "examples": {
          "standard": [
            {
              "text": "取れてしまったボタンを、針と糸で付け直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壁に貼ったポスターが剥がれてきたので、もう一度しっかり付け直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "途中で折れてしまった枝を、テープで付け直すことはできなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "中味は同じであるにも関わらず、器を変えるたびに一から値段を付け直すというやり方は、平凡社の専売特許ではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「火の玉」少尉は、マイクに紐線をつけなおすことに、つい注意を注ぎすぎたようであった。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "火をつけなおすひまなんてない。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような不安な思いのなかから、直子をとらえなおす手がかりをあらたに見つけなおすという新しい作業が、ヨシオの内部で始まった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
