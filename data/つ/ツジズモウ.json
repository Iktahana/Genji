        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村外れの野原に立てられた小屋で、旅回りの一座による辻相撲が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "辻相撲の呼び込みの声に誘われて、多くの見物客がテントの中へ入っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熱気に包まれた辻相撲の土俵で、力士たちが激しくぶつかり合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
