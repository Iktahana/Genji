    "definitions": [
      {
        "index": 1,
        "gloss": "amateur wrestling on a street corner or in an empty field (esp. in autumn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋祭りの境内で辻相撲が開催され、村一番の力自慢が集まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供たちが空き地で辻相撲に興じている姿は、微笑ましい光景だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "辻相撲で勝ち残った者には、豪華な賞品が授与されることになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "投げられて坊主なりけり辻相撲　勇ましい男らしい辻相撲などがあそこにもここにも行なわれるからである。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「投げられて坊主なりけり辻相撲」という其角の句にしても、その坊主頭が異様に眼に映ることを考慮に入れなければならない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "wrestling show in a roadside tent",
