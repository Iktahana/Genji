        "examples": {
          "standard": [
            {
              "text": "この学校では、通学服の着用が義務付けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい通学服が届いたので、さっそく試着してみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "通学服を着ると、自然と気が引き締まる感じがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、一つの学校の遠足のような趣に、同じような年頃の、同じような通学服姿の女学生達の、おとなしい、だが圧力のこもった波をその辺に溢れさせた。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼろをつくろって、何とかして着るとか、夫の古外套を更生して、子供の通学服を作るとかいうことは、アメリカではほとんどない。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
