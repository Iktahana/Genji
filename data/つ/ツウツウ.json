        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "社内の極秘プロジェクトの進行状況が、ライバル会社につうつうに漏れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お喋りな彼に秘密を話すと、次の日にはクラス全員に内容がつうつうになってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サーバーのセキュリティが甘いせいで、顧客情報が外部へつうつうの状態だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
