        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強い風が吹き荒れ、遠くの畑から砂が飛んでつちふる一日だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サハラ砂漠から飛来する黄砂で、毎年春にはつちふる現象が起こる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓の外を見ると、まるで空から土が降ってくるように、激しくつちふっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "霾るや、黄なる沙、嵐と哮び、漲るや、洪き水、天傾ぶけぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "み冬の夕かげあかき砂の原｜空眼薄らに駱駝来れり蒙古びと駱駝追ひつつ夕べなり早駈けに乗る驢馬の後尻霾らす黄沙の平ただならず日は朱に澱み蒙古犬吼ゆ註、霾るとは遠く沙塵の黄濁するを云ふ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲端に霾る、と桃青居士の誇張した岩が根道も、追ひ剥ぎの出るに値する位は、人通りもあつたのである。",
              "citation": {
                "source": "山のことぶれ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
