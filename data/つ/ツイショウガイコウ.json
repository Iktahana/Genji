        "examples": {
          "standard": [
            {
              "text": "小国が強大な隣国に対して追従外交を行うのは、避けられない現実かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの国の外交方針は、常に大国の意向に沿った追従外交だと批判されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "追従外交を続けることは、長期的には国益を損なう可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このことは、吉田内閣のごとく、その主体性を没却せる、アメリカ追従外交政策によっては断じて打開ができないのであります。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
