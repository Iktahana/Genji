        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "わが軍の騎兵隊は、敵陣の最も脆い部分を突き崩すことに成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "横一列に並んだ相手の防衛ラインを、パワープレーで突き崩す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "圧倒的な戦力差を活かして、包囲網を内側から突き崩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
