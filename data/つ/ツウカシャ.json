        "examples": {
          "standard": [
            {
              "text": "厳しい予選を勝ち抜いた通過者たちが、壇上に整列した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一次試験の通過者リストが、掲示板に貼り出されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通過者には後日、二次の詳細がメールで送られる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しばらく東京及ヨコハマ着の切符発売停止（軍の者をのぞく）また京浜通過者の切符も同様なり。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
