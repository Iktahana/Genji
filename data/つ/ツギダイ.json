    "definitions": [
      {
        "index": 1,
        "gloss": "stool (stood on to reach high objects)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
