        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "派手な演出を避け、親しい友人だけを招いた約やかな結婚披露宴を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は約やかな性格なので、目立つ場所よりも裏方で支えることを好む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算の都合上、新製品の発表会は約やかな規模で開催せざるを得なかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
