        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "餅つきの絵本には、臼と杵と月の兎が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古くから日本では、月に月の兎がいると信じられてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜空を見上げると、本当に月の兎が餅をついているように見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「私の祖父の家来であった年寄が、月の兎の餅を拾って食べたところ、三ヶ日は夜目が見えたという話ならば聞き及んでおりましたが、月の姫の寵愛の笛をこの私めが拾う縁に当ろうなどとは、夢にも思うてみませんでした。",
              "citation": {
                "source": "紫大納言",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
