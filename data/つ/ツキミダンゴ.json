    "definitions": [
      {
        "index": 1,
        "gloss": "dumplings offered to the moon (on the 15th day of the 8th month and the 13th day of the 9th month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちと一緒に、十五夜に供えるための月見団子を丸めて作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「月見団子、あんこをつけるのと醤油で焼くの、どっちが好き？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山積みにされた月見団子の横で、ウサギの形をした饅頭が可愛らしく並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然るに独吾輩の如き世間無用の間人にあつては、あたかも陋巷の湫路今なほ車井戸と総後架とを保存せるが如く、七夕には妓女と彩紙を截つて狂歌を吟じ、中秋には月見団子を食つて泰平を皷腹するも、また人のこれを咎むることなし。",
              "citation": {
                "source": "礫川記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲の側には、フットボールの球程のキルク玉が巨人国のお月見団子みたいに積上げられた。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを垣根の隙からそっとさし入れて、縁端のお月見団子を取って行くのである。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
