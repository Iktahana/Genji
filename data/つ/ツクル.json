    "definitions": [
      {
        "index": 1,
        "gloss": "to make",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は趣味の模型を作ることに没頭している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供と一緒に庭で砂の城を作るのは楽しい時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "段ボールを使って、猫のための新しい家を作ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「自己以外のものと争ふことは修辞を作り、自己と争ふことは詩を作る」（三六・一〇・五）",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことがさまざまの迷蒙を作る！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の余剰価値ともあるべき筈の芸術が浅墓なことであるくらゐならば、頼みもしないにそんなものを作らなくてもよいのだし、作るとすれば図々しいことである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたどんなにして名前なんかを考へ出すの、あたしの一寸知つてる人はね、男だつたら自分の学校友達なんかゝら、女のだつたら恋人や恋人のお友達の名を色んなにモヂて作るんですつて。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからの映画は、必ずしも「敗者の糧」を目標にして作るような事は無いかも知れぬ。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、詩といへば「ああいふもの」と、一般的にハツキリと位置するものとなつたとしたら、楽しむ方でも作る方でも、事情は一変するのであるが、これは容易に首肯されさうでゐて、却々了得され難いことだと思はれる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、芸術家が、生活家の義務を強ひられざるやうな環境を作ることによつて。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は皆、その中では真剣になつて人生と取組み合ひ全力を出しきつて文学と四つ角力をとつてるのに、詩や俳句を作る時は、乙に気取つた他所行きの風流気を出し、小手先の遊び芸として、綺麗事に戯むれてゐるといふ感じがする。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本の學校教育は、いたづらに子供を小常識人化し、小才智人化し、チンピラ小學生の侏儒を作ることを以て、究極の目的としてる如く思はれる。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に詩を作る人々は、過去においても未来においても、新しい詩においても古い詩においても、必須的に先ず俳句や和歌を学び、すべての技術の第一規範を、それから取り入れねばならないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るや小豆の煮える中　という句を作り、さらに春風馬堤曲を作る蕪村は、他人の藪入りを歌うのでなく、いつも彼自身の「心の藪入り」を歌っているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍に倨して詩を作る。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の座敷は殿方ばかりにて、ビール又は正宗の空壜を作るによねんなし。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、陸上の家のやうにあんな窮屈な屋根や壁を作る必要は無いのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大網の尖端は、紐のように太く揺れて、アール・ヌーボー式の図案に見るような、印象の強い輪廓を作って、幾筋となく繋がっては、環を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師は楓の細木を伐り朴し、枝葉を払わないままで、柱を立て、私たちの用意して来た、二畳敷ほどな油紙二枚を、人字形に懸けて、家根を作る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士山は日本では三千七百七十八米突という抜群の標高を有しているが、太平洋方面は黒潮が流れるほどの暖かさで、かつ冬季は霽れて雨量が少なく、山腹以上の傾斜が急峻であるから、これも氷河を作る資格がない。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそればかりで出来るのではない、万年雪や氷は、塑造的物質になって、その通過する地床の傾斜に、少しでも変化があれば、氷雪はそれに応じて裂罅を作ること、渓流の「渦巻き」が、いつ見ても一つところに、居据わりのように出来ているのと同じく、クレッヴァスも毎年同一の地点に出来る現象を呈する。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを刳りつくすと、また雪がずり下りて、一段低い所へ同じものを作るので、日本北アルプスにはそれが頗る多い。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を作る時に拵らへたセメント置場か何かのバラックである。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の手で作るか、自分の労力の正当な報酬として得たもののあまりに少ないのに驚いた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にこういう空間曲線を作る事は厄介であるから、その代りにこの曲線をＸＺ面とＹＺ面に投射したものと二つを画いて調べる外はないのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大変にうまい法だが難儀な事にはこの種板を作るのがなかなか六かしい。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこんな風でなく始終強さの変らぬ規則正しい波を作る事が出来れば種々の便がある。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで近年になって規則正しい波を作る工夫が色々出来た。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも六稜あるいは稀に三角形の氷の薄片であるが、その規則正しい輪郭は千変万化で如何なる美術家でもこれだけの変った形を作る事は出来そうにもない。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに長い電灯を何のために作るだろうかと尋ねてみると、これは物好きでも酔興でもない。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原料を作るには水力電気を用いる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの針金を作る方法が色々工夫された、例えば細粉にした金属を膠でこねて糊状にし、これを糸にした後、膠だけ焼いて取るとか、またこの金属の酸化物をこねて糸にした後これを還元させるとかする。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
