        "examples": {
          "standard": [
            {
              "text": "成人式は、子供から大人へと成長するための重要な通過儀礼とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新入社員にとって、厳しい研修合宿はある種の通過儀礼のようなものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "世界各地には、若者が一人前として認められるための独自の通過儀礼が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この時期、早熟な少年たちのあいだでは、仲間たちを、そして自分自身を圧倒するねたを仕込むために哲学書を読むという、古典的な青年期の通過儀礼がなお生きていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは二人とも同様に、隠秘学上の経歴の中の特定の段階で、何らかの悍ましい宗教的な通過儀礼を受けたことを物語っているのだろう。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
