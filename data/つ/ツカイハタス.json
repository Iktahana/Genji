        "examples": {
          "standard": [
            {
              "text": "ギャンブルで全財産を使い果たし、彼は身を持ち崩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最後の一滴まで燃料を使い果たし、飛行機は無事に着陸した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今日一日で体力を使い果たして、一歩も動きたくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "用あるものは、ことごとくその用を使い果たすところに天命があるのだと思う。",
              "citation": {
                "source": "残肴の処理",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝らの内臓の炎が感覚を使い果たす故。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "体力を事実上使い果たす時が来た。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしワルシャワにおける秩序をではなかった――自分の睡眠を護ることに残りの精力を使い果たす、あの疲れた反動保守家らとは異なっていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
