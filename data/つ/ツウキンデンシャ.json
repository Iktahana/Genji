        "examples": {
          "standard": [
            {
              "text": "朝の通勤電車はいつもぎゅうぎゅう詰めだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は通勤電車の中で、いつも英字新聞を読んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遅延で通勤電車がなかなか来なくて困った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『ＤＤＪ』に初めて登場したテキサス版が、いかに機能を限ったものとはいえ二・九Ｋバイトに収まっていると知って、通勤電車の中で八進数で書かれた機械語のリストを読みはじめ、何をどう処理しているのかを分析してみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃の時間には通勤電車につめこまれているべき年齢のはずのぼくが、漠然とした表情でここに座っていられる事情を無言のうちに追求されることもない。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
