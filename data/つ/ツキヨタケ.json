          "standard": [
            {
              "text": "ブナの枯れ木に重なり合って生えている月夜茸が、闇の中で青白く光っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「月夜茸はシイタケに似ているけど、猛毒だから絶対に食べてはいけないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "撮影のために夜の山に入り、光る月夜茸の姿をカメラに収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "天狗茸、蠅殺茸、虚無僧茸、落葉茸、萌黄茸、月夜茸、笑茸、といったようなしれものが、全く真顔をして、茸には慣れた山人をも誘惑して、毒手を逞しうするという例も絶無ではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            }
          ]
