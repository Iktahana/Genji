          "standard": [
            {
              "text": "彼の作り顔は、本心とは裏腹に、全く笑っていないように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞台役者は、様々な感情を表現するために作り顔を使いこなす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カメラの前では、みんな自然と作り顔になってしまうものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして今度は滑稽な作り顔をして見せました。",
              "citation": {
