        "examples": {
          "standard": [
            {
              "text": "失敗して落ち込んでいるはずなのに、彼は付け元気を出して笑ってみせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不安な気持ちを隠すために、精一杯の付け元気で「大丈夫だ」と言い張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プロジェクトが難航する中、リーダーの付け元気さえも痛々しく感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あんなもの蜻蛉のお繋りだと思やあいゝわ」　すると客は「それでも、あゝいうのは根からわしの性に合わんね」と言い、それから付け元気のように唄声を張り拡げました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸っ子だぞ」と、長助は付け元気で呶鳴った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわべは昔以上に生気溌剌たるものがあるようで、実は付け元気や空威張りになって来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時の付け元気で一緒に行こうなどと云ったものの、かれは確かに中途で変心したに相違ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱い身体の付け元気は永持がしない。",
              "citation": {
                "source": "始業式に臨みて",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
