        "examples": {
          "standard": [
            {
              "text": "持ち運びに便利な継ぎ竿を持って、早朝から近くの川へ釣りに出かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年愛用している継ぎ竿のジョイント部分が緩んできたので、修理に出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本格的な継ぎ竿は高価だが、その分しなりが良く大物とのやり取りもスムーズだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "行李の中には私たち共用の空気銃、Ｆが手製の弓を引くため買ってきた二本の矢、夏じゅう寺内のＫ院の古池で鮒を釣って遊んだ継ぎ竿、腰にさげるようにできたテグスや針など入れる箱――そういったものなど詰められるのを、さすがに淋しい気持で眺めやった。",
              "citation": {
                "source": "父の出郷",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、そういう人は高価な継ぎ竿を幾本も持っているし、魚籠、餌箱、帽子から服から靴まで、すべてその道の装具をきちんと揃えている。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "継ぎ竿が三本、魚籠にも餌箱にもどこかで見た記憶がある。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
