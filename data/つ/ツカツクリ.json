        "examples": {
          "standard": [
            {
              "text": "塚造の仲間は、地面に巨大な塚を作り、その発酵熱を利用して卵を孵化させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オーストラリアの森で、一生懸命に落ち葉をかき集める塚造の姿を観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "塚造の雛は、卵から孵るとすぐに自力で塚の外へ這い出し、空を飛ぶことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "深川の紫塚造船所の製図引で大深泰三という男だよ。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察医が来て愛子を介抱している間に、俺達は紫塚造船所に乗込んで、机の曳出を片付けている最中の大深を、有無を云わさず引っ捕えた。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋の波瀾と離合のからくりが、いつかつくりばなしめいて感じられ、現実性と迫力を失ってしまう一半の原因は、そこらへんからくるのではあるまいか。",
              "citation": {
                "source": "志士と経済",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
