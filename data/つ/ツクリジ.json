        "examples": {
          "standard": [
            {
              "text": "運動会の組体操で、生徒たちが協力して人文字を作り字を完成させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドローンを使った作り字は、夜空に美しいメッセージを描き出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観客が一体となって作り字を掲げ、選手たちを応援した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
