        "examples": {
          "standard": [
            {
              "text": "「峠」や「畑」は、日本で作られた国字、つまり作り字の一種である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は日本の作り字に興味を持ち、その成り立ちを調べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "作り字の中には、日本の文化や自然を反映したものが多く見られる。",
              "citation": {
                "source": "幻辭AI",
