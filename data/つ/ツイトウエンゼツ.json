        "examples": {
          "standard": [
            {
              "text": "大統領は、前首相の功績を称える追悼演説を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の追悼演説は、故人への深い敬愛の念に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その式典では、著名な作家が追悼演説を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "お喋舌の好きな男で、どんな腹の空いた時でも追悼演説を頼まれると、直ぐ出掛けて往つて、宮川氏のやうに悲しさうな詞を料理場の油虫よりも沢山並べ立てて呉れる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、先生の声は沈痛なもので、突然、クレマンソーの追悼演説を始めたのである。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
