        "examples": {
          "standard": [
            {
              "text": "正月には、搗き臼と杵で餅つきをするのが恒例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの家には、大きな搗き臼が置いてあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "搗き臼で米を搗くと、独特の風味が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どういふものか、さつきうす暗がりで見たぼんやりした小さい白い時計の文字盤が頭の中で見えてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに娘をもつ親の習いで、化物ばなしの話の本の中にある赤坊の頭をかじって居るような顔をした娘でも花見だの紅葉見なんかのまっさきに立ててつきうすの歩くような後から黒骨の扇であおぎながら行くのは可愛いいのを通りすぎておかしいほどだ。",
              "citation": {
                "source": "元禄時代小説第一巻「本朝二十不孝」ぬきほ（言文一致訳）",
                "author": "井原西鶴",
                "note": "青空文庫"
              }
            }
          ]
        }
