        "examples": {
          "standard": [
            {
              "text": "彼は昔から土弄りが好きで、週末はいつも庭で過ごしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、よく裏山で土弄りをして秘密基地を作っていたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい花壇を作るため、朝からずっと土弄りをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしなまじっか学問なんか噛りちらすより、土弄りでもしていた方がよかったかも知れんよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭お島がつれられて行ったときに、彼は麦や空豆の作られた山畑の中に、熱い日に照されて土弄りをしていたが、無智な顔をして畑から出て来る汚いその姿を見たときには、お島は慄然とするほど厭であった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり土弄りをして暮しているじゃないか」「ふむ、誰がその親のところへ、籍を入れてくれろと頼みに行ったんだ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
