        "examples": {
          "standard": [
            {
              "text": "チャンスを活かせず三者凡退に終わったが、次の回こそは必ず得点してほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ドラマが最高の盛り上がりで終わったので、早く次の回が見たくて仕方がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次の回では、いよいよ主人公と宿敵が直接対決するシーンが描かれる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――読むと云つても、わたしはそれが非常にのろくて、断じて選り好みや怠惰をきめ込んでゐるわけはないのであるが、月々の主なる雑誌の半分も読めぬうちに、やがて次の月となり、読み残したものは次の回へなどゝ断つたものゝまるで借金なんてものが容易に返済出来ぬと同様に、怕るべき言ひわけに化してしまつたのだ。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして次の回に入った時、ヤッペの顔には、今度こそ断然たる行動に出るだろうとみんな期待したほど、ありありと決心の色が現われていた。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            }
          ]
        }
