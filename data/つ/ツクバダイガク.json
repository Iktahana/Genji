        "examples": {
          "standard": [
            {
              "text": "筑波大学の広大なキャンパスを移動するために、学生たちは色とりどりの自転車を愛用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「筑波大学の二次試験、試験会場の教室が多すぎて危うく迷子になりそうになったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "筑波大学は数多くのメダリストを輩出しており、スポーツ科学の分野でも世界的に有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東京大学が東京教育大学（あの気味の悪い筑波大学が正気を失う前の姿だ）と共に入試の中止に追い込まれた一九六九年から、ちょうど十年が過ぎたころのことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六七（昭和四十二）年に筑波大学の前身にあたる東京教育大学理学部の応用数理学科を卒業した桜井にとって、前橋高校は初めての赴任先だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
