        "examples": {
          "standard": [
            {
              "text": "試験前になると、毎日夜遅くまで机に向かうようになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "集中して勉強するために、静かな図書館の机に向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、大学のレポート作成のため、朝から晩まで机に向かっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "病院から帰って来ると、直ぐ机に向かう。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから土曜の夜が終り、時計の針が一時を過ぎると、私は機械のように机に向かうことにきめた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
