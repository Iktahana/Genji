[
  {
    "uuid": "2b95e63b-b2bf-5d29-bb2f-87bc728d6349",
    "entry": "突っ張る",
    "reading": {
      "primary": "つっぱる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
