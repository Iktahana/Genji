        "examples": {
          "standard": [
            {
              "text": "雨上がりの森で、形が面白い土栗を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "土栗は湿気を感知すると、星のように開く性質がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、土栗の胞子を飛ばして遊んだ記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "またなお中国に土児、一名ハ土栗子、新鄭山野ノ中ニ出ヅ、細茎ハ蔓ヲ延テ生ズ、葉ハ、三葉毎ニ一処ニ攅生ス、根ハ土瓜児根ニ似テ微シク団ク、味ハ甜シ、救飢ニシ根ヲ採リ煮熟シテ之レヲ食フ」（漢文）である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電報用紙、使ひかけの書簡箋、手すき紙の角封筒がすこし、鏡の割れたのと香水の空壜、それに、去年の夏裏の崖つぷちで拾つた土栗といふ星形の黒く乾いた茸、これは幾島に名前を訊ねようと思つて持つて帰つたのである。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
