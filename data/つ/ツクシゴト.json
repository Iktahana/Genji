        "examples": {
          "standard": [
            {
              "text": "筑紫箏の伝統的な奏法を学ぶため、福岡に住む師匠のもとに弟子入りした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雅楽の流れを汲む筑紫箏の音色は、どこか厳かで気品がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は筑紫箏の流祖である諸田賢順の足跡を、古文書を読み解きながら熱心に調べている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
