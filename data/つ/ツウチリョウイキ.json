        "examples": {
          "standard": [
            {
              "text": "Windowsの画面右下にある通知領域に、ウイルス対策ソフトのアップデート通知が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "使わないソフトのアイコンが通知領域に溜まって邪魔なので、表示設定を整理した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "通知領域にあるスピーカーアイコンをクリックして、会議前に音量をゼロにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
