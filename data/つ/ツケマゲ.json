        "examples": {
          "standard": [
            {
              "text": "日本髪を結うには、しばしば付け髷が用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞妓さんは、華やかな付け髷で頭を飾る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代劇の撮影で、俳優は重い付け髷をつけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "言わば白粉ははげ付け髷はとれた世にもあさましい老女の化粧を白昼烈日のもとにさらしたようなものであったのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪を合総に取り上げた撫付け髷、品も威もある風貌、いわば幾とせの霜を経た梅の古木のおもかげでこの玄鶯院と名乗る老翁、どうもただの隠者とは受け取れない。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あっしの真物の髷は髱の中へ突っ込んで、叔母さんから鬘の古いのを貰って、付け髷を拵えて頭の上へ載っけて行きましたよ、――遉に曲者も偽物の髷とは気が付かなかった」「ハッハッハッ、そいつは上出来だ」　平次も思わず笑ってしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "付け髷でも用意したんですか」「そんな間抜けたものを用意するものか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "髷切り",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
