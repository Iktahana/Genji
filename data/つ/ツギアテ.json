        "examples": {
          "standard": [
            {
              "text": "昔の人は、ボロボロになった服に継ぎ当てをして、大切に長く着続けたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のジャケットの肘には、スエードの継ぎ当てが施されていて、とてもお洒落だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "色とりどりの布を継ぎ当てして作ったキルトは、温かみのある芸術作品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかもその皺だらけな襞や色とりどりな継ぎ当ては画匠の見界によつて都合よく美化されてゐるのだと彼は考へてゐた。",
              "citation": {
                "source": "吸血鬼",
                "author": "ジョン・ポリドリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋を玄關に解いて、つぎあてだらけの洋服に、脚絆をつけてゐる。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
