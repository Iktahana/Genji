        "examples": {
          "standard": [
            {
              "text": "平安時代の貴族の女性は、顔を白く塗り、作り眉を描いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞台メイクでは、役柄に合わせて様々な形の作り眉が描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は毎朝、丁寧に作り眉を描くことから一日を始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時太閤殿下には、作り鬚、作り眉を遊ばし、鉄漿をおつけになりまして、美々しき衣裳をお召しなされ、供奉の人々も皆々派手を競われて、若々しきいでたちをなされましたので、その行列を拝見しようと、大勢の群集が野にも山にも満ち／＼たほどでござりました。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            }
          ]
        }
