        "examples": {
          "standard": [
            {
              "text": "医者に相談して、自分に合った通じ薬を処方してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行中に便秘になったので、薬局で通じ薬を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "通じ薬に頼りすぎるのは良くないと聞いたので、食生活の改善も心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "学生の一人が医者に通じ薬を貰いに行った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼムを噛んだり、宝丹を呑んだり、通じ薬をやったり、内地から持って来た散薬を用いたりする。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
