        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "たくさんの紙片を丁寧に繋ぎ合わせて、一枚の大きな絵を完成させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "途切れた会話をうまく繋ぎ合わせることで、誤解が解消された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い記憶の断片を繋ぎ合わせると、過去の出来事が鮮明に蘇る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "映画の編集過程　たくさんな陰画の堆積の中から有効なものを選び出してそれをいかにつなぎ合わせるかがいわゆるモンタージュの仕事である。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田を踏みにじられた隣りの農場の小作が、壊れた瀬戸物でもつなぎ合わせるように、田の中に入って行って、倒れた稲を起しにかかった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはすべての材料をひとつにつなぎ合わせる触媒のようなものだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていっさいがっさいを、マスタード・マヨネーズがつなぎ合わせる。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中で切れている糸の一筋をもつなぎあわせることはできなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのフィルムを何度繰り返してどうつなぎあわせるかを、僕が最終的に決定した頃に、エマニュエルがいなくなった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
