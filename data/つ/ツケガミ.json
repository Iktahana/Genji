        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "結婚式の披露宴に合わせて、華やかな付け髪でボリュームを出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はショートヘアだが、時折付け髪を使ってロングの髪型を楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "江戸時代の女性たちは、付け髪を駆使して複雑な日本髪を結い上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "着物や帯もずいぶん買って貰った、春秋には白粉を付け髪を結い、美しく着飾って、そのころ杉田屋にながくいた定五郎という老人の背に負われて、巳之吉夫妻といっしょに花を見にゆき、秋草を見にいった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に金さんが得意先に出かけて行った時や、何かにつけがみがみ叱りつける彦さんが居ない時など、彼は小僧達と一緒にこっそり薩摩芋を買って食べたりした。",
              "citation": {
                "source": "少年の死",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
