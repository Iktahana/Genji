        "examples": {
          "standard": [
            {
              "text": "スーパーには、新鮮な作り茸が一年中並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "作り茸は、パスタや炒め物など、様々な料理に使える便利な食材だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "採れたての作り茸を使って、美味しいキノコ汁を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、一年ほど経つて、ひよつくりたけと逢つたが、たけは、へんによそよそしくしてゐるので、私にはひどく怨めしかつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
