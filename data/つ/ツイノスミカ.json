        "examples": {
          "standard": [
            {
              "text": "定年退職後は故郷の海が見える高台に家を建て、そこを終の棲家にするつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒を離れ、静かな山里で見つけた古い古民家こそが、私が求めていた終の棲家だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ここが最後の場所になるんだね」と、夫婦で終の棲家となるマンションの鍵を受け取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そうすれば、お父様は終の棲家へ然るべく導かれることでしょう〉彼は門番部屋で彼女宛に一筆書いた、そして文面を隠して、これを女主人に届くようにテレーズに託してくれるように門番に頼んだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "こここそ、ついのすみかだ。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
