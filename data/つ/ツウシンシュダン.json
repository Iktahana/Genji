        "examples": {
          "standard": [
            {
              "text": "現代では、メールやSNSなど、多様な通信手段が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "communication breakdownを防ぐために、複数の通信手段を確保しておくことが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あっ！phoneのbatteryが切れた！他に通信手段はないかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なお博士の発表によれば、この生理電波――と博士はその頭脳使用によっても生ずる電波をそう名付けている――の利用こそ、かの怪人とわれら地球人類の間の意志疎通を図り得る純粋通信手段だと信ずるというのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説の仕立てでは、月面上の通信手段として地中通信が利用されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によって奇抜な「人間豹」の通信手段であった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
