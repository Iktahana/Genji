        "examples": {
          "standard": [
            {
              "text": "人気のシリーズなので、出版社が急遽、追刊を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "限定版の追刊が決定し、ファンは歓喜した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この専門書は、最新の情報を加えた追刊が出る予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そのほかのことは、こいついかんとなつたら、その場で、なんの躊躇もなく、ひらり、ひらりだ。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
