        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は疲れているのに、客の前ではいつも作り笑顔を絶やさない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作り笑顔の裏には、隠された悲しみがあるように見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司の無理な要求に、部下たちは作り笑顔で応じるしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しまいには「ウウウ」と云いながらも私の作り笑顔に苦しい上眼を張ろうとします。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ、おどろいた」　博士は、急に作り笑顔になって、「全くあぶないところだから、いつも足下に気をつけていたまえ」「はあ、ありがとうございます。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のような愚鈍は、所詮、死が最善の解決だなどと思って……」　そういう淋しげな、そして、蒼白い彼の作り笑顔を見て、法印は礼拝するような敬虔な面持ちをもって、「それが範宴どのの尊いところだと私は思う。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "作り笑顔のすべを学んではいたが、心は重く、襲い来る革命の陰におびえ、夜は眠れなかった。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
