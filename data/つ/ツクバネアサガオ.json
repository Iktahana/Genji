          "standard": [
            {
              "text": "玄関横の花壇に植えた衝羽根朝顔、いわゆるペチュニアが、鮮やかな紫色の花を次々と咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「衝羽根朝顔は長雨に当たると花が傷みやすいから、軒下に移してあげたほうがいいわね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商店街のプランターから溢れんばかりに咲き誇る衝羽根朝顔が、道行く人の目を楽しませている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "丈なす薔薇、色鮮やかな衝羽根朝顔、小さな淡紅色の花をつけた見上げるような莨の叢立ち、薄荷、孔雀草、凌霄葉蓮、それから罌粟。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            }
          ]
        }
