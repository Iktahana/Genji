        "examples": {
          "standard": [
            {
              "text": "友人が「あのスパイ映画、経済スパイがテーマで面白かったよ！」と言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "産業技術の情報を狙う経済スパイの活動が活発化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は経済スパイから国の重要な技術を守るため、対策を強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "横浜の外人たちは、ソヴエットの経済スパイだろう、なんて言っていますわ……さっきのウラニウムのことですけど、輸出禁止の法律がないのをいいことにして、日本のウラン鉱の標本がさかんにソヴエット方面へ流れているんだそうですね……ヤマさん、あなたあたりがシテになって、あれこれとなすっているんじゃ、ありません？",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムステルダムでもアントワープでもいろいろ奔走してみたんだが、御承知の通りヨーロッパには経済スパイがウヨウヨしていて危なくって手が出せない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
