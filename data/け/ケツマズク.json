    "definitions": [
      {
        "index": 1,
        "gloss": "to stumble (over)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
