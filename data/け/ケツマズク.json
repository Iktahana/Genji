        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あと一歩のところで蹴躓き、目標達成はならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な商談で蹴躓き、契約を逃してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての海外出張で、言葉の壁に蹴躓いてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
