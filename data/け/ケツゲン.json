        "examples": {
          "standard": [
            {
              "text": "プレゼンテーションの最後に、簡潔な結言を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の論文の結言は、今後の研究の方向性を示唆していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結言として、私たちは協力することの重要性を強調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "結言「マルクス」ト「クロポトキン」トヲ墨守スル者ハ革命論ニ於テ羅馬法皇ヲ奉戴セントスル自己矛盾ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "結言　更に一般の場合、物その物の本来の使途以外に、此の白銅貨の如く科学的性能を様々に生かして用いられるものは色々とあると思うが、これが調査と研究とは、けだし文化史的にも科学史的にも興味のあることと信ずる。",
              "citation": {
                "source": "白銅貨の効用",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、余が偶然論の結言なり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
