        "examples": {
          "standard": [
            {
              "text": "昔の天文学では、精密な軌道計算は熟練した計算者の仕事だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その会社の経理部門には、ベテランの計算者が何人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "統計分析の精度は、データ入力の正確さと計算者の技量に依存する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "純粋経済学の発祥地である十九世紀のフランスがこれに全く無関心であるとしたら、それはブルジョアの狭隘な見解、十九世紀のフランスを、哲学、倫理学、歴史、経済学の知識のない計算者を作り出す領域と、少しの数学的知識もない文学者を出す領域の二つに分けた智的教養、に基いた見解によるのである。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る／＼計算者のペンの下では数字がずん／＼ふえて行つた。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
