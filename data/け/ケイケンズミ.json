        "examples": {
          "standard": [
            {
              "text": "このゲームのチュートリアルは、すでに経験済みのプレイヤーにはスキップできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その企画は過去に失敗しているため、経験済みの課題として慎重に進める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私はあの辛い出来事を経験済みなので、彼の気持ちがよくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんなことは初めてじゃない、善良な女性が犯罪者に人生を縛られ、危機の際にどんなことをやらかすか、経験済みだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種のことは経験済みです。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
