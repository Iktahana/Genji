        "examples": {
          "standard": [
            {
              "text": "家計は、消費活動における最も基本的な経済単位である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業は、生産活動を行う上で重要な経済単位として機能する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国家は、国際経済において最も大きな経済単位と見なされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それ故労働組合運動は経済単位としての英国国家組織のなされる提案に密接な関係をもって従わなければならぬ。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
