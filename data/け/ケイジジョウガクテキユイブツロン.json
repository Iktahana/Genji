        "examples": {
          "standard": [
            {
              "text": "エンゲルスは、デュ―リングの形而上学的唯物論を批判し、弁証法的唯物論を提唱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "形而上学的唯物論は、物質を固定不変なものとして捉える傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の思想は、伝統的な形而上学的唯物論の枠組みを超えようとする試みだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "之に対してフランスの夫は他に対して最も特徴あるものを挙げれば唯物論（ブルジョア的形而上学的唯物論）であった。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義的唯物論は形而上学的唯物論でなければならない。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し唯物論の――乃至哲学一般の――起源から云っても、唯物論はこのような形而上学的唯物論ではなかった。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクス主義に於ける唯物論は、機械的唯物論でもなければ形而上学的唯物論でもない。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
