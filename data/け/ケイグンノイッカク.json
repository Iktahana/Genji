        "examples": {
          "standard": [
            {
              "text": "彼は若くしてその分野の第一人者となり、まさに鶏群の一鶴だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの平凡な才能の中で、彼のひときわ輝く才能は鶏群の一鶴と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パーティー会場で、彼女は鶏群の一鶴のように優雅に佇んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鶏群の一鶴、そんな感じだ。",
              "citation": {
                "source": "I can speak",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くも利権割取を政治家の余得として一進一退を総て金に換えて怪まない今の政界にあっては沼南は実に鶏群の一鶴であった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "家光は大勢の若者の中から、鶏群の一鶴をすぐ見出したらしく、「又十郎に起たせい。",
              "citation": {
                "source": "柳生月影抄",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
