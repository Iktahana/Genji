        "examples": {
          "standard": [
            {
              "text": "消費者の選択は、自由な経済行為の代表的な例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "すべての経済行為には、何らかの目的がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "倫理的な視点から、特定の経済行為の是非が議論されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "衣食の必要がありながら、また、どうにかして実現し得る労働の能力と機会とを持っていながら、凡て母の仕事に匹敵する精神的生活者が、心的にも体的にも経済行為を取らずに、唯だ専ら精神的生活者であるという功労を以て国家の俸給に衣食したいと要求したら、山田さんはそれを是認されるでしょうか。",
              "citation": {
                "source": "平塚・山川・山田三女史に答う",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって経済行為に対する道徳的態度は昔のように簡単に行くまい。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず十七世紀以来の経済行為が何より自由の意識の実際的な地盤であった。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
