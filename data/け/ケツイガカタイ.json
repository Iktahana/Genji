        "examples": {
          "standard": [
            {
              "text": "彼は一度決めたことは絶対に曲げない、決意が固い人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はトップを目指すという決意が固く、毎日練習に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度決意が固いと、周りの意見は耳に入らなくなることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの陣に、弟の孔明が参加していないことも、いかに玄徳の決意が固いものであるかを証拠だてていると思った。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
