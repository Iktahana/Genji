        "examples": {
          "standard": [
            {
              "text": "日々の生活には、経験則に頼る場面が多々ある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "火を使う際は、経験則に基づいて安全に配慮することが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の経営は、長年の経験則によって裏打ちされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "身内の論議ではＰＣ―８８０１の路線継承を主張する役割をになった浜田は、過去の経験則に沿った唯一実現可能性のあるプランとしてオフィスコンピューターの超小型版を推す声が勢いを増す中で、渡辺和也の断言が芽吹かせた懸念にこだわっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カナカ族だけはバカげた経験則のたぐいで本能と忠告に頼ることができよう。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事は鼻が効くけど、まさかこの女が片棒を担ぐなど思いもしなかったし、更に今までのフェンウィックの経験則から、ヴィラがお尋ね者を隠す理由が無い。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
