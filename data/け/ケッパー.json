        "examples": {
          "standard": [
            {
              "text": "サーモンのマリネにケッパーを散らすと、独特の酸味と香りがアクセントになって味が引き締まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「パスタにケッパーを入れるだけで、急に本格的なイタリアンの味になるから不思議だよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スーパーの瓶詰めコーナーで、小粒のケッパーを選んで買い物カゴに入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "○頭全体を水二升、玉胡椒二十粒、ルリーの葉四枚、玉葱三個、塩少しを混合せたる汁に入れて四時間以上湯煮て姿のまま皿へ載せケッパーソースを掛けて食してもよし。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケッパーソースはバター一杯にてメリケン粉一杯をいため牛乳一合にて弛め塩胡椒にて味を付けたる白ソースを作りその中へ瓶詰のケッパーという酸味ある青豆の如きものを二十粒ほど入れて作るなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
