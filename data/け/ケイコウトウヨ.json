        "examples": {
          "standard": [
            {
              "text": "病気の治療のため、薬の経口投与が開始された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は患者に、毎日決まった時間に薬を経口投与するよう指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この薬剤は、経口投与でも高い効果を発揮する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "従ってトリプトファン経口投与はホモゲンチジン酸排泄を増やさないと結論するのが正しいと感じた。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            },
            {
              "text": "分解能力に過剰な負担がかかっているのか完全に失われているにしても、アルカプトン尿者へ経口投与したホモゲンチジン酸は普段の排泄に加えてほぼ定量的に排泄されることを H.Embden は示した。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
