        "examples": {
          "standard": [
            {
              "text": "珪藻土は、高い吸水性を持つため、バスマットによく使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この壁は、調湿効果のある珪藻土で塗られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "畑に珪藻土をまくことで、害虫対策になることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここで七輪と言ったのは、一つの例として挙げただけで、この問題だけならば、珪藻土の利用などで、近年大いに進歩している。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この砂は Kieselguhr（珪藻土）であります。",
              "citation": {
                "source": "湯川博士の受賞を祝す",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
