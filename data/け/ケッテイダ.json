        "examples": {
          "standard": [
            {
              "text": "野党側のスキャンダル追及が決定打となり、現内閣の支持率は過去最低を記録した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼の浮気が決定打になって、ついに離婚を決意したの」と彼女は静かに語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新製品の圧倒的なコストパフォーマンスが、競合他社を市場から追い出す決定打となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三津子その人が充分に強烈で、岬から岬まで彼女が海を泳いで渡ったのは、言うならば決定打だった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
