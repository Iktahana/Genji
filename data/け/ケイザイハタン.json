        "examples": {
          "standard": [
            {
              "text": "バブル崩壊後、日本経済は長期にわたる経済破綻の危機に瀕した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その国は、デフォルト寸前の経済破綻の危機に直面している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経済破綻を防ぐためには、財政の健全化が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしこの努力も第一次大戦後の経済破綻、それに伴っての大失業、より多くの女子の失業等の大波に攫われて、まだ人民のものとしての広い活動を展開していなかった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　号外磁石収縮し始む原因頗る不明なれども対内経済破綻に依る脱獄事件に関聯する所多々有りと見ゆ。",
              "citation": {
                "source": "出版法",
                "author": "李箱",
                "note": "青空文庫"
              }
            }
          ]
        }
