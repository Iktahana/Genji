        "examples": {
          "standard": [
            {
              "text": "七輪を使った後は、炭を消しつぼに入れて消火する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キャンプでは、火の始末のために消しつぼが役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "消しつぼの中で、赤々と燃えていた炭がゆっくりと冷えていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "細かな炭を七輪につぐと、網の目をもるばかりでなく、おこりも悪く、煮物のすんだあとで、残りの火を消しつぼにとることもできません。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮物のときに七輪に残った火は、こうして長火鉢の火を丁寧にいけてあるなら、やはりその上にのせるよりも、すぐに消しつぼにとった方がよい。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "竈の下も風呂の下も毎日灰をかき出し、大きい灰ふるいを用意して必ずそのかきだした灰をふるい、小さな消し炭を消しつぼに入れること。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
