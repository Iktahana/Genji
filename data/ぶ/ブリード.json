        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "印刷時に裁ち落としのズレを防ぐため、データには必ず3mmのブリードを設けてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "写真をページの端まで配置したいので、ブリード部分までしっかり画像を引き伸ばして。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "入稿データにブリードが不足していたため、印刷所から再提出の連絡が来た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
