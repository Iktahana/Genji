[
  {
    "uuid": "73ff6c58-19d6-584c-97a9-abbd67fba66c",
    "entry": "文科系",
    "reading": {
      "primary": "ぶんかけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "humanities, social sciences, and fine arts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は昔から数学や物理が苦手だったので、迷うことなく文学部や法学部などの文科系の学部への進学を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その企業はIT企業でありながら、理系だけでなく文科系出身の学生も積極的に採用し、多様な視点を取り入れようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は文科系の大学出身だが、独学でプログラミングを習得し、今では優秀なシステムエンジニアとして第一線で活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "研究室や実験室に立て籠った私位の年輩の学究達は、文科系統であろうと理科系統であろうと、やがて学位を得ていいような自然の季節であるかも知れない。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門学校では文科系統の学徒が容しゃなく前線へ送り出され、理科系統のものだけが戦力準備者としてのこされた。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人間問題について特に敏感な文科系統の若い人々が、少年期と青年期の境に戦争にさらされたということにさらに大きい混乱の動機がかくされてもいた。",
              "citation": {
                "source": "生きつつある自意識",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府は、文科系統の学生だけを前線に送った。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立大学の昇格申請が最近においてなされたが、注目すべきことは申請の全部が文科系統の学校であることである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国家の大学が国家の名において文科系学生のみを戦線に配置した、そのあと始末を全く省りみないのは、矛盾ではなかろうかと思います。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、私立大学の文科系に籍を置いていた私が個人で所有しうるコンピューターなるものに本当に興味を持ちはじめるのは数年後からなのですが、今こうして振り返ってみると、やはりこの偶然を多少は喜ばせてもらいたい気持ちになります。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術者でない人間、特に私のように文科系出身の人間にとっては、半導体もコンピューターも、ソフトウエアもハードウエアも、ともかく常人には近づけぬコンピューターの国のお話と、ごっちゃに見えてしまいやすい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理部、天文部、英語部、エスペラント部、美術部、写真部、図書部、グリークラブと文科系のクラブの大半に同時に所属し、文化祭の準備に没頭し、コンサートや弁論大会の企画に駆けずり回った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村先生に習ひましたけれども、もう先生の万葉には我々若干あき足らぬ気持を感じた位で、その外には、外の文科系統の文献の専門家は沢山いらつしやいましたが、万葉の専門家は木村先生を除けば一人もをられなかつた。",
              "citation": {
                "source": "真間・蘆屋の昔がたり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別な研究とか実験とかのない文科系統では、それぐらいなことは、おれの能力を以てすれば容易だ。",
              "citation": {
                "source": "失われた半身",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回は文科系統の方々の奮起をのぞむ次第です。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライプチヒには多数のわが留学生がおり、文科系統の者も常に三、四名はいた。",
              "citation": {
                "source": "ヴィルヘルム・ヴント",
                "author": "川合貞一",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直な謙虚な自然科学者に神を信仰する者が多く、実験という面倒な仕事をせずにただ多くの報告を読んでいる文科系の人に唯物無神論者の多いのはこの間の消息を語るものである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "同勢は六人ほどで、文科系統が多かつたけれども、Ｇ君は工科だつた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "関東の播磨人　布佐の播磨屋の息子であった岡田武松君は、文科系統の学科もよく出来た。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "工学部では風船爆弾を製造した実績をかわれてか、軍の要請に応じて新兵器の製作研究に総力をあげ、文科系の各学部の学生たちは多くが軍需工場へ動員されていた。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間は、自分が一番やりたいと思うことを、しなければならん」と言つて、僕が將來文科系統の勉強をしたいと望んだことにも賛成してくれたのです。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
