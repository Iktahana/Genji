    "definitions": [
      {
        "index": 1,
        "gloss": "cultural",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はスポーツをするよりも本を読んだり絵を描いたりするのが好きで、高校では迷わず文化系の部活である美術部に入部した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "体育会系のノリが苦手な私にとって、静かな環境で自分のペースで活動できる文化系のサークルは居心地が良かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "文化系のクラブ活動が盛んなその高校では、毎年秋に開催される文化祭のレベルが非常に高いことで地元でも有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "特に教学というカテゴリーが西洋渡来の科学に対抗する代用品として、東洋的乃至日本的な封建文化系統から拾われて来たことに、吾々は注意を払うことが必要だろう。",
              "citation": {
                "source": "ひと吾を公式主義者と呼ぶ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子の方の学校はどうなのか、やはり文化系統はなくなるのかよくわかりませんが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
