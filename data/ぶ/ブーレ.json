        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "軽快なリズムのブーレが流れると、広場に集まった人々は手を取り合って踊り始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バロック時代の組曲には、しばしば舞曲の一つとしてブーレが組み込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はバレエのレッスンで、ブーレのステップを何度も繰り返し練習していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この男はこの船の船医で、ブーレーというミュンヘン出のドクトルであった。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーレー博士が質問するまにまにポツポツと遭難談を初めたものであるが、話が二人の水夫の幽霊のところまで来ると、不思議にもブーレー博士が一層熱心になって、鼻眼鏡をかけ直しかけ直し謹聴してくれた。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーレー博士は厳そかにうなずいた。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしブーレー博士は私と反比例に、沈着いた態度で鼻眼鏡を外した。",
              "citation": {
                "source": "幽霊と推進機",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝは古へはアクワアルブーレエと稱せられた處である。",
              "citation": {
                "source": "温泉雜記",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし諸君は、ころりがコレラ病と言われるようになり、ブーレ踊りがカチューシャ舞踏と言われるようになったからと言って、世界に大変化をきたしたと思ってはいけません。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
