          "standard": [
            {
              "text": "先行きが不透明なＶＵＣＡの時代において、企業には迅速な意思決定が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ＶＵＣＡという言葉が象徴するように、現代のビジネス環境は予測が極めて困難だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "リーダーはＶＵＣＡに対応するため、常に複数のシナリオを用意しておくべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それも、オルガンを入れてブーカ／＼やり、一方では又、仏党の人々が木魚をポク／＼叩いて読経したのだと申しますから、随分、変珍奇であつたであらうと思はれます。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            }
          ]
        }
