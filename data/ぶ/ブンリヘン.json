        "examples": {
          "standard": [
            {
              "text": "慢性骨髄炎が進行し、壊死した骨の一部が分離片となって周囲の組織を刺激していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "整形外科の執刀医は、X線画像で確認された骨の分離片を慎重に摘出しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "傷口から膿とともに小さな分離片が排出され、ついに長引く感染症が治癒に向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "sequestral",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
