        "examples": {
          "standard": [
            {
              "text": "現代の若者にとって、文語文をすらすらと読みこなすのは至難の業かもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "論語の教えを学ぶために、まずは文語文としての構文を丁寧に分解していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その古い石碑に刻まれた文語文の碑文を、拓本をとって調査することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "然れども文語文を作らしめば、一日二十枚なるも難しとせず。",
              "citation": {
                "source": "病中雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病中雑記」の文語文なるも僕にありてはやむを得ざるなり。",
              "citation": {
                "source": "病中雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生の文語文のヘタのせい也）　が正しいのです。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国語に於いても、同樣の考方が採用されたが、それは、文語文と文語文法の教授が主であつたあいだは、それで通用したのであるが、口語法が課せられるやうになつてからは、その趣は、いちじるしく変つて来た。",
              "citation": {
                "source": "国語科学習指導要領試案（文法編）",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代に於ては、口語文が一般に行はれて文語文は甚だ稀にしか用ひられません。",
              "citation": {
                "source": "国語科学習指導要領試案（文法編）",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして中学校に入つて始めて文法を学ぶものは口語文にはかなり親しんで居りますが、文語文には甚だ疎いのであります。",
              "citation": {
                "source": "国語科学習指導要領試案（文法編）",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            },
            {
              "text": "文法科を、講読、作文に奉仕するものと考へることは結構であるが、それは、文語文に対する文語法教授の時代ならばいざ知らず、口語文に対して口語法の教授をすることは、殆ど意味をなさないではないかと。",
              "citation": {
                "source": "国語科学習指導要領試案（文法編）",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
