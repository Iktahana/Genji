        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プログラミング言語のコンパイラを、その言語自身で記述することをブートストラップという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初期の顧客からの収益を再投資し、ブートストラップで着実に会社を成長させてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "統計学において、データの再サンプリングを行うブートストラップ手法は非常に強力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
