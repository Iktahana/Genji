        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ニューヨーク旅行の最大の目的は、本場のブロードウェイで人気のミュージカルを観劇することだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は幼い頃からの夢を叶えるため、ブロードウェイのオーディションに何度も挑戦し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "タイムズスクエアからブロードウェイの劇場街を歩くと、きらびやかなネオンと活気ある雰囲気に圧倒される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その街は狭くて長い通りで、それを歩くのに彼はほとんど一時間近くかかったが、その間に通行人は次第に減って、通常、公園の近くのブロードウェイ12で午ごろ歩いている人の数ほどになった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たち四人は、牛の背中にのって、ニューヨーク市のブロードウェイを通っているぞ」「牛の背中にのって……」　ネッドが目をまるくした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今、午前三時半における新宿のブロードウェイの入口にさしかかったところである。",
              "citation": {
                "source": "ネオン横丁殺人事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから見ると、第五街は素晴らしくきれいに見えたし、ブロードウェイは宮殿のようだった。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにくらべればブロードウェイはしずかでさびれた感があった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の優しいのも道理、このカーマス・ショオはブロードウェイ生粋のレビュー団でも何でもなく、実は上海から香港の間で駆り集めた田舎廻りの寄席芸人の一団で、中には昨日まで大馬路の闇に咲いていたなどという劇しいのもいた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人はバイクを公園に停めて中野ブロードウェイに入り、本屋で立ち読みしたり喫茶店でコーヒーを飲んだりして時間を潰したが、ふとした気まぐれから中野通りを渡ってサンプラザの前を通ると“サイバネティック・スキゾイド”のポスターがたまたま目に入った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブロマンの前で今夜……八時」　ブロードウェイ・マンションのことである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
