        "examples": {
          "standard": [
            {
              "text": "その手紙は少し古めかしい文語調で綴られており、送り主の厳格な人柄が伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近の歌謡曲には珍しく、歌詞に文語調のフレーズが混じっていて耳に残った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゲームのキャラクターが文語調の喋り方をすることで、独特の神秘的な雰囲気が生まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "）しかしながら共に純情風のものであり、詠嘆的文語調の詩である故に、あはせて一册の本にまとめた。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国語というものはもともと口で物をいうことなのに、日本でも、演説になるとたちまち文語調になる。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
