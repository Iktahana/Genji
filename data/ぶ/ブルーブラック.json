        "examples": {
          "standard": [
            {
              "text": "彼は重要な書類にサインする際、必ずお気に入りの万年筆にブルーブラックのインクを入れて使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "真っ黒ではない、どこか深みのあるブルーブラックの髪色が彼女のミステリアスな雰囲気を引き立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "学生時代、ノートをまとめるのによく使っていたのは、目に優しいブルーブラックのボールペンだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "きちんとおかれた赤とブルーブラックのインク。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は冷たく星々はブルーブラックの空に氷点の如く灯っていた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
