        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の書く文章は、いつも文尾に「〜だ」と「〜である」が混在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ドイツ語の動詞が文尾に置かれる規則に、最初はとても戸惑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "疑問文を作るときは、文尾のイントネーションを少し上げるのがコツです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「……まつる」と文尾に始終つく処へ、まつろふの聯想が加つて、自卑の語法となつて来たのだ。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして家を出る時に何だか見つかったような気がしたので、後ろから来るあかりはみな追手のように思われて、二人ともずいぶんびくびくしながら行った。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "折よく傍を自転車にのった酒屋さんが通りかかったから、うちへ知らせてもらったんだけれど、ずいぶんびっくりしたわ。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はわたしたちがこんな質問を出したので、ずいぶんびっくりしたと言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、漁師ははんぶんびくびくしながら、いいました。",
              "citation": {
                "source": "漁師とそのおかみさんの話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
