        "examples": {
          "standard": [
            {
              "text": "アウェイの洗礼として、彼がボールを持つたびに凄まじいブーイングが起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "審判の不可解な判定に対して、観客席からは一斉にブーイングが浴びせられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "不甲斐ないプレーを続ける選手たちに対し、サポーターはブーイングで不満を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして彼がロックビートに乗せて歌いはじめるや、観衆からはブーイングが起こり、彼は舞台を下りざるをえなかったのです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
