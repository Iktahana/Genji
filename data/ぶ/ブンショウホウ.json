        "examples": {
          "standard": [
            {
              "text": "英語と日本語では文章法が根本的に異なるため、直訳すると意味が通じない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生成AIのモデルに、特定の作家の文章法を学習させて模倣文を作らせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "接続詞の使い方が独特なこの作品は、文章法の観点からも非常に興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
