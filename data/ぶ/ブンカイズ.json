        "examples": {
          "standard": [
            {
              "text": "プラモデルの組み立て説明書にある精密な分解図を見ながら、数百個もある細かいパーツを順番に組み上げていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "お客様自身で家具を組み立てていただくため、付属の説明書には部品の構成がわかりやすい分解図を採用しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "エンジンの構造を理解するために、設計部門から取り寄せた立体的な分解図をモニターに映し出して議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "近藤正斎の辺要分解図考巻三に左の記事がある。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ国の文学の世界では、数こそ少ないけれども優秀な数人の人たちが、歴史の上にあらわれた人間の新しい現実を現実としてうけいれ、そこに粗野なものと同時に人間にとってよりよいものを発見しはじめているとき、絵画が、ピカソの最も果敢な精神においてさえ、未開にひかれ、現実の分解図解の方向にばかり向けられている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
