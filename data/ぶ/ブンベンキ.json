        "examples": {
          "standard": [
            {
              "text": "分娩期に入ると、子宮口が徐々に開き始め、胎児が産道を降りてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "看護師が頻繁にバイタルをチェックし、分娩期の進行具合を確認している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "分娩期の初期はまだ会話ができる余裕があったが、次第に痛みが強くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "出てみると近所の家からの取次で、分娩期が五六日後に近づいてゐた妻が、朝Ｎ氏が出て行つた後で急に虫がかぶつて来て、つい今しがた安産した。",
              "citation": {
                "source": "茶話",
                "author": "昭和五（一九三〇）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "分娩期が始まっている。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
