          "standard": [
            {
              "text": "翻訳ソフトの設定で、文章単位ではなく単語単位の置換を指定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文脈を理解するためには、文字ではなく文章単位で内容を追う必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プログラムがテキストを解析する際、改行コードを文章単位の区切りとして認識する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが、ＪＸ用に開発する新しいテキストベースの製品では、文章単位でカタカナも含めて一気に変換してしまう連文節変換まで機能を拡張し、これをＡＴＯＫ３と改名することとした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
