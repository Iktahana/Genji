        "examples": {
          "standard": [
            {
              "text": "整備工場で、古い金属部品の表面にこびりついた頑固なサビを物理的に落とすために、研磨剤を吹き付けるサンドブラスト処理の装置を稼働させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ハリウッドのアクション映画の撮影現場で、迫力あるクライマックスの爆発シーンを撮るために、専門の特効チームにより大規模なブラスト効果が仕掛けられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "旧車のバイクのエンジンのオーバーホールに伴い、シリンダーブロックの蓄積した油汚れをウェットブラストで新品のように徹底的に洗浄した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
