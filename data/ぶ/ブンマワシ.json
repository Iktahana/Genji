        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台が180度回転するぶん回しの演出により、場面転換がスムーズに行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歌舞伎の舞台には、ぶん回しと呼ばれる伝統的な回転機構が備わっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ぶん回しがゆっくりと動き始めると、客席からは感嘆の声が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
