        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は私にとって、親分とも呼べるくらい頼りになる存在だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
