        "examples": {
          "standard": [
            {
              "text": "彼女の書く文には、独特のリズムと情景を思い起こさせる力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は学生時代から文を綴るのが好きで、よく同人誌に短編小説を寄稿していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その手紙の文からは、彼がどれほど故郷を恋しく思っているかが痛いほど伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "the literary arts (as opposed to the military arts)",
        "register": "standard",
