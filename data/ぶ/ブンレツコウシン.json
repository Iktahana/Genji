        "examples": {
          "standard": [
            {
              "text": "観閲式において、陸上自衛隊の隊員たちによる一糸乱れぬ分列行進が披露された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "警察学校の卒業式では、真新しい制服に身を包んだ新人警察官が誇らしげに分列行進を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ブラスバンドの演奏に合わせて、各国の代表選手たちがスタジアムを分列行進していきます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その日、フウバア大統領の前を、颯爽と、分列行進をしていった女子選手達のうちに、あなたのりりしい晴れ姿をちらっと垣間見ました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "分列行進というのが毎週のように行われ、組の先頭にたって行進し、カシラーミギをかけた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
