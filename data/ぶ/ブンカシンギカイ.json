        "examples": {
          "standard": [
            {
              "text": "文化審議会の答申を受けて、新たに三つの伝統芸能が重要無形文化財に指定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今日のニュースでは、文化審議会が国語施策の改善案について議論した内容が報じられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は文化審議会の専門委員として、歴史的建造物の保存と活用に関する提言を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "保護期間七〇年延長への道　保護期間延長については、文化庁の諮問機関である文化審議会著作権分科会で、過去、何度か論議されてきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化審議会著作権分科会における、著作権法改正の論議は、下部に設けられた法制問題小委員会で進められる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "同会と、続く第六回の論議を受けた若干の字句修正を経て、二〇〇五年一月二四日に開かれた親委員会の文化審議会著作権分科会第一四回に、「著作権法に関する今後の検討課題」が報告された。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
