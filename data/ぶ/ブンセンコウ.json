        "examples": {
          "standard": [
            {
              "text": "祖父は昔、新聞社で腕利きの文選工として働き、ものすごいスピードで活字を拾っていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "デジタル化の波に押され、熟練の文選工たちが次々と印刷の現場から姿を消していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新人の文選工は、頻繁に使う漢字の配置を覚えるだけでも一苦労だったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この原稿を受取った私の友人は、いつもの通り内容をロクに見ないまま文選工場へまわすに違いない。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "活字を使っていた時代には、文選工と呼ばれる印刷所のスタッフが原稿を片手に一字一字活字を拾い、行と行の間に詰め物をはさみながら頁を組んでいきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野は三吉より三つ年上で、郵便配達夫、煙草職工、中年から文選工になった男で、小学三年までで、図書館で独学し、大正七年の米暴動の年に、津田や三吉をひきいて「熊本文芸思想青年会」を独自に起した、地方には珍らしい人物であった。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "「安雄ッ、武ちゃん――」　よばれた二人の文選工が、まだよごれ手のまま、ボンヤリはいってくると、「お前たち、もう今夜はいいから、ポスターをてつだいなさい」　と、あごでしゃくった。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
