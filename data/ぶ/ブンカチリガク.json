        "examples": {
          "standard": [
            {
              "text": "文化地理学のゼミでは、特定の地域における宗教施設の配置と街路の形成プロセスの関係を調査している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風土や気候がその土地独自の食文化にどのような影響を与えているかを、文化地理学の観点から分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は文化地理学の第一人者として、国境線が人々のアイデンティティや空間認識に与える影響を研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも文化地理学の方ではもっと大きい問題かもしれない。",
              "citation": {
                "source": "『西遊記』の夢",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそういうことは従来も度々いわれているので、別に耳新しいことでもないが、ただある量を一つの要素として採用するよりも、その時間的あるいは空間的の変化を見た方が、現象のさらに詳しい説明が出来るという良い例が、文化地理学にも気象学にも見られるという点は、一部の読者には興味があることであろう。",
              "citation": {
                "source": "清々しさの研究の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
