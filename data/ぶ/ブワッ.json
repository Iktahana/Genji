        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "オーブンの扉を開けた瞬間、焼き立てのパンの香ばしい匂いがぶわっと顔に広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "突風が吹いて、積もっていた落ち葉が空中にぶわっと舞い上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "トンネルを抜けると、目の前に青い海がぶわっと開けて思わず歓声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すると、ぶわっとすべての花が咲いて、妖精たちが小さなおきさきと王さまのところへやって来ました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
