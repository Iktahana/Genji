        "examples": {
          "standard": [
            {
              "text": "紛争地帯において、敵対する民族のアイデンティティを奪うために歴史的なモスクや図書館が意図的に破壊される文化殺戮が国際社会から強く非難されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "武装勢力が占領した古代遺跡をダイナマイトで爆破する映像は、人類の共通財産に対する許しがたい文化殺戮として世界中に衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "過去の歴史において、征服者が被征服者の言語や宗教を弾圧し、固有の伝統を根絶やしにしようとする文化殺戮は幾度となく繰り返されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "戦争中の日本の文化殺戮の実状や、日本の文化人が歴史的に自主性を欠いていることについての反省は、日本の近代史の見直しと共に真摯な課題となって来ている。",
              "citation": {
                "source": "作家への新風",
                "author": "――著作家組合にふれて――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
