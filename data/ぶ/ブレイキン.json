        "examples": {
          "standard": [
            {
              "text": "パリオリンピックの新競技としてブレイキンが追加されたことで、多くの若者がダンススクールに通い始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "駅前の広場でブレイキンの練習をしているグループがいて、通行人が立ち止まって見入っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女はブレイキンの大会で優勝するために、毎日何時間もパワームーブの練習に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この式を英国教宗にてはホリー・コミュニオンといい、ローマ宗にてはミサといい、非国教宗にてはローズ・サパーといい、あるいはプリマス・ブレズレン宗にてはブレイキング・ブレッドという。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
