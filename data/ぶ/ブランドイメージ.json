        "examples": {
          "standard": [
            {
              "text": "相次ぐ不祥事の報道により、その食品会社のブランドイメージは大きく失墜した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "若年層へのブランドイメージを向上させるため、人気アイドルを新CMに起用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "高級感と信頼性というブランドイメージを崩さないよう、出店する立地は厳選している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "企業のコンピューター市場で絶対的なブランドイメージを誇るＩＢＭがビジネス市場に向けて送り出すマシンなら、なおさら一六ビット化は不可避に思えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーの書籍のブランドイメージを大いに高めている『アラン・ケイ』、『ワークステーション原典』といった仕事では同社の渡辺俊雄氏が大いに力をふるって、困難なプロジェクトをゴールまで引っ張ってきている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが八ビットを制したデジタルリサーチは、いまだに高いブランドイメージを備えていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
