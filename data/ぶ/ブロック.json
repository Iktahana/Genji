        "examples": {
          "standard": [
            {
              "text": "突然の雷雨で、道路は倒木によるブロックとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自身のキャリアにおける様々なブロックを乗り越えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このソフトウェアのアップデートは、古いバージョンとの互換性のブロックを生じさせている。",
              "citation": {
                "source": "幻辭AI",
