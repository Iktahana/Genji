        "examples": {
          "standard": [
            {
              "text": "予定外の工事が、交通のブロックを引き起こし、大渋滞となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の執拗な質問は、会議の進行におけるブロックとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突如現れた障害物が、我々の進路におけるブロックとなった。",
