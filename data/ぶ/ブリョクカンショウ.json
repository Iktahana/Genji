        "examples": {
          "standard": [
            {
              "text": "領土問題がエスカレートし、武力干渉（ぶりょくかんしょう）の危機が迫っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "他国の内政への武力干渉（ぶりょくかんしょう）は、国際法に違反する行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「武力干渉（ぶりょくかんしょう）ではなく、平和的な対話で解決すべきだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、何分、その地方は、もう伊太利軍の支配下にあるのですから、公然武力干渉が行はれます。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
