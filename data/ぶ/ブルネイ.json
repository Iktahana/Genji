        "examples": {
          "standard": [
            {
              "text": "東南アジアのブルネイは、豊かな資源に恵まれた小国として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ブルネイのモスクは、黄金のドームが夕日に輝いてとても美しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼は仕事の都合で、来月からブルネイに駐在することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "で三隻のうち最も破損のひどいコンセプションをボホル島で焼き、トゥリニダッドはカルバリョが、ヴィクトリアはゴンサロ・バス・デスピノーザが、指揮を取って、南ミンダナオ島のカガヤン、更に北西パラワン島などを廻り、アラビア人の手引きによって南方ボルネオのブルネイを訪れたりなどした。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行先は、台湾からマラッカに至るまでの諸地方、ブルネイやモルッカの諸島などである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
