        "examples": {
          "standard": [
            {
              "text": "大統領は各界の専門家からなるブレーントラストを組織し、経済対策の助言を求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "創業期から社長を支えてきたブレーントラストが、次期社長の人事について密かに協議している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女はその卓越した分析能力を買われ、政府のブレーントラストの一員に抜擢された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それには、国民を総動員したる所のブレーントラストでなければならぬ。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口が僕と上森・菊田を招き、ロッパブレーントラストを作らうといふ話なのだ、こっちの下心も知らず、無駄な話であるがまあ雑談し、馳走になる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
