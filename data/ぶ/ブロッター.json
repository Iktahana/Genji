        "examples": {
          "standard": [
            {
              "text": "社長室の重厚なマホガニーのデスクには、真鍮製の装飾が施されたブロッターが置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "万年筆で契約書に署名した後、彼はインクが擦れないように素早くブロッターを押し当てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "骨董市で見つけた木製のアンティークなブロッターを、書斎のインテリアとして購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "〔欄外に〕　片春に伊東みやげのきれいなブロッターをあげる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブロッターにつかうために細く截った吸取紙をこの紙の上にのせています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
