        "examples": {
          "standard": [
            {
              "text": "水たまりに足を踏み入れると、ピチャッと水が跳ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "猫が水を飲もうとして、誤って皿を倒し、ピチャッと音を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんがお風呂でピチャッと水遊びをして、楽しそうだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ツェねずみはプイッとはいって、ピチャピチャピチャッと食べて、またプイッと出て来て、それから大風に言いました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、水の上にはね上がっては、ピチャッ、ピチャッと、音をたてました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
