          "standard": [
            {
              "text": "古い変圧器の中にPCBが含まれていることが判明し、特別管理廃棄物として処理された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "PCBは毒性が強く分解されにくいため、環境への流出を厳重に防がなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "過去に起きたPCBによる食中毒事件は、化学物質の安全管理に大きな教訓を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
