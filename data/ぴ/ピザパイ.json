        "examples": {
          "standard": [
            {
              "text": "昔のアメリカ映画に出てくるような、大きなピザパイを一度お腹いっぱい食べてみたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母が古い料理本を見ながら、当時の呼び方で「今日はピザパイよ」と食卓に並べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焼きたてのピザパイからとろりと溶け出すチーズの香りが、部屋中に広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これをピザパイのように八等分する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井は口笛を吹きながら、キュビストのピザパイの外周から、中央の回廊と部屋をつなぐドアの方向に、ひとりでずんずんと入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
