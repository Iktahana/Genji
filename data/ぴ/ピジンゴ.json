        "examples": {
          "standard": [
            {
              "text": "ソロモン諸島では、共通語としてピジン語が広く話されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あれ、なんて言ったの？」と、ラジオから流れるピジン語のニュースに耳を澄ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピジン語を学ぶことで、現地の文化や人々の考え方に一歩近づくことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
