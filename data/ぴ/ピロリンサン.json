        "examples": {
          "standard": [
            {
              "text": "生体内のエネルギー通貨であるATPは、高エネルギーリン酸結合を持つピロリン酸を介して生成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ピロリン酸は、核酸合成や脂肪酸合成など、様々な生化学反応に関与している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歯科治療で、歯石の沈着を抑制するためにピロリン酸が配合された歯磨き粉が使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "欠乏患者は運動をすると血液中のピルビン酸または乳酸が異常に高くなることが知られており、彼のグループはチアミン-ピロリン酸がピルビン酸デカルボキシラーゼの補酵素の役割を果たすことを示した。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
