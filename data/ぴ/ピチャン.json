        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供が水たまりに飛び込み、盛大にぴちゃんと水を跳ね上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お風呂のお湯が、誤って浴槽の外にぴちゃんと飛び出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "洗い物をしていると、水がシンクからぴちゃんと飛び散った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もったいぶって、ぽたんと落ちるのもあるし、せっかちに、痩せたまま落ちるのもあるし、気取って、ぴちゃんと高い音たてて落ちるのもあるし、つまらなそうに、ふわっと風まかせに落ちるのもあるし、――」　Ｋも、私も、くたくたに疲れていた。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
