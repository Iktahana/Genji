        "examples": {
          "standard": [
            {
              "text": "試験が終わった打ち上げに、仲の良い友達を集めて寮の部屋でピザパを開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今週末、うちでピザパしない？」と誘われたので、ワインを一本持って行くことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宅飲みとピザパを同時に開催したら、結局ピザが足りなくなって追加注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これをピザパイのように八等分する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井は口笛を吹きながら、キュビストのピザパイの外周から、中央の回廊と部屋をつなぐドアの方向に、ひとりでずんずんと入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
