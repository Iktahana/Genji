        "examples": {
          "standard": [
            {
              "text": "十年に及ぶ彼らの確執に、ついにピリオドを打つ時が来た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は現役引退を表明し、プロ野球選手としての生活にピリオドを打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このプロジェクトの成功をもって、長い準備期間にピリオドを打つことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アクースティック・ギターのコードが流れるなか、ウッド・ベースが降りてきて、エレキ・ベースがその下降にピリオドを打つ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "富岡との交渉はこれで、一応はピリオドを打つてしまつたと云つてもいゝ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "号外を出すことぐらいに事を欠くものか、何を莫迦な」　どうする、どうすると、さながら娘義太夫の堂摺連のように四方八方から詰め寄られて、さすが警保局長も哀れはかなく見えた時、この騒動にピリオドを打つように、けたたましく卓上電話のベルが鳴り出した。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "働く婦人自身が結婚までとピリオドをうつ気分には、働きそのものの発展性がないこと、独立的生計が営めないこと、めいめいが特殊の技術をもっていないことなどにからんで、ブルジョア婦人雑誌の封建的な現代では、エロティックな結婚病に対するまんせい的な刺戟の害毒があります。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
