          "standard": [
            {
              "text": "彼女は、まとめ髪をピン留めでしっかりと固定していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "美容師さんが、私の髪をピン留めでアレンジしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は、可愛いピン留めがたくさんあったけど、今はあまり見かけなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "カンバスの空いた部分に一枚の紙片がピン留めしてあって、酷く丸まっていた――多分、背景を悪夢のようにおぞましく描き効果を上げるためにピックマンが使っている写真だろうと思った。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
