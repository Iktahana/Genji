        "examples": {
          "standard": [
            {
              "text": "ピーラーを使えば、じゃがいもの皮も薄くスピーディーに剥くことができて効率的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しく買ったピーラーは切れ味が鋭く、キャベツの千切りもプロ並みに仕上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピーラーの先端にある小さな突起を使って、じゃがいもの芽を丁寧にくり抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "専用のピーラーを試してみたこともあるのだが、包丁で切った方が好みに合った。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
