        "examples": {
          "standard": [
            {
              "text": "バターの香りが食欲をそそる、エビピラフをランチに注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "母が作る炊き込みピラフは、野菜がたっぷり入っていて栄養満点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプの夕食で、飯盒を使って本格的なピラフ作りに挑戦した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ポタアジュ、フィレソール、羊肉のピラフ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終って医者へ寄り、旅用の薬を貰ひ、ニューグランドで一人食事、カレースープに、松茸と舌平目のピラフ、ローストビーフ、プディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤山と会ひ、食事、にほひがしなくてうまくない、トマトクリームスープ、ピカタ、ピラフにアスパラガス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老のピラフのやうなものに、スープ（コンソメ）をかけて出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピラフは（芝海老とチキン、マッシュルーム）クリームソース掛け。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
