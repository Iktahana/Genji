    "definitions": [
      {
        "index": 1,
        "gloss": "nee-naw (sound of an emergency vehicle siren)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
