        "examples": {
          "standard": [
            {
              "text": "モーパッサンの『ピエールとジャン』を読み、兄弟間の嫉妬と疑惑が渦巻く心理描写に唸った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遺産相続を巡って崩壊していく家族の姿を、『ピエールとジャン』は淡々と描き出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文学の授業で『ピエールとジャン』が取り上げられ、19世紀フランスのリアリズムについて議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "モーパッサンと云えば、数日前に杉捷夫君の近訳『ピエールとジャン』を白水社から送って来た。",
              "citation": {
                "source": "銷夏漫筆",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はオルランドルフ版の『モーパッサン全集』の中では、デュピュイの挿絵を出色だと昔から思っていたので、杉君訳の『ピエールとジャン』にも原書の挿絵が取入れてあるのを懐しく思った。",
              "citation": {
                "source": "銷夏漫筆",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角オルランドルフ版の『ピエールとジャン』をお持ちの方々は、もう一度その挿絵の巧さを味われんことを。",
              "citation": {
                "source": "銷夏漫筆",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
