        "examples": {
          "standard": [
            {
              "text": "子供たちが凧を揚げて、糸をぴんと張って遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ステージの幕がぴんと張られて、これから始まる劇に期待が高まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、緊張で背筋をぴんと張って、本番に臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "綱が斜にぴんと張ると、伝馬は汽船と同じ速力になって、走りだした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめはほんのちょっとの注意で事足りるが、一ぺん乗り込んだら最期、すべての綱がぴんと張る。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
