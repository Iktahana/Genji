          "standard": [
            {
              "text": "設計図面や仕様書を一元管理するために、PDMを導入して情報共有のスピードを上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "PDMのおかげで、過去の設計データを検索して流用するのが非常に楽になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複数の拠点で開発を進める際、PDMなしでは最新のバージョン管理が維持できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
