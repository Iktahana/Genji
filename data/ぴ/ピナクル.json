        "examples": {
          "standard": [
            {
              "text": "その山頂は、まさにピナクルと呼ぶにふさわしい鋭さで空を貫いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のキャリアは、この受賞をもってまさにピナクルに達したと言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "建築家は、超高層ビルの一番高い部分にピナクルを設計した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三ピッチ目のピナクルをまわる――三年ほど前、初めて、屏風岩の雲稜ルートをのぼった時のことが思い出された。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            }
