        "examples": {
          "standard": [
            {
              "text": "歯車のピッチが正確でないと、スムーズに噛み合わない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このネジのピッチは細かすぎて、手作業での加工が難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "設計図には、各部品のピッチがミリ単位で詳細に記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
