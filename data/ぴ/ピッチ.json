        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マラソンランナーは、一定のピッチで走り続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームはプロジェクトのピッチを上げて、納期に間に合わせようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は自分のピッチを崩さずに、黙々と作業を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは演奏者の右手が高いピッチのピアニッシモに細かく触れているときだった。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらの方がピッチが出ている。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの地下室の古井戸は随分深い上にピッチリと蓋が出来るようになっていて、息抜きがアノ高い煙突の中へ抜け通っているんです。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一人はワイシャツ一つになって体操をしてみたり、駆け足のまねをしてみたり、ピッチャーの様子をしたりしている。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず試みに「炭俵」上巻の初めにある芭蕉｜野坡の合奏を調べてみると、「むめが香にのっと日の出る山路かな」の発句にはじまって、「屏風の陰に見ゆる菓子盆」の揚げ句に終わる芭蕉のパートにはいったいにピッチの高いアクセントの強い句が目に立つ。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして「宵の内はらはらとせし月の雲」（芭）と一転しているのは一見おとなしいようでもあるが、これを次に来る野坡の二句「藪越しはなす秋のさびしき」「御頭へ菊もらわるるめいわくさ」の柔らかく低いピッチに比べると、どうしても違った積極的主動的の音色を思わせる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年｜小田原の浜べで大波の日にヘルムホルツの共鳴器を耳に当て波音の分析を試みたことがあったが、かなりピッチの高い共鳴器で聞くとチリチリチリといったように一秒間に十回二十回ぐらいの割合で断続する轢音が聞こえる、それがいくらかこの蝗群の羽音に似通っているのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が姫君を診察するとき、心臓の鼓動をかたどるチンパニの音、脈搏を擬する弦楽器のピッチカットもそんなにわざとらしくない。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一進一退のピッチは軈て矢を射るよりも速くなっても、自分には同じ水の上に松浦の艇と自分の艇とが一二メートルずつ競り合っているに過ぎない感じだ。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺の木綿のピッチリした長股引を、芝居の鳶の者が、はいているようですけれど、あれを欲しいと思いました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小走りの速度がむす子を追うときのピッチと同じほどになると、不思議にむす子を追うときの焦々した嬉しさがこみ上げて来て、かの女は眼に薄い涙を浮べた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピッチピッチ、チャップチャップ、ランランラン、　ピッチピッチ、チャップチャップ、ランランラン、　あ、あ、牧舎が見えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ふらふらと洗面台のほうに行って、ピッチャーの水をなみなみと陶器製の洗面盤にあけて、ずっぷりひたした手ぬぐいをゆるく絞って、ひやっとするのを構わず、胸をあけて、それを乳房と乳房との間にぐっとあてがってみた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま三人の話をききつづけるのは、盗み聞きのような気がして、慶一は意識してピッチをあげて口を開いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志が泳ぐすがたを見るのは、べつに今夜がはじめてというわけではないが、月明りのせいか、あるいは静寂のせいか、リズミカルなピッチに魅いられたように、慶一は立ちつくした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "』」　それとわかるように、高志は声のピッチをさげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いままできいたことがなかったけど、あれはどうしてだったんだ、正確なところ」「なんの話だ」「どうして、いきなり出ていったんだよ」　突然、かなり近いところから、複数の車のイグゾーストと、タイヤがきしむ音がきこえ、メロディーフォンがいいかげんなピッチで騒ぎたてた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一期生会宴会部長として、みなさんにお知らせがあります」　山崎の声は、とうてい、お願いをするようなピッチではなく、脅迫にきこえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃校同然じゃないか」　最後のところにきて、慶一の声は一気にピッチがさがり、山崎の怒りを溶かした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "終わったら、ヘッケルとジャッケルのために飲みましょう」　ワラは、いつもより声のピッチをあげ、山崎をなぐさめ、あらかじめ、高志と慶一が拒絶する道をふさいだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉田工業は、臨時工の若干を本工に直すかも知れないという噂さで、最後のピッチを挙げていた。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前のピッチングもあれじゃだめだ。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし進んでゆくほどに、その急ピッチの音楽浴が二人の脳髄を次第々々に蒸していった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の靴は床をハイ・ピッチで叩きつづけている。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムがしきりにピッチをきざんでいる。",
              "citation": {
                "source": "宇宙女囚第一号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女のために己は蒸溜器の底に日の目をも見ずに、かたく、くらく、つめたく、こびりついて居るピッチのようにしてでも生きて居なければならない」　男は心にそう思って自分を命にかけて思って居る、何も彼もささげつくした女の名をこころでよんで見た。",
              "citation": {
                "source": "死に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
