    "definitions": [
      {
        "index": 1,
        "gloss": "private message",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "詳細な打ち合わせが必要ですので、後ほど私の個人アカウント宛てにＰＭをください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ＳＮＳのコメント欄で話すのは憚られるため、続きはＰＭでやり取りしましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "知らない相手から突然ＰＭが届いたが、内容を確認したら昔の友人からの連絡だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しばらくして、フォークソングの人気を押し上げたＰＰＭ（ピーター・ポール＆マリー）というグループを案内役にボブ・ディランを聞き始め、そこからピート・シーガー、ウッディー・ガスリーとさかのぼっていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "首吊りの話」　柾生は、ブラザーズ・フォアの〈｜七つの水仙〉と、ＰＰＭの〈パフ〉も好きな曲にあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオが「アット・ザ・トーン、４ＰＭ」と時刻を知らせる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもめげず、逆ＰＰＭとでもいうべき構成の、郁子・知子＆柾生は、〈サムタイム・ラヴィン〉を最後まで歌いきった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今一つ、話の序に、君が嘸聞きたがっているだろうと思う、例の新聞広告、とだしぬけに言ったのではわかるまいが、今から一ヶ月半ほど前に、都下の主な新聞の三行広告欄へあらわれた不思議な広告ＰＭｂｔＤＫの種明しをもしようと思う。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると其処には、ＰＭｂｔＤＫと書かれてあった。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＭｂｔＤＫとは、別に暗号でも何でもなく、Prof. Mohri bows to Dr. Kario.の最初の一字ずつをとったのだ。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その巴里が、２・３０ＰＭのブウルジェが、ふたたび「社会」が人性が生活が、いまぐんぐん機の下に盛れあぶってきている。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "電電公社通信研究所の依頼を受け、日本電気は音の信号に応じてパルスの位置をずらすＰＰＭ（パルス・フェーズ・モジュレーション）と呼ばれる技術を用いた通信装置の開発を進めていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客の反応はひどく否定的で、ピーター・ヤロー（ＰＰＭのひとり）のとりなしでギターをアクースティックにかえ、ディランは泣きながら『すべては終った、ベイビー・ブルー』をうたわなければならなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
