          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本のＰＭが外遊先で首脳会談を行い、経済協力に関する共同声明を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "次期ＰＭには誰が相応しいかという世論調査の結果を、各局が速報で伝えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ＰＭによる記者会見が開かれ、物価高騰に対する新たな経済対策の骨子が示された。",
              "citation": {
                "source": "幻辭AI",
