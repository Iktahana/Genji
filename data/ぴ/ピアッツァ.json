        "examples": {
          "standard": [
            {
              "text": "イタリアの古い町にあるピアッツァで、噴水の音を聴きながら朝のカフェラテをゆっくりと楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末になると、町の中心にあるピアッツァには移動式の露店が立ち並び、多くの市民で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "名作映画のロケ地としても知られるそのピアッツァは、世界中から観光客が訪れるフォトスポットだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ルガノ・チェントラーレから、ピアッツァ・ジアルディノ Pazza Giardino の緑の蔭を通りぬけて、カムポ・マルツィヨ Campo Marzio の方までうろついた。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
