          "standard": [
            {
              "text": "クライマーは、岩壁にピトンを打ち込みながら慎重に登っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この垂直の壁を登るには、複数のピトンを使って支点を作る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古びたピトンが岩肌に突き刺さっており、かつての登山家の痕跡が伺えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私達の仲間にピトンという傴僂の若者がありましたが、ムリオに買収されたと見えて、或晩町の料理屋へ私を誘って行きました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その室へ私を押し入れると、ピトンは逃げて行って了いました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
