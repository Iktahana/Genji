        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "レコードプレーヤーのピックアップが古くなると、音が悪くなることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいピックアップに交換したら、レコードの音がクリアになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はレコードの溝を正確に読み取るピックアップの性能を重視している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 4,
        "gloss": "pickup (truck)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
