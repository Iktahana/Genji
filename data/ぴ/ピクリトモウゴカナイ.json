        "examples": {
          "standard": [
            {
              "text": "森の中で野生のシカに出くわしたが、向こうはこちらを警戒してピクリとも動かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "集中して獲物を狙うクモは、巣の中央で石像のようにピクリとも動かずにいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "授業中に居眠りをしている彼は、先生が近づいてきてもピクリとも動かないほど深く眠っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "が、相手は気味の悪いほど、冷静にピクリとも動かない。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……）花岡　（その佐山の始終の姿を、残忍なしつこさで注視していたが、たおれた佐山がピクリとも動かないのをしばらく見ていてから、歯をむき出して村子をかえり見る）……見ろ！",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンはピクリとも動かない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
