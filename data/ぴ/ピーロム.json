        "examples": {
          "standard": [
            {
              "text": "専用の装置を使って、開発したプログラムをＰＲＯＭに一括で書き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ＰＲＯＭライターを使用して、チップにデータを書き込む作業を慎重に進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一度書き込むと内容を消去できないタイプのＰＲＯＭを、制御基板に実装した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方ＥＰＲＯＭ（Erasable Programable ROM）と呼ばれる特殊なタイプなら、いったん書き込んだ情報を紫外線を照射するなどの処置を施して消してから、再度新しい内容を書き込むことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コストで比較すれば、ＥＰＲＯＭはマスクＲＯＭに比べて大幅に高くなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「なにが起きるか分からない」との古山の意見を入れて、取りあえず初期の出荷分はＥＰＲＯＭで臨み、これ以上大きな問題は起こらないと見極めがついた時点でマスクＲＯＭに切り替えるという方針が採用された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが増設ボード化とＥＰＲＯＭという二重の保険をかけて古山が取り組んだ賽の河原の石積みのゴールは、この時点でもまだ先が見えなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
