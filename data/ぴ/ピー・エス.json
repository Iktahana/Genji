        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "マンションの共用部にあるＰＳ内には、各住戸の水道メーターや配管が収められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "設計図を確認すると、キッチンの背面にＰＳが配置されているのが分かる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定期点検のためにＰＳの扉を開けて、ガスの配管に漏れがないかチェックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
