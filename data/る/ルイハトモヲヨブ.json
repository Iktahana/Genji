        "examples": {
          "standard": [
            {
              "text": "「あの子たちがいつも一緒に楽しそうにしているのを見ると、まさに類は友を呼ぶだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ボランティア活動を通じて意気投合し、類は友を呼ぶという言葉を改めて実感した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "類は友を呼ぶと言うし、自分を磨き続ければ自然と素敵な仲間が集まってくるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その當時、類は友を呼ぶといふ諺のやうに、一つの寶石が他の寶石を引き付けたと一般に言はれたものであつた。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "近似性や類は友を呼ぶ風なものであったとはどうしても思われない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――類は友を呼ぶと言うのか、この屈辱感は、もうひとつのちがった屈辱感を、つづけて俺の心に呼びよせていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
