        "examples": {
          "standard": [
            {
              "text": "車内で地図を確認するためにルームランプを点灯させたが、消し忘れてバッテリーが上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夜間のドライブ中、同乗者が足元に落とした鍵を探すためにルームランプをつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "純正のルームランプを明るいLEDに交換したら、夜間の車内が劇的に見やすくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その夜の雨の中でルームランプの明るい車の中にぽっつりといて、もうあなたはきっと眠っていらっしゃると、その刻限（十時すぎ）について考え何だか妙な気がしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふしぎな尾行　原っぱのすみの、暗やみの中に、ヘッドライトも、ルームランプも消した一台の大型自動車が、とまっていました。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
