        "examples": {
          "standard": [
            {
              "text": "「あの読書会に集まるメンバーは皆マニアックで、まさに類をもって集まるという感じだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "類をもって集まると言うし、良き友を得たいなら、まずは自分自身が誠実であるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "共通の志を持つ若者たちが類をもって集まり、新しい社会運動の拠点が形成されていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「類をもって集まる」ということわざは植物にも当てはまるようである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまなら、やれるぞ――と、類をもって集まる浪人どもやら、西国大名の野心家の家臣なども気脈を通じて、ここにいつか、もっともらしい幕府顛覆の盟約書などが、起草されていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
