        "examples": {
          "standard": [
            {
              "text": "人形に針を刺して相手を呪うのは、類感呪術の典型的な一例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "文化人類学の授業で、世界の様々な民族に伝わる類感呪術について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "類感呪術は、似たものは似たものを生むという発想に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ナショナリストの思考法には、もしかすると類感呪術――政敵の像を燃やしてみたり、絵を射撃の標的にしたりといった広く行われる慣習も多分ここから来ている――を信じてでもいるのだろうかと思わせるものがある。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
