        "examples": {
          "standard": [
            {
              "text": "旧約聖書のルツ記は、異邦人の女性ルツの美しい物語を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "日曜学校で、先生がルツ記のあらすじを子供たちに分かりやすく説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ルツ記に描かれる嫁と姑の深い絆には、いつも心を打たれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "第三の「知恵」と呼ばるる部分は、詩篇、箴言、ヨブ記、エレミヤ哀歌、ダニエル書並びに新しい時代に書かれた歴史書（歴代志略、エズラ書、ネヘミヤ記、ルツ記）を含むものであって、紀元前第二世紀終わり乃至第一世紀始めごろにはできあがっていたものと思われる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
