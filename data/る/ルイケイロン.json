        "examples": {
          "standard": [
            {
              "text": "ユングの性格類型論を参考にして、チームメンバーの役割分担を見直すことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "マックス・ウェーバーの支配の類型論は、現代の政治組織を分析する上でも有効だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "言語の類型論を学ぶことで、異なる言語間の共通点や相違点がクリアになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かかる思想の多種多樣の諸形態を歴史の觀點よりして殊に類型論的に取扱ふは興味深き事柄ではあるが、もとより吾々の任務より遠ざかる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Nygren: Eros und Agape. 〔2 Ba:nde〕. は類型論的論究とキリスト教における發展の歴史的敍述とを兼ね備へたものとして、アガペーの觀念に關して最大の貢獻をなした書である。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            }
          ]
        }
