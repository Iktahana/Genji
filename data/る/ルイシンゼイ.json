        "examples": {
          "standard": [
            {
              "text": "一部の経済学者は、資産の極端な集中を防ぐために富裕層への累進税を導入すべきだと主張している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "累進税のシステムは複雑になりがちで、確定申告の際に計算を間違える個人事業主が後を絶たない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "消費税のように一律の税率ではなく、所得に応じた累進税こそが公平な税制だという意見がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "前の年から、ソヴェト政府が累進税で富農の私有財産制への実際上の復帰を統制しはじめた。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
