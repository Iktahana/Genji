        "examples": {
          "standard": [
            {
              "text": "西日を避けるために、窓の外側に木製のルーバーを取り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "浴室のドアには、通気性を良くするためのルーバーが付いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "ルーバーの角度を調節して、部屋に入る光の量をコントロールした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "この頃、若い少年期の青春発動を自分でもたまげるほど驚いた馬鹿にセンチメンタル時代に、連続映画にかわって、まるで春の花のように、けんらんとスクリーンをうずめ出したのは、ユニヴァーサル映画会社のブルーバード映画、バタフライ映画であった。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "春や春、はる南方のローマンス……　と、うたわれた、あのブルーバード映画時代なのである。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "マートル・ゴンザレス、エラ・ホール、プリシラー・デン、リリアン・ギッシュ、ムンロー・サルスベリ、ケーネス・ハーラン、ＥＴＣ、ＥＴＣ、まったく花を競うスター達リンゴの花の散るようなブルーバード映画、僕をたいした不良少年にもならずに救ってくれたのは、もしかするとこのブルーバード映画であったかも知れない。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい何かのものをもって札幌に来た二人は尊敬され乍ら、お祈りをしてイギリス生粋の酸っぱいルーバープに牛乳かけてたべているうちに、日本はこの人々を消耗して、からをイギリスに戻したのでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
