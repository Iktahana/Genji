        "examples": {
          "standard": [
            {
              "text": "天界を追放されたルシフェルは、地獄の王として君臨することになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "そのファンタジーRPGでは、最終ボスとして大天使ルシフェルが立ちはだかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "ルシフェルの反逆は、多くの芸術家たちのインスピレーションの源となってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "併し地獄に降ったダンテが、地心に刺きささったルシフェルの側腹を潜り抜ける時、急に眩暈がして戸迷いをしたというが、之は尤もではないだろうか。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "Lucifer",
        "register": "standard",
        "nuance": null,
