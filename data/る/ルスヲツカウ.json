        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "しつこいセールスマンが来たので、留守を使ってやり過ごすことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "借金の取り立てから逃れるため、彼は一ヶ月以上も留守を使って部屋に引きこもっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "訪問販売のチャイムが鳴ったが、面倒だったので留守を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "で、あたしも、じゃあ、あのお馬鹿さんがまた退屈をさせにやってきたんだわって言って、もう少しで居留守を使うところでしたわ……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "小野さんは先方の感情を害せぬ限りは留守を使う勇気のある男である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一切の面会を拒絶したが、居留守を使う不快に堪えがたくて、できるだけ、旅行にでた。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　訪客を断るにはいろ／＼の手があるが、最も普通に用いられるのは居留守を使うことであろう。",
              "citation": {
                "source": "客ぎらい",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
