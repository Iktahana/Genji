        "examples": {
          "standard": [
            {
              "text": "決裂寸前の外交交渉は、一歩間違えれば全面戦争に繋がりかねない、累卵の危うきにあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "綱渡りのような資金繰りでしのいでいる今の事業は、まさに累卵の危うきを地で行く状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「国家存亡の機において、政府がこの累卵の危うきをどう脱するのか、国民は注視している。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "即ち支那をこの累卵の危うきに救うべく一日の猶予もならぬ時である。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
