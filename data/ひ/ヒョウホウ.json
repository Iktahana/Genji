        "examples": {
          "standard": [
            {
              "text": "南極大陸の氷棚は、地球温暖化の影響で崩壊が進んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "巨大な氷棚が海にせり出し、その先端からは時折氷山が分離する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "氷棚の下には、未知の海洋生物が生息している可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一度ごく短時間着陸したが、これは広い高原を通過した後、偶々氷棚上空で乱気流に巻き込まれ方向舵の調子が悪くなったためだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
