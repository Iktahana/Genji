        "examples": {
          "standard": [
            {
              "text": "友人から、日立製作所の最新技術に関するセミナーに誘われたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この高層ビルは、日立製作所の新しいオフィスらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "日立製作所の株価が、今日のニュースで大きく変動していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "十一月の開所に向けて、日本電気をはじめとして日立製作所、富士通、東芝が開発作業を進めたが、結局間に合ったのは日本電気のＮＥＡＣ―２２０１のみだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに先だってＲＣＡ社との技術提携に踏み切った日立製作所は、提携先の路線にもとづいてＩＢＭ機用に開発されたプログラムをそのまま利用できる互換路線をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日立製作所はモトローラと、６８００に関するセカンドソース契約を結んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
