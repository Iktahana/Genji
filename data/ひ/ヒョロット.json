        "examples": {
          "standard": [
            {
              "text": "しばらく見ないうちに、甥っ子はひょろっと背が伸びて中学生になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ひょろっとした男が、黒いコートの襟を立てて通りを歩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はひょろっと立っているだけで、どこか芸術家のような雰囲気が漂う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その晩の挙動なり、……あの余り……貴方の前じゃけれどもが、風采の上らん、痩せた、薄髯のある、背の屈んだ、こう、突くとひょろひょろっとしそうな、人に口を利くにおどおどする、初心らしい、易っぽい、容子と云うのがじゃね、　人品備わらんですじゃろうが、どうですかね、……きゃッ、きゃッ、きゃッ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやっと思って玄竜が振り返って見れば、入口のところに角帽を目深く被った背のひょろっとして高い大学生が蒼くひきつった顔をして突立っていた。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょろっと手もとへ流れこんだ左膳の体あたり、無造作に持った濡れ燕の柄が、その切っさきを受けとめて、かわりに、足をすくわれたように空に泳いでいるのは、かえってその斬りつけたひとり。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "やせてひょろっと背の高い少年が、邦子は好きではなかった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
