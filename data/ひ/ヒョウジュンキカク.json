        "examples": {
          "standard": [
            {
              "text": "日本独自の標準規格であるJISは、工業製品の品質と安全性を保証している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外へ製品を輸出するためには、現地の標準規格に適合していることを証明する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この充電器はUSBの標準規格に準拠しているため、多くのデバイスで使用可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが親会社のパイオニアが、８ビット・パーソナルコンピューターの標準規格を狙ったＭＳＸプロジェクトに加わったのがきっかけとなって、祝田さんの関与は深まります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ　ＡＴの標準規格とされたのが六四〇×三五〇で十六色のＥＧＡ（エンハンスト・グラフィックス・アダプター）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ＩＥＥＥに設けられた委員会で、アルテアのバスはあらためて定義しなおされるとともに機能を拡張され、Ｓ―１００バスという学会の標準規格として確立された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアに使われ、その後業界標準規格として広く利用されはじめたＳ―１００バスを使ってマシンを自作してみた松田は、担当していた材料実験の制御にこうしたシステムを利用するようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
