        "examples": {
          "standard": [
            {
              "text": "平飼いで育てられた鶏の卵は、味が濃くて美味しいと評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近では、動物福祉の観点から平飼いの養鶏が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "平飼いの豚は、自由に動き回れるためストレスが少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それに対しヤマギシでは、ブロイラーも採卵鶏も、放し飼いに近い「平飼い」にされる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひらがいやこっちから行こう。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
