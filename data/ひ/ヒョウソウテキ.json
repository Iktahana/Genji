        "examples": {
          "standard": [
            {
              "text": "表層的な知識だけで知ったかぶりをすると、専門家との会話ですぐに底が割れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "異文化を理解するためには、衣装や料理といった表層的な特徴だけでなく、その歴史的背景も知る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二人の関係は表層的な付き合いに留まっており、互いの本音を語り合うことはほとんどない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あのやり口が実に露骨で表層的。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品の中にはきわめて象徴的な夢もありますが、もっぱら表層的な内容のみを追って訳したことを明記しておきます。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
