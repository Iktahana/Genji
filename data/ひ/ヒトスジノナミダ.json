        "examples": {
          "standard": [
            {
              "text": "感動的な物語を聞いて、彼女の目から一筋の涙がこぼれ落ちた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悔しさを噛み締めながら、彼の頬には一筋の涙が伝っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "別れ際、母親の目には、子供を案じる一筋の涙が光っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おや、と思ふうちに、一筋の涙がこめかみを流れました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のせいか、一筋の涙痕が頬を伝うて流れているもののように見えますけれども、やはりよく眠っているには睡っているに違いありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母さん、もうそろそろ疼痛時にしないかね」　見ると、素子の顔に一筋の涙が伝い落ちている。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
