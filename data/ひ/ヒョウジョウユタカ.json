          "standard": [
            {
              "text": "彼は表情豊かなので、何を考えているかがすぐに顔に出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台の上で、表情豊かな演技を見せる彼女に観客は釘付けになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "表情豊かな犬を見ていると、言葉はなくても通じ合えている気がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも正当なソナタやシンフォニーのように四楽章から成る場合だと、第一章が通例早いテンポのソナタ形式のもの、第二章がいわゆるスロームーヴメントで表情豊かな唱歌形式のもの、第三章が軽快な舞踏曲のようなもので、往々｜諧謔的なスケルツォが使われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
