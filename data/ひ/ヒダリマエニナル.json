        "examples": {
          "standard": [
            {
              "text": "彼の事業はかつては順調だったが、最近は左前になる一方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このままでは会社が左前になるのは目に見えている、と社員たちは不安に感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「何とかしないと、うちの店も左前になるぞ！」と店主は焦っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一体模写・反映ということは、知識や認識を物理的な鏡の機能に譬えた言葉だが、鏡のどこに譬えたかと云えば、鏡が（平らであって塵がなければ）物をそのままに（左前になることは別として）写すという、その真実さを有つ点に、譬えたのである。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
