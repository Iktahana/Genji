        "examples": {
          "standard": [
            {
              "text": "引っ込み思案な彼も、新しい職場ですっかり人慣れてきたようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最初は緊張していた子犬も、毎日散歩に連れて行かれるうちに人慣れてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "留学当初は戸惑っていたが、次第に人慣れてきて、積極的に交流するようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ファルサリア役の餘波エジプトに及びてかの地の禍ひとなれるをいふ。",
