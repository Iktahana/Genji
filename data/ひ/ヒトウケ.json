        "examples": {
          "standard": [
            {
              "text": "非等時性伝送は、同期信号なしでデータを送受信する方式である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古いモデムでは、非等時性伝送が一般的に使用されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "RS-232Cのようなシリアル通信プロトコルは、非等時性伝送の一例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "素人受けのする奇瀑也。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人受けもよく、親たちにも愛せられていたようでもある。",
              "citation": {
                "source": "父",
                "author": "金子ふみ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから人受けもよく、親達にも愛せられていたようでもある。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鷺はなかなか軽妙にして飛び放れたる芸をなし、和泉もまた鷺のごとし、唯ひとり大蔵は堅実なる芸をなせば素人受けなき方なり。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうとも殺人受け負い業者さ！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが浮世の殺人受け負い業者、云いかえると英雄豪傑だが舵の取り方がうまくないなあ」ヒョイと振り返ると薬草道人、一人のモカへ話しかけた。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
