        "examples": {
          "standard": [
            {
              "text": "ヒト科（ヒトか）に属する動物は、人間だけでなく類人猿も含む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "進化の過程で、ヒト科（ヒトか）の生物は脳が著しく発達した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "分類学上、ヒト科（ヒトか）は霊長目の一部である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ぼくには、その人怖じしない態度が好きだった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "『嘘じゃない、ほんとだよ』　たとえ、少年であっても俺は客だ、という気でいるから、私は人怖じなどしない。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小みどりは、まだおぼこであるとはいえ宴席へ侍るのがしょうばいであるから世の生娘とは違って、大して人怖じはしない。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
