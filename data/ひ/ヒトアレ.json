    "definitions": [
      {
        "index": 1,
        "gloss": "brief storm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜中に突然、窓の外で一荒れあり、雷鳴が轟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "出航後、沖に出るとすぐに海上は一荒れした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天気予報では、午後から一荒れあると伝えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どう見ても一荒れ荒れねば天気は直りそうもなく思われる。",
              "citation": {
                "source": "大雨の前日",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一月には木枯らしが吹き、一荒れごとに淋しい落葉の音もまれに、梢越しにははや雪が見え出してくるし、安曇野の村々には冬篭りの用意ができ、どの家にも暖い炬燵が仕切られてくる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから一荒れ来るからねえ」ラツールが空を見上げた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一荒れ来るかもしれません」　艇長も外に目をやった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩あたりは一荒れ来るかなあなどゝ、まだ船に残つてゐた客は、あがる支度を整へて、甲板へ出て来て、噂しあうた。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワーニャ　いよいよ一荒れくるぞ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりやあ一荒れ来ずばなるまいと、わしなどもさう思ひますよ。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜井君は大谷君親子の言葉を引取つて、いかにもはつきりとした調子で、「一生の願ひとあれば、お登りにならないわけにいかないでせう。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "(a bout of) bad mood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は最近、仕事のストレスで一荒れすることが増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は気分屋で、時々一荒れするが、すぐに元に戻る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家族会議で意見が対立し、一瞬一荒れしそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
