        "examples": {
          "standard": [
            {
              "text": "菓子折りを平包みにして、丁寧な挨拶と共に取引先に手渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風呂敷の平包みは、結び目を作らないので最も格が高いとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大切な着物を、たとう紙ごと大きな風呂敷で平包みにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あるいはまた平包みというのが、風呂敷包みのもとの名のようにいう人もあるが、それもまちがっている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平包みはただ物を平たく包むだけで、これならば支那からくる呉服商人なども持ってあるいている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平包みや服紗包みが前に、なかったら、風呂敷包みということはかんがえ出されなかったろうとまでは言うことができる。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち平包みの布の二隅を引出して、これを紐のかわりにして背に負うもので、これは両腕の上部に力の半分を持たせるから、今までの荷負いのように手を自由に使うことができない。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
