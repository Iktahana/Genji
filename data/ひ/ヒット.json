        "examples": {
          "standard": [
            {
              "text": "この映画は世界中で大ヒットし、続編の制作も決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バットの芯でボールを捉え、快音とともにレフト前ヒットとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「うわー、この曲、めちゃくちゃヒットしてるじゃん！」と友人が興奮気味に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
