        "examples": {
          "standard": [
            {
              "text": "失敗の責任をすべて一人で引っ被ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は嫌な仕事をいつも文句も言わずに引っ被る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「私が全部引っ被るから、君は気にしなくていい」と上司が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "灯りを消して、更紗の懸蒲団を引っ被ると、蝦のように躯を曲げて、すぐさま寝入ってしまった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の外れに来て、急に小男は、着ているその半纏の裾をひったぐるようにして頭からひっかぶるのだった。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、フトンをひっかぶる気配、周囲の三四人が低く笑う。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
