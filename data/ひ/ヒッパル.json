    "definitions": [
      {
        "index": 1,
        "gloss": "to pull",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "重いドアを、全身を使って力強く引っ張る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供は母親の服の裾をちょんちょんと引っ張って、注意を引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "犬が散歩中にリードを引っ張るので、飼い主は大変そうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "死ぬまで車を引っ張る馬のように、死ぬまで苦労を背負わせるんだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝お絹の家　お絹は天窓の紐を引っ張る「さァ此処から」と急き立てる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ張るということに対しては、猫の耳は奇妙な構造を持っている。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子の差し出した手を、その男の児がやけに引っ張る。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の児が手を引っ張る力加減に変化がつく。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "強く引くのかと思うと、身体つきだけ強そうにして軽く引っ張る。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその若い人が怒ってね、『引っ張るなったら、先刻たがらいで処さ来るづどいっつも引っ張らが。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、だしぬけに袂を掴んで引っ張る奴があるので、驚いて振り返ると……」「お鎌婆さんか」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は唇をかみしめてふっと空をみつめたまま、その男が引っ張るのに任せていた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "護謨を延ばして、今少し引っ張ると切れると云う所迄構わず持って行く。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は両親の寝床の間にもぐりこんで、長い白髯を引っ張るやら、皺くちゃの乳房にかじりつくやら、ひとしきり困らしていたようだが、いつの間にかぐっすりと眠りこけてしまったらしいのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで出るかと続けて引っ張るとすらすらとすっかり出る。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ張るべきだという意志は、あなたがわたしに強いた意志じゃないですか？",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「引っ張るも引っ張らないも、弾丸を込めた鉄砲を……」「本当に危なかったわ。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出きったところで、我が友人は私の袖を引っ張る。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ホームズはつぶやき、綱を引っ張る。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは帽の一方の縁を高く反り立たしめる事、昔｜流行し帽の頂から緒でその縁を引っ張るため縁に穴あり、緒の端に付けたボタンを通して留めた、そのボタンと穴の周囲の環から化け出たというが通説だ（ウェッブ氏の書四四頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸水素｜吹管の炎で溶かしておいて、両方の手で、左右へ引っ張ると細い糸ができるのです」　三四郎は「そうですか」と言ったぎり、引っ込んだ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんなことを言って引っ張るくらいなら、いっそきっぱり今のうちに断わるほうが得策だから」　「いまさら断わるなんて、僕はごめんだなあ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんなことを言って引っ張るくらいなら、いっそきっぱり今のうちに断わるほうが得策だから」「いまさら断わるなんて、僕はごめんだなあ。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は一杯機嫌でお此にからかって、その袂などを引っ張るので、お此はうるさいのと癪に障るのとで、一つ嚇かしてやろうと思って、袂から西洋マッチをとり出して、手早く摺りつけて二、三本飛ばせると、二人は火が飛んで来るのにびっくりして、忽々に逃げ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の急いているお倉は上の空で返事をしながら、婆さんを引っ張るようにして急いで帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ軒を飛びだすなり俊夫君は、私を引っ張るようにして、ちょうどそのとき通りかかったタクシーの空車を拾い、まっしぐらに警視庁さして急がせました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばニュートンは林檎が落ちたのを見て、これは地球が引っ張るのではないかと想像してみた。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどはその首に綱を結びつけて引っ張ると、ウシが二、三歩動いたかと思うたとき、突然坑が落ちて、鉱夫どもが七十五人惨死したというのであります。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はかくあまりに顕著な例を挙げてみると、同じチビキの石でも引っ張るほうの千曳きと生き物の血を塗いたほうのチビキとの二つの区別があり、また起原があることがあいわかる。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "『斯なる上は其の方達両名で中の子を引っ張るより外裁きのつけ方はあるまい。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大規模なソフトウエアに、プログラム上の欠陥であるバグや、処理速度の足を引っ張る問題点が数多く残されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大化した組織が往々にして官僚的な手続きを煩雑化させ、迅速な処理の足を引っ張ることを自覚していたＩＢＭは、社員の自発的な試みを後押しする受け皿となることを目指して、独立事業単位という制度を用意していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等は何か無性に面白がって餅を握りながらバタバタと縁側を追い廻る、小さいのは父上の膝で口鬚をひっぱる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to string (lines)",
