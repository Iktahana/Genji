        "examples": {
          "standard": [
            {
              "text": "アンケート結果は、見やすいように表形式でまとめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このデータベースは、表形式でデータを保存している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議資料は、数字が多いため表形式で提示するのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ブリックリンはこのマシンで、集計表形式の自動計算ツールのプロトタイプを書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戯曲作家は、さういふ理由から、いつでも自分の作品を、この二つの発表形式の上に成り立たせようとする。",
              "citation": {
                "source": "昭和の劇文学の全貌",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "室寿詞は、いはひ詞の代表形式で、すべての呪言が其型に這入つて発想せられた事実は証明する事が出来る。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと抽象的な発表形式を採用しろというのが司法省案に対する修正案であったらしい。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
