        "examples": {
          "standard": [
            {
              "text": "古文の授業で肥前風土記の逸話を読み、当時の豊かな自然環境に驚かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図書館の郷土資料コーナーで、肥前風土記の現代語訳版を手に取ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "肥前風土記に記された「松浦佐用姫」の伝説は、今も地元の人々に語り継がれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ナド見エ、又豐後風土記日田郡五馬山ニ、土蜘蛛五馬媛、肥前風土記佐嘉郡ニ、土蜘蛛大山田女、狹山田女ナドモアリ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "絡※・臥機が夢に神｜憑りを現ずる事、姫社の由来（肥前風土記）にある。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと異風な幡は、前にあげた肥前風土記｜基肄郡｜姫社社の由緒に見える。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
