        "examples": {
          "standard": [
            {
              "text": "即位の礼が執り行われる宮殿には、百僚が整列して新しい時代の幕開けを祝った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "王の号令の下、百僚は一丸となって国家の危機を乗り越えるべく奔走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "朝廷の儀式では、百僚がそれぞれの位に応じた装束を身にまとい、壮観な眺めだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その所長は研究員の人に「君たちは百僚有司のその有司の一人じゃないか、こういう場合には、そんな馬鹿な話があるはずがないと言下に言い切れるようにならなくてはいけない」と訓えられたそうである。",
              "citation": {
                "source": "流言蜚語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく大仏の前に、皇后太子並に群臣百僚を率いておまいりになり、左大臣｜橘諸兄をして奏文を読ませ給うた。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
