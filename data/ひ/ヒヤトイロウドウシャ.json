        "examples": {
          "standard": [
            {
              "text": "港湾地区では、多くの日雇い労働者が貨物の積み下ろしに従事している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その施設は、日雇い労働者たちが格安で宿泊できるよう運営されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "景気が悪化すると、まず日雇い労働者たちの雇用が真っ先に打ち切られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "わたし自身としては日雇い労働者の仕事がいちばん独立的なものであるということを知った。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋の留さんという日雇い労働者に働き口をたのむ。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は日雇い労働者だったが、もとは坑夫などもしたことがあるそうで、酔って暴れだすと手がつけられなかった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
