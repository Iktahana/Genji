    "definitions": [
      {
        "index": 1,
        "gloss": "cold wind blowing at Lake Biwa around the 24th day of the second month of the lunisolar calendar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "比良八荒が吹く頃は、湖面が荒れるので漁師たちは出漁を控える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "春だと思って薄着をしていたら、比良八荒の冷たい風に凍えてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "比良八荒は、冬の名残を惜しむかのように強く冷たく吹き抜ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで、この時分を、比良八荒と申しまして、事に慣れた漁師でさえも、出舟を慎しむのだそうでございます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
