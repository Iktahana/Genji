    "definitions": [
      {
        "index": 1,
        "gloss": "Buddhist service centred around the Lotus Sutra held over four days in Shiga Prefecture, starting from the 24th day of the second month of the lunisolar calendar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "比良八講が始まると、いよいよ滋賀にも春の訪れが感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい修行を終えた僧侶たちが、比良八講の法要を厳かに執り行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "比良八講の期間中は、多くの参拝客が琵琶湖畔の寺院を訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
