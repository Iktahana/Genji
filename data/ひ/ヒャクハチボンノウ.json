        "examples": {
          "standard": [
            {
              "text": "人間には百八煩悩があると言われ、欲望を断ち切るのは容易ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "座禅を組みながら、自らの内にある百八煩悩と向き合う時間を持った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "除夜の鐘が、私たちの百八煩悩を一つずつ消し去ってくれると信じたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "百八煩悩おのづから消えばこそ、殊更に何かは消さん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに思へば、鬼の形しけるは我身を纏ふ百八煩悩の現躰なりける。",
              "citation": {
                "source": "松島に於て芭蕉翁を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
