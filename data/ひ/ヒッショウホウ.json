        "examples": {
          "standard": [
            {
              "text": "彼はこのゲームの必勝法を見つけ出したと豪語している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなことにも必勝法があるとは限らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "受験に向けて、効果的な必勝法を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一体｜球賭盤の必勝法には、たとえばシャルル・アンリの倍賭法、アランベエルの早見法、ウエルスの｜勝ち乗り法なぞと、およそ小一万もありますが、計算や罫線で勝てるわけがないんですヨ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは私の巷談に説く必勝法には同感していないのである。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の必勝法と彼らのそれとは距りがあり（彼らはみんなベテランだ）その距りは絶対で、知己を感じるイワレはないように見える。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
