    "definitions": [
      {
        "index": 1,
        "gloss": "to stick to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "壁に貼ったポスターが、湿気で引っ付いて剥がれなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供が母親のスカートに引っ付いて、離れようとしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨で濡れた落ち葉が、靴の裏に引っ付いて歩きにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "残念な事には、小夜子と自分は、碁盤の上に、訳もなく併べられた二つの石の引っ付くような浅い関係ではない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男と引っ付くために彼女は一体何をしたんだろうね。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈から落ちて来る小虫がひっつくのかもしれない。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の皮がひっつくくらい、ペコペコになっていたせいか、涙が出るほど美味かった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時間で乙の旅人が甲の旅人に追い着くかという事がどうしてもわからぬ、考えていると頭が熱くなる、汗がすわっている足ににじみ出て、着物のひっつくのが心持ちが悪い。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉は壁にぴったりひっつくと、足が動かなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏小路に出ればそこは所謂鐘路裏で、カフェー、バー、立飲屋、おでん屋、麻雀屋、周旋屋、飲食店、旅館等が、目をぴかぴか光らせたり、口を開けたり、尻ごみしたり、地べたにひっつくように蹲んだりしている。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由来については、牛蒡の種に小さい棘があって、よく物にひっつく様に、この人々は容易に他人にひっ憑くから、それでこの名を得たのだと言われている。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to become intimate (of a man and woman)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "二人は出会ってすぐに意気投合し、あっという間に引っ付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの二人は最近、やけに引っ付いているように見えるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の同僚同士が、久しぶりに会って引っ付いたという話を聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
