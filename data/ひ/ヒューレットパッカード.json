        "examples": {
          "standard": [
            {
              "text": "彼は大学入学を機に、ヒューレットパッカードの最新モデルのノートパソコンを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会社のプリンターが故障したので、保守サービスを通じてヒューレットパッカードのエンジニアを呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヒューレットパッカードは、かつてガレージから始まったシリコンバレーの伝説的な企業の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここでもなかなか仲間の輪にとけ込めなかったジョブズだったが、一〇歳を過ぎたころからエレクトロニクスに関心を抱き、近所に住むヒューレットパッカード（ＨＰ）社のエンジニアの家に押しかけては質問の雨を降らせるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同校で電子工学を学んだデビット・パッカードとビル・ヒューレットは、恩師の推し進めたプログラムに乗って、一九三九年にヒューレットパッカード（ＨＰ）社を起こした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
