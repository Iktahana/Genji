        "examples": {
          "standard": [
            {
              "text": "新しいご近所さんへ、引越しそばとして手作りの蕎麦を持っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ご迷惑をおかけしますが、これが引越しそばです。どうぞお召し上がりください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は、引越しそばを配るのが近所への挨拶だったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのうえ、かんじんの引越しそばをあつらえるのは忘れてきたというに至っては、われながら、愛想も小想も尽き果ててしまいましたよ。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
