          "standard": [
            {
              "text": "レポートを書くための基礎資料として、百科辞書で用語の定義を確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の家には、革装の豪華な百科辞書が全巻揃っており、書斎の重厚さを引き立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "百科辞書を読んでいると、一つの項目から派生して、次々と新しい知識が繋がっていくのが面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今手許にあるヘルデルの百科辞書を開いてみると、ラテナウは一九二二年六月二四日ベルリンで「ユダヤ人並びに“〔Erfu:llungspolitiker〕”（ヴェルサイユ条約履行主義の政治家という意味）として国民社会主義の行動派によって暗殺された」とある。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日出来たばかりの百科辞書を見ても旧説ばかり書いてあって、迚も問題にならん。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
