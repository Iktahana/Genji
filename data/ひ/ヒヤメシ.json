    "definitions": [
      {
        "index": 1,
        "gloss": "cold rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝食で残った冷や飯を使って、お昼にパパっとチャーハンを作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の人は、冷や飯にお茶をかけてサラサラとかき込むのが日常だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レンジでチンすれば、冷や飯も炊きたてのように美味しく食べられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "銀ぶら道中記（六）　西洋でブレッド・アンド・ミルクの生活といえば、日本の冷や飯にたくあんに相当すると聞いたことがあるが二た昔前まで、ミルクにパンに紅茶を一食まぜるということはハイカラな生活で、まあ自慢の一つになるものであった。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（青木先生の食客となって一生冷や飯を食うのもいいさ）などと磊落に思うこともあった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝が揺れさわぐと、やみのなかに黒い影がおどって、冷や飯｜草履をとおして、地面の冷えが、はい上がってきた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "板の間で冷や飯を食べ、雑巾バケツの側で叱られ、又、おかみさんの足腰を揉ませられる事よりも、それは奴隷的な屈辱感に汚される心地であった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼はお午すこし前に妻を起さぬようそっと餉台を出し、沸しざましをかけて独り冷や飯をかき込んだ。",
              "citation": {
                "source": "モルモット",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれや、泥棒仲間へ落ちたおちぶれ者」「なにを、廟堂の冷や飯食いめ」　発矢。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の木戸口や楽屋裏へ来て、芸人の冷や飯をもらって歩くお前たちが、口出しをする幕じゃあるまいに」「女のくせにしやがって、きいたふうな事を言やあがる。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおれの部屋に冷や飯を食っている岡ッ引だから、訊いてみて、もしそうだったら、灯ともし頃を合図に、大川と浜町の陸から、例の所へ人数をよこすように親方が言い残して行きましたと、言伝をしてくれないか。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校に行くにもひやめし草履をぺた／＼穿いてはよく出かけた。",
              "citation": {
                "source": "田舎からの手紙",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引替え私は寄宿舎の中にくすぶっていて、その中でこそ気焔も吐くが、外に出ては、嫡子でいながらひやめし喰いにも追従せられぬので、自分のみすぼらしさをつくづくと感じた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "中剃をひろくあけたつっこみにゆい、陸尺半纒にひやめし草履。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやめし草履をひきずる先生の横に、ちょこちょこ走りのお美夜ちゃん……稚児輪の似あうかわいい顔で両袖かさねて大事そうに、胸のところにだいているのは、泰軒小父ちゃんの一升徳利で。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "へつ、俺みてえに貧乏な百姓の、ひやめし次男だとか、喜十のおじさんみてえな人間は、そんな悠長なゴタク並べてはおれねえだ！",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結構ですね」と平五はやり返した、「養子にいっても小遣に不自由したり、好きな酒も飲めずにちぢこまっているくらいなら、ひやめしを食ってるほうがましですよ」　杢之助の顔色が変った。",
              "citation": {
                "source": "末っ子",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恥からさきに話しますが、いちばん初めは七つの年です」と平五は続けた、「そのとき新庄の叔父は三十で、まだ木挽町に部屋住でいました、そして、もうそんな年では生涯ひやめしを食うことになるだろう、とまわりの者も云うし、自分でも諦めていたんでしょう。",
              "citation": {
                "source": "末っ子",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三男坊のひやめしなもんですからね、こんな贅沢な芸当は習わして貰えなかったんです、済みませんが煎茶にして下さいませんか」「芸当とは仰しゃること」　夫人は笑った。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うが嫁に遣らなければならず、こっちが四男のひやめしという条件では、もちろん思案する余地などありはしない、それはわかりきっていたが、大四郎は淋しいような、哀しいような孤独感にとらわれ、ほどをみはからってその座を立った。",
              "citation": {
                "source": "ひやめし物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大四郎はとぽんとしてしまった、一生ひやめしと諦めていたのが、正経閣出仕で十人扶持、分家が定れば百石以上で家も貰えるという、また本には代え難いが三十金という大枚な金もはいる、あんまり思いがけない事ばかりで、すぐには嬉しいという気持さえ感じられなかった。",
              "citation": {
                "source": "ひやめし物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
