          "standard": [
            {
              "text": "彼の家まで、ひとっ飛びで行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バスに乗れば、目的地までひとっ飛びだ。",
