        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "部屋の左奥には、古い木製の棚が置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は資料を探しに、書庫の左奥へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのカフェは、通りの左奥にひっそりと佇んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "左奥の窓際に寄せて机が一脚置いてあり、上には硯やインキ壺がのっていた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず初めに舞台の左奥の隅から、軽く、きわめて軽く、ふうわりと浮き出てくる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場所は、舞台の左奥の隅から右前の隅へ引いた対角線の、出口から見てちょうど三分の一ぐらいのところである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左奥は暗い断崖に終っている。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よけいな装飾も余計な家具もない四角なその広間の左奥のところに立派なデスクがあった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく見える玄関は外来の玄関で、その左奥に信濃町に面して、私たちの入口があるがはっきりしないこと。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
