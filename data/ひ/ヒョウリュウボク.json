        "examples": {
          "standard": [
            {
              "text": "浜辺で拾った形の良い漂流木を加工して、部屋のインテリアにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大雨のあとの川には、上流から流されてきた大きな漂流木が溜まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焚き火の材料にするために、乾燥した漂流木をいくつか集めてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "漂流木を五、六本あつめて火を焚いたが、それも氷がとけたために消えてしまつて、彼等は暗やみの中で夕食をとつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーントンは、ハンズとピートに漂流木の上に腹這いに寝かされ、激しく前後に動かされて、正気附いた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
