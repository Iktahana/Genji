        "examples": {
          "standard": [
            {
              "text": "新しい大使は、就任後すぐに総理を表敬した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国際会議の開会に先立ち、関係各国の代表者が主催者を表敬訪問した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来日した要人が、文化施設を訪れ、職員らに表敬の意を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一人やなんぞ、気にもしないで、父子は澄まして、衆の我に対する表敬の動揺を待って、傲然としていた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な学者たちが表敬訪問せずにスイスを通過することはなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
