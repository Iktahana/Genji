        "examples": {
          "standard": [
            {
              "text": "クリスマスなので奮発して、精肉店で一番良い牛ヒレ肉を500グラム予約した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ヒレ肉は脂肪が少ないので、ダイエット中の方や高齢者にもおすすめの部位です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このヒレ肉のステーキ、ナイフがスッと入るくらい柔らかいね」と家族が喜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "或る華族さんは毎日牛のヒレ肉を配達させていた処功者な人に見せたらヒレ肉でなくって極く悪い肩の肉だったそうです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年間ばかりヒレ肉の代価を払って毎日肩の下等肉を押し付けられたのです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔うしのヒレ肉と辛いソースをかけたマッシュルーム、炙った膵臓、熱いイセエビ、アンズのタート、中央にはシラバブとジェリーのピラミド。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
