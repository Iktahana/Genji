        "examples": {
          "standard": [
            {
              "text": "顔の表情筋を鍛えるエクササイズをして、若々しい印象を保つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "常に同じような表情をしていると、特定の表情筋だけが凝り固まってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "表情筋をほぐすマッサージを受けたら、驚くほど顔が軽くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "埒もない対話をしているのに、一一の詞に応じて、一一の表情筋の顫動が現れる。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし純一の目に強い印象を与えたのは、琥珀色の薄皮の底に、表情筋が透いて見えるようなこの女の顔と、いかにも鋭敏らしい目なざしとであった。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにしろ、あの垣の上に妙な首が載っていて、その首が何の遠慮もなく表情筋を伸縮させて、雄弁を揮っている処は面白い。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の色は真つ蒼になつて表情筋の痙攣を起してゐる。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
