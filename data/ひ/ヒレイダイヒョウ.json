          "standard": [
            {
              "text": "比例代表の名簿順位を決めるプロセスは、党内での政治的な駆け引きが反映される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「比例代表の結果待ちです」と事務所スタッフが緊張した面持ちで電話に応対した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "少数政党であっても、比例代表であれば議席を得るチャンスが十分に存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "比較的小選挙区に於ける定員制の弊、比例代表制の必要など、得点数と当選数とが平行しないという矛盾に基くのだが、夫は、ここでの大衆がもつ機械的組織がこの資本制支配社会に於て現実に受け取る処の矛盾に他ならない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
