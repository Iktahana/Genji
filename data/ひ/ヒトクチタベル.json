        "examples": {
          "standard": [
            {
              "text": "疲れていたので、何か一口食べたい気分だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このお菓子、美味しいよ。一口食べてみて！」と彼女が勧めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝は時間がなくて、パンを一口食べるのが精一杯だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "パンはとてもおいしくて、一口食べると舌のなかにつばきがあつくなるような気がします。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このパンが、魔法のパンで、一口食べると、お午飯を食べたぐらいお腹がふくれるといいな。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            }
          ]
        }
