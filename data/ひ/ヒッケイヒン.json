        "examples": {
          "standard": [
            {
              "text": "防災リュックには、懐中電灯やラジオといった必携品を詰めておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このサバイバルキットは、どんな状況でも生き残るために必携品と言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "遭難事故に備え、地図とコンパスは必携品として携帯することが推奨されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「杖」は身を憩わせるためまた野獣を追うためで、旅人の必携品でありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてどない旅の途上にある青年の必携品としての文庫本、というイメージで角川文庫は宣伝されていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
