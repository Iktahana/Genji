        "examples": {
          "standard": [
            {
              "text": "駐車場で、車の左後ろを電柱にぶつけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その建物は、交差点を渡ってすぐの左後ろに見えるはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の左後ろに座っていた女性が、静かに本を読んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "振り返ると、いつになく左後ろ斜に岩は岩と白い飛沫をあげている。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返ると、いつになく左後ろ斜めに岩と岩と白い飛沫をあげてゐる。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋の左後ろに、一本の立木を利用して屋根をふいた便所がある。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に向かって左後ろのがよい。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
