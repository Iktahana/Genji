        "examples": {
          "standard": [
            {
              "text": "災害に備えて、必要最小限の食料と水は確保しておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は必要最小限の荷物で海外へ旅立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議では、必要最小限の情報のみが共有された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これにたいし、統制は專制と自由を綜合開顯せる指導精神であり、個々の自由創意を最高度に發揚するため必要最小限度の專制を加えることである。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "体つきはよく見れば充分に女らしいのだが、女らしさを必要最小限以上には感じさせない。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府に訴えたりはたらきかけたりしても、なにごとも解決されるみこみはない、という正しい認識から出た必要最小限の効果を持つ抗議手段が、坐りこみだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
