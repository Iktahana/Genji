        "examples": {
          "standard": [
            {
              "text": "最新の有機ELパネルを搭載した表示装置は、黒の再現性が非常に高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "屋外でも視認性が確保できる、高輝度の表示装置を導入することに決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "医療現場で使用される表示装置には、極めて高い解像度と色の正確性が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「マイコンのお目ざめプログラム」では、ＴＫ―80に付いている表示装置、七セグメントのＬＥＤ上にまずは両まぶたを表示する。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな中で、モステクノロジー社が売り出していたＫＩＭ―１と名付けられたキットには、日の字型の小さなＬＥＤの表示装置とごく簡単な十六進のキーボードが組み込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＫＩＭ―１には十六進の簡単なキーボードと、日の字型のＬＥＤの表示装置が二つ組み込まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
