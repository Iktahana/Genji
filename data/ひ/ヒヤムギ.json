        "examples": {
          "standard": [
            {
              "text": "そうめんよりも少し太い冷や麦は、もちもちした食感が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冷や麦の束の中に数本だけ混じっているピンクや緑の麺を見つけると、少し嬉しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お中元で届いた冷や麦を、家族全員で囲んで食べるのが我が家の夏の定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ビールやサイダアのビラがある、「ひやむぎ」と書いた貼紙、店は開け放して、長い床几が二、三脚、硝子の簾、造花の軒飾り、祭りの提灯。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひやむぎでもやるかな。",
              "citation": {
