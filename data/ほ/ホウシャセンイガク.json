        "examples": {
          "standard": [
            {
              "text": "彼は放射線医学の専門家として、最新のMRIやCTスキャンを用いた非侵襲的な画像診断技術の研究に長年従事してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "放射線医学の進歩により、がん細胞だけをピンポイントで狙い撃ちして正常組織へのダメージを最小限に抑える治療が可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その大学病院には、全国から複雑な症例の患者が集まるため、放射線医学教室の医師たちは日々高度な読影技術を磨いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "原子爆弾の原子病は果たしてどんな症状を呈したかというと、大体以上略記した過去の放射線医学の知識に一致するものであった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
