        "examples": {
          "standard": [
            {
              "text": "革に美しい模様を彫り上げるのは、大変な技術が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はその金属板に、緻密なデザインを時間をかけて彫り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人は、一枚一枚の銅板に手作業で紋様を彫り上げていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この不動様の三尊を彫り上げるということは彫刻の稽古としては誠に当を得たものであって、この稽古中に腕もめきめき上がって行くのです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを歴史の背景の前に描こうとする時、主観の中にとじこもり、或は一般的に暖いもの、妥協的なもの、話し合いで分るものという先入観で感じられている人情のほの明りの中に溺れては、その中での歌はうたえても、現実を力強く彫り上げることは不可能であろうと思われる。",
              "citation": {
                "source": "パァル・バックの作風その他",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
