        "examples": {
          "standard": [
            {
              "text": "彼は高校時代から砲丸投げの選手として活躍し、県大会で何度も優勝を果たしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "オリンピックの砲丸投げの決勝戦では、力強い掛け声とともに鉄球が宙を舞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "短距離走と違って、砲丸投げは瞬発力だけでなく全身の筋肉を連動させる高度な技術が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "考えようによってはランニングや砲丸投げなどのレコードよりもより多く文化的の意義があるかもしれない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の中では砲丸投げが始まった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲丸投げほど力のいるものはなかろう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、砲丸投げが出来るので。",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、すぐその木蔭で、砲丸投げをやり出した。",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、砲丸投げが出來るので。",
              "citation": {
                "source": "麥藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
