        "examples": {
          "standard": [
            {
              "text": "シダの葉の裏をよく見ると、胞子が入った胞子嚢の粒がたくさんついている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "カビは、菌糸の先端に作られた胞子嚢から大量の胞子を放出して繁殖する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "胞子嚢が破れると、中から無数の胞子が風に乗って飛んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "生殖は隠花植物、殊に羊歯植物門類似で、翼端に胞子嚢があり明らかに葉状体ないしは前葉体から進化したものだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
