        "examples": {
          "standard": [
            {
              "text": "117番に電話をかけると、プップップッポーンという正確な報時信号が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "船舶の航行安全を守るため、灯台からは定期的に報時信号が発信されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "報時信号に合わせて一斉にカウントダウンを始め、新年を迎える準備をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "僕は毎晩のように鉱石の上を針でさぐりながら、銚子局の出す報時信号のリズムに聴き惚れたものです。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞電報も報時信号もうけとったし、今夜はもう電信をうつ用も起らないだろうから、器械の方にスイッチを切りかえて、君も寝ることにしたまえ」　器械というのは、警急自動受信機のことである。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
