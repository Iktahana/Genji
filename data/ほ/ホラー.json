        "examples": {
          "standard": [
            {
              "text": "夜中に突然の物音に、思わずホラー映画のような悲鳴を上げてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はホラー映画が大好きで、どんなに怖いシーンでも平気で見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その古い洋館は、まるでホラー映画のセットのような不気味な雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "綿花畑で仕事をしながら叫ぶようにうたわれたフィールド・ホラーは、これは単純に実用音楽だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルースがもしスピリチュアルやフィールド・ホラーといまでもつながっているとするならば、そのつながりは精神的なものではなく、むしろ、スピリチュアルもフィールド・ホラーもブルースも、いずれもアフリカからもってきた音楽としての、純粋に音楽上の同一性だけだろう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜくりかえすかというと、おなじ文句を何度もくりかえすフィールド・ホラーの影響と、三行目を考えだすための間、そして、英語がまだあまりうまくできなかったので、聞いている人たちの理解をよりよくするために、二度くりかえされたというのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
