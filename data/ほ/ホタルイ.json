        "examples": {
          "standard": [
            {
              "text": "田んぼの畔に、蛍藺が群生しているのを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蛍藺は、湿地を好む植物で、日本の各地に自生している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭に蛍藺を植えて、和風の趣を出してみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と、彼のからだがほたるいかのように光った。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのそばにいた他の異人が、またすっと立ち上って、全身をほたるいかのように光らせる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
