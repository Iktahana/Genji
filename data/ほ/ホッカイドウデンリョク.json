        "examples": {
          "standard": [
            {
              "text": "台風の影響で、一部地域で北海道電力の供給が一時的に停止した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "毎月、北海道電力から送られてくる電気料金の請求書を確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「北海道電力は、再生可能エネルギーの導入にも力を入れているらしい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "というのも国策パルプ、苫小牧製紙、東洋高圧、帝国製麻、日本製鋼、北海道電力といった優良株を、北海道に工場があるという理由で、絶対に買わない男がいるという話をとたんに思い浮べたからである。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは北海道電力会社の委嘱によるものである。",
              "citation": {
                "source": "雪は資源である",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この電源開発は、電源開発会社と、北海道電力会社との手でなされたものである。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
