    "definitions": [
      {
        "index": 1,
        "gloss": "stitched side of some traditional Japanese clothing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
