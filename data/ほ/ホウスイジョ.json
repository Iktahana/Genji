        "examples": {
          "standard": [
            {
              "text": "訓練中の兵士たちは、烹炊所に集まって温かい麦飯を頬張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "船底に近い烹炊所は、常に熱気がこもっており夏場は非常に過酷だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "烹炊所の壁には、週間の献立表が丁寧に貼り出されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "肴が必要だったが、そこはうまいこと烹炊所にわたりをつけて、缶詰などをもらって来る。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにいて、毎日いやな思いで苦労して、この先どうなることかと暗い思いをしているとき、食事当番で烹炊所の前に整列していると、その年初めてのつくつく法師がそばの木に取りついて、いやな声立てて鳴きましたよ。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
