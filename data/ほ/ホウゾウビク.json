        "examples": {
          "standard": [
            {
              "text": "法蔵比丘は、世自在王仏のもとで、理想の国土を築くための修行を重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "浄土教の教えにおいて、法蔵比丘の立てた誓願は救いの根本とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "法蔵比丘の物語を語り継ぐことで、先人たちは困難な時代を生き抜く糧とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "法蔵比丘の超世の祈りは地獄に審判されていた人間の運命を、極楽に決定せられた運命にかえたではないか。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "法蔵比丘の水の中、火の中での幾万劫の御苦労はあまねく、衆生の一人、一人への愛のためだったのだ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "法蔵比丘の超世の願いは思えば想うほど畏ろしい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで阿弥陀如来が法蔵比丘の昔平等の慈悲に催されて普く一切を救わんが為に唱名念仏の本願を建てられたのである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
