        "examples": {
          "standard": [
            {
              "text": "水道管のバルブや継手には、耐食性に優れた砲金製の部品が使われていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古い大砲の砲身に用いられていたことから、この銅と錫の合金は砲金と呼ばれるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父の形見の時計は、経年変化によって砲金特有の重厚で渋い輝きを放っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "折角勢い込んでいたＴ君は「もう戦時態勢にはいったのだから、そういう研究は止めて、砲金の熱伝導度の測定を始めてくれ」ということで、急に金属物理学の助手に早変りすることになった。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを砲金でも作ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲金で作っても、こうはうまくいかないだろう。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
