          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ホモ・サピエンスは、現生人類の学名である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アフリカで発見された初期のホモ属の化石は、人類進化の歴史を物語る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ホモ・エレクトスは、火を使い始めた最初の人類だとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
