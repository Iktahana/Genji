        "examples": {
          "standard": [
            {
              "text": "長年の慣習であったものが、国民の強い要望を受けてようやく法文化されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "基本的人権の尊重を法文化することは、民主主義国家としての根幹をなす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "時代の変化に伴い、かつての道徳規範が次々と法文化され、厳格な運用が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "文部省にこの実状がわかっていない筈はないのに、六・三と分けて、後の三年は通信教授だけでもいいということを法文化しようとしている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省は六・三制の三の部は、通信教授を受けることで完うしたものと認めるということを法文化そうとして一般の批判をうけた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
