        "examples": {
          "standard": [
            {
              "text": "富山湾では、春になると蛍烏賊の群れが見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旬の蛍烏賊は、茹でて酢味噌で食べるのが最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蛍烏賊の生態は、まだ多くの謎に包まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――敵はいずれも全身から蛍烏賊の如き青白き燐光を放つ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、彼のからだがほたるいかのように光った。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのそばにいた他の異人が、またすっと立ち上って、全身をほたるいかのように光らせる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
