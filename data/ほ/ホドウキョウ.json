        "examples": {
          "standard": [
            {
              "text": "駅前の歩道橋を渡ると、すぐにデパートが見えてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、学校へ行くのに毎日あの歩道橋を渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "交通量の多い通りを安全に渡るため、歩道橋が設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "人混みを避けふたりだけで幹線道路の歩道橋に腰を下ろして。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩道橋で越えるつくりもあれば、線路の下をくぐる配置もあって、目線と線路の高さが同じになり、向こうへ海が見えるということなども起こる。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
