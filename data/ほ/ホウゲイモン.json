        "examples": {
          "standard": [
            {
              "text": "皇太子殿下の御成婚を祝して、駅前の大通りには色とりどりの花で飾られた巨大な奉迎門が建設された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "古い写真帖に、戦前の軍隊の凱旋パレードの際に立てられた、杉の葉と提灯で装飾された奉迎門が写っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "町の入り口に木材で仮設の奉迎門を組み立て、祭りの準備を急ピッチで進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ぽつり、ぽつり、ぽつりと、奉迎門の明るい電光飾に、三人の褞袍着の姿が埠頭の広場に現れる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、巨大な奉迎門の黒い影、影、影、　正門と両側の小門。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ては本斗の海産物で装飾したその奉迎門は、確かに思いつきであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
