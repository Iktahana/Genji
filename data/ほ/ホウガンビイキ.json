        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本人の国民性として、どうしても弱い立場の者に肩入れしてしまう判官びいきの傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "高校野球で無名の公立校が強豪の私立校に挑む姿を見ると、つい判官びいきで応援したくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "その悲劇的な結末は当時の人々の心を打ち、判官びいきの感情とともに物語として語り継がれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "判官びいきの人たちはその反動から競争者の富子を憎んだ。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、判官びいきの熱だつて、農村にまで栄えて行つた。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の経験か今では訣らなくなつたが、栗原氏、尾上松助の言ひひろめたものゝ様に考へられてゐる、奥州の「判官びいき」の話がある。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其為にこそ、関東から奥州へかけて、あんなにまで判官びいきを流行させたのも、謂はゞ恐歓待の現れだつたと言はれぬこともない。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もそれを書いてゆくだろうが、どうやら私も自然判官びいきの一人になりそうである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくなども、義経は好きだが、そして義経の生涯や性格に多分な詩と劇的な興味は覚えるが、義経讃美も度が過ぎて、いわゆる判官びいきの引き仆しが多く、その一例がここにも見られる。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
