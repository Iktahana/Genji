        "examples": {
          "standard": [
            {
              "text": "工場の屋上から地上へと続く放水管が、経年劣化により錆びて一部破損している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大雨の際、放水管が詰まってベランダに水が溢れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地下道の壁面に沿って、無数の放水管が複雑に入り組んで設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "同時に水の轟く音は、鋭い叫び声のような――ちょうど幾千という蒸気釜がその放水管から一時に蒸気を出したと思われるような――物音にまったく消されてしまいました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
