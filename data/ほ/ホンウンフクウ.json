          "standard": [
            {
              "text": "彼の態度は翻雲覆雨のようで、信頼できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政治家の言葉は、しばしば翻雲覆雨に変わりやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "翻雲覆雨な友情よりも、揺るぎない信頼関係を築きたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "翻雲覆雨　翻手為雲覆手雨とは人も知りたる貧交行の中の句にして、句意はたゞ反覆常ならぬことを云ひたるまでなるに、支那の悪小説などには怪しからぬことを形容する套語として用ゐられたるが多し。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "市参事会員の行動斯くの如く、市会の形勢亦翻雲覆雨して、氏に求むるに市有案の撤囘を以てしたるに至ては、是れ氏に向て詰腹を切らしめむとするに均し。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
