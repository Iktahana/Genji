        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、自分の経験を大げさに語り、しばしばホラを吹く癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その男は、自分がどれほど勇敢かを周りに信じさせようと、必死にホラを吹いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あまりにも実現不可能な計画を語るので、皆、彼がホラを吹いていると思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "父が患者に対して愛嬌をふりまくとか、患者を心服せしめるためにホラを吹くとか、そういう類の外交術をやっている場面はかつて見たことがないが、病気と聞いて即座に飛び出して行かない場合もかつてなかったと思う。",
              "citation": {
                "source": "蝸牛の角",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり人間は、ほらをふくに限る。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間のくせに、ほらをふくな。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
