        "examples": {
          "standard": [
            {
              "text": "訓練生たちは泥まみれになりながら、低い障害物の下を匍匐前進で突き進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アクション映画の主人公が、敵に見つからないよう通気口の中を匍匐前進で移動している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害現場では、天井が崩落する危険があるため匍匐前進で生存者を捜索することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また小銃を捧げての匍匐前進。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "匍匐前進をやった後は、黄砂がどこからともなくしみこんで、胸や腹の皮膚を黄色にした。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
