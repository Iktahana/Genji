        "examples": {
          "standard": [
            {
              "text": "イネ科植物は、英語ではホモノ科、あるいはグラス科とも呼ばれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食料源として重要な穀物の多くは、ホモノ科に属している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ホモノ科の植物は、世界中の生態系で主要な役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このコブナグサは Arthraxon hispidus（Thunb.）Makino の学名を有し、ホモノ科（禾本科）の一年生禾本で、各地方の随地に生じ土に接して低く繁茂し、前にも書いたように秋に沢山な針状花穂が出て上を指している。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
