        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "医療ドラマで、人体の骨付き模型が使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "骨付き構造は、人体の動きを理解するのに役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の描くキャラクターは、骨付きの描写が非常にリアルだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
