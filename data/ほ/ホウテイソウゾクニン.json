        "examples": {
          "standard": [
            {
              "text": "亡くなった父の遺産を公平に分割するため、まずは誰が法定相続人にあたるかを戸籍で調査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "法定相続人が配偶者と子供のみの場合、法律で定められた相続分はそれぞれ二分の一ずつになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遺言書が残されていなかったため、法定相続人全員が集まって遺産分割協議を行うことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "皆んな死んでしまえば、甥の田庄平が法定相続人だ。",
              "citation": {
                "source": "悪魔の顔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ファディウス・ガルスという大金持が娘に全遺産をゆずりたいと思っていたが、法律が女子の相続しうる額をきめているので、ルフスを法定相続人とした。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
