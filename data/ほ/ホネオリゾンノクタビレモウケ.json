        "examples": {
          "standard": [
            {
              "text": "徹夜で資料を作成したが、会議が中止になり、骨折り損のくたびれ儲けだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のために一生懸命やったのに、全く感謝されず、まさに骨折り損のくたびれ儲けだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "散々準備した運動会が雨で延期になり、骨折り損のくたびれ儲けとみんなが嘆いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "高大之進の一行は、骨折り損のくたびれ儲け。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも警部補と二人で骨折り損のくたびれ儲けになったような気がした。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨折り損のくたびれ儲けだ。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つ盗ろうぜ」「骨折り損のくたびれ儲けになりそうだからなあ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
