        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "営業成績がトップだったので、社長から直々に報奨金が手渡された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新製品のアイデアが採用され、社内規定に基づき報奨金が支給されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "オリンピックで金メダルを獲得した選手には、国から多額の報奨金が出る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "出頭して自白した犯罪者にも恩赦が与えられたが効果無く、莫大な報奨金も無駄だった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
