        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冤罪で拘留されていた男性に対し、国は刑事補償法に基づき報償金を支払った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "証拠品の提出に協力した市民へ、感謝の意を込めて一定の報償金が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "土地の強制収用に伴う報償金の額について、地権者との間で協議が続いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それからまた、そこは殺人報償金★の手広い取引でも名高かった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺人報償金　　死に当る大罪人を告発したり、主人や恩人などを敵に売って殺させたりした報酬として受ける金。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
