    "definitions": [
      {
        "index": 1,
        "gloss": "to be strongly attracted (by)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女はその美しい歌声にすっかり「惚れ込んだ」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、その才能と情熱に「惚れ込んで」チームに加入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この作品の独創性に「惚れ込んで」、私は作者のファンになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "将軍家がそんな物まで食べなくともよかつたかも知れないが、実をいふと、将軍家などいふものは、さうした料理のつまとか、ほんの一寸した洒落とかいつたやうなものに甚く惚れ込むものなのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒たちはもちろん、教職員全体が頭から惚れ込むやうな塾長を得て、はじめて速水女塾の将来には光明が認められるんだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたが生まれて始めて惚れ込む女が出てくるとしよう、その女は金持ちで綺麗で、しかもぴちぴちに若いときている、もう言うことなしだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのめくら野郎がほれこむのもむりはねえのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々がよく見ることだが、彼らは仲間のある毛色にほれこむ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
