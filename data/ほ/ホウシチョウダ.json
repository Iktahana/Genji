        "examples": {
          "standard": [
            {
              "text": "彼は封豕長蛇のごとき欲深さで、次々と他人の土地を奪っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "歴史上、封豕長蛇の振る舞いをした権力者は、いずれも民衆の反感を買い没落している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あの悪徳商人は、まさに封豕長蛇を地で行くような男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "しからずんばたちまちかの封豕長蛇もって我をして城下の盟をなさしむべし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼十六歳の時、山田｜亦介について長沼流の兵法を学ぶや、亦介曰く、「今や英夷封豕長蛇、東洋を侵略し、印度先ずその毒を蒙り、清国続いでその辱を受け、余※未だ息まず、琉球に及び長崎に迫らんとす。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
