        "examples": {
          "standard": [
            {
              "text": "湿地に仏の座（コオニタビラコ）の群落を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "早春の田んぼの畔には、黄色の仏の座が咲き誇る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この花は一般的に仏の座と呼ばれているが、種類がいくつかある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
