[
  {
    "uuid": "b4984462-b01a-57c2-8175-5b2d74e31f78",
    "entry": "掘り込む",
    "reading": {
      "primary": "ほりこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to dig into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "壁に小さな棚を掘り込んで、飾り付けをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭に池を作るために、深く地面を掘り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はその問題の本質を掘り込むために、何時間も議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしここに困ったことには、硫黄ヶ滝を境いとして西北の方は一体に神保帯刀様の領分の大富の金山に属しておりますれば、一尺たりともその方角へ掘り込むことは出来ませぬ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みをおびたやわらかそうな石で、見るからに石碑にして字をほりこむに手ごろのような石なのである。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
