        "examples": {
          "standard": [
            {
              "text": "警察が個人の住宅を捜索するには、裁判所から発行された令状という明確な法的根拠が必要不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政府が新しい規制を導入するにあたり、憲法や既存の法律との整合性を含む法的根拠を精査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の主張は一見もっともらしく聞こえるが、具体的な法的根拠が欠けており、勝訴の確率は極めて低い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "劇作家組合の規約は、別に法的根拠を有するわけではない。",
              "citation": {
                "source": "演劇と政治",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大本教の検挙の法的根拠はその教理内容の実際が不敬にわたることだった。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
