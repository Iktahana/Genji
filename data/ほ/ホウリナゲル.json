        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちは、公園でフリスビーを放り投げて遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は怒りに任せて、スマートフォンを壁に放り投げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もっと遠くまで放り投げてみて！」と、コーチが指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで外套をつかんで外へ放り投げるとする。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハハ」「何か方法を用いたら、三四百米、放り投げることができないかい」「それも考えられますが、角度の問題ですよ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（赤んぼを舞台の外へ放り投げる）さて、そろそろクイーンさまのところへ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの歩みは馬のものとは見えず――もはや鹿のそれで、歩むと同時に後ろの荷車がフラフラと揺れ、そのひと揺れひと揺れが今にも彼らを崖の下へ放り投げることになるのではないかと思った。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人を手も足も出ないやうな目に合はせた時の、非常に激昂したあの人を、今でも、私、見るやうですわ――私たちのお茶をこぼすやら、バタのついたパンをもみくしやにしてしまふやら、私たちの本を天井まで放り投げるやら、定規とで、煖爐圍と火爐具とで、大騷動を演じるやら大變でしたの。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "床や、扉や、幅木に放り投げると、そこでじっとして動かなくなった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブライ社長がテーブルに手紙を放り投げると、クレードルストンが読み上げた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれはそんなことに、もう怒らないことにしている」　上衣を床の間に放り投げる。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、午後武道の時間だったらしく、垢じみた柔道着をいいかげんにまるめて手にぶらさげていたが、道江にはあいさつもしないで、それを自分の机の近くにほうりなげると、すぐ次郎に言った。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to abandon (one's work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
