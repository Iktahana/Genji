        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仕事の途中で責任を放り投げるようなことは、許されない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなに困難な状況でも、彼は決して仕事を放り投げなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう嫌だ！全部放り投げたい！」と、彼女は机に突っ伏した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
