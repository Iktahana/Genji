          "standard": [
            {
              "text": "彼は大学で方言学を専攻し、東北地方のアクセントの違いをフィールドワークで調査している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "柳田國男の著作は、日本の方言学を語る上で避けては通れない重要な資料だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近ではAIを使って膨大な音声を解析し、方言学の新しい知見を得ようとする試みがなされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（附記）是は昨年五月の近畿方言学会の講演に、若干の資料を補足して解説を精確にしたものである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
