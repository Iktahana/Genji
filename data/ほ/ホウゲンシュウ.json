        "examples": {
          "standard": [
            {
              "text": "五家七宗の一つである法眼宗は、中国の五代十国時代に法眼文益によって開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "法眼宗の教えは、万物の中に仏性を見出すという深い哲学性を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "鎌倉時代、日本から中国へ渡った僧侶たちが法眼宗の文献を多く持ち帰った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "恐くは永春院の子法眼宗英であらうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は法眼宗英の家の子弟ではなからうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
