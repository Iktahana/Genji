        "index": 1,
        "gloss": "school building for housing an imperial photograph and a copy of the Imperial Rescript on Education (pre-WWII)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
