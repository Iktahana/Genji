        "examples": {
          "standard": [
            {
              "text": "ヒトデやクラゲのように、体の中心から放射状に同じ構造が繰り返される体制を放射相称という。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "生物学のレポートで、刺胞動物が示す放射相称の利点について考察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "菊の花びらの見事な並び方は、植物における放射相称の美しい一例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "過大に成長した未知の海棲放射相称動物でなければ恐らくは植物。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "放射相称動物が幾つかの原始的な特徴を失うことなく驚くべき進化を遂げたのだろう。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生達は超太古の熱帯性放射相称動物のことを病的なイマジネーションたっぷりに扱い、おかしな想像ばかりしている。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "放射相称動物、植物、怪物、星の落とし子――何と呼ぼうが、彼らは人間だったのだ！",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
