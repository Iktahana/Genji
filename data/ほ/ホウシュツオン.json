          "standard": [
            {
              "text": "言語学の授業で、声門を閉鎖して作る放出音の発音方法を練習した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "グルジア語やアムハラ語など、コーカサス地方やアフリカの言語には放出音が多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は、放出音の「pʼ」と無気音の「p」の音の違いを聞き分けるのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "凡そ三十秒乃至は一分毎に、恰も空気枕の栓を抜いた刹那の如き放出音が、敵と味方の堅い唇から、交互に盤面にあたつてゐた。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
