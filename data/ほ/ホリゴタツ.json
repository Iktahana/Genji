        "examples": {
          "standard": [
            {
              "text": "冬の寒い夜は、掘りごたつに入って温かいお茶を飲むのが至福の時間だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母の家には、昔ながらの掘りごたつが今も残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "足を伸ばしてくつろげる掘りごたつは、外国人観光客にも人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "掘りごたつのテーブルをはさんで、ナナエのむかい側にハチミがいた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんなかに掘りごたつがあり、彼女たちはこたつに入っていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
