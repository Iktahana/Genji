        "examples": {
          "standard": [
            {
              "text": "人気バラエティ番組のヒットの裏には、斬新な企画を練り上げる放送作家の存在がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は放送作家としてデビューして以来、数々のクイズ番組の構成を手掛けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若手放送作家たちが集まり、深夜枠の新番組に向けたアイデア出しを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ミュージシャンか物書きか、なにかそうした仕事で食っていきたいと考えていた藤井は、大学の軽音楽部でバンドを組み、放送作家の見習いとしても働きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送作家で進むのか、会社の設立に向けてもう少しまっとうなキャリアを積むのか――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
