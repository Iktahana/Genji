        "examples": {
          "standard": [
            {
              "text": "外科手術で骨切りを行い、変形した関節を修正した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の足は骨切り手術を経て、以前より歩けるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "獣医が犬の脚に骨切りを施し、歩行を改善した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "枠に縛りつけられて、ヒンヒン鳴いている奴を、薪割のようなやつで、額を一つガンと喰わせると、ころりっと参ってしまいまさあ、それを骨切り鋸で、ごそごそっと首を引けば、それであんたの役目は済んだというものですよ。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋で鰻を食うに、骨切りなどの法なく、ブツブツと胴切りにして羹に煮るを何やら分らずに吃う。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
