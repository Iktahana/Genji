        "examples": {
          "standard": [
            {
              "text": "子供の頃、ディズニー映画の「バンビ」を何度も見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「バンビ」は、自然の美しさと厳しさを教えてくれる感動的な物語だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の描く鹿の絵は、まるでバンビのように愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヨーロッパの中世紀に紙は普通にバンビク紙（Charta Bambycina）、若くはダマスク紙（Charta Damascus）と呼ばれて居る。",
              "citation": {
                "source": "紙の歴史",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
