        "examples": {
          "standard": [
            {
              "text": "ヘルメットのバイザーを下ろすと、日差しが眩しくなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車のサンバイザーが壊れてしまい、運転中に太陽が直接目に入る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "野球帽のバイザーを深くかぶり、相手チームのサインを見破ろうとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〔六月予記表〕『太陽』の九月号のために、六月四日（土曜）　岡部氏（英男のアドバイザー）夫人、佐和子氏とお茶に来られる。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイミスのミショノーは彼女の疲れた目をかばって、緑のタフタの汚らしいサンバイザーを着けていたが、それにくっついている真鍮の輪を見れば、天使も哀れさを感じながら遠のいてしまうように思われた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
