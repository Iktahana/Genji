        "examples": {
          "standard": [
            {
              "text": "日曜日には、多くの人がバプテスト教会に集まって礼拝を行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "街の中心には、歴史あるバプテスト教会が建っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はバプテスト教会で結婚式を挙げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それによってプロテスタントと称される新しい教会運動が起こったが、それには聖公会（もしくは監督教会と呼ばれる）、長老教会、組合教会、メソジスト教会、バプテスト教会、その他多くの教派が分かれて、止まるところを知らない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりとめのない文章には以下のような語句があった：(*19)エノク・ボーエン教授エジプトより一八四四年五月帰国――古いバプテスト教会を六月購入――考古学の業績＆神秘学の研究で知られる。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
