        "examples": {
          "standard": [
            {
              "text": "走行中にタイヤがバーストし、車がコントロールを失いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古い水道管が突然バーストし、道路が水浸しになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「きゃー！びっくりした！急に風船がバーストしたよ！」と子供が大きな音に驚いて叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本公演だって、ジョンは、あのトレイドマークの黒いリッケンバッカー３２５ではなく、サンバーストのエピフォン・カジノを弾いていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、おれたちの場所だ」　折り畳みイスにすわり、深いサンバーストのギブスンＪ-１６０Ｅをかかえ、躰をゆらゆらさせている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このギター以外なら、なんだって、くれてやる」「いや、じつはな、そのギターのことなんだ」　広岡は、おぼつかない目で、美しいサンバースト仕上げのボディを見おろした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンバーストを見ると、めまいがするんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バディー・ホリーが使ってたやつだっていっても、たいていの奴は信じるくらいの、サンバーストのストラトだぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
