        "examples": {
          "standard": [
            {
              "text": "インドの寺院の境内には、樹齢数百年とされる巨大なバニアンの木がそびえ立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バニアンの木は、気根を垂らして広範囲に枝を伸ばす特徴がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その村では、バニアンの木の下に集まって会議を開くのが伝統だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大きなバニアンの樹の下に、一台の手動のミシンが置いてあり、ポリネシア系の若く美しい女性が、ストゥールにすわってそのミシンを操作しています。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "13『鯨が泳ぐ』　あの大きなバニアンの樹が、太陽の光をさえぎる。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラハイナの港に出るときには、ぼくはいつもこのバニアンの樹の下を歩く。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
