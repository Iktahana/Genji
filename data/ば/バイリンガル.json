          "standard": [
            {
              "text": "彼女は英語とスペイン語を話す完璧なバイリンガルなので、海外との交渉もスムーズだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グローバル企業では、バイリンガルの社員がプロジェクトの成功に不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃から複数の言語に触れることで、自然にバイリンガルになることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "結局のところ、アメリカのソフトウエアを引き込む受け皿となりえたはずのＪＸは、ジュニアが惨敗を強いられる中で、せっかくの日英バイリンガルマシンとしての性格を生かせなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
