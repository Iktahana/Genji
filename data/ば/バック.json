        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駐車場から出る時は、必ずバックギアに入れて慎重に進む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "車の運転免許を取るとき、バックでの駐車が一番難しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "坂道でバックする際は、特に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
