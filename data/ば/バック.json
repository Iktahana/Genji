        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この絵のバックに描かれている山々はとても雄大だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンサートのバックに流れる映像が、音楽と見事に調和している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "写真撮影の際、バックをぼかすことで被写体を際立たせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
