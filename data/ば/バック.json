        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この商品にご満足いただけない場合、全額バックいたします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キャンペーン期間中に購入すると、購入金額の一部がキャッシュバックされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不良品だったので、お店でレシートを見せて全額バックしてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
