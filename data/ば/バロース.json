          "standard": [
            {
              "text": "インターネットで情報をバロースする時間は、あっという間に過ぎる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいプロジェクトのアイデアを得るために、様々なサイトをバロースした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はいつも、オンラインストアでファッションアイテムをバロースするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "コンピューター・メーカーの高千穂バロースの研究所を、浮川との結婚を機会に辞していた初子のプログラマーとしての力は、大きな戦力だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学卒業後、橋本初子は、大型コンピューターメーカーの高千穂バロースに入社し、神奈川県相模原の研究所に配属された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
