        "examples": {
          "standard": [
            {
              "text": "庭の薔薇のつぼみが膨らみ始め、開花が待ち遠しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、まだ固い薔薇のつぼみのように、未来への期待に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花瓶に飾られた薔薇のつぼみは、やがて美しい花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」　一瞬、自分の耳を疑いながらも、アナベルはドレスの胸に挿していた薔薇のつぼみを外して、スペンサー氏の手の上に置いた。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた　死の輪飾りを薔薇のつぼみのやうなお前のやはらかい肩へおくるだらう。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "その両方にばらのつぼみが一つずつ開きかけていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
