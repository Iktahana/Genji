        "examples": {
          "standard": [
            {
              "text": "母が焼いてくれたバターケーキは、素朴で優しい味がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このカフェのバターケーキは、しっとりとした食感が人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、休日に家族のために手作りのバターケーキを焼くのが趣味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お登和嬢は労を厭わず「お茶の時出しますのはテーケーキの外にバターケーキが味も美味しくってようございます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "バターケーキの拵え方は色々ありますが誰にでも容易く出来る法で致しましょう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりバターケーキには玉子一つにメリケン粉が大匙二杯、焼粉が大匙十分の一、バターが大匙に軽く半杯位と覚えていらっしゃればようございます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このバターケーキも早速家で拵えさせましょう。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山が少しく遠慮して「イヤモーお構い下さるな、僕は今お登和さんに珈琲ケーキやバターケーキを御馳走になった処だ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
