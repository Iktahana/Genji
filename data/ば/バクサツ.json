          "standard": [
            {
              "text": "ニュースで、要人がテロリストに「爆殺」されたと報じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画の衝撃的なシーンで、敵が主人公に「爆殺」された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は無実の罪で「爆殺」された友人の復讐を誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はかの村民の妻と姦通していて、妻と共謀の末にその夫を爆殺し、あたかも落雷で震死したようによそおったのであった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "気鋭の中国研究者として知られた同教授は、三重県に本部のある『山岸会』へ行き『共同生活実践の中で中国研究を続ける』という」　一九二八（昭和三）年、中華民国の政治家、張作霖が日本の関東軍によって爆殺された年、新島淳良は生まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "張作霖を爆殺した犯人は支那の便衣隊だと日本軍は発表した。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
