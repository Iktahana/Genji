        "examples": {
          "standard": [
            {
              "text": "「なんでそんなことしちゃったのよ、あんたは本当にバカ女ね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の言うことを全く聞かない彼女を、心の中でバカ女と呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドラマに出てくる意地悪なバカ女の役は、いつも女優の好演が光る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いまごろさ、東京はたいへんな騒ぎだよ」「でもよ、あんな警備じゃあ、バカ女どもも近づけないだろうな」　山崎は他人ごとなので、どうでもいい、という表情だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはそんな男さ、あんな奴の嬶になり手は、金岩の町にも、大野の町にもゐないからね、そんなバカ女はあたしで打止めだらうから、あいつはさがし※つて謝まりにやつて來るだらうて、かへつてやるもんか。",
              "citation": {
                "source": "命",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカの大バカ女、……　あん子はそれでも毎日晝飯にかへる親達のお菜づくりを暗い勝手でこさへた。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのバカ女のために、逃亡の計画も何も、滅茶苦茶にされた世界一の大バカ男が、ここにいる。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
