        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝一番のスキー場には、誰も滑っていないバージンの雪が広がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "まだ人の手が加えられていないバージンの森は、神秘的な雰囲気に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「わー、見て！一面バージンの雪だよ！今日一番乗りだね。」と友人がはしゃいで叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
