        "examples": {
          "standard": [
            {
              "text": "バレーボールの練習で、腕がパンパンになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "体育館でバレーボールの試合が行われており、大きな歓声が上がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バレーボールは、チームワークが重要なスポーツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "窓の外の中庭では、産業戦士が昼の休憩時間らしく、嬉々としてバレーボールをしている。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とお話なさるのを一種の恥辱か何ぞのように考えておられるようでしたが、それでも対抗のテニス、バレーボール、ランニングなぞが近付いて来ますと、先生も級友も、上級の生徒さんまでもが皆、私の周囲に寄ってたかってチヤホヤされるのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十九日（日）　休日　このごろ、バレーボールがはじまった。",
              "citation": {
                "source": "日記",
                "author": "一九四九年（昭和二十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "バレーボールかバスケットボールの球だろうと思うのですけれども、それをぼくの画室の板壁にどしんどしんとぶっつけて、どんな仕組みになっているのか、何点何点と点を取り合う遊びが始まるのです。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
