        "examples": {
          "standard": [
            {
              "text": "製造物責任法により、企業は製品の欠陥による賠償責任を負う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "交通事故では、過失の割合に応じて賠償責任が生じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は弁護士に相談し、自身の賠償責任について確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで近世の社会は従来の「過失責任主義」に対して、「無過失賠償責任」の原則を要求するに至ったのです。",
              "citation": {
                "source": "嘘の効用",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも賠償責任の合理的原因とするに足るべき事例がある。",
              "citation": {
                "source": "嘘の効用",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
