    "definitions": [
      {
        "index": 1,
        "gloss": "even a homely girl looks beautiful at the peak of her youth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
