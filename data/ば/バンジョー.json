        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の弾くバンジョーの陽気な音色が、会場全体を盛り上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バンジョーは、カントリー音楽には欠かせない楽器の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い頃、彼は初めてバンジョーの音を聴いて、その魅力に引き込まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それだのに、その言下に軽蔑し去った江の島へ、密女と共に遊びに出かけると云うのなら、いくら春のバンジョーのように朗らかな気立てのエンミイ夫人でも、腹に据えかねるのが当然です。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤はバンジョーをもっているし、広岡はギターをすこし弾く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "るろうの伊太利人は、バンジョーを胸から提げて道傍に立ちます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に腰かけた黒人の男の音楽者が、白ズボンの片脚でドタドタ床を鳴らしつつ、バンジョーとウクレリーで、南洋的な、官能的な音楽を奏す。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人だけ老年のやかましくしやべり立てる男がいて、これにはマグルトン氏も目を留めずにはいられなかつた……突き刺すような叫び声で、バンジョーやカスタネットの騒音に負けないで鳴りひびく金切声の宗教的予言と言つてもいいくらいであつた。",
              "citation": {
                "source": "青君の追跡",
                "author": "THE PURSUIT OF MR. BLUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_033.png、横441×縦133）入る］図‐33　目の見えぬ娘がバンジョーの一種を弾きながら歌を唄ってゆっくりと町を歩くのをよく見たし、またある場所では一人の男がパンチ・エンド・ジュディ〔操り人形〕式の見世物をやっていた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は音楽上の声音を持っていず、我国のバンジョーやギタアに僅か似た所のあるサミセンや、ビワにあわせて歌う時、奇怪きわまる軋り声や、うなり声を立てる＊。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "六弦、十二弦のギター、五弦バンジョー、ベース、マンドリンを、思うままに奏することができる。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
