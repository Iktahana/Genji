        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議中、彼は重要なメモをバインダーに挟んで常に手元に置いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "イラストを描く際、紙が動かないようにバインダーでしっかりと固定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いバインダーには、学生時代の思い出のプリントがたくさん残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
