    "definitions": [
      {
        "index": 1,
        "gloss": "great strength and energy (of a mighty hero)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまさに抜山蓋世の気概で、どんな困難にも立ち向かっていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その若き将軍は、抜山蓋世の勢いで敵軍を打ち破った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難なプロジェクトを成功に導くには、抜山蓋世の精神が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "裁縫は知らざるも、庖丁を学ばざるも、卿等が其美を以てすれば、天下にまた無き無上権を有して、抜山蓋世の英雄をすら、掌中に籠するならずや、百万の敵も恐るゝに足らず、恐るべきは一婦人といふならずや、そも／＼何を苦しんでか、紅粉を措いてあくせくするぞ。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花顔柳腰の婦女子も或は羅刹夜叉となり、抜山蓋世の勇士も忽ち餓鬼畜生に変ずる。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
