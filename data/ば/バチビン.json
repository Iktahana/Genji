    "definitions": [
      {
        "index": 1,
        "gloss": "Edo-period hairstyle for the common man (the entire head shaved just above the ear, with the remainder tied up in the back)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "浮世絵に描かれた江戸時代の庶民は、「撥鬢」という独特な髪型をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代劇で初めて「撥鬢」の髪型を見た時、その斬新さに驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の演じる役は、「撥鬢」が特徴的な江戸の町人だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "浪六はちぬの浦浪六と号して、撥鬢奴小説で溜飲を下げてしかも高名であった。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白れえじゃねえか、それから、どうした」　貧相な撥鬢奴は、すっかり恐れてしまって、首に手をやって、「えへへ、どうも、とんだことを……」　藤波はいよいよ蒼ずんで、「なにも尻込みをすることはなかろう。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "ねずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ッぽいみじん縞の袷に石帯を固くしめ、片手をふところにして丸腰、弾力のある小肥りな肉じまりに、三十前後の風貌をあらわしてはいますが、市井遊侠のばちびんとも見えず、そうかといって堅気らしくも思われません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
