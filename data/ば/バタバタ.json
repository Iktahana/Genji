    "definitions": [
      {
        "index": 1,
        "gloss": "flapping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鳥が大きな羽でバタバタと飛び立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "洗濯物が風でバタバタと音を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は扇子で顔をバタバタと扇いでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "子供等は何か無性に面白がって餅を握りながらバタバタと縁側を追い廻る、小さいのは父上の膝で口鬚をひっぱる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ署の高等係中村は、もう、蚊帳の外に腰を下して、扇子をバタバタ初めていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「女と云う奴　命懸けで　恋する事知らぬ」　何だか二人の間湿ッぽくなった時、　バタバタと二三人の人が慌ただしく二人を追い越して走る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、其の時、バタバタと駈けて来た武士。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三一　兵士は藁人形のようにバタバタと倒れた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "バタバタ倒れる者が多くなる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は、鶏をも、二本の脚を一ツにくくって、バタバタ羽ばたきするやつを馬の鞍につけて走り去った。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間や、向うの傾斜面には、茶色の鬚を持っている男が、こっちでパッと発火の煙が上ると同時に、バタバタ倒れた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、包囲線をめがけて走せて来る汚れた短衣や、縁なし帽がバタバタ人形をころばすようにそこに倒れた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子はバタバタとチャールストンを踊るだけである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外からバタバタ眼つきをかえて駈け込んで来て、いきなり、ずぶりですからね。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かげろふはお茶をとらうとして出した手を空にあげて、バタバタもがきながら、「あはれやむすめ、父親が、　旅で果てたと聞いたなら」と哀れな声で歌ひ出しました。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かげろうはお茶をとろうとして出した手を空にあげて、バタバタもがきながら、「あわれやむすめ、父親が、　旅で果てたと聞いたなら」と哀れな声で歌い出しました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャ――ッ……」「おそろしいッ……」　と言う震え声の中に女どもが二、三人バタバタと遠退いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関で自分の靴に足を突込むと、バタバタと往来へ走り出て、いずこともなく消え失せて行った。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "助けてくれ」　と言ううちに、バタバタと誰か逃げて行く音がしました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひよどりは、そんなせまい、くらいところへ入れられたので、いやがってバタバタバタバタしました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥かごは、早速、「バタバタ云っちゃいかん。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひよどりは、それでも、まだ、バタバタしてゐましたが、つかれてうごけなくなると、こんどは、おっかさんの名を呼んで、泣きました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれもみんな、はじめはバタバタ云って、手もつけられない子供らばかりだったがね、みんな、間もなく、わしの感化で、おとなしく立派になった。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫んでそれからバタバタ、ノートを閉じました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネネムはあわててバタバタバタバタもがきました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし……」　兵古帯のお加代は針助のあとを、バタバタと追うて行って、「――あんな子あたしに預けてどうするのさ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてバタバタという騒々しい足音と共にお前がひどく狼狽しながら息を切らして姿を現わすと、再び別荘の方へ走って行くのが木の間がくれに見られた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一羽は、門のところに立って、羽をバタバタさせていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラスは、道ばたの木の上にとびあがって、馬車が見えなくなるまで、黒い羽をバタバタさせていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
