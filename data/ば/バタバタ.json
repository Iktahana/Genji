        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちが廊下をバタバタと走っていく音が聞こえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は遅刻しそうになり、階段をバタバタと駆け上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝早くから隣の家がバタバタと忙しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "(falling) one after another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
