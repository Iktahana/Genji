        "examples": {
          "standard": [
            {
              "text": "引退する先輩から、部長のバトンを渡された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームの勝敗は、いかにスムーズにバトンを渡すかにかかっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「さあ、君にバトンを渡すよ。頑張ってくれ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さうしてバトンを渡す。",
              "citation": {
                "source": "新カナヅカヒの問題",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "より若い世代に対して手を差しのべ、それを育成し、激励し、バトンを渡すという事をほとんどしない。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
