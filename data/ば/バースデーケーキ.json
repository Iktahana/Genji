        "examples": {
          "standard": [
            {
              "text": "妹のバースデーには、毎年手作りのバースデーケーキを焼いてお祝いしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ろうそくが立てられたバースデーケーキが運ばれてきて、みんなでハッピーバースデーを歌った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「わー！このバースデーケーキ、すごく大きいね！全部食べられるかな？」と子供たちが目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ハネて、アマンドより一寸寄れといふ電話あり、レスアマへ寄ったら、バースデーケーキ一と、大皿にチキンなど盛りたるものをよこしたから大荷物。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "バースデーケーキを切って食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
