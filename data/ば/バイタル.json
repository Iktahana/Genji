        "examples": {
          "standard": [
            {
              "text": "今日の会議で話し合う問題は、会社の将来にとってバイタルな決定となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの成功には、彼の存在がバイタルな要素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "これらの資源は、国家の経済にとってバイタルな役割を担っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "技巧、内容の問題――里見氏としては、自分のバイタルなことにふれて来たわけだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペインにはアブルカシムのような有名な外科医やイブン・バイタルのように優れた薬理学者がいた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
