        "examples": {
          "standard": [
            {
              "text": "バイキングは、かつてヨーロッパの沿岸地域を襲撃し、交易を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で、勇敢なバイキングの文化について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドキュメンタリー番組で、バイキングの船が再現されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "音に聞えた昔の海賊村上流の水軍でも、又、山のような怒濤をものともしなかったバイキング海賊でも、この水門だけは乗り切れないだろう。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは恐ろしく豪華なザクースカ(*3)（ソ連版バイキング）だった。",
              "citation": {
                "source": "西洋科学は素晴らしい",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
