        "examples": {
          "standard": [
            {
              "text": "深海に潜る「バチスカーフ」の開発は、人類の知識を広げる上で重要な役割を果たした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドキュメンタリーで、未知の生物を探して海底を探索する「バチスカーフ」の映像を見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「バチスカーフ」に乗って深海の世界を旅するのは、きっと忘れられない経験になるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "六月二十一日の第一面トップ記事として、五段抜き初号活字の扱いで、「深海の底の海水は動いていないというのが、これまでの海洋学の定説であったが、バチスカーフによる観測で、根底から覆えされた。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バチスカーフ号は、日本の救いの神といえるかもしれない」　こういう記事である。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題があるとすれば、如何にしてそういう合金を安価につくるかという点にあるので、バチスカーフとは、関係のない話である。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バチスカーフも「廃棄物を捨てるのに反対する有力な立証」など、とんだお土産を残して帰って行ったものである。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
