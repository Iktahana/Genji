          "standard": [
            {
              "text": "聖書には、万軍の主なる神への賛美が数多く記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祈りの中で、彼は万軍の主の御名を呼び、導きを求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "万軍の主の御加護がありますように、と人々は心から願った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "勇壮なる争闘の神――万軍の主たる神――が君臨している圏内から外に出で、戦争地域から外に出でて、彼は自分の足下に、燃ゆる荊の炬火が暗夜のうちに消えてゆくのをながめた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
