        "examples": {
          "standard": [
            {
              "text": "19世紀の哲学において、バイタリズムは科学的還元主義に対する重要な思想潮流だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の生命に関する考察は、バイタリズムの考え方に通じるものがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代生物学はバイタリズムを否定しているが、その思想的影響は今なお残る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これらの考えは医学のドグマティズム（Dogmatism：教条主義）、ヒポクラテスの名前と関連し、この信念は近年のバイタリズムと関連する。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
