        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "このアプリケーションは、バックグラウンドでデータの同期を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い計算処理は、ユーザーインターフェースをブロックしないようバックグラウンドで実行される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンでは、複数のアプリがバックグラウンドで動作していることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
