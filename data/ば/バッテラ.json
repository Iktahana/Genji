        "examples": {
          "standard": [
            {
              "text": "漁港には小さなバッテラがたくさん停泊していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の漁師は、このバッテラに乗って沖へ出ていたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもたちが池で手作りの小さなバッテラを浮かべて遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時分にはボオトの事をバッテラという人も多かった。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草橋の野田屋や築地の丁字屋から借舟をするにしても、バッテラと荷足とは一日の借賃に非常な相違があった。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
