        "examples": {
          "standard": [
            {
              "text": "バスク語は、ヨーロッパで最も古い言語の一つと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人はバスク語の響きに魅了され、独学で勉強を始めたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バスク語の歌を聴いていると、故郷の風景が目に浮かぶようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち、古いフランスの通俗語の上に、プロヴァンス語、スペイン語、イタリー語、地中海の海港の言葉である東方語、イギリス語、ドイツ語、フランス・ロマンとイタリー・ロマンとローマ・ロマンとの三つの種類のロマン語、ラテン語、それから、バスク語、及びケルト語。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にバスク語をとれば――〔gai:ztoa〕（悪き）―― gahisto, 悪魔。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　事実一五七一年に、ラ・ロシェルでバスク語の新約聖書が公刊された。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
