        "examples": {
          "standard": [
            {
              "text": "大勢の観客を前に、彼は緊張で場後れしてしまい、いつもの実力が出せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めての大舞台で場後れしないよう、入念なリハーサルを重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は場後れすることなく、堂々と自分の意見を述べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "文化の上から見ればおくれている素質こそ、文明のある操作に便宜であるという、文化と文明とのきわめて微妙なさか立ちの形があらわされているのである。",
              "citation": {
                "source": "婦人の文化的な創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一日おくれればおくれるだけ、倍加的に立ち直りにくくなるのは決つてゐるが、それもある限度があつて、遂に、今となつては、いくら仕事をする気になつてもおつつかないと云ふ瞬間が来る。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
