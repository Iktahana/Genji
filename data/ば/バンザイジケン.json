          "standard": [
            {
              "text": "韓国の独立運動における万歳事件は、歴史の教科書で詳しく解説されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "1919年に起こった万歳事件は、多くの人々の心に深く刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "万歳事件の精神は、現在も韓国の人々に大きな影響を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その頃は万歳事件のあとで、朝鮮人は極度に弾圧され、全体からすれば朝鮮文化の破壊が遠慮なく行われていた時期であった。",
              "citation": {
                "source": "四十年の回想",
                "author": "『民藝四十年』を読んで",
                "note": "青空文庫"
              }
            }
          ]
        }
