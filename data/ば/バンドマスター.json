        "examples": {
          "standard": [
            {
              "text": "そのオーケストラのバンドマスターは、長年の経験を持つベテランだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は若くして才能を認められ、有名ジャズバンドのバンドマスターを務めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バンドマスターの指示に従い、全員で息の合った演奏を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "契約に際して二等車を指定するのがバンドマスターの義務である。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドマスターの谷とヤツ子はここ一週間ほど反目しあっていた。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幹事ではいらッしゃるのね」「そうなんです」「井田さんに申上げるの筋違いかも知れませんけど、私はね、この文化祭にバンドマスターの谷さんがなさった契約、不満なんです。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつかどこかで」が終ると、赤羽天人は、バンドマスターにちょっと首をすくめてみせ、らせん階段を降りた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
