        "examples": {
          "standard": [
            {
              "text": "車の小さな傷は、近所の板金屋に持っていけばすぐに直してくれるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故で損傷した車を板金屋に預けたら、まるで新車のように綺麗になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昔、板金屋で修行を積み、独立して自分の店を持った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば箱の大きさから、電源の取付け位置、ねじの位置まで標準化されたために、板金屋がＰＣの箱をバンバン作って、世界中に売りまくっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
