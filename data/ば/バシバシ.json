        "examples": {
          "standard": [
            {
              "text": "彼の怒りが爆発し、机をバシバシと叩き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サッカーの試合で、選手たちはボールをバシバシと蹴り合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雨が窓ガラスをバシバシと打ち付け、嵐の激しさを物語っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おまけに竹刀でバシバシと、すこたんを遠慮なしに打ん殴りやがったっけ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の向こうに一つの傘におさまったバアサンと女の子が消えていくのを見届けてから、オレはエノキの葉についたしずくをバシバシ払いながら五階の廊下を歩いた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上、女中の居ないことや何かでヒステリックになり、バシバシ国男に云い気の毒に感じた。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
