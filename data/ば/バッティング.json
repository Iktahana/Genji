        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はバッティング練習でホームランを連発した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームの勝利には、強力なバッティングが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもたちがバッティングセンターで楽しそうにバットを振っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それがおわるとフリーバッティングをやる、それも投球するものは先生である。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女の子だけのチームで、じつはエース・ピッチャーだったとか」「まったくそんなことはないのよ」「でも、相当に練習しないと、あんなふうには投げられない」「前に住んでた町にバッティング・センターがあって、もとプロ野球の選手が経営してるの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は仕事が忙しいし、顔を合わせることすら珍しい状態がいつもあったりするから、自分でまずキャッチ・ボールができるようになろうと、私は思ったの」「だからバッティング・センターへいった」「打つのも面白そうだけど、球がちゃんと投げられないと、つまらないわね。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
