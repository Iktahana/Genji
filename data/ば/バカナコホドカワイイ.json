        "examples": {
          "standard": [
            {
              "text": "いたずらばかりする息子だが、馬鹿な子ほど可愛いと言うから仕方ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生は、手がかかる生徒に対して「馬鹿な子ほど可愛い」と感じることがあるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はいつも失敗ばかりしているが、どこか憎めない。まさに馬鹿な子ほど可愛いを地で行くタイプだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「馬鹿な子ほど可愛いものだと言うけれど、ほんとうにまたあのお袋が可愛がっておるのでござります」お貞は僕にさも憎々しそうに言った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿な子ほど可愛い、と云う心持、卑小なる良人ほど可愛いか？",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
