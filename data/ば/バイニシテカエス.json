    "definitions": [
      {
        "index": 1,
        "gloss": "to repay double the original amount",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今回のプロジェクトで受けた恩は、必ず倍にして返すつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の裏切りには、倍にして返すほどの怒りを感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困っている友人を助けたら、「いつか倍にして返すから」と言ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「……そうすれば、今までのものも全部二倍にして返すよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チケットを倍にして返すから、あたしと踊ってよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国時代のごとき斬込み戦法で三十や五十殺したところで近代兵器の殺戮力はそれを数十倍数百倍にして返すだろう。",
              "citation": {
                "source": "戦争中止を望む",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、お寺なら慈悲があるから頼めば貸してくれるだろう、と早速でかけてかけあってみると、よかろう、その代り利息は倍にして返すのだよ、と二斗の酒をかしてくれた。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、お寺なら慈悲があるから頼めば貸してくれるだらう、と早速でかけてかけあつてみると、よからう、その代り利息は倍にして返すのだよ、と二斗の酒をかしてくれた。",
              "citation": {
                "source": "土の中からの話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "円の中に「心」とした紙に包んで貸してくれるのを、翌年倍にして返す。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "投資してくれりや一年の間にや五倍にして返すがな。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがてえ、これで目が出たら、倍にして返すぜ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to repay x times the original amount",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "投資した金額が倍にして返ってくるような、美味しい話はめったにない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もし彼が約束を破るなら、私はその代償を倍にして返してもらう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "努力すれば努力した分だけ、倍にして返ってくるのがこの仕事の醍醐味だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
