        "examples": {
          "standard": [
            {
              "text": "アメリカの刑事事件では、多くの場合、陪審裁判が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自身の潔白を証明するため、陪審裁判を望んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "陪審裁判は、市民が司法に参加する重要な仕組みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "東京に於る、始めての陪審裁判の記事非常に興味あり。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼朝を主として弁護すれば、彼も意義ある使命をとげた一偉人にちがいないが、陪審裁判ではとても勝目がない。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
