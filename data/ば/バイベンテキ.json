        "examples": {
          "standard": [
            {
              "text": "あの会社は完全に買弁的で、国内市場の利益よりも外国資本の要求を優先している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の政策は、外国の企業に有利な買弁的なものであり、国民の反感を買った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "植民地時代の支配層は、本国の意向に沿う買弁的な態度で民衆を苦しめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何故ならこうして新しい社会に生きられる様になった中国人民、婦人達こそ、日本の人民が婦人が帝国主義の戦争によってどんなに苦しめられ、そして今も尚買弁的な政府のもとで不幸を解決されずにいるかと云う事を真に理解し、同情する事の出来る人々です。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらすべては政権の買弁的性質の増大とともに一般の批判にさらされる立場におかれている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
