        "examples": {
          "standard": [
            {
              "text": "同じ商品でも、色のバリエーションが豊富だと選ぶのが楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この料理は季節ごとにバリエーションが変わり、飽きさせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいスマホケースは、デザインのバリエーションがたくさんある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "洋画バリエーションは色彩にもっと留意して貰いたい。",
              "citation": {
                "source": "マイクロフォン",
                "author": "「新青年」一九三三年七月",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが作り出されるバリエーションは限りなく、語り尽くせないほど存在するとしても、光がそうであるように、私たちはみな一つだったのである。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目はどうやら練習すれば弾けないことはなさそうだが二番目バリエーションになるとかなわない。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "白から黒までのあらゆるバリエーションのどの音階を自分がもって居るか。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
