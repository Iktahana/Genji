    "definitions": [
      {
        "index": 1,
        "gloss": "a Buddha or Bodhisattva taking away suffering and conferring peace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仏教の教えである抜苦与楽の精神は、多くの人々を救ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "僧侶は人々の抜苦与楽を願い、日々修行に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "抜苦与楽の思想は、慈悲の心に基づいている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "我邦でも弘法大師は今に存在して、遍路の行者とまでも云えない世の常の大師まいりをする位の者の間にも時によりて現われて、抜苦与楽転迷開悟の教を垂れて下さるという俗間信仰がある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が抜苦与楽の説法を疑ふ事なく一図に有がたがツて盲信すれば此世からの極楽往生決して難きにあらず。",
              "citation": {
                "source": "為文学者経",
                "author": "三文字屋金平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
