        "examples": {
          "standard": [
            {
              "text": "そのバンドのライブでは、力強いバックコーラスがボーカルの歌声を一層引き立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ソロ曲を歌う時でも、彼女は信頼できるメンバーにバックコーラスを頼むことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この曲のサビのバックコーラスは、聴く人に希望を与えるようなハーモニーが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「ウェ、シェキナ・ベイビー・ナウ」　と高志が歌いだしたので、慶一も即座に乗って、「シェキナッベイビー」　とバックコーラスをつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちおう、野瀬とふたりでバックコーラスをやってみたが、話にならなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
