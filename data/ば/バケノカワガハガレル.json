        "examples": {
          "standard": [
            {
              "text": "酒の勢いで、彼の普段の紳士的な化けの皮が剥がれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窮地に立たされると、人柄の良いふりをしていた部長の化けの皮が剥がれ、本性が見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「うわ、あの人の化けの皮が剥がれた瞬間、見てしまった！」と彼女は驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "また有名な「三人一両損」の裁判でもこれを西鶴に扱わせるとその不自然な作り事の化けの皮が剥がれるから愉快である。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
