        "examples": {
          "standard": [
            {
              "text": "「もう、なんてバーローなんだ！」と彼女は彼が自分の足につまずいた後に叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はそんな重要な詳細を忘れるなんて、バーローだと彼を罵った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あいつは本当にバーローだよ、こんな簡単なこともできないんだから」と同僚がつぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "日頃は舞台でバタフライをチョッピリ附けただけの彼女達が、今日は思い思いのドレスにぴったり姿体をつつんで、帽子なぞをまぶかにかぶっているので、どれがシルバーローズか、マリヤ・マリーかわからない。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんの船に乗って、アラスカのいちばん北のとっさき、バーロー岬から、もっと東の方へ、北極の海を、氷のわれめをつたわって、行ったことがあった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに今記録に残る英国商船のみを辿ってみても、ノーリッジ号一万二千｜噸……ベッドフォード号九千六百噸……カウンテス・オブ・カーナヴォン号六千八百噸……バーロー号三千噸……エクゼター号七千六百噸……クィーン・オブ・サンダーランド号四千八百七十噸……指を屈するだに痛ましき犠牲の数々であった。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
