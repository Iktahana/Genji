        "examples": {
          "standard": [
            {
              "text": "炉の中にくべられた散炭は、ゆっくりと燃えながらじんわりと熱を放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの製法で作られた散炭は、火持ちが良く、料理の風味を引き立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山間部の民家では、暖房や調理に散炭が今でも使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "charcoal sold in bulk (instead of in straw bags)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
