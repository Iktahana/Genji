        "examples": {
          "standard": [
            {
              "text": "揚げたての天ぷらを、大根おろしと生姜を入れた温かい天つゆでいただく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このお店の天つゆは、出汁の香りが豊かで、天ぷらの味を一層引き立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天ぷらの献立に欠かせない天つゆは、醤油とみりんと出汁で簡単に作れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天つゆで召し上るもよし、食塩と味の素を混ぜたやつを附けてもよし、近頃では、カレー粉を附けて食わせるところもある。",
              "citation": {
                "source": "下司味礼讃",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            }
          ]
        }
