        "examples": {
          "standard": [
            {
              "text": "引っ越しの際には、転出先に新しい住所を届け出る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "郵便物の転送サービスを申し込む際、転出先情報を記入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は転職により、以前の勤務地とは異なる転出先へ赴任した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鶴見はやっとの思いで、転出先の農家に帰り著いた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに昨年の秋になって、転出先から疲れ切った翼を休めにもとの古巣に戻って来て、さて今年の夏になって見ると、裏庭を畑におこしたそのあとの土に、この久しく忘れていたとんぼ草が一面にはびこり出したのを発見した。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
