        "examples": {
          "standard": [
            {
              "text": "天永年間には、多くの文化財が創建された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古文書は天永年間のものと推定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天永の時代、都では疫病が流行し、多くの人々が苦しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "清洲近在の天永寺の天沢という坊主が関東へ下向の途中、甲斐を通った。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また良俊といふ公卿の清衡をたよつて陸奧に下向したのは、これ五位以上の者猥りに京畿を離るべからずとの制禁を蔑如し、國家に背きて清衡に從つた者であるとて、其廉を以て相當の制裁を加へむとの僉議があつたことが、中右記天永二年正月廿一日の條に載つて居る。",
              "citation": {
                "source": "日本史上の奧州",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
