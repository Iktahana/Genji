        "examples": {
          "standard": [
            {
              "text": "山頂から眼下に広がる雲海と朝日のコントラストは、まさに天下の景であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その景勝地は、古くから文人墨客たちが天下の景と称えて止まない場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おーい！ここから見える夕日は、間違いなく天下の景と呼ぶにふさわしいぞ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あの那覇にある辻原の如き天下の景観と呼んでよいでしょう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
