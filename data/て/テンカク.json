          "standard": [
            {
              "text": "漢字の点画を一つひとつ疎かにせず、楷書体で丁寧に書き進める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "書道の先生から、この文字の右はらいの点画が少し短いと指摘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、おじいちゃんの書く字は点画が力強くて、見ていて気持ちがいいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "今や、茂太郎は、星を一層深く見ることを覚え、そうして眺めた星の一つ一つを点画として、自分としての空想を描き出すことで、毎夜の尽くることなき楽しみを覚えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
