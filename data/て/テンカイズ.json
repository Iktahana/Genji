        "examples": {
          "standard": [
            {
              "text": "リフォームの打ち合わせで、壁紙の張り分けを確認するために展開図を作成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "建築士が示した部屋の展開図には、コンセントの位置まで詳細に記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平面図だけでは分かりにくい家具の高さ関係を、展開図で詳しくチェックする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "巻き尺で林檎の高さと直径を計った僕は、適正と思われるゆとりを持たせた大きさの箱の展開図を、鉛筆でボール紙に書いた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "貼り合わせるために必要な糊しろを、間違えないように展開図に加えた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
