        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "事態が悪化していくのを、ただ手をこまねいて見ているしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "目の前で困っている人がいるのに、手をこまねくわけにはいかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "上司は部下の失敗を叱ることなく、ただ手をこまねいて見守っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
