        "examples": {
          "standard": [
            {
              "text": "企画書の作成には、事前に用意されたテンプレを利用すると効率が良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレポートのフォーマットは、会社の規定テンプレに従っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ウェブサイトのデザインも、いくつかのテンプレから選んで作成できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第二はさまざまな電子本の体裁のテンプレート集。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にあらかじめ用意されているテンプレートを用いれば、本作りの作業自体には頭をひねる要素はほとんどない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
