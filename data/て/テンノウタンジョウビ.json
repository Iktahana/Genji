        "examples": {
          "standard": [
            {
              "text": "天皇誕生日は国民の祝日であり、多くの人が休日を楽しむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎年2月23日は、天皇誕生日として国を挙げてお祝いされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天皇誕生日の一般参賀には、国内外から多くの人々が訪れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（天皇誕生日を迎えるにあたり、来客はしきりと至り、公使館の前では馬によって塵が舞い上がる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の丸ぐもり　沖繩島民にたいし、二十九日の天皇誕生日には、日の丸の旗を掲げるもさしつかへなし、と米軍側の指示があつたと、新聞に小さく出てゐた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老歌人　天皇誕生日である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇誕生日で人出多く、立ち通しでフーフー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
