        "examples": {
          "standard": [
            {
              "text": "てんかん患者への偏見をなくすため、正しい知識を広める啓発活動が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近では、てんかん患者でも一定の条件を満たせば運転免許の取得が可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学校側は、てんかん患者の生徒が安心して学べるよう適切な支援体制を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ドストエフスキーは精神医学者ではなかったが精神病質者、てんかん患者、犯罪人、を巧みに記述した。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身が精神病質者であり、てんかん患者であった事実は彼の感覚を鋭くしたかも知れない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
