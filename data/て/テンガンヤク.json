        "examples": {
          "standard": [
            {
              "text": "診察の結果、ドライアイだと言われ、新しい点眼薬を処方された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンタクトレンズを装着したまま使える点眼薬を探しているんですが、どれがいいですか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もし炎症がひどくなったら、この点眼薬を１日３回さしてください」と先生に言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "翌朝起きて顔を洗ってくると、彼女は手提げの中から点眼薬を出して、ごろりと仰向けに臥た。",
              "citation": {
                "source": "独り旅",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説書きが眼を奪われたら、運の尽きと思うから、手を消毒する石炭酸と、点眼薬と、黒い雪眼鏡を万田先生から貰って、念入りに包んで送ってくれ。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "云々…………」　そういった手紙の返事として妻から送って来たのが、この点眼薬と、消毒薬と黒眼鏡であったのだ。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がひどくて、殆んど焦点がきまらない有様なので、いつか目を悪くした時慶応で貰った点眼薬をまた貰って、この二日程はふすまのワクが真直にみえる様になりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
