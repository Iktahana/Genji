        "examples": {
          "standard": [
            {
              "text": "歴史の教科書で、シルクロードの主要ルートである天山北路について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隊商たちは、厳しい自然条件の中、天山北路を越えて西方へと交易を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天山北路沿いには、古代の交易都市の遺跡が点在している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし私のように、天山北路の沙漠の中に埋れていた絵に凝っていれば、そういう気骨は折れないので、気持は甚だ楽である。",
              "citation": {
                "source": "八戒に遭った話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
