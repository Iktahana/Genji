        "examples": {
          "standard": [
            {
              "text": "彼の悪行はすぐに露見し、天罰覿面とはこのことかと人々は囁いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "他者を陥れたその報いは、まさしく天罰覿面というべき結果として現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "悪いことをすれば必ず報いがある、天罰覿面を目の当たりにした気分だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これを採用するときは天罰覿面、乗客は反省するであろう。",
              "citation": {
                "source": "発明小僧",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天罰覿面よ」「こら、なにをいっとるか。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天罰覿面と云いましょうかな。",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天罰覿面は仕方がないさ」　他巳吉は左門を責めてゐるのであつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
        }
