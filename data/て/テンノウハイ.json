        "examples": {
          "standard": [
            {
              "text": "サッカーの天皇杯は、アマチュアからプロまで全てのチームに参加資格がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "全国高校野球選手権大会の優勝校には、深紅の優勝旗と共に天皇杯が贈られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天皇杯は、様々なスポーツで最高の栄誉とされるカップである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえば各種のスポーツや競馬などに、天皇杯や天皇賞は贈られているが、賞と共にグランドに臨まれることはないし、そこの民衆と一しょになって共に一日を遊ぶという時間もお持ちになっていないようだ。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
