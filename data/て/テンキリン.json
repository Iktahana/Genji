        "examples": {
          "standard": [
            {
              "text": "昔の人は、天気輪を見て天候を予測していたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの建物には、屋根に美しい天気輪の装飾が施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天気輪は、天体の運行と地上の気象を結びつける象徴だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "〔五、〕天気輪の柱　牧場のうしろはゆるい丘になって、その黒い平らな頂上は、北の大熊星の下に、ぼんやりふだんよりも低く連って見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまっ黒な、松や楢の林を越えると、俄かにがらんと空がひらけて、天の川がしらしらと南から北へ亘ってゐるのが見え、また頂の、天気輪の柱も見わけられたのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、頂の天気輪の柱の下に来て、どかどかするからだを、つめたい草に投げました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔六、〕銀河ステーション　そしてジョバンニはすぐうしろの天気輪の柱がいつかぼんやりした三角標の形になって、しばらく蛍のやうに、ぺかぺか消えたりともったりしてゐるのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」博士はちょっとジョバンニの胸のあたりにさわったと思ふともうそのかたちは天気輪の柱の向ふに見えなくなってゐました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病技師〔二〕あへぎてくれば丘のひら、　　　　地平をのぞむ天気輪、白き手巾を草にして、　　　　　　をとめらみたりまどゐしき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、天気輪の柱　牧場のうしろはゆるい丘になって、その黒い平らな頂上は、北の大熊星の下に、ぼんやりふだんよりも低く連って見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまっ黒な、松や楢の林を越えると、俄かにがらんと空がひらけて、天の川がしらしらと南から北へ亘っているのが見え、また頂の、天気輪の柱も見わけられたのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、銀河ステーション　そしてジョバンニはすぐうしろの天気輪の柱がいつかぼんやりした三角標の形になって、しばらく蛍のように、ぺかぺか消えたりともったりしているのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　天気輪の柱　牧場のうしろはゆるい丘になって、その黒い平らな頂上は、北の大熊星の下に、ぼんやりふだんよりも低く、連なって見えました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまっ黒な、松や楢の林を越えると、にわかにがらんと空がひらけて、天の川がしらしらと南から北へ亙っているのが見え、また頂の、天気輪の柱も見わけられたのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　銀河ステーション　そしてジョバンニはすぐうしろの天気輪の柱がいつかぼんやりした三角標の形になって、しばらく蛍のように、ぺかぺか消えたりともったりしているのを見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもうそのかたちは天気輪の柱の向こうに見えなくなっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
