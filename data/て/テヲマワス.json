        "index": 1,
        "gloss": "to use one's influence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は警察の上層部にまで手を回して、事件をもみ消そうと画策した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「事前に手を回しておいたから、明日の会議はスムーズに進むはずだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライバル社より先に契約を取るため、あらゆるルートに手を回した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それで取っ手を回すと同じリズムでキュル／＼／＼と一種特別な轢音を立てるのであった。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズは笑いながら、その子の耳の後ろに手を回すと、その顔から面をはぎ取った。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（女の胴に手を回す）ね、そうでしょう、もうこうなったら否も応もない、どうしたって逢わずにゃいられないんだ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "番兵をつとめるほどの虎ですから、人間のようにとってをまわす芸当だって、できないとは言えません。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹に、とってをまわす知恵があるのでしょうか。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とってをまわすくらいは、ちゃんと知っているにちがいありません。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
