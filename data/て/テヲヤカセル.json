        "examples": {
          "standard": [
            {
              "text": "彼はわがままばかり言って、周囲の人々をいつも手を焼かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「これ以上お母さんを手を焼かせるんじゃないよ」と父親が叱った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新入社員の教育係は、自由奔放な新人に手を焼かせられているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "目的地たる屯営に到着した時、「フー」が何か面倒を起こして当局の手を焼かせることになった。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どういう奴とこの上海で連絡を取ったか、素直に言ったらどうだ」「そう手を焼かせるな」「強情な奴だ」　口々に刑事は言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
