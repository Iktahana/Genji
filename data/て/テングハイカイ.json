    "definitions": [
      {
        "index": 1,
        "gloss": "parlour game in which three people each write one line of a 5-7-5 poem (without seeing the other lines; often producing humorous results)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忘年会で天狗俳諧をやってみたら、予想外に盛り上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天狗俳諧は、それぞれの個性がぶつかり合って面白い作品が生まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の天狗俳諧の句は、いつも意表を突くものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二人の間にわだかまった事をときたいと云う様にそれからは出来るだけ陽気に天狗俳諧をしたりしてさわいだ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙと二人天狗俳諧をして遊ぶ。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　或る夜秀吉はお伽衆を集め、天狗俳諧をやっていた。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
