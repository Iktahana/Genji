        "examples": {
          "standard": [
            {
              "text": "古い天体図には、現代の分類とは異なるユニークな星座の絵が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キャンプ場で天体図を広げ、目の前の星空と見比べながら星座を探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分の部屋の天井に、光る塗料で精巧な天体図を描いて楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これがために用いた天体図や写真に含まれていた星の数は百万を少し越えている。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内には、剥製にした動物の標本が処も狭く並んで居り、広々とした壁にはいろいろの天体図や気象図などが掲げてあった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "関ヶ原戦後の京都においてさえも、神父の天文や地理に関する話をきき、天体図や地球儀を見せて貰いに来るものが非常に多かったという。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
