        "examples": {
          "standard": [
            {
              "text": "街のシンボルであるテレビ塔が、夜になると鮮やかにライトアップされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テレビ塔の展望台からは、天気が良ければ遠くの山々まで一見できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地上デジタル放送への移行に伴い、新しいテレビ塔が建設されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "火星へ行ける日が来ても、テレビ塔の上から落ちる一枚の紙の行方はわからないのである。",
              "citation": {
                "source": "科学の限界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の新設中のテレビ塔では、中京人のこの寂寥感は、到底、癒やしきれるものではないらしい。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百メートル道路やテレビ塔の陰翳に茶道が盛んであるなども、何か現代名古屋図の矛盾のようでいて、そのくせ、おかしくないのである。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
