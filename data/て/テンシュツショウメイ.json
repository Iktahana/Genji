        "examples": {
          "standard": [
            {
              "text": "役所で転出証明書を発行してもらい、新しい住所の役場に提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転出証明は、住民票を移す際に必要な書類だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "転出証明書がないと、転入の手続きができない場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "転入は転出証明だけでは駄目なので、一寸暇どるやうです。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場の机で、老人は転出証明を書いてくれた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいパンパンというものは移動がはげしいし、転出証明もない者が多く、たいがい選挙権を持たない連中だ。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
