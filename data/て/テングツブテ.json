    "definitions": [
      {
        "index": 1,
        "gloss": "rock flying out of nowhere (while in the mountains)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
