        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "書道の先生は、筆の転折の角度について細かく指導してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この文字の転折は力強く、書の全体を引き締めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は転折の練習を何度も重ね、美しい線を書けるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
