    "definitions": [
      {
        "index": 1,
        "gloss": "changing direction (esp. of a ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐の中、船は巧みに転折して危険を回避した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な転折点に差し掛かり、彼は慎重に次の行動を考えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人生にはいくつかの転折があり、そのたびに新たな道が開ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "川は尾久の渡より下二十町ほどにしてまた一転折して、千住製紙所の前を東に流る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○綾瀬川は荒川の一転折して南に向つて流るゝところにて、東より来つて会する一渠の名なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "川はこゝに至つて復一転折して南西に向つて流る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は湾※と曲り込んで、そして転折して流れ去る、あたかも開いた扇の左右の親骨を川の流れと見るならばその蟹目のところが即ち西袋である。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
