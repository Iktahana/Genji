        "examples": {
          "standard": [
            {
              "text": "清涼殿の殿上の間は、天皇が政務を行う重要な場所であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "殿上の間では、夜ごと歌会や管弦の宴が催されたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は殿上の間に招かれ、天皇に直接拝謁する栄誉を得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "公式のお召しではなくて、殿上の間に来ておいでになったのに仰せが下ったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘解由小路中納言｜経房、検非違使別当左衛門督実家の両人は、院の殿上の間の板縁に出ていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして八月十六日、前内大臣宗盛以下平家一門百六十余人の官職をすべて剥奪、殿上の間から除籍された。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
