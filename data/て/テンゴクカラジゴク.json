        "examples": {
          "standard": [
            {
              "text": "宝くじに当たったかと思いきや、詐欺だと分かり天国から地獄へ突き落とされた気分だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合は最終回に逆転され、まさに天国から地獄のような展開だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "期待に胸を膨らませていたが、結果は裏目に出て天国から地獄を味わった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こうして天国から地獄へと真っ逆さまとなったＤＲＩ在籍当時、吉本さんは同社版のＷｉｎｄｏｗｓにあたるＧＥＭに取り組んでいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで天国から地獄の底へ逆落しにされたようなものではございませんか。",
              "citation": {
                "source": "機密の魅惑",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
