        "examples": {
          "standard": [
            {
              "text": "ロケットの打ち上げを成功させるには、点火薬の品質管理が極めて重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "花火師は、美しい大輪の花を咲かせるために特製の点火薬を調合する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い不発弾を処理するため、慎重に点火薬をセットして爆破作業を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は自分の鉄砲の点火薬を調べてみた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれでは本気で一合戦やらなければなるまいということがわかりかけて来たので、自分の点火薬を調べた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はちょっと暇が出来たので、時を移さず自分のピストルの点火薬を換え、それから、一挺がいつでも使えるようになると、念に念を入れるために、もう一挺の方の弾薬を取り出して、それも初めから新たに装填し直しにかかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
