        "examples": {
          "standard": [
            {
              "text": "木材の汚れを落とすために、布に少量のテレピンを染み込ませて丁寧に拭いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テレピンは揮発性が高いので、使用するときは必ず換気を良くしなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "画材屋で「テレピンを一本ください」と言うと、慣れた手つきで奥から出してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "兵営の普請に足りなくなったからテレピン油を工場から買って来て呉れ。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「土木建築設計工作等請負　ニジニ・ハラウ、ふん、テレピン油の工場だなんて見るのははじめてだぞ。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして松林のはづれに小さなテレピン油の工場が見えて来ました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵営からテレピン油を取りに来ました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間にすっかり縛られて車が青くなり樽が見えなくなってもう誰が見ても山から松枝をテレピン工場へでも運ぶとしか見えなくなった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰度強い印象派の色彩のかげに微かなテレピン油の潤りのさまよふてゐるやうに彼の集のかげに今なほ見出されずして顫へてゐたものである。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しき思われは探しぬ、色黒き天鵞絨の蝶、日ごと夜ごとに針を執り、テレピンを執り、かくて殺しぬ、突き刺しぬ、ちぎり、なすりぬ。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで妾は豚の脂をつけたり、テレピン油をぬったりしてみたのですがね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はテレピン油で拭いた後のグリインの浸染んだ掌を開いて良人に見せました、「リラへ行つて洗ふさ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレピン油の入れ物を嗅いでくしゃみをし、即座に退却してテーブルに乗った。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は卵黄、パラ油、テレピン油からなる軟膏を持っていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
