        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は気分屋で、まさに天気屋といった性格だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの天気屋の部長は、機嫌がいいと仕事もスムーズに進むんだけどね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天気屋な彼女に振り回されるのはもう嫌だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "相変らずのお天気屋だよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴方はお天気屋だもの、　そいで又我ままなんだもの、　あの女だって思いがけない処に気をつかって居るんですよきっと。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、　私のお天気屋と我ままと『かんしゃく』さえ御承知なら。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもね、　あの女はほんとうに感情家で我ままで御天気屋なんだよ。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんとすねたり、うんと甘えたり、手のつけられないお天気屋になつてやりたい。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂の主婦の姉の子だが、主婦なる女人が天下に稀なお天気屋で、朝は娘を甘やかし、夜は娘を打擲するめまぐるしい変転ぶり。",
              "citation": {
                "source": "探偵の巻",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天気屋だから、さて娘が帰らないとなると、騒ぎが芝居もどきになる。",
              "citation": {
                "source": "探偵の巻",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんとすねたり、うんと甘えたり、手のつけられないお天気屋になってやりたい。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
