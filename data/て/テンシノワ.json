        "examples": {
          "standard": [
            {
              "text": "彼女の美しいブロンドの髪には、光が当たるとまるで天使の輪のように輝く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "舞台の照明が主人公の頭上に当たり、幻想的な天使の輪が浮かび上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絵画の中の聖人たちは、常に頭上に天使の輪が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "パウロは天上にて得し知識をばディオニュシオスに傳へたりと信ぜられしによりてかく〔輪〕天使の輪第二十九曲ベアトリーチェ天使を論ず一―六ベアトリーチェの默しゝ間の極めて短きを譬へにて表はせり。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
