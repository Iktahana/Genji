        "examples": {
          "standard": [
            {
              "text": "「お客様は神様」というのが、この店の店是だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どの従業員も、店の店是をよく理解し、実践している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい店長は、これまでの店是を見直し、新たな方針を打ち出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これはいかにも人情味のない頑固なやり方のようだが、私は店是というものを国の掟の如く峻厳なものにしておきたいという私の主義と、一つは前にも述べた如く人に縋らずに独立不羈で商売をやって行きたいという信念からであった。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "船と陸とには、おしげもなく灯火がてんぜられ、まるでみなとまつりの予行演習であるかのようにおもわれた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
