        "examples": {
          "standard": [
            {
              "text": "最近のテレビドラマは、漫画を原作にした実写化作品が非常に多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "毎週楽しみにしていたテレビドラマがいよいよ最終回を迎えるので、今日は直帰する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はテレビドラマの端役として出演したのをきっかけに、一躍スターダムにのし上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「もう一度やり直そうよ」――浩はその台詞から刑事物のテレビドラマを思い浮かべる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一度やり直そうよ」――テレビドラマの中の凶悪犯の女は言い、現実の世界の不良少年の母親は復唱する……。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
