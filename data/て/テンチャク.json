        "examples": {
          "standard": [
            {
              "text": "目薬をさすときは、薬液が溢れないように一滴ずつ正確に点着させることが重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "微細な電子部品の接点に、専用の接着剤を自動機で精密に点着させる工程を見学した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "害虫の発生している箇所にのみ殺虫剤を点着させることで、環境への負荷を最小限に抑えることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一時三十分出発、一時間にして二千九十八米の三角点着。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒部川の左岸を遡り、崖上を迂廻すること二度、本流を徒渉すること三回にして、五時三十分、東沢の合流点着。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
