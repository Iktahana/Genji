        "examples": {
          "standard": [
            {
              "text": "故郷を離れて天涯万里、遠く異国の地で働く彼は、毎晩のように家族を思い出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "天涯万里の彼方から届いた一通の手紙が、彼女の沈んでいた心を温かく包んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "渡り鳥たちは天涯万里の旅を続け、今年も無事に北の湖へと戻ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いやしくもこの気慨あるものは、自国を遊園とし、海外を工場とし、よろしく遠く天涯万里に向かって雄飛活躍せざるべからず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる日本人の一人もおらざる天涯万里の異域に単身突入して、成功の彼岸を見るに至るまでの苦心は思い知るべし。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "がこうして二度やってきて見るとあんまり永い忘却、あるいは天涯万里の漂遊が、何か一つの原因であったような感じもする。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
