[
  {
    "uuid": "95b48809-ac87-5b17-99eb-fd568c89c180",
    "entry": "生い茂る",
    "reading": {
      "primary": "おいしげる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
