[
  {
    "uuid": "b8bc88da-e87d-54ba-9468-4e7c99c01a88",
    "entry": "御神籤",
    "reading": {
      "primary": "おみくじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
