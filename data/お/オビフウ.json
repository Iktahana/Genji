        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "家内にも言いきかせ、とにかく之は怪しいから、そっくり帯封も破らずそのままにして保存して置くよう、あとで代金を請求して来たら、ひとまとめにして返却するよう、手筈をきめて置いたのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、新聞の帯封に差出人の名前を記して送ってくるようになった。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、「金木町のＷ」と帯封に書いてよこすようになった。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日九時に出社すると、いきなり郵送用の帯封へ宛名を書かされた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時になると、帰って再び帯封を書き出した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "中指に桃色のペンだこが出来たのを、情けない気持で見ながら、年中帯封を書かされるのなら、やり切れぬなと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――どないや、帯封何枚ぐらい書けた？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売人なみや」　褒められたと思ったので、「帯封書きはえらいですね」と、微笑しながらお愛想にそう言うと、「明日からほかの仕事してもらうぜ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "月給はろて帯封書いて貰てたらうちの損や。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日一日中帯封を書いて、五時過ぎ、台所で手を洗って、「そんなら、帰らせていただきます」くたくたになって帰った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長と園井が印刷所へ出張校正に行った留守中、豹一が帯封を書いていると、妻君が奥から出て来て、「毛利はん。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙の代筆が済むと、相変らず帯封を書き続けるのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへ帯封を巻きつけて糊をつけるのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ふと社長の妻君がせっせと帯封に糊をつけているのを見た途端、その光はあっけなく消えてしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり帯封書きだったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻は店前に出してある、帯封のしてある本を取り上げて、店番の年増にこう云うのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか当節は警察がやかましゅうございまして」　帯封の本には、表紙に女の顔が書いてあって、その上に「笑い本」と大字で書いてある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には一口噺か何かを書いて、わざと秘密らしく帯封をして、かの可笑しな画を欲しがるものに売るのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と仰りながら、一緒に郵便函の中に這入つてゐた何かの雑誌の帯封を切つて、ところ／″＼を御覧になる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれ以外の日にもよく遊びに行ったが、ことに下宿を登坂や田中のいた月島に移してからは、ほとんど毎日学校の往復に寄って、雑誌の帯封を書く手伝いなどして一日遊んでいた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その懇話会賞も制定され、その名の叢書も刊行され、それらの小説集の表紙には時の農林大臣有馬頼寧の写真が帯封の装飾として使われるという前例のない有様を呈した。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず眼を惹いたのは、一ト区切ずつ帯封を施した厚ぼったい紙幣束であった。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい五円紙幣二十枚、括った帯封には、親戚の老人の手で、一金一百円也　　　　永代経料×　×　寺　殿　　　　　　　　　　×　×　家　と細字で書かれてあった。",
              "citation": {
                "source": "棄てる金",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧館の二階の日本間に、机を八ツ程あわせて、私たちは毎日せっせと帯封書きだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の青インクが生かわきなので、帯封をするたびに、腕から手がいれずみのように青くなる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "のりをつけるもの、帯封を張るもの、県別に束ねるもの、戸外へ運び出すもの、四囲はほこりがもうもうとして、みな、たすきがけで、手拭の姉様かぶり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また読みたいとも思わず、私は、大正十一年の秋、やっと職をみつけて、赤坂の小学新報社と云うのに、帯封書きに傭われて行きました。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　襯衣の釦　某君が他の同志たちと共に、懸命に帯封書きをやっていた時のことである。",
              "citation": {
                "source": "条件反射",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の非合法性を持った印刷物の帯封で、その晩のうちに片付けなければならない状勢にあった。",
              "citation": {
                "source": "条件反射",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが次第に自分で気になって、片手で胸元を押え押え帯封書きをしていたが、またすぐに痩せた胸が覗き出す。",
              "citation": {
                "source": "条件反射",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
