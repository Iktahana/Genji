        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「おっちゃんあっこ、おっちゃんあっこ、はんぶんはんぶん」　といいつついきなり父に取りつく。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚がへんだよおんちゃん」「へんだ、おっちゃんへんだ」　奈々子は父の手を取ってしきりに来て見よとの意を示すのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子は水鉢の縁に小さな手を掛け、「きんご、おっちゃんきんご、おっちゃんきんご」「もう金魚へにゃしないねい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんもといい、あっこといい、おっちゃんといったその悲しい声は永遠に父の耳を離れてしまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっちゃんにあっこ、おっちゃんにおんも、おっちゃんがえい、お児ちゃんのかんこ、お児ちゃんのかんこがえいと声がするかと思うほどに耳にある彼の子の言葉を、口にいいさえすればすぐ涙は流れる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これどこの人」「それゃあよそのおっちゃん」振向きもせず相変らずせっせと老人はその児を洗っていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「おっちゃん、煙草の火貸してんか」　ドスンドスンと歩いていた木崎の前に、娘はバスガールのように足をひらいて、傲然と立ちはだかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、娘は三十芸者のように、器用に火をつけて、「おっちゃん、どこまで行きはるのン……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おっちゃんは……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おっちゃん、アパートでひとり……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、その人うんと言ってくれるかな」「ええおっちゃんやさかい、うちを助けてくれはるやろ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、かたわらに顫えていた十位の女の子が、「おっちゃん、うちも中イ入れて」　と、寄って来た。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おっちゃん、うちおなかペコペコや」「おっさんもペコペコや。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン食べよか」「おっちゃん、パン持ったはるのン？",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は夢中になって、ガツガツと食べると、「おっちゃん、うちミネちゃん言うねん。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっちゃん、ミネちゃんのお父ちゃんやな。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、僕が南方へ行ってしまったら、寂しがってくれる人がいるかな」葉子「喜ぶ人もいるわ」十吉「誰だ、そいつは」葉子「夜店出しのおっちゃん」この時、店の間の小鳥が突如鳴声を立てる。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜店出し「なんや、あんたか」葉子「おっちゃんも乗ったはったの」夜店出し「大阪からずっと立ち通しやったんや。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっちゃんが今朝土間で新井の伯母が川さはまって死んだそうだ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京新聞さ書かれたら伯母も成仏すっぺと云ったら、おっちゃんがおっかない顔してコケ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓馬夫人もまた近所の人たちに「おっちゃんが若い時東京で生ましてきた子なのやで」と言っていた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちが敵機なんでしょうね」「サア迚も見えませんね、白い布の尾をふき流して居りますそうですが」暫く立って見ていたら「あすこへバク弾を落したよ」と、呑気そうに太った防護団のおっちゃんが云っている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなにおっちゃんに見えたんでしょうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族づれのおっちゃんやおばちゃんは、とっくにはじまっている秋に早くも調子を合わせ、セーターやカーディガンを着こんでいる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
