[
  {
    "uuid": "f813a36b-1c27-54b7-8828-2459d4776469",
    "entry": "お勤め",
    "reading": {
      "primary": "おつとめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's business",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "字を書くことの上手な人はこういう機会に存分に筆を揮って、自分の筆端からほとばしり出る曲折自在な線の美に陶酔する事もあろうが、彼のごとき生来の悪筆ではそれだけの代償はないから、全然お勤めの機械的労働であると思われる上に、自分の悪筆に対する嫌忌の情を多量に買い込まされるのである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これなんだね」「鉄道馬車」「これなんだね」「お勤め人、洋服を着て鞄持って」　四郎はその絵姿をつくづく眺めていたが、やがて言った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ中国筋のある御大名と申すだけのことで……」「あなた様のお勤めは……」「表使を勤めて居ります」「左様でございますか」と、半七は微笑んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後でしたからお勤めはありません。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○科にお勤めになっていらっしゃる……成る程。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勤めがらに對しても、聊か取つくろはずばあるべからずと、胸のひもだけはきちんとしてゐて……暑いから時々だらける。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、やはり市役所の方へお勤めなのですか？",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子もためになるお客だから、せいぜいお勤めなさいなぞと、福井楼が出していたある出先の女将に言い含められ、春よしのお神から聞いて、若林のあることも薄々承知の上で出され、すでに三四回も座敷を勤めていたが、そのたびに多分の小遣いも貰い、そうそうは若林に強請りにくい場合の埋合せにしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は、もう何のお勤めもしなくていいのよ。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お勤めがすむと、老婆の心は餅に往った。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何しろこの雪でしょう、それに私などと違って、あなたはお勤めがおありになりますから。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りですな、先生なにからお話して宜いやら、それよりか先生、何故あなたはお勤めも学問の方もおよしになってこちらへ御隠退なさいましたか、お知らせも下さらないで」　荘子は久し振りで支離遜に逢って嬉しくもあったが直ぐそれを聞かれるのはすこしうるさかった。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どなた様も日々のお勤め御苦労に存じます。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これからまた夜學のお勤めですか」と、千代子がこわい顏で冷かすのを、いつも聽き捨てにして出る。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはどこにお勤めでしたの？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもお勤めの邪魔をして気の毒じゃ、すぐお暇をいたそう」　三左衛門は僧の人の来るのを嫌うのは、勤行の邪魔になるから嫌うのだと思った。",
              "citation": {
                "source": "竈の中の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『最近までコクソン＆ウッドハウスにお勤めで？",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ストレーカは長らくこちらにお勤めで、ロス大佐？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子兄弟相変らず揃うてお勤めなさる、めでたいことじゃと言うのでござります。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "男だって官吏になって、お役所のお勤めというところまでは、だれもできますが、実際適所へ適材が行くということはむずかしいものですからね。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勤めに出れば出る、帰れば帰るで、役所のこと、友人や先輩のことなどで話したいことがたくさんあるんですから、それは他人には言えません。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの従者は寺へ帰して惟光だけを供につれて、その山荘をのぞくとこの垣根のすぐ前になっている西向きの座敷に持仏を置いてお勤めをする尼がいた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢へ女王が斎宮になって行かれたことはあっても、加茂の斎院はたいてい内親王の方がお勤めになるものであったが、相当した女御腹の宮様がおいでにならなかったか、この卜定があったのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "また昼夜に六回の仏前のお勤めをいたしますのにも自分の極楽往生はさしおいて私はただこの子によい配偶者を与えたまえと祈っております。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうずっと前からお悪いのを我慢あそばして仏様のお勤めを少しもお休みになりませんでしたのが、積もり積もってどっとお悪くおなりあそばしたのでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうした貴公子に愛してもらえば、ただの女官のお勤めをさせるより私はそのほうへ上げてしまいたいくらいだ。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、父は学校のおつとめの帰りに、岩見先生のお家へ、お礼とお詫びにあがったようでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、その近くには修道院があって、若い娘さんが、何人もおつとめをしていた。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての人の幸福のために戦うと云うところにあれらの意義はあるのです）　しかし芸術家となった以上、そこにいわゆる社会人のおつとめ以外、もっと大変な芸術というすべてのモラルやカテゴリーや時代を超越したものにぶつかって行くのです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
