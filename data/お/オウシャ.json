          "literary": [
            {
              "text": "往者長尾｜景勝ノ部将｜甘糟備後ノ拠ル所タリ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ、不老国の往者たる可き担保として、見る可きものなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "廉直の・（五三）邪枉の臣に容れられざるを悲み、（五四）往者得失の變を觀る、故に（五五）孤憤・五｜蠧・内外儲・説林・説難、十｜餘萬言を作る。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "老莊申韓列傳第三",
                "note": "青空文庫"
              }
            }
          ]
        }
