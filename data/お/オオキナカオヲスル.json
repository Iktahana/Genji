    "definitions": [
      {
        "index": 1,
        "gloss": "to look as if one is important",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし世間ではやはりかういふ「お手本」を鵜呑みにして、内心はともかく、表面だけはそのお手本のやうに取りつくつて、大きな顔をするといふ傾向があるやうです。",
              "citation": {
                "source": "宗教と科学についての所感",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがただ口だけで、どんな罪でも引受けるといって大きな顔をするのではない。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "スミレへもこの位の愛を持たねばスミレを楽しむ人も余り大きな顔をするわけには行くまい。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故われらは学者で候との大きな顔をするのが大きらいで、私のこの気分は私に接するお方は誰でもそうお感じになるでしょう。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ただ大きな顔をするんでしょう。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな大きな顔をするな。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……コーヒーぐらいおごったって大きな顔をするな、そんなぐらいの気持じゃなかったんだ。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
