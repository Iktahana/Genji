          ],
          "literary": [
            {
              "text": "（隣を視る）御覧なさいまし、女郎花さんは、もう、あんなにお釣りなさいました。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お釣りぢやあ無いんですか？",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お銚子が一本ついて、タイムどしたら、百円でお釣りが来るのどっさかい、安おっしゃろ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、たくさんお釣りなさい。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたも去年お釣りになって……。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釣りを寄こすとき、私を早く出ろ、早く出ろという風に押すのよ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "数人の酒場男と酒場女が、この、戦時そのままの騒ぎを引き受けて、酒をつぐ・グラスを抛る・金をひったくる・お釣りを投げる・冗談を言い返す・悪口もかえす・喧嘩の相手もする・自分も呑む。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様んとこじゃ、いつもお釣りは人の掌にはじくようにぽいと落すそうじゃが、おう、ほんとかえ？",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して娘さんは煙草のお釣りを、「はい一銭のお返し」と云って、私の掌の上に押し付けるようにして渡してくれた。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "神話時代には、神功皇后が船待ちの徒然に、裳の糸をぬかれて、初めて鮎をお釣りになつたと云はれてゐるが、その後の海幸山幸の話にしても、今でも石器時代の骨の釣針が貝塚から出ると同じで、原始生活者にとつては「釣り」は生活の一部であつた。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とうとう萩丸殿をお釣りなされた」と、口の中で呟いた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「羅漢様に美い男てえのはねえものだなあ」「べらぼうめ、こちと等は羅漢様からお釣りをもらいてえくれえのものだ」「ちげえねえ、いよう羅漢様」「羅漢様――」「羅漢様――」　山を遊覧する人間が、大きな声を出してみたくなるのは、妙な心理作用であると思いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸あたりから遊覧に来た連中らしいが、とうとうそれらは羅漢様からお釣りを取ろうという面を見せずに、あちらの山に消えてしまう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れは、何処でお釣りになツたのです。",
              "citation": {
                "source": "元日の釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紙帳といえば、妾がお釣りしたのでございますの」　栞は云いつづけた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "干ぼしになって死ぬ時ア一緒に死ぬべえ、と言って、その五両札へ二両のお釣りを置いて帰って来ただが、おかみさん、去年は豊年で、それでやっぱり飢饉と同じことだった。",
              "citation": {
                "source": "飢餓地帯を歩く",
                "author": "――東北農村惨状報告書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夕風に吹かれながら、こんなところであなたと魚づくしをやる気はねえのだから、鮫なと海坊主なとお好きなものをお釣りなせえ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "鎌いたち",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所釣友会の千葉県養老川で、この仕かけを使ってみたが、ほかの人は、「そんなことをして遊んでいないで、本会だから一生懸命お釣りなさいよ」　といっていた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗林さんの支払いは受取りがあって、こちらで少し余分に払ったものだから、お釣りを切手で寄越してくれました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "受取りを調べると五十二円二十五銭で、私は五十三円送ってお釣りをもらったと覚えています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじさま」と宇乃が訊いた、「お釣りになった魚を、どうして逃がしてしまいますの」「あれは鮠だからだ」「鮠ではいけませんの」「宇乃は寒くないか」と甲斐が振向いた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「釣るまねだけはするんです」「しかし魚が食いますから釣れると困ります」「いや、若様がお釣り上げになるまで餌をつけないで釣るんです」「ははあ、なるほど。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富田さんを二枚もお釣りになりました」「なに？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご自分でご自分を五、六枚お釣りになりました」「黒須先生は？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今お釣りになった魚は」「然うですね」「小さかったですな」「※っ子ですよ」「沢山釣れますか？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでホヲリの命が釣道具を持つて魚をお釣りになるのに、遂に一つも得られません。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "また筑紫の松浦縣の玉島の里においでになつて、その河の邊で食物をおあがりになつた時に、四月の上旬の頃でしたから、その河中の磯においでになり、裳の絲を拔き取つて飯粒を餌にしてその河のアユをお釣りになりました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし低気圧がもう一層近くなってそれが季節風を消却してなおおつりの出る場合には、夕風は夕風でもいつもとは反対の夕風が吹くのである。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に待っている人のことなどはまるで考えないで、自分さえ切符を買ってしまえばそれでいいという紳士淑女達のことであるから、切符売子と色々押し問答をした上に、必ず大きな札を出しておつりを勘定させる、その上に押し合いへし合いお互いに運動を妨害するから、どうしても一人｜宛平均三十秒はかかるであろう。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手術料は毎回払いであったが、いつも先生自身で小さな手さげ金庫の文字錠をひねっておつりを出してくれたのが印象に残っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
