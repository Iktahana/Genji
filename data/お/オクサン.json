        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「君ちやん（僕の名、実は君介、どうもブラ公みたいな名ですよ）どうも遅くなつて御免よ、富田の奥さんがいろんな話をしなさるから、あとからあとから話しなさるから。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――奥さんを早くお持ちなる方が好いわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　社交ダンスなんて、金を貰つたつて閉口だけれど、奥さんは持ちませうかね、何処からか探して来てね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　いゝや、あなたを奥さんにしようか。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　だつてねえ………あたし「奥さん」だとか、「妻」だとか、「お嫁」だとかつて言葉が嫌なのよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今な奥さん、坊ちやが隣り下駄屋から――あれ何言ふか、野球手袋な、あれお主婦さに出して貰ふ彼方駆けたで。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "………あなたもお嫁入――人の奥さんにでもおなんなすつた方が遂々は………。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその客である奥さんは、彼をよく知つてゐながら彼の父とも母とも一面識さへなかつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥さんなるものの姪と彼とが恋仲であることを奥さんに知られてゐる彼だからなのである。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の頃は、よく勉強してゐますか」　頭の低い人間だけれど、やつぱりブルヂョアなのだ、見下ろすやうに奥さんは彼に言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんが別嬪なのに引き換へて、自分の母親が衰へ顔であることと、如何にかかうにか生活の出来るといふ程度の自分の家を見られることは、とても堪らないことであつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんと、も一人の奥さんの親族の奥さんとは、扇を使ひながら、「扇風器もないのか……」つて顔をしてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも福岡市でも竹原といへば知らない人もないつて言つて好い位な家なんですから、余りお粗末にやれば……」　それは奥さんに従いて来た奥さんの声だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんが母に挨拶してゐる時に、後ろでも一人の客は吹き出してゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「如何ですね」　二等から奥さんて奴がやつて来た。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もかも再会に懐しむ、あの貞順な奥さんも昔の喜びに笑ひいでる。",
              "citation": {
                "source": "秋の日曜",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夏目先生が英国へ留学を命ぜられたために熊本を引上げて上京し、奥さんのおさとの中根氏の寓居にひと先ず落着かれたときのことであるらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは、退屈さうだ。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夕方が来ると、先生ははだしになつて家のまはりや庭に水を撒かれる、奥さんはかひがひしく夕餉の仕度をされる。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仲間がだいぶありますね」　やがて「これから大井川あたりまでご一緒に連れ立って、奥さんを案内してあげたいんだが何しろ忘れて来た用事というのが壁の仕事でね、乾き工合もあるので、これから帰りましょう。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が昔現在の家を建てたとき一番日当りがよくて庭の眺めのいい室を応接間にしたら、ある口の悪い奥さんから「たいそう御客様本位ですね」と云って、底に一抹の軽い非難を含んだような讃辞を頂戴したことがあった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奥さんの寸言の深い意味に思い当る次第である。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年奥さんと二人連れで道をあるいていた時だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんと一緒に銀杏を買いに寄ったことのある市場だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしはそのお礼によって、あとくされと紛議をかもさないように奥さんにご用立てしましょう。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ですが、奥さんは必要なもののありかをご存じですか。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一たい、おくさんのような、華やかなそして詩人肌の方が、また間違ってるかも知れんが、まあ、兎に角、どうして哲学なんかに縁がおありでしたな」今度は社会教育の参考資料にとでもいった調査的な聞き振りだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奥田）　あ、おくさん！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奥田）（まじめになり）しかし、おくさん。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（奥田）　おくさん！",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
