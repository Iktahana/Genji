        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "セコンドメイトは、私と並んで、私が何を眺めているか検査でもするように、私の視線を追っかけていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、何か知ら追っかけられるような、切迫した感じで彼をつっ突いた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼は、恐しい夢でも見てるような、無気味な気持に囚われながら、追っかけられながら、デッキのボースンの処へ駆けつけた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで行っても稲田は追っかけて来るのである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見かけた田代はコーヒーの勘定などはあとでいいからすぐ駆出せばよいのにその勘定でまごまごしてなかなか追っかけない。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に蜻蛉を捕るのに、細い糸の両端に豌豆大の小石を結び、それをひょいと空中へ投げ上げると、蜻蛉はその小石を多分｜餌だと思って追っかけて来る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあまりあせり過ぎては、却って自分にある好い物を捨てて自分にないものを追っかける恐れがありはしないか。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時など、拳銃を握って、軍医を追っかけまわしたことがあった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おしかは云って追っかけた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山も田も抵当に入り、借金の利子は彼等を絶えず追っかけてきた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森をくゞりぬけて奥へパルチザンを追っかけたことがある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これから、さき、なおどれだけ自分の意志の反してパルチザンを追っかけさせまわらされるか量り知れない自分にはうんざりせずにいられなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、始終過激派を追っかけ、家宅捜索をしたり、武器を押収したり、夜半に叩き起され、やにわに武装を整えて応援に出かけたりしなければならなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年兵の食器洗い、練兵、被服の修理、学科、等々、あとからあとへいろ／＼なことが追っかけて来るのでうんざりする。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいな髭の男は、やっと、この豚どもを逃がしてはならないことに気づいて、あとから白い手を振り上げて追っかけた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "追っかけられると、豚はなお向うへ馳せ逃げた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は乾麺麭を一袋握って、あとから追っかけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は追っかけて来ていいことをしたと思った。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士は、烏が雪をかきさがし、つついているのを見つけては、それを追っかけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士はそれを追っかけた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画はあひる泥坊を追っかけるといったようなたわいないものであったが、これも「見るまでは信じられなくて、見れば驚くと同時に、やがては当然になる」種類の経験であった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の坊ちゃんは、部落の子供達を集めて、それぞれ四五尺の棒を手にして、猫を追っかけてぶん殴りに来た。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこまで追っかけろって云うんだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千人の将卒が、総がかりで、その便衣隊を追っかけまわした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は、支那人に追っかけられる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高取は一年間の勤めを了えて、二年兵になったその日に、歩哨に立っている場所を離れて鶩を追っかけまわした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、追っかけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、朝、早くから、逃亡した工人を追っかけて、汚穢物乾燥場の、汚穢の乾物を積重ねてある蓆俵のかげに、すなんでいたのを掴まえてきた話をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パルチザンはそれにつけこんで、百姓に化けて、安全に、平気であとから追っかけて来た軍隊の傍を歩きまわった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の村には燃えさしの家が、ぷすぷす燻り、人を焼く、あの火葬場のような悪臭が、部隊を追っかけるようにどこまでも流れ拡がってついてきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
