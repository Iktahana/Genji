        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "良心は遅かれ早かれ、磨滅する性質のものだ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――高山の中腹では、この雪線を境としてその上に雪が堆積して、万年雪となり、その万年雪の一部が氷河の運動を起して、徐々と下落し、遅かれ早かれ、融解するのである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、黙阿弥翁のことであるから、遅かれ早かれ世に出るには相違ないが、ここに「児雷也豪傑譚」という評判物の草双紙がなかったらば、或いはその出世が三年や五年はおくれたかも知れない。",
              "citation": {
                "source": "自来也の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅かれ早かれ自分は谷底に落ちねばならぬとは十分に承知しているくせに。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度で噛むとは限らぬから、一週間のあいだは毎晩うまく避けられたのだろうが、遅かれ早かれ、その犠牲となるに違いない。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ何か予期せぬことで離ればなれになったとしても、わたくしはあの方を信じると誓ったことをけして忘れは致しませんし、あの方も遅かれ早かれお誓いになるはずでした。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな弱りはてた――こんな哀れな有様で――あのもの凄い『恐怖』という幻影とたたかいながら、生命も理性もともに棄てなければならんときが、遅かれ早かれかならず来るのを感ずるのだ」　なお私はときどき、きれぎれの曖昧な暗示によって、彼の精神状態のもう一つの奇妙な特質を知った。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこのことは是非とも大声で言っておきたいのだけれど、我々を取り巻く環境をコンピューター社会としてとらえ、この社会の基盤を整備するという課題は、遅かれ早かれ絶対に浮上するのだよ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの事はお雪の口からみな文字春の耳にはいるので、彼女はいよいよ暗い心持になって、津の国屋は遅かれ早かれどうしても潰れるのではあるまいかと危ぶまれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それもどうで遅かれ早かれ知れることで、秘し隠しにしようとするのは卑怯というもの。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅かれ早かれ他へ縁付けなければならないのだ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と言ふものは、この世の中にあることは、――古から今日までの人間のやつて来たことは、遅かれ早かれ屹度経験するものである。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "“不入の間”の扉が遅かれ早かれ開放されるのは自然の勢いで、かならずしも両君の力ばかりとは言えないかも知れないが、実行の方面において最も早くその大勢を導くことに努力した両君の功績は、長く没すべからざるものがあると言ってよい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅かれ早かれ、こっちの物よ」　吉五郎は冷えた猪口を飲みほして、自信があるように微笑んでいると、兼松もおなじく得意らしく笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで三甚は思いも寄らない手柄をしたのですが、自身番へひかれて行った時に、金蔵はたいそう口惜しがって、どうでおれは遠島船を腰に着けている人間だから、遅かれ早かれ御用の声を聞くのは覚悟の上だが、いざお縄にかかるという時には、江戸で一、二といういい顔の御用聞きの手に渡る筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "人相書が廻っている以上、遅かれ早かれ網にかかるものとは察しているが、それまでの間に何事もなければいいと、半七は思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、「マリー・ロオジェ事件」を読まれた読者は、以上の点を除いては、文中に挙げられた大小すべての事項が遅かれ早かれ洩なく、分析解剖されていることに気附かれるであろう。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今の花江と結婚するとすれば、――花江が夢殿村に勤めている以上、いずれ遅かれ早かれ、その村の患者と同様な病いに見舞われることは覚悟していなければならぬのだ。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし遅かれ早かれ将来においてはふたたび傍観する時がくるはずである。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは遅かれ早かれ死なねばならぬ。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして遅かれ早かれ貧しい犬のように死んでゆかねばなるまい。",
              "citation": {
                "source": "孤独",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の運命は遅かれ早かれ溺死するのに定まっていた。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんな政府が出現して、どのような革命が来ようとも、遅かれ早かれこの問題だけはさし迫って来ることだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は吾輩が遅かれ早かれこの危険千万な放れ業式の解放治療の実験を切り上げて、その内容を学界に発表すると同時に、行衛を晦ますであろう事を、ずっと前から察していたんだね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは女としては珍らしい冴えた頭脳を持っているＴ子がもし、Ｍの行衛不明と、如月寺の絵巻物の紛失事件を綜合して考えた場合には、遅かれ早かれ或る恐ろしい、一つの疑いに直面るにきまっている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＭが海外に逃げ出した心理を通じて、Ｍは遅かれ早かれ、必ず日本に帰って来る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅かれ早かれヴェルダンの土になります。",
              "citation": {
                "source": "戦場",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れでもおしかさんは別者にして、近衛様のお側室さま格に思い、やがて呼迎えられる日のあることを、遅かれ早かれ、約定済みのように傍の者も思っていたが、侯爵は思いもかけぬ病気で不意にこの世を去られた。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの事は、遅かれ早かれ、おれ一人で片付けて見せるから、差支はないが、又例の堀田がとか煽動してとか云ふ文句が気にかゝる。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの事は、遅かれ早かれ、おれ一人で片付けてみせるから、差支えはないが、また例の堀田がとか煽動してとか云う文句が気にかかる。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
