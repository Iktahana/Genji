    "definitions": [
      {
        "index": 1,
        "gloss": "to crowd out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "管壁の摩擦に打勝って卵を押し出すために卵の後方の環状筋を断えず収縮して卵殻を圧しつける。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　タエは、鉱車を押し出す手ごをした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行列はこれからリボリの大通りシャンゼリゼーのほうへ押し出すのだそうです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船宿の女将が船の舳に手を添えて何の力草にはならなくとも、「いってらっしゃいまし」と押し出す所作のあるのは、旧幕の頃、この辺から猪牙で山谷堀や深川へ遊客が通った時分の名残りの風習だということです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林通勝、池田信輝、柴田勝家等が、はやる馬の口を押えて「敵｜衆く味方少くあまつさえ路狭くて一時に多勢を押し出す事が出来ないのに、どうして正面からの戦が出来よう」と諫めたが、いささか出陣前の余裕を失った信長は聴かずして中島に渡ろうとした。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホッ、ホッ、ホッ」と押し出すような特徴ある笑声を思い出すのである。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがつけてなかったということは、犯人が舟を押し出す前にそれを具えておく用心を怠ったのだと想像すれば、やっと説明ができる。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し出す方法は、すでにありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか世間がそうぞうしいから、いっそ今年はお見あわせにしようかと云っていたんですけれど、やっぱり若い衆たちが納まらないので、いつもの通り押し出すことになったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼『文壇的文学を主観的傾向のものであつたと見ることができるならば、現今言はれてゐる文学の大衆化は、文学の客観的価値の押し出しである――』と中條氏はいふ、現在の文学の求めてゐるものに、主観とか客観とか二等分して、それを押し出すとか、引つこめるとかいふ、それほど彼女のいふやうに簡単にいけば問題はない。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより日光山にこの鼠の死にたる骸を重宝して納め置き、今に走り大黒とて押し出す御影なりと記す。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し出す群れと、引き返す群れとが打ち合った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると後方の押し出す群れと衝突した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　風邪でつぶれてしまつた喉から押し出すやうにして嗄れた聲で老人は答へた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝろあらためて七月朔日の朝露を踏む△筍を観てゐると、それを押し出す土の力と、伸びあがるそれ自身の力とを感じる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笹村はそこに突っ立っていながら、押し出すような声音で言った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、自身生かしきれぬ純な情感に苦しむとき、その無力と躊躇と昏迷した考えをてきぱきと解明して、後からつよく押し出すものよりは、音楽にしろ、映画にしろ、小説にしろ、あるままの生活の感情を認めて、一緒にたゆたって、ほのかになって、眠らしてくれるものの方が抵抗力の弱いものには楽です。",
              "citation": {
                "source": "私も一人の女として",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小さき町にて」「ビュビュ・ド・モンパルナス」「母への手紙」の作者、シャルル・ルイ・フィリップも熱心な彼女の支持者であったが、自分のためにさえ何もなし得なかったフィリップにはマルグリットを世のなかに押し出す力はなかった。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者の朝から夜をとりまく現実の力が、やがて彼の性格の積極面を正しく押し出すようになって、実践的に階級人としての移行が起るにつれ、芸術に関する道も当然新たな方向に発展せしめられた。",
              "citation": {
                "source": "文学における古いもの・新しいもの",
                "author": "――「風雲」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルニィ夫人はバルザックを世間に押し出すために全く「母以上のもの、友達以上のもの、一人の人間が他の人間に対してなし得るすべてのものに優る」献身的な情愛と社交婦人としての実際的な手腕を傾けたのであった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが思想文化が一つの新しい秩序を押し出す時、之を混乱として受けとる側も、やがては之に対抗する独自の別な秩序を打ち樹てようとし始める。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけではない、文化と云えば今日どこの国でもすぐ様社会観や政治思想とからみ合っており、又文学其の他に現われる思想の自由を想定しなければならないが、処が日本に於て思想らしい思想を持つものはどうも日本の公式思想として押し出すのに、政府にとって都合が悪いのである。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と歯の隙間から、不可思議な息を押し出す――が罩もり、その呼吸に「カナリヤの労働」――きな臭い煙草――の名の香が絡み、散乱する長調の音譜と、澎湃たるこの雑色の動揺と、灼輝する通行人の顔と動物的な興奮。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義文学運動の中に、労働者階級の使命を明らかにして、おのずからプロレタリア文学の伝統のどの部分が継承されなければならないか、という点を押し出すことは、そのたたかいの中にとかされた。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "炬燵の中の雪見酒めいた文学の風情は、第二次大戦後の人類が、平和をもとめ、生活の安定をもとめてたたかっている苦痛と良心に対して、さすがにあつかましく押し出すにたえ得なかったのであった。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長篇が本質の貧寒さから、時流におされて素材で押し出す傾に陥った対症として、作家が真のモティーヴをもって描く短篇のうちにのこされた文学性がかえりみられたのであった。",
              "citation": {
                "source": "今日の文学の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　豊子は、癖で下顎を押し出すように合点しながら、先輩らしく答えた。",
              "citation": {
                "source": "七階の住人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは失敬」と云つて、義雄が出ようとすると、「いいのだよ、君も知つてるだらう」と引きとめ、その手で女の頸を押し出す。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄いヴェールを揺り分けるようにして、先達の血にまみれたはれぼったい脣がぴくぴく動き出したかと思うと、赤い歯並の間から押し出すように何かを先達が呶鳴ろうとする幻影が現われた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がとても深くおりてきますよ」　と言って、ちょっと山のほうをながめてから大将がぜひもっと近くへ来てくれと言うので、余儀なく鈍色の几帳を簾から少し押し出すほどにして、裾を細く巻くようにした少将は近くへ身を置いた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
