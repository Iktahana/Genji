        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "取散らした包紙の黴臭いのは奥の間の縁へほうり出して一ぺん掃除をする。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間から祭壇を持って来て床の中央へ三壇にすえ、神棚から御厨子を下ろし塵を清めて一番高い処へ安置し、御扉をあけて前へ神鏡を立てる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂から出て奥の間へ行くと一同の着替えがそろえてある。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間でお通夜してくれる人たちの話し声が細々と漏れる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた煤やら垢やらで何の木か見別けがつかぬ位、奥の間の最も煙に遠いとこでも、天井板がまるで油炭で塗った様に、板の木目も判らぬほど黒い。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎が、　「あれ、石松、眼どうしたんだい」　「なに、なんでもねえんだよ」　石松、奥の間を見て、　「お父っつあん居ねえのか」　「清水へ行ったわ」　「清水へ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝奥の間の　源兵衛と主膳。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "持っていた幣束で彼の面を一つ打ったままで、無言で奥の間へはいってしまわれたが、それを知った拙者はすぐにその場へ踏み込んで、久次郎の不埒をきびしく叱って、今後決して、参ることは相成らぬと襟髪をつかんで表へ突き出してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間で信子の仕度を手伝ってやっていた義母が「さあ、こんなはどうやな」と言って団扇を二三本寄せて持って来た。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉が種々と衣服を着こなしているのを見ながら、彼は信子がどんな心持で、またどんなふうで着付けをしているだろうなど、奥の間の気配に心をやったりした。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間からこの家の主婦が出て来た。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦は奥の間から古ぼけた手帳のようなものを出して来た。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間の主人主婦の世界は徳川時代とそんなに違わないように見えた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると少女は身体の具合が少し悪いと言って鬱いで、奥の間に独、つくねんと座っていましたが、低い声で唱歌をやっているのを僕は縁辺に腰をかけたまま聴いていました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせいは取りあえず奥の間に行って、講談物か何かを読み耽っているらしい奥様の前に手をついた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時でも姉はいそ／＼と出迎へてくれるのに、今日は近所から預かつてある十許りの女の子が淋しさうな顔をして、入口に出て来たばかりなので、少し気先きを折られながら奥の間に通つて見ると、姉は黙つて針仕事をして居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の間、次の間、仏壇の間、という順に、内庭の木立の繁み近くに迄建て連ねられた幾つかの座敷に沿うた縁廊下は、遥々と見渡すほどに長く延びて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――…………………………※はれて逢われぬ恋仲に、人に心を奥の間より、しらせ嬉しく三千歳が、このうたいっぱいに、お蔦急ぎあしに引返す。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから晩餐の御馳走になって、奥の間の最上等の座敷へ案内されて、ここを私の居間と定められたが、こんな立派な広いお座敷に寝るのは実に今夜が嚆矢だ、併し後で考えるとこのお座敷が一向に有難くない、思い出しても慄然とするお座敷であったのだ。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の神か知らないが、それを祭ってある奥の間には二本の蝋燭がともっていた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の目を見ないような奥の間にばかり閉じこもっているために、運動不足、それに伴う食欲不振がいよいよかれを疲らせて、さながら生きている幽霊のようになり果てた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「お二階どす」　女中にいわれて、君勇は二階への階段を登りかけて、ちらと奥の間の方を見た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家では大きい妹の時子も、下の奥の間で寝ていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、眼が醒めましたら、台所の入口と私の枕元に在る奥の間の中仕切が開け放しになっておりましたから、ビックリして奥の間の様子を見に行ってみますと、お父さんと、お母さんが殺されております。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "野蛮人の弟は、きのうの新内で、かぜをひいたらしく、離れの奥の間で火鉢をかかえて坐って、兄の草むしりの手伝いをしようかどうしようかと思い迷っている形である。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、お照さんは奥の間で寝てゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
