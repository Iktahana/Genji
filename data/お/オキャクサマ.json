          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんならそのときぼくはお客様になっていってもいいだろう。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松、外へ向って次郎長に、　「御貸元、汚ねえ処で御座いますが、さッどうかお入んなすって……」　「あら兄さん、お客様なの」　次郎長、入って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父っつあん、お客様よ」　お静の呼び声に、我に返った源兵衛、店の方へ行く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻、清水からお客様が見えたのよ」　「清水って、お貸元の処からか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "美味いわよ、とっても」　「それで……もう帰ったのか」　「お客様？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、お客様がお帰りだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「いや、どうしても今夜中に立たなくちゃならねえ」　「お客様じゃねえか」　この時、七五郎、表を見て言う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主が聞かれて「よくお訊ね下さいました」　実は、Ｔ「隣りの室のお客様が　宮本武蔵先生」　これには武蔵、ばからしゅうて暫時言葉も出なかった。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに好いお客様でございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お客様がいらっしゃるではないかね、人の足になんか搦まって、贅沢じゃあないか、お前達は虫を吸っていればたくさんだよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あれ、いけないよ、お客様があるじゃないかね。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（畜生、お客様が見えないかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（何でございますね、あとでお食んなさい、お客様じゃあありませんか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものはいつでも食られます、今夜はお客様がありますよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあお客様に一ツお聞かせなさいましなね。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（今夜はお客様があるよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お客様があるじゃないか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて低声で、（お客様があるよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だってお前様はお客様じゃあないかね、お客様なら私ン処の旦那だね、ですから、あの、毎度難有う存じます。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉は極の悪そうな趣で、「お客様だって、あの、私は木挽の小僧だもの。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日見た「エノケンの酔虎伝」でもお客様に出してある菓子を略奪に出て来る男の子がどの俳優よりもいちばん自然で成効しているように思われた。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごちそうに出した金米糖のつぼにお客様が手をさし込んだらどうしても抜けなくなったのでしかたなく壺をこわして見たら拳いっぱいに欲張って握り込んでいたという笑話がある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたともあろうものが、あんな馬鹿話をなさるのはおよしなさい、お客様に軽蔑されるばかりです、もっと真面目なお話が出来ないのですか、まるで三流の戯作者みたいです、と家内から忠告を受けた事もあるのですが、くるしい時に、素直にくるしい表情の浮ぶ人は、さいわいです。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「本当にいゝね、そんならその時僕はお客様になって行ってもいゝだらう。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンナに降りますと、お客様もお見えになりませんな。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ来て見ても、お客様が一人立っておいでになる古本屋なら、大丈夫立って行くものです。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから一人もお客様がお見えにならないと手前が自分でサクラになってノソノソ降りて行きまして、本棚なぞを整理致しておりますんで……これがマア商売のコツで御座いますナ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見つけたお客様のお顔色次第で千円ぐらいは吹っかけてもアンマリ罰は当るめえ……と思っていた訳ですが……普通の聖書にしてもソレ位のねうちはあるんですからね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの東京のお客様でしょ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで　こねこたちを　うちのなかに　いれて、　おきゃくさまが　つくまでに　よごれを　おとして　きがえを　させようとしたのです。",
              "citation": {
                "source": "ねこぬこタムのはなし",
                "author": "THE TALE OF TOM KITTEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
