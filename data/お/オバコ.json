        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おばこについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おばこがありますね。",
              "source": "幻辞"
            },
            {
              "text": "おばこというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおばこの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおばこが好きです。",
              "source": "幻辞"
            },
            {
              "text": "おばこを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おばこの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おばこはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおばこがあります。",
              "source": "幻辞"
            },
            {
              "text": "おばこは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おばこについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおばこの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おばこの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおばこが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おばこについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおばこは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおばこについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おばこという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおばこの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おばこを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」と言い棄てに、ちょこちょこと板の間を伝って、だだッ広い、寒い台所へ行く、と向うの隅に、霜が見える……祖母さんが頭巾もなしの真白な小さなおばこで、皿小鉢を、がちがちと冷い音で洗ってござる。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生際が抜け上って頭の半ばから引詰めた、ぼんのくどにて小さなおばこに、櫂の形の笄さした、片頬痩せて、片頬肥く、目も鼻も口も頤も、いびつ形に曲んだが、肩も横に、胸も横に、腰骨のあたりも横に、だるそうに手を組んだ、これで釣合いを取るのであろう。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙騒ぎもやや鎮まった時分、倉持は二三人取巻きをつれて来たり、一人で飯を食いに来たりもしていたが、よって来ると三味線をひかせておばこ節など唄って騒ぐくらいで、手もかからず、気むずかしいところも見えなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "車のわだちのあとに生えてゐたおばこ草もいつの間にかなくなつた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴしりと脛を叩くおばこの固い紐の花。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は『おばこ』といふ草の葉を採つて遊んだことが有りますか。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣りのお勇さんもあの『おばこ』を採つて來て織ることを樂みにするやうな幼い年頃でした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "結綿、割唐子、めおと髷、唐人髷、蝶々、文金高島田、島田崩し、投島田、奴島田、天神ふくら雀、おたらい、銀杏返し、長船、おばこ、兵庫、勝山丸髷、三つ輪、芸妓結、茶筌、達磨返し、しゃこ、切髪、芸子髷、かつら下、久米三髷、新橋形丸髷。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも綿を入れたり、火熨斗をかけている女房さんは、平面ではあったが目に立つ顔で、多い毛を、太い輪のおばこに結っていた。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおばこ来たかやと……　たんぼのはんずれまで、出てみたば……」　清江の歌が聞えて来た。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう清江は、そんなことなどどうでも良いという風に、「おばこ来もせず、用のない、　たんばこ売りなど、ふれて来る。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かだが底張りのある、おばこ節であった。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばこ来もせで相馬の大作なんぞいかめ面。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "時二郎は新聞を見ていたが「おばこ節」を鼻唄で唄っていた。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地しばりやおおばこなど、葉末に露をたたえた雑草をはだし足袋に蹴立てて歩いて行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば、追分の如き、おばこの如き、或は此玄如節の如きものが出来たので、其起源は、勿論、ほそり・なげ節などの起源になつて来るのだらう。",
              "citation": {
                "source": "感謝すべき新東京年中行事",
                "author": "――第四回郷土舞踊と民謡の会・批判――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、のぞき出した半白半黒、それをおばこに結ったのが、ばらばらに乱れて、細長く萎びた、疎ら歯の婆さん――その顔が提灯の灯に、おぼろに照されて、ばけ物じみている。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水を堰いて如何するのかな」「水力電気たら云うてな、あんたはん」と茶を持て来たおばこのかみさんが云う。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さきにおばこ節を口誦んでいた一人の青年も、それにつれて突っ立ち上り、両手を天井へ届くほど伸ばして、ああ、ああ……とあくびを連発した。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばこ踊　夜四山楼の晩餐に、庄内のおばこ節というものを聞かして貰うの光栄を得た。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばこ踊とは娘ッ子の手踊の義であるそうな。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "説明に曰く、「おばこ」とは若き女を指したることにて、弟をおじといい、妹をおばと呼ぶより出でたることなるべしだと。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばこ」の「こ」はけだし東北地方の方言で、よく名詞の尻につける「コ」であろう。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばこ節の歌詞は田舎情緒の方言丸出しの無邪気なものだ。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばこ来るかやと田圃の外んづれまで出て見たば、コバエテ／＼、おばこ来もせで用のない煙草売りなの（なのはなどの意）ふれて来る。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "コバエテ／＼おばこ居たかやと裏の小ん窓から覗いて見たば（見たばは見たればの意）、コバエテ／＼、おばこ居もせで用のない婆様なの（など）糸車、コバエテ／＼。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
