    "definitions": [
      {
        "index": 1,
        "gloss": "female role (e.g. in film)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三崎座の女役者を、御贔負は、皆呼びずてでございます。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "別けて申上げまするが、これから立女役がすべて女寅が煩ったという、優しい哀れな声で、ものを言うのでありまするが、春葉君だと名代の良い処を五六枚、上手に使い分けまして、誠に好い都合でありますけれども、私の地声では、ちっとも情が写りますまい。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "変り種は地方廻りのオペラコミックの女役者と乞食が一人あった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女役者はルイ子といって、その座中では花形だそうである。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校にいた頃、脚本朗読会をやってわざわざ友田恭助を東京から呼び、佐伯は女役になってしきりにへんな声を出し、友田は特徴のある鼻声をだし、終って一緒に記念写真を写したこともある。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたたかにうち黄ばむ写真屋の古きならびは、半盲目の病児らの日向ぼこをば見るごとく、掲げたる鈍き写真のうちにくはせ者の女役者の顔のみ白く、罎ならぶ※のそば、露台にダアリヤの花ただひとつ赤けれども、なべてみな色もなし、入口の静かなる空椅子のうへに、みよりなき黒猫ぞひとりまた背を高めたる。",
              "citation": {
                "source": "浅草哀歌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までのことは、何もかも……何もかも……偽り……まことは妾は……女……女役者……」　と云いさして平馬の方向へガックリと顔を傾けた……が……しかし、それは苦痛のためらしかった。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳閣寺の宮芝居は坂東小三という女役者の一座で、ここらではなかなかの人気者であることを半七は知っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女役者にこんな芸の出来る筈はない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、おれの腑に落ちねえのは、小三の芝居は女役者だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼び物の虎が出て来ない上に、錦祥女を勤める坂東小三津という女役者も急病だというので、きょうは舞台を休んでいるのです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近寄って覗くと、四十近い女役者が弟子らしい若い女二人を連れて、格子のなかで押し問答をしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだから油断がなりませんよ」「そうすると、小三津という女役者もそれに引っ懸かったんですね」「そうですよ」と、老人はうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは国姓爺の芝居です」「鳳閣寺の芝居ですね」「さっきもお話し申した通り、ここの芝居は女役者の一座ですから、男と女と入りまじりの芝居は出来ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸棚の中がおかしいので、念のために明けてみると、そこに若い女役者の死骸がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いとんぼを捕ふれば女役者の肌ざはり。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃に女優という名称はない、すべて女役者と呼ばれていて、今日のいわゆる女優劇は女芝居というのであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、江戸時代からの掟として、男女合併興行は厳禁されていたので、女芝居はすべて女役者のみで一座を組織しなければならなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その関係上、座頭の女役者は熊谷や松王や由良之助を勤め得る者でなければならない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、男の俳優とおなじように、女役者のあいだにも立役と女形とは、はっきりと区別されていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "粂八の名はかねて聞いていながら、その舞台を今日はじめて見物して、なるほど東京唯一の女役者であるということを私もたしかに承認した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれは文字通りの“噂”にとどまって、どこの劇場でも在来の女芝居以外に女役者を雇い入れようとはしなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は一面にその伎倆を認められながらも、単に時代おくれの、小芝居廻りの老いたる女役者として、その余生を送るに過ぎなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市川九女八は日本における女役者の最後であった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の俳優の中で延そうという者も見当らないが、先ず宗之助であろう、あの人は女役が適当であると自信して、かなりいい立役が附いても喜ばぬ風であるが、とにかく年は若し、最も有望なんであろう。",
              "citation": {
                "source": "当今の劇壇をこのままに",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐猿は今千艸屋に飼われて居る、浦原お浦は米国へ行き女役者の群に入り何所か西部の村々を打ち廻って居る相だ、天然に狂言の旨い女だから本統の嵌役と云う者だろう、時介は直ちに外国へ漫遊に出て未だ帰らぬ、余と春子の間には玉の様な男の子、イヤ是は読者が羨むから云わずに置こう。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "女役者の一座がかかった。",
              "citation": {
                "source": "山峡新春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ」　そのような女役者が夜になると山中鹿之助を演じた。",
              "citation": {
                "source": "山峡新春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは男ばかりの演舞であったがとうとう女役が登場しだした。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
