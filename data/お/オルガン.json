        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "例へば夏休みも近づかうといふ暑い日に、唱歌教室で先生が、オルガン弾いてアーエーイーすると俺としたことが、笑ひ出さずにやゐられなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は毎日暑く、今産院にゐる娘は「ブーラ、ブーラ、ブーラブラ」といふ象といふ題の児童唱歌をオルガンで歌ひ、姉娘は夜になるとパウリスタに連れてつてアイスクリームを食べさせてくれた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の夏の夜月は空にメダルのやうに、街角に建物はオルガンのやうに、遊び疲れた男どち唱ひながらに帰つてゆく。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫のオルガン六つですか」と何遍も駄目をおしている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫のオルガン」が何のことだか分からないが多分おもちゃのことらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはちょうどオルガンとかピアノのキーのようなもので、一つの言語にはちゃんときまった数のキーがあるようなものです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つのピアノとかオルガンとかに備え付けられているキーは限られている。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他には客間にあったオルガンを書斎に移したくらいで、外には別に造作を加えるようなことはしなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルガン音階のＣ音を出したのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "手押車の前方には自働オルガンが縱に置かれてあつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき女がオルガンのハンドルを※した。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧師が賛美歌の番号を知らすと、堂のすみから、ものものしい重い、低い調子でオルガンの一くさり、それを合図に一同が立つ。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから子供部屋へ行ってオルガンをひいた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は裏庭を左にした壁のオルガンの前に腰かけて、指の先の鍵盤から湧き上がる快い楽音の波に包まれて、しばらくは何事も思わなかった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が再びオルガンの前に腰を掛けると彼はまた縁側へ廻って来て幾度となく礼を云った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屈辱の苦味をかみしめて歩いているうちに偶然ある家へはいると、そこは冷やかな玄関でも台所でもなくそこに思いがけない平和な家庭の団欒があって、そして誰かがオルガンをひいていたとする。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらにおむつが干したりしてあるが、それでもどこかオルガンの音が聞えていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時々オルガンの低いうなりが響いたり消えたりしていました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは少し讚美歌の練習をしませう」と軈て牧師が男らしい聲で快活に云ふと、女で居ながら人の前で決して面をかぶらない、其の細君は飾氣のない身ぶりで腰掛を立上つてオルガンに近づいた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルガンが鳴り出すと相島は昂然として腰掛から立上つたが、餘の人は坐つた儘で居る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　＊　　　　　　　＊　書棚とピアノとオルガンと、にわか百姓の素性を裏切る重々しい椅子とで昼も小暗い父の書斎は都会からの珍客で賑わっていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は不断のオルガンを弾じ雲はトマトの如く又｜馬鈴薯の如くである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）　私はいまペンを置いて「その火絶やすな」という歌を、この学校に一つしかない小さいオルガンで歌いたいと思います。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『多分もう学校へ帰つてオルガンでも弾いてらつしやるかと思つた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩堂とお医者様の玄関及び郷校のオルガンある室との間を最も繁く往来したりければ、薬の香り、楽声の余韻なども沁みこみてありと知るべし。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "會毎に三人は相談して必ず月に一度の贈品を大島小學校に送る、それが必ずしも立派な物ばかりではない、筆墨の類、書籍圖畫の類などで、オルガン一臺を寄送したのが一番金目の物であつた。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は吾国固有の美風である神仏の崇拝、父母師友の恩義を忘れて個人主義、唯物主義的な権利義務の思想に走ること行燈とラムプを取換えるが如く、琴、三味線、長唄、浄瑠璃を蹴飛ばしてピアノ、バイオリン、風琴、オルガンを珍重すること傘を洋傘に見換える如くであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきまで「青葉茂れる桜井の」と繰り返していた隣のオルガンがやむと、まもなく門の鈴が鳴って軒の葉桜のしずくが風のないのにばらばらと落ちる。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれから数時間の後に行って見ると、だれかが押し入れの中にオルガンの腰掛けを横にして作ってやった穴ぼこの中に三毛が横に長くねそべって、その乳房にこの子猫が食いついていた。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉は夕暮その家を辭して、石垣の上に靜かなオルガンの音を耳にしながら、細道を一人かなしく家に歸つたのである。",
              "citation": {
                "source": "三十三の死",
                "author": "素木しづ子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
