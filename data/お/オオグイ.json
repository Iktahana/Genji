        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　怪力、大食い、これが、しかし、全くのすごい美人なのだ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの怪力、あの大食い、あの強慾。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　生蕃さんはふだんあんまり大食いをするから、こんな時に困るんだわ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次女は、もともと、よほどの大食いなのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、書斎に引き籠り、人目を避けてたちまち大食いの本性を発揮したというわけなのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、いまはそうでも無いけれども、かつて、非常な大食いであった。",
              "citation": {
                "source": "食通",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の檀一雄などに、食通というのは、大食いの事をいうのだと真面目な顔をして教えて、おでんや等で、豆腐、がんもどき、大根、また豆腐というような順序で際限も無く食べて見せると、檀君は眼を丸くして、君は余程の食通だねえ、と言って感服したものであった。",
              "citation": {
                "source": "食通",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごはんも、たしなみなく大食いして、三杯目くらいに、やっと思い出して、『しまった！",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、元来、この町に、立派な玄関を磨いた医師のうちの、書生兼小使、と云うが、それほどの用には立つまい、ただ大食いの食客。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――また大食いな男で、一升一かたけぺろりの勢。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか大食いだとみえて、さんざん食べたり、飲んだりして、こんどはおなかがくちくなると、鬼は二人とも、ぐうぐう高いびきをかいて寝込んでしまいました。",
              "citation": {
                "source": "人馬",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃、大食いの親父は息子の重みを背中に感じ、ヒョロヒョロしながらも、その重みを歩く張りにして、それから未だ一里もあった街道をもう風景に対する感動もないまでに疲れ切って歩いて行った。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これはじきなおるよ」「口のはたに黒子があるから大食いだわ」「食うに困らない黒子なんだ」　喧嘩のおわりはいつも光一が母に叱られることになっている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腹をこわしてたんだなあ――さあ、とにかくその着物を脱いで……どら、こっちに来な、あんまり大食いをした罰かな？",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥った女よりも痩せた女の方が大食いであることは、昔からきまっている。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたい、低脳な者は大食いだし、随って浪費癖はつきものだ。",
              "citation": {
                "source": "ものの影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子鮒とか泥鰌とか、ろくなものはいないだろうが、大食いの懶け者には、手頃な時間つぶしだ。",
              "citation": {
                "source": "ものの影",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬吉というのは勿論アダナで、大食いというところからきている。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれぐらい大食いはないということだ。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、遠慮した奴にかぎって、食べ出せばたいがい大食いである。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロパーヒン　なんて大食いだ！",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　イワン、デミトリチの左の方の隣は、猶太人のモイセイカであるが、右の方にいる者は、まるきり意味の無い顔をしている、油切って、真円い農夫、疾うから、思慮も、感覚も皆無になって、動きもせぬ大食いな、不汚極る動物で、始終鼻を突くような、胸の悪くなる臭気を放っている。",
              "citation": {
                "source": "六号室",
                "author": "アントン・チエホフ　Anton Chekhov",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一そのうえ落着いて大食いをされた日にゃ、米が高くなって諸人の迷惑だ」「悪い口だなア、親分」「ところで、その八五郎が武芸のたしなみを見せようという相手のところへ真っすぐに案内しな」　そんなことを言いながら、二人は軒並の楊弓場を覗きながら、入船町の方へ歩きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "アホウドリは、とても大食いな鳥だ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはそれ中学二年という年頃は、たいへん自意識の多い年頃で、あいつは大食いだと周囲から思われるのが辛さに、一箇で我慢したのである。",
              "citation": {
                "source": "腹のへった話",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人共に大食いで口の賤しい方だったから。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――露西亜人云うたら、何であない大食いやねんやろ。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "オオマクレーといくか」　大食いのことを根室のカニ工場の女工たちは、青森あたりの方言なのか、オオマクレーと言っていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「よほどの大食いなら別だけど」　そう言って順子の母は深町に顔を向け、笑った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食で特に大食いをするのがクセで、白いパンにピーナッツ・バター、ねりつぶしたバナナなどを塗りこめてサンドイッチにこしらえ、ペプシ・コーラとミルクで交互にながしこむのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
