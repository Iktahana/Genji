    "definitions": [
      {
        "index": 1,
        "gloss": "to descend (e.g. a mountain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、自分から動く火吹き達磨のように、のたうちまわった挙句、船首の三角形をした、倉庫へ降りる格子床（グレイチン）の上へ行きついた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小さな穴からは、丈夫な生きた人間が「一人」で、縄梯子を伝って降りるより外に、方法は無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年がいま水際に降りる岩石の階段に片足を下ろしかけたとき、その石の蔭になっている岸と水際との間の渚に、薄紅の色の一かたまりが横たわっているのが眼に入りました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、つかまへられる鳥よりは、つかまへられないで無事に天の川の砂の上に降りるものの方が多かったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りは下りだから無造作に二人で降りる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りる人もなく乘る人もない。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、醤油屋の坊っちゃんは、プラットホームに降りると、すぐ母を見つけて、こう叫びながら、奥さんのいる方へ走りよった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああもう降りるかい。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりは降りるときはわざと巣からはなれて降りるから飛びあがるとこを見なければ巣のありかはわからない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、つかまえられる鳥よりは、つかまえられないで無事に天の川の砂の上に降りるものの方が多かったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから滑り降りるのだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう部分からは、冷えた水が下へ降りる、そのまわりの割合に熱い表面の水がそのあとへ向かって流れる、それが降りた水のあとへ届く時分には冷えてそこからおりる。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車から降りるとき兄は笑うた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天使が空を舞い、神の思召により、翼が消え失せ、落下傘のように世界中の処々方々に舞い降りるのです。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昇る時は、ドスンドスン、降りる時はころげ落ちるみたいに、ダダダダダ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の疎開していた町から、汽車で三、四時間、或る港町の駅に降りると、小川新太郎君は、りゅうとした背広服姿で、迎えに来ていた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、つかまへられる鳥よりは、つかまへられないで無事に天の川の砂の上に降りるものの方が多かつたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、降りるんですよ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとおおぜいの人々は、降りる人を待つだけの時間さえ惜しむように先を争って乗り込む。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三のになると降りる人の降りたあとはまるでがら明きの空車になる事も決して珍しくない。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時ある高い階級の婦人が衆人環視の中で人力車を降りる一瞬時の観察から、その人の皮膚のある特徴を発見してそれを人に話したので、実に恐ろしい女だと言ってそれが一つ話になった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段も自分で降りると云ふのを、鶴吉が無理に背負つて、「梯子段を一人で降りるなんて、落ちて死んぢまふぞ」　と云ふと、お末は顔の何処かに幽かに笑ひの影を宿して、「死んでもいゝよ」　と云つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、民也が、はじめて其の姿を見たのは、揃つて二階からすら／＼と降りる所。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあけがをしないやうに降りるんだ』船乗りが云ひました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この深山で置いてきぼりを食っては、麓へ降りる道も分からないではないか。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行船を降りるや否や、「東助、東助。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "内のか、外のか、重なり疊んだ棟がなぞへに、次第低に、溪流の岸に臨んで、通廊下が、屋根ながら、斜違ひに緩く上り、又急に降りる。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出かけるとなって庭へおりると、髪があんまりひどいからちょっとなでつけるまで待ってちょうだいと言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が走って行かないうちに、早く鳥がおりるといゝな。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりる支度をして下さい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
