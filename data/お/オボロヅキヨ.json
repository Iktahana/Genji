        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女｜倶して内裏拝まん朧月　春宵の悩ましく、艶かしい朧月夜の情感が、主観の心象においてよく表現されてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯今は凄いほど、星がきらついて参りましたが、先刻、その時分は、どんよりして、まるで四月なかばの朧月夜見たような空合、各自に血が上っておりましたせいか、今日の寒さに、皆汗を掻いたでござります。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれも、そゞろ身にしみて、春の夕の言の契は、朧月夜の色と成つて、然も桃色の流に銀の棹さして、お好ちやんが、自分で小船を操つて、月のみどりの葉がくれに、若旦那の別業へ通つて來る、蓋しハイカラなものである。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯氣が霞の凝つたやうにたなびいて、人々の裸像は時ならぬ朧月夜の影を描いた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその古樹がちらほら残って、真盛りの、朧月夜の事でした。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朧月夜にしくものぞ無き、という歌なんどは宜いが、雪まじり雨の降る夜の露営つづきは如何に強い武人であり優しい歌人であり侘の味知りの茶人である氏郷でも、木の下風は寒くして頬に知らるる雪ぞ降りけるなどは感心し無かったろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲いのは――もしか出来たら――偐紫の源氏雛、姿も国貞の錦絵ぐらいな、花桐を第一に、藤の方、紫、黄昏、桂木、桂木は人も知った朧月夜の事である。",
              "citation": {
                "source": "雛がたり",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「朧月夜の色なんだよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一日の夜、朧月夜に暗い二の丸の櫓に、四郎出で立って、静かに下知を下した。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏にも頭中将にも第二の行く先は決まっていたが、戯談を言い合っていることがおもしろくて、別れられずに一つの車に乗って、朧月夜の暗くなった時分に左大臣家に来た。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若々しく貴女らしい声で、「朧月夜に似るものぞなき」と歌いながらこの戸口へ出て来る人があった。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朧月夜の尚侍も静かな院の中にいて、過去を思う時々に、源氏とした恋愛の昔が今も身にしむことに思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "情景朧月夜の春の宵。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は、インヂアンのガウンでロシナンテを飛したいつぞやの晩と同じやうな朧月夜であつた。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "春もたけなわなる朧月夜に、塩竈通いのそそり節が生暖い風に送られて近くきこえた時、若い尼は無念無想で経を読んでいられたであろうか。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "話変わって、雨のそぼ降る六月の朧月夜であった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはどうも朧月夜の出来事である。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "「波さえ音もなき朧月夜に、ふと影がさしたと思えばいつの間にか動き出す。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔に増してあらゆる点の完成されつつある跡の見える朧月夜の君の手紙がいっそうの魅力になって、昔の中納言の君の所へも、二人の逢う道を開かせようとする手紙を院は常に書いておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はどちらとも離れていてよい暇な時であったから、朧月夜の君の二条邸へ院は微行でお出かけになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たよりない春の朧月夜だ。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "院は二条の朧月夜の尚侍になお心を惹かれておいでになるのであったが、女三の宮の事件によって、後ろ暗い行動はすべきでないという教訓を得たようにお思いになって、その人の弱さにさえ反感に似たようなものをお覚えになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の力なんて弱いものねといふほどの興味を表へ出した朧月夜の日本情調である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画が済んでから、またＡデッキに出てみますと、太平洋は、けぶるような朧月夜でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "月は無かつたが朧月夜と云つた風に薄く曇つて居る星明りの中に汽車から下りて直ぐ前の桟橋に繋がれた汽船へ乗移つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前書によって、光源氏の君が、落花のちりこむ高欄のほとりに佇んで、朧月夜の内侍の許へ忍ぼうとしてでもいるかの絵姿を思い浮かべるのであるが、余りに美しい絵そら事よりは、事柄は平凡でも、京の夜桜を見てきて雨となったという、静かなうるおいのある現代句の方に、親しみを覚えるのである。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は春「うす紫にうち煙つた朧月夜」で「風も無いのに眞白に咲き滿ちた櫻の梢からは、音も無く花｜片が、ひらひらひら――ひらひらとしつきりなしに」散りかゝるといふやうな婦人向の、極めて通俗に美しいと呼ばるべき景色である。",
              "citation": {
                "source": "貝殼追放",
                "author": "「八千代集」を讀む",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から朧月夜ゆえ向河岸まで能く見えます。",
              "citation": {
                "source": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "author": "粟田口霑笛竹（澤紫ゆかりの咲分）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
