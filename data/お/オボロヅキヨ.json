    "definitions": [
      {
        "index": 1,
        "gloss": "misty, moonlit night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
