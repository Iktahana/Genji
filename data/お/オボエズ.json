        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "悶え苦しさに覚えず唸り声を出すと、妻は驚いてさし覗いたが急いで勝手の方へ行って氷を取りかえて来た。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸ばたの流し場に手水をすました自分も、鶏に興がる子どもたちの声に引かされて、覚えず彼らの後ろに立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、本当に誰れかの手先に使われて、寒い冬を過したシベリアのことは、いまだに憤りを覚えずにはいられない。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、勝つことが出来ない強力な敵に遭遇したような緊張を覚えずにはいられなかった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えず叫びしが心を籠めて、気を鎮めて、両の眼を拭い拭い、水に臨む。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭覚えず頭を縮め、面を顰め、しばし天窓を撫でゝ、「さて／＼強き御力かな、そなたは聞及びし諏訪越中な。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昔の日本の蘭学者のエレキテルなどというような言葉を思い出して覚えず微笑せずにはいられなかった。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で覚えず笑い出してしまった最も愉快な場面は、犬が蠅取り紙に悩まされる動作の写真的描写である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えず舌で入れ歯を押しはずして押し出そうとする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末はそれでもその後少しも腹痛を覚えずにしまつたが、力三はどつと寝ついて猛烈な下痢に攻めさいなまれた挙句、骨と皮ばかりになつて、九月の六日には他愛なく死んでしまつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年ばかりも前のこと、場所も意外なり、境遇も変っているから、滝太郎の方では見忘れて、何とも覚えず、底気味が悪かった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも既に説うごとく、この人形は亡き母として姉妹が慕い斉眉物なれば、宇宙の鬼神感動して、仮に上※の口を藉りかかる怪語を放つらんと覚えず全身｜粟生てり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "同一世の孤児よ、と覚えずほうり落ちた法師自身の同情の涙の、明の夢に届いたのである。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "動きゃあしないから、切っておくれ」　予はそのあまりの無邪気さに、覚えず森寒を禁じ得ざりき。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後姿を見送っているうちに、覚えずほろりとした。",
              "citation": {
                "source": "白い路",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを眺めた者は、誰だって覚えずにはいられない本能的憎悪を、雄吉君は人一倍にしつこく、強く感じたらしかったのです。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えず叫びしが心を籠めて、気を鎮めて、両の眼を拭ひ拭ひ、水に臨む。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そう承れば恥入る次第で、恥を申さねば分らんでありますが、うたゝ寐の、この和歌でござる、」「その歌が、」　とこなたも膝の進むを覚えず。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行方を目で追うた時、覚えず紀昌は石上に伏した。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀昌の家に忍び入ろうとしたところ、塀に足を掛けた途端に一道の殺気が森閑とした家の中から奔り出てまともに額を打ったので、覚えず外に顛落したと白状した盗賊もある。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えず、自分は声を追うて走り出した。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、覚えず瞼が染まった。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　辻町は、その乳のわきの、青い若菜を、ふと思って、覚えず肩を縮めたのである。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えず、恍惚する、鼻の尖へ、炎が立って、自分で摺った燐寸にぎょっとした。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われを憎むとは覚えず、内に行くことをこそ好まざれ、外にて遊ぶ時は、折々ものくれたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造はその話の内容を聴くよりは、籠に飼ってある鈴虫の鳴くのをでも聞くように、可哀らしい囀の声を聞いて、覚えず微笑む。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "末造は覚えず蹙めていた顔を、又覚えず晴やかにせずにはいられなかった。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "末の子が寝返りをして、何か夢中で言ったので、お上さんも覚えず声を低うして、「一体わたしどうすれば好いのでしょう」と云って、今度は末造の胸の所に顔を押し附けて、しくしく泣いている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お常はしぶしぶその方を見て、覚えず足を駐める。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのつぎの夜もつぎの夜もおぼつかなくて、何時しか暁月夜の頃にもなれば、などかくばかり物はおもはする、いとつれなくもあるかなと憎くむ／＼猶まつに弱らで一夜を待あかしゝに、ある暁のいとねぶうて、物もおぼえずしばし夢結ぶやうなりしが、耳もと近くその声あやまたず聞えぬ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
