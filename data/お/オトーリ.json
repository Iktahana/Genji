        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中でも早吸の瀬戸などは神武天皇が東征の時に御通りになったというので、歴史で名高くその名も潮流の早い事を示していて大変に面白い名でありますが、今ではただ豊後海峡と呼ばれています。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "感嘆して曰く、神化の名將なり、天の照鑑もおそろし、早々御通りあれと。",
              "citation": {
                "source": "石田堤",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨晩あなたは、殺人事件のあった富倉町を御通りにはなりませんでしたか」　康雄は、ぐさと、短刀で胸をさされる思いをした。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすると、ちょうど、富倉町を十二時頃御通りになった訳ですね。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが御通りになったとき、ある家の中から女の悲鳴のような声は聞えませんでしたか」　康雄は何となく、気味が悪くなって来た。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事はさぐるように康雄の顔を見つめて居たが、「若しや、あなたが御通りになったとき、家の中から、一人の若い女が飛び出しては来ませんでしたか」「知りません。",
              "citation": {
                "source": "好色破邪顕正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ奥の方へ御通りなすって――」　と亭主に言われて、学士は四辺を見廻わした。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様が花やかな御風俗で御通りになる時は、土壁の窓から眺め、障子の穴から覗き、目と目を見合せて冷な笑いかたを為るのです。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "島屋の若旦那、荒町の亀惣様、本町の藤勘様、越後屋の御総領、三浦屋の御次男、いずれも羽織｜袴の御立派な御様子で御通りになりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "島屋の若旦那、荒町の亀惣様、本町の藤勘様、越後屋の御総領、三浦屋の御次男、いずれも羽織袴の御立派な御様子で御通りになりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜酒問屋の前などを御通りになると、目暗縞の着物で唐桟の前垂を三角に、小倉の帯へ挟んだ番頭さんが、菰被りの飲口をゆるめて、樽の中からわずかばかりの酒を、もったいなそうに猪口に受けて舌の先へ持って行くところを御覧になる事があるでしょう。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「只今、お仕事中ですから、こちらへ御通り下さい。",
              "citation": {
                "source": "楊先生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王様の御通りだぞ。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "可いんでせうね」と念を押して、何にも知らない下女を氣の毒がらしてゐる所へ、最前の仲働が出て來て、「何うぞ御通り下さい」と丁寧に頭を下げたので、今度は宗助の方が少し痛み入る樣になつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王樣の御通りだぞ。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御通りなさるは女王樣だ。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この間二度ほど途中で御目にかかりましたが、時々あの辺を御通りになるんですか」「実はあの高橋の総領の娘が片付いている所がついこの先にあるもんですから」　高橋というのは誰の事だか健三には一向解らなかった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいんでしょうね」と念を押して、何にも知らない下女を気の毒がらしているところへ、最前の仲働が出て来て、「どうぞ御通り下さい」と丁寧に頭を下げたので、今度は宗助の方が少し痛み入るようになった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "至尊の御通りを拝さんとする国民は罪人のやうに扱はれ、警護者の鋭い監視のもとにおかれた。",
              "citation": {
                "source": "君臣相念",
                "author": "龜井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔った者の微吟というふうな、ごく低い声であった、「……今日も旅人の、御通り候わば」　そううたいかかると、柵の中から、これも低いさびた声で、こうつけるのが聞えた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
