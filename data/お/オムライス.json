          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして、一寸考えて、オムライスを注文した。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに筋向いの弥生座はピエルボイズ専門のレヴュ小屋で、小屋がハネると、レヴュガールがどやどやとはいって来るし、大阪劇場もつい鼻の先故、松竹歌劇の女優たちもファンと一緒にオムライスやトンカツを食べに来る。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイウエオ順に考えていくことを思いついた彼は、ア、イ、ウ、エ、と心のなかでたどっていき、「オムライス！",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｃ女は、「ハラボテお呉れやす」　ハラボテとは、オムライスのこと。",
              "citation": {
                "source": "色町洋食",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "オムライスの、ふっくりとふくれた姿を、ハラボテ女に見立てたものだろう。",
              "citation": {
                "source": "色町洋食",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "田原屋のハヤシライスとオムライスとって貰って食ひ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単にオムライスを食べて、中泉眼科へ寄り、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "外出せず、中西のビフカツとオムライスで食事すませ、ミルクコーヒーなどのみ、ねころんで揉ませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又々麻雀にひっかゝってしまひ、大丸の内で、チャシウメンやオムライスで安く腹ごしらへし乍ら、しきりにガメって、しきりに負けた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑の王国の大辻の淀君といふ愚劇をのぞいて、慨嘆して中西でカツレツとオムライス食って座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は、ゆっくり麻雀する約束なので五時まで、オムライスなんど食ひ乍らやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、タンシチュウ二の後、赤だしとオムライスと命じる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オムライスの姿を見ておどろく、日本最大のオムライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
