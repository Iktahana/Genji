        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "徳川家瓦解の時は、王政復古に當つてマゴつかない丈けの思想、智識が既に養成せられてゐた。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が、排幕派の議論が勝利を占めて十二月九日、王政復古の号令が発せられ、アンチ徳川の連中は悉く復活し、公武合体派は参朝を禁ぜられてしまった。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "元弘三年六月五日、後醍醐天皇は王政復古の偉業成って、めでたく京都に還幸された。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、素朴な一般武士の頭には、延喜｜天暦の昔に還らんとする、難しい王政復古の思想など、本当に理解される訳はないのである。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の王政復古を持ち来した原動力は何であったかといえば、多くの歴史家がいうとおり山陽の『日本外史』がその一つでありしことはよくわかっている。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の王政復古前後の歴史をことごとく調べてみると山陽の功の非常に多いことがわかる。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "王政復古は、天下の大勢でござります。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、王政復古となれば高松藩お取り潰し。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新の眼目が王政復古にあったが如く、廃藩置県にあった如く、昭和維新の政治的眼目は東亜連盟の結成にある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」直木三十五、吉川英治らが明治維新を「王政復古の名によって描き出し、帝国主義段階の今日において大衆のファッショ化を積極的に強化しようとはかっている。",
              "citation": {
                "source": "文学に関する感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの姉たちは、尊王攘夷というスローガンの実体が、王政復古といいながら実は天皇を絶対権力者とする半封建的資本主義社会体制への移行であることを知っていなかった。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は王政復古の時に当つて、人に先んじて起つて王事に勤めたのである。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく王政復古、いわく皇武合体、二つのものは内政上における常時の論派なり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治維新の王政復古と共に、今上陛下は武門政治を初め一切の有害無用な旧習を破壊遊ばし、併せて汎く新智識を世界に求める事を奨め給い、学問、技術、言論、信教、出版等あらゆる思想行動の自由を御許しになり、生命、財産等の人権を御保障になっております。",
              "citation": {
                "source": "女子の独立自営",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス大革命からナポレオン帝政を経て王政復古に至る時代の、影の人物、謎の人物としてのフーシェのことは、いろいろの人に取上げられているが、最も面白いのはステファン・ツワイクのフーシェ伝である。",
              "citation": {
                "source": "砂漠の情熱",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の話ながら、予の父は明治維新の直後、王政復古の恩沢を国民に如実に示す方法の一つは、国民の健康を保護して安堵せしむるにありと考へ、明治六年に今の京都府立病院を全国に率先して創立し、内外の医家を聘して診療に当らしめたのであつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると薩長などは夙くに朝廷の或る人々と謀る所があっていたから直ちに慶喜公の出願を採用され、いわゆる王政復古の大改革となった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、ワーテルローの戦いと、王政復古と、一八三二年の暴動と、社会の最下層と、パリーの市街の下の下水道とが、詳細に述べられなければならなかったのである。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果諸般の改革を見、翌九日、天皇｜親臨、王政復古の大号令を下され、徳川幕府は十五代、二百六十五年を以て、政権朝廷に帰したのであった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鵜の丸兵庫は慶安三年に勤王思想を旗標として、多数の浪人を糾合し、徳川幕府を倒壊し、王政復古の実をあげようと、いわゆる慶安騒動を起こした、由井正雪の異母弟なのである。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王政復古の頂言者、文運改革の指導者たる大詩人は斯の如くにして生れたり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れか図らん此｜眇々たる一書天下に流伝して王政復古の預言者となり社会の改革を報ずる暁鐘とならんとは。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに彼をして安政文久の際に在らしむるも彼は決して純乎たる王政復古論を唱へ得るものに非ず。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "王政復古――老年の復活」すべてのものが町人的（いまの言葉で小市民的）になる。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の王政復古というやつで、宗教は神道ひとつ、仏教もつぶしてしまえという反動時代だったから、切支丹の復活を許すだんではなかった。",
              "citation": {
                "source": "二合五勺に関する愛国的考察",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の他の部分はチャールズ二世時代のフランス趣味に從つて造られてゐて、この改修を加へたのは、わたしの友人の語るところによると、彼の祖先の一人で王政復古時代にチャールズ二世に隨つてイギリスへ歸國した人であつた。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸のほかのところはチャールズ二世の時代のフランス好みの建て方で、友の言うところによれば、それを修理し模様変えをしたのは、彼の祖先で、王政復古のときに、チャールズ二世にしたがって帰国した人だそうだ。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            }
          ]
        }
