        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ずいぶん、つましい奥ゆかしいことなんだ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には奥ゆかしい廂の上に枝垂柳が垂れている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "李張は燭火の前に浮き出た花のような姿を見たうえに、奥ゆかしいその物ごしを見せられてますますその女が慕わしくなった。",
              "citation": {
                "source": "悪僧",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その風味のよさ、嫁ごというのも、容色も心も奥ゆかしい、と戴いています。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥ゆかしいところは欠けて、派手な現代型の贅沢さが見えるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十万円の現金をもつてゐるといふのに比べると、それだけの提琴を持つてゐるといふのは、何だか一寸奥ゆかしい点が無いでもない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は揉みあげを短く刈つて、女の羨しがるほどの、癖のない、たつぷりした長い髪を、いつも油で後ろへ撫であげ、いかに田舎の家がゆつたりした財産家で、また如何に母親が深い慈愛を彼にもつてゐるかと云ふことを語つてゐるやうな、贅沢でも華美でもないが、どこか奥ゆかしい風をしてゐた。",
              "citation": {
                "source": "或売笑婦の話",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀しみを胸に抱きながら、七尺の屏風も躍らばよも踰えざらん、と歌い弾じたお軽の奥ゆかしい心根。",
              "citation": {
                "source": "軽女",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉のひきかた剃りかたにも、おのずとそのひとひとの身分が現われてい、同時にそれぞれ奥ゆかしい眉を示していたものである。",
              "citation": {
                "source": "眉の記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れなんと思ふも物の悲しきをいかさまにしていかさまにせん　選んだ紙の色、書きよう、焚きしめた薫香の匂いもそれぞれ特色があって、美しい感じ、はっきりとした感じ、奥ゆかしい感じをそれらの手紙から受け取ることができた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤袴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと思うとこの姫君は心細い身の上のようで気の毒だが、曾祖父の宮、祖父の太政大臣、父宮などの遺産の分配されたのが多くて、夫人は、高級の貴女の生活の様式をくずさず愛女をかしずくことができて、奥ゆかしい佳人の存在と人から認められていた。",
              "citation": {
                "source": "源氏物語",
                "author": "紅梅",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざって出て、「あちらの襖子は少しあらわになっていて心配なようね」　と言い、こちらを見上げた今一人にはきわめて奥ゆかしい貴女らしさがあった。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "東中野へ出て行く道には、大名笹で囲まれた板垣直子さんの奥ゆかしい構えがある。",
              "citation": {
                "source": "落合町山川記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がその時｜老成人であるか又は仏者であったら、人道｜世教の為めに如何とか、又は平等を愛して差別を排するとか何とか云う説もあろうが、十歳以上十九か二十歳の少年にそんな六かしい奥ゆかしい考のあるべき筈はない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "文豪の旧宅が互に贈答をする習慣も奥ゆかしい。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築の外観の宏壮なのも、実は近寄つて見ると巨石を用ひた英仏の古い奥ゆかしい建築と異つて、概ね人造石で堅めてあるのでがつかりする。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は賞められて恥かしがり、この席に連なッているのをむしろ憂いことと思ッているらしく、話もせず、人から物を言いかけられると、言葉少なに答えをするばかり、始終下を向いていた，がその風はいかにも柔和でしとやかで、微塵非難をする廉もなく、何となく奥ゆかしいので、自分は余念もなくその風に見とれていた。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ皆さん、自分は老年の今日までもその美しい容貌、その優美な清しい目、その光沢のある緑の鬢、なかんずくおとなしやかな、奥ゆかしい、そのたおやかな花の姿を、ありありと心に覚えている……が……悲しいかな、その月と眺められ、花も及ばずと眺められた、その人は今いずこにあるか。",
              "citation": {
                "source": "初恋",
                "author": "矢崎嵯峨の舎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屁をたれるな、と気付いたトタンに、ガチャ／＼それとなく皿など重ねて音をたてゝあげるだけのカンと思いやりが閃くようになりゃ、奥ゆかしいというものだ。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論「野分の又の日こそ甚じう哀れなれ」と清少納言が書いた様な平安朝の奥ゆかしい趣味は今の人にも伝はつて居るから、野分と云ふ雅びた語の面白味を感じないことは無いが、それでは此吹降に就ての自分達の実感の全部を表はすことが不足である。",
              "citation": {
                "source": "台風",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ奥ゆかしいと言はねばならぬ。",
              "citation": {
                "source": "大井広介といふ男",
                "author": "――並びに註文ひとつの事――",
                "note": "青空文庫"
              }
            },
            {
              "text": "菱山修三のお母さんは若い頃ナギナタの達人だつたさうで、菊五郎の踊りを見ると、あの身振りは残身にかなつてゐるなどゝナギナタの言葉で感動するさうであるが、奥ゆかしい話である。",
              "citation": {
                "source": "剣術の極意を語る",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンディション不良のマーシャル橋爪をいたわる心事は場にみち、奥ゆかしい極みなのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "世界新記録病",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中々奥ゆかしい色である事は受け合うておく。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この本堂の屋根の一部と、寂然した広い庭と、苔生した地面と、平らな石畳の道と、楓の並木のしなやかな枝葉と、清らかな空気とを、重々しい御門の向うに眺めては、その奥ゆかしい寂しい風致に、私は幾度心を打たれたことであろう！",
              "citation": {
                "source": "或る女の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、儒者ふうの老人のまとっているところの雰囲気は、「本郷の殿様」と呼ばれている武士のまとっているところの雰囲気とは、全然別趣のものであって、穏和と清浄と学者的の真面目さ――そういうものを合わせたような、限りない奥ゆかしい雰囲気であった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それはなんと奥ゆかしい言葉ではありますまいか。",
              "citation": {
                "source": "ニュートン",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははははは」　なんというわけのわかった、奥ゆかしいお侍だろう！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもと幕府の奢侈禁止令に対して起こったことであるかもしれぬが、やがてそれが一つの好みになってくると、奢侈をなし得る能力のあるものでも、それを遠慮した形で、他人に見せびらかさない形でやることが、奥ゆかしいように感ぜられて来た。",
              "citation": {
                "source": "藤村の個性",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし陰気だが、話してみると、教養のある奥ゆかしいところがあって、剛子にすれば、社交室のとりとめのない男たちとよりは、この老人と一緒にいるほうがむしろ楽しいくらいだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "社交室",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
