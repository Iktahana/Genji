        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お産という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお産の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お産を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお産という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お産の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お産は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お産の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お産と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お産は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お産はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お産の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お産の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お産が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お産を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お産のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お産に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お産の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お産の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お産は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お産の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "果して妻は糟毛がお産をしました。",
              "citation": {
                "source": "牛舎の日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうか、そこでお産をしようと云ふのだな。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそんな折なぞにお産をする牝牛くらゐ、かはいさうで、みじめなものはなかつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、おふくろが来て、女房がお産をしたが、もう、三日、飯をくわずにいると云うんです。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王はお産をした妻からも、老母からも、その後、便りがなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふむ、お産をしたんだね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……同じ夜の寢る時分、「裏家では、今夜、お産のやうでございます……」　と云つた、お媼さんは、あとじさりに蚊帳へ潛つた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おぎい、おぎい、）　ツて聲がします……　あゝ、明方にお産があつた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と幽に成つて行つたのは、お産婦から引離して、嬰兒を連れて退らしい。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大騒ぎのすぐあと、七日目に嫁御がお産じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方から逆寄せして、別宅のその産屋へ、守刀を真先に露払いで乗込めさ、と古袴の股立ちを取って、突立上りますのに勢づいて、お産婦を褥のまま、四隅と両方、六人の手で密と舁いて、釣台へ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中へ、お産婦の釣台を。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒門へ着かしって、産所へ据えよう、としますとの、それ、出養生の嬢様の、お産の床と同一じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "到津遊園・人影ちらほらとあたゝかく獅子も虎もねむつてゐる　　　白雲閣即事二句・お産かるかつたよかつた青木の実・訪ねて逢へて赤ん坊生れてゐた　二月廿二日曇、何か降つてきさうだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「其の代り女にはお産といふ大難があるぢやありませんか。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と由三はお産のあツた家を六軒ばかり數へた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母はそう言って赤児を抱き取り、黝ずんだ乳首を含ませながら、お産の話をしはじめた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、お産の騒ぎとは考えた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、お産に縁があるかと思って、婆の志。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宅のお産をお忘れですか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼がさめてから、やれ不思議な有難い夢よ、とひどく気がかりになっていたところにあなた、いきなお旦那が、お産のすむまで宿を貸せと台所口から御入来ですものねえ、夢は、やっぱり、正夢、これも、日頃のお不動信心のおかげでございましょうか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、だって、お産にちなんで数の子ですよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が覚めた頃には、お産もすんでいるだろう。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つかん事を聞くがね、どこかこの近所で、今夜あたりお産をしそうな人はあるまいか。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこへ時々客では無い、町内の人らしいのが、引過ぎになってもちょいちょい出たり入ったりするから、少しその心当りの事もあるし、……何も夜中の人出入りが、お産とは極らないけれど、その事でね。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その……近所のお産のありそうな処は無いかって、何か、そういったような事から。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原へ行くと云う、彼処等じゃ、成程頼みそうな昔の産婆だ、とその時、そう思ったから、……後で蔦屋の二階で、皆に話をする時も、フッとお三輪に、（どこかお産はあるか）って聞いたんだ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おさんどんですか。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "撫子　いいえ、いま思知ったんです、まったく罰が当りますから、私を可哀想だとお思いなすったら、このお邸のおさんどん、いくや、いくや、とおっしゃってね、豆腐屋、薪屋の方角をお教えなすって下さいまし。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさんどん見たいに頬ペタばかり赤くしやがって……」　なぞと寄ってたかって笑い物にした。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
