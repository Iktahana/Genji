[
  {
    "uuid": "9847b813-0b57-5b6e-94d1-19b74fd7c58a",
    "entry": "お付き合い",
    "reading": {
      "primary": "おつきあい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
