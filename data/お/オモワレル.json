[
  {
    "uuid": "6a5e44be-b0a6-5dd4-a109-0c0896ba9600",
    "entry": "思われる",
    "reading": {
      "primary": "おもわれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
