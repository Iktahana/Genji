        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうして現に日本の方言にも東北地方や沖縄の方でも出雲地方でもハ行音を「ファフィフェ」など言うのは、昔の音が田舍に遺っているのです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "パピプペポと発音するのは、今でも沖縄の田舍に残っております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の道々聞いて来たのは、劇場のそれのような本式の賑かなのではなく、余り慣れない手が独りでポツンポツンと爪弾していたような音だった）此処は沖縄県人ばかりのための――従って、芝居は凡て琉球の言葉で演ぜられる――劇場である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてパラオ本島を十日ばかり徒歩旅行した時、途を聞く相手が皆沖縄県出の農家の人ばかりで、全然言葉が通じないで閉口したことを憶い出した。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十三年の四月、桜の真盛りに、福岡市の洲崎お台場の空地（今の女専所在地）で九州沖縄八県聯合の共進会があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄でリゾートの設計と開発の管理にあたって欲しいという話があり、これにのったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津田さんはバブルがはじけていく時期を、沖縄の方言で「いい加減」を意味する、〈てーげー〉に過ごしました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は、都会にあって沖縄にないものばかりを数える日々が続きましたが、やがて文化、風土、気候と、すべてにおいてここにしかないものが見えてきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沖縄に一日いれば新聞記事が書ける。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦争には、必ず勝つ」　と冒頭して、「戦争には必ず勝つが、しかし、皆さんが軍の命令通りに仕事しなければ、作戦に支障を来し、沖縄のような結果になる。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲に於いてはナチスの全滅、東洋に於いては比島決戦についで沖縄決戦、米機の日本内地爆撃、僕には兵隊の作戦の事などほとんど何もわからぬが、しかし、僕には若い敏感なアンテナがある。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮にある沖縄人から前日報ぜられたは、以前ハブ蛇多き山を焼くとかように自身を咬んだまま死んだハブばかり間見当った由。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄首里の人末吉安恭君二月号に載せた予の不毛婦女に関する説を読んで来示に、かの辺りで不毛をナンドルー（滑らか）と俗称し、少し洒落ては那覇墓と唱う、琉球の墓は女根に象る、普通その上と周縁に松やうず樹｜芒等を栽え茂らす、しかるに那覇近所の墓に限り多くは樹芒少なく不毛故の名らしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は沖縄人で相貌が内地人らしくないので疾うから覘われていたのだそうだと、当人が後に来ての話である。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の校長は一種の愛国者で、琉球人に高等教育を受けさせるのは国家のためにならないという意見を有っていたが、そういうことが動機となって、明治二十八年の秋に、沖縄の中学で未曾有のストライキが起った。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一この書が沖縄の社会に対して貢献する所があったら望外の幸である。",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十四年七月初旬沖縄図書館にて伊波普猷",
              "citation": {
                "source": "「古琉球」自序",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に就いて名高いのは、ゑぞのいくさもい月のかずあすびたちともゝとわかてだはやせいぢへきいくさもい夏はしげちもる冬は御酒もる　〔十五―一八〕と歌われた（このオモロの新解釈については『沖縄考』五三頁―五四頁を見よ）英祖のイクサモイであった。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教はこの時始めて沖縄に入ったのである。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく沖縄史の幕が開けてから尚巴志が三山を統一するまで、およそ三百年の間首里おやぐにで繁昌したのは浦添の人であった。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに浦添は首里の出来ない以前に於ては沖縄島の中心であったろう。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　案ずるに沖縄の港は牧那渡、泊、那覇という順に開けたのであろう。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃には泊港が沖縄第一の港であったのである。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　沖縄と南洋諸島との交通が、察度以前に既に開けていたという証拠はあるが、南洋諸島の船舶が何港に碇泊したかということは判然しない。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「江戸立之時仰渡並応答之条々之写」という書にも「昔は沖縄島那覇港者唐融通の港にて候由」という記事がある。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "（最近神歌及び『由来記』の研究から、沖縄及び那覇の語源を発見したが、それは近著『沖縄考』で発表した。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "察度の時に沖縄に帰化した三十六姓を那覇に置いたことや、武寧の時に始めて天使館を那覇に立てて冊封使時中を迎えたことなどを見ると、那覇の村落が五、六百年前からあったということは明かである。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄人の最大欠点は恩を忘れ易いという事である。",
              "citation": {
                "source": "沖縄人の最大欠点",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄人はとかく恩を忘れ易い人民だという評を耳にする事があるが、これはどうしても弁解し切れない大事実だと思う。",
              "citation": {
                "source": "沖縄人の最大欠点",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "似たようなことは、同郷人の間にしばしば見かけたり、経験したりする風景で、お互がお互の日本語を、おきなわやまとぐちだと言ってくさし合っている図なのである。",
              "citation": {
                "source": "おきなわやまとぐち",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
