        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「鞭が厭なら、泥を調って醤をこしらえるか、それとも身のたけ三丈の鬼になるか、どっちでもその方のいい方にするがいい」　大異は早く鞭を逃れたいと思ったが、泥を調って醤をこしらえることはできないので三丈の鬼になろうと思った。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鬼になるか、よし、よし、では皆で三丈の鬼にしろ」　大異の体はそのまま石床の上へ横倒しにせられた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内が殺人鬼になるかもしれない――息子は今も危険なんです！",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼になるジャンケンして。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに一心になっているのに、可哀そうな気もするが、大切な雪之丞のためにゃあ、鬼になる外はあるめえよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "唄の最後に、手の甲を打たれた者が、鬼になる。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼になるか、人になるか、そこにも又、問題はあるであろうし、私も人たらず、鬼とならざるを得ぬような生長変貌が行われぬとは云いきれぬ。",
              "citation": {
                "source": "わが思想の息吹",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オバサンとヨッちやんは鬼になる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみも鬼になるんだよ。",
              "citation": {
                "source": "月夜のかくれんぼ",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食うや食わぬの境になると、人間が鬼になる浅ましさ、おれはこの眼でよく見て来たぞ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が青鬼になると丁度いいわね。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪悪を楽しむ鬼になる。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して鬼になるより、隠れる方が好きであった。",
              "citation": {
                "source": "過ぎた春の記憶",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は従来電力の鬼とは言われてきたが、これからは原子力の鬼になるつもりだ」というのが、その骨子である。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかといえば、提案者が、「原子力の鬼になる」と言っておられるところを見ると、含みがありそうに思われる。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂ひを嗅いで當てるなんて、犬ぢやあるまいし――私はそんな事で鬼になるのは嫌だよ」　伴三郎はツイと身をかはして、意地の惡い微笑を浮かべて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "麝香の匂ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、俺は匂を嗅ぎ出されて鬼になるなんか眞平だよ」「それぢや、もう一度｜鬼定をしようか、その方が早いぞ」　白旗直八は如才なく仲裁説を出しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "麝香の匂ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が噛み合つてゐると際限もない、――鬼は二人の方が面白いから、左孝も鬼になるがいゝ、その代り灯を消して捕まへるんだ」　伴三郎はこんな事を言ひ出します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "麝香の匂ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼になるのは私のやうな佛性の者に限るとよ」　左孝と白旗直八は背中合せに立つて目を縛り、同時に廣間中の灯を皆な消しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "麝香の匂ひ",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂いを嗅いで当てるなんて、犬じゃあるまいし――私はそんな事で鬼になるのは嫌だよ」　伴三郎はツイと身をかわして、意地の悪い微笑を浮べております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、俺は匂いを嗅ぎ出されて鬼になるなんか真っ平だよ」「それじゃ、もういちど鬼定めをしようか、その方が早いぞ」　白旗直八は如才なく仲裁説を出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が噛み合っていると際限もない、――鬼は二人の方が面白いから、左孝も鬼になるがいい、その代り灯を消して捕まえるんだ」　伴三郎はこんな事を言い出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼になるのは私のような仏性の者に限るとよ」　左孝と白旗直八は背中合せに立って目を縛り、同時に広間中の灯をみんな消しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "麝香の匂い",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、悪くすれば、善鬼になる惧れがある）　そう惜しんで、忠明は、（弟子ならば）　と、その忠言を喉まで出しかけたが、遂に、何もいわなかった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
