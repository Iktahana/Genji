        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お知らせという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお知らせの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お知らせを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお知らせという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お知らせの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お知らせは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お知らせの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お知らせと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お知らせは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お知らせはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お知らせの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お知らせの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お知らせが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お知らせを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お知らせのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お知らせに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お知らせの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お知らせの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お知らせは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お知らせの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "僕は彼の詩集、「春と修羅」を十年来愛読してゐますが、自分が無名のために、此の地方で印刷された驚くべき詩集を、皆さんにお知らせする術を持ちませんでした。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕が、いつかお知らせしたでせう？",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此セメントを使った月日と、それから委しい所書と、どんな場所へ使ったかと、それにあなたのお名前も、御迷惑でなかったら、是非々々お知らせ下さいね。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中君の人間に就いて、讀者にぜひともお知らせしたい事項は、もう他には無いやうです。",
              "citation": {
                "source": "田中君に就いて",
                "author": "――田中英光著『オリムポスの果實』序",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、父と、姉に、それから、お友達に（ウナ電）お知らせ下さいまし。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、これだけの、小さな小さな「火事教育」でも、これだけの程度にでもちゃんとしたものがわが国の本屋の店頭にあるかどうか、もし見つかったかたがあったらどうかごめんどうでもちょっとお知らせを願いたい。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、あなたに、強くなってもらいたく、あなたの純潔信じて居るものの在ることお知らせしたく、あなたに自信もって生きてもらいたくて、ただ、それだけの理由で、おたよりしようと、インク瓶のキルクのくち抜いて、つまずいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ直後のことも、あれこれ書いてお知らせするつもりでありましたが、ふと考えてみれば、そんな悲しさは、私に限らず、誰だって肉親に死なれたときには味うものにちがいないので、なんだか私の特権みたいに書き誇るのは、読者にすまないことみたいで、気持ちが急に萎縮してしまいました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室の主人にお知らせしようと思い、あなた、と言いかけると直ぐに、「知ってるよ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなる以上は、私の所言を発表して、読者にお知らせしておくのが便利と考えられる。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり確定すれば、又お知らせしますから。",
              "citation": {
                "source": "私有農場から共産農団へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だつて、何の企謀を遊ばすんではなし、主のある方だと云つて、たゞ夜半忍んでお逢ひなさいます、其のあの、垣根の隙間を密とお知らせだけの玉章なんですわ。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旗野さん、」「…………」「貴方の祕密が、私には知れましても、お差支へのない事をお知らせ申しませうか、――餘り御心配なすつておいとしいんですもの。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんならどうでも助からぬか、末期の際に次三郎｜様にお目に懸って、おのれの悪事をお知らせ申し敵が討って貰いたい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――内證でお知らせ申さうが、海から颯々と吹通すので、朱鷺、淺葱、紅を、斜に絞つて、半身を飜すこと、特に風のために描いた女の蹴出の繪のやうであつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（失物はココにある、というお知らせだろう、）（どうか、）と言う、ひそひそ相談。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――わざわざお呼び立てして、実は小郷事件が遂に解決しましたので、一寸お知らせしようと思って……」「ほう……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして出発の御時間を、すぐにお知らせ願いたいのですが……甚だ恐縮ですが……」「かしこまりました。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかり次第、後便でお知らせする、と言ってやったが、どうにも、彼等一家の様子をさぐる手段は無かった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四　決闘の勝敗の次第をお知らせする前に、この女ふたりが拳銃を構えて対峙した可憐陰惨、また奇妙でもある光景を、白樺の幹の蔭にうずくまって見ている、れいの下等の芸術家の心懐に就いて考えてみたいと思います。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、いま、お知らせ致します。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと、くわしく紹介したいのであるが、いまは、それよりも、この家族全部で連作した一つの可成り長い「小説」を、お知らせしたいのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お知らせしなければならぬ事は、むしろその後の生活に在るのです。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには態と公式めいた簡潔な文で、先頃お知らせしたＫ・Ｓ氏をよろしくと書いてあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅からお帰りなったら、お宅へいつ頃伺って好いか、お知らせ下さい。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、もしそちらでお金が急に要るような事があったら、電報でお知らせ下さいまし。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下同断）　おたづねの鎌倉右大臣さまに就いて、それでは私の見たところ聞いたところ、つとめて虚飾を避けてありのまま、あなたにお知らせ申し上げます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お歌の事に就いては、また後でいろいろとお知らせしなければならぬ事もございますが、十三、四歳の頃からもうあのお方は、新古今集などお読みになり、さうして御自身も少しづつ和歌をお作りになられて、その十七歳の頃には、もう御指南のお方たち以上の立派なお歌人におなりになつて居られたのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当は二十日ごろまでに、兄より何か、委細のおしらせあるか、と待って居たのですが。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで急いでおしらせ申しにあがりました」と申しました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
