    "definitions": [
      {
        "index": 1,
        "gloss": "joy of being born a woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ほんとうに、そんなお内儀さんになれたら女冥利につきるけれど……ねえ、銀三さん、あちこち選り好みばかりしていないでさ、手近いところであたしなんかどうでしょう。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は一生あなたの事は忘れません、私はもうあれだけ嬉しい思ひをすれば、女冥利にも盡きる位ですもの。",
              "citation": {
                "source": "歡樂",
                "author": "永井壯吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　見とれて、恍惚となったが、「女冥利、妾アどうあろうと……」　と、よろめくように前へ出た。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女一　でも、殿様のあのお言葉、ほんとうに女冥利、嬉し涙が溢れてなりませぬ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな立派な、気だてのおやさしい五兵衛さまをすてて、そんなことをするなどと、女冥利につきた方でございます。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな人数に加えて下すって、百人目の満願に私の唇を所望されるのは、女冥利というもので御座いましょう。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千石の殿様に、自分の看病をさせることが女冥利に尽きると思うなれば、お角は、どうしても明日から起きて働かねばならないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
