        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "尤もこの頃人の話で大凡こんなものかくらいは解ったようだが元来西洋の音楽などは遠くの昔バイオリンを聞いたばかりでピアノなんか一度も聞いた事はないからなおさら駄目だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "探りを入れるにしても大凡の見当を付けてからの事にしなければならないと考えたが、そのアラカタの見当が、なかなか付かなかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の身長の高さは大凡定つてゐるのであるから、無暗に最大範圍に於ける最高級に達することを欲せず、比較的狹い範圍内に於て志を立てて最高位を得んことを欲したならば、平凡の人でも知らず識らず世に對して深大なる貢獻をなし得るであらう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて今までに發表されたそれに關する意見を、私の讀んだ限りの範圍に於て考へて見るに、大凡二つに別けることが出來る。",
              "citation": {
                "source": "農村の中等階級",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の感得せし水晶の珠数は掛て今なほ襟にあり、護身刀の袋の緒は常に解て右手に引着けたり、法華経八軸は暫らくも身辺を離れず、而して大凡悩大業獣に向ふこと莫逆の朋友に対するが如し。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣づかりの桑畑は葉が大凡落ちて其芋畑へも散らばつてをる。",
              "citation": {
                "source": "寫生斷片",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幾らもしないね、其れ丈ぢや」「そんでも大凡まあどの位したもんでがせうね」勘次は又反覆して促した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "棧敷は大凡余が腰のあたりまでしか無いといふ程低い。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣づかりの桑畑は葉が大凡落ちて兼次の芋畑へも散らばつて居る。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後も大凡どうゆう風に終るか、どうして二人を孔雀から私が救け出したか、孔雀は何故二人をさらはうとしたか、孔雀は以何に同情すべき身の上であるか、私は何故心配して孔雀にさらはれた二人を夢中で追ひかけたか、といふ事などはこゝに私がくどくどと説明するまでもなく皆様の想像にお任せいたします。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "常々私が唱歌に関しては彼等のリーダーであつて彼等の歌ふ限りの大凡の種目は新旧の差別なく私の伝授に依るものばかりであつた。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の身長の高さは大凡定まっているのであるから、無暗に最大範囲に於ける最高級に達することを欲せず、比較的狭い範囲内において志を立てて、最高位を得ることを欲したならば、平凡の人でも不知不識のうちに、世に対して深大な貢献をなし得るであろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大凡その見当はわかつてゐた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはやこの様子を見た以上聞かいでも大凡の事は察しがつくが、でも念のために承わろう。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通り片袖に髪の油がしみついたと言えば大凡察しがつこうわ。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、そればかりではない、それから大凡十間ばかり離れたところには、新しい一箇の赤塗の大きな喞筒が据ゑられてあつて、それから出て居る一箇のヅックの管は後の尾谷の渓流に通じ、二箇の径五寸ばかりの管は大空に向つて烈しい音を立てながら、盛んに迸出して居るのを認めた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜周囲には村の若者が頬かぶりに尻はしよりといふ体で、その数｜大凡三十人｜許り、全く一群に為つて、頻りにそれを練習して居る様子である。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれの幼い頃はお互にまだ記憶えて居るだが、そんなに悪い餓鬼でも無かつたゞが……」　かう言つたのは年の頃｜大凡六十五六の皺くちやの老婆であつた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其証拠には、それから、大凡一年ばかり経つと、丸で人間が変つたかと思はれるやうに、もうふつゝりと女郎買をやめて、小作人まかせに荒れて居た田地を耕し、人の為めに馬を曳いて賃金を取り、養蚕の手伝をして日当を稼ぐなど、それは村の人が一時眼を聳だてる程の勤勉なる労働者と為つた　其頃である。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大凡周囲四里半の氷上にあつて、漁人の生活は、全く世の中との交渉を杜絶する。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大凡一望平坦の氷原にあつて、空は手の届くやうな低さを感ずる。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」　杜にはそれが何人であるかは大凡気がつかぬでもなかったが、ついそう聞きかえさずにはいられなかった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "因にこの無線電話の通話料は、一分間につき大凡五十円である。",
              "citation": {
                "source": "科学時潮",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官は彼の手に女の片袖が握られていることと、床の上に盃が割れていることと、机の上に注ぎかけの盃のあることによって、大凡その場の状景を察したが、死体解剖の結果、中毒の徴候は発見されないで、死因は心臓麻痺だとわかった。",
              "citation": {
                "source": "変な恋",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで使いなれた智識感情といえる語を用いていわんには、大凡世の中万端の事智識ばかりでもゆかねば又感情ばかりでも埒明かず。",
              "citation": {
                "source": "小説総論",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い娘達を引連れて彼女が町を通っている時刻は大凡知れていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場側に立つて車を待つ間、夫人はお鶴の前に近く居ながら、病院のあるといふ場処を大凡の想像で見当を附けて見た。",
              "citation": {
                "source": "燈火",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあ、家の方は大凡見当がついたというものだね」と相川は尋ねた。",
              "citation": {
                "source": "並木",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "磁石とコンパスでこれらの雲のおおよその方角と高度を測って、そして雲の高さを仮定して算出したその位置を地図の上に当たってみると、西は甲武信岳から富士箱根や伊豆の連山の上にかかった雲を一つ一つ指摘する事ができた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがおおよそ百年に一遍くらいちょっとした吹雪があったとすると、それはその国には非常な天災であって、この災害はおそらく我邦の津浪に劣らぬものとなるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
