        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「冬」は雪持の万年青に紅い実ののぞいてゐるところである。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでやはり不用意に写して置いた庭の万年青の写生画一枚を上げた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十五年五月万年青ほれ／″＼と空に小鳥をとりにがし、君涙して悲めどそれもせんなや。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと鉢の万年青すら、いまはその児に、手をのべてこそ匍ひ寄りし君がその児に、人妻よ、二人してふかく秘めたる赤き実も遂に知られて、あまつさへ、もぎりとらるゝ。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓の障子が一尺ばかり明いていて、卵の殻を伏せた万年青の鉢が見えている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして丁度真ん前に来た時に、意外にも万年青の鉢の上の、今まで鼠色の闇に鎖されていた背景から、白い顔が浮き出した。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく窓に現れた小僧は万年青の鉢の置いてある窓板の上に登って、一しょう懸命背伸びをして籠を吊るしてある麻糸を釘からはずした。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の万年青や兎とおなじわけで、理窟も何もあったものじゃありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい斑紋を持ち、若しくは珍しい形をした万年青が生じると愛好家はその非常な価値を認めるが、しかしその万年青をつくづく研究して見ると決して偶然に生じたものではなく、やはりその系統の中にその高貴な由緒を持っていた事が発見される。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "投つたまゝにして置いた万年青の鉢だの、丈の低い痩せこけた芭蕉だの、ボケだの、薔薇だのが見えた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸暑くても窓を明けることは出来ず、その硝子窓の外に並べて置かれてある大きな鉢植ゑの万年青の葉が埃塵で真白になつてゐるのを見た。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この彦太楼尾張屋の主人というは藐庵や文楼の系統を引いた当時の廓中第一の愚慢大人で、白無垢を着て御前と呼ばせたほどの豪奢を極め、万年青の名品を五百鉢から持っていた物数寄であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳の画を愛好する少数｜好事家ですらが丁度朝顔や万年青の変り種を珍らしがると同じ心持で芸術のハイブリッドとしての椿岳の奇の半面を鑑賞したに過ぎなかったのだ。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "番附といふのは、相撲や万年青のそれと同じやうに横綱もあれば、大関もあり、又貧乏神もあるといつたやうに、現代の画家にそれ／″＼格つけをしたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "くうた事のないのは杉の実と万年青の実位である。",
              "citation": {
                "source": "くだもの",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは丸い小い葉で、一つは万年青のような広い長い葉で、今一つは蘭のような狭い長い葉が垂れて居る。",
              "citation": {
                "source": "熊手と提灯",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜万年青、一名いかりおもと、それを愛して俊和尚が植えひろげてゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに万年青年のおもかげがある、どことなく人をひきつける徳がある、大いに話して大いに笑つた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "矛盾のままの、無理だらけの毎日を送って、ちっとも心に不満が起らない程日本の「家庭生活」のなかでの経験者――既に一人の女性はその家庭の犠牲となったほどの――男の人が、万年青年であり得るでしょうか。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青島を見物した、檳榔樹が何となく弱々しく、そして浜万年青がいかにも生々してゐたのが印象として残つてゐる、島の井戸――青島神社境内――の水を飲んだが、塩気らしいものが感じられなかつた――その水の味もまた忘れえぬものである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年青や葵などの植木鉢が置き並べられてあるその間をはなはだ巧みにそれこそ足音ひとつさせずにやって来ては、つい先日も私が画室のガラス障子越しにそっと凝視めていることも気がつかぬらしく、愛らしい三毛と白の二匹がひっそり冬陽を受けて寝そべってぬくもっていました。",
              "citation": {
                "source": "画室談義",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "万年青の芽分けが幾鉢も窓にならべてあって、鉢には鰻の串をさし、赤い絹糸で万年青が行儀わるく育たないように輪を廻らしてあった。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は縁側にちかい伊予簾のかげに茵を敷いていて――縁側には初夏ならば、すいすいと伸びた菖蒲が、たっぷり筒形の花いけに入れてあったり、万年青の鉢があったり石菖の鉢がおいてあったりした。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう万年青の御手入はおすみですか。",
              "citation": {
                "source": "動物園",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "金糸雀　理髪店の店さきには、朝日の光がさわやかに、万年青の鉢を洗つてゐる。",
              "citation": {
                "source": "動物園",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "建具屋と仕立屋の間に挟まつた小ぢんまりとした二階屋で、その二階の出窓に、万年青の鉢が二つ三つ、晩秋の午後の薄日を浴びて並んでゐた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆への救いででもあるのか、或は悪魔の手弄みか、実際この十姉妹の流行は、一時天下を風靡した万年青と同じく、不可解な魅力を以って、四国を発端にして中国近畿、殊に慎作の故郷附近には感冒よりも凄じい伝染力をふるった。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この附近には、十姉妹や万年青等の流行を先鞭的にきたすだけに、賭博等の悪習も封建時代から濃い筋を引いていた。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　天皇は、はじめ日向においでになりますときに、阿比良媛という方をお妃に召して、多芸志耳命と、もう一方男のお子をおもうけになっていましたが、お位におつきになってから、改めて、皇后としてお立てになる、美しい方をおもとめになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭、おもと、松、棕櫚、こんな物へ弟の馨は亡き人を忍ぶつもりで毎日水をやつてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
