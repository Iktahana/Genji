          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼女が長崎の女である限りは、お蝶さんが肺病と脚気と弁膜症を併発して瀕死の病床にあっても、それは実に、驚くべき大食らいにきまっておりますよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "長崎チャンポン――九州の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）うそ泣きなのか　セイウチさん　　　子どもよりも　大食らいして　　　ぼくらはただの薬味かよ　　　ごめんなさい　ああ（セイウチうめく）　　　あ　こんにゃろめ　ああ　　　できるのは　ふんづけることだけ　座り込む二匹のカキ、そこへ三匹目が登場。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれほどすなおでなかったし、そのうえ大食らいであったゼルビノは、いつまでもぶうぶううなっていた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなかの減っているうえに、ゼルビノはひじょうに大食らいであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはなまけ者の大食らいではあるけれど、ありふれたものとはちがって、曰くつきのもの、たとえば、すべての美しくして高遠なるものに同情するなまけ者の大食らいなのである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
