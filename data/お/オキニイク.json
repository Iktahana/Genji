          ],
          "literary": [
            {
              "text": "この肉に女中さんが猫イラズを入れたから、私が鼠の通る道へ置きに行くんだよ。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんは、そん中からお金を出して、お勝手のテーブルの上へ置きに行く。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食をする前に面紗を寝床に置きに行く時、枕の下にそっと押し込んでおき、晩になって寝床の中で食べます。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい橋が二、三間おきにいくつもかけられている。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
