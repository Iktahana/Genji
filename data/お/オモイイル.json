          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それに引かえ父というのは、何か思い入ると大きい黒い瞳がじっと凝って来て、間違ったことは許さぬという代りに相手を庇えばどこまでも庇い切る一徹さを備えた人でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし君自身の不幸に比べてみると、はるかに幸福だと君は思い入るのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえり緑鮨がのれんかけかけている、山口空腹だろうと思い入る。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の底に足がついて、世に疎きまで思い入るとき、何処よりか、微かなる糸を馬の尾で摩る様な響が聞える。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
