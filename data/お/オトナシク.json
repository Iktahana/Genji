        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども出左張屋でなく奇麗な口をムツチリ噤んで大人しくしてゐれば、それがまた妻君には癪なんだらうから………。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬でもなかなか大人しくのまぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく我儘であるくせにまた甚だしく臆病な彼は、自分で断然年賀端書を廃して悠然｜炬燵にあたりながら彼の好む愚書濫読に耽るだけの勇気もないので、表面だけは大人しく人並に毎年この年中行事を遂行して来た。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下に小さな子供が二、三十人も集まって大人しく坐っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の人らしい両親に連れられた十歳位の水兵服の女の子が車に酔うて何度ももどしたりして苦しさうであるが、苦しいとも云はずに大人しく我慢してゐるのが可愛想であつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が其處へ來る前から、中學の一年か二年位と見える子供が唯一人材木の上に腰をかけて居たが、私が描き始めると傍へ來て大人しく見て居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の人らしい両親に連れられた十歳くらいの水兵服の女の子が車に酔うて何度ももどしたりして苦しそうであるが、苦しいともいわずに大人しく我慢しているのが可哀相であった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "純潔な処女をこの一角の怪獣の棲家へ送り込むと、ウニコールがすっかり大人しくなって処女の胸に頭をすりつけて来る。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に美しいものは大人しく黙っている。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の農夫等が年中大人しく真面目に働いているのが、鎮守の祭とか、虫送りとか、盆踊りとか、そういう機会に平生の箍をはずして、はしゃいだり怠け遊んだりした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の方がたいてい大人しくしおらしくて女の方がたいて活溌で度胸がいいのがこうした群に共通な現象のようである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその男のよく飼い馴らしたと見える鴉が一羽この男の右の片膝に乗って大人しくすまし込んでいる。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でもまア、新米らしく大人しく黙っているか。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、貴郎は柄にないわ、主公様は大人しく鯛魚とおっしゃるもんです、ねえ、めのさん。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、大人しくしていなさい、とそう云うてやりまして、実は何でござります。",
              "citation": {
                "source": "朱日記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様は病気が悪いから、大人しくしろよ、くらいにしてあったんですが、何となく、人の出入、家の者の起居挙動、大病というのは知れる。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由も分らずに押付けられたものを大人しく受取つて、理由も分らずに生きて行くのが、我々生きもののさだめだ。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由も分らずに押付けられたものを大人しく受取って、理由も分らずに生きて行くのが、我々生きもののさだめだ。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若かった頃は意地が悪くて、木之助を見ると白い眼をして見下したが嫁いだ先で苦労をして戻ってからは、人が変ったように大人しくなったのである。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、泣かんでも可い、泣かないで、大人しくして居るとな、直ぐ母樣が連れに來るんぢや。",
              "citation": {
                "source": "迷子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　御膳の時さえ、何かと文句があったほど、この分では寝る時は容易でなかろうと、小宮山は内々恐縮をしておりましたが、女は大人しく床を伸べてしまいました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は十番館以外のホールへは行かず、また、十番館では、陽子以外のダンサーとは踊らず、陽子が他の男と踊っている時は、大人しく一つ椅子に腰を掛けて、いつまでも同じ姿勢のまま、陽子の体があくまで待っているのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ちゃんが黙って遊びに行ってしまったって大変御機嫌が悪いから、早く行って大人しくあやまっていらっしゃいと言うのである。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人官吏が自ら納税を怠っている時でも、彼だけはちゃんと納めたし、部下の犯罪があれば何時でも大人しく裁判所長の召喚に応じた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人しく服罪している者を爆破しようというのは勿論言語道断だが、勝手に禁錮を流罪に変更するのも随分目茶な話だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の男は大人しく頷いて、てれた笑い方をした。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビスケットとカヴァを馳走してやったら、大人しくアピア街道の方へ行進して行った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は、その時も趙が大人しくあやまるだろうと思っていた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナポレオン先生、大人しく此の船に乘せられて、Ｔ島に移りますかな？",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンは大人しく立上つたが、巡警が尚も其の腕を取つて警官の方へ引張らうとした時、憤然とした面持で、島民巡警を不自由な肱で突き飛ばした。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
