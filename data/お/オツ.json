[
  {
    "uuid": "39d3e5e3-71ed-5a55-bac2-3b48de10f452",
    "entry": "乙",
    "reading": {
      "primary": "おつ",
      "alternatives": [
        "オツ"
      ],
      "is_heteronym": false
    },
    "grammar": {
