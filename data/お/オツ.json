    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(the) second (party, rank, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "乙吉ト新美ノ二人ガ、子供ヲ大事ニ気ヲ附ケマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "パパハ乙吉ニヤリマシタ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙吉ハ二人ヲ大事ニシテクレマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大学に再び這入らうとした時或独乙人が君は独乙語が達者なんだから日本の大学なんかに行かないで金を作つて留学でもしろと説かれて父は大学を思ひ止まつたのだつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は皆、その中では真剣になつて人生と取組み合ひ全力を出しきつて文学と四つ角力をとつてるのに、詩や俳句を作る時は、乙に気取つた他所行きの風流気を出し、小手先の遊び芸として、綺麗事に戯むれてゐるといふ感じがする。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "門だけではなく、乙姫のお部屋にも、屋根や壁はあります。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それもまた乙姫の尊嚴を維持するために作られたもので、雨露を防ぐためのものではありません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浦島はなほもけげんな顏つきで、「その乙姫の部屋といふのは、どこにあるの？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、」とその時、足許で細い聲がして、「私たちはここに毎日集つて、乙姫さまの琴の音に聞き惚れてゐるのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」龜はすかさず口をはさんで、「ひよつとしたら、この掛橋も浦島の若旦那を歡迎のために、乙姫さまが特にさかなたちに命じて、」「あ、これ、」と浦島は狼狽し、赤面し、「まさか、それほど私は自惚れてはゐません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはさつきから、乙姫の居所を前方にばかり求めていらつしやる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、さかなども、少しどけ、若旦那が乙姫さまに逢ひに行くのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫さまがお迎へに出てゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島はあわてて眼をそらし、「乙姫か。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と上級の宿命の筈の浦島も、乙姫の前では、すつかり卑屈になつて逃支度をはじめた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乙姫さまは、あなたの事なんか、もうとうにご存じですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、たとひ乙姫さまが、あなたの事を何もご存じ無くつたつて、乙姫さまは警戒なんてケチくさい事はてんで知らないお方ですから、何も斟酌には及びません。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、乙姫さまのお招きだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは私たちに對してはひどく高慢な乙な構へ方をするけれども、女には、からきし意氣地が無いんですね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は無言で、くるりとうしろを向き、そろそろと歩き出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はじめて氣がついたのであるが、乙姫の背後には、めだかよりも、もつと小さい金色の魚が無數にかたまつてぴらぴら泳いで、乙姫が歩けばそのとほりに從つて移動し、そのさまは金色の雨がたえず乙姫の身邊に降り注いでゐるやうにも見えて、さすがにこの世のものならぬ貴い氣配が感ぜられた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は身にまとつてゐる薄布をなびかせ裸足で歩いてゐるが、よく見ると、その青白い小さい足は、下の小粒の珠を踏んではゐない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れたばかりの赤ん坊の足の裏と同じやうにやはらかくて綺麗なのに違ひない、と思へば、これといふ目立つた粉飾一つも施してゐない乙姫のからだが、いよいよ眞の氣品を有してゐるものの如く、奧ゆかしく思はれて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍宮に來てみてよかつた、と次第にこのたびの冐險に感謝したいやうな氣持が起つて來て、うつとり乙姫のあとについて歩いてゐると、「どうです、惡くないでせう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍宮ではこの藻を食べて、花びらで醉ひ、のどが乾けば櫻桃を含み、乙姫さまの琴の音に聞き惚れ、生きてゐる花吹雪のやうな小魚たちの舞ひを眺めて暮してゐるのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と龜は小聲で言つて無作法に乙姫のはうを顎でしやくり、「あのかたは、何も孤獨ぢやありませんよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、一つには私が今迄に、詩人である人と余りおつきあひして来なかつたといふことに過ぎないのかも知れません。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」笑って、そうして、美事に禿げて光っているおつむを、つるりと撫でた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしいものは、何もございませんが、どうぞ、お箸をおつけになって下さい。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
