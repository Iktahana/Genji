        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "が、何かしら、生きて行くのに大骨を折ると云ふことに、熱意を欠いたとでも云ふのであらうか。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "女主人は肉の小さい切れを、大骨折をして皿に取つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼としては非常な大骨折で、僅か二三日の間に、げツソリ頬の肉が※けたと思はれるばかり體も疲れ心も勞れた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦口氏の「新評註ハムレット」には、原文も全部載っているので、辞書を片手に、大骨折りで読んでみた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "からみ附くのに大骨折りさ。",
              "citation": {
                "source": "失敗園",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっきり、この界隈と見込みをつけ、一軒一軒さがして、いやもう大骨折さ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの心裡の説明は、その御当人にさえうまく出来ないものらしいし、まして私のような鈍才無学の者には、他人の気持など、わかりっこないのであるが、しかし、巷説の魯迅の転機は、私にはどうしても少し腑に落ちないところがあるので、敢えて苦手の理窟を大骨折りで述べて見た次第である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、「人の福の為めに大骨ばかり折って、自分の為にはまず福運のある方じゃござんせんな」　と苦笑して、漸く耳朶のラヂオ体操の手を収めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全篇の大骨子を彼の仁義八行の珠数に示したるは、極めて美くしく儒道と仏道とを錯綜せしめたるものなり。",
              "citation": {
                "source": "処女の純潔を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくって、その沢山の不幸な人間をもっと、もっとふやすために、あんたは、大骨折りで勉強して、そしてひとかど善人ぶってるのよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は大骨折つて、やつと、此大鱒を打殺し升た。",
              "citation": {
                "source": "鼻で鱒を釣つた話（実事）",
                "author": "若松賎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "物が物なので、このモデルにする狆を探すのに大骨折りをして、初めた所ですが、どんなものでしょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "葉茶屋の狆のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "その編輯をしていた士官が、「原稿は余るほど集まるが、いゝ原稿が無いんで――埋合せに大骨だ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、手を貸してくれ」　田方氏の首から、三本目の腕をはなすのに、余と、アパートのかみさんとは、大骨を折らなければならなかった。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっはっはっ、大骨を折らせやがった」　追跡隊の人々は、面白そうに笑いあった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん大骨が折れる探偵事件であるが、さやうに大骨が折れるところが、また虫喰ひ算ファンにとつて、實にこたへられない快味である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん大骨が折れる探偵事件であるが、さように大骨が折れるところが、また虫喰い算ファンにとって、実にこたえられない快味である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際的には石や石膏をいじるより、例えば「文化と休みの公園」の広場に飾られてるような大骨板張の大労働者像、一九三〇年のメーデーに赤い広場に飾られた大群像、または示威運動の張りものみたいな非写実的な、応用美術の方が手に入ってる。",
              "citation": {
                "source": "プロレタリア美術展を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そんな食堂とは食堂がちがいますよ――旦那も、先生も、これには大骨折りでした」「こんなところに、こんな好い食堂があるかって、皆さんがよくそう仰って下さいますよ」とお力も言葉を添えた。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "リットマンこそ迷惑な話しだが、慰めたり、宥めたり大骨を折って朝になった。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場芸術となると、ああしないではなりますまいが、塗って塗ってぬりつぶして、その上からまた線を描き起してあるというようなことで、それがすべての作家にとって、大骨折りだと思います。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやあ、貧乏暇無しでして」　と、葛岡氏は鷹揚に笑って、「学校の刺繍科なんてものは、いまのところ、ほんの附け足しで、設備といってもまだまだ貧弱極まるものですし、教えるのに大骨ですよ。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "振仮名を拾って大骨を折ってする彼の読書の辛さを思いやって、Ｇはある時、肩のこらぬ面白そうなものを、というので、講談に近い、「西郷隆盛」か何かを差し入れたことがありました。",
              "citation": {
                "source": "ある男の堕落",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の不自由な博士のことであるから、こうしてＸ号と同居していて、自分の身をまもることに大骨が折れた。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「相手は六人だから訳はあるまい」「癖を取るのは訳はないんですが、六人が一緒に集まって、話しているところへぶつかるのが大骨折りでございました」「一緒に住んでいないのだからな」「みよし屋の寮だけがまあまあで」「だから俺が教えたのさ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が花子と何の関係もなかったことを弁護するのに大骨折りをしたと、宗吉は警官の前で明けすけに話した。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "香奠の包みはとにかく、線香とか菓子とかいう物品は、本人に持ち帰って貰うわけにはゆかず、私が大骨を折って説得し、それだけは納めさせた。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
