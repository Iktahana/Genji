  {
    "uuid": "782e834a-0290-560e-88c8-c00ce485a166",
    "entry": "おは",
    "reading": {
      "primary": "おは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good morning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と忍びやかにうち出でさせ給へるに、言の葉なくて、玉枝の君はうち笑みおはしぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲の国に徂徠する天人の生活を夢想しながら、なおはるかな南の地平線をながめた時に私の目は予想しなかったある物にぶつかった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはやうござります。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここです、おはひり下さい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私ですよ、と訪問客が答へる、おはやう！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはやう、坊達、おつ母さんはお家かね？",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはやうございます、神父様、と彼女は云つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の牡雀は早速灰色の馬の方に飛んで行つた、「おはやう、親愛な牝馬さん。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おはやう、唄うたひさん、私に何か用事でもあつて？",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その時、殆ど何ものかに教えられたように、彼が二月前日本を発つ時、彼の恋人が、　――たまに公園でも散歩なさる時、おはきなさいまし。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ苹果はおはじめてでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく知ってらあ、ぼくおはなししやう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しるべの燈火かげゆれて、廊下の闇に恐ろしきを馴れし我家の何とも思はず、侍女下婢が夢の最中に奧さま書生の部屋へとおはしぬ。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神もおはしまさば我家の檐に止まりて御覽ぜよ、佛もあらば我が此手元に近よりても御覽ぜよ、我が心は清めるか濁れるか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿、今もし此處におはしまして、例の辱けなき御詞の數々、さては恨みに憎みのそひて御聲あらく、さては勿躰なき御命いまを限りとの給ふとも、我れは此眼の動かんものか、此胸の騷がんものか、動くは逢見たき慾よりなり、騷ぐは下に戀しければなり。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはぐろのような臭気が車内にみなぎっていたが出所は分からない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おんちゃんごはんおあがんなさいって」「おはんなさいははははは」　父は両手を回し、大きな背にまたふたりをおんぶして立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても遅くおはします事かな、いつも九時のかねは膳の上にて聞き給ふを。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神もおはしまさば我が家の軒に止まりて御覧ぜよ、仏もあらば我がこの手元に近よりても御覧ぜよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿、今もし此処におはしまして、例の辱けなき御詞の数々、さては恨みに憎くみのそひて御声あらく、さては勿躰なき御命いまを限りとの給ふとも、我れはこの眼の動かん物か、この胸の騒がんものか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつも暁よりなきいでゝ夕ぐれまでは御軒のものなるを、いかにしてさは聞き給ひけん、物ぐるほしくもおはしますかな」といよ／＼笑ふに、「さにはあるまじ。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例えば子供の誤って呑込んだおはじきが消化器系を通過する径路を示すのを見たが、これなどでも消化器というものの本質には少しも触れないで、ただ土管のつながりのようなものとしか思われないように出来ていた。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、七五郎さんよ」　七五郎、表から覗いて、　「とっつあん、留守か」　「え、おはいんなさいよ」　「大変だったッてねお静坊、吃驚しただろう」　「ええ、とても怖かったわ」　石松、奥より出て来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだ、これは石松の処へ来た手紙だ」　「誰からなの」　「おはん？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「四日程前よ」　「何しに行ったんだ」　「おはんさんから手紙が来たの」　「おはんさんって……誰だ」　七五郎が、　「お前の女房じゃねえか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、びいどろといふ色硝子で鯛や花を打出してあるおはじきが好きになつたし、南京玉が好きになつた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、おはいり下さいな……」と、女は小聲に私をうながした。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
