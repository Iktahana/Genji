      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tail and feathers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「一体誰がはじめにそんなものを欲しいと云い出したんだ」と人びとが思う時分には、尾羽打ち枯らしたいろいろな鳥が雀に混って餌を漁りに来た。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひき更えて小野の方は、画学校時代にこそ秀才で通ったこともあるが、彼の奉じている浪漫主義の影が薄れ無論天性の不勉強も祟って、今では全く尾羽打ち枯らしてしまって、ただ学生当時からの情誼で葛飾の画室を半分貸して貰いながら居候同様に同居しているわけであった。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜羽のこの美しい水鳥はお互いに心いっぱいに愛の喜びを感じているとみえて、小さい二つの尾羽はきそうようにふられていた。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば矮鶏の尾羽の端が三｜分五分欠けたら何となる、鶏冠の蜂の二番目三番目が一分二分欠けたら何となる。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕が風切羽と尾羽とを打ち交わす度に白い腹が翻ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏冠や、猛猛し眼の稜稜、尾羽、翼、はららぎぬ、はたはた、ああ、はたはた、岩根の、白羽蟻の吹雪と舞ふ柱を。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾羽ひろげ、雲はいま、羽ばたきにけり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すうつと落ちてゆく、大きいうねりの窪みへ、風も無い穏かなうねりだ、尾羽根を立てて、なんとまた、光つた叡智の瞳。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その畑に動く群禽つくづくと尾羽根振りては、また空へ飛び立ち翔る。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、極彩色の孔雀がきらきらと尾羽を円くひろげた夏の暑熱と光線とは、この旅にある父と子とを少からず喜ばせた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その畑に動く群禽、つくづくと尾羽根振りては、また空へ飛び立ち翔る。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなあはれ、ここの丘窪、明るけど古さび棚田、うれしけど冬の日棚田、その空に翔る群禽、鶺鴒の薄黄の尾羽のただ波うちて影もとまらず、影もとまらず。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "思金神とすべての神々は、「それではいよいよ、天安河の河上の、天の岩屋におります尾羽張神か、それでなければ、その神の子の建御雷神か、二人のうちどちらかをお遣しになるほかはございません。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし尾羽張神は、天安河の水をせきあげて、道を通れないようにしておりますから、めったな神では、ちょっと呼びにもまいれません。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはひとつ天迦久神をおさしむけになりまして、尾羽張神がなんと申しますか聞かせてご覧になるがようございましょう」と申しあげました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると尾羽張神は、「これは、わざわざもったいない。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾羽張に白帆は揚げて。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は、この青年を、彼女の「足下」にひざまずかせようという意図でもあるように夫人の片言微笑には、孔雀が尾羽を、一杯に広げたような勿体ぶった風情があり、華やかな巧緻な媚に溢れていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、一年ばかりたったある日、尾羽打ち枯らした薄汚い恰好でやって来ると、実はあんな悪いことをしたので「部屋」を追出されてしまった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "板の新しいだけ、なおさら安っぽく、尾羽打ち枯らした、糟谷の心のすさみがありありと読まれる。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつもいんねんもない人に対しては恬淡になれぬたちなのにも関はらず、尾羽打ち枯した彼の姿を見れば見るほど愛惜を覚ゆるのであつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "参事官たりし荒尾※　尾羽打枯せる今の荒尾の姿は変りたれど、猶一片の変らぬ物ありと知れる貫一は、夢とも消えて、去りし、去りし昔の跡無き跡を悲しと偲ぶなりけり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾羽身がろさのともすれば、葉の漂ひとひるがへり、籬に、木の間に、――これやまた野の法子兒の化のものか、夕寺深く聲ぶりの讀經や、――今か、靜こころそぞろありきの在り人の魂にしも沁み入らめ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、極彩色の孔雀が燦々と尾羽を円くひろげた夏の暑熱と光線とは、この旅にある父と子とを少からず喜ばせた。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、南国のぬれつばめ、尾羽は矢羽根よ、鳴く音は弦を「春」のひくおと「春」の手の。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、南國のぬれつばめ、尾羽は矢羽根よ、鳴く音は弦を「春」のひくおと、「春」の手の。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾羽うち枯らしても山杉甚作源の頼經。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "と忍びやかにうち出でさせ給へるに、言の葉なくて、玉枝の君はうち笑みおはしぬ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲の国に徂徠する天人の生活を夢想しながら、なおはるかな南の地平線をながめた時に私の目は予想しなかったある物にぶつかった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはやうござります。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
