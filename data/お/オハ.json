[
  {
    "uuid": "9b8f6389-5b7f-5f72-ae10-51ea4c73d3c2",
    "entry": "尾羽",
    "reading": {
      "primary": "おは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
