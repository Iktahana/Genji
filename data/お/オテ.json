        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「全くだ」とＡも思ふ、「しかしま、お手柔らかに」と、表情以て友達甲斐を発揮する。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな奇麗な手のお手紙を貰つた女の人が、此の世の中に幾人あるのか知ら？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いお手紙をいただきました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたび私の「惜別」が橋になって、あなたから長いお手紙をいただきましたが、私は、たいへんうれしかった。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお手紙の文面が、やさしく正直なのも大きな悦びでありましたが、それよりも何よりも、私にはあのお手紙の長さが有難かったのです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、あなたのお手紙の長さに感奮し、その返礼の気持もあり、こんな馬鹿正直の無警戒の手紙を差上げる事になりました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ三十通ほどの手紙、全部がそのＭ・Ｔさんからのお手紙だったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がきょうまで、がまんしてあなたにお手紙差し上げなかったわけは、すべて僕の自信の無さからであります。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "純真太宰治「純真」なんて概念は、ひよつとしたら、アメリカ生活あたりにそのお手本があつたのかも知れない。",
              "citation": {
                "source": "純真",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさほどは、長いお手紙をいただきました。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、何度も云ふやうだが詩人がその先人のお手本――茲では必竟本場のお手本といふことになるが――を、よく呑み込まなければならない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手を、よごすのがいやなのさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれだつて、舟の漕ぎ方くらゐ知らないわけでは、まさか、そんな、知らないと云ふわけでは決して無いんだが、けふはひとつ、わが女房のお手並を拜見したい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十九日までに五、六枚書け、といふお手紙であつた。",
              "citation": {
                "source": "義務",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七、八年も前の事であるが、私は宮崎氏からお手紙をもらつた。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうな内容のお手紙を受取り、私はへんな、夢見心地に似たものを感じた。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が牛舎の流しを出て台所へあがり奥へ通ったうちに梅子とお手伝いは夕食のしたくにせわしく、雪子もお児もうろうろ遊んでいた、民子も秋子もぶらんこに遊んでいた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上がってからおよそ十五、六分も過ぎたと思う時分に、あわただしき迎えのものは、長女とお手伝いであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが政さん、あなたの写真とあなたのお手紙でありまして……」　お祖母さんが、泣き出して、そこにいた人皆涙を拭いている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのお手紙をお富が読みましたから、誰も彼も一度に声を立って泣きました。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが師よ、　貴方が少からぬ御好意をもつて私の本をお受取りなさつたと仰言られたあの四月六日日付のお手紙は、私を非常に幸福にさせたことを、今なほ貴方に申し上げたうございます。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "翡翠の飛込みのお手本をやって下さい」　水だらけの子供を十人ばかり乗せ、櫓台の下へ田舟を漕ぎ近づけて、材木屋の貝原が、大声を挙げた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お手本をも一度みんなに見せといて、それからやらせます」　脂肪づいた小富豪らしい身体に、小初と同じ都鳥の紋どころの水着を着て、貝原はすっかり水泳場の助手になり済ましている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日も鷹見は、帰路にぜひ寄れと勧めますから、上田とともに三人連れ立って行って、夫人のお手料理としては少し上等すぎる馳走になって、酒も飲んで「あの時分」が始まりましたが、鷹見はもとの快活な調子で、「時に樋口という男はどうしたろう」と話が鸚鵡の一件になりました。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『六番でお手が鳴るよ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵のことはもう判りました」「そりゃあお手柄だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお手際じゃあ、ここにいる人間もどんなものだか判りますまいね」「いや、それで判った」と、式部は又にわかに声をやわらげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのおてんばのことは、どうも、俺には分らないよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何かおてがかりがありますか。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「盆大の月」とか、「たらいほどなおてんとう様」とかいうのも学問的にはナンセンスである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
