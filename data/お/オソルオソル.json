        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それと見るより美登利の顔は赤う成りて、どのやうの大事にでも逢ひしやうに、胸の動悸の早くうつを、人の見るかと背後の見られて、恐る恐る門の傍へ寄れば、信如もふつと振返りて、これも無言に脇を流るる冷汗、跣足に成りて逃げ出したき思ひなり。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けたらこの子はどうなるかと、恐る恐る考えた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次尚も、Ｔ「それから　其の黒羽二重に　朱鞘の長刀　落し差して　居る処……」　と云われて仲蔵、恐る恐る「それがどうか致しましたか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲蔵が恐る恐る出て来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉「おう仲蔵か」　仲蔵、恐る恐る「はい」と答える。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）　やがて、　取次の侍が、恐る恐る出て来て、其の場にペタリと平伏した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "内のお絹、恐る恐る、見ると、　山賊の好色の笑。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして輕く跳りあがる心を制しながら、その城壁の頂きに恐る恐る檸檬を据ゑつけた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手持｜無沙汰に、ほとんど恐る恐る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　恐る恐る、彼女の夫が云った。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅は、なお気がかりらしく、今度は恐る恐る、上目遣いに職長の方を見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気をつけて見ていると実にいろんなところから――それが皆申し合わせたように同じぐらいずつ――恐る恐る顔を出すのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして軽く跳りあがる心を制しながら、その城壁の頂きに恐る恐る檸檬を据えつけた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は鞄を持った片手を、鞄のまま泥について恐る恐る立ち上った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何故ともなしに……そうして絹本を表装した分厚い画帳を恐る恐る繰り拡げていたように思う。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは恐る恐るそこらをぶらつき初めた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はもう大丈夫なのかと恐る恐る住居の掃除なぞに取かかり始めたが八日の晩から、また噴火は激しくなって再び人々を縮み上らした。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははッ、（恐る恐る地につけたる額を擡ぐ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は血の気を失った顔を、恐る恐る上げて仰いだが、少年を見ると斉しく身を顫わした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　恐る恐るいうおもはゆげな状を、少年は瞻りながら、事もなげにいった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　撥を片手で引つかむと、恐る恐る差出した手を素疾く引込め、とさかをはらりと振って行く。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子を昇りつくし、それでもなるべく音の立たぬよう昇降口の蓋を開き、じつに恐る恐る半身を突出して甲板上の光景を眺めしが、オオ！",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼ばれた被告は立ち上つて、「はい」と云つて恐る恐るお辞儀をした。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　掏摸は陳じ得ず、低頭して罪を謝し、抜取りたる懐中物を恐る恐る捧げて踞まりつ、「どうぞお見逃しを願います。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と家令を先に敷居越し、恐る恐る襖を開きて、御容顔を見奉れば、徹夜の御目落窪みて、御衣服は泥まぶれ、激しき御怒の気色｜顕れたり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と握占めた掌を、自分で捻開けるようにして開いたが、恐る恐る透して見ると、「何ぢゃ、蟹か。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "身震いして少し起きかけて、旅僧は恐る恐る燈の影に透したが、幸に、血の点滴ではない。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまでは、とうけて恐る恐る干すと、ややあって、客僧、御身は苦悶し、煩乱し、七転八倒して黒き血のかたまりを吐くじゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰元は恐る恐る繰り返して、「お聞き済みでございましょうか」「ああ」とばかり答えたまう。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と荒らかに言棄てて、疾風土を捲いて起ると覚しく、恐る恐る首を擡げあぐれば、蝦蟇法師は身を以て隕すが如く下り行き、靄に隠れて失せたりけり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
