        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これじゃ、いかなだんなでも尾っぽを巻くなあたりめえでしょうよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなの足もとに、目を光らして尾っぽをつっ立てながら、ためていますぜ」「そうか、それをきいちゃ、なおほっておかれねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがいなかっぺいのけんつくぐれえに尾っぽを巻いて、江戸八百八町の名折れじゃござんせんか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "はばかりながら、あれしきのけんつくに、むっつり右門ともあろうおれが、たわいなく尾っぽを巻いてたまるけえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらもう尾っぽを巻いて小さくなっているから、ひとっ走りにやってくんな」　走らせて景気よく永住町のその大園寺へ乗りつけると、ものごし態度の鷹揚さ、あいさつ口上のあざやかさ、まことにみずぎわだった男ぶりです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのようなあきめくらがのぞいたっても、犬が星をみるようなものなんだから、尾っぽを巻いておとなしくかしこまってな」「ちぇッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "するから、尾っぽをふるから、心のよごれぬ女までが、お雪のまうなものまでが――」　たまりかねたとみえて、新兵衛は、膝の横に寝かしてあった大刀を、じりじりと引きよせた。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛が、尾っぽの毛がそこらについているような気がしてならねえですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾っぽの方からこおってきそうです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾っぽを口にくわえてて、全身にパン粉がまぶしてあってよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも口に尾っぽをくわえたあいるな。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、海へ放り投げられて、で、落ちるまでに暇があって、で、口に尾っぽをくわえるて、で、二度と口から出なくなったってえことよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尾っぽを口にくわえてて――全身にパン粉がまぶしてあってよ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、口に尾っぽをくわえるて。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「慍って飛びついて来たから、ぶん殴ってやった、けど、強くてこんなに尾っぽ食われちゃった。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「老眼鏡でないと、こまかい尾っぽのすじは判らない。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、そろそろ、尾っぽの継ぎ張りをやろう。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと、尾っぽをひろげるんだ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界一のダチョウ尾っぽも、これに比べりゃ掃除たわしだ。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、給料だけで、おっぽり出された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年、二、三カ月で、現役から、おっぽりかえされるシュギ者が不思議にも、二人か三人這入って来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなきゃ、表へおっぽりだすぞ！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを、イヌみたいに、お堂の外へおっぽり出しちまうんだ」「ぼくには、五十ターレルしかありませんが」と、ヨハンネスは言いました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうも、たぶん、おとうさんが家へ帰ってきて、ジュリーをおっぽり出したぐらいのことでしょう。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざというとき、たゞおっぽり出されの、あばよで塩花を撒かれてしまうんではつまらないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな目的でおれたちの血と汗を絞りとっていたのかと、皆んなは転げまわって口惜しがり、工事が済むといきなりおっぽり出されたことへの怒りも砂を噛む想いで、じりじり来たが、とりわけ佐渡島他吉はいきなり血相をかえて、ダバオを発って行き、何思ったのかマニラの入墨屋山本権四郎の所へ飛び込んだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　他吉は叫んで、俥をおっぽり出して、推寺町から大江神社の境内まで追うたが、ふところに君枝に買うてやった空気草履がはいっているのに気をとられて思うように走れず、到頭逃がしてしまった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはびっくりいたして、手に持っていた竹の皮包みや何かを、そこへおっぽり出して、そばへ行って『どうしたどうした』と申しました。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに、私の買物となると、おっぽり出されるなんていやだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この小厮をどこかへおっぽりだして来る」　広巳は庖厨口からゆるゆると出て往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
