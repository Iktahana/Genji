    },
    "definitions": [
      {
        "index": 1,
        "gloss": "place for dancing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "浅夜に瀟洒な鉄線を組み立てている清洲橋を渡って、人形町の可愛らしい灯の中で青苦い香気のある冷し白玉を喰べ、東京でも東寄りの下町の小さい踊り場を一つ二つ廻って、貝原はあっさり小初の相手をして踊る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の踊り場には、地つきの商店の子弟が前垂を外して踊りに来る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "止った所はもう一つの傾斜へ続く、ちょっと階段の踊り場のようになった所であった。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベランダから池の向こうの踊り場を正視していたときに、正面から左方約四十五度の方向で仰角約四十度ぐらいの高さの所を一つの火の玉が水平に飛行したというのである。",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り場でピストルをひねくり回し、それを取り上げられて後にまた第二のピストルをかくしに探るところなどは巧みに観客を掌上に翻弄しているが、ここにも見方によればかなりに忠実な真実の描写があり解剖がありデモンストラチオンがある。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その狭い入り口から急な階段を上がると、中段の踊り場に花売りの女がいた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の垢でもろけた家並の中に、まるで金の入歯をしたようにバル・デ・トロア・コロンヌだとか、バル・デ・ファミイユだとか、メイゾン・バルとか言うような踊り場が挟まっていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れは巴里祭の期間中これ等の踊り場がする、お得意様への奉仕であった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの踊り場の前にも吐き出す、乱曲を浴びながら肩を怒らしてズボンへ両手を突込んだ若者と、安もので突飛に着飾った娘達とが、ごちゃ／＼していた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯んな場所に不似合な程、見優りのするベッシェール夫人がその踊り場の一つのブウスカ・バルへ傘をつぼめてつか／＼と入って行くと彼等は話声を止めて振返った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其所を通って奥の突当りに十三坪ほどの踊り場があった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と歯痒ゆそうに返事をしながらジャネットは目につくほど踊り場の空気に呼吸を弾ませていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は入口の通路から踊り場へ移る角のテーブルへ坐った。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば巴里の踊り場でみる日本のタンゴというものが腰に異様なねばりと業があってみんな女と柔道をやっているもののように眺められた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを上がった踊り場は、正面玄関から上がれる飾り立てられたもうひとつの階段の反対側に当たる。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この踊り場から応接間と寝室数室に通じていて、カニンガム親子の部屋もそこに含まれていた。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "我を忘れて部屋から踊り場の方へ駆けてゆく。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ヱレベータアを出て、踊り場へ入つていくと彼はいつでも憂鬱を感じた。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木はこの青年を、どこかの踊り場で見てゐるに違ひなかつた。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも行きつけの踊り場だけに、アトホームな感じがした。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時すぎると、さすがに踊り場らしい華やかな気分が漂つて来た。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り場の気分が、段々高調に達して来た。",
              "citation": {
                "source": "二つの失敗",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森は中央階段をのぼり、デコレイション・ケーキのような、屋上出入口の踊り場で立ちどまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森は、あきらめて踊り場に坐りこみ、慶一にも、そうするようにうながした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮の屋上への出口、「サンルーム」と呼ばれている、三六〇度ガラスにかこまれた、踊り場の屋根の上にカメラをセットしおわったときには、太陽はかなり高くなっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四階の踊り場なら、どん詰まりなので、慶一と柾生がいる三階の踊り場よりはマシだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の踊り場にも三人組がいる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーラスまでくると、非常扉が開いて、頭が雀の巣のようになった、一八〇を超える大男が、ノブをもったまま、踊り場の慶一と柾生を見る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　踊り場からようやく初めて二｜哩も踊子を連れて来て、与えた花束の大きさを較べられては、甲谷とて発奮せずにはおられないのだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四メートルほどのぼると、岩のおどりばがあって、そこからまた鉄ばしごがつづいています。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
