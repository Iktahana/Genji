  {
    "uuid": "1928942d-79a2-5d44-890d-ecf444b37629",
    "entry": "応竜",
    "reading": {
      "primary": "おうりゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Yinglong (dragon and rain deity)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "明の嘉靖年間、林応竜適情録二十巻を編す、中に日本僧虚中の伝ふる所の奕譜三百八十四図を載すといふ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊楠いわく、支那でも、古く黄帝の世に在った応竜は翼あった。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那で応竜を四足に画いた例を多く見たが、邦俗これを画くに、燕を背から見た風にし、一足をも現わさぬは、燕同様短き二足のみありという意だろう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから思い付いてリンネウスが飛馬竜（ペガスス・ドラコニス）と命名したまま今も通用する小魚、和名はウミテング、その形怪異で牛若丸の対手としていつも負けている烏天狗や応竜の日本画に似、英語で海竜という。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
