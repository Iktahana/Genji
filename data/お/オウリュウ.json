[
  {
    "uuid": "7f6a85ff-0700-525b-91d6-dc9b2fe3ed08",
    "entry": "横流",
    "reading": {
      "primary": "おうりゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
