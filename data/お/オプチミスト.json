        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そしてこんな些細な事柄にもオプチミストとペシミストの差別は現われるものかと思ったりした。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者はペシミストであり、後者はオプチミストであるともいわれる。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年二十年と経つたら、今より数十倍応用の範囲が弘まり、五十年も経つたら、各国の小学校の必須科目になるかも知れん、現に既に必須科目にしてゐる地方もある位だから、そりや然ういふことになるかも知れん、私はエスペラントの将来に就いては大のオプチミストだ。",
              "citation": {
                "source": "エスペラントの話",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はオプチミストです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朗かな理知」は、オプチミストの涙よりもペスミストの微笑を愛したであらう。",
              "citation": {
                "source": "ファンテジイ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はオプチミストではなかつた。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、オプチミストになつたのだ。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、オプチミストになり得たことを今は、ともかく、最も誇る。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は更にオプチミストにならなければならず、そしてオプチミストたることを、真実誇る。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は更に偉大なオプチミストとなる為に、多くの影を墓に埋めて行くであらう。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その如くに、私はオプチミストたり得た。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルトルが共産党員だなどゝいふのでサルトルの文学に文学以外の読み方をする日本の批評家の精神的貧困は哀れビン然たるもので、彼の文学は凡そ共産党などゝいふものではなく、非常に安易な絶望、非常に安易な欲望の否定で、あはれむべきオプチミストであるにすぎない。",
              "citation": {
                "source": "観念的その他",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果引き出されるものがペシミストの像であるか、それともオプチミストの像であるかなどということも、差当り心配しないことにする。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
