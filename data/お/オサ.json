        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や、観念なぞ、無用の長物といつた有様である。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "長の年月、海を見るたびに、おぼろに感じてゐたことが、急に明るみに出た感じ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、右のことが分つたので歓喜にむせぶ気持でゐるが、又一方、長年求めあぐんで、暗中模索してゐたものが、一時に分つたので、慄へてもゐるといつた状態である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の紹介は少しく長くなりすぎた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かういふ誤解といふものが、長い間には、どのやうな所まで増大してゆくものか、それは頗る大した増大なのだが、かゝる誤解は、特殊的なものであるので、世間一般からは、顧みらるべくもなく、Ｂはそれを、創作にでもするよりほか、致し方もないことだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、長いことはない、四五年の寿命だが、高等学校の文芸部の我鬼大将であつたこと以外に如何なる文学的経歴をも有しない男が、雑文家だの、批評家だの、評論家だのといふ肩書の下に、世間といふ舞台をのし歩くのである。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か処方せんけれあならんと思つたかした校長は、その五名を放校に、他の十五名を謹慎処分といふことにしました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窮地に陥つた校長は、遂に如何にすべきか、文部省迄陳情して来ました。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気の軽重で、処分の軽重を決めたといふ校長の頭の程は、凡そ奇ッ怪なものでありますが、或ひは此の校長が、その地では人望のある、謂はば人格者かも知れないのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長がもし人望のよい人である場合は、文部省によつて、アツサリ放校が取消されたにしても、何らか校長の顔を立てるためには生徒の方に臨時の損が振りかけられたに相違ありません。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリスタン・コルビエールは、千八百四十五年、七月十九日、午前八時、モルレーに於て汽船会社の社長の息子として生れ、千八百七十五年、三月一日午後十時同所で死んでゐるから三十年に足らぬ生涯であつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は長い間トリスタン・コルビエールは美的感情を欠いてをり、芸術に無智であると思つて来た。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ積めるに決つてゐると、腹の立つてゐる矢先ではあり「えゝこなひだ府の何とか課長さんの引越が一台で出来たといふ新聞の記事を見ましたよ」と、僕は二人の間に立ちはだかるやうに云つたのだつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母の来るのはいやに遅いが、どうせ近所へのお暇乞ひがまた長いのであらう。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒屋の御用聞きが現れて、何なりと御手伝ひしませうと云ふと、有難いが「あれを何処これを何処と、片附けるのは却々自分でないと分らないから」と、それをニコ／＼しながら、長々とやるのでその御用聞きはしまひには僕の顔を見て笑つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　押入の掃除をすませて、漸く中から出て来ると、前ゐた人が忘れて行つたらしい粗末な白木の小さな神棚（神道の）、それが茶の間の長押の上に三角の棚を打付けてその上に載せてあるのだが、それを下ろして呉れといふ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると私は白い糊の付いた看護衣の、長い四角い顔の、スリッパを穿いた男を想ひ出すのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さ二町ばかりの、その暗い湿つぽい通りに、今挙げたホンの三四軒の店屋が所々にあるのは、まるで蛍でもゐるやうな感じだつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍々あつて男――もう今では夫、入口より葉巻を銜へ、長きマントの儘、如何にも寒い中を歩いて帰つて来た風である。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　淋しからう淋しからうつて言つといてはあなた出て行くのね、そして長い間、帰つてはいらつしやらない。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　長く出てゐりやあ、お前が手紙を書くに遥つくり出来るだらうと思つてね、とそれはまあ冗談だが………。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符売場前の長い列の、私は最後の方だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなかが空いた時芝居なんかの中に、さう長くゐられるものではない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して、貧しき境遇にあるもの、生れながらによきキリストの血を受けて長く苦労せる人人の心には、自然とやさしい人情の種が蒔かれて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを当の松岡は（これは譬噺で、事実談ではありません）レニンに呆れられているという事にも気づかず、「なんだ、レニンってのは、噂ほどにも無い男だ、我輩の眼光におされてしどろもどろではないか、意気地が無い！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なんか、首でも吊らなければおさまりがつきそうもないのに」「そうして、君がいちばん長生きをするだろう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
