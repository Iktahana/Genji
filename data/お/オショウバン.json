    "definitions": [
      {
        "index": 1,
        "gloss": "sharing a meal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何しろ、杉野の家で、早午飯に二人で牛肉なべをつゝいて居ると、ふすま越に（お相伴）といふ聲がしたと思ひな。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旨うございましたよ、私もお相伴しましたっけ、」　と悠々と迫らぬ調子で、「宵には何事もありませんでした。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だけがお相伴さして頂きます」　私はまたしても、河沿いの家の人事に絡み込まれるのを危く感じたが、それよりも、いまの取り止めない状態に於て、過剰になった心にああいう下町の閉された蔵造りの中の生活内部を覗くことに興味が弾んだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お相伴しますとも、お取膳とやらで、」　と小芳が嬉しそうに云う。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）亀姫　ああ、姥、お前も大事ない、ここに居てお相伴をしや。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歪んだ運命のお相伴なら、もう父や葛岡のことだけで沢山でございます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはかの女がいのち賭けで起して呉れるそれのお相伴に与って、僅に人生の無聊を消し得たのではあるまいか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終｜脂っこいもののお相伴をするせいよ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子を出して殘念ながらお相伴は出來ないと云つた。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛もそのお相伴で、おちおち眠られなかった。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何もありませんが、おあがりになってくださいまし、お嬢さんも私もお相伴いたします」　章はお辞儀をした。",
              "citation": {
                "source": "狼の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その都度、私がお相伴に預かるのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者も稽古が遅くなった時、二三度夕食のお相伴をしたことがあるが、遠慮のないところ無類の肉類好きの祖父の影響を受けた自宅の夕食よりも遥かに粗末な、子供心に有難迷惑なものであった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもお相伴を難有うございますよ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ゼラール中尉と一緒にいるということは、常に彼の意志や欲求のお相伴をするということであった。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もここでお相伴をするから。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お相伴させていただければしあわせに存じます」　活発にいうと、おくする色もなくちゃぶ台についたものでしたから、右門は当然のごとくにあり合わせの精進物だけをそちらへ分けてやりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして加集は能くそのお相伴をしたのであつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、単に Par amour（色ごととして）ならお相伴しますがね！",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するてえと、不意に何処からともしれず、とんと素性も分らねえ男が入つて来て、お相伴にあづかりたいといふんでさ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古のたびごとに、うら若かった嫂といっしょに、いたずら盛りの小伜かく申す自分も、ちょこなんとお相伴して、窮屈な茶室にしびれを切らせながら、結構な御ふくあいなどと、こまっちゃくれた挨拶を無意識に口にしたものであった。",
              "citation": {
                "source": "茶の本",
                "author": "はしがき",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芝居から帰ると二階へあがって、寝る前に白｜葡萄酒をあがるのえ、わたしもお相伴するわ。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしもお相伴をさせられる。",
              "citation": {
                "source": "源泉小学校",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって自分の手にかけたお座敷で、兄弟分がこしれえたお庭を眺めながら、旦那様のお相伴をして一杯頂戴出来るなんて職人｜冥利の行止まりでげしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外だつたのは、その女が食堂でいつもあのお婆さんのお相伴をしてやつてゐる大人しさうな顏の娘だつたことである。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのお相伴をくらって、あそこの洗面器の下の下水穴から顔を出した不運な溝鼠が、鶴彌氏に殉死してしまったというわけなんですが、如何ですな」「大いへん面白い御創作ですね。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三「小糸氏さあさあ遠慮はいらない、ここでゆっくりお品殿と、ままごとをしてお遊びなされ、拙者お相伴いたしましょう」　ここは神田神保町の、十二神貝十郎の邸であった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ兄さんが一人で二階で飲んでる分にはちっともかまいませんが、私もお相伴をして、毎日飲んでるとなっては、帳場の手前にしてもよくありませんからね」　これが惣治の最も怖れたことであった。",
              "citation": {
                "source": "贋物",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾お相伴いたします」　で、お浦は茶碗を引き寄せ、自分の膝の前へ置き、それへ徳利の酒を注いだ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにかおしょうばんにあずかりたいこと。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
