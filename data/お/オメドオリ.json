    "definitions": [
      {
        "index": 1,
        "gloss": "audience (with someone of high standing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "はじめてお目通りを致します。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はツ、初めましてお目通りを仕ります。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目通りに控えさせましたるは、当座の太夫元滝の白糸にござりまする。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、お目通りで、着物を引掉って神田児の膚合を見せてやらあ、汝が口説く婦じゃねえから、見たって目の潰れる憂慮はねえ、安心して切立の褌を拝みゃあがれ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やぁ、はぁ、これは先生、かけちがってお目通りもし申さんで。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、大碓命は、その二人の者をご自分のお召使いに取っておしまいになり、別に二人の姉妹の女を探し出して、それを兄媛、弟媛だといつわって、天皇にお目通りをおさせになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、王さまのお目通りへ、つれて出ました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、みんなは、「この人を、王さまのお目通りへ、つれて出よう。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でもありましょうが、江戸時代にはオランダ人が五年に一度ずつ参府して、将軍にお目通りを許される事になっていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は五、六人に大木を舁かせていて、御主人にお目通りを願うという。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「塩冶の奥方にお目通りして、かの歌を窃とまいらせましたら、手にとりあげて御覧じて、しばしは顔をあかめておわす。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その殿様というのはエラソウで、なかなか傲然と構えたお方で、お目通りが出来るどころではなく、御門をお通りになる度ごとに徳蔵おじが「こわいから隠れていろ」といい／＼しましたから、僕は急いで、木の蔭やなんかへかくれるんです。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳蔵おじは大層な主人おもいで格別奥さまを敬愛している様子でしたが、度々林の中でお目通りをしてる処を木の影から見た事があるんです。",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、四、五日してから、その男は飄然として登城した、そして、忠直卿にお目通りを願いたいと目付まで申し出でた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身が今、お目通りに出たら必定お手打ちじゃ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たといいかがなろうとも、お目通りを願うのじゃ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "末には百姓町人の賤しきをさえお目通りに引き給い、無礼に飾なく申し上ぐることを、いと興がらせ給えり。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、早速に御前へお目通り願おうぞ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸旗本早乙女主水之介、松平の御前にお目通り願わしゅう存じまするが、いかがにござりましょう」「なになに、旗本とな――」　声をきいて、源七郎君お自ら磊落そうにふり向くと、流れに垂れた釣竿をあやつりあやしつつ、じいッと退屈男をやや暫し見守っていたが、伯楽よく千里の馬を知るとはまさにこれです。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて藍丸の都の王様の御殿へ着いて、御殿の大広間で皆が王様にお目通りを許されて、この鏡を取った前後のお話しを申し上げた時、この珍らしい鏡というものを拝見に来ていた、沢山の貴い人々の内で、泣かぬ者は一人もありませんでした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様、かうして直々お目通りをして御機嫌を伺ふことの出来ましたのを何より喜ばしく存じます。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちが参って都のめずらしいお話などお聞かせ申したらお慰みにもなろうに……」　それは千枝太郎が待ち設けているところであったので、彼は是非お目通りが願いたいと頼むと、家来の一人は奥へ立って行ったが、やがて一人の侍女らしい女を連れて来て、彼女の案内で庭口へまわれと言った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初めてお目通り仕まつりまする」　千枝太郎は、草に手をつきながらそっと見あげると、正面に坐っている若い女――無論それが三浦の孫娘の衣笠であろう――年こそ少し若いが、その顔かたちはかの玉藻に生き写しであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よしんば居りましたところで、決してお目通りへ出て来るやうな事はございません。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うめえ話じゃアねえか」　と、吉をとりまく職人たちは、ワイワイひしめいて、「妻恋小町の萩乃さまにじきじきおめどおりをゆるされるばかりじゃアねえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「助左衛門と同じ御病気だ」康継はふと胸苦しげに云った、「――御発病の初めから全身が御不随であられたらしい、侍医の言を楯に老臣どもが拒むため、おれもいちどきりおめどおりをしてはいないが、……ただしきりに涙をおながしなさるばかりで――」　それ以上は言葉が続かなかった。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度ばかり新泉を訪ねた、いちど殿におめどおりをしたい、うかがいたいことがある。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっとした表情で、風呂舎から出ると、持参の古びた帷子に、そまつな葛布の袴をつけ、茶を啜る暇も惜しいというふうに、「比女さまに、すぐおめどおりが願いたい、と申上げて呉れ」　こうせきたてた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしい、押しておめどおりをしよう、案内して呉れ」　そして、さっさと廊下へ出ていった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "権之丞は縁側に坐って、「比女さま、権之丞おめどおりを願います」　かなり高い声で云った。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
