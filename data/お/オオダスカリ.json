        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だいいち、あなた、ちゃんばら活動のロケエションが大助かりです。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかげで私も大助かりでございます。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭さまで大助かりをいたしました。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それじゃあ牛も大助かりだ。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのお金を届けて下さいましたときは、ほんとうに大助かりでございましたの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に殿様お気に入りで、お手廻りの御用はすべてお菊が勤めてくるるので手前共も大助かりだ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の航海にはしかしお陰様で大助かりをしまして、ゆうべからきわだってよくなりましてね」　と付け加えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもまあ、目あきであって大助かりだが、ときにおまえさんは妙なお道楽をお持ちだね」「へえい、あいすみませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "籔蚊があまりゐなくなつて大助かり。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し開けましょう」　若い男がそういって車窓をあけると、老紳士は額を拭きながら、「これは、大助かり」　私は説明をつづけた。",
              "citation": {
                "source": "ペルゴレーズ街の殺人事件",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも倅がいるので大助かりさ。",
              "citation": {
                "source": "父",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し講演後の御馳走だけは里見君が勇敢に断つてくれたから、おかげ様で大助かりだつた。",
              "citation": {
                "source": "講演軍記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お信さんは躊躇もなく、気軽に私の肩に手をかけながら、「よう言うておくなはつた、大助かりどす。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い姉が、秋の展覧会に入選いたしましてあのお金大助かりでございましたのよ」　二人はいつか肩を並べて歩いていました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ昔のことですのさ」「そう諦めててくれりゃア、私も大助かりだ。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "平、片山両氏が手つだいに来てくれて大助かりだった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると召集をうけたから、名誉なことである、わが家の誇りでもある、大いにお国のために働いて下さいと大そう感動ゲキレイしたのはヤッカイ者が一人へって大助かりだという気持からの国家への感謝感激のアラワレであったろうと人々は推察した。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあれば、仕事の上に大助かりだね。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、こつちの手持だけ、その値段でやれると大助かりだわ」「わかりました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が政治に凝らないのは世のため人のため大助かりだなぞと考えた。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベスさまは一ばんよくできたかたで、手まわしがよく、わたしは大助かりです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り私は大助かり、お蔭で悪口云われません。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハガキを書くと少し手が慄えたが、もう痛まないだけでも大助かりです。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "喉渇いてないから」「なかなか経済だね、この子は」――ルピック夫人はいう――「みんな大助かりだ」　そういうふうで、彼は、はじめの一日、朝から晩まで、葡萄酒を飲まずにいた。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあなたが助けに来て下さつたので、本当に大助かりよ。",
              "citation": {
                "source": "姉弟と新聞配達",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかに宿をとらなくちゃアならないと思っていたところを、こうしてこちらへ御厄介になることになって、旅籠賃だけでも大助かりだよ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「地主さんがわかった人ですから、わたしどもも大助かりなのです。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもやってみてくれようと言うなら、わたしは大助かりさ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりや勿論、多少でも何とかして貰へれば、僕の方も目下融通が付かなくつて弱つてゐるんで大助かりだが、今日の主眼点はそれぢや無いんだ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正直に云って、ペレールの人たちが、このことについて知っていないのは、おおだすかりです。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
