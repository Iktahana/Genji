    "definitions": [
      {
        "index": 1,
        "gloss": "carrying (someone) on one's back (esp. a child)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一体、私の背に負んぶをして、目を塞いで飛ぶところだ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おはんなさい、ハヽヽヽヽ　父は兩手を廻し、大きな背に又二人を負んぶして立つた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を負んぶすることでさえも、非常に肩が痛く、また重いものである。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を負んぶした波田は、汗をたらしていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の母ばかりでなしに、沢山の母たちが毎日のように警察に出掛けて行ったが、母はそこでよく子供を負んぶした労働者風のおかみさんと会った。",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が何時か特高室で会ったことのある子供を負んぶしていたおかみさんが、その蜜柑の一つを太い無骨な指でむいていたが、独言のように、「中にいるうちのおど（夫のこと）に一つでも、こんな蜜柑を食わせてやりたい……！",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少しお前が良くなれば、俺はお前を負んぶして、ここの花園の中を廻ってやるよ。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事が始まつたのかと、背中に子供をたゞ負んぶして駈け出して來る隣村の人も見えた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "町は海岸の停車場から五キロほど山道を曲りくねって登った所に嶮しい階段のように造られ、海抜二〇〇米の懸崖の上に家が家を負んぶしたような奇観を呈している。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しもこの時誰かが、この男、徳次に向つて君はこの奥さんの幼い時に抱いたり負んぶしたりしたことがあるのかねとからかひ半分に訊いたら、彼は本気になつて考へこみ、何かしらそんなことがあつたやうに思ひ出し、信じこんだかもしれない。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、負んぶなどして」といいますと、「大木へ蝉が止ったようでしょう」といって揺すぶるので、「大木へ蝉、大木へ蝉」といっては取りつきます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ババンに負んぶしなさい」　そういって、熱のあるという末子、十二歳の千博を、ヨネが便所につれて行く気配が聞えた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知ってますとも、わしはな、昔諸戸屋敷に奉公して居って、道雄さんの小さい時分抱いたり負んぶしたりした程じゃもの、知らいでか。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが間もなく、それに代る木野田清太郎老という七十余歳と、ねんねこで孫を負んぶした佐藤八三さんという二人の古老が現われ、じゅんじゅんと、金売り吉次の由来因縁を説明してくれ出した。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おんちゃんごはんおあがんなさいって」「おはんなさいははははは」　父は両手を回し、大きな背にまたふたりをおんぶして立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「王のおッ母ア、上の子供をおんぶして、工場へ泣いて来る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんぶするならしてくれ、で、些と他愛がないほど、のびのびとした心地。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなかにも子供がいるし、背中にひとりおんぶして、もうひとりの子の手をひいて、そうして自身もかぜ気味で、一斗ちかいお米を運ぶ苦難は、その涙を見るまでもなく、私にもわかっている。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人をお見送りしてから、目刺を焼いて簡単な昼食をすませて、それから園子をおんぶして駅へ買い物に出かけた。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ひと片附きしたので、園子をおんぶして行ってみると、向うから、隣組のお方たちが、てんでに一本二本と瓶をかかえてお帰りのところであった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりで夕飯をたべて、それから園子をおんぶして銭湯に行った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してそこ／＼に踏台から降りて、手伝ひに来てくれた姉の児を引きとつておんぶした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱いて戻って、介抱をしたあとを、里へ……人橋かけるじゃあなし、山男そっくりの力ですから、裸おんぶであっためながら、家へお送りはしたそうですが、それがもとでお亡くなりは、どうもぜひない事でしたわね。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……前に内にゐて手まはりを働いてくれた淺草ツ娘の婿の裁縫屋などは、土地の淺草で丸燒けに燒け出されて、女房には風呂敷を水びたしにして髮にかぶせ、おんぶした嬰兒には、ねんねこを濡らしてきせて、火の雨、火の風の中を上野へ遁がし、あとで持ち出した片手さげの一荷さへ、生命の危ふさに打つちやつた。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこだどこだ」「下の方には居ないようだ」「二階だ二階だ」　といううちに、五六人ドカドカと二階の梯子段を飛び上って来る音をききますと、ヒョロ子は慌てて豚吉の方へ背中を向けて、「サア、私におんぶなさい」　と云いました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しいすがたをしたおかみさんが、子供を半てんおんぶで背負ひこみながら、天日のさす道を歩いてゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母は誰かをおんぶしてゐるらしく、ねんねこを着て居た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酌のひとは、鳥のように素早く階下に駆け降り、やがて赤ちゃんをおんぶして、二階にあがって来て、「さあ、逃げましょう、早く。",
              "citation": {
                "source": "貨幣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母は誰かをおんぶしているらしく、ねんねこを着ていた。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その日は、当寺へお参りに来がけだったのでね、……お京さん、磴が高いから半纏おんぶでなしに、浅黄鹿の子の紐でおぶっていた。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
