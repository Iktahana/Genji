        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "手紙で失礼ですがお願いいたします。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それでは何分お願いいたします。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では何分とも、よろしくお願いいたします。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうかお願いいたします。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうかそうお願いいたします。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私もどうかそうお願いいたします。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくお願いいたします」　ほとんど入神の演技でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは大姉さんに、お願いいたします。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「割に素直に書かれて在ると思いますから、いい作品だと思いますから、どうかよろしくお願いいたします。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "御多忙中を大変恐縮に存じますが、本紙新年号文芸面のために左の玉稿たまわりたく、よろしくお願いいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお御面倒でしょうが、同封のハガキで御都合折り返しお知らせ下さいますようお願いいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦号には是非お願いいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の礁が一日も早く除れまして、此の荒海を往来する諸人をお助けくださいますようにお願いいたします。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私で能ることなら、往っても良いのですが」「それはどうも有難うございます、どうかお願いいたします」「何方ですか」「すぐですが、車を持っておりますから」　老嫗はちょっと背後の方を振返って指をさした。",
              "citation": {
                "source": "賈后と小吏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「送ってあげましょう、私も猟にきて帰れないので、しかたなしにここに寝ておりますものの、ゆっくり睡れないのですから、貴女の家の簷の下でも拝借しましょう」「では、お願いいたします」　章は立ちあがって猟袋を背にかけはじめた。",
              "citation": {
                "source": "狼の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　編輯長は思いがけぬ豹一の申出でにすっかり気を良くして、そんな冗談をいい、「それじゃ、くれぐれもお願いいたします」　という豹一の汗のたれるような言葉を耳に残しながら、電話を切った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、お願いいたします」　元振は声をかけてまた戸を叩いたが、依然として応がないので、彼は中へ入って声をかけるつもりで戸に手をかけてみた。",
              "citation": {
                "source": "殺神記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、すこしお願いいたします、私は旅の者ですが」　元振がこう言ったが、聞えないのか女は顔をあげなかった。",
              "citation": {
                "source": "殺神記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、もし、しょうしょうお願いいたします」　中から年とった男の声がした。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、どうぞお願いいたします」と言うのである。",
              "citation": {
                "source": "秋草の顆",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのとき運悪く、峻も私の傍にいたのであったが、貞子は峻の前に手を突いて「どうぞ宜敷くお願いいたします」と挨拶をした。",
              "citation": {
                "source": "秋草の顆",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞわたしに代わり、吉川訓導の卑屈な不道徳極まる行為を責められ、哀れな少女千葉房枝の名誉を世の中の人々にお告げくださいますようお願いいたします。",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの話は今後もお忘れになりませんでしたら、もう少し年のゆきました時にお願いいたします。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、お委せいたしますから、何うかよろしくお願いいたします。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つかぬことをお願いいたしまするが、ただいますぐと、ご城中にお使いのお腰元たちのこらず、わたくしにかがしてくださりませぬか」「なに、かぐ？",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓホテルや、Ｔホテルだとどうしても人目につきやすいですから」「じゃ、そうお願いいたしますわ。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと、あたくしはこれから警察に参り、あの井戸まで出張して頂くようにお願いいたしますわ」「待ちなさい」と夫の声が慄えた。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしくお願いいたします。",
              "citation": {
                "source": "日記・書簡",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにとぞお願いいたします。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どももいつか許されますようおねがいいたします。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
