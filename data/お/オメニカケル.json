          ],
          "literary": [
            {
              "text": "こんな前置きを書くと、さも長いものを書きさうでもあらうが、骨子だけを誌すにとゞめて、色んな場合に適用してお目にかけるといふことは一切抜きにするから、そんなに長くはなるまい。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「旦那、魅込まれたようにあとびっしゃりをしながら、厭だ、神さまへお初にお目にかけるもんだから、途中で開けることはならないッて申しやす。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもね、あの、お宮様へ行かない前に、他所の人に見せるのは口惜しいんですから、私、貴下にお目にかけるわ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図を書いてお目にかけると、よくわかるのですが、謂わば、フランス式とドイツ式と二つある。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "画を書いてお目にかけると、よくわかるのですが、謂わば、フランス式とドイツ式と二つある。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は袋の中から七篇の見本をとりだして、もいちどお目にかけるまでのことだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様にお目にかけるほどの本芸は、お互にうぬぼれぬ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう四、五日余裕があれば、私も、いろいろと思案し、工夫をこらして、これを、なんとか一つの物語にまとめあげて、お目にかけるのだが、きょうは、すでに三月二日である。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴兄の短篇集のほうは、年内に、少しでも、校正刷お目にかけることができるだろうと存じます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "再々悪筆をお目にかける失礼、お許し下さいまし。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村山伏の犬おどしにて、お目にかけるものにてはなしと云って、差し出す。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も毎朝ラジオ体操がやれるようなほがらかな気分になれれば、そうしたら、きっといつもきげんのいい顔をお目にかけることができるかもしれない。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一顔を見ると直ぐに清書を持出して、お目にかける。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、もう一つお目にかける物がある」　老人はさらに桶の板一枚を出してみせると、ゆうべの矢はことごとくその板の上に立っていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでしょう、私たちは、その要求が通ればよし、通らなければ、私たちの力がどのくらいあるかを、お目にかけるまでです」　ストキは最後の言葉に、力をこめて言い切った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も、いま暫くで、三田さんの親友として恥かしからぬ働きをしてお目にかける事が出来るつもりでありますが。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "命婦は源氏の今日の出立を申し上げて、この手紙を東宮にお目にかけると、御幼年ではあるがまじめになって読んでおいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、あたしの踊りをＦさんにお目にかけるんですつて！",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今おもしろいものをお目にかけるから。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女に、もし少しでも良心が残っていらっしゃるのなら、今貴女にお目にかけるものを、平然と読めるかどうか試して御覧なさい！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先日のお言葉に、御老年の御身、次の御参府も望まれないによって、虚堂の墨蹟御覧になりたいとのことでござりましたが、この後とも引続き御参府をお待ちいたせばこそ、わざと今日はお目にかけるのを差控えたのでござります。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱんぱんとひとにらみに藻屑をあばいてお目にかけるから、ついてきな」「ちげえねえ」「おそいや！",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お目にかけるやうなものぢやありません。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどの石部金吉なむっつり右門が、今回の四番てがらにばかりは珍しくも色っぽいところも少少お目にかけることになりましたから、まことに春は価千金、あだやおろそかにはすべからざるもののようです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするてえと、おれもちっとてつだうかな」　物静かにいいながら、ではまた、そろそろはなばなしいところをお目にかけるかな、というようにゆうぜんとあごをなでだしたものでしたから、すっかり有頂天になってしまったものは伝六です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この果物がどんな不思議な働を致しますかという事は、直きに貴方にもお目にかける事が出来ましょう。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとかやってお目にかけると、チャンスカ某にいっておいて下されい」　と、楊博士はすこぶる快諾の意を表したのであった。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "能因　　唯今お目にかける。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女に、もし少しでも良心が残つていらつしやるのなら、今貴君にお目にかけるものを、平然と読めるかどうか試して御覧なさい！",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ちょっと見当たらず、お目にかけることはできませんが。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
