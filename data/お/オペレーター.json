        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一九七〇年代に入ってから活版にとって代わったオフセットでも、まず原稿をそばに置いて、写真植字機のオペレーターが一字一字、文字を選んで写真に撮りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇年代に入ってパーソナルコンピューターやワードプロセッサーで原稿を書くことが多くなると、工夫すればオペレーターによる作業を省けるようになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一字一字印画紙に文字を撮影していく写植オペレーターの都合を考えて、そんなときは、変化する字詰めに合わせて区切りを入れた原稿用紙に文章を書き写したりしました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっかけは、彼がイリノイ大学の材料研究所に設置された大型コンピューターの、オペレーターになったことでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初コンピューターはフルに使われていたわけではなかったらしく、四人いたオペレーターは、腕に磨きをかけるためとして、空き時間にマシンを使うことを認められました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰め打ちでは、この作業を写植オペレーターが代行する。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "就職斡旋の制度はなかったが成績がずば抜けてよかったせいもあるのだろう、大型コンピューターのオペレーターの仕事を紹介してくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七九（昭和五十四）年十月、タケシは電話工事の仕事をやめ、オペレーターとして働きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペレーターが実際やる仕事のほとんどは磁気テープや磁気ディスクの交換など、単純な作業である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがタケシは、オペレーターという仕事を大いに活用した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシの派遣された会社では、これまで使っていた機械をＩＢＭの新しい中型機、４３３１に置き換えるため、人員をそちらにまわす必要があってオペレーターを補充していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペレーターとして働きながら勉強を続けていく一方で、パーソナルコンピューター上でのソフトウエア開発の仕事を探しはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八二（昭和五十七）年三月、ソフト開発の仕事を決めてタケシはオペレーターをやめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "国際電話のオペレーターに「マイクロソフト社につないでくれ」と頼むと、どこのマイクロソフトだとたずねられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "――問題は現実に働くものや動くものや個物や何かの解釈にあってはならぬ、解釈はこういう事物の実際的処理のための単なるオペレーターに過ぎない、結果として出す時にはそれは消去されていることが必要だ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルドーザーのオペレーターは、肥った白人の男性だった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "西側だけど」「島育ちかい」「そう」「きみがほんとうの島育ちなら、いまここでブルドーザーの向きを反対にし、帰っていくはずだ」　オペレーターは頬をふくらませた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝の仕事がいい仕事がどうか、ぶつけてみればわかるよ」　ブルドーザーのオペレーターは葉巻きを噛んで考えた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラマの次男が反対側からブルドーザーに飛び乗り、兄といっしょにオペレーターを押さえこんだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペレーターがエンジン・フードを開いてあちこちいじっていたが、ブルドーザーは重く静止したままだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その向こうに会議室がふたつあり、さらにその奥はテレックス・マシーンとそのオペレーターのコーナーだった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
