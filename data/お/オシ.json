      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "muteness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども人は、ひとたびこの小説を企てたその日から、みるみる痩せおとろえ、はては発狂するか自殺するか、もしくは唖者になってしまうのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コクトオは気がちがいそうになって日がな一日オピアムばかりやってるそうだし、ヴァレリイは十年間、唖者になった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――然るに、自己をなくしてゐた、即ち私は唖だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の科學智識が一般的に發達してゐることは、一昔前に育つた僕等の大人が、しばしば唖然として舌を卷くほどでさへもある。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日辻潤來り、わが生活の荒蕪を見て唖然とせしが、忽ち顧みて大に笑ひ、共に酒を汲んで長嘆す。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして興味を牽いて救われるのは、その男が唖者のように表現の途を得ないで、いろいろに感情の内爆や側爆のこういう所作をすることである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年四月九日『東京朝日新聞』）　　　　　　　　　七十五　　　　　　唖に言語を教うる法　電話や蓄音機の発明に依って有名なグラハム・ベル氏はまた唖者に言語の発音を教うる法に関する著者として知られている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方法によって言語を発するようになった唖者は沢山あるそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「あっしが盲目で唖で聾になったら知ら無え事」　「なにッ」と鉄五郎が気色ばむのを三次一足退って又「へ……」　と笑って粉かした。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰欝に唖々と鳴き交すその声は、丘の兵舎にまで、やかましく聞えてきた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると突然子供はワアワアと唖のような声を出して駆け出しました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖、聾、盲などは不幸には相違ありません。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴となると、心の唖、聾、盲ですからほとんど禽獣に類しているのです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者唖然たらざるを得ない。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、六時間を、たゞ、唖の小ロボットのように、手を動かすばかりで過すのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、その時、親爺の破廉恥さ加減に、暫らく唖然とした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時以礼は、唖のように口を噤んでしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈の伸びたのが前は鶏冠のごとくになって、頸脚へ撥ねて耳に被った、唖か、白痴か、これから蛙になろうとするような少年。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし世界じゅうの人間が残らず盲目で聾唖であったらどうであろうか。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聾唖者には音響の言語はないが、これに代わるべき動作の言語がちゃんと備わっているのである。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいと答えて、みち問えば、女、唖なり、枯野原。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "路問エバ、オンナ唖ナリ、枯野原。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの助平の責任を、何もご存じない天の神さまに転嫁しようとたくらむのだから、神さまだって唖然とせざるを得まい。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ死ぬ程息苦しくなって、張り裂けるほど胸が轟いて、唖のように何の返事もし得ないまま立ち上りますと、ソロソロとアヤ子から離れて行きました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様を信ずれば盲目が見え、唖が物を云い、躄が駆け出すのだ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり掃溜から出たお話で……」「……やはり掃溜から……イカナ事……」　松倉十内は唖然となった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ」　今度は赤猪口兵衛が唖然となった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、人間の扮したお園が人形のお園と精密に同じ身ぶりをしたとしたら、それはたぶん唖者のように見えるか、せいぜいで、人形のまねをしている人間としか見えないであろう。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に唖になったのだろうか。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まあこのおしまひの手合なんぞは、云つてることに何の意味もないにしてからがチヨイト頭を捻ること言換れば位置にお構ひなしに移動の万能範囲を拡げることが、いとも優秀なことのやうに思はれることは現時の流行感冒である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
