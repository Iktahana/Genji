[
  {
    "uuid": "e877cf2f-b3cc-5b54-b87f-4fcef71c29c3",
    "entry": "唖",
    "reading": {
      "primary": "おし",
      "alternatives": [
        "あ",
        "おうし"
      ],
      "is_heteronym": false
    },
    "grammar": {
