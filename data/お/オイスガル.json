[
  {
    "uuid": "6f046355-0ab9-5c8d-878d-41e940be2e1e",
    "entry": "追いすがる",
    "reading": {
      "primary": "おいすがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
