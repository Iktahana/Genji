        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "外国の人もまた、マリヤ様、エス様が、たいへんありがたいおかたであるという事は、教会の雰囲気に依って知らされ、小さい時からお祈りをする習慣だけは得ていながらも、かならずしも聖書にあらわれたキリストの悲願を知ってはいないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外國の人もまた、マリヤ樣、エス樣が、たいへんありがたいおかたであるといふ事は、教會の雰圍氣に依つて知らされ、小さい時からお祈りをする習慣だけは得てゐながらも、かならずしも聖書にあらはれたキリストの悲願を知つてはゐないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉一枚動かない沈鬱なる空の下に、案じたほどのこともなく向う岸へ渡り、崖の上へ立って振り返ってみると、白衣の道者の一連が来て、大沢の手前でうずくまり、先達がお祈りを上げている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたといふの、　あゝ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられやうとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなあの北の十字のときのやうにまっすぐに立ってお祈りをはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は又、貴方が私の健康をお祈り下さつたことを感謝いたさねばなりませぬ。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたといふの、あゝ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられやうとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云ってお祈りしたというの、　ああ、わたしはいままでいくつのものの命をとったかわからない、そしてその私がこんどいたちにとられようとしたときはあんなに一生けん命にげた。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなあの北の十字のときのようにまっすぐに立ってお祈りをはじめました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸に十字を切って、わけの判らぬ言葉でもって烈しいお祈りをはじめたのである。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりはこう言ってお祈りしたというの。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときさそりは斯う云つてお祈りしたといふの。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなあの北の十字のときのやうにまつすぐに立つてお祈りをはじめました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、外衣も裏衣も、雨や、風や、岩角に破られてしまって、二人ともホントのヤバン人のように裸体になってしまいましたが、それでも朝と晩には、キット二人で、あの神様の足※の崖に登って、聖書を読んで、お父様やお母様のためにお祈りをしました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとアヤ子は、はるかに海の中に突き出ている岬の大磐の上に跪いて、大空を仰ぎながらお祈りをしているようです。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、だんだんお腹がすき出したので、男は早速、神様の仰ゃったことを思い出し、空を仰いでお祈りを始めた。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女もまた、地の上に伏して、お祈りした。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのお祈りはそれよ」シグナレスは思い切って言いました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが何時迄も丈夫でいられるように神様へお祈り致します。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "この僧侶は祈っているようすでしたが、そのお祈りのさいちゅうに何か物思いにしずんでいるようでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "』母親はこう言って、お祈りの途中でさえぎりました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あたし、お祈りしたのよ。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の上の人たちは、みんな、この歌をうたい、お祈りをしたおかげで、魂が高められたように感じました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、おとうさんは、両手を合せて、お祈りをすますと、自分も横になって、すぐに、ぐっすりと寝こんでしまいました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんは、すぐに、ひざまずいて、お祈りをしました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、わたくしには、生きている人たちへの、義務がありましたのに、それを忘れましたことも、どうか、おゆるしくださいませ」　こう、お祈りをしますと、おかあさんの心は、すっかり軽くなったような気がしました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、教会の鐘が、朝のお祈りのために鳴り出しました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし、休まなくちゃいけない」　こう言いながら、ヨハンネスは、そこにひざまずき、手を合せて、夜のお祈りをとなえました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は苦しくなると、神においのりするものでありますが、もっと、ぎゅうぎゅう苦しくなると、悪魔にさえ狂乱の姿で取り縋りたくなるものです。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かう言つて、手を合せて、なが／＼と神さまにおいのりを上げました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
