              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "みんながみんな大喜びで笑ひ始めた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と龜は大喜びで、「しかし、あまりそんなに興奮して心臟麻痺なんか起されても困る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人席なんか大喜びで、あれは受けとッたよと当日のはなし。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようよう死んでるぞ、死んでるぞ」と数多い死体を見て大喜び。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次も大喜びで続いて花道へ飛び上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "門前で待っていた君江達大喜び。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主も大喜びに「それは、それはＴ「ようこそ　御泊り下さいました」　と下へも置かぬ待遇です。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り掛かった侍五人は大喜び。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大喜びのおふみ、ふと思い出して伝六に、Ｔ「土左衛門は」　伝六がアッ、Ｔ「其奴忘れてた」　で慌てて走り去る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "５３＝密室　二階の敬四郎センセイ、　「此奴は面白い」　と大喜び。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「拒むと罰が当りますぞ」５９＝二階　敬四郎お兼とは知らずに大喜びで見て居ます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "53＝密室　二階の敬四郎センセイ、　「此奴は面白い」　と大喜び。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「拒むと罰が当りますぞ」59＝二階　敬四郎お兼とは知らずに大喜びで見て居ます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷珸は大喜びで、天下一品、価値｜万金なんどと大法螺を吹立て、かねて好事で鳴っている徐六岳という大紳に売付けにかかった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小菅は大喜びであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茸狩りに来たのは、どこかのお父さんとお母さんと姉さんと坊ちゃんでしたが、ここへ来ると皆大喜びで、「もはやこんなに茸はあるまいと思っていたが、いろいろの茸がずいぶん沢山ある」「あれ、お前のようにむやみに取っては駄目よ。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは大喜びで連れて帰って、寄ってたかって介抱をして、もとの通りにふくらましてやりました。",
              "citation": {
                "source": "キューピー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあみんな来い」　と大喜びで、ばあやも連れて東京のおうちへお帰りになりました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイダーの瓶の中に落ちていたのを水を入れて外に出してやりました」　とチエ子さんは大喜びをしながらお母さんにお話しました。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人の部下はもう世界長の首尾がいいので大喜びです。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　二十「その書生さんの時も、本宅の旦那様、大喜びで、御酒は食らぬか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井さんもその一人で、一旦浪人した旧藩主のお屋敷へ帰参することになったので、お父さんも息子も大喜び、近所の人たちもお目出たいといって祝いました。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半時間も改札嬢と話してたのか」　三人がそろったので小隊長は大喜びだったが、オトラ婆さんは鬱々としていた。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼は大喜びで走って来てみると、それは誰かが落した大きな人形でした。",
              "citation": {
                "source": "人形と狼",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主も大喜びでしたがお神さんは亭主に向つて此金剛石の指環を篏めても恥かしく無い位の立派な着物をこしらへて呉れと頼みました。",
              "citation": {
                "source": "金剛石",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主は直ぐに家中にある一番良い布を切つてお神さんの着物をこしらへて其上に靴から帽子手提袋まで作つて与へますとお神さんは大喜びでそれを身に着けて方々歩いて居りましたが其中にこれ位立派な着物を着て居るのに馬車が無くてはきまりが悪いから、立派な二頭立ての馬車を買つてくれと云ひ出しました。",
              "citation": {
                "source": "金剛石",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝早く起きて見ると、もうすっかりいいお天気になっていましたが、池も田も水が一パイで皆大喜びをしていると、田を見まわりに行っていたお父さんはニコニコして帰ってこられました。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあお祝いにみんなで遊びましょう」　と大喜びで遊びはじめました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギンはおおよろこびで、「いえいえけっしてそんなことはいたしません。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の犬たちはおおよろこびでとび出して、八方へにげていきました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
