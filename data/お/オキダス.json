        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "朝、目がさめて、きょうこそは、しっかりした意志を持ちつづけて悔いなく暮そうと、誓ってお床から起き出すのですけど、朝御飯まで、とっても、もちません。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜就眠の時に当たって、明朝五時に覚めてそして猟に行こうと思い、或いは六時に覚めて直ちに文を書こうと思って、そして五時或いは六時に起き出すことも元より少なくはないが、そういう精神の命令が無くて自然と覚めることもまた少なくない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　境港と美保の關　七月十五日の朝は、私は早く床を離れて、鷄二の起き出すのを待つた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時になると起き出すのであったが、〔七字伏字〕向いあった側に〔二字伏字〕、そこは男ばかり〔九字伏字〕が並んでいる。",
              "citation": {
                "source": "日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ早いだろうに」　と言って源氏は起き出すのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "野分",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎右衛門とは昔から縁つづきの四郎兵衛という家の若者が、朝十時頃になっても老人の起き出す気配がないので行って見ると、寝床の中から裸の半身を乗り出して、まだ歌い踊っているような恰好の老人を見出した。",
              "citation": {
                "source": "一老人",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上の朝飯　翌朝の三時頃から、同じ家の内に泊っていた土方は最早起き出す様子だ。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時になると、四人がいっせいに起き出す。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方は用心深い、経験に積んだ人であるから、その朝わたしが起き出すまえに道中の食料を包んでおいた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドブ板や往來に、夜のうちに落した小判が、お角が起き出す迄無事でゐるわけはねえ」「盜人を嗅ぎ出して強請つたんぢやありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "九百九十兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――内儀のお篠さんはどうだ」「年寄りの側に居るんですもの、そっと人殺しに起き出すことなんか出来るものですか」　とガラッ八。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "梅吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドブ板や往来に、夜のうちに落した小判が、お角が起き出すまで無事でいるわけはねえ」「盗人を嗅ぎ出して強請たんじゃありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "九百九十両",
                "note": "青空文庫"
              }
            },
            {
              "text": "――内儀のお篠さんはどうだ」「年寄の側に居るんですもの、そつと人殺しに起き出すことなんか出來るものですか」　とガラツ八。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "梅吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが起き出すと、自然、家の者も起きなければならないことになるので目がさめると、それこそどろぼうのように釣り竿とビクを持って、こそこそと家を出る。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムックリと一週間のベッドから起き出すと母からもらった短剣を出して見た戦争中にトギ屋に出して研いである突けば心臓を貫いて余りがあろう青く澄んだ刃の奥に私の顔がうつっているそこから覗いている眼は冷たく静かに私の方を見ているたしかに私は昂奮はしていない自分でも物たりないほど落ちついていた。",
              "citation": {
                "source": "殺意（ストリップショウ）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、早い時間に起き出す大変さに比べれば何てことはないし、飲んでいれば風邪やインフルエンザにも強くなる。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
