        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "頭を撫でてやつてゐると親犬までやつて來て私の額や頬に身體をすりつける。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を撫でてやっていると親犬までやって来て私の額や頬に身体をすりつける。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ぽけなむくむくしたのが重なり合って、首を擡げて、ミイミイと乳房を探している所へ、親犬が余処から帰って来て、其側へドサリと横になり、片端から抱え込んでベロベロ舐ると、小さいから舌の先で他愛もなくコロコロと転がされる。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬小舍の寢藁の中に疲れた肉體を横たへ、涙にうるんだ顏をしながら、縋りつく小犬に乳を飮ませてゐる親犬のお腹は、裂けても破れてもゐなかつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "女人崇拜",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は見る見るうちに大きくなり、一年二年たつともう立派な親犬になりました。",
              "citation": {
                "source": "犬の八公",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親犬は一年に二度づゝ、一度に四匹も五匹も、子供を産みました。",
              "citation": {
                "source": "犬の八公",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "子犬もやがて親犬になつて、それがまた子供を産み初めました。",
              "citation": {
                "source": "犬の八公",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが二、三ヵ月たつと次第に育ってきて、親犬ほどになると時たま野性を発揮して、人を襲う態度を示すので、村中の問題となった。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "親犬と子犬とが遊ぶように、どこでも構わず、かみついたり、なめたり、たたき合ったり、ゆさぶったり、思い切り体と体とぶっつけ合って、時のたつのを忘れてみたい。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "親犬は、きちがいのようになって探していました。",
              "citation": {
                "source": "酒屋のワン公",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "親犬らしい一匹にそれよりも体の小さいのが三匹寄り添っている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "四名の兵たちは、それから永いこと、まるで親犬の乳房にすがるひと腹の仔犬のように、頬と頬とをくっつけあい、鼻と咽とをくッくッと鳴らしていました。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬が吠える、同時に小門の下から夥しい小犬が走り出して来て、関守氏の足もとにまつわる、同時に、中では吠える親犬をしまい込む家人のあわただしい物音が聞えたが、やがて門が内から開かれて、「お越しやす」　極めて尋常な女中が一人、現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩垣根の下に、萩の花を浴びて、この頃生れた犬の子が白い親犬に戯れている。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
