[
  {
    "uuid": "e33892ed-2ac9-5fe2-a5a5-cd292e72e416",
    "entry": "お忍び",
    "reading": {
      "primary": "おしのび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "travelling incognito (of a person of high rank)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お忍びという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお忍びの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お忍びを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお忍びという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お忍びの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お忍びは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お忍びの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お忍びと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お忍びは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お忍びはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お忍びの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お忍びの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お忍びが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お忍びを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お忍びのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お忍びに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お忍びの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お忍びの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お忍びは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お忍びの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これわれと永久に別れて無究に相見ず、われは北極の氷と化し君は南極の石となりて、感ぜず思わず、限りなく相見ずと思いたもうともなお忍びたもうことを得るや。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "のう、いかな事でも、明神様の知己じゃ言わしったは串戯で、大方は、葉山あたりの誰方のか御別荘から、お忍びの方と思わしっけがの。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傑作「人間万事嘘は誠」のあらましの内容は、嫌厭先生という年わかい世のすねものが面白おかしく世の中を渡ったことの次第を叙したものであって、たとえば嫌厭先生が花柳の巷に遊ぶにしても或いは役者といつわり或いはお大尽を気取り或いはお忍びの高貴のひとのふりをする。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は初め怪しみ、遂には恐れて、こは狂人なるべし、狂人を紹介せる嘉悦氏もまた無礼ならずやと、心に七分の憤りを含みながら、なお忍びに忍びて狂人のせんようを見てありしに、客は忽ち慚愧の体にて容を改め、貴嬢願わくはこの書を一覧あれとの事に、何心なく披き見れば、思いもよらぬ結婚申し込みの書なりけり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その後も毎晩お忍びでございましたか」と、七兵衛は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな浮気なお忍び姿を陛下は御覧になりませんからね」　と命婦が言うと、源氏は二足三足帰って来て、笑いながら言う。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇太后の性格をよく知っておいでになって、その方の意志で動く当代において、今後はどんなつらい取り扱いを受けねばならぬかというお心細さよりも、またない院の御愛情に包まれてお過ごしになった過去をお忍びになる悲しみのほうが大きかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五夜の月の美しく静かなもとで昔をお忍びになって帝はお心をしめらせておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いっそこれまで参りましたら、かねてのわたくしの意見の通りに伯耆の大山へゆき着いて、かしこい修験者の許にしばらくはお忍びなされませ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "２「許せよ」　ずいとはいっていった覆面姿をながめて、お忍び通いのお客さまとでも思ったものか、初めのうちはやけにあいきょうを振りまいていましたが、さすがは目ききを元手の質屋に仕える少年店員です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから――」「それから誰じゃ」「ちとこれは他言を憚りまするが、遠藤｜主計頭様が、お忍びでちょくちょくと参られまするでござります」「なにッ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、大名のお忍びですから、頻りにと云ったところで、月に二三度ぐらいのことでしたが、それでも殿様は大執心で、相方の女に取っても、その店に取っても、大変にいゝお客様であったのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳桂院様がおなくなりになった後でも、奥様はたび／＼お忍びで猿若町へお越しになりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「娘御はゆうべ何処へかお忍びではござりませぬか」と、千枝太郎はそれとなく探りを入れてみた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の独帝は人一倍この遊びが好きで、皇帝の位に即いてからも、大晦日の晩になるとこつそりお忍びで市街へ浮れ出し、擦れ違ひざまに他人の隙を見ては、ぽかりぽかりと擲りつけたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある歳の大晦日の晩、独帝はいつものやうにお忍びでこつそり市街へ飛び出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分はたいそうにせずともよい身分でいて、閑散な御境遇でいらっしゃる院の御｜機嫌を伺いに上がることをあまりしない私の怠惰を、お忍びのあまりになってくだすったお手紙だからおそれおおい」　と六条院はお言いになって、にわかなことではあるが冷泉院へ参られることになった。",
              "citation": {
                "source": "源氏物語",
                "author": "鈴虫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「珍しくお忍び歩きをなさいましたのですよ」　と女房たちはささやいていた。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御愛情をお持ちくださるなら、しばらくお忍びくだすって、慰安の方法を私が講じますのを待ってもらいますことが、世間体もよろしいかと思われます。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものように先払いもさせずにお忍びでお出かけになったからですよ。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私としては、貧乏は持ち前のことだし、また、公然をてらったのでなく、所謂お忍び的行為が全然出来なかったまでのことである。",
              "citation": {
                "source": "三木清を憶う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、外部へは綺麗に隠して、閣議の帰りやなんかに、お忍びの自動車を仕立ててニュウリイのアパアトへしきりに通っている。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて白旗弓之助様、昨夜はどういう覚し召しで、ここへお忍びなされましたな？",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ面白くなってきた」　このお忍びの酒もりへ、さらにお忍びの誰かが合流するだろうと寒吉は考えた。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのストリップは腰部をブンマワシのようにふりまわすことのみに専念し、房事を聯想させる目的のためでしかないような卑ワイなものであったが、場内は閑散として、労働者よりもむしろ洋服族が主としてお忍びの態でつめていた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小屋がけのストリップへお忍びの洋服族のところへはポンビキのオバサン連が忍びよる。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおとうさんのあでやかな娘姿がお店へ出てから半年もたつた頃、ある日そのお方がおしのびで侍女二三人程連れて街へ買物がてら散歩にお出になつたのですよ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間のように大勢家来なんかつれないで一人で、たった一人で、おしのび下されたく……。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときその店先には、王さまが、おしのびで、一人のおともをつれて、金の指輪をなほさせに来てゐました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様のおしのびめいたり、しんみり父親の油滲んだ手を思い出したりして、後に随いて廻っているうちに、だんだんに情緒が出た。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
