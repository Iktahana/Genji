    "definitions": [
      {
        "index": 1,
        "gloss": "one person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お一人様について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お一人様がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お一人様というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお一人様の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお一人様が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お一人様を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お一人様の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お一人様はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお一人様があります。",
              "source": "幻辞"
            },
            {
              "text": "お一人様は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お一人様について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお一人様の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お一人様の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお一人様が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お一人様についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお一人様は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお一人様について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お一人様という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお一人様の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お一人様を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やあ、御新規お一人様あ、」　と尻上りに云って、外道面の口を尖らす、相好塩吹の面のごとし。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……御新規お一人様、なまで御酒……待った、待った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お一人様は東寄りに、べつのお一人様は西寄りの築地のかげにまいっていられます。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
