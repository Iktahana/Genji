        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『水野先生、お宅からお電話です‥‥‥』と、その時、不意に私の耳元に響いた小使の聲はどんなに私の心を驚かせただらう。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お電話を差し上げて、かえって失礼したようなものですね。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お電話ありがとう御座いました。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく倉庫主任宛のお電話が警察にかかって参りましたのでスッカリ安心して手配してしまったのです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、田代さんからお電話でございますが。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あや子は忘れて居たものを思ひだしたと云ふ風で、「今のお電話は、どなた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、女中がはいって来て、「旦那はん、お宅からお電話どす」「電話……？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラスコリニコフを模倣したのかな」　一方は大学生、一方は三高生……なるほどと唸っていると、女中が、「お電話どす」　と、知らせに来た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私今日あたりお電話して、事によったら行ってみようかと思ってたんですけれど、出しぬけでも悪いかと思って。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきはお電話で恐縮でした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、井伏さんが釣竿をかついで、南伊豆の或る旅館に行き、そこの女将から、「お部屋は一つしか空いて居りませんが、それは、きょう、東京から井伏先生という方がおいでになるから、よろしく頼むと或る人からお電話でしたからすみませんけど。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠気ざましに……」　木崎の腕に針がはいった時、「木崎さアン、お電話ア……」　女中の声が廊下で聴えた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――木崎さん、お電話ア」「今、手が離せんよ」　注射器のポンプを押しながら、坂野が代って答えた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は伯母様からお電話がかかりまして、銀座のセイロン紅茶店へ参りまして伯父様と伯母様とに、貴方の弟御さんからスッカリ御事情を承りましたが……」「エッ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はあ、お電話も下さらないものですから……」と、女中は弁解した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれかへ、ぜひお電話をねがいます。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "バー・スワン一　溝板を飛んで来る板裏草履の音がして、勢いよく格子戸が開くと、「南條さん、お電話ですよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日ここへ寄っていたんですが、すっかり仕上ってからと思って、お電話しなかったんです。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は、まだオドオドしながら、「一度かけましたんですけれど、お話し中でお待ちしている内に、今の方から、お電話がございましたので……」と、相すまなそうな女中の云い訳を、背中で聴き流しながら、二階の部屋へ帰って来ると、綾子夫人は、もう一度鏡の前に、苦っぽい笑いを浮べて、腰をかけた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月中に、一、二度お電話がかかりましたことは、存じております。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、お電話だけじゃ、よく呑み込めないんで、お呼びしましたのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦「江藤先生、お電話です」江藤「有難う、今直ぐ……」江藤、先刻からの書き物に区切りをつけるために、万年筆を取りあげ、それをしきりに振る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、「維康さん、お電話でっせ」胸さわぎしながら電話口に出てみると、こんどは誰か分らぬ女の声で、「息を引きとらはりましたぜ」とのことだった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝえ、そんなこともありませんが……」「妾、今、どこからお電話してゐるかお解りになつて……」「解りませんな。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥さんからお電話でしたけれど、切れてしまひました。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、好子さんからお電話よ。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方のお電話のすぐ後へ帰つたのよ。",
              "citation": {
                "source": "水ぎわの家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京橋からお電話でした。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時二分で鵠沼を出て、五時すぎついて、新宿で一寸夕飯たべて、かえって、幸子ちゃんのところへ門の鍵やポストのものとりにたかちゃんが行っていて、私は火をおこしていたら、「おでんわです」というので黄色いドテラの上に羽織きて出かけたら、栗林氏でした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
