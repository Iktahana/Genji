        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」とそのお人形さんみたいな可愛い女の子が、お爺さんの前にお行儀よく坐り、まんまるい眼をぱちくりさせて答へる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お行儀よく並んで飛ンで行った。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になって、子供たちがまだお行儀よくテーブルにむかっていたり、低い椅子に腰かけたりしているころ、オーレ・ルゲイエがやってきます。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをお行儀のわるい子供たちの上にひろげると、その子たちは、ばかみたいに眠りこんでしまって、あくる朝目がさめても、なんにも夢を見ていないのです。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生に一ぺんでも、王妃さまに、褒められたいと念じて、お行儀にも学問にも努めてまいりましたのに、まあ、あたしは何というお馬鹿でしょう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いっきりお行儀を悪くして、いけない事ばかりしてやろうという気になっちゃったのよ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "官吏だ」「お行儀がよくって」「おそろしくいい。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンと両手を膝に置いて」　とお行儀を教えながら二度程繰り返して附けてくれる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご飯中、ねむくなるなんて、そんなお行儀のわるいことじゃ駄目ですよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルタの殿方、ずらりとならんで、お行儀のいい、ハートのご婦人。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、老先生は昔からお行儀が悪く、言葉｜遣いもぞんざいで、それがまたお母さまのお気に召しているらしく、その日は御診察など、そっちのけで何かとお二人で打ち解けた世間話に興じていらっしゃった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあの、所謂上流サロンの鼻持ちならないお上品さには、ゲロが出そうで、一刻も我慢できなくなっていますし、また、あのおえらがたとか、お歴々とか称せられている人たちも、僕のお行儀の悪さに呆れてすぐさま放逐するでしょう。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○お父さん　しつかりして下さいまあ　お行儀が悪いいや　驚ろいたよあゝ　びつくりした○テン太郎　お前の行つた街がミルチス・マヂョルといつたかねほんとうですよなんですか　そのミルチス・マヂョルといふのは貴方○わしは驚ろいたよ　お前の夢の話の中でそれだけは真当のことだよエ？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "お行儀もへつたくれもあるもんか。",
              "citation": {
                "source": "熱海へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お行儀よく、膝の上に置いていらっしゃるのねぇ、さあ握手！",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしそんなに順番を待っている程、お行儀がよくないわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのときふと気がついたのは、そこにちんまりとお行儀よくすわりながら、手あぶりの上へ両手をかざしていた少年僧のことです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほゝゝ、いゝお行儀で入らつしやいますこと。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞひもじいだろうから、かってにつまんでお上がり」「…………」「ほほう、なかなかお行儀がよいのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤイヤ、唖で耳がきこえないのなら何を云ってもつまらないから、やっぱり我慢をしていよう」　と思いながら、両手を膝の上に置いてお行儀よく澄ましていました。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鍛冶屋の娘が、そんな小間使ひなんて……お行儀ひとつ知りはしない。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し随分暑苦しいことだらうな、この真夏の晩と来たら――」「婦人連が汗を流して、お行儀好く、あの姿で――俺達｜武士にお酌をする光景を想ふと、これ御同役、一興ぢやなからうかね。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日の新聞は、その話を伝へて、自分の崇拝者をこんなに邪慳に取扱つたゴリキイには、お行儀作法の端くれでも教へ込まなければなるまいと、冷かしを言つてゐたが、そんな事をいふ輩は崇拝者を持つた事の無い奴で、世の中に崇拝者程うるさいものは無い。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅馬字普及３・22（夕）　大阪大学病院の桜根孝之進博士は、ふしだらな病人達には、皮華科のお医者さんとして知られてゐるが、健康で、お行儀のいゝ人達には、熱心な羅馬字普及論者として知られてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お行儀な西洋人に見せたら屹度笑はれてよ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　宗教学校出の婦人だつたら、そんなのを見て酸漿のやうに顔を紅くするかも知れないが、しかしそれは物を知らないからで、お行儀な西洋人にも、肉刀で物を食べるのは少くない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は時に小夜子の帳場で、お行儀よく坐っている彼女を見かけるのだったが、渋い作りの身装もきちんとしていたが、ごつい金歯がひどく顔の感じを悪くしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お行儀を教えたり、根気のいる初等学科を教えたりすることは、皆、児童心理を専攻した家庭教師にまかされています。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事中にひよつこりと清丸さん来訪、さつそく御飯をあげる（炊いてはおそくなるから母家で借りる）、お行儀のよいのに感心した、さすがに禅寺の坊ちやんである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その反対に、おぎょうぎのわるい、よくない子どもを見ると、悲しくなって、思わず泣いてしまいます。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
