        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お座なりという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお座なりの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お座なりを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお座なりという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お座なりの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お座なりは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お座なりの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お座なりと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お座なりは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お座なりはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お座なりの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お座なりの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お座なりが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お座なりを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お座なりのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お座なりに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お座なりの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お座なりの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お座なりは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お座なりの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "山岸君も、亀井君も、お座なりを言うような軽薄な人物では無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座なりのお世辞がだんだん身を縛つてしまつて、ぬきさしの出来ない破目となつたのでもあらう。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今にだんだんだんだん色々なこと分るようにして上げますわ」　智子は心に絶望に近いものを感じながら、こんなお座なりを云ったことが肌寒いように感じられて夫の方を今更ながら振り返った。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先生に診て貰っておれば、きっと治して下さるんだよ」　お座なりの見当違いの説明に、必死の望みを外された政枝は、見る見る顳※に青筋を立てて父親を瞠んだ。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんなお座なりの解決で気が済むなら、誰も身上相談欄へ手紙を出すもんかね。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、すべてに対する未練、執着、気がかり、気兼ね等から超脱する事一、すべてを冷眼視し得る度胸で本心のゆらめきを圧迫し去る事一、如何なる俄作りの感情、お座なりの意志、間に合わせの信念でも直に本心一パイに充実させ得るように心掛ける事　といったような術を天然自然と会得しております。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しさ、などという無責任なお座なりめいた巧言は、あまり使いたくないのだが、でも、それは実際、美しいのだから仕様がない。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、自分独りで、グッと踏み堪える力がなくて、毎日のように友人を代りばんこに尋ねて、同じ愚痴を繰り返して、安価のお座なりの同情で、やっと淋しさをまぎらして居るような河野の態度も、雄吉には堪らなくはがゆかった。",
              "citation": {
                "source": "神の如く弱し",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座なりではなかつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に対して言つたことも、ちとお座なりすぎてゐる。",
              "citation": {
                "source": "スケツチ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら広津氏の筆によって教えられることになると、私にはお座なりの概念論としてより響かなくなる。",
              "citation": {
                "source": "広津氏に答う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三日の間、食事の時に宿の女中とお座なりの言葉を交すだけだったので、人間の肉声に渇していたのである。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとなしい」「我ン張りのない」職工を会社が勝手にきめて、お座なりに開くそんな「工場委員会」に少しも望みをつないでいなかった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにどんなに見に行きたいにしたところで、一人っきりで、一人っきりの女を誘うようなことはできないたちだったので、お座なりに、独り言のような調子でばつを合わせたのだった。",
              "citation": {
                "source": "謎の女",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、父の立場を気の毒に思つて、「それで……」と母に向つて云つたが、何と云つていゝか何んな言葉も続かなかつたので、たゞ如何にも物解り好さ気にニヤ／＼しながら、隣家から駆けつけたお座なりの仲裁人の気持で、好い加減に口のうちで「まアまア！",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "口先でばかり巧みなお座なりを喋つて、娘の縁家先などを餌食にした周子の父親の心根を想像すると、その片割れである周子の色艶までに憤懣を起したりした。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣傳演説に於ても、お座なりを云つて大衆を煽ることは出來ない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の若さと正直さは、この老作家の前にいい加減なお座なりは言ってはいられなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、身の上相談の答えというものの十中八九は、率直に云ってお座なりである。",
              "citation": {
                "source": "女性の教養と新聞",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　メーラが、またお座なり哲学を並べた。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しはる子は、こう困っている有様を見ると、「ではまあさし当りもう一度××堂の×さんのところへでも行って見るんですね、私の方も考えて置きましょうから」というお座なりで帰す訳には行かない気がするのであった。",
              "citation": {
                "source": "沈丁花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしさびしいんですもの」　圭一郎は「あゝ」と頷いて顏を出し二言三言お座なりに主人夫婦が旅に出かけたことなど話柄にしたが、直ぐあとが次げずに口を噤んだ。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……お気に障ったら御免なさいですが、林友吉は決してお座なりは申しまっせん。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くはなれた存在だった、ずっと前に書いたものには、気高き人とか麗人とか、ありきたりの、誰しもがいうような褒めことばを、ならべただけですんでいたが、そんなお座なりをいうのはいやだ。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、試みに、譏詞と諷刺のあらん限りを尽し、お座なりの捏造を旗太郎に向けてみた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこの時、あなたの一杯に毛の生えた脚の、女らしい体臭に噎せると、ぼくはぞっとしていたたまれず、「熊本さんは肥りましたね」とかなんとか、あなたの萎れを気づかっていたつい最前の自分も忘れ、お座なり文句もそこそこに、立ちあがると逃げだしてしまいました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座なりと口上と紋切型が多すぎるからです。",
              "citation": {
                "source": "劇作家としてのルナアル",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "話術を看板にした「話」に真の魅力がない如く、お座なりと紋切形の口上が、いかに言葉巧みに述べられても、それは退屈以上の何物でもない証拠である。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの県会議員や、国会議員が口先で、政策とか、なんとか、うまいことを並べても、それは、その場限りのおざなりであることを彼等は十分知りすぎている。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お酒をやめて、ご病気をなおして、永生きをなさって立派なお仕事を、などそんな白々しいおざなりみたいなことは、もう私は言いたくないのでございます。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
