[
  {
    "uuid": "13c9639f-9ab9-5789-b3bd-bf6c27869307",
    "entry": "お仕舞い",
    "reading": {
      "primary": "おしまい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お仕舞いという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお仕舞いの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお仕舞いという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お仕舞いは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お仕舞いの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お仕舞いは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お仕舞いはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お仕舞いの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お仕舞いが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お仕舞いのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お仕舞いに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お仕舞いの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お仕舞いは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お仕舞いの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "とにかく滅多に出て来っこない珍本ですからドウゾお大切にお仕舞いおき願いますよ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一長い事打たずにお仕舞いおきになっておりましたので皮が駄目になっております。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この短篇集でお仕舞いになるのではないかしらと、ふと思う。",
              "citation": {
                "source": "悶悶日記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなって来ると、お仕舞いまで申しあげます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の附近のバアのラジオは私を追いかけるようにして、いまは八時に五分まえである、台湾はいま夕立ち、日本ヨイトコの実況放送はこれでお仕舞いである、と教えた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ってくんねえ」　　　　　六「長くなるから、ここらでお仕舞いにしましょうかね」と、半七老人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御法要や御説法があるそうでございますから」「老婢と話が合うようになっちゃあ、おれももうお仕舞いだな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「お話はもうお仕舞いです」と、半七老人は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「お話は先ずここらでお仕舞いでしょう」と、半七老人はひと息ついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、このお話もまずお仕舞いでございます。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでお仕舞い……目出度し目出度しかね。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからすぐかけつければ間に合わないこともありませんわ、飛行機が滑走を始めれば、もうお仕舞いですよ」「ありがとうエミリー」と、ドレゴは本気になって感謝した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄はそこでお仕舞いになってはいず、股のところから大樹の向う側にずっと長く斜に引き張られているのではないか。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "男娼のことは余談にわたりますから、詳しくは申し上げませんが、なにしろ女と違って、子供時代が売り物ですから、十七八にもなればもうお仕舞いです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "……『こうなったからには、どっちみち同じじゃないか――どうせ二人の間は、きれいにお仕舞いなんだもの』　わたしは彼女のところへ出かけて行ったが、肝心の話を切り出すどころか、雑談さえ思うようにできない始末だった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに思いをかけてる人であるなら、みんなくれてお仕舞いなさいよ。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国の川開きもこうなってはお仕舞いだとケチった連中もあるが、これだけは滅ぼしたくないものだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、もうお仕舞いですよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひどう苦しみましたか……たいした苦しみがなければ、先ず結構な方です」といった具合で、私がもうこれでお仕舞いですかと訊ねますと、まだ一日位は保つだろうと言うのでした。",
              "citation": {
                "source": "臨終まで",
                "author": "梶井久",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあまり売れ口のよくない新聞なので、明るいうちに、夕刊としての効力のなくならないうちに早くばたばたと売ってしまわなければ、もうお仕舞いであったからだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下郎の癖に、仇討などと――そして、お仕舞いまで、下郎扱いにされて――大損したぞ、畜生。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那の、印籠が、お仕舞いだったが、左手は、初めてだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "御苦労なことじゃ」　この頃の爆撃はラジオのアナウンスだけで、お仕舞いだから、頼りない。",
              "citation": {
                "source": "今昔ばなし抱合兵団",
                "author": "――金博士シリーズ・４――",
                "note": "青空文庫"
              }
            },
            {
              "text": "火のついた巻煙草がだんだんと短くなってお仕舞いになると脂くさくなる。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」「あの卵は、どこかにお仕舞いでしょうか」「卵というと……」「先日、あちらからお持ちかえりになりました、アノ駝鳥の卵ほどある卵でございますが……」「ああ、あれか」と博士は始めて背後へふりかえった。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吸血鬼事件も、これでお仕舞いになるでしょうな。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも訳が分らないうちにお仕舞いになって、すこし惜しい気もするけれど」　それを聞いていた大江山捜査課長は、奮然として卓を叩いた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、彼もさすがにてれくさそうにして眼を激しくしばたたかせながら、そうして、おしまいにはほとんど不機嫌になってしまって語って聞かせたこんなふうの手柄話を、あんまり信じる気になれないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（手紙というものは、なぜおしまいに健康を祈らなければいけないのか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで聴いたキービッツという若いプリバート・ドチェントの空中電気の講義は始め十人くらいの聴講者がだんだん減ってとうとう二、三人になってしまった、そのせいか数時間でおしまいになった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
