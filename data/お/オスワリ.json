        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「さあ、又お座りね。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ　斯くて――Ｓ＝大広間　殿様の御座へ、殿様がお座りになる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日須利耶さまは童子と食卓にお座りなさいました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話してあげるからおまえは鞄を床におろしてその上にお座り。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お座りなさいましよ、」　女は襟巻を机の上へ乗せて、その方を背にして一方の蒲団の上に坐つた。",
              "citation": {
                "source": "青い紐",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあお座りに、落ち着いて、いくつか質問にご回答を。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でも、まずお座りなさいな」　わたしは腰を下ろして、『グルジヤの丘の上』（訳注　プーシキンがカフカーズをさまよいながら、遠い恋人を思って作った抒情詩。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんの連れは然し、「戸に近い方がいいものね、ばあや、洋傘置いちゃうといいわ、いそいでお座りよ。",
              "citation": {
                "source": "一隅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃龍も居合わせ、「きっとどっせ、好う好う左の花道見といやっしゃ」と云ったが、自分一人になった時、「ほんまに間違えてお座りやしたらあきまへんえ、左の花道のねきいお座りやっしゃ」と念を押した。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬川は机の上の手紙を慌ててかくし、抽斗の中へ蔵い込むと、それから机に背を凭らせて寄りかかりながら「まあ、お座り」と言った。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に椅子へお座りなさいなどと自分の爲に色色と心を遣はれた。",
              "citation": {
                "source": "巴里の旅窓より",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と命じてから、「お久美、まあお座り。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前にお座りになり、御肖像に向ってさめざめと泣いて入らっしゃるのでございます。",
              "citation": {
                "source": "蛇性の執念",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大奥様はその前にべたりとお座りになり、私に外へ往って待っていろと目くばせ遊ばしますのです。",
              "citation": {
                "source": "蛇性の執念",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一つ、お座りのとき、竹越の『日本経済史』をよんで面白く思った、お菊という女。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座りなさい」　驚いたことにトリガーセンが座った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様のそばにお座りになって、トリガーセン島を幸せにしてください。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここにお座り下さい」彼女は自分の寝室に入り、暖炉の横の二人掛けソファを指しながら言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが、どうぞ、お入りになってお座りくださいな。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーバー所長が咳払いして叔母に近づき、全く事務的に、「奥さま、どうぞお座りください。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェシのそばにお座りになり、片腕でジェシの頭を抱かれた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞお座りになって、ごゆっくり葉巻を吸って、もう悩まないでください。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、王様、お座りになって気楽になさって下さい。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "千秋様、思し召は、どうお座りましょうの」　すると、座にいた幸右衛門は、顔を真っ赤にして、「おばば様、御無用ですっ、なまじ、相見て別れるより、私は琴の音を聞いたのみで心が満たされている。",
              "citation": {
                "source": "日本名婦伝",
                "author": "小野寺十内の妻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか、おかあさまの指ぬきの中に、おすわりくださいませ」と、小さなハツカネズミが言いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠綱さまと義村さまは、お庭の簀子の円座におすわりになつて、まづ義村さまが、このたび和田左衛門尉義盛の政所襲来と同時に、義村、政所の前の南側に馳せ向ひ、まつさきに敵勢に矢を射込みましたが、塵ひとつ義村の眼前を駈け行くものは見受けられませんでした、といかにも実直さうに申し述べました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっといつわりを言う神が乗りうつったにちがいない」とおぼしめして、それなりお琴をおしのけて、だまっておすわりになっていました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このあいだ、王女さまは玉座におすわりになりました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と肩を一つ揺っておいて、「皆静にしておくれ、お蝶さんお前もおすわり。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "利章は「おすわりなされい」と云つて動かずにゐた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
