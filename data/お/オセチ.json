        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あとはまたお節句に団子をこしらえてやるせに、それにつけて食うんじゃ。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お節にや拵ふるに、このあたり門を流るゝ小川に浸して、老若男女打交り、手に手に之を洗ふを見た。",
              "citation": {
                "source": "城の石垣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドド……胴と……足が……ベベベ別々に……ワワワワァ――ッ……」　時は徳川十一代将軍家斉公の享和二年三月十一日、桃のお節句以来、晴れ続いた朝のことであった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昨日はお雛様のお節句だわね――その蛤と栄螺ですって。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……横寺町で、お孃さんの初のお節句の時、私たちは此を御馳走に成つた。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お節句の人形によく似てる。",
              "citation": {
                "source": "狸と与太郎",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズ、貴様の職はお節介屋だとな！",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者諸賢は私を救いがたいお節介者だと思われるだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "深川の火事の時は、ちょうどお節句で飾ってあった、あの騒ぎに内裏様の女の方の、珠のちらちらのついた冠がたった一つ紛失したのを、いつも気にかけておいでなさるくらいだのに、ああ、情ない。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁の名はお節といい、浅草の山谷の露路の奥に十人ばかりの子供をあつめて、細々ながら手習い師匠として世を送っている磯野小左衛門という浪人の娘であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は先年世を去って、当時は父の小左衛門と娘お節の二人暮らしであることも判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきぬはその翌日、女中のお直をつれて再び馬道の家へきのうの礼にゆくと、お節はきょうも参詣に出たというので留守であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを押し返して幾たびか口説いた末に、父の小左衛門には毎月相当の隠居料を贈ること、お節には嫁入りの支度として二百両を贈ることで、まず相談が纏まった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月はじめの吉日に、お節は鍋久の店へめでたく輿入れを済ませて、若夫婦の仲もむつまじく見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋久の嫁のお節は十日ほど前から風邪を引いたような気味で、すこし頭痛がするなどと云っていたが、医者に診て貰うほどの事でもないので、買い薬の振り出しなどを飲んでいるうちに、二十九日の朝から何だか様子が変って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、お節……」　その声を聞きつけて、母のおきぬは茶の間を出てゆくと、長い縁側の途中でお節に出逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い嫁は顔も隠れるほどに黒髪を長く振り乱して、物に狂ったように駈け出して来たので、おきぬは驚きながら、ともかくもそれを支えようとすると、お節は力まかせに彼女を突きのけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物音は表の方まで響いたので、店の者もみな驚いて奥へ駈け込もうとする時、出逢いがしらにお節が飛び出して来たので、彼らは又おどろいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも相手が主人であるので、さすがに手あらく取り押えかねたのと、あまりの意外に少しく呆気に取られて、唯うっかりと眺めているうちに、お節は彼らを突きのけて、今や卸しかけている大戸をくぐって表の往来へぬけ出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかでも新次郎という若い者が一番さきへ駈け出して、お節の右の袂を捉えようとすると、彼女は身を捻じ向けて振り払った上に、なにか刃物のようなものを叩きつけて又駈け出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その闇のなかをお節は駈けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもお節は遠くも行かずに、眼の前の新堀川へ身を跳らせて飛び込んでしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の人々が雨夜の河岸を奔走して、そこか此処かと探し廻ったが、二、三日降りつづいて水嵩の増している川の面に、お節の姿は浮かびあがらなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "お節の身投げも意外の椿事に相違なかったが、鍋久の家内には更におそろしい椿事が出来していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い者の新次郎がお節を追い捉えようとした時に、投げ付けられたのは剃刀であって、それは店さきの往来で発見された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "新次郎は別に怪我もなかったが、お節が刃物をたずさえて狂い出したのを見れば、彼女が夫の久兵衛を殺害して、自分も入水したものと認めるのほかは無い。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち会いの医者の意見も同様で、おそらくお節が突然に乱心して、夫を殺し、自分も自滅したのであろうというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "お節の死骸は遂に発見されなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一旦は納まったものの、お節の入水も久兵衛の変死も近所ではみな知っているのであるから、人の口に戸は立てられぬという譬えの通りで、その噂はそれからそれへと伝わって、神田の吉五郎の耳にもはいった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前中自分は床に居、午後、おせち煮を大晦日フィットで手伝う。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
