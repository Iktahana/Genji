        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大雨の中を頭からぬれひたって銀座通りを歩いていてもだれもとがめる人もなければ、よけいな心配をする人もない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう大雨が降って来た。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時分はまだ一個の荘、家も小二十軒あったのが、娘が来て一日二日、ついほだされて逗留した五日目から大雨が降出した。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "藻抜けのように立っていた、私が魂は身に戻った、そなたを拝むと斉しく、杖をかい込み、小笠を傾け、踵を返すと慌しく一散に駈け下りたが、里に着いた時分に山は驟雨、親仁が婦人に齎らした鯉もこのために活きて孤家に着いたろうと思う大雨であった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大音あげ、追掛しが忽ちに雲起り、真闇になり、大雨降出し、稲光烈しく、大風吹くが如くなる音して座頭はいづくに行しやらむ――と言ふのである。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が邦の俗書に、朝に西北の方に黒雲見ゆるは雨なり、といひ、青き雲北斗を蔽へば大雨なり、などいへるあるを見れば、おしなべて我が邦にては、麦を晒すに好しといひ、老鸛河を尋ねて哭すというやうなる事は、云ひ得ざるにや。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに大雨でも降り出すか、あるいは川か海か野へでも焼け抜けてしまわない限り鎮火することは到底困難であろうと考えられる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沛然と大雨になり、無力な私も、思わぬところで御奉公できるかも知れない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからどこまで大雨のあとのようにびしょびしょなので、ぞうりがすぐ重くなって足のうらが気味悪くぬれてしまった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は急に大雨となり、風もひどく、飲んでる最中二度ばかりも停電した。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "途すがら、遠州｜灘は、荒海も、颶風も、大雨も、真の暗夜の大暴風雨。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、間を置いちゃあ大雨ですから市中は戦です。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが東都出発の数日以前から、殆んど毎日のように暴風｜大雨で、各地水害の飛報は頻々として来る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は少しも険阻ではないが、ただ連日の大雨のため諸所山崩れがあって、時々頭上の断崖からは、土石がバラバラと一行の前後に落ちてくるには閉口閉口。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにこの山中に生ずるサヤハタという木は、水中に在ってもよく燃えるので、その皮を炬火として大雨中でも振回して歩く事が出来るそうだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「切手がはげて居ました…………其日は大雨がふりまして…………」「切手がはげて居た。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「其日は大雨がふりまして…………」「そんなお天気の事なんぞはどうでもいい。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は非常の大雨で、しかも郵便函には郵便物が一杯であつたから、その口元にある手紙の二三通は雨がしみ込んで濡れて居た。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「其日は大雨で…………。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日…………大雨の日。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "カナ／＼は土用あけて二日の――大雨があつた――あの前の日から鳴き出した。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返すやうだが、それが二日で、三日の午すぎ、大雨に弱り果てて、まだ不安ながら、破家へ引返してから、薄い味噌汁に蘇生るやうな味を覺えたばかりで、罐づめの海苔と梅干のほか何にもない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の内ではない、戸外である、暴模樣の篠つく大雨。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから一度でも忘れると、たちどころに、大雨、大雷、大風とともに、夜叉ヶ池から津浪が起って、村も里も水の底に葬って、竜神は想うままに天地を馳すると……こう、この土地で言伝える。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳を澄ますと、屋根の上は大雨であるらしい。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時入浴して座敷に帰ると、桂川も溢れるかと思うような大雨となった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大夕立、まことに大雨大雷だつた、これで二人の憂欝は流れ去つてしまつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども勿論、そんな真暗な大雨の夜に窓から訪れて来る様な酔狂なお客様の影なぞは見とめるべくもなかったので、再びファイヤープレイスの前に戻りました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雨が、ザアッと降ってきたんでしょうか？",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
