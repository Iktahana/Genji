[
  {
    "uuid": "cc37228d-2a1f-5cdf-b3c0-59b0c75cf6bd",
    "entry": "お兄さん",
    "reading": {
      "primary": "おにいさん",
      "alternatives": [],
      "is_heteronym": false
    },
