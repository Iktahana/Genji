        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "上陸当初の日に一瞥して嘔吐を催し、現代日本の醜悪面を代表する都会と罵り、世界のどんな汚い俗悪の都市より、もっと殺風景で非芸術的な都市と評した東京は、彼が死んでも住みたくない所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "草花に処々釣り下げたる短冊既に面白からぬにその裏を見れば鬼ころしの広告ずり嘔吐を催すばかりなり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田君子から私は動物的な感触とピカデリあたりの聯隊旗みたいな嘔吐物をうけたのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅海では人々があまりに情熱的になるものだから妾は嘔吐をもよおしたほどです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は死を嘔吐して踊場で狂った人間のようにお互の足を踏みつけた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海に挙行された東邦大会の選手権把持者――だが、女優のＮは艶めかしい嘔吐を空中に吐いた。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどいのになると、穢い話だが嘔吐を催す。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所どころに嘔吐がはいてあったり、ゴミ箱が倒されていたりした。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、牛乳やいわゆるソップがどうにも臭くって飲めず、飲めばきっと嘔吐したり下痢したりするという古風な趣味の人の多かったころであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五分程経つたと思ふと、お末はひどく驚いたやうにかつと眼を開いて、助けを求めるやうにあたりを見まはしながら頭を枕から上げたが、いきなりひどい嘔吐を始めた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日登山第一の元気はどこへやら、焼酎は頭へ上って、胸の悪き事｜甚しく、十二、三町走るか走らぬに、迚も堪らず、煙草畑の中へ首を突込んで嘔吐を吐く。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "見付けられたかと、大急ぎで煙草畑から首を突出してみると、幸いに嘔吐はくところは見付けられず、そこには六十ばかりの梅干｜婆さん眼玉を円くして、あっちに駆け行く一行を眺めつつ、「何事が起っただね」と、さも驚いた顔。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに宿醉の朝に於ては、どんな酒にも嘔吐を催すばかりである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試に思へ、彼の糞汁はいかむ、其心美なるにせよ、一見すれば嘔吐を催す、よしや妻とするの実用に適するも、誰か忍びてこれを手にせむ。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……早く退けしゃらぬと、私も嘔吐そう、嘔吐そう、殿。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、女児も十二三でなければ手に掛けないという、その清浄な梅漬を、汚穢くてならぬ、嘔吐すと云う。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（二寸の蚯蚓、三寸の蛇、ぞろぞろと嘔吐すが怪しゅうないか。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ああ、書きながらも嘔吐を催す。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目の津軽海峡は、波高く風すさび、白鴎絹を裂くが如く悲鳴して、行きし時には似ぬシケ模様に、船は一上一下さながら白楊の葉の風にひるがへるが如く、船室は忽ちに嘔吐の声｜氛々半余歳、塵臭漸やく脱し難からむとするに至つて、乃ち突如として帰去来を賦しぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗と脂がアバタの穴についたその寝顔は、いかにも醜悪であったから、木鼠胴六は、「何てきたねえアバタ面だ」　と、ペッペッと唾を吐き散らし、わざとらしく嘔吐を催した振りをしながら、佐助の懐中をさぐったが、鐚一文も出て来なかったので、呆れかえってしまった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然街は彼を歓迎せず、豚も彼を見ては嘔吐を催したであろう。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の一壮士、奇運に遭会し代議士の栄誉を荷ひて議場に登るや、酒肉足りて脾下見苦しく肥ゆるもの多し、われは此輩に会ふ毎に嘔吐を催ふすの感あり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日は大変元気で鯛の刺身を一人で三人前も喰べたのはいいが、そのおかげで昨夕は何度も嘔吐や腸出血らしいのがあったのだとも言った。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪食家の皇帝は、満腹のために食事がそれ以上喰べられなくなるのを嘆いて、満腹すれば独得の方法で自ら嘔吐し、胃の腑を空にして再び食卓に向ったというのだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は、頭の中に火の車が廻っているようなのを感じながら嘔吐をも催し、精も根も無くなって、寝台の上へどっと突伏して了うのであった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの者も怪しんで鏡にむかうと、皆その通りであるので、驚いて倒れる者もあり、嘔吐を催す者もあった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の肩の辺から、枕の方へかけて、未だ彼女がいくらか、物を食べられる時に嘔吐したらしい汚物が、黒い血痕と共にグチャグチャに散ばっていた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、――」「僕は」私はぶちまけてしまおうと思った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云おうとして居る。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
