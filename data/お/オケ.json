        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "斯かる時純粋芸術が在りとするや、芸術が幸福な時代におけるよりも却てそれは謂はば純粋に過ぎる、純粋もいいが線が細過ぎる、といふやうなことが、いへるといふやうなことはなからうか？",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの詩集は、北原兄の『思ひ出』以後における日本唯一の美しい抒情小曲集である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に老いの近づいたヘルンは、自分の死後における妻子の地位を考えた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　室生犀星君は、最近における故人の最も親しい友であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は芥川君の死因について書く前、この短かい年月の間における、我々の思ひ出深い交情を追懷して見たいと思ふ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に彼の觀照が澄めば澄むほど、素通しの硝子における陰影の缺陷が著るしかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文學上における主觀主義者――それ故にまた浪漫主義者――としての私の立場は、芥川君の「あまりに文藝的な」「あまりに觀照的な」態度を好まなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし私が、私の言語における「詩」といふ定義を換へるならば、彼は疑ひもなく詩人――しかも最も若き時代の詩人――であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川君のあの論文、及び最近における彼の多くの感想をよんだ人は、いかに彼が純粹な詩の憧憬者であり、ただ詩的なものの中にのみ、眞の意味の文學があり得ることを、必死に力説してゐるかを知るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の過去における一切の思想と感情とに、ある根本的の動搖があり、新しき生活の革命に入らうとする、けなげにも悲壯な心境が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの日の印象ほど、芥川君の眼における少年らしさ、風貌における書生らしさを見たことがない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私の信ずる所によれば、彼の自殺における「漠然たる不安」の一つは、近く來らんとする彼自身の心境的革命にまで、名状しがたき不安の困憊を感じたのである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私が此處まで考へてきた時、始めてあの鵠沼における悲壯な會話が、言語の隅々まで明らかに解つてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからさういふ時には、よく云はれるやうに「芸術家は子供つぽいものですよ」と云つておけばよい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があらゆる俳句を理解し得ず、俳句を本質的に毛嫌いしながら、一人例外として蕪村を好み、彼の俳句だけを愛読したという事実は、思うにおそらく、蕪村の情操における特異なものが、僕の趣味性や気質における特殊な情操と密に符合し、理解の感流するものがあったためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの「蕪村の情操における特異性」とは、第一に先ず、彼の詩境が他の一般俳句に比して、遥かに浪漫的の青春性に富んでいるという事実である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば、これらの句には、洋画風の明るい光と印象があり、したがってまた明治以後の詩壇における、欧風の若い詩とも情趣に共通するものがあるからである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度万葉集の和歌が、古来日本人の詩歌の中で、最も「若い」情操の表現であったように、蕪村の俳句がまた、近世の日本における最も若い、一の例外的なポエジイだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで芸術における「主観的」「客観的」もしくは「主情主義的」「主知主義的」ということは、本来何を意味するものだろうか。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら多くの人は、これらの客観的特色の背後における、詩人その人の主観を見ていないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではそもそも、蕪村におけるこの「主観」の実体は何だろうか。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の咏嘆しているものは、時間の遠い彼岸における、心の故郷に対する追懐であり、春の長閑な日和の中で、夢見心地に聴く子守唄の思い出である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉における木曾義仲の崇拝や、戦国時代への特殊な歴史的懐古趣味を、一方蕪村の平安朝懐古趣味と比較する時、両者の異なる詩人的気質が、おのずから分明して来るであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩における観照の対象は、単に構想への暗示を与える材料にしか過ぎないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百数十年も昔に作った蕪村の詩が、明治の新体詩より遥かに芸術的に高級で、かつ西欧詩に近くハイカラであったということは、日本の文化史上における一皮肉と言わねばならない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく徳川時代における蕪村の新しさは、驚異的に類例のないものであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
