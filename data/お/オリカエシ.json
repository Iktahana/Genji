    "definitions": [
      {
        "index": 1,
        "gloss": "by return",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "折り返し南洋から繪葉書が來て「おまへの手紙を讀みました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがそのはじめは不精密なる経験の試験的整理を幾重となく折り返し繰り返し重ねて、漸進的に進んで来たものである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンパルナスのキャフェ・ド・ラ・クーポールの天井や壁から折り返して来るモダンなシャンデリヤの白い光線は、仄かにもまた強烈だった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお御面倒でしょうが、同封のハガキで御都合折り返しお知らせ下さいますようお願いいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社の余暇を盗んで書いたので意を尽せないところが多いだろうが、折り返し、御返事をまちます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大塚はその藤葛を手にしてその端を帯に差してそれを折り返した。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のその返事に折り返して来た伯父の葉書には、災難はいつ降ってくるか分らず、人は常にそれに対して、何時遭遇しても動ぜぬだけの心構えを養って置くことが必要である、といった意味のことが認められていた。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は催促されないように折り返し色紙を返送した。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして封筒の折り返しはゴムで貼り付けてあり、間違いでなければ、煙草を噛んでいた男がやった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　返事の代わりに、ホームズは依頼人の膝に置かれていた腕を取り、黒いレースの袖口をつまんで折り返した。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "封筒を拾い上げてみますと、折り返しの裏糊のすぐ上に赤い墨の走り書きが。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかから五粒だけつまんで、状袋に入れ、折り返しの内側に「ＪＯ代理人ＳＨ」と記す。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかげでわざわざ行った先から折り返して無駄足を踏まずに済む。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し聞き取れぬ所があつたので折り返して聞いたら赤い顏をして仕舞つたのである。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "中将からまた折り返して、君にかく引き取られぬる帯なればかくて絶えぬる中とかこたんなんといっても責任がありますよ。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法の折紙とは、一つの基本的な折方から出発して、様々の形に三十七種まで麒麟やら、扇やら、機関車などに変化するもので、彼は獄中で差入れの塵紙を根気よく折り返して考案したのだ、発売したら子供達が喜びさうなものであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船員は傍若無人に衣嚢の中から何か書いた物を取り出して、それを鉛筆でチェックしながら、時々思い出したように顔を引いて眉をしかめながら、襟の折り返しについたしみを、親指の爪でごしごしと削ってははじいていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長が音をたてて新聞を折り返した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折り返していうべき言葉に窮してしまって、拙くも、「わたしはこんな所であなたとお話しするのは存じがけません。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が、僕のこの苦言に憤慨して、折り返し傑作を寄せてくれれば幸いだ」　罠！",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偽りの姿と言葉想ひを変へ国を変へてここに現れよ、またかしこにも」　彼もまた更に折り返して歌つた。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵を討つ所存は毛頭ござらぬわ」　老僧は折り返していった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、折り返して返事が来た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い毛裏を折り返した法衣を裾長く引く坊さんが、うつ向いて女の手を台の方角へ導いてやる。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手紙が着き次第すぐにも立たして下さい――そう言って兄の方から折り返し浅井に迫って来た。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、自分が二度も折り返して観せて貰ったのは、ただ自分の研究心の満足のためばかりであったことや、いずれ、これが真物ではなかったことが子爵の耳にも入るに違いない時のこと等を考えると、彼は寧ろ痛み入った気持になった。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷峰は寢卷きを着かへながら、その赤いもみの裏を折り返して義雄に見せ、「これもあの女に」と、高砂樓のなじみを思ひ出す樣子で、「貰つたのぢや。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一行の先輩の間に、これを贈るにどう云ふ形式を以てするが好いかと云ふ評議があつて、結局折り返して使に本を持たせて還すのは面白くない、幸同行清川安策の父玄道は寿海を療治してゐるから、これに託して寿海の宅へ送つて遣るが好いと云ふことになつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯上げは上に、腰帯は下に、帯を中にして二つの併行線を劃した緋と、折り返して据わった裾に、三角形をなしている襦袢の緋とが、先ずひどく目を刺戟する。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "令子もな」　校舎の表なら事務室のまえ、裏なら職員室の下をとおらねばならず、三人はいちど下の道にひきかえし、そこからおりかえして、庭園に沿った県道への道を歩き、校門からふたたびキャンパスに入り、小庭園の東屋にたどりついた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
