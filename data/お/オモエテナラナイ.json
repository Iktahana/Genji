    "definitions": [
      {
        "index": 1,
        "gloss": "cannot help feeling that",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
