    "definitions": [
      {
        "index": 1,
        "gloss": "road for persons of high rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その帰り途に下谷の御成道へさしかかると、刀屋の横町に七、八人の男が仔細らしく立っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の送葬のときに私も町内の附き合いで行ってやったから、よく知っています」「むむ、妙信寺か」　源次に別れて、半七は御成道の大通りへ一旦出て行ったが、また何か思いついて、急に引っ返して広徳寺前へ足をむけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てめえは御成道の横町のお化け師匠の情夫か、亭主か。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "西岡は下谷御徒町の親戚をたずねて、その帰り途に何かの買物をするつもりで御成道を通りかかると、自分の五、六間さきを歩いている若い娘の姿がふと眼についた。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日見馴れている妹ではあるが、兄は今更のようにその顔や形をじっと眺めると、さっき御成道で見かけたかの娘と不思議なほどに好く似ていた。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "金兵衛はその日、下谷御成道の同商売の店から他の古道具類と一緒にかの兜を買取って来たのである。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、最初お前にその兜を売った御成道の道具屋はどうした。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御成道の道具屋の女房はこの七月に霍乱で死にました。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれ自身の云うところによれば、ある夜更けに下谷の御成道を通ると、路ばたの町屋の雨戸の隙間からただならぬ光りが洩れているので、不思議に思って覗いてみると、それは古道具屋で、店先にかざってある木彫りの弁天の像から赫灼たる光明を放っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛声をして、提灯を振り廻して、御成道を上野へ向けて行く。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう人物か知らないが、とにかく、約束通り、私は、その宿所へ訪ねて見ると、それはなかなか立派な構え、御成道の大時計を右に曲って神田明神下の方へ曲る角の、昌平橋へ出ようという左側に、その頃横浜貿易商で有名な三河屋幸三郎、俗に三幸という人の店であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "貿易品の型彫りをしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでも二、三日まえ、あいつが御成道の横町を通ると、どこかの古道具屋らしい奴と紙屑屋とが往来で立ち話をしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "贋物を売った古道具屋は御成道の横町で、亭主は左の小鬢に禿があるそうです」　　　　　四　師走の町の寒い風に吹かれながら、日の暮れかかる頃に半七は下谷へ出て行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "御成道の横町で古道具屋をたずねると、がらくたばかり列べた床店同様の狭い家で、店の正面に煤けた帝釈様の大きい掛物がかかっているのが眼についた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "下谷｜御成道の道具屋の隠居十右衛門から町内の自身番へとどけ出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は下谷の御成道に店を持っている遠州屋才兵衛という道具屋である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂を聞いて、彼は善八と一緒に御成道の遠州屋へ乗り込むと、才兵衛の死骸はまだ引き渡されていないと見えて、店の番頭らは帰って来なかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿店の前を過ぎ行く夜寒かな　御成道は車少く、三橋渡れば左右の飲食店建物いかめしけれど内は淋し気に見ゆ。",
              "citation": {
                "source": "夜寒十句",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙「そんなら此所から遠くもないから御成道の黒焼屋の横町さ。",
              "citation": {
                "source": "七福神詣",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の昌平橋は只今は御成道の通りに架って居りますが、其の頃は万世橋の西に在りましたので、多助は山出しでございますから、頓と勝手が知れません。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "油揚げ百五十枚が、下谷御成道建具屋金八。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "毅堂が上総国久留里の藩主｜黒田豊前守直静に聘せられ下谷｜御成道の上屋敷に出仕したのはあたかもこの時分であろう。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三郎は或夜｜御成道で何者にか頤を斬られた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日強ひて下谷へのおもひでを挙げようならば、御成道の大時計、同じく御成街道東側にあつた風船あられ屋の舶来風絵看板、動物園裏門下の通りで見た先代市川団蔵の世にも花やかな葬儀の大行列、あぶらでりした七月の朝小舟で船頭が漕いでいつては採つて来て呉れた不忍の池の蓮の花と実。",
              "citation": {
                "source": "下谷練塀小路",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしその声は旅鴉のごとく皺枯れておったので、せっかくの風采も大に下落したように感ぜられたから、いわゆる源ちゃんなるもののいかなる人なるかを振り向いて見るも面倒になって、懐手のまま御成道へ出た。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで躯の中から不機嫌を叩き出そうとでもするように、力のこもった大股で、御成道を横切ると、松下町から武家屋敷のあいだをぬけ、細くて急な坂を登ってみくみ町まで、ぐんぐんと休みなしに歩き続けた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野広小路から御成道に進行中、僕はふと買物を考付いたので、突然女房に向って、「オイ、俺はうさぎ屋で買ってくるから、みんな広瀬中佐の銅像んとこで待ってろ」と、言い放つと同時に、僕の小隊に振り向きもせず、黒門町で下車して終った。",
              "citation": {
                "source": "青バスの女",
                "author": "辰野九紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり覚えているのは、下谷の御成道の太助｜店という長屋にいたときのことで、おせいは五歳だったが、母親は良人と娘を捨てて出奔した。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "借馬だけに我々も尻馬に乗って出かけたのが神田｜御成道、同秋葉原、浅草の猿若町等々。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした借馬屋直伝の馬術も、少し慣れると早や一ぱしの乗馬家気取り、新調の乗馬ズボンに竹のむち、遠乗りでもしそうな姿、御成道の借馬屋などこういう連中が押しかけて、一時間二十銭の奮発で街頭へ進出。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
