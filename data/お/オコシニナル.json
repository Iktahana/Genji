          ],
          "literary": [
            {
              "text": "へい、そしてどちらへお越しになるんで。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どこへお越しになるのでござります。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへお越しになるのでござります！",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまかいまかと、お越しになるのをお待ちしていたところでござります」「なに！",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甚だ立入つたことをお尋ねいたしますが、どちらへお越しになるのでございますか？",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様が、あなたがお越しになるとおっしゃったのです。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "（註八〇）おい、ジョージ、お前、体をゆすぶり起して、リヴジー先生が柵をお越しになる手伝いをしてあげろ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最初の内、そうした身分の方でございますれば、わざわざ私たちの様なところへお越しになるのも、不審といえば、不審なこと、何故にまた、お宅へ名ある師匠をお呼びよせにはならないのであろう、と考えたのでございました。",
              "citation": {
                "source": "両面競牡丹",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此方へお越しになるのを機会に橋口さんの謡曲丈けは是非断って戴きます。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体この辺はあなた方のお越しになる所ではないがどうしてこんな所にお越しになったかという。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれからそのゲロン・リンボチェの所にお越しになるには、ちょうど一日ほどの道がござります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれから多分十五、六日間は人に逢うことは出来ますまいから充分ご用心なすって、雪の中の豹に喰われないようにお経でもお読みになってお越しになるがよかろう。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからまずあそこへお越しになるのが一番｜得策であるといって親切に馬を貸してくれたです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私はもうあんな所に行かないんだから案内者は付けられませんが、あなたがお越しになるならば私はこの馬を牽いて来た人に吩咐けますから、この馬方と一緒に行かれるがよかろう。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも其堂へお越しになることもあれば成らぬこともありますので、その法会に集まる僧侶がおよそ二万人位のものです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでその後は誠に久し振りで、あなたはよくこちらにお越しになる事が出来ましたというような話。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで上等社会の婦人は幾分か綺麗であるとはいうものの、一番お座の冷める話は、お便に行ってその儘お越しになるという秘密を思い出すと、どんな美人でも一遍に嫌になってしまうです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "第百二十四回　恩人の義烈心事既に決す　この日私はまた大蔵大臣の宅へ帰りまして、大臣にこれまでの秘密を打ち明けようと思ったところが、生憎この日は五月二十二日即ちチベット暦の四月十三日で、法王がノルプ・リンカの離宮からラサ府へお越しになるということで、前大蔵大臣も奉迎に行かれたです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは、お一人で、その八幡村から、これへおいでになったのですか」「はい……」「して、またお一人で、これから武州沢井までお越しになるのですか」「はい……」　武者修行は、そこでもう追いすがる勇気も、正体を見届けくれんの物好きも、すっかり忘れてしまっていたそうです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――はあ、日本画の方の受持ち筒井春江先生やのんで、常時お越しになる訳やのうて、ときどきやって来られて、何処が悪いやとか此処をこないせえやとかいわれますのんで、常は生徒たちが勝手にモデル見て画いてますねん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………そう云って丹生夫人は、自分の方は孰方にしても座敷を申込んだことであるから、定刻には橋寺氏を誘って約束の場所へ出かけて行くつもりなので、御返事のお電話を戴くには及ばない、大概お越しになるものと思ってお待ちしている、………と云うのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ムッシューが広間にお越しになるのでしたら、既に一人、来客がおられます。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那は大湊へお越しになるのではございませぬか」　さざえを焼いている老爺に注意されて、「そうだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、吉野太夫様の」「ああそうか、来るか」「お越しになることは、どんなことをしてもお越しになると仰っしゃいましたが……」「……ましたが……。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんでも浪人したという話だ」　そこへさっきの菖蒲革が帰ってきて、「眼八、やはりお役宅のほうで待っていろとおっしゃったよ、すぐにお越しになるだろう」「ありがとうぞんじました」　と、およその時間を計りながら、そこで、二、三服煙草を吸ってから、役宅の奥へ入って行った。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるひ　おこしになるまで　しっかり　みはっておくと　やくそくしました。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ　リービは　ダッチェスの　おへんじを　うけとり、　その子犬さんが　おこしになると　知るや　すぐさま　――　パイを　オーヴンに　ひょいと　入れます。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "内大臣どのにしたところで、そのじぶん敵か味方かわからない土地をお通りなされて、わずかのにんずでみのゝくにからはる／″＼おこしになるというのは、容易のことではなかったのです。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前ぶれなしにいきなりおこしになるから、若様がたはもとよりのこと、家庭教師が面くらう。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
