        "index": 1,
        "gloss": "daikon, etc. trimmings, usu. added to rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "關取、ばんどり、おねばとり、と拍子にかゝつた言あり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「飯炊くとき、おねばりとってやんな」　その次の日又重湯を運んでやり、歩けるようになる迄、粥をやるのがいしの任務であった。",
              "citation": {
                "source": "秋の反射",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君がとんぼとりにつかうもちは、その芋をつぶすときに出来るおねばのことであるが、さてそのこんにゃく屋さんは、はたらき者の爺さんと婆さんが二人きりで、いつも爺さんが、「ホイ、きたか――」　と云って私にニコニコしてくれた。",
              "citation": {
                "source": "こんにゃく売り",
                "author": "徳永直",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
