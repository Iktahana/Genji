        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "狭い東洋の門戸――ＰＨＡＲＡＯＨの国。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　で、ついに私も、こんなに骨を折らせた旅行用衣裳掛けなる怪物を現実に――ＯＨ！",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とたくさんの物語の主人公と女主人公がこのまち筋を歩かせられ、またこれからも、どれだけその人道を蹈むことだろうか――ＯＨ！",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機・複葉・とんぼ・無数の水々しい飛行機――新鮮な果実のような、悪戯心に満ちた反撥と弾力をじっと押さえて、ＯＨ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "Off she goes ―― The Silver Wing !　ＯＨ！",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩情と俗曲と秋波と踊りと酒と並木と女の足との統一ある大急湍――ＯＨ！",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の代りに美人の顔が咲いてる絵――これは仏蘭西しゃぼんの広告――寝台の脚とそばに脱いである男女二足の靴だけを大きく出した写真――靴屋の広告――「ＯＨ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて「ＯＨＡＹＯＵ」の文字が一文字ずつ現われる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日には、猫が走っても犬が吠えても、顔をしかめて「ＯＨ！",
              "citation": {
                "source": "字で書いた漫画",
                "author": "谷譲次",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、権十は和尚が不在の理由をきき、愕然として顔色を変へたが、すこしも早く、ＯＨ！",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と聞いてみたら、「ＯＨ、イエス！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側から自分の顔を支えるようにし、「ＯＨ！",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国紳士とは、ぼくがＯＨＶのバーチカル・ツインに乗っているからだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
