    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oar",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールド・ロング・サインを歌い、炉辺の団欒を思い、その郷愁を白い雲にイメージする英吉利文学のリリシズムは、偶然にも蕪村の俳句において物侘しく詩情された。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪は昔の徳川時代の医者のような総髪を、絵にある由井正雪のようにオールバックに後方へなで下ろしていた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキのように固くなったオバーオールが、三着。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オールドゥーヴル」は「前菜」に殆ど駆逐されたかたちである。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いオールバックの男が這入ろうとすると、役人が二、三人寄って行って、その男の洋服のかくしを一つ一つ外から撫で廻していた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の大将が食卓でオール・ドゥーヴルを取ってから上目で給仕の女中の顔をじろりと見る、あの挙動もやはり「生きてはたらきかける」ものをもっている。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、どうかね、お客さまのお顎が白くて、それに円くて、大へん温和しくいらっしゃるんだから、やはりオールバックよりはネオグリークの方が調和がいゝぢゃないかな。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "公爵のシャトーの中のかび臭い陰気な雰囲気を描くためにいろいろな道具が使われているうちに、姫君の伯母三人のオールドミスが姫君の病気｜平癒を祈る場面がある。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾きかけたオヴァオールから酸っぱい汗の臭いが蒸れ立って何とも云えぬ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールを入れて左右のハンドルを片手で握り乍ら素早くシートへ彼女は腰を滑り込ます。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子はオールでバランスを保ちながら、靴の紐を手早く結ぶ。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールもまちまちに河下の方へ艇頭を向けると、下げ潮に乗って、逃げ出した。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから室子は結局のところは男に敵わないと思っていたが、この青年は抜群の腕と見えて、彼女の左舷の方に漕ぎ出ると、オールへ水の引掛け方も従容と、室子の艇の、左舷の四分の一の辺へ、艇頭を定めると、ほとんど半メートルの差もなく漕ぎ連れて来る。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、どうかね、お客さまのお※が白くて、それに円くて、大へん温和しくいらっしゃるんだから、やはりオールバックよりはネオグリークの方がいいじゃないかなあ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "端艇は忽ち艇頭を右に轉じて、十二の「オール」の波を切る音と共に、本艦指して矢のやうに進んだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそうオールスターキャストというだろう。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールスターキャストというのがつまりそれだ。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、オールドカルトンとかニューカルトンとかカフェマキスィムとか云ったたぐいの家々と共に上海一流の酒樓であるところの、「上海の赤風車亭」と呼ぶ家の地下室にあった倶楽部なのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらも都の者らしく、男は学生式のオールバックで、女は下町風の桃割れに結っていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」これはこれ、藝術家のコンフイテオール。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」これはこれ、芸術家のコンフィテオール。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら危い足どりでその舟に乗り込み、「ちゃんとオールもございます。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と勝治が言って、ピチャとオールで水面をたたいた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ピチャとオールの音。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パチャとオールの音がして、舟は小島の陰からあらわれた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎日本社會黨論評（同上）二十一、二兩日の諸新聞は日本の社會黨が容易ならざる大逆の陰謀を企て居れりとの報を載せ、中にもウオールド新聞の如きは日本は今日までは善良なる文明を輸入し居りしも今日は追々惡しき文明を輸入し初めたりと論じ居れり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀の家ではだん／＼持船を人に譲って、残した小綺麗な船だけにオールのクラッチを取付け女子供でも漕げるような遊山船にしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長身痩躯、漆黒な髪をオールバックにした三木雄は立派な一個の美青年だった。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌社へきけば判るだろうと思い、文芸春秋社へ行き、オール読物の編輯をしているＳという友人を訪ねると、Ｓはちょうど電話を掛けているところだった。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
