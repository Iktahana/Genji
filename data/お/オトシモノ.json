    "definitions": [
      {
        "index": 1,
        "gloss": "lost property",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私はその人がなにか落し物でも捜しているのだろうかと思いました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり落し物だ、と思いました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし落し物なら影を背にしてこちらを向いて捜すはずだ。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二三間手前で、思い切って、「何か落し物をなさったのですか」　とかなり大きい声で呼びかけてみました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「落し物でしたら燐寸がありますよ」　次にはそう言うつもりだったのです。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし落し物ではなさそうだと悟った以上、この言葉はその人影に話しかける私の手段に過ぎませんでした。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　落し物もいろいろあるが、切子燈籠を往来のまん中に落して行くのは少しおかしいと女房は思った。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地の大都会の人は、落し物でも探すように眼をキョロつかせて、せせこましく歩く。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽の人はそうでない、路上の落し物を拾うよりは、モット大きい物を拾おうとする。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、どうしてこんなものが落ちていたのかな」　博士はそれが、今暁この屏風岩の上空をとんでいった東洋人爆撃機からの落し物であろうとは、気がつくよしもなかったし、それが出征将士慰問の前線文庫の一冊である新品月遅れ雑誌であったことをも知るよしもなかった。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は川上機関大尉のもちこんだ日本酒でひどくいい気持になり、いいたいことをいって寝てしまったが、今朝になると、なんだか昨夜のうちに落し物をしたような気がしてならない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼をそうした絶望に逐いやったことも可哀そうに思えたし、好い金の蔓を見失ったことも残念だったので、なおいくらかの自信と希望を失わないながらに、何か落し物でもしたような心寂しさを感じていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに何も落し物はないだろうな」　両手のポケットを外から叩いて、思い出そうとしたときに掌がいやにニチャニチャする。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "落し物をした、――拾ふことあれば落すことあり、善哉々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "落し物でもしたのかい」と上から不思議そうに聞きかける須永を見ると、彼は咽喉の周囲に白いフラネルを捲いていた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は落し物を拾いに帰る人の急ぎ足で、また元の派出所近く来た。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日のある暮れ方二三の遊び友達と遊んだあとで何かつまらない落し物を探していた。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奇抜な出来事は翌日の新聞に、落し物や寄附の記事とまぢつて、最も小さく報道された。",
              "citation": {
                "source": "風人録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは伊助の落し物かも知れないな」　それはツケヒゲのようであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺失物というのは落し物とか、忘れ物とかいう意味であった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服をつけ、オーバーをひッかけ、あたりに落し物はないかと見まわし、屋根裏を降りて、スパナーをフトコロに忍ばせ、足音を殺して、外へでた。",
              "citation": {
                "source": "都会の中の孤島",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか落し物をしたような気持ちである。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "落し物はないか、跡を残しちゃアいまいかと、律儀者だけに、イザとなると、度胸もつくし、用心もいい。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二　密室大犯罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｎ君……」　こんどは少し大声で呼ぶと、何と感づいたかＮ君は、何か落し物でもしたように、足許へ顔を俯むけてグルグル舞いをするのである。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂とは大分相違して案外楽に行けるぞと早合点して、何か落し物でもした時のように、軽い失望の気が起らぬでもない。",
              "citation": {
                "source": "釜沢行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に嗅覚の鋭敏な人間で、紙屑籠を肩に担いでは、その紙屑の一つのように江戸の町々を風に吹かれて歩きながら、ねたを挙げたり犯人を尾けたり、それに毎日のように落し物を拾って来るばかりか、時には手懸り上大きな獲物のあることもあった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宇治の茶箱",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おあいは、落し物なら夜中に起さなくともいいのにと、ふいに、内儀のうつむいている腰のあたりを見ると、金繍のある立派な夏帯の上に、どこからきて止ったものであるか、一｜疋の仄白い毒々しい夜の蛾が、ぼんやり手燭にぼやけて烟ってみえた。",
              "citation": {
                "source": "蛾",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、落し物をな。",
              "citation": {
                "source": "蛾",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か落し物でも見つけに來たやうなふうであつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四之木は痩せた小男で、言葉に九州方面の訛りがあり、なにか落し物でも捜すように、大きな眼で絶えず周囲をきょときょと眺めまわしていた。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
