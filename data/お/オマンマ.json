        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "行つて見るとまだ叔母は朝御飯が漸くすんだばかりで、ゆるゆるとお茶を飲みながら近所の人とトラックの話をしてゐるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お腹を拵へないことには、手伝つても貰へまいから、まづお午御飯だが、あの七輪にタンと火を起こして頂戴」「あゝ疲れた疲れた」と云つてパツタリ坐る。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯が煮けるまでにはまだ時間があるといふので、それからまたハタキと箒を買ひにやらされた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、お祖母さん、あたしお腹が空いたの――」「ぢきに御飯にしてあげるから、勉強してるんですよ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「祖母さんは今頃時分ヤツと御飯ね。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父に隠れて喫つてゐた煙草が懐にあつたので、それが御飯の時若しか転んで出でもすると不可ないと思つてそれを書斎に持つて行つて本棚の後に投げて置いた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が御飯の間に這入ると父と母はしてゐた話を急に止めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなになんでも延長したり質の問題にして考へたりしてたら御飯も食ふ時間がなくなりますよ」「さうかしら……」「女としては物分りの好い方だし、昨日の昼迄ならさうだわねと位に言つて呉れたんだらうにな……」と彼はさう思つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて歯をみがいて、御飯を食べて洋服を着ると、子供は学校に、お父さんはお役所へ行くのでありました。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子は三杯目に、「御飯未だあるの」　と女房に訊いた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何たべる」「何にしよう」……「御飯だの、おかずだの別々にたべるの面倒くさいわ、チキンライスにしましょう」。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし母がよく小言を云うにも拘らず、民子はなお朝の御飯だ昼の御飯だというては僕を呼びにくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私も起きるからお前御飯前なら御飯を済ましてしまえ」　僕は何のことか頻りに気になるけれど、母がそういうままに早々に飯をすまして再び母の所へくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくに上って御飯をたべて……」　僕は上りもせず腰もかけず、しばらく無言で立っていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……やがてお父さんが、「それでもまア一寸御飯を済して往ったら……あアそうですか。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯は勿論茶もほしくないです、このままお暇願います、明日はまた早く上りますからといって帰ろうとすると、家中で引留める。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶や御飯やと出されたけれども真似ばかりで済ます。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯食べて行ったらどう。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ御飯にしますから」　「石松は居ないのか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴ン方、御飯よ……」　「あ、今行くよ」　七五郎、不気嫌に家へ入る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あれが蜂の子供の御飯になるんだよ」「御飯に？",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてね、來年の春になつて卵がかへると蜘蛛が蜂の子供の御飯になるのさ」　と、話し聞かせてゐる内に、夫の頭の中には二三｜日前の妻との對話が不意に思ひ浮んで來た。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らんとおったのが御飯を食べるとき醤油が染みてな」義母が峻にそう言った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て衣絵さんが、婿君とこゝを通つて、鰻を試みたと言ふのを聞いて居たので、園は、自分好きではないが、御飯だけもと思つたのに、最う其は売切れた……「そら行け。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐吉さんが何も飲まないのだから、私一人で酔っぱらって居るのも体裁が悪く、頭がぐらぐらして居ながらも、二合飲みほしてすぐに御飯にとりかかり、御飯がすんでほっとする間もなく、佐吉さんが風呂へ行こうと私を誘うのです。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふたりとも、あの、おひるの御飯は？",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺なんざあ、三十年も銅や岩ばっかり噛って来たが、それでも歯が一本も欠けねえ」「岩は、俺たちの米のおまんまだ」　と云う程、慣れ切った仕事であったのに、それでもその一瞬間は、たとい夏であっても体のどこかに、寒さに似たものを感じるのであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「後の台詞はあちらの方が御存じだ」　と言って、Ｔ「現場を押さえて臭えおまんまを噛ましてやると仰しゃるんでしょう？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、俺の町の、場末の煤煙だらけの家に残っているおッ母アも、手袋を縫って、やっと、おまんまを食っているんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「水の上でおまんま喰ってる船頭が」Ｔ「違いねえ」　と伝六。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
