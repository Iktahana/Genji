          ],
          "literary": [
            {
              "text": "大鈴小鈴一　仁徳天皇には皇子が五人、皇女が一人おありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "課業の終を告げる大鈴が鳴り渡ると、男女の教員はいづれも早々に書物を片付けて、受持々々の教室を出た。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　急に大鈴の音が響き渡つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鈴の音が響き渡つたのは間も無くであつた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "小使の振鳴す大鈴の音が三時間目の終を知らせる頃には、最早郡視学も、町会議員も帰つて了つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時大鈴の音が響き渡つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
