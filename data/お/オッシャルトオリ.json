        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おっしゃる通り、急死というのじゃあどうも仕方がございません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、情夫でもこしらえたとかいうような浮いたお話なら、おっしゃる通り、わたくしも大抵のことは大目に見て居りますけれども、どうもそれがまことに困りますので……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "（嬢様、何か存じませんが、おっしゃる通りになすったがよいではござりませんか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "心持が悪いとおっしゃるからおっしゃる通りに伺いました。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　青月代は辿々しく、「で、ございますから、遠慮をしまして、名は呼びません、でございましたが、おっしゃる通り、ただ迷児迷児と喚きました処で分るものではございません。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもあんたのおっしゃる通りだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房　貴女、おっしゃる通りでございます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那様のおっしゃる通りきっと勤めりゃそれで可いのだ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、その指輪をはめていらっしゃる方のおっしゃる通りに、しなければならないのでございます。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「説明はわかりませんが、おっしゃる通りです。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、貴郎、そうして、小松原さんのおっしゃる通りになさいよ。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっしゃる通りに童どもを引き分けさせてもよろしゅうございますが、童どもは死んでも別れぬと申すそうでございます。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも姉えさんのおっしゃる通りにします」「おう、よく聴いておくれだ。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっしゃる通りでござります。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらこそ飛んだ粗相、本当に三平さんとやらがおっしゃる通りです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっしゃる通り妾はサンタ・マリアの出身ですわ」「ほんとうのことを言って下さい。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはあなたのおっしゃる通り、将軍は別に悪意があってなされた事ではなく、たくさんのなかですから、きっとお書き落しになったに相違ありません。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、やはり殿様ですから、恐れ入ります、おっしゃる通りです、というだけです。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっしゃる通りではないじゃないか、こうじゃないかといっても、成るほどそれはおっしゃる通りです。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬もおっしゃる通り、法師髪の月毛でございます。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくお父様がおっしゃる通りのことをして――椅子の上に一寸置いて――大切な眼鏡をみっしりと破ってしまった。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの意志は、あなたにまたお目に掛かって、御相談がいたしたい、ただのお話もいたしたい、なんでもあなたがそうしろとおっしゃる通りにいたしてみたい、昔の御交際を喚び戻したいと云うだけでございました。",
              "citation": {
                "source": "田舎",
                "author": "マルセル・プレヴォー　Marcel Prevost",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くおっしゃる通りなの。",
              "citation": {
                "source": "辻馬車",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもおっしゃる通りです。",
              "citation": {
                "source": "最終の午後",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "……文晁先生は当代の巨匠、先生の一｜顧を受けようと、あらゆる階級の人間が伺向するということだ」「へえへえ旦那のおっしゃる通りいろいろの人が参詣します。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅費は足りなくっても嘘をつくよりましだと思って、到底あなたのおっしゃる通りにゃ、出来ません、この辞令は返しますと云ったら、校長は狸のような眼をぱちつかせておれの顔を見ていた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり教頭のおっしゃる通り、寛な方に賛成します」と弱い事を云った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのおっしゃる通りだと、下宿屋の婆さんの云う事は信ずるが、教頭の云う事は信じないと云うように聞えるが、そういう意味に解釈して差支えないでしょうか」　おれはちょっと困った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや、おっしゃるとおりだ。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニワトリの奥さんのおっしゃるとおりよ」と、人形のベルタは言いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
