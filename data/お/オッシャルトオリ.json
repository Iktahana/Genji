    "definitions": [
      {
        "index": 1,
        "gloss": "as you (they, etc.) say",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
