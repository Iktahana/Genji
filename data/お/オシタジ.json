          "standard": [
            {
              "text": "お下地という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお下地の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お下地を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお下地という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お下地の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お下地は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お下地の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お下地と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お下地は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お下地はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お下地の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お下地の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お下地が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お下地を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お下地のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お下地に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お下地の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お下地の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お下地は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お下地の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おしたじが悪くって、めしあがられやしませんから。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらのお肴の方は少しおしたじが足りませんでしたかと思ひますけど……」「うゝん、丁度いゝ。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えて云えば、刺身の醤油、酢の物の酢、そばのおしたじ、でんがくの味噌など、その醤油や酢やおしたじや味噌などこそ、あらゆる香料を用い人智をしぼって研究すべきであり、天然の材料そのものは、あくまでも天然のままでありたい。",
              "citation": {
                "source": "「自然」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「がまんしてね」と少女は云った、「おしたじがないから塩にしたの、まずいかもしれないけれどしようがないわ」「有難う」と彼はちょっと頭をさげた、「いまは口にはいるものなら、なんでもいいよ、でも小さいのによくなんでも知ってるね」「貧乏のおかげよ」　りつ子は米を出して、また川のほうへ出ていった。",
              "citation": {
                "source": "おごそかな渇き",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
