[
  {
    "uuid": "978fdc01-2671-564b-99c3-4eac4092f9c2",
    "entry": "終わり",
    "reading": {
      "primary": "おわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
