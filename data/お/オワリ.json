    },
    "definitions": [
      {
        "index": 1,
        "gloss": "end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ピアノの音はこの物語の終わりまでつづいて行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "余はその罪のない横顔をじっと見入って、亡妻のあらゆる短所と長所、どんぐりのすきな事も折り鶴のじょうずな事も、なんにも遺伝してさしつかえはないが、始めと終わりの悲惨であった母の運命だけは、この子に繰り返させたくないものだと、しみじみそう思ったのである。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の humid（水けある）の終わりのｄをとれば「ウミ」に近くなり、第二｜綴字だけだと「ミヅ」になる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "梵語 udadhi（海）が単数四格で終わりにｍがつけば「ワダツミ」に近づく。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一語は診察の終わりであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにフランスのハイカイはなるほど三つの詩句でできているというだけは日本のに習っているが、一句の長さにはなんの制限もないし、三句の終わりの語呂の関係にも頓着しない。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱漆で塗った地に黒漆でからすの絵を描いたその下に烏丸枇杷葉湯と書いた一対の細長い箱を振り分けに肩にかついで「ホンケー、カラスマル、ビワヨーオートー」と終わりの「ヨートー」を長く清らかに引いて、呼び歩いていたようにも思うし、また木陰などに荷をおろして往来の人に呼びかけていたようにも思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを味わってみれば、自分一人である問題を解決しようとして一生何も貢献せずに終わり、あるいは恥をかく事もなく、めいめいの分に応じた仕事を楽しむ事ができそうである。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなればそれぞれの終わりに if C is D, if C is E. という文句が抜けているのが普通である。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労または倦怠が一たんそうしたものに変わったが最後、いつも私は終わりまでその犠牲になり通さなければならないのだった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は近くの沖にゆっくり明滅している廻転燈台の火を眺めながら、永い絵巻のような夜の終わりを感じていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついに肉体は無感覚で終わりました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その終わりに近いあるアーベントのことだった。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくあることではじめは気にならなかったが、プログラムが終わりに近づいてゆくにつれてそれはだんだん顕著になって来た。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の拍手とともに人びとが外套と帽子を持って席を立ちはじめる会の終わりを、私は病気のような寂寥感で人びとの肩に伍して出口の方へ動いて行った。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨　八月も終わりになった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また終わりに諏訪湖の神渡りの音響の事を引き、孕のジャンは「何か微妙な地の震動に関したことではあるまいか」と述べておられる。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "終わりには「病気」に関する一節があって、そこには風土病と気候の関係が論ぜられ、また伝染病の種子としての黴菌のごときものが認められる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際科学の巻物には始めはあっても終わりはないはずである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "終わりのｎは問題外とする。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またシラブルの終わりのｎは除外することにする。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には三声のうちの終わりの一つまた二つを「テッペンカケタ」で止めて最後の「カ」を略することがあり、それからまた単に「カケタカ、カケタカ」と二度だけ繰り返すこともある。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし自然の歴史が繰り返すとすれば二十世紀の終わりか二十一世紀の初めごろまでにはもう一度関東大地震が襲来するはずである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めから終わりまで繰り返さるる怒濤の実写も実に印象の強く深い見ものである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　「世界の終わり」と「模倣の人生」　同時に上映されたこの二つの映画の対照が自分には興味があった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "終わりの「出ぅよ」を早口に歌ってしまうと何かに追われでもしたようにみんないっせいに駆け出すのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学の二年の終わりに病気をして一年休学していた間に「片はしご」というのをおろしてくれたのが近所の国語の先生の奥さんであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからおまえの実験は、このきれぎれの考えのはじめから終わりすべてにわたるようでなければいけない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、大王どの、また高貴の客人がた、今晩はちょうどわれわれの方でも、飛び方と握み裂き術との大試験であったのじゃが、ただいまやっと終わりましたじゃ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももうきのうで休みは終わりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
