        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "笑い苦しめられた芸妓の一人が、その復讐のつもりもあって「姐さんは、そのとき、銀行の通帳を帯揚げから出して、お金ならこれだけありますと、その方に見せたというが、ほんとうですか」と訊く。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供じゃあるまいし、帯揚げのなんのって……」　こどものようになって、ぷんぷん怒るのである。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや旧派の束髪に結って、ふっくりとした前髪を取ってあるが、着物は木綿の縞物を着て、海老茶色の帯の末端が地について、帯揚げのところが、洗濯の手を動かすたびにかすかに揺く。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色の帯揚げは絶対に胸元にみせない事。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄桃色の帯揚げが、際立って艶に若々しく見えた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイは帯揚げの結びめでもゆるめたいような苦しい気になった。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、近所まで帯揚げのしんとピンを買いに行く。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "七瀬と八峯にも人形を出してやつて、それから着物を着更へやうと帯揚げを解きながら思ひついて縁側へ出て四畳半の書斎を覗いた。",
              "citation": {
                "source": "日記のうち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍と白の浴衣に、紅い帯揚げが、ちらりと、そこに動いた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、これでおしまい……」お綱は涼しい顔で帯揚げを引き抜き、桝で量る程な金銀をザラザラと詰め込み、さッさと体に着けてしまう。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして冨美子のかえるときお母さんのおびあげ、友ちゃんの半エリ、達ちゃんのかみそりの刃をとぐもの、ことづけます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
