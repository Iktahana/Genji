        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "動物はいないかと聞いたら「虎と尾長猿、おしまい、finished」といった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山海経』に招揺の山に獣あり、その状｜禺（尾長猿）のごとくして白耳、伏して行き人のごとく走る、その名を※々という。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと三本脚になったように見えますが、カンガルーや、尾長猿などは、太い尻尾をたいへん巧みにつかえますねえ、あのように活用するといいと思いますよ。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じ事を尾長猿が行つたところで、嬰児が行つたところで少しも気に懸けるには及ばない。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹帽に星のついたのを冠っている老翁の寝部屋に一つの尾長猿が這入って来ているところが先ず画いてある。",
              "citation": {
                "source": "ドナウ源流行",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "猩々、猿、手長猿、尾長猿から始まり最後はイルカ、サカマタ、ウニコール、スナメリ等であつた樣に思ふ。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾長猿の牝鍋の傍に蹲り、鍋の中を掻き廻し、煮え越さぬやうにす。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾長猿の牡と小猿等とはその傍に蹲り、火に当りゐる。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他に、くる／＼※ることを覺え込んだ尾長猿がまた彼等の慰み相手であつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
