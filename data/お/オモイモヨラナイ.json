        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "紙屋の亭主こそ実に迷惑で、それがために思いもよらない災難をうけて、一旦は召し捕られたり、その後もたびたび番所へ呼び出されたり、どうもひどい目に逢いましたが、右の事情が判って無事に済みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもよらない掛け合いをうけて、お豊は魂が消えるほどにびっくりした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、煮ようたって醤油なんか思いもよらない。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもよらない、参詣の、それが貴方。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわたしに取っても思いもよらないことだった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果こんなに厳重に警固しているうえは、いくら切支丹でも逃げることは思いもよらないから、願いを聞いてやっても好いと云うことになって二人の縄を少しゆるめてやった。",
              "citation": {
                "source": "幻術",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は風雨の夜をあるいて、思いもよらない拾い物をしたのであった。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはくだくだしく申上げるまでもありませんが、それから又ふた月ほども過ぎた後に、松島さんがお母さん同道でたずねて来て、思いもよらない話を持出しました。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る人に鑑定してもらうと、それは何代目かの明珍の作であろうというので、勘十郎は思いもよらない掘出し物をしたのを喜んだという話であるから、おそらく捨値同様に値切り倒して買入れたのであろう。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶がとどこおりなしに友之助と結婚すれば、お筆に取っては最も好都合であり、又そうなるのが当然であると信じていたところへ、思いもよらないお蝶の自殺という事件が突発して、お筆は溝口家に居たたまれないような羽目になってしまった。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君と久し振りで会って、愉快に飲んだし、思いもよらない君の戦話を聴いたし、もう、何にも不満足はない。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は旅の者で、まだ一度もお目みえしたこともないうえに、大切な巾を汚して、罪をのがれることができたなら幸いだと思っていたのです、結婚を許していただくとは思いもよらないことです」　公主が言った。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一度は、私どもが漁場へ着いて間もなく疾風が吹き起って、帰ることなどは思いもよらないくらいに海峡がひどく大荒れになったために、一週間近くも漁場に留まっていなければならなくて、餓死しようとしたことがありました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "四分の一マイルほどあるこの通りを、彼はそんなに年をとった人間には全く思いもよらない敏捷さで駈け下り、追っかけるのに私は非常に難儀をしたほどであった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事で、下宿の生活を楽しむなど思いもよらないと、大いにわれを叱って、無理々々に不快を打ち消した。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが屋の飼い鶏が客に対して、思いもよらない椿事を仕いだしたので、店の者共も蒼くなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも思いもよらない災難で飛んだ目に逢いました」と、お藤は眉をしかめながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ往来へ投げ出して置いたらば、凍死か行き倒れで済んだかも知れなかったのであったが、かれらの浅はかな知恵が却っておのれに禍いして、思いもよらない悪事発覚の端緒を開いたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで人々もほっと息をついて、しめ切った雨戸などを明けはじめると、さらに又思いもよらない椿事の出来しているのに驚かされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに……と申しては、あまりに手前勝手かは存じませんが、どうぞ快く御承知くださりませ」　自分をここまで誘い出して、おそらく闇討ちにでもするのであろうと澹山は内々推量していたが、その想像はまったく裏切られて、彼は思いもよらない難題を眼のまえに投げ付けられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "同性愛などとは思いもよらない仲であった。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、睡眠が与える元気回復ということは思いもよらないことであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "情人として逢うようなことは思いもよらないようにもう今の御息所は思っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは三十になるまで独身で、きざみ煙草の荷をかついで江戸市中の寺々や勤番長屋を売り歩いているのであるから、その収入は知れたもので、このままでは鬢の白くなるまで稼ぎ通したところで、しょせん一軒の表店を張るなどは思いもよらないことであった。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹から思いもよらない疑いを受けている林之助は、こうして夜ふけにお里と繋がって歩いていることが何だか疚しいように思われてならなかった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　内輪にこういう小刀細工をしている人間があろうとは、さすがに思いもよらない小坂部は、あくる朝ともかくも館を出た。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもよらない報せを師直の娘から受け取って、塩冶の奥方は涙を流して喜んだ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この同士討ちは、小坂部に取っても思いもよらない幸いであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里にいたとき、何度かこんな片言を云っていたが、京都でこんな言葉を使うとはおもいもよらないことだ。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかゝる無自覚な面が歴史的に復活しておもいもよらないカイビャク以来の愛国者になるであろうということなどは、もとより夢にもおもわない。",
              "citation": {
                "source": "二合五勺に関する愛国的考察",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
