        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もう断るにしては遅すぎる。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロヴァイダーに電話をかけて繋ぐ、いわゆるダイヤルアップの方式では、スピードが遅すぎる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京セラ自身百も承知だろうが、現在搭載されている二四〇×三二〇ドットの液晶は遅すぎるし解像度が低すぎる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "代りを函館から取り寄せるのには遅すぎるし、出来高だって問題にならない程少ないし。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸、今からではもう遅すぎるかなあ」　ドレゴは、水戸の腕をゆすぶった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、出勤が遅すぎるじゃないですか」「ああ、いやソノ、出願事件ですかな」「もう三十分も遅ければ、先生のお宅へ伺おうと考えていたところです。",
              "citation": {
                "source": "特許多腕人間方式",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩飯には少し間があるが、晩飯を済したのでは、夜の部の映画を見るのに時間が遅すぎる――ちやうどさう云つた時刻であつた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、もう遅すぎるセルでもちょっと汗ばむほどの、気持のいいぽかぽかする暖かさだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の婦人は日本の歴史のなかで今日幸福になっても遅すぎる位のたくさんの犠牲を払っております。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリア文学の擡頭に対しても「この頃やつと始まりしは、反つて遅すぎる位なり。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしちゃ谷村さんは遅すぎるな。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "栖方も梶の知らぬところで、その限界を踏みぬいている様子があったが、注意するには早や遅すぎる疑いも梶には起った。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十分では躊躇もされたが、それはまだ遅すぎるわけでもない間に合う時間だった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のことを云うには早すぎるし、否定するには遅すぎるし、というところでしてね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「道理でちつと御帰りが、遅すぎると思つてゐやしたよ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も彼も遅すぎる気がした。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私達が歩いている街路は、大震災後四五年たって――余りに遅すぎるが――漸く復興されてる最中だった。",
              "citation": {
                "source": "球体派",
                "author": "豊島与志雄著",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポテトが大好物の烏啼がこの企てをするのはもっともなことで、どちらかというと遅すぎる位のものです。",
              "citation": {
                "source": "奇賊は支払う",
                "author": "烏啼天駆シリーズ・１",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくても、一般からは事件の捜査や裁判が遅すぎると非難ごうごうたるものですからなあ」　大寺警部はいよいよ独特の奇声をふりしぼって不満をぶちまける。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたら、遅すぎるかもしれないが、明日にしよう。",
              "citation": {
                "source": "暗号音盤事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し遅すぎるかも知れないがね。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弦三はもう帰っているかい」「弦三は、アノまだですが、今朝よく云っときましたから、もう直ぐ帰ってくるに違いありませんよ」「あいつ近頃、ちと帰りが遅すぎるぜ、お妻。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二十四五歳になる婦人としては、つれあいを持つには遅すぎる。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ああ、母の来るのは何時もあんまり遅すぎる！",
              "citation": {
                "source": "麦藁帽子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今になつて自分自身の手で何ひとつ器用に出来ないのを後悔しても、もう遅すぎる。",
              "citation": {
                "source": "身についたもの",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもえらい占ひ者がゐて二分か三分前にそれを言ひあてたところで、この場合どうすることも出来ない、もう遅すぎる、その人もけつきよくは一しよに死んでしまふだらう。",
              "citation": {
                "source": "燃える電車",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外交は遅すぎるほうがよいので、早すぎるのが困る。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "薊――そうねえ、だけど、それじゃもう遅すぎるわ。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その家の御主人は厳格なひとで、私の帰宅のおそすぎる時には、こらしめの意味で門をしめてしまうのである。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平たく言えば早すぎるのやおそすぎるのがいろいろに錯綜交代して来るわけである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
