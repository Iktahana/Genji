    "definitions": [
      {
        "index": 1,
        "gloss": "one's favourite party trick (favorite)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何と云ってもいちばん多くの独創的な点をもっているのはいちばん小さい冬子の自由画であったが、その面白い点が一度認められ賞められるとそれがもう十八番になって、例えば富士山が出だすとそれがいかなる絵にでも必ず現われるのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠井さんは、長い廊下を、ゆきさんに案内されて、れいの癖の、右肩を不自然にあげて歩きながら、さっき女将の言った二十八番の部屋を、それとなく捜していた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私の生れは…………」「××県××郡名取村三百二十八番地だな」「はい、いいえ、わとみ村であります。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「和富村三百二十八番地。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて団十郎は歌舞伎十八番の「暫」を勤め、連日売切れの大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月、歌舞伎座にて団十郎は十八番の「助六」を演じ、前年の「暫」に劣らざる好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九月、歌舞伎座にて市川猿之助は二代目段四郎と改名して、歌舞伎十八番の「鎌髭」を勤む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にいっとくれなはれや、というのは政江の十八番だった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹林に恵れた小田原の山荘に於ける震災前後の生活から、珠数工に隣り住んだ谷中天王寺十八番地の仮寓時代、大森は馬込の月光の谿を瞰望した丘の上の一年が此の間に推移した。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしき我が武ちゃんよ、――今様のハイカラの名は敬慕するかはせみの君、外国のラリルレ語酔漢の語でいへばm…m…my dear brethren !――君が文読み、くり返し、我が心青柳町の裏長屋、十八番地ムの八にかへりにけりな。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎十八番なぞはその一例で、平生の芝居でも、誰の何々はこうこう……なぞいうところに観衆のこうした観賞欲が含まれている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに籠城が北条の十八番でも、のびのびと屈托のない秀吉に対しては一向利き目がない。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」葉子「えゝ、あるわ」十吉「その中の『雨だれ』というのを掛けてみてくれ、たしか十六番だ」鶴三「『雨だれ』なら、十八番だ、蜂谷さんの、だって、雨の音楽だろう？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "高尚がる俗人というのが木島の十八番だそうな、矢野も木島のいうことはおもしろいと思った。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校の庭から遠く海を隔てた相州あたりの山々を得意になつて望んだものだが卒業の時にはたう／＼六十八番に下落してしまつたのである。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "進み進みて下影森を過ぎ上影森村というに至るに、秩父二十八番の観音へ詣らんにはここより入るべしと、道のわかれに立札せるあり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八番の観音は、その境内にいと深くして奇しき窟あるを以て名高きところなれば、秩父へ来し甲斐には特にも詣らんかとおもいしところなり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が中途でプツリと切れたので、直ぐ二十八番を呼出そうとすると、丸善は今焼けてるという交換局の返事だから、そりゃ大変というので……』と、恰も一里も先きに火事があったように悠々閑々と咄していた。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人の先蹤を追った歌舞伎十八番のようなものでも椿岳独自の個性が自ずから現われておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものはためし、あちらを捜させてごらんなさりませい」　むっつり流十八番のからめ手詮議です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用の筋ゃなんですかい、お駕籠ですかい」　ひとりで心得ながら、得意になってはせつけたのを、むっつり流十八番、にこりともしないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで小判の顔が拝まれますかね――」　出したところをむんずと見舞ったものは、おなじみのむっつり右門が十八番中の一つなる草香流やわらの逆腕の一手です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "拷問、火責め、お次はどんな手が出るかしらねえが、急がねえところがまた右門流の十八番でな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先は伝六さまの十八番だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつり流十八番｜桂馬飛びという珍手を忘れていたはずだが、おまえさん心当たりはないかえ」「さあ、いけねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八番のからめ手詮議でぴしぴしとたたき上げていってみようよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそは忘れてはならぬ右門流十八番中の十八番、一見｜迂遠に見えて迂遠でない、遠回りしていって、事の起こりの根から探り出す名人独自のからめ手詮議なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんだご災難でござりましたな」　いいつつ、名人十八番中の十八番なるあの目です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "饗宴の興を添えるために来客のだれかれがいろいろの芸尽くしをやった中に、最もわれわれ子供らの興味を引いたものは、ある大工さんのおはこの影絵の踊りであった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下戸の種田君に追分と云ふおはこがあつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
