        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何々｜大姉と刻してある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは大姉さんに、お願いいたします。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、池袋の大姉さんの御推薦でした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頃、父に、母に、また池袋の大姉さんにも、いろいろ言われ、とにかく見合いだけでも等と、すすめられましたが、私にとっては、見合いもお祝言も同じものの様な気がしていましたから、かるがると返事は出来ませんでした。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池袋の大姉さんも、しっかりおやり等と、お手紙を下さるようになりました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法諡を臨照院相誉迎月｜大姉と云う。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "少い世捨人な、これ、坊さまも沢山あるではないかいの、まだ／＼、死んだ者に信女や、大姉居士なぞいうて、名をつける習でござらうが、何で又、其の旅商人に婦人が懸想したことを、不思議ぢやと謂はつしやる、やあ！",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどね、瑞心院妙月大姉としてあるようですが、気味のわるい、なんのまじないでしょうかね」「知りたけりゃ、ねこにきけよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "他は同じく新帰元円明貞鏡大姉とあるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "居士号大姉号をつけてあるところは相当金持ちだな」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから七面堂のあたりをさがした處、右手の深い草むらのなかに「信敬院妙立日如大姉」の石碑がころがつてゐたといふ事を聞かされた。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石碑の面には文字の刻みも消えはじめて「信敬院妙立日如大姉」右に寛保一辛酉、左に四月十日、妙經百部、繪島殿、とある。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "居士と大姉11・９（夕）　今本紙に「昨日の事」を書いてゐる久保田万太郎氏の家では、先日祖母さんが亡くなつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてもっとも遅く目が覚めた大姉が見ると二人の妹たちがそこにおらぬので、妹らよ妹らよと声のかぎり呼んでみたがすこしも返辞がなかった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうようなことで大姉がいくら呼んでみても妹たちがおらぬから、あきらめてその付近の大森山と小森山を重ねて早池峰山よりも高くしてそこに住もうと思って山々を重ねに取りかかったけれども、そのうちに夜が明けるのでそれもできずしかたなく同村の胡四王山に飛んだ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくそうしてその大姉は同所胡四王山の神となった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄は姉の法名、佳室妙豊大姉というのを彫りつける下書きを文人的凝り性から、何百枚も書き直しては丹念に書いていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の戒名は釈貞室妙証大姉と申します。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宝珠院妙心｜大姉」十一「汝、わが悲哀よ、猶賢く静かにあれ」　この文句を口吟んで見て、岸本は青い紙の蓋のかかった洋燈で自分の書斎を明るくした。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "年かさの大姉さんといふのが傍に居て監督して居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "半千院出藍終葛大姉というのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母の戒名は妙輪院清芳光桂大姉である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "信政の父八左衛門は法諡を大音柏樹居士と云ひ、母は※相寿桂大姉と云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其妻即信階の母は善室英証大姉と云つて、明和五年五月十三日に歿した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "法諡を寿山院湖月貞輝大姉と云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "戒名は寿山院湖月貞輝大姉である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "法諡を快楽院是参貞如大姉と云ふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に云つた如く、霊台院殿信誉自然現成大姉は津軽氏比佐子で、墓は浅草西福寺にある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳松院殿縁峰貞操大姉は錦橋の妻｜菱谷氏である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋林浄桂大姉は直卿の妾である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
