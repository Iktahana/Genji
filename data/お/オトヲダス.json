[
  {
    "uuid": "530f880b-d89f-598c-9392-06f640b471cd",
    "entry": "音を出す",
    "reading": {
      "primary": "おとをだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
