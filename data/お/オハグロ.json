          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "微かにお歯黒をつけた蚕豆の粒の一つと一緒に繊弱い豆の虫が一匹落て出た。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "微かにお歯黒をつけた蚕豆の粒の一つと一緒に繊弱い豆の虫が一匹落て出た。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お歯黒をした気味の悪い口を私の耳に押しつけながらもう涙ぐみ、そして私がわけの判らぬままにキョトンとしていると、もっとはんなりしなはれと叱りつけて、悲しかったらわてといっしょに泣きイ、さア、せえだい泣きイと、言うのです。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとっくに死んでいたおきみ婆さんと同じようにお歯黒に染めていたその婆さんは、もと髪結いをしていて、その家の軒には「おめかし処」と父の筆で書いた行灯が掛っていたのだが、二三年前から婆さんの右の手が不随になってしまったので、髪結いもよしてしまったらしい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂しい無縁坂を降りて、藍染川のお歯黒のような水の流れ込む不忍の池の北側を廻って、上野の山をぶらつく。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆あさんはお歯黒を剥がした痕のきたない歯を見せて、恭しいような、人を馬鹿にしたような笑いようをして、頭を二三遍屈めて、そのまま跡へ引き返して行った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お歯黒｜溝の側を大門に廻る。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゅうちょなく伝六に導かれていったその姿を見迎えながら、落としまゆにお歯黒染めた、まだみずみずしいうばざくらの若後家が声をひそめると、もっけもないことをささやきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはお歯黒をつけるには必ず必要の五倍子の粉を売っていた店で、店の中央に石臼を据えて五倍子粉を磨っている陰陽の生人形が置いてあって人目を惹いたもの、これは近年まで確かあったと覚えている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "お若い××様が御巡幸の時、百代と二人ならんだ姿をお見詰めになって――たしかにお目にとまったのだが、まだお歯黒をおつけになって、お童様だったから――なんて話もきくともなくきいた。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下で八十の彼女は、日ごとに、六ツ折りの裾に絵をかいた障子屏風を廻らし黒ぬりの耳盥を前におき、残っている歯をお歯黒で染めた。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな年寄りが出てくるのかと思ったら、色の浅黒い、顔の長いひっつめのいちょうがえしに結った、額に青筋の出ている、お歯黒をつけた、細二子の袷に黒い帯をひっかけ（おかみさん結び）にした女が出て来て、「なんだ今時帰って来て――」と突然どなってつづけた。",
              "citation": {
                "source": "古屋島七兵衛",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんが死んで、おきねさんが三ツ輪に結って、浅黄がのこをかけてお歯黒をつけて、どこかみだらな顔つきになったが、それも見えなくなった。",
              "citation": {
                "source": "テンコツさん一家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "三等船客の僕は、同室のギリシャ商人がのべつに歌ふ鼻唄にごうを煮やし、お歯黒をつけた安南の美女に、果敢ない想ひを寄せてゐた。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中の少年を、五十前後のお婆さんにした様な全体の感じ、お歯黒をつけた口元、背中にちんまり結んだ帯の恰好、よほど暗くなつた、屋並みはづれの薄明りで、はつきり見てとつた様な気がする。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原田圃の全景を眺めるには廓内京町一、二丁目の西側、お歯黒溝に接した娼楼の裏窓が最もその処を得ていた。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『註文帳』は廓外の寮に住んでいる娼家の娘が剃刀の祟でその恋人を刺す話を述べたもので、お歯黒溝に沿うた陰欝な路地裏の光景と、ここに棲息して娼妓の日用品を作ったり取扱ったりして暮しを立てている人たちの生活が描かれている。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々隣の叔母さんは粗末な垣根のところへやって来て、お雪に声を掛けたり、お歯黒の光る口元に微笑を見せたりした。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉原田圃の全景を眺めるには廓内京町一二丁目の西側、お歯黒溝に接した娼楼の裏窓が最も其処を得てゐた。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「註文帳」は廓外の寮に住んでゐる娼家の娘が剃刀の祟でその恋人を刺す話を述べたもので、お歯黒溝に沿うた陰鬱な路地裏の光景と、こゝに棲息して娼妓の日用品を作つたり取扱つたりして暮しを立てゝゐる人達の生活が描かれてゐる。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり私たちがいい人だと思ってなめるのもたいていにしておくれよ」　昔、根津で勤めをしていたという、眉の剃りあと青いお歯黒つけた、デップリと大柄のお神さんも、脇から険しい声を立ててきた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鉄漿とは、お歯黒。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "初音屋と呼ばれた人情噺の柳朝（春風亭・三代目）と馬楽と自分と三人でひと晩遊びに行ったが、その頃のお歯黒溝に沿った家々にはみな跳橋というものが向こう側まで掛け渡されていた。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ浮子の動きを見落すまいとして居る精神活動は、眼の方は浮子を専念見つめて居るのであつて、向ふ岸の草のゆるぐのも、水面を舞つて居るお歯黒｜蜻蛉の動きも無視し、又は無反応である。",
              "citation": {
                "source": "健康を釣る",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――むかしながらの、お歯黒のように澱んだ古い掘割の水のいろ。",
              "citation": {
                "source": "雷門以北",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お歯黒溝ですからな」　と巡査と俥屋は片岡君のマントの裾で手を拭いた。",
              "citation": {
                "source": "一年の計",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きみは下水のお歯黒溝であぶあぶしているし、僕は橋の上で一銭呉れというふうに、一日呶鳴っているようなもんだ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お糸婆さんは、お歯黒のはげた歯をむき出して、変な笑いかたをする。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つんぼかと覗けばかねをつけている」「稍しばしあってお歯黒返事する」などという川柳は、この句を解する上に多少参考になる。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀はちょうどお歯黒を附けかけていたが、急いで頬ぺたの汚れているのも拭かずに、飛んで来て介抱をしたので褒められ、燕は黒繻子の引掛け帯などをしているうちに、少し遅くなって碌々死水も取らなかった。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはぐろのような臭気が車内にみなぎっていたが出所は分からない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
