        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "茶会御出席に依り御心魂の新粧をも期し得べく、決してむだの事には無之、まずは欣然御応諾当然と心得申者に御座候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "応諾の御返事を、すぐには書けなかったのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも厭なような様子をしてみせ、また幾度も拒絶して彼を怒らせて、おとなしくしている自分をもちょっとむっとさせるような言葉を彼に吐かせてから、とうとう私は応諾してやった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つうんと承知をしてくれよ」　正木正太と名乗る半纏着の男は、ようやくのことで五郎造の薦めを応諾した。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後のかた、まことに済みませんが、もう一つやりますから、少々お待ち下さい」　老人の静かな声に、帆村もまた無言で応諾した。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何は兎もあれ僕はスウィッチを直ぐ様、送信機の方へ切換えると「応諾」の符号を送りました。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴局ノ都合如何」相手「応諾。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、法水はまた皮肉にも、応諾の旨を回答して、室を出た。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の午後二時に……との応諾だった。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてのことに、やっと応諾の返事が、ノーマ号からあがったので、いよいよ事務長はボートを仕立てて、六人の部下とともに海上に下りた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見が離れようとすればするほど纏りついてくる女の執拗さにあきれて、女の媚には応諾も与えずに、押黙って本を見ていた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「次に来るは応諾の時期である。",
              "citation": {
                "source": "幻影の盾",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず彼は躊躇なしに応諾を与える事ができなかった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――果して当時のモスコーからの情報によれば、国境委員会設定の件に就き、ソヴェート政府に於て応諾の色があると報じられた。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――果して、モスコーからの情報によれば、国境委員会設定の件に就き、ソヴィエト政府に於て応諾の色があると報じられている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿Ｑは応諾しながらも不承々々に出て行ったから、気にとめているかどうかしらん。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もそれを拒む理由はないし、欣然と応諾しました。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この花の咲いたような美夫人から……私なぞの終世垣間見ることもできぬ上流の貴婦人から、かくも容易く応諾の返事が得られようなぞとは、私にとってはまったく意外も意外！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がいたら先方の申込みを応諾させることは出来ない迄も、せめて人並な挨拶ぐらいはさせたに違いないものを。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかね嬢は些かの躊躇もなく応諾し、かなり積極的な態度で、あでやかに媚笑し、すり寄って、彼の手を握った。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしプロイセンがベルリン大学臨床の長として招聘したときには応諾した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "――たった今、主人信長を弑逆した光秀すら、信忠から書を以て、親王の御移徒を仰いだうえで決戦せんとの申し入れには、欣然、応諾の旨を答えている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、喜兵衛の使いが、僧庵を訪れて試合｜応諾を伝えたので、初めて事の次第を知った庵主は胆を消し、「小忰の悪戯ゆえ、なにとぞ深くお咎めなく容赦されたい」　と百方陳謝した。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
