          ],
          "literary": [
            {
              "text": "神田七段の昇段問題で日本將棋聯盟に紛擾起り、分裂の危機に頻すとの事、お役目柄倉島君忽卒として暇を告げて行く。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目首尾よく相勤めませねば、わたくし此の場で自害でもいたさねば相成りませぬ」　彼女は更に帯のあいだから袋に入れた懐剣のようなものを把り出して見せた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目柄がよう出来た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間外れたお役目柄が天道様の下で通用するかえ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大風呂敷が何を包んだものか、何処の穴から出て来たものかがわからぬうちは、お気の毒ながらお役目柄がお先まっくらじゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目仕事じゃない証拠じゃ」「何でもよい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は特に奮発して晩酌三合（いつもは二合）、いゝ気持で寝てゐるところを揺り起された、臨検だといふ、お役目御苦労、問はれるまゝに日本禅宗史を一席辯じて、おまはりさんと宿の人々を感心させた（と自惚れる）。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "相州さまはまた、ひたすらお役目お大事で、朝から晩まで幕府のこまごましたお仕事に追はれて、例の異常の正しさを以て怠らず律儀にお働きになり、その頃は将軍家の御意にさからふやうな事もほとんどなく、いまさら御一族と謀つて何かたくらむなどそんなおひまも野心もお持ち合せにならぬやうな御様子でございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことでよくお役目がつとまるとある人が感心する。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どなたもお役目御苦労に存じます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにこのたびのお役目は外記が申し上げて仰せつけられたのか」「そうじゃ。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい近くのカフェーの卓に向うと、久野はウェイトレスが持って来たソーダ水を、お役目のように、すゝりながらいった。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、こうした機会もあるのだから、仏語を少しでも覚えて置けばよかった、学生時代にお役目のように、講義を聴き放しにしたことが、一寸残念のように思われました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目に親切をしてくれるのがある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そなたのおとうさんは、ご藩にいられたおり、どんなお役がらでござったな」「殿さまのお手紙とかを書くお役目にござりました」「ほほうのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目ご苦労さまにござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会に住む、手の白い役人や学者が、日給を貰って名文に綴り上げて、メガホンで吹き散らすお役目物の宣伝と、この侠客の態度とは、その真実味に於て、鉄の弾丸と風船玉ほどの違いがある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか「緋鯉に餌をやるのを忘れたでせう、あなたのお役目よ。",
              "citation": {
                "source": "鵞鳥の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いかようのお役目でも、わたくしきっと承りまする」「まずは過分じゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お役目の方が御覧になりましたなら、何もかもお判りでござりましょうから、なまじいに隠し立てはいたしません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分もお役目柄でもう何もかも御承知でございましょうが、和泉屋の伜も飛んだことになりまして……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労人なぞというものは、せいぜい、そのくらいのことを言っていればお役目は済むのだ。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたは、このあたしを縛るつもりなのネ」「……うんにゃ、縛るのはもうよしたよ、はッはッはッ」「だってそれじゃお役目をどうするの……」「お役目か、お役目なんざ……もう罷めちまうばかりだ」「ヘン、云ってるよ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "侘しいですよ、ぽつねんと一人では」　お清は、「他に人がいないわけじゃあるまいし、とんだお役目ね」と云って笑った。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目に調べていたのが、斯う立派に逆証されて、刑事たちは、これでほっと安心した気持ちだった。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "お役目が済みましてからお邸にお帰りになりました時、いつになく暗いお顔をなされご機嫌もよろしくございませぬ。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどももみの木のおやくめは、もうすんでいました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            },
            {
              "text": "けちけちの、わからずやの、人をしかり飛ばすがおやくめだからね、なんにもご存じなしのくせにさ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
