[
  {
    "uuid": "90d7bab8-91c5-59d2-a05e-e749c9b55640",
    "entry": "女芸人",
    "reading": {
      "primary": "おんなげいにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
