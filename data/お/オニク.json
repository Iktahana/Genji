[
  {
    "uuid": "d1c5fc25-afc2-509e-b8c8-83bc6d1a0a0b",
    "entry": "尾肉",
    "reading": {
      "primary": "おにく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "whale tail",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その尾に夥しく節あり、驚く時非常な力で尾肉を固く縮める故ちょっと触れば二、三片に断れながら跳り廻る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ってどこにも一点として、精神的のところはなくて、徹頭徹尾肉感的であった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山榛の木の根方にうち倒れた、醜い空骸は、土に還ると共に、根方に寄生して、そこから穂のような花をさし出すおにくという植物になった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもお祖父様はご自分のためには、しまいまでお祈りをしませんでした」「お嬢様のおためには祈られました」「神よ、私をおにくしみください。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其地は、畏るべきところとして、半固有名詞風におにくまともかみくまとも言うて居たのであらう。",
              "citation": {
                "source": "信太妻の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん　ものうりの　にぐるまは　まわってきます　――　おにくやさんに、　うおやさん、　それから　ぱんやきティモシー。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさかな　いらないおにくも　ばいばい！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそなたはまだ年端もいかねば、藩中のお歴々からあらぬおにくしみをうけても、そなたのためになりませぬ。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぶなが公も浅井どのゝためにはたび／＼あやうい目におあいなされ、よほどおにくしみが深かったのでござりましょうけれども、もとはと云えば御じぶんの方がせいしを反古になされたのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども小谷のころのことを十とせにちかい今となってもおわすれなさらず、これほどつよく根にもっておいでなされ、とりわけおん兄のぶなが公へそれまでのおにくしみをかけていらっしゃいましたとは。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょうのけがわの中から、にんげんの子どもがとびだしたら、とらは、いっそうおどろいて、たけしくんのかおにくいつくにきまっています。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
