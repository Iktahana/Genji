        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お帰が遅れはしても、却てしっかりした足附で、御先祖の御殿の竈の前に、8615楽しくお近づきになる御主人様、ヘレネ様のお福を分けてお戴なさい。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、背をのけぞらして、落ちこんじゃうよ」「そして、“真実”とお近づきになるのね」オリーヴは、はしゃいで言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お近づきになるなんてまっぴらだといった態でさ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが本当だろうと間違っていようと、お近づきになるのもいやなんです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただ私は、みなさんとおちかづきになるのが何よりの楽しみでございました。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからすこし明治二十何年という時代の婦人作家たちとおちかづきになるところです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
