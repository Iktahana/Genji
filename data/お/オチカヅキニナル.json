        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お帰が遅れはしても、却てしっかりした足附で、御先祖の御殿の竈の前に、8615楽しくお近づきになる御主人様、ヘレネ様のお福を分けてお戴なさい。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか、背をのけぞらして、落ちこんじゃうよ」「そして、“真実”とお近づきになるのね」オリーヴは、はしゃいで言った。",
              "citation": {
                "source": "井戸",
                "author": "Ｗ・Ｗ・ジェイコブズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お近づきになるなんてまっぴらだといった態でさ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが本当だろうと間違っていようと、お近づきになるのもいやなんです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただ私は、みなさんとおちかづきになるのが何よりの楽しみでございました。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからすこし明治二十何年という時代の婦人作家たちとおちかづきになるところです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
