        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ピアノトリオ位で非常に優れた室内音楽でも附属しているのは決して悪いものではないとしても、併し「演出効果」なぞと云う大掛かりな仕掛けは実際邪魔になり過ぎる場合がある。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果第二に、これを日本で成功させようとすれば大掛かりな日本語化作業が必要となる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大掛かりな行列が、其所の坂の下まで来てゐると云ふので、台所の女たちは、恐しさに立ちすくむ者もあつた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが後期に及んでいかに大掛かりな舞台建造物を持つようになったかも知っていた。",
              "citation": {
                "source": "エトナ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな大掛かりの浮き岩を人工で作ったというのは、決して冗談や好奇心からではあるまい。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは諸国を巡って歩く、大掛かりの香具師の群れであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それも大掛かりの巣窟が」「面白い出来事にぶつかりそうだよ、さあ中へはいってみよう」　そこで三人は岩壁に添って、左側の方へ行ってみた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには大掛かりな陥没の痕が明らかに残っていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "老練な私掠船員による大掛かりな襲撃隊を編成し、ポートゥックスト農場においてカーウィンに奇襲をしかけるべきだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハートが見つけた所によると、アマサ・フィールドの区画にある通路からかなり離れた所に大掛かりな穴が掘ってあり、一味は発見前に相当長時間作業をしていたに相違ない。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢に見たものからの大掛かりな変更に気づいたのは僅かに二度のみで――その内の一度は、記憶にあるアーチ型入口を塞いだ輪郭を辿ることができた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在意図されている南極への侵入――大規模な化石狩りと大掛かりなボーリング及び太古の万年氷雪の融解とを伴う計画に反対する理由を述べることは、全く以て私の意に反するのだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要なら更なる移動のため備品を他の三機に移送するが、目下のところ大掛かりな飛行の要なし。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行は極めて頻繁だったが、永住のための移動は種族が拡大する際の大掛かりな植民運動を例外として比較的稀だった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレントン・デンですら、仲間にそっと加わるまで、そんなに大掛かりだとは知らなかった。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "賭け金詐欺でやす、大掛かりで巧妙な仕掛けで、ずっと競馬場でやられていやす。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺すもよし、ものを盗むもよし、ただ少しおおがかりな犯罪ほどよいのですよ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、硫酸タンクなんておおがかりな設備をすれば、いずれは見つかるにきまっています。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
