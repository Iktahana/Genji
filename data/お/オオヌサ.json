    "definitions": [
      {
        "index": 1,
        "gloss": "streamers (made of linen, paper, etc.) attached to a long pole (used as a wand in grand purification ceremonies)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
