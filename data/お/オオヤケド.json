        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、空襲で家は焼かれ、その二十六になる末娘は大やけどをして、医者の手当も受けたけれど、象さんが来た、象さんが来た、とうわごとを言って、息を引きとったという。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると大国主神は、それほどの大やけどもたちまちなおって、もとのとおりの、きれいな若い神になってお起きあがりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぬきは背中中大やけどをして、うんうんうなりながら、まっくらな穴の中にころがっていました。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大やけどはどうしたらなおるだろう。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院にいま十九になる少年が大やけどをして、泣き叫んでいる。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで赤チンをぬられ繃帯をしてくれましたが、後で、わたくしが近所の医者で治療を受けた時、医者も、大やけどに直接赤チンに繃帯とはと、その手当の粗雑さにあきれていました。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その三　精神病診断書",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに――あの古い鏡も大やけどサ。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすこしでわたしは大やけどをするところでしたよ。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
