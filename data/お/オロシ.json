[
  {
    "uuid": "75218845-aec1-5925-bcd6-9cfaec1377d4",
    "entry": "下ろし",
    "reading": {
      "primary": "おろし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞",
