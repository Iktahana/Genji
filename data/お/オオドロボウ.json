        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "河内山宗俊だつて大泥棒だァなァ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "きめてしまって、私は、大泥棒のように、どんどん歩いた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五右衛門は、腹が立つやら、情けないやら、熱いやら、痛いやら、まるで精神状態が目茶苦茶にみだれてしまったが、しかし、この男は元来が虚栄心で固めて日本一の大泥棒になったくらいの男であったから、さすがに燃え残りの自尊心を取り戻して、「やいやい、野郎共、何を笑うておる。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬上の詩わが大泥棒のために投繩を投げよわが意志は静かに立つその意志を捕へてみよ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔馬、たてがみもまだ生えた許り、可愛い奴に私はまたがる、私の唯一の乗物、そいつを乗り廻す途中にはいかに大泥棒といへども風邪もひけば女にもほれる、酒ものめば、昼寝もする、すべてが人間なみの生活をする。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私の大泥棒の仕事は馬上で詩をつくること、先駆を承はること、前衛たること、勇気を現はすことにつきる。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが友よ、戦へ、敵のもちものは豊富だぞ――、ぬすめ、それぞれ大泥棒の襟度を現はせよ、仔馬の集団、赤きわが遠征隊、捕吏の追跡、閃めくカギ繩マントでうけよ、マントが脱げたら上着でうけよ、上着がぬげたら素裸だ、鞍が落ちたら裸馬だ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが大泥棒の詩人たちよ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、これまでもあったことなので、あの大泥棒の色魔の餌食になっておられる、この奥さんがかわいそうで、じっとして聞いておれなくなったものですから、ちょっと口をきこうと思って出かけて行ったのです」「それからどうしました」「実にあきれた奴です。",
              "citation": {
                "source": "誰が何故彼を殺したか",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「塚をあばくっていうのだから、大泥棒かと思ったら、今度は歴史をあむんだそうだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と恐ろしい声で、「あっしは大泥棒でございますよ」「そう」とちっとも驚かない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく、大泥棒などは、小さな罪を白状して、監獄へ入れてもらい、人殺しの罪をまぬがれるという話ですが、私は、人殺しをしたら、病院へ駈けこむに限ると思うのです。",
              "citation": {
                "source": "按摩",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察から楼主へ、楼主から朋輩へ――、『みどりさんのあのお客は、大へんな大泥棒だって、ああこわい、こわい。",
              "citation": {
                "source": "ある遊郭での出来事",
                "author": "公娼存廃論者への参考資料としての実例",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という大泥棒だろう！",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒険大泥棒　その繁華な交叉点で吾輩がぶつかったのは、ちょうどその助からない種類の貴婦人だった。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『莊子』の盜跖篇に據ると、孔子が大泥棒の盜跖を説諭に出掛けた時、盜跖は人肉を肴に晝食を取りながら、孔子を恫喝して、疾走歸。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸を名打ての大泥棒が、大川屋さんの、塀際にいたとかいうことで、いやもうこの界隈、やかましいことでござりました」　水ッ涕を啜りながら、闇太郎の後姿に、眼が触れたか触れぬか、「とかくこの頃は、物騒な市中の形勢――お互に、苦労が多いな。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大捕物がありやしてね」　と、老人は、水ッ涕を啜って、目を輝かして、「といったって、手も足もないような手先衆が、翼の生えている大泥棒を追っかけたんですから、捕まりっこはありませんよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で大分、燗酒は、売れましたがね」「ははは、――それじゃあ、その大泥棒が、とっつぁんにはいい恩人だったじゃねえか――」　闇太郎は、のんびり笑って、樽にかけた片足を、片一方の股の上に組むのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、鼻をひょこつかせるようにしながら、この磊落な大泥棒は、そのままいいほどの間合をおいて、雪之丞の乗物を跟けはじめた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼の渡世がら大泥棒につきあっておくのも、いつかは屹度芸の上でも役に立とう。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見りゃあ、おまえさんが、たとい、どんな秘密に苦しんでいても、はるばる遠い、東の都で、だしぬけにあった赤の他人、しかも大泥棒から、なにもぶちまけて、胸の中を見せてくれと頼まれても、すぐに、べらべらしゃべるわけにもいかねえだろう。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「矢っぱり、このおれも、いくら素性を隠そうとしていても、あらそわれねえものがあるのかな」　と、闇太郎は両手で、顔をつるりと撫でるようにして、「おれが、おまえの身の上を、根ほり葉掘り聞くのは、なる程、無理かもしれねえが、おれの方は、もうとっくに、大泥棒と知られてしまっているのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、長二郎の――今自来也と呼ばれた大泥棒のかせぎより、お初の方が、ぐっと良いこともあった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はな、大変な大泥棒だ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし、それからが大変で『金がなければこそこの恥辱を受ける』とそのお侍さん、その晩大屋さんの家へ強盗にはいって、大金を奪いとったのを手始めに、大泥棒になったそうです」　　　　風呂の中の人形「泥棒に！",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……昨夜、沼田様のお牢を破りました三国峠の権という大泥棒が……」「あッ」　と松乃は起き上がった。",
              "citation": {
                "source": "猿ヶ京片耳伝説",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんも……」「王朝時代の大泥棒、明神太郎から今日まで、二百人に及ぶ泥棒の系図、それから不思議な暗号文字――道標、畑の中、お日様は西だ。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは妾は座を外し」「うん、そうさな、では少しの間、座を外して貰おうか」「はい」と云って出て行くお米、主人庄司甚右衛門はスルスルと前へ膝行ったが、「客人、いやさ勾坂甚内、大泥棒にも似合わねえドジな真似をするじゃねえか」　両手を袖へ引っ込ませると、バラバラと落ちて来た小判｜幾片。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
