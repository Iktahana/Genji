    "definitions": [
      {
        "index": 1,
        "gloss": "magnanimity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "悪い癖だが、無くて七癖というから、まあ大目に見てやるんだね。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば或る時、大目玉を引ン剥いて、毛剃が白眼※した百萬の唐船も斯くやと許り。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫はそれを涼しいもののように眼を細めて恍惚と眺め入っていたが、突然野太い男のバスの声になって「そりゃ、貝原さんはいい人さ、小初先生と僕のことだって大目に見ての上で世話する気かも知れませんさ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ちっとぐらいのことは大目に見てやる方がいいぜ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、情夫でもこしらえたとかいうような浮いたお話なら、おっしゃる通り、わたくしも大抵のことは大目に見て居りますけれども、どうもそれがまことに困りますので……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に似あわない大酒は、こういう商売の者として大目にも見られたのであるが、そのほかに誰にもゆるされないのは、かれの手癖の悪いことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人同志で大目に見られた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの消息を見抜いている×××は、表面やかましく云いながら、実は大目に見のがした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなやつもめったにゃねえよ、往来の少ない処なら、昼だってひよぐるぐらいは大目に見てくれらあ、業腹な。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」田園紳士二、「まあまあ、あんな子供のことですからどうか大目に見てやって下さい。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違うて大公儀の耳にでもそげな事が入ったなら、直ぐさま、黒田五十五万石のお納戸の信用に差響いて来るやら知れぬ話じゃけに、成る限り大切を取って極々の内密に、しかも出来るだけ速よう下手人を探し出せと言う大目付からの御内達で、お係りのお目付、松倉十内｜様も往生、垂れ冠って御座る。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きにもっともな話……」「……又、大目付様からの御内達で、どのような場合でも蔵元屋の内幕に立入って、蔵元屋の信用に拘わるような事を探り立てしてはならぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体大目付の注文が無理と思うが」「ハハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十二、十三と三日も経っとるのに下手人がわからんとは余りにも手｜緩いちゅうて、大目付から矢の催促じゃ」「ふうん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "上役と言うものは下役の苦労を知らんのが通例じゃが……」「……と言うのが……何でもその日田の御金奉行の野西｜春行という若侍が、あの騒動の起って以来、毎日、御城内の大目付、川村｜様のお役宅に押しかけて来て、この騒動がいつまでも片付かねば蔵元屋の信用にかかわる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に眼に物を見せてくれようで……」「その上に、これも松倉どんから聞いた話じゃが、あの蔵元屋の後妻が野西の尻に付いて、場所もあろうに大目付の役宅へシャシャバリ出て『可愛い娘を祝言前に殺されて妾ゃ行く末が暗闇になりました。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十五万石の大目付、丸潰れと来たなあ」「それでももしや、お熊の縁談から起った意趣、遺恨じゃないかと思うて、襟半の方へ探りを入れてみると、花婿の半三郎も、今は隠居しとる父親の半左衛門夫婦も、神信心の律義者という評判に間違いないらしい」「それは毛頭間違いない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの蔵元屋は存じてもおろうが当藩の御用金を扱うておる者じゃけに、何事も大目に見ておったのでな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御家老様、大目付殿、お納戸頭などと十分に御打合わせを願うた上で、お指図を受けねばならぬが……しかし……」　と十内は無念そうに唾液を嚥み込んで、眼をギョロリと光らした。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら大目付様がウロタエさっしゃっても、手がかりも足がかりもない立派な人間に疑いをかけさっしゃる筈はないが……扨は松倉十内がうろたえたかな……」「ええッ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりあえず御差紙は大目付様からの御状箱に入っておりましたか……」「さあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大目付様にも何にも生まれて初めて見る御状箱で御座いましたけに、よくわかりませなんだが、お先方様のお名前は渋川様と御座いましたが……渋川ナニ吾様とか……」「エッ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田藩の大目付様に先手を打たれて、今頃はボンヤリしておる事と存じまするが……この後始末はいずれ貴方様へかかって来る事と存じまするが……」　半三郎はもう腰が抜けたように呆然となっていた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先、大目付様が、日田のお金奉行の手先とは言え歴とした公方様の御家来の野西春行を、どのような風に処置さっしゃるか、お納戸頭が、蔵元屋の帳面の大穴をどう誤魔化さっしゃるかが、日本一の面白い見物で御座いましょうが、それは取りあえず貴方様の御決心には拘わりのないこと……悪い事は申しません。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "痳疹の神様とかけて大目付と解く。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその野西から取上げた調書と、証拠の風呂敷を松倉様の手から差出いたら、大目付では大層なお喜びで、松倉さんは直ぐに御加増の沙汰と聞いた」「ヘエ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時は艦内の生活万事が平常よりか寛かにしてあるが、この日はことに大目に見てあったからホールの騒ぎは一通りでない。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあこのくらいな横着は先生にも大目に見て頂くさ」　麒麟児といわれて十四の歳から新日本音楽の権威である千歳の父のもとに引取られ、厳しく仕込まれた慶四郎は、青年になるに随ってめざましく技倆を上げた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、さとったところを「一生参学の大事｜畢れり」（生涯の修業の大目的が達せられたということ）とか、「桶底打破」（迷いの桶の底を抜くということ）とか言って、ひとまず人生の疑問が片付いた形容をいたします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひしひしと花ふだの響がするのを、保養の場所と大目に見ても、好いこととは思わなかったが、時にこそよれ頼母しい。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
