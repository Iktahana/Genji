          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」葉藏は、おどけものらしく眼をくるくると丸くして言ふのである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鹿はよほどおどけもののようでした。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鹿はよほどおどけもののやうでした。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」黒ずんでいる唇をおどけものらしくちょっと尖らせて、コップのビイルをほとんど一息に呑んでしまった。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白、カナリヤ、四十雀、鶉に文鳥に黒鶫、鳥もいろいろあるなかにおかめ鸚哥はおどけもの焦れて頓狂に啼きさけぶ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "目白、カナリヤ、四十雀、鶉に文鳥に黒鶫、鳥もいろいろあるなかに、おかめ鸚哥はおどけもの、焦れて頓狂に啼きさけぶ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからおどけもののいるかが、とんぼがえりしたり、大きなくじらが鼻のあなから、しおをふきだして、そのへんいちめんに、なん百とない噴水がふきだしたようでした。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそこに「キューピーのマザア」が（私があのおどけもののキューピーを部屋に飾つて置く所から、院長はいつもたはむれに私をかう呼んだ。",
              "citation": {
                "source": "嘘をつく日",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "南さんは私によく、「私の府会議員の叔父さんはおどけものですよ。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどけものの鳥は、ガンたちが道に不案内なのを見てとりますと、さかんにガンたちを迷わせようとします。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとりの少年は、少年探偵団の団員で、小学校六年生の野呂一平君という、おどけものの、おもしろい少年です。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
