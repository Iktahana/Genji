        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "友人の目にも、俗人の目にも、ともに大人しい人といふ印象を与へて、富永は逝つた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の目にも大人しい人として映つた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "港の市の秋の日は、　　大人しい発狂。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃某氏のために揮毫した野菜類の画帖を見ると、それには従来の絵に見るような奔放なところは少しもなくて全部が大人しい謹厳な描き方で一貫している、そして線描の落着いたしかも敏感な鋭さと没骨描法の豊潤な情熱的な温かみとが巧みに織り成されて、ここにも一種の美しい交響楽が出来ている。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし細君はごく大人しい好人物だというので近所の気受けはあまり悪い方ではなかったらしい。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、三匹の大きい方の亀が一番小さい大人しい亀に、お前一走り行って傘を取って来いと言うと、小さい亀が言うのには、おれが傘を取りに行ってる間、おれの珈琲飲んでしまう積りやろ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまにはこういう大人しい娘の肌に、思う存分針を入れんと、淋しゅうて仕様ない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木之さん、あんたは大人しいから、たとい五十銭でも貰えば貰っただけ家へ持って来るからええけど、うちの人は呑ん兵衛で、貰ったのはみんな飲んでしまい、まだ足らんで、持っていった銭まで遣ってくるから困るよ。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "気心の好い平生大人しい人でありますから、私共始め御主人も、かれこれ気を揉んでおりますけれども、どこが痛むというではなし、苦しいというではなし、労りようがないのでございますよ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京ちゃん、やけに大人しいね。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　日頃大きな声も出せぬくらい大人しい北山には、ついぞこれまでなかった狂暴なその表情は怒りに逆上しているように見えたが、しかし、それは憤怒というより、むしろ北山の恐怖から出たものだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "春ちゃんは無口な大人しい子供で、成績もよく級長であったから、やはり女の方の級長をしている雪子という蒼白い顔の大人しい娘を「おれの娘」にしていたが、思わず、「うん」とうなずいて、その日から安子の「好い人」になってしまった。",
              "citation": {
                "source": "妖婦",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の妻はすこぶる大人しい女だった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人しい青年で、親にも告げずに身に佩びては悪かろうと、豎牛を通じて病父にその名誉の事情を告げ玉環を見せようとした。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガクラオ部落のギラ・コシサンは大変に大人しい男だった。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在年寄夫婦が商売しているのだが、土地柄、客種が柄悪く荒っぽいので、大人しい女子衆は続かず、といって気性の強い女はこちらがなめられるといった按配で、ほとほと人手に困って売りに出したのだというから、掛け合うと、案外安く造作から道具｜一切附き三百五十円で譲ってくれた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこうしたいわゆるマルチメディア絡みの技術に関しては、標準を素直に集めるという大人しい姿勢にソニーが留まることはない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "安斎は大人しいが気の利いた男で、霽波と一しょには騒がないまでも、芸者と話もする。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝彦は白痴ではあったが、美奈子｜丈には、やさしい大人しい兄だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、若杉さんは、今まで被告函の中に畏まっている大人しい窃盗や強盗や殺人犯なら、幾人見たかわかりません。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今宵若杉さんの前に立っている本当の泥棒は、そう大人しい人間ではありません。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質の大人しいおくみは、上に立つ女中や、いろんなところに気くばりばかりして、辛いうるさいことが多かつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、不意に自ら耻じると、主人に会った犬のように、私は大人しい表情に戻り、それから静かに処女の方を振り返った。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝彦は白痴ではあつたが、美奈子｜丈には、やさしい大人しい兄だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此｜兄は自分が豁達である丈に、妹の大人しいのを可愛がつてゐた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から偉い偉いということを速水君が言われましたが、貴方がたの方が遥かに大人しい、能く出来ていると思います。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く気の小さい大人しい者である。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは品の宜い、大人しい絵でした。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮気っぽい利国は直きに、大人しい許りで外から帰っても嬉しいやうな顔もして見せぬ志津に厭きはじめた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草を日本趣味といふ意味での、おとなしい閑雅さから、伊香保を日本趣味といふのは適評である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
