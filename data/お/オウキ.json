[
  {
    "uuid": "67ac19e5-bb31-5ecb-96d5-4bf2db846d64",
    "entry": "嘔気",
    "reading": {
      "primary": "おうき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
