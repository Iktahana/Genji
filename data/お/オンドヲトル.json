      {
        "index": 1,
        "gloss": "to take the lead (of a group of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（私――と――）と、好い声で一人の女が音頭をとる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「辰さん、お前音頭をとるンだぜ」「※、乃公が音頭とるべい。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か一人が音頭をとる。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、いい笛の音色や、小さならっぱの音や、それに混じって、歩調を合わし、音頭をとる太鼓の音が起こって、しんとしたあたりが急ににぎやかになりました。",
              "citation": {
                "source": "雪の上のおじいさん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと云つて先頭に立つて賑かに音頭をとるのではなく、むしろ黙々として小人数で沢歩きをするといつた風であつた。",
              "citation": {
                "source": "夜の鳥",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "チビの鮎子さんが、音頭をとることになって元気よく立ちあがったが、なんというのだったか忘れてしまった。",
              "citation": {
                "source": "キャラコさん",
                "author": "雪の山小屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホントから言やあ、金太が音頭をとるんだがな、なあ金太。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても、歌の音頭をとる十八九の娘と、踊のリーダーになつて居る、十六七の娘の非凡さは大したものでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれが音頭をとるともなく、期せずしてみんなの両手が、高く空にあがりました。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこで、もう一騒ぎ騒ぎましょうよ」　麗子が音頭をとると、残る一同それに賛成して、裸体のまま、赤と白との男女が一団を為して小山へと駈け上って行った。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（そうだ、馬関から乗った春日丸で――）　思いだしたが、空とぼけて、「深川だよ」　次の音頭をとると、「こらっ、屋根ぶねの提灯にせいっ」　また、呶鳴る。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こよいの勝ち軍はひとえに貴軍の謀略と働きにあるのですから、玄徳殿が音頭をとるべきです」と、曹操も譲りあう。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
