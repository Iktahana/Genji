    "definitions": [
      {
        "index": 1,
        "gloss": "(your) words",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "正午に、おいで下さるように、という小坂氏のお言葉であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対に今の新人はその基本作因に自信がなく、ぐらついている、というお言葉は、まさに頂門の一針にて、的確なものと思いました。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の上に俯伏して居れば雀のお宿に行けるなんて、あははは、馬鹿な事だが、でも、どれ、それではひとつお言葉に從つて、ちよつと行つてまゐりませうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反對に今の新人はその基本作因に自信がなく、ぐらついてゐる、といふお言葉は、まさに頂門の一針にて、的確なものと思ひました。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくて、若し私がうまく行かないやうでしたら、貴方がそのお作品や、そのお言葉や、貴方がその「主」であるところの永遠なお力のすべてでもつて、私を御助力くださつたやうに、私の妻をも御助力くださいますやうに。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "案ずるに、「ダス・ゲマイネ」の註釋などせよとの親切心より發せしお言葉ならむ。",
              "citation": {
                "source": "「地球圖」序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お言葉に甘えて老僕イシャク・バイをつかわす。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」あなたのお言葉、わすれていませぬ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "このつぎには、五十銭でも五銭でも、お言葉にしたがいますゆえ、何卒、いちど、たのみます。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しい才能と思われるから、とか何とか、恥ずかしくて、とても私には言えませんけれども、なんだか、ひどく私を褒めて、このまま埋らせてしまうのは残念だ、もう少し書かせてみないか、発表の雑誌の世話をしてあげる、というような事を、もったいない叮嚀なお言葉で、まじめにおっしゃっているのでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで……その父の死にました理由がわかりますようなお言葉を、先生に一筆書いて置いて頂きましたならば……その子供たちの成長後に……」　あとは声が曇って、わからなくなった。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "願わくは一合わせ見参仕りたい」「イヤ、これはお言葉までもないこと。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎はなお言葉なくながめ入りぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら、九頭竜の野郎、それは耳よりなお話ですから、私もひとつ損得を捨てて乗らないものでもありませんが、それほど先生がたがおほめになるもんなら、展覧会の案内書に先生がたから一言ずつでもお言葉を頂戴することにしたらどんなものでしょうといやがった。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔とは神様の御恩を忘れたばかりでなく、お互いにあやめ合ったり、傷け合ったりする時の、人間の心をさして云うものなのだよ」　お祖父さんは、なお言葉を続けてトシオの疑いを、みんな除けてやろうとしました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗人　――わたくしはあなたのその情深いお言葉に憎しみを持つようになったものです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは今朝あなたのお言葉を聞いて、現世の愛の果敢ない事も本当の愛の世界の不壊な事ものみ込めました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお困った事には今朝のお言葉を聞く迄は、わたくしの全部が統一してまっしぐらにあなたを恋して居たのに較べて、あのお言葉を聞いた後はわたくしの心の半分は熱し、半分は静かに湛えてじろじろわたくしを眺めるのです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに今迄わたくしが望んで居たあなたは、ただ純で美しい女のあなたであったものが今朝あのお言葉を伺った後はあなたが気体のような超人間的なものに見做されて仕舞って、あなたの存在は破滅のない確さにはなったが、手にも取られず感情にも引きかかって来ない、わたくしにとってまことに仕末の悪いものになりました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――そのお言葉を聞くにつけ、いよいよあなたがおいたわしゅう存じます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――おお、何という嬉しいお言葉、さ、阿難さま。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――只今の頼母しきお言葉に引き換え、そのお気色はどうした事で御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が只今の打って変った御様子、すべてを与えて私を充たして下さろうとなさる御志し、その情のお言葉の端から、み仏の光がわたくしの心に射して、わたくしはもう、勿体ない気持ち許りなので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　（取次ぐ）お女中、可恐い事はないぞな、はばかり多や、畏けれど、お言葉ぞな、あれへの、おん前への。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　えっ、えっ、それは決して正しき神のお言葉ではない。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顧みもせず島野は、己ほどのものが、へん、愚民にお言葉を遣わさりょうや！",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シグナレスさん、それはあんまりひどいお言葉でしょう。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と語ると、夫人も微かにうち點頭き、俯伏して愛兒の紅なる頬に最後の接吻を與へ、言葉やさしく『日出雄や、お前は今此災難に遭つても、ネープルスで袂別の時に父君の仰つしやつたお言葉を忘れはしますまいねえ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』といふと大佐は大に喜び『實は其お言葉を待つて居つたのです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おことばまことに畏くて、何とお答へいたしていゝか、とみに言葉も出でませぬ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
