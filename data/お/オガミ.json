    "definitions": [
      {
        "index": 1,
        "gloss": "male god",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「そして、……」　声も朗かに、且つ慎ましく、「竜神だと、女神ですか、男神ですか。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまたお二人、そのつぎには男神女神とお二人ずつ、八人の神さまが、つぎつぎにお生まれになった後に、伊弉諾神と伊弉冉神とおっしゃる男神女神がお生まれになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの五人の男神は私の玉飾りからできたのだから、私の子だ」とおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大空の神々の中でいちばんちえの深い思金神と、いちばんすぐれて力の強い手力男神とをさらにおつけ添えになったうえ、「思金神よ、そちはあの鏡の祀りをひき受けて、よくとり行なえよ」とおおせつけになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神二人に挑まれて、嫁せずして終りぬと云ひ傳ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（アクテオンは、希臘の男神の名なり、女神ヂアナを垣間見て、罰のために鹿に變ぜられ、畜ふ所の群犬に噬まる。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前には、鉄の冠を戴いて、白い顔に黒い髯を勢よく生やし、紺青の着物を着た立派な冬の男神と、緑色の髪に花の冠を戴いて、桃色の長い着物を着た春の女神とが座わっています。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神の如き岩手山と、名も姿も優しき姫神山に挾まれて、空には塵一筋浮べず、溢るゝ許りの夏の光を漂はせて、北上川の上流に跨つた自然の若々しさは、旅慣れた身ながらに、吉野の眼にも新しかつた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神の如き岩手山と、名も姿も優しき姫神山に挾まれて、空には塵一筋浮べず、溢るゝ許りの夏の光を漂はせて北上川の上流に跨つた自然の若々しさは、旅慣れた身ながらも、吉野の眼には新しかつた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノトス（Notos）（注四）は女神と男神の恋濃かに生みし子なればこそ。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "また岩手紫波地方に行なわれている口碑ではこの山は男神だとされている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "往古、岩手山（男神）と姫神山（岩手郡）は夫婦であったのに早池峰山が姫神山に横恋慕して、あるとき女神を欺いてわがものにした。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "伎佐貝比賣の命といふ妙齡の女神が愛する男神との間に王子を設け隱れた産家として選んだのがこの海岸の洞窟であるといひ傳へられてゐる。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "二流、三流の通俗画家が、凡庸な構図とあり来りな解釈とで、神話の男神、アポロー、パンまたは、キリスト教の聖徒などを描いた他、或る女流画家の特殊な稟性によって、ユニクな属性を賦与された男子の肖像が在るだろうか。",
              "citation": {
                "source": "わからないこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向にだけは、男神が甦生しても大して意外でない悠々さがある。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄幹は透谷、藤村などのロマンティック時代を、芸術至上主義の気よわなロマンティシズムであるとして、『明星』を彼のいわゆる「荒男神」のロマンティシズムに方向づけた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堺の菓子屋の娘として、『文学界』をよみ、やがて『明星』にひかれて、『みだれ髪』をあらわした（一九〇一）与謝野晶子は、女として人間として彼女のうちに燃えはじめたロマンティシズムの性格が、鉄幹の「荒男神」ロマンティシズムと、どのようにちがうかということは自覚するよしもなかった。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の眸はまさしく遠い水平線の向こうの国と、恋し男神との夢を追っているようであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう晶子の情熱と自覚とはあくまでも感情的なものであったが、その特質を、鉄幹の「荒男神」的ロマンティシズムの根にあった現実性との結合で観察すると、「やは肌の」の歌も「罪おほき」の歌も、今日の読者には一種のいじらしささえ加えてよみとれて来る。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神は萌黄の羅を著流して手に短き杖を持ちながら透明なる卓にもたれ、「光は居ずや。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は用意とゝのひたる旨を答へ、さらばとて男神立ち上らんとし給ふ時、白銀の屏風に吹かるゝ如く開きて、やがて女神は身を現し給ひぬ。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝしばし樣子見給ひし後歩み寄りて男神に向ひ、「何處にか行き給ふ、二人を伴れて。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "と玉の如き聲に少し角立てゝのたまへば、男神も稍※ためらひつゝ、「今しも人間界に遊ばんと思ひて出で行くなり。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神は女神をなだめて、「さな怒りなせそ。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言ひ殘して男神は二人の神の子を從へ立ち出で給ひぬ。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出でゝ見まはしつ男神、「人間界は暗し。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神は光と匂に導かれて闇の中を下り給ふ程に森近くなれば、先に行きし光は少し引き返して、「はや到り著きぬ。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神、「少女は來てありや、潜に下りて見よ。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたたちと一緒にお日さまをおがみたいと思ってです。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と身を震わし、おがみ手をしかと合せて、「こうだから、よ、よ、三吉。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
