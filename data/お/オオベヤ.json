    "definitions": [
      {
        "index": 1,
        "gloss": "large room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "江口冴子、大部屋だが、さっき紹介された女優達の中で一番印象に残っていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちぇッと舌打ちしたのは大部屋の俳優たちだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "傘をさしてとぼとぼ夜更けの雨の道を一人帰って行く冴子の姿は、いかにも大部屋の女優の稽古帰りめいていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも大部屋ならかえって連立って帰る友達があってもいい所かも知れない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れにしても、冴子は昨夜の、ふとうらがれた大部屋女優の感じはなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大部屋の女優に対する劇作家の態度にしては、一寸軽軽しすぎるくらい、丁寧だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を上り下りする人間は、大概顔見知りの店員たちで、それは確に、三階の寝泊りの大部屋へ通うものであって、昼は店に行っていてそこには誰もいない。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角い大部屋だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "開けると、地下室とも穴蔵ともとれる大部屋に出た。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "をぢは我を抱き卸して、例の大部屋の側なる狹き一間につれゆき、一隅に玉蜀黍の莢敷きたるを指し示し、あれこそ汝が臥床なれ、さきには善き檸檬水呑ませたれば、まだ喉も乾かざるべく、腹も減らざるべし、と我頬を撫でゝ微笑みたる、その面恐しきこと譬へんに物なし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四層屋の背後なる大部屋は内より戸を鎖しあるを以て、更にその戸を破壊したり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云って、遊び人にしちゃあ野暮に出来ているし、まあ、屋敷の大部屋にでも転がっていたような奴ですね」「折助か」と、半七はうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは下谷の小森という与力の屋敷の中間で、ふだんから余り身状のよくない、方々の屋敷の大部屋へはいりこんで博奕を打つのを商売のようにしている道楽者であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの室にはわたしと外にだれか一人、隣の室には婦人連、そして向かい側の大部屋にはその他の大勢という割当てであったが、その大部屋はまるで動物園のおりよろしくで、皆が鉄ごうしにつかまって怒鳴る、わめく、笑いくずれるの大騒ぎであった。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時にも大部屋の中間どもが清水山探検に押し出そうとしたのであるが、余り騒ぎ立てるのもよくあるまいという部屋頭の意見で、一旦はそのままに鎮まったが、大入道や九尾の狐の噂がだんだんに高くなったので、彼等はもうたまらなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうして、どうしたえ」「なにしろ大部屋の連中ですからね、大きな犬を一匹連れて来たんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤代様のお屋敷の大部屋で毎日賭場が開けるもんですから、長作はその方へばかり入り浸っていて、仕事にはちっとも出ません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "化け銀杏",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房はことし二十歳ですが、その兄貴の米吉というのは商売無しの遊び人で、大名屋敷や旗本屋敷の大部屋へはいり込んで日を暮らしている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主あがりの良住と一緒に押込みを働いて、ふところは相当に重い筈ですから、どこかの大部屋へでも遊びに行って打ち殺されたか、ごろつき仲間にでも狙われたか、それとも別に仔細があるのか、ともかくも誰かに打ち殺されて、死骸を王子辺のさびしい所へ捨てられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たしてそうだとすれば、米吉という奴は博奕を打つので大名屋敷の大部屋へはいり込む関係から、こいつが先ず誰かに買収されたものと想像されます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやでかなりにふところを肥やした筈ですが、悪運尽きて忽ち滅亡、殺した者は大部屋の仲間でもなく、ごろつき仲間でもなく、ひょっとすると例の屋敷の連中が秘密露顕の口を塞ぐために、急所の当身でも喰わせたかも知れません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、あの辺には屋敷が多いので、わっしも大部屋の奴らを相当に知っていますが、この間からいろいろの噂を聞いていますが、噂という奴はどうも取り留めのないもので……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの俳優ジヤツク・バリモアが、ある時楽屋の大部屋をのぞくと、そこに下廻りの俳優達がごたごた押し並んでゐて、謎々のやうな遊びをして、きやつ／＼と陽気にはしやいでゐるのを見出した。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……所謂大部屋連、下まわりっていうようなものは、存在してるのかしら。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大部屋、下まわりにしたって、大家連と同じ芸術労働組合員だもの。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋は二階をあがったりおりたり、特有な臭をおしわけてゆくような処で、日本でいう大部屋という感じだった。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーイも中国人だから大部屋への遠慮もあると見え、卓を叩いて呼んでもなかなか日本人の部屋へ這入って来なかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈は中国人のいる大部屋の方を眺めながら、いつの間にかまた矢代の日ごろの考えの中に入り込んでいる自分を発見して、いや、おれのはまた矢代とは別だ、共同の一線を発見することだと強いて心中思おうとするのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣劇の俳優、レビューガール、どんな大部屋の大根役者でも大井広介にきけばたちどころに名前が分る。",
              "citation": {
                "source": "大井広介といふ男",
                "author": "――並びに註文ひとつの事――",
                "note": "青空文庫"
              }
            }
          ]
        }
