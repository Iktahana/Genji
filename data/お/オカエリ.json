        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "５向ふに、水車が、見えてゐます、　　苔むした、小屋の傍、ではもう、此処からお帰りなさい、お帰りなさい　　僕は一人で、行けます、行けます、僕は、何を云つてるのでせう　　いいえ、僕とて文明人らしくもつと、他の話も、すれば出来た　　いいえ、やつぱり、出来ません出来ません。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒヨツト葉巻を手に取り、マークをみてゐる）女の声　（ドアの辺りより）お帰りなつてるのね。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻や女中たちが、玄関の畳に列び坐って、『お帰り遊ばせ』とお辞儀をする。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田さんが郷里へお帰りになりましたので、私共も心細く存じておりましたところ、昨年の暮に、大隅さんから直接、私どものほうへお便りがございまして、いろいろ都合もあるから、式は来年の四月まで待ってもらいたいという事で、私共もそれを信じて今まで待っておりましたようなわけでございます。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰りの日までは、どんなに親しい人にだって手をふれさせずに、なんでも、そっくりそのままにして置かなければ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、氷山にぶっつかって船が沈みましてね、わたしたちはこちらのお父さんが急な用で二ヶ月前一足さきに本国へお帰りになったのであとから発ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえね、ひょっと妾と入れ違いに帰って居るかも知れないから」　「妾もう失礼しますよ、源兵衛さん、御邪魔しました」　「あ、お帰りかね」　「さようなら」Ｓ＝茶店の表　お勘婆さん、帰って行く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さッ早くお帰り」　「おッ母、俺ァ今一寸」　「何を愚図々々してるんだい。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰りと云ったらさっさと帰るんだよ」　「困ったなァ」Ｓ＝茶店の表で　次郎長と石松。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、お客様がお帰りだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次子供の頭を撫でて「いい子だから早くお帰り」と言い捨てて去って行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次にさあ早くお帰りと言われて何度も振り返って笑ったり手を振ったりし乍ら長屋の奥へ消えて行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が「お帰り下さいまし」ときっぱり断わる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江に、Ｔ「心配せずに家へお帰り」　なりひらも、Ｔ「俺達が引受けた以上悪い様にはせぬ」　と言って半次に娘を送って行くように言う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「少しも早くお帰り下され」　と頼むのを、　冷笑浮べてなりひら、Ｔ「ところで」　俺も、　えッ、と左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこれ早く致せと叱りとばし、さて、Ｔ「では早速お帰り下さりますよう」　なりひらが中々動かない。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには夜遅くお帰りなさるせいもあるでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時分お帰りなさるようでは、あなたは御保養にいらっしゃったのではございませんね。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならあなた、弟さんを直ぐに連れてお帰りなさいましよ。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お帰りなさいまし。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊っちゃんお帰り。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雪が柔らかになるといけませんからもうお帰りなさい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ゆるゆる歩いて明るいうちに早くおうちへお帰りなさい。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰りになりましたらあなたの王様に海蛇めが宜しく申し上げたと仰っしゃって下さい。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷笑を浮べ乍ら、Ｔ「いいお湯が沸いてるよ」Ｔ「一風呂浴びてお帰りよ色男」　伊吉口惜し涙。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お帰り」姑はなにか呆けているような貌だった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなときスマ子女史は、彼女の「彼氏浮気もの」を待つあいだを英語の勉強をしたり寝台のうえで体操をしたり日本の作家の有名な小説を読んだりしているが「彼氏浮気もの」が、にこ／＼わらいながらかえってくれば、悦しくなって、なにしろ彼は可愛いいので、だがすこしばかり眼に涙をためて、――おかえり！",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あら、お早う、いつおかえり？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あしたは、まっすぐに家へおかえりなさいね。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
