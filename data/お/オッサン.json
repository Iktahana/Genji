    "definitions": [
      {
        "index": 1,
        "gloss": "middle-aged man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どや、おっさんが一つ仕込んだろか」「えっ……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おっさんとこイ、来たらいつでも仕込んだる。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前の掏摸になるネやったら、おっさんの云うことをきいたら、間違いない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっさんとこイ来たら、いつでもパンを食べさせたる」「おおけに……」「それから……」　と、にやりと笑って、「――刺青をしたる」「えっ……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日程経った頃だったろうか、千日前のお午の夜店で、夜店外れの薄暗い場所に、しかもカーバイト代を節約した一層薄暗い店を張っていると、おっさん一杯くれと若い男が前に立った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎もぽかんともしていられず、おっさん一杯といわれると、低声でヘイと返事し、兄の手つきを見習って、コップにあめを盛った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところが、おっさん、少々別条があるんですよ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっさんら見てみイ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そないべんちゃら（お世辞）せんでも、他あやん喧嘩したこと黙ってたるわいな」　そして、早く配ってしまわねば叱られるさかいと、駈け出して行くのを、他吉は随いて行って、「ほな、おっさんに夕刊一枚おくれんか」　その気もなく言うと、「やったかて、読めるのんかいな。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっさんら新聞見ても、新聞やのうて珍ぷん漢ぷんやろ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他吉の俥はどこの誰よりも速く、客がおどろいて、「あ、おっさん、そないに走ってくれたら、眼エがまう。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君ちゃん、今晩はおっさんとこで一しょに寝よ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "種吉は高利貸の姿を見ると、下を向いてにわかに饂飩粉をこねる真似したが近所の子供たちも、「おっさん、はよ牛蒡揚げてんか」　と、待て暫しがなく、「よっしゃ、今揚げたるぜ」　と言うものの、摺鉢の底をごしごしやるだけで、水洟の落ちたのも気附かなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅宇しかえ屋のおっさんかて、こないだ流してる最中にひっくりかえりはったやないか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな棺桶に半分足突っ込んだおっさんと同じようにせんといて……。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はそれぞれ、おっさん、鯨や、とか、どじょうにしてくれとか粋な声で注文して、運ばれて来るのを寿司詰の中で小さくなりながら如何にも神妙な顔をして箸を構えて、待っているのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴ったくそわるいさかい、亭主の顔みイみイ、おっさんどないしてくれまんネいうて、千度泣いたると、亭主も弱り目にたたり目で、とうとう俺を背負うて、親父のとこイ連れて行きよった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに浜子は私がせがまなくても、あれも買え、これもほしいのンか、ああ、そっちゃのンもええなア、おっさん、これも包んだげてんかと、まるで自分から眼の色を変えて、片ッ端から新次の分と二つずつ買うてくれ、私はうろうろしてしまった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おっちゃん、うちおなかペコペコや」「おっさんもペコペコや。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミネちゃんが泣くと、おっさんまで泣きとなる」　しかし、なかなか泣きやまなかった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっさんが今おもろい話聴かしたるさかい、涙拭いて聴きや」　そして、小声で落語を語りだすと、ミネ子ははじめ面白そうに聴いていたが、しかし直ぐシクシクと泣きだした。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に、落語やれいうのは、葬式の日にヤッチョロマカセを踊れいうより、殺生やぜ」　言いながら、涕き声になると、ひしとミネ子を抱きしめて、「ミネちゃん、おっさんの子になるか」「なる。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺生だっせエ」　参ちゃんは思いだしたようにそう言ったが、べつに怒ってる風も見えず、「――花屋のおっさんにもあの雑誌見せたりました」「へえ？",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家のおっさんのガッチリして御座るのには呆れた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つの都松竹映画大船作品演出　川島雄三人物――中瀬古庄造庄平寿子矢野鶴三葉子新吉健介小谷初枝辻節子尾形清子蜂谷十吉夜店出しのおっさん船山上等兵江藤医学士大雅堂主人標札屋の老人他に、国民学校訓導、看護婦、子供達。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自分の家だ）新吉が家の前で繃帯をとっていると、夜店出しのおっさんが、車を曳いて帰ってくる。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新吉「おっさん、もう帰りか？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……我我も善は急げの方でな」夜店出し「そんならチョボチョボやな」新吉「ほな、おっさんもう夜店出せへんのんか」夜店出し「今どき夜店出してぼや／＼してられるかいな」葉子「もう雨の心配なくなったな」四人朗らかに笑う。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして、早く配ってしまわねば叱られるさかいと、駈けだして行くのを、他吉は随いて行って、「ほな、おっさんに夕刊一枚おくれんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
