        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "後日再び奥州から大軍の将として上洛する途上この宿に立寄り懇ろに母の霊を祭る、という物語を絵巻物十二巻に仕立てたものである。",
              "citation": {
                "source": "山中常盤双紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄としての價値要素は、武將プラス政治家の綜合天才であるけれども、尊氏は武將として、それほど大した軍略家でなく、いつも大軍を擁して戰ひながら、概ね負けてばかり居るし、政治家としての手腕も、家康や秀吉に遠く及ばない。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戰爭」「大軍叱咤」「壞滅の鐵道」「鯨」「腕」「腕」などは明らかに彼の目の前に展けた新しい視野を示してゐる。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、百万の大軍がいま戦争さいちゅうの曠野。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして征服者の大軍の通り去った野に落ちちらばった弾殻を拾うような仕事に甘んじると同じような事になりがちである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ聞かざる大軍器※　風のごとく來り。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に潜める大軍器※と言ふ樣な文句で、隨分奇妙な、恐らくは新派先生一派から税金を徴收に來さうな詩ではあつたが、月明に、風清きんだよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が潜心苦慮せる大軍器は遂に首尾よく竣成しましたらうか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十回　月夜の大海戰印度國コロンボの港――滿艦の電光――戰鬪喇叭――惡魔印の海賊旗――大軍刀をブン／＼と振廻した――大佐來！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹は大軍刀ブン／＼と振り廻し海賊船若し近寄らば吾から其甲板に飛移らんばかりの勢ひ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　＊　　　　　　＊　　　　　　＊　　　　　　＊　　　　　　＊　今から六百余年｜前の弘安年中に、元の蒙古の大軍が我が九州に襲って来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものすごい、大軍隊が、できあがりました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、大軍隊が、船に乗りこみました。",
              "citation": {
                "source": "わるい王さま（伝説）",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大胆不敵になり、無謀にもただ一人、門を乗り越えて敵の大軍中に跳び降りた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれなる平野の大軍は英將ウエリントンの一隊。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も景隆の器の小なる、能の功を成すを喜ばず、大軍の至るを俟ちて倶に進めと令し、機に乗じて突至せず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "景隆が大軍功無くして、退いて徳州に屯す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝｜大理少卿薛」］を遣りて、燕王及び諸将士の罪を赦して、本国に帰らしむることを詔し、燕軍を散ぜしめて、而して大軍を以て其後に躡かしめんとす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ってましたと計りに関白の方では、此の大石を取れば碁は世話無しに勝になると、堂々たる大軍、徳川を海道より、真田を山道より先鋒として、前田、上杉、いずれも戦にかけては恐ろしく強い者等に武蔵、上野、上総、下総、安房の諸国の北条領の城々六十余りを一月の間に揉潰させて、小田原へ取り詰めた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月は斎藤九郎兵衛が京都から浅野長政等の書を持って来て、いよいよ関東奥羽平定の大軍が東下する、北条征伐に従わるべきである、会期に違ってはなりませぬぞ、というのであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが秀吉の方は大軍堂々と愈々北条征伐に遣って来たのだ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に「見崩れ」というのは敵と対陣はしても、敵の潮の如く雲の如き大軍、又は勇猛｜鷙悍の威勢を望み見て、こいつは敵わないとヒョコスカして逃腰になり、度を失い騒ぎかえるのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "金七が還っての報告によると、猿面冠者の北条攻めの有様は尋常一様、武勇一点張りのものでは無い、其大軍といい、一般方針といい、それから又千軍万馬往来の諸雄将の勇威と云い、大剛の士、覚えの兵等の猛勇で功者な事と云い、北条方にも勇士猛卒十八万余を蓄わえて居るとは云え、到底関白を敵として勝味は無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三国の代の英雄の曹孟徳が、百万の大軍を率いて呉の国を呑滅しようとしつつ、「月明らかに星｜稀にして、烏鵲南に飛ぶ」と槊を馬上に横たえて詩を賦したのも丁度斯様いう夜であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが大軍であり、地理案内者である。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗が若しも途中で下手に何事か起した日には、吾が領分では有るし、勝手は知ったり、大軍では有り、無論政宗に取って有利の歩合は多いが、吾が領内で云わば関白の代官同様な氏郷に力沙汰に及んだ日には、免るるところ無く明白に天下に対して弓を挽いた者となって終って、自ら救う道は絶対に無いのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は山三の先登は此の翌年、天正十九年九戸政実を攻めた時だともいうが、其時は氏郷のみでは無く、秀次、徳川、堀尾、浅野、伊達、井伊等大軍で攻めたのだから、何も氏郷が小小姓まで駈出させることは無かったろう。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何程の事かあらん、一当てあてゝやれと、此方からも下野境まで兵を出したが、如何さま敵は大軍で、地も動き草も靡くばかりの勢堂しく、掻楯ひし／＼と垣の如く築き立てゝ、勢ひ猛に壮んに見えた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
