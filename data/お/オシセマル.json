        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "押し迫るにつれて店はだんだん忙しくなって来た。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "去勢牛、袋詰、乾草、ジプシイ、皿小鉢、百姓女、薬味麺麭、帽子――すべてがけばけばしく、五彩燦爛として、乱脈に、うようよと累なりあひ、入り乱れて、ぱつと眼の前へ押し迫る。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地間には人の子ひとり影を見せず、ドニェープルの水音だけが哀愁をもつて胸に押し迫る。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり僕は、鐘鳴器特有の唸りの世界を指して云うのだ」と法水は、押し迫るような不気味な声音で云った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、激しく押し迫る破倫な衝動のために、いきなり彼は、早苗の手を捉えてグイと引き寄せた。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かに口辺に漂わす一、二辺の微笑みから覗かれる、底の知れぬ偉大な力の海が冬子に押し迫る。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "十本あまりの毒刃は、ズ、ズ、ズと、趾先ですり寄る刺客たちと一緒に、二人の前後に押し迫る。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間逃げ退く足音がしたが、忽ち後方から押し迫る、十数人の足音がした。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去と現在が撓わにまで未来に押し迫る深い情趣である。",
              "citation": {
                "source": "探偵小説の芸術性",
                "author": "――文学のメカニズム――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや押し迫るように、僕のほうへ顔を向けながら、いったのである。",
              "citation": {
                "source": "幸福への意志",
                "author": "DER WILLE ZUM GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "アムラはしかし、その押し迫るような姿勢を変えずに、前と同じ重々しい抑揚でいいつづけた。",
              "citation": {
                "source": "ルイスヒェン",
                "author": "LUISCHEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
