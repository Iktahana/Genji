[
  {
    "uuid": "0fcf793f-19ad-5224-a546-fb33d630a4b3",
    "entry": "惜しむ",
    "reading": {
      "primary": "おしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
