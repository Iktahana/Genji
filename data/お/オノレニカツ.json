        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "己に克つといふことが微塵程もない。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は寺に往きて聖母の前に叩頭き、いかで我に己に克つ力を授け給はれと祈りて、さて頭を擧げしに、何ぞ料らむ聖母の面は姫の面となりて我を悦ばせ又我を苦めむとは。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者等は自己に克つ。",
              "citation": {
                "source": "色褪せた書簡箋に",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "客を逐ふの工夫は、只是れ己に克つなり、只是れ禮に復るなり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔譯〕眞己を以て假己に克つ、天理なり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇三　戰場に於て千々の敵に克つよりも、一の己に克つ人こそ實に戰士中の最上と云ふべけれ。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇四　己に克つを勝れたりとす、他の諸人に克つに非ず、自己を從へ、所行常に節制ある人の勝利には一〇五　神も健闥婆も亦魔羅も及び梵も、斯かる人の勝利には反抗する能はず。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "「剛いというのは、人に克つことではなくて、己に克つことじゃ。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "己に克つ、――聞いたことがあるだろう、己に克つって。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その己に克つことが、活人剣を握る人の心構えなんだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "己に克つというのは、自分だけの利益とか、名誉とか、幸福とかいうものをすてて、一途に国のため、世のため、人のためにつくそうとする心になることなんだ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、神よ、私が自己に克つ力を私にお与え下さい！",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
