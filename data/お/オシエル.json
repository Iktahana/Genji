    "definitions": [
      {
        "index": 1,
        "gloss": "to teach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "魔除鼠除けの呪文、さては唐竹割の術より小よりで箸を切る伝まで十銭のところ三銭までに勉強して教える男の武者修行めきたるなど。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの子規自筆の記念品は、子規の家から中村｜不折の家に行く道筋を自分に教えるために描いてくれた地図である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも子供だけにはこんないたずらをさせないように家庭や小学校で教えるといいと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震津浪の災害を予防するのはやはり学校で教える「愛国」の精神の具体的な発現方法の中でも最も手近で最も有効なものの一つであろうと思われるのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校や中学校で教える天文学では、大小無数の恒星もその一なる太陽も動かぬものとなっている。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに動いているものを動かぬなどと教えるのは不埒千万だと御咎めになる方があれば、それには次のような弁解をしなければならぬ。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時「オイ君の食ってるビフテキは一時間三十｜浬で走っているぜ」と教えるのは少々馬鹿げているではないか。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた、流転、無常を差別相の形式と見、空無、涅槃を平等相の原理とする仏教の世界観、悪縁にむかって諦めを説き、運命に対して静観を教える宗教的人生観が背景をなして、「いき」のうちのこの契機を強調しかつ純化していることは疑いない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論科学全体の綜合的歴史はとても教えることは出来ないが、ある事項に関する歴史でよろしい。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく簡単なことについて歴史的に教えることも幾分加味した方が有益だと確信するのである。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような点から考えると物理実験を授けるべき教員は、教える前に自分で十分にすべての実験を練習し、あらゆる場合に遭遇し、あらゆる困難を切り抜けて来なければならないかという疑問が起る。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校で物理学を教える場合に、方則の成立や意義や弱点を暗示するのは却って迷いを生じ誤解を起すという説もある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず講義講演によって人に教えるという事に興味と熱心をもっているそうである。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に教える事は極めて基礎的なところだけを、偏しない骨の折れない程度に止めた方がいい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教える能力というのは面白く教える事である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ反対に私は学校で教える理科は今日やっているよりずっと実用的に出来ると思う。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生に一般的な初歩の実験を教えるという案を立てたが、その頃まだ学生用の器械などは市場になかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから足ることを知る節制謙譲が生まれるであろう、と教える東洋風の教えがこの集のところどころに繰返して強調されている。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの一つだけにして他は割愛して、その代りその一つをもう少し詳しく分かるように説明した方が本当の「物理」を教えるためには有効でありそうに思われる。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体「教えるためには教えない術が必要である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も中学校で一々無理に教える必要はないと思われる。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教えるためには教えないことが肝心である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を見るべきか、それを如何に見るべきかということを教えることである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、教授の職責の大きな部分は学生を教える事である。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことから考えてみると、我国固有の国民思想を保存し涵養させるのでも、いつまでも源平時代の鎧兜を着た日本魂や、滋籐の弓を提げた忠君愛国ばかりを学校で教えるよりも、時にはやはり背広を着て折鞄でも抱えた日本魂をも教える方がよくはないかという気がしたのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして姉も弟も初めのうちは小学校に出していたのが、二人とも何一つ学び得ず、いくら教師が骨を折ってもむだで、到底ほかの生徒といっしょに教えることはできず、いたずらに他の腕白生徒の嘲弄の道具になるばかりですから、かえって気の毒に思って退学をさしたのだそうです。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義の現実がみんなにおしえるんだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、天文・地質・生物の諸科学が、われらにおしえるところである。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしもきみのためにはならない、茶釜の破片をしまってある場所は、もしぼくが殺されると、きみにおしえることができない。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場からは販売員がついて来て、使いかたをおしえる。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
