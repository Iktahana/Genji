        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これが又大のおめかしと來て、當世風の廂髮、白粉をべた／＼塗る。",
              "citation": {
                "source": "鑑定",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おめかしでもしろ！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のお化粧もやめてしまったが、その代りに夕方になると急にソワソワし出して、お湯に行ったり、おめかしをしたりして、まだ明るいうちに夕飯を仕舞うと、女中とチエ子を追い立てるようにして寝かした。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは決して、世の常の洒落者やおめかしやでなく、むしろ概してその反対であるけれども、その心の中の鏡に映して、常にイメージしている自分の姿は、永遠の美少年でありたいのである。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者になったからって、急におめかしをする必要もないが、こんな生気の無い顔は困る。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大層、おめかしだね。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとっくに死んでいたおきみ婆さんと同じようにお歯黒に染めていたその婆さんは、もと髪結いをしていて、その家の軒には「おめかし処」と父の筆で書いた行灯が掛っていたのだが、二三年前から婆さんの右の手が不随になってしまったので、髪結いもよしてしまったらしい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてたいへん慌てながら、傍に化粧をしてゐた、おめかし屋のイソクソキ（啄木鳥のこと）にむかつて、『さあ、母さんの病気です。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さのうちは老予言者ででもあるように、寂しい姿をして、節くれだった裸の枝で意味ありそうに北極星の彼方を指さしていた公孫樹までが、齢にも不似合な若やぎようで、指さきという指さきをすっかり薄緑に染めておめかしをしている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "安い油をてかてかとぬったぐあい、女に会えるからのおめかしに相違あるめえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは髪床へいって、朝湯へ回って、たいそうごきげんうるわしくおめかしをしていたはずだが、違うのかい」「もうそれだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんなもこれですみにはおけませんね、べっぴんときくと、急におめかしを始めたんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こやつら何をしたのじゃ」「いいえなに、このおめかしさんの髪へ触ったとか触らないとか言ってね。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんな、あっしゃもう帰らしていただきます」　がらにもないおびえを見せたものでしたから、今度は右門のほうが不思議に思ったので――「バカだな、いざとなっておっかなくなったのかい」「いいえ、ちがいます」「じゃ、うちへけえって、おめかしをし直して来ようというんか」「めったなことをおっしゃいますな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめかしずきの女だった証拠なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるおめかしの大品評会場である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴蘭、おめかしの好な女、白い喉を見せて歩く蓮葉者の故意とらしいあどけなさ、丸裸の罔象女。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある学者の報告によると、その男の飼つてゐた一羽の孔雀は、どうかすると鶏小舎のなかへ忍び込んで、おめかしやの雄鶏の後をせつせと追ひ廻したさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達は何れもおめかしや揃ひと来てゐるので、ある日の事｜辛抱がしきれないでロツクフエラアに注意をした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おめかしやの婦人は弾機ではじき飛ばされたやうな顔をして、さつさと其処を立ち去つたさうだ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくらおめかしをしてもあかん体や」彼はそうも言った。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は非常なおめかし屋で念入にお化粧した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姉はおめかし屋で、小説や、芝居を好み、交際もいいくせに、少しも浮いたところがなかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またすみちゃんが一生懸命おめかしして行くんじゃんしょう」　伯母がからかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、出掛けて行って会う分には損はない――アンドルウ・ヘルグラインは、すっかり好い気もちに納まり返って、急におめかしを始める。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親が出かけて行つてからも、オクサーナは長いあひだ、錫の縁を嵌めた小さい手鏡の前でおめかしをしたり、容子を作つたりして、われと我が姿に飽かず見惚れてゐた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」」］　さう言つて鏡を取りあげると、またしても彼女は男の前でおめかしをやり出した。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
