        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "併し自修ばかりでは一人合点で済まして居て大間違いをして居る事があるものですから、そこで輪講という事が行われる。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらなさそうな顔をしてその本を棚に返す……と思ったら大間違いの豈計らんやでげす。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛が言葉以外に、実体として何かあると思っていたら、大間違いだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "代数や幾何の勉強が、学校を卒業してしまえば、もう何の役にも立たないものだと思っている人もあるようだが、大間違いだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君やわしらが、文字を使って書きものをしとるなどと思ったら大間違い。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、昔から言われておるように、そういう境地が楽しいものだと思うたら、大間違い。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "塾の名前は忘れたが、タカが女の学問塾と思って軽侮すると大間違い、頭山満を初め後年、明治史の裏面に血と爆弾の異臭をコビリ付かせた玄洋社の諸豪傑は皆、この高場乱子女史と名乗る変り者の婆さんの門下であったというのだから恐ろしい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "資金に詰まって友達の生胆を売って大間違いを仕出かしたのを幕切にして、立派にやめてしまいましたが、考えてみると私輩の一生は南京花火のようなもので……シュシュシュシュポンポンポン……ウワアーイというただけの話で……。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "些くともこれは大勢同志を比較した統計で、ふだん出合頭に鼻の高し低しを見てその人間の文化程度を測定するのは大間違いの初まりではあるまいかと考えられます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに慎みぶかいお姉さまを危険視するなんて、大間違いだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「釜の下の灰まで自分のもんや思たら大間違いやぞ、久離切っての勘当……」を申し渡した父親の頑固は死んだ母親もかねがね泣かされて来たくらいゆえ、いったんは家を出なければ収まりがつかなかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのでんで文化が進歩したって、人間が幸福になれると思うのは、大間違いだ」かつての自分の意見を否定し、おまけにその口調がふざけたものになってしまった、「文化人になりたいか？",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きこもって私を寄せ付けないつもりなら大間違いですよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の思うにゃあなたがかえって子に不孝だ」「どこまでも我儘をとおして親のいうことに逆らうやつが親不孝でないだろか」「親のいうことすなわち自分のいうことを、間違いないものと目安をきめてかかるのがそもそも大間違いのもとだ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬数が多いから多少はほかの馬にも票が割れるだろうなどと想像すると大間違いである。",
              "citation": {
                "source": "競馬の一日に就いて",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "楚人その卜いは大間違いだ、楚王は汝を殺して鐘に血塗らんとするに何の吉もないものだと威した。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その源由を察せずに、似た物は必ず同根同趣と判断するは大間違いじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを読んで、さほど精力強い豕を食ったら定めて精力強くなる理窟で、豕をシシと呼んだ事は上に述べた通り、それからむやみに子を孕んで困るをシシ食うた報いというたに相違ないと、独りよがりをやらしていたところ、『嬉遊笑覧』を読んで自説の大間違いたるを悟った。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、あれがただの過失だなんて思ったら大間違いです。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア文學は、愛と平和との中に、靜かな朗らかなクラリオネットの音の中に發育したものと思うのは大間違いで、血と鬪いとの中から戰いとられたものである。",
              "citation": {
                "source": "政治的價値と藝術的價値　マルクス主義文學理論の再吟味",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「徴兵の期間ば短くするために青訓さ行ぐんだら、大間違いだど！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こういう社会ファシストの本体というのは本当の芝居を大衆の前ではなくて背の方で打つところに面目があるのだから、これだけでうまく行ったと思えば大間違いなのだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺言を放送した男の棲んでいた遊星が崩壊したのでことは終ったと思ったのは大間違いだった。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、自然と心より物の方がほんとうの存在のように考えるのですが、物だけで、パンだけで一切の問題が解決されると思ったら、それこそ大間違いです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世の中に、人間ほど豪いものがないと思ってちゃ、それは大間違いですよ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は探偵小説の科学的利用について述べたので、探偵小説の目的が探偵学の普及にありという意味にとっては大間違いである。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金のウシの話一　思想というものに、そう大差がなかろうと思うのは大間違いで、昔の人の心持を今日の常識から考えてみていかにも理解のできぬことが雑多にあります。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "不景気の根が絶えるとでも思ったら大間違いです。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで俺は、俺の脳髄が俺の手足を動かすものだとばかり思っていたが、それは大間違いだった。",
              "citation": {
                "source": "鎖工場",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハートの　クイーンが　そのあたりに　あかい　バラの　きが　ほしいって　いったらしいんだけど、　なのに　かわいそうに　このにわしくんたちは　おおまちがいを　しでかして、　かわりに　しろいのを　うえちゃったんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
