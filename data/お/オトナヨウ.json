        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あなたより先にここへ来たのは、あのＡ組の美木でしたね……美木は大人用のスキーをつけていたでしょうね？",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は総領娘のために子供用のヴァイオリンと大人用のヴァイオリンを買って来た。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "未納　母さんと亜鈴体操したことあってよ、妾達、大人用の亜鈴。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常袋の中に私は忘れず太郎用の本一冊大人用の本一冊入れておこう、もしやけ出され野宿するときそんな本を朗読してきくような場合が決してないとは云えなかろう、そういう心くばりがこの一家における私の独自性であり芸術のありがたみでもあるわけだと思う。",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大人用でしょう」　と、千二は困った顔だ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此外少し高尚な繪本も見たがそれは幼兒用のものではなく、大人用であつたらしい。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "純毛は大人用は本年はないでしょうね、折角のおくりものでも。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人用のは四拾円、子供用のは三拾五円、大きさに比較して値段のちがいは少かった。",
              "citation": {
                "source": "日日の麺麭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人用のグラヴもひとつ見つかった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
