        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女の子が追いかける草のなかを、ばったは二本の脚を伸ばし、日の光を羽根一ぱいに負いながら、何匹も飛び出した。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは……これで……お暇を……この御恩は死んでも……」「アラマア……」　眉香子は追いかけるように二、三歩進み出た。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていちばんあとから見えと因襲の靴を踏み脱ぎすてたヒロインが追いかける。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、そりゃ……」　困ると、あとを追いかける余裕もなく、鶴雄は赧くなってぽかんと見送っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、女の子は、そのあとを追いかけるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……あなたって人は……ほんとに仕様のない人ね」「……ウーン……どうせヤクザモノさ」「だけど……」「何だい……」　私は追いかけるようにこう云いながら心もち冷笑を含んで彼女を見上げた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は現実の彼岸に於て、絶えず生活の掲げる夢を求め、夢を追いかけることに熱情している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "という文句を追いかけるように二人の耳へ送った。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の附近のバアのラジオは私を追いかけるようにして、いまは八時に五分まえである、台湾はいま夕立ち、日本ヨイトコの実況放送はこれでお仕舞いである、と教えた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の主人公が、どんな武装をしてあなたを追いかけるか知れません。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、わたしは追いかけるように訊いた。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏姫が鄭に着くと、それを追いかけるようにして巫臣の密使が鄭に行き、夏姫を聘し度い旨を伝えた。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "準之助は、失踪した愛人を、追いかける青年のように、焦慮し緊張していた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たしてその通り、夕食の頃に汐を噴いているのを一頭見かけたが、あんな地位にあっては、船でその跡を追いかけることは不可能であった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し遅れて男が隠れた場所から出てきて、自転車に飛び乗り、ご婦人を追いかける。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズが後に続き、私も馬は道ばたで草でも食ませることにして、ホームズを追いかける。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先を追いかけると、どうも窓越しに雫落ちるわびしい庭を見ているとしか思えない。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは追いかけるように訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二雄さんは不意の出来事に顛倒してしまって、なかなかわたくしのあとを追いかける余裕はなかったのです。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長は葉子の言葉を追いかけるように、「用はあとでいいます。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐が鶏をねらって来たのを、犬が見破って、狐を追いかける歌なのよ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、悪漢を追いかける色男役ですな。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎と学生とを、乗せた自動車は、今発車したばかりの電車を追いかけるように、凄じい爆音を立てたかと思うと、まっしぐらに国府津の町を疾駆した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "府中を落ちて二、三里も行った時、彼らの一群を追いかける織田家の甲冑が四、五町後の街道に光るのを見た時に、彼は死を恐れる心よりほかの考慮は何もなかった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はあとを追いかける。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さっと立ち上がりながら、すかさずにつかつかと追いかけると、源之丞と呼んだ師範代の若者が相手にしようともしないのを恨むように、おこったように、やさしくにらみにらみ奥の間へ立ち去ろうとしていた娘のあとから不意に呼びかけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "左のスティックをさきに打ち、ほんのわずかに遅れて、右のスティックで追いかけるのが、「左のフラ打ち」。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三人の棒頭にピストルを渡すと、すぐ逃亡者を追いかけるように言った。",
              "citation": {
                "source": "人を殺す犬",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "高松さんは土間に飛び降りて追いかけると、相手は素疾く表へぬけて出る。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の羞恥心と恐怖心とがひとつになって、千枝太郎はもうその車を追いかける勇気を失った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
