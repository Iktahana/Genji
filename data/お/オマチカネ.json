    "definitions": [
      {
        "index": 1,
        "gloss": "long-awaited",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "奥さんがお待ちかねよ」　といった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若様もお待ちかねよ」　ともう一人のがいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ちかねでした」といつて案内する女中に導かれて三階の一室にはいつて行つた時には、おんつぁんも、勃凸も、Ｉも最上の元気で食卓を囲んでゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "入道さまは法名を蓮胤と申して居られましたが、その蓮胤さまが、けふ御ところにおいでになるといふので私たちも緊張し、また将軍家に於いても、その日は朝からお待ちかねの御様子でございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん、お待ちかねだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さんがお待ちかねでございます、どうぞいらしてくださいまし」　喬生の手首には金蓮の手が絡ってきた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして、それが判ります、私は杜陽ですが」「家の旦那様が、あなたのいらっしゃるのをお待ちかねでございます、さ、どうか、暫く此処でお休みください、申しあげてまいりますから」　痩せた男は体を片寄せて杜陽の入るのを待っていた。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那様が、お待ちかねでございます、さあどうぞ、此方へおいでくださいますように」　痩せた男は急いできたと見えて呼吸をはずましていた。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ほんの偶然だが、その御前様はその月曜に一通の電報を受け取っていて、夫が出かけたすぐあとだったのだが、その内容は、お待ちかねの大事な小包がアバディーン海運会社の事業所で取り置きされているとのことだったそうだ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あなたがお客様お待ちかねの紳士ですね。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さんがお待ちかねでございます、どうぞいらしてくださいまし」　喬生の手首には金蓮の手が絡って来た。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥さまがお待ちかねでございます」　逢う約束をしている者はなかった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またお目ざめになりますのをお待ちして、若宮にお目にかかりまして、くわしく御様子も陛下へ御報告したいのでございますが、使いの私の帰りますのをお待ちかねでもいらっしゃいますでしょうから、それではあまりおそくなるでございましょう」　と言って命婦は帰りを急いだ。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "八橋さんの花魁もさぞお待ちかねでござりましょう。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「番町の殿様お待ちかねでござります」と、女房は笑顔を粧った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様がお待ちかねでございます。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺社奉行さまが、さばきのむちと情とを持って、お待ちかねでござろうわ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "上様お待ちかねじゃ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――みなの衆、豊明権現様もさき程からきっとお待ちかねじゃ。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床は寝床だったが、ふっくらとしたその夜具の中には、旦那のおいで、お待ちかね、と言わぬばかりに、仲よく二つの枕がのぞいていたのである。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お奉行さまがだいぶそなたをお待ちかねの様子じゃったが、お越しがなかったから敬四郎どのにご命令が下りましたぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの、お待ちかねですから、お早く願います……」　せきたてるようにまた呼んだ表の声をききながら、不審そうに首をかしげて、しきりと鼻をくんくん鳴らしていたが、不意に名人がおどろくべきことをいって立ちあがりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ちかねでしたでしょう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞかし伊豆守様お待ちかねにござりましょうから、ではご案内くださりませい」　何が何やら解しかねるといったおももちで、ぽかんとそこに番士たちが待ちあぐんでいましたものでしたから、右門は改まって声をかけると、城中への案内を促しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、伊豆守はことごとくお待ちかねでしたので、右門参着と聞くやただちにご寝所へ通して、刻下に人払いを命ずると、すわるもおそしと声をかけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待ちかねでござるぞ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間にはリット少将が、お待ちかねであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロロ王が、おまちかねです。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くもその顔色を見てとった大尉は一彦の肩を叩き、「さあ、元気を出して謎にぶつかって見ようではないか、博士にはすまないが、まずこの室内をよくさがして見よう」　　　顔の怪塔王　　　　　１　お話はかわりまして、ここは皆さんおまちかねの怪塔の中です。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、おまちかねの方よ」　蓬莱和子は少し嫌味な笑い方をした。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
