[
  {
    "uuid": "24823f89-dbb1-5983-8ea5-a61fc43c8b03",
    "entry": "魘われる",
    "reading": {
      "primary": "おそわれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
