          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "尤も、私の詞が氏に影響するなどと考へるのは、或は少々の烏滸の沙汰かも知れないが……。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまで、民衆を指導するなどと考えていたのは烏滸の沙汰である。",
              "citation": {
                "source": "全体主義への吟味",
                "author": "――今日の民衆、知識人への課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼らは父がかかる怯懦なる器量をもって、清盛を倒そうともくろんだのは、全く烏滸の沙汰であると放言しました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな疑惑は畢竟無知のさせる烏滸の沙汰である。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう迅いのがゐるのだから、蟹の穴みたいな書齋にのみ引つ込んでゐる僕などに、物漁りなど烏滸の沙汰である。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
