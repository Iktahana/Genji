        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すると途中で、そこの海の神がふいに大波を巻きあげて、海一面を大荒れに荒れさせました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇月の天気も大荒れで、ふたりとも一日中、部屋に閉じこもっていた。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一度は、私どもが漁場へ着いて間もなく疾風が吹き起って、帰ることなどは思いもよらないくらいに海峡がひどく大荒れになったために、一週間近くも漁場に留まっていなければならなくて、餓死しようとしたことがありました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に大荒れの、しかし厳かにも美しい夜、また、そのもの凄さと美しさとではたとえようもない不思議な夜であった。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がよすぎてむかむかすらあ」　悲憤やるかたなかったとみえて、伝六の空もようは大荒れです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "へルンが日本に参ります途中どこかで大荒れで、甲板の物は皆洗いさらわれてしまう程のさわぎで、水夫なども酔ってしまったが酔わない者は自分一人で、平気で平常のように食事の催足をすると船の者が驚いていたと話した事がありました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンが日本に参ります途中どこかで大荒れで、甲板の物は皆洗いさらわれてしまう程のさわぎで、水夫なども酔ってしまったが酔わない者は自分一人で、平気で平常のように食事の催足をすると船の者が驚いていたと話した事がありました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇が舷梯を離れるや否や、もう篠つく雨となつて海上は大荒れに荒れだした。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの大荒れにも拘らず、彼等は一時間半の大搖れにも、遂に船醉を感じないで、目的地に着いた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百何千のひとは、今朝になるまで、この未曾有の遅延が、「質問順位で大荒れ」を理由とするとは知らず、二時間以上待っていた次第であった。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう知らないばかりか、きょうになっても大荒れの必然はよく理解されまい。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば第二回のところではこの感情を中心的に扱っていて、一中に入ろうとした時、自分が私生子であるということを知ってたいへん苦しみ、うちへかえって嫌だ嫌だと気狂のように大荒れに荒れる、その絶望の心を書いている。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんざん大荒れに荒れた後で、ふいとまた雷がやんで、あらしがしずまって、夏の夜がしらしらと明けかかりました。",
              "citation": {
                "source": "田原藤太",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天候は春より変りやすいが、ウェーブが小さく大荒れがないので山へ登れない日は殆んどない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ大荒れしのち、宮のところへ来てあやまったとのこと。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後、日本海は荒れることが少くなったそうだが、この日は海が大荒れで、私たちは伏木港外の雨晴という海岸へ義経の古蹟を見に行くはずであったが、海岸の路上に波がうちあげるために一時は通行ができなかった。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、帆柱のかげからムックリとはね起きた六尺ゆたかの壮漢、「こいつら、ふざけやがって……」　盆ゴザも、場銭も、火鉢も、煙草も、手あたり次第に取って海へ投げ込む大荒れの勇者が現われました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いのほかの大荒れで、奥筋の道や橋は損じ、福島の毛付け（馬市）も日延べになったとの通知があるくらいだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "田畑のことは確かにもわからないが、この大荒れでは稲穂もよほど痛んだのではないかと言って、彼のそばに来てその心配を始めるのは問屋の九郎兵衛だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半蔵さん、きょうはわたしも初めて家を出まして、伊之助を連れながら大荒れの跡を見てまいりましたよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の二十三日あたりは大荒れでございまして、中津川じゃ大橋も流れました。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には馬、時には徒歩の旅人姿で、半蔵が東京への道をたどった木曾街道の五月は、この騒ぎのうわさがややしずまって、さながら中央の舞台は大荒れに荒れた風雨のあとのようだと言わるるころである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "脅しすかして問い詰めると、才蔵は頭を掻いて、文らしいものを預って腹巻へ落しこんで行ったが、なにしろあの大荒れなので、雨と汗のしめりで、糊のように溶けてしまった。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将は、畜生ッ、巡査を呼びやがったな、どうするか見ていやがれ、と靴のままで式台に飛びあがって、大荒れに荒れたが、警官は、この家は代が変って、君達の友達はいないのだから、乱暴してはいけないと上手に揉みほぐし、束にして押しだしてしまった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は其処で十五分位だまつてその重々しい大荒れの有様を見てゐました。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちゃもう、この上は堪えてつかわさぬぞ」などとのたまい、桐の夏枕を掴み投げにし、大荒れに荒れたもうた。",
              "citation": {
                "source": "玉取物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大荒れに荒れてドアを壊して部屋へ入ると、六枚折の屏風をひき廻した内側に明々と台ランプを点し、布団の上に括枕が二つ、枕元には燗徳利や小鉢まで置いてある。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤掃の埃しづまる葉蘭かな　　　　子規　煤掃をすると家の内は綺麗になるけれども、一時は煤埃が空中に舞い上ってその辺一面に大荒れに荒れるのであるが、その煤掃も終って暫く時間が経つと、空中に散ばっていた埃も自然と地上に静まって来る、その埃は庭の葉蘭の上にも懸っているというのである。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうのように大荒れに雨が降ると、ああきょうのような日でなかってよかったと云っていらっしゃる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ムーンライト・ソナタ』でお月様の出を強調したり、『アパショナタ・ソナタ』で、ピアノを叩き潰すような感情の大荒れを見せられたり、そんな馬鹿げた芝居気の演奏に我々は馴らされて来たのである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
