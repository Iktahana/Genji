        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "何よりも荒馬のいきり立って躍り上がる姿にはたとえるもののない「意気」の美しさが見られるのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋と正面に向き合う処に、くるくると渦を巻いて、坊主め、色も濃く赫と赤らんで見えるまで、躍り上がる勢いで、むくむく浮き上がった。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダッともろ手体当てに、雨戸を難なく押し破りながら、先頭に主水之介、つづいて京弥、あとから神官正守の順でいきなり広縁に躍り上がるや、ずいと先ず退屈男が静かに部屋の中へ押し入ると、悠揚莞爾としながら、さらに静かに浴びせかけました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "背嚢の中の雑品や弾丸袋の弾丸がけたたましく躍り上がる。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお此の魂である、天の日、太洋の浪、それと共に若やかに燃え上がり躍り上がるのは。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅は云う、赫としてここに躍り上がると。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、非常にひよわなさかなのように思われているが、その実、鮎は俎上にのせて頭をはねても、ぽんぽん躍り上がるほど元気｜溌剌たる魚だ。",
              "citation": {
                "source": "鮎の食い方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州｜花隈の城主として、天狗飛切りの秘術を編み出し、当時｜芳名香しいところの、戸沢山城守より伝授されたる小太刀潜入飛燕の術もて、岩に手を掛け枯木に縋りまたは空中を両手で煽ぎ、数十｜丈の壁面を、目にも止まらず躍り上がる。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と、叫んで空に躍り上がる）フーミ　できるだけ海の遠くにな。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "その法は、児童五、六人相集まり、互いに手を取りて環状をなし、その中央に一人の童子を入れ、周囲にて手を振り躍り上がりつつ反復数回、左のごとく唱うるときは、妖怪その中央の童子に移りきたりて、童子は自然に周囲のものとともに躍り上がるに至るという。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "――寿童丸様」朱王房は、牢内の闇から、じっと、孤雲の面を見つめていたが、躍り上がるように立って、「やっ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、いよいよ今朝、必死の出陣とみえる」　山の中腹にある病舎の軒下から、唯そう感じただけで眺めていた蔵六は、そのうちに躍り上がるほど驚いた。",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにおろうと、この方のいるところへ必ず戻ってくる質だが」「あ――」万吉が、話の中途で、躍り上がるばかりに指さした。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらとこをたつたいまこつから出して――」　突然、岩田熊吉はおどりあがるやうな身ぶりをし、荒々しく目の前の陳述臺をおしのけ前へ進み、手をのばして訊問臺の縁を引つつかんだ。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ一等賞はぼくにきまった」　と、おどりあがる者がいるかと思うと、「なァに、スズキなんかいくらつってみてもだめさ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もそう……スミルノーフ　（おどりあがる）黙れ！",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、道場では、どこまでも、お蓮様も丹波も在宅のように装って、屋敷を明けていることはひた隠しにかくしているのだが、なんの交渉もないとはいえ、またいかに広い屋敷内でも、一つ屋根の下のこと――今まで知らなかったのは源三郎だけで、それだけに彼は、おどりあがるように馬上に身をひきしめ、「おもしろい！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌人の音声清らかにして調子熟すれば、その足の上下一層迅速にして、座中を縦横におどりあがる。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ではいって来ます」　万三郎はたちまち嬉しくなり、まるでおどりあがるような声で云った。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、捜し出してやる」　言葉とともに土足のまま縁におどりあがると、後から後からと踏みこんで、家中を歩きまわった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　中村警部は、おどりあがるようにして、そのランチに呼びかけるのでした。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おどりあがるようにして叫びました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、みんなはおどりあがるようにして叫ぶのでした。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おどりあがるような、さけび声でした。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
