        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "思いっきりお行儀を悪くして、いけない事ばかりしてやろうという気になっちゃったのよ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "版を作るまではえらく厄介だが、後は不良品が出ないように思いっきりきれいにした部屋にこもって押すだけだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップルがマックのＯＳを売り渋っても、思いっきり安くて速ければ、これで何とか勝負になる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐中電灯で目標をたしかめ、慶一が、思いっきり山崎の足を踏みつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはあとで音をかぶせるから、思いっきり鼻かんだって、痰を吐いたってわからないからな」「そんなことするかさ」「あのな、これは芝居じゃない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は四脚の短長格を思いっきり声を引き引きがなり立てて、韻が入れかわり立ちかわり、まるで小鈴のような空ろで騒々しい音を立てたけれど、わたしはじっとジナイーダの顔を見たまま、彼女がついさっき言った言葉の意味を、しきりに考えていた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこの上、何ひとつ運命から求めてはいけない、今こそ『思いっきり、心ゆくまで最後の息をついて、そのまま死んでしまえばいいのだ』と、そんな気持がした。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はばばアのいうとおり、なんとかして命だけは持って出て、出たら三日でも四日でもいい、思いっきりしたい放題をやって、無茶苦茶をやって、それがすんだら街のまん中で電車にでもからだをブッつけて死んでやるつもりです。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はよく耕地へ行って見ますがね、そこでときどき、思いっきり高くとびあがって見るんです。",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、岡田はまた防毒面に雑嚢をなくしているのを分隊長に発見され、銃床で思いっきり尻ぺたをこづかれ、六尺豊かの大男が鼠のようにキュウキュウ泣いていた。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "物をいわれてもはぎれのいい少し高調子の丸みのある声で答え、たたみのけばなんかむしらない人、いろいろな向面に趣味をもって音楽も少しは出来文学の話相手も出来る人、髪でもなんでもさっぱりしていやみのないめずらしい形に結って思いっきり何でもはっきりした娘がすき。",
              "citation": {
                "source": "妙な子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『さあ、そいつを思いっきりひっぱたくんだよ、思いっきり！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちにいて、思いっきり勉強するの、好いもの書くわ。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "神にも、仏にも、思いっきり、その無情をなじりたいような気持であった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家へ帰りましょう、それから思いっきりにぎやかな所へ行きましょう」　小さい声で云ってつまさきを見たまんま大急ぎで家の沢山ある通りに出た。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　斯う思うとすぐ、今日一日は源さんを思いっきりいじめてやれとむごい心持になった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年も半年も会わないで手紙さえやりとりしなかった時はたびたびでもその次会った時には昨日会った人達の様に何にもこだわりもなく打ちとける事が出来たのも、お京さんが思いっきりの音無しい人で自分が我儘な気ままな女だからどうか斯うか保って居たんだ。",
              "citation": {
                "source": "千世子（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで初めの百本は、ただ一寸刻み五分だめしのつもりでやって置いて、やがて最後の百一本目を思いっきりピシリとやったものだから、脊骨が砕けてしまったそうですよ。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃ身が持たないよ――お泣き、思いっきり泣いて泣いて、泣きつくしておしまい。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いっきりが肝腎です！",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもう思いっきり大胆に、例の女の面影や、やがて来るべき自分の幸福を心に描いて、なんの憚るところもなく想像の翼をひろげて行った。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっつけ亭主が帰って来ようが、その上でわしら二人の四本の手でもって、お前さんという天晴れ貞女を、馬小屋で思いっきり叩きすえさせて貰おうじゃないか。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ふたり腰をおろす）坐って、思いっきり話しましょう。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、酔っぱらったが最後、僕は思いっきりもう、ずうずうしい鉄面皮になる。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いっきり弾いて泣いてみよう、ばかみたいに泣いてみよう。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて一生に一度は、思いっきりやってごらんなさい。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あのワーニャ伯父さんは、あたしには、魔性の血が流れている、「せめて一生に一度は思いっきりやってごらんなさい」って言ったっけ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようなカウンターのある店は、当時としてはおもいっきり洒落た店であったはずだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
