        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女は突っ伏して大泣きに泣いた、さすがに声は立て得ないから背を波打たして苦しそうであった。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "容体を伯母の乳母も話して大泣きに泣いていた。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ私が努力を要するかと言いますと、思いも寄らぬ昔話をあなたがお聞かせになったものですから、いっそうこの世に跡を残さない身になりたい欲求が大きくなったのです」　と、薫の泣きながら言うのを聞いている弁はまして大泣きに泣いて、言葉も出しえないふうであった。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "生みの親のことも忘れて、こゝのお二人に馴れ親しみましたので、私はお側を離れて行くのが、ほんとうに悲しうございます」　二人は大泣きに泣きました。",
              "citation": {
                "source": "竹取物語",
                "author": "和田萬吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親の小言も馬耳東風で、しまひに大泣きに泣いて大人を強迫する。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、涙こそこぼさないが、顔中、大泣きに泣いていたろう、今松。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスの向こうにはっきりと見えるのに、せいいっぱいテーブルの足からのぼろうとしても、すべるすべる、しまいにはくたびれて、かわいそうにかわい子ちゃんはへたりこんで大泣き。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたりこんでまた大泣き。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたみたいな気高い娘が、」（たしかにお高い）「こんな大泣き！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいにはくたびれて、かわいそうにかわい子ちゃんはへたりこんで大泣き。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "へたりこんでまた大泣きのはじまり。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ここでかわいそうで、アリスはまた大泣きのはじまり、だって心がとってもせつなくて、しょげていたからね。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孃さん、旦那樣、それでは――」　お谷は縁側の板敷に、ガバと身を投げて大泣きに泣くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝からあの人は一度も顏を見せないんですもの――忙しいには違ひないし、極りも惡いことでせうが、私がこんなに、こんなに――」　お京は大泣きに泣くのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "心中崩れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に素姓を覺らせないため――」　振り返るとお春の春吉は、人ごみの後ろに、全身をふるはせて、大泣きに泣いて居るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "萬兩分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "磔刑柱を背負はされたつて、私は怨には思はない」「本當か、矢つ張りお前がやつたのか」「さア、私はもう、――」　お美乃はこの時始めて、側に居る亭主の三十郎を意識したやうに、すがり付いて、大泣きに泣くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒矢",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分さん、神とも仏とも、――」　五十近い幸右衛門は恥も体面も忘れて大泣きに泣き入るのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分さん、神とも佛とも、――」　五十近い幸右衞門は恥も體面も忘れて大泣きに泣き入るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さん、旦那様、それでは――」　お谷は縁側の板敷に、ガバと身を投げて大泣きに泣くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "女の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に素性を覚らせないため――」　振り返るとお春の春吉は、人ごみの後ろに、全身をふるわせて、大泣きに泣いて居るのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "万両分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊勢屋の身上に恐れて尻尾を卷くやうな岡つ引に用はない、娘の敵は私が討つから覺えて居やがれ」　十七年前に※り取られた、たつた一人の娘戀しさに、三味線堀に獨り住居して居る、大ヒステリーの四十女は、もう十手も捕繩も眼中になく、大泣きに泣き濡れて足袋跣足のまゝ、外へ飛び出してしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "血塗られた祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の母親は大泣きに泣いて十幾幕も愁歎場を見せた。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "大泣きしたあとに気分が晴れるあの心理上の効果があり、音楽のよろこびは別世界へいく楽しさであった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ単に、なにか悲しい原因があるから泣くというのではなく、生理的あるいは精神的な本能のひとつとして大泣きするという、人間が持ちうるごく自然な姿の「泣き」なのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロックンロールが持つ快適さは、はじめから陽気に単純にしあげられたビー玉のようなうれしさではなく、複雑なものに発展しうる土台を持った、大泣きしたあとの昇華的なさわやかさでなければならない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すすり泣いていた伊織は、だんだん声を高めて、果ては、天地にただ独りいるように、声をあげて、大泣きに泣き出した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんぐりと口を開いて、先刻、大泣きに泣いたままな顔をして、――もちろん頭からズブ濡れになって、泥田になった耕地に案山子みたいに立っているのだ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
