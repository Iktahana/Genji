        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分が牛舎の流しを出て台所へあがり奥へ通ったうちに梅子とお手伝いは夕食のしたくにせわしく、雪子もお児もうろうろ遊んでいた、民子も秋子もぶらんこに遊んでいた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上がってからおよそ十五、六分も過ぎたと思う時分に、あわただしき迎えのものは、長女とお手伝いであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "降誕祭の初めの日には、主婦さんが、タンネンバウムを飾るから手伝ってくれぬかと言うので、お手伝いしました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、綴方の事は、きれいに忘れて、学校から帰ると、花壇の手入れ、お使い、台所のお手伝い、弟の家庭教師、お針、学課の勉強、お母さんに按摩をしてあげたり、なかなかいそがしく、みんなの役にたって、張り合いのある日々を送りました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の此のむずかしい世の中に、何一つ積極的なお手伝いも出来ず、文名さえも一向に挙らず、十年一日の如く、ちびた下駄をはいて、阿佐ヶ谷を徘徊している。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、抜け目の無い男で、「オベリスク」の編集は世間へのお体裁、実は闇商売のお手伝いして、いつも、しこたま、もうけている。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月島丸が沈没して、その捜索が問題となった時に、中村先生がいろいろの考案をされて、当時学生であったわれわれがお手伝いをして予備実験をやった。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生がたのお手伝いをして、例の小船で調べて回ったこともあったが、とにかくおもしろい現象である。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（框の縁に腰を掛く）お勝手働き御苦労、せっかくのお手を水仕事で台なしは恐多い、ちとお手伝いと行こうかな。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃　いや……お手伝いという処だが、お百合さんのそうした処は、咲残った菖蒲を透いて、水に影が映したようでなお綺麗だ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、この店のお手伝いでもしてみない？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろしければ、大きなかがみの前で王さまのお着がえをお手伝いしたいのです。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あなたの気持がしっかりしていて、将来の方針をはっきり打ち樹て、そうして私に相談をしてくれたら、私は、たといわずかずつでも、あなたの更生のために、お手伝いしようとさえ思っているんです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまには、祖父、祖母、母もお手伝いする事になっている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの、やや長い物語にも、やはり、祖父、祖母、母のお手伝いが在るようである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお手伝いに伺いましたとき」といって言葉を切り、そしていい継いだ。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろしい、一つお手伝いしましょう」　中老の社長はその男にも好意を持つと同時に、自分も自分の奥に燃え燻ってしまった青春の夢を他人ごとながら、再び繰り返せるように気が弾んで来たらしい。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見た娘は「私もお手伝いさせて頂きますわ」　と云ったきり、私たちから離れて、すっかり事務所の男達の中に混り、野天風呂も沸せば、応接用の室を片付けて、私たち女二人のための寝室も作った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何一つ、あなた達のお手伝いが出来ません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "及ばずながら、私たちは、その背後で、せめて身のまわりのお世話でもしてあげて、わずかなお手伝いをしたいと念じていたのですが、ばかばかしい、その背後のお手伝いの女こそ、男のひとたちの生きる唯一の目当だったとは、まるで笑い話ですね。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕とホレーショーは、その贋の検事に、深刻な顔つきをしてお手伝いをして、いい気持でいたんだから、これは後世までの笑い草にもなるだろう。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けさは、兄さんも僕も、手伝いどころか皆の邪魔になるばかりなので、二階に避難して、お手伝いの人達の悪口などを言っていたら、杉野さんが、こわばった表情をして、用事ありげに僕たちの部屋へはいって来て、ぺたりと坐って、「当分おわかれですわね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥田先生がおひとりで晩ごはんのお仕度をしていらっしゃるという事を母から聞いて、何かお手伝いでもしようかと思ってお部屋をのぞいてみました。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金が来るまで、私はお店のお手伝いでもさせていただくわ」　私は坊やを背中からおろし、奥の六畳間にひとりで遊ばせて置いて、くるくると立ち働いて見せました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで私は、このお店でお手伝いしていますから」「お金が、かえって来れば、そりゃもう何も」とご亭主は、ひとりごとのように言い、「何せことしも、あと五、六日なのですからね」「ええ、だから、それだから、あの私は、おや？",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはもう二人の忠義な下僕になりすまして、納屋へ食事を持ちはこぶやら、蠅を追うやら、櫛でお蘭のおくれ毛を掻き上げてやるやら、何かと要らないお手伝いをして、二人の淋しさを慰めてやろうと畜生ながら努めている。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この短文の論旨は、あの人がかねて言っているような「同胞の政治運動にお手伝いするため」の文芸、とは多少ちがった方向を指差しているようにも思われるが、しかし、「無用の用」という言葉になかなかの含蓄が感ぜられる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「は、私はちっとも急ぎませんけれど、今日は名代も兼ねておりますから、疾く参ってお手伝いをいたしませんと、また菅子さんに叱言を言われると不可ません――もうそれでは、若竹座へ参っております時分でしょうね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を見詰められたので、睫毛を伏せて、「はい、ですが私はただお手伝いでございます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、見ねえな、おれが察して、当分ままたきのおてつだいでもするかといったら、あのとおり、ぽろぽろとうれし泣きをやったじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
