        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大抵目ぼしい、小作人組合の主だった、（ならず者ども）は、残らず町の刑務所へ抛り込まれてしまった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "末広君の学術方面の業績は多数にあって到底ここで詳しく紹介することは出来ないし、またそれは工学方面の事に迂遠な筆者の任でもないが、手近な主だったものだけを若干列挙してみると次のようなものがある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦死者があると、いつも、もと坊主だった一人の兵卒が誦経をした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、町では、彼の傭主だった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主だった星座を暗記していれば素人でも新星を発見し得る機会はあるという事も話した。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿は老遍路さん、可なりの年配だけれどがっちりした体躯の持主だった。",
              "citation": {
                "source": "遍路の正月",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "下地は好きなり空腹でもあったので、ほろほろ気分になって宿のある方へ歩いていると、ぴこりと前に立ってお辞儀をした男があった、中年の、痩せて蒼白い、見るから神経質らしい顔の持主だった。",
              "citation": {
                "source": "道〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、白人と土人とを問わず、島の主だった人々には残らず招待状を送った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれを見てではなく、あの魔物を見たからなのだ」というのが、主だった魚銛発射手の一人の注釈であった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きが主だったことは言うまでもない。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽吉夫婦は、そちのにらんだとおりじゃぞ」「えッ、じゃ、やっぱりご亭主が嫁さんで、お嫁さんがご亭主だったんですかい」「そのとおりじゃ」「いくら欲の皮がつっ張っていたからのことにしたって、あきれたものだね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、神主だったことに不思議はないが、意外だったのはその年齢でした。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬られたのは下谷の紙屋の若夫婦で、娘はおかみさんの妹、連の男は近所の下駄屋の亭主だったそうです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人共同じような純白の三つ揃いを着て、どことなく洒脱な風貌の持主だった。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一番｜主だった僕の目的と言うのは、始めからこいつにあったのさ。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはリット少将をはじめ、主だった英人技師の宿泊所であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは艦隊の主だった者の間にだけ打合せのあったことであるが、実は飛行島の秘密をさぐるため、川上機関大尉に特命を出したのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが柳下空曹長は、無類とびきり強い心の持主だった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "リット少将は、さすがに人の上にたつだけあって、英国人らしい深い注意の持主だった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ子供を無事に生んで、良人に一生涯迷惑をかけてやろうという心が主だったので御座います。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような批評家は同じ考えを作品にまで敷衍して、バルザックの描く主だった人物を見よ、ゴリオにしろ、ベットにしろ、皆その人生を慾望の偏執によって貫く異常人ではないかと強調するのである。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉浦は、その家が何をしていたのか当時は知らなかったが、そしてその家の相応な構えなのにもかかわらず馬鹿にけちだったところから後では高利貸かとも想像していたが、こんど行って聞いて見ると新発田第一の大地主だった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、横罫の厚い紙の面には、きっと寄附金の受取りに必要な、金額や会の主だった人の名や目的が刷って有るのでしょう。",
              "citation": {
                "source": "私の見た米国の少年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ君、工場の主だった者あ毎晩のように芸者買いさせとるんだから、と云った。",
              "citation": {
                "source": "くちなし",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主だった神官の一人がのりとを読んだ。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、その婦人たちのなかでも主だった人と目されている一人が傍の友達に次のようにいったそうだ。",
              "citation": {
                "source": "ものわかりよさ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉捷夫そのほか、いくたりかの人は、かりにも日本の主だった文学者があつまったファシズムに抵抗するために協力を語ろうとする席に、そのときのような空気は予期しなかったと失望を洩したのだった。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の政府の政治家の主だった者たちのほとんどはこの士族のための藩校の出身者たちです。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その学生は、帽子も被っていない丸坊主だったが、いきなり僕が頭を出している二階を見上げるとヒラヒラと右手をあげてうちふった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私の今お話しするさわぎが起こった年から五十年ほど前に、町のおもだった人々が、その聖者の尊像をないしょで町から持ち出して、五、六里もはなれた所にある高い山の中にかくまってしまったのです。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
