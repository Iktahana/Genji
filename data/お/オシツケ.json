    "definitions": [
      {
        "index": 1,
        "gloss": "imposition (i.e. of rules, of a decision)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
