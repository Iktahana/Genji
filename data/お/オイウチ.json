    "definitions": [
      {
        "index": 1,
        "gloss": "attacking a fleeing enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どうだ参ったか」　鼈四郎は追い討ちしていい放った。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでおひつ炊飯器や電気ザブトンを見せられて追い討ちをくらったオレは、生来の想像力の貧困にもかかわらず「時代は変わる」と唐突に確信してしまったというのが今回の御粗末だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "気勢に乗った七福神組は、追い討ちに後を追っかけたが、心配したのは松代である。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひょっと致すと敵の奴ばら、退散したのではござらぬかな」「逃がしては一大事じゃ」「追い討ちをかけようではござらぬか」「さようさ。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の姥の眷族や、姥に味方して戦っていた、ここの大藪地の住人の、野武士や非人や盗賊の群れは、六波羅勢と同じように、移動する松明にたぶらかされ、飛天夜叉組落ちると観じ、追い討ちにかける気でその方角へ、いずれも馳せて行ったらしい。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「背後より大弥太の手の者など、追い討ちかけないものでもなし、わたし殿陣仕ると、このように申して彦四郎は、わざとおくれましてござります」　八郎は一揖してお答えした。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から玉置の荘司の勢が、追って来る様子もなかったので、さては先刻この方面へ落ちよと、声をかけてくれた声の主が、これも先刻云ったように、玉置の荘司の勢を遮り、追い討ちさせないに相違ないと、感謝せざるを得なかった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あの篝火の衰え様では、明日退陣と見てよかろう」「…………」「一戦も交えず正成をして、退かせましてござりますと、これを功にして京に帰らば、公綱の面目は立つからのう」「これは御意にござります」「公綱としてはわしを追い討ち、この陣を破りたく思ってはいようが、それにしては兵が少なすぎる。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と無慈悲な追い討ちをかけた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏勢は、勝に乗じて、馬の太腹がつかる当りまで海に馬を乗り入れて、平家の小舟を追い討ちした。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "義経ら八十余騎は、渚伝いに志度へ追い討ちをかけた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏はこれを聞き残念がったが、船がなくてはどうすることもできず、もう追い討ちをかけようともしなかった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家を追い討ちにするには今こそ、という意見もあったが、後方もまだ固まらず不安である、と頼朝は兵を収めると駿河から鎌倉へもどった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、本隊が留守だと見て取って、もしかすると追い討ちと来るかも知れねえから、やっぱり皆に出かけて貰わねえじゃなるめえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "摺れ違って、二三歩後ろの方へ、スタスタと行く相手へ、追い討ちに一と太刀、「え――ッ」　存分に浴びせるはずの手は、思わず宙に釘付けになりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしばしば叛乱将校の個人に関する噂話などを、何かにつけやりだしたり、口ぎたなくかれらの罪状に追い討ちをかけたりして、心ある塾生たちの反感を買った。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、本隊が留守だと見て取って、もしかすると追い討ちと来るかも知れねえから、やっぱり皆に出かけてもらわねえじゃなるめえ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで蟹江は追い討ちをかけるように、言葉をつぎました。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは松崎平馬から、早水秀之進の使命がどんなものか聞いたばかりなので、新島八十吉が追い討ちにやられたという話にひどく憤慨した。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このまえのときには、寺池の横車がとおった、明らかに寺池の非分だったのを、どういうわけか涌谷は旗を巻いた、こんどはそれに対して寺池が追い討ちをかけたのだ」　――新たな件ではございませんか。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟弱外交の賛成者としては、どうかね」「それは昔のことですよ」と砂馬が取りなすように、「今の猪沢さんは対支強硬論者だ」　黙って口をつぐんでいる猪沢に、客は追い討ちをかけるみたいに、「商売上からそうなったのか」「矢萩さんにかかると、ボロクソだね」と猪沢は笑った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "へどもどする刑事に、「陸軍だよ」と俺は追い討ちをかけた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それっ、追い討ちにかかれ」「焼き立てろ、火攻めに移れ」　良兼の部下は、余勢を駆って、さらに、豊田郷の深くに進攻し、放火、掠奪、凌辱など、悪鬼の跳躍をほしいままにして、その日の夜半頃、筑波へひきあげた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小僧ッ――」と追い討ちにのびた蔦之助の烈剣に、あわや、竹童まッ二つになったかと見れば、切ッ先三｜寸のところから一｜躍して四、五｜間も先へとびのいた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぷウッ……」　と唇へ流れ込んだ血を吹いて、不意の助太刀をくわッと睨んだ小六が、追い討ちの大刀をふりかぶって飛びついたが、御方はそれに眼もくれず、今度は、こんがらの真正面の敵｜臂の久八へ斬りつけて、戞然とたッた一合、見る間に、相手の鍔を割って、ばらッと柄手の指を斬り落す。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど、瀕死の状態にまで撃攘されていた山県昌景の隊とついに合流して、その当面の敵軍――越後の柿崎隊の勝ちほこっていたものを――見るまに反撃し、追い討ちし、潰乱せしめた。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手配を」「追い討ちをッ」　と、すぐ諸方へ伝令を飛ばしながら、木下勢を追いかけた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、「いまに慌てふためいて、総勢、退軍しはじめるから、そこを追い討ちすればよい」　と、晏如としていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして即座に、鳥居元忠、渡辺｜守綱の二臣に、手勢をさずけて、追い討ちをかけた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
