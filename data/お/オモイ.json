  {
    "uuid": "cbb59dc1-d440-5d4d-8701-eb422292e86e",
    "entry": "思い",
    "reading": {
      "primary": "おもい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thought",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私あの家、面白いの家と思いました』と幾度も繰返して口惜しがった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどにも情深く、心根のやさしい人があるかと思い、ヘルンに対して、何かいじらしく涙ぐましいものさえも感じたというのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か心配でもあるのかと夫人が聞いたら、あまり楽しくて嬉しいので、いつまでこの家に住み、いつまでこんな幸福が続くかと思い、それがまた心配になって来たと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋の日に、庭の桜が返り咲きをしたのを見て、『春のように暖かいから、桜思いました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その時の大興奮は、いまでも、私の最も貴重な思い出の一つになっているのである。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　実につまらない思いで、私ひとり、黄昏の海を眺める。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと一人、くらい境遇に落ち込んだ場合、その肉親のうちの気の弱い者か、または、その友人のうちの口下手の者が、その責任を押しつけられ、犯しもせぬ罪を世人に謝し、なんとなく肩身のせまい思いをしているものである。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病弱を美しいと思い描いたことがなかったか。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて彼と銀座で逢い、「なんてまあ哀しい男だろう」と思い、私も、つらくてかなわなかった。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど、まとめて一本にしたのを機会に、感想をお書きなさい、その他の作品にも、ふれて書いてくれたら結構に思います、というのが編輯者、辻森さんの言いつけである。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、目がさめて、その映画を思い出したら、嗚咽が出た。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、思い出して、また泣いたというのは、流石に、この映画一つだけである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを、どうお思いでしょうか。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しつけのよい家庭を維持しながら、よい仕事も出来るという政治家もあってよいと思います。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、兄は、それが出来るかも知れない極めて少数のひとの一人だと思います。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ複雑にくすぐったく、私は、恥ずかしい思いである。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、思いちがいしていた。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "など叫喚して手がつけられず、私なども、雑誌の小説が全文削除になったり、長篇の出版が不許可になったり、情報局の注意人物なのだそうで、本屋からの注文がぱったり無くなり、そのうちに二度も罹災して、いやもう、ひどいめにばかり遭いましたが、しかし、私はその馬鹿親に孝行を尽そうと思いました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人も、たいていそんな気持で、日本のために力を尽したのだと思います。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を思いつくのは私の宿命です。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と大声が出て、立って居られずぺたんと草原に坐って、思い切って泣いてしまいました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、妹の不正直をしんから憎く思いました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねに、自身にできる限りの範囲で、それを為し遂げるように努力すべきだと思います。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、あまりの恥ずかしさに、その手紙、千々に引き裂いて、自分の髪をくしゃくしゃ引き※ってしまいたく思いました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いても立ってもおられぬ、とはあんな思いを指して言うのでしょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身も世も、あらぬ思いで、私は、すぐには返事も、できませんでした。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいぶかしく思いながらその後姿をそれとなく見送り縁台に腰をおろすと、馬場はにやにやうす笑いして言いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、帽子をあみだにかぶっても気になるし、まぶかにかぶっても落ちつかないし、ひと思いに脱いでみてもいよいよ変だという場合、ひとはどこで位置の定着を得るかというような自意識過剰の統一の問題などに対しても、この小説は碁盤のうえに置かれた碁石のような涼しい解決を与えている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
