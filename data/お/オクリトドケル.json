    "definitions": [
      {
        "index": 1,
        "gloss": "to send to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "新吉は此の装飾の下に雑沓の中でカテリイヌを探す自分のひと役を先ず頭に浮べたが次にリサがまたどういう工夫で今日の祭の街で自分に新らしい娘を送り届けるのか。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一揆等は氏郷に対して十分｜畏れ縮んで居り、一揆の一雄将たる黒沢豊前守という者は、吾子を名生の城へ人質に取られて居るのを悲んで、佐沼の城から木村父子を名生に送り届けるから交換して欲しいと請求めたので、之を諾して其翌月二十六日、其交換を了したのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレのごとき怠惰で残酷な客に、内に秘めた原石の輝きを送り届けるには、やはり自ら化けてもらわざるを得ないのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "、此処まで来てゐながら、国にも帰れずに、Ｆの埠頭まで貴方を送り届けると、そのまゝすぐ元の方へ引返さなければならないのではありませんか。",
              "citation": {
                "source": "海をわたる",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申せばもうおわかりでござりましょうが、ひと重のしごきをわざわざ二重の袋仕立てにしたというのも、じつはその袋の中へてまえからの文を忍ばせて、首尾よく送り届ける仕掛けのためのくふうでござりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "関雪氏はいい気になつて、宿まで送り届けるからといつて、厭がる麦僊氏を無理強ひに出迎への自動車に積み込んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、伝令兵を呼んで、この男を本籍地へ送り届けるようにしろ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の落着先が判れば托された品を次の便船で送り届ける事が出来ると思ったからである。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大阪では宇和島というあの侍に、ひどい目に逢ったのう」「ミッシリ峰打ちに叩かれて、ぶざまに気絶をいたしました」「本来はあいつを味方に引き入れ、平野屋から加賀屋へ送る品物――凄く高価な品だというから、いずれは腕利きの人物に持たせ、送り届けるに相違ない。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上様は先程息がきれましたというから、この儘では置けないというので、御領主様へ届けると、敵討の事だからというので、孝助は人を付けて江戸表へ送り届ける。",
              "citation": {
                "source": "怪談牡丹灯籠",
                "author": "怪談牡丹灯籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から、軍司令部へ送り届ける。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "拠なく丑松は送り届けることにして、ある時は右の腕で敬之進の身体を支へるやうにしたり、ある時は肩へ取縋らせて背負ふやうにしたり、ある時は抱擁へて一緒に釣合を取り乍ら歩いた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔つて居る敬之進を家まで送り届けることにして、一緒に雪道を歩いて行つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　斯う引受けて貰ひ、それから例の『懴悔録』はいづれ東京へ着いた上、新本を求めて、お志保のところへ送り届けることにしよう、と約束して、軈て丑松は未亡人と一緒に見送りの人々へ別離を告げた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "生糸売り上げの利得のうち、小判で二千四百両の金を遠く中津川まで送り届けることが寛斎の手に委ねられた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな街道筋の混雑する時で、それを送り届けることも容易でない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらんなさいな、織って、染めて、それから先方へ送り届けるんじゃありませんか。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆吉を送り届けると、周平はそのまま帰ろうとした。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、自分のことさへどうでもよけりや、君を家へ送り届けるなり、警察へ引渡すなりする処だ。",
              "citation": {
                "source": "命を弄ぶ男ふたり（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "モニカを無事に岸まで送り届けるには、どのみち、できるだけ大勢｜助人があるほうがいい。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は、それからせっせと仕事に励み、実費以下にしてもらった費用を半年後に、無事送り届けることができたのである。",
              "citation": {
                "source": "生きているコタンの銅像",
                "author": "――アイヌの慈父・高橋房次――",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｕ君はその原稿のゲラ刷をちょうどいまパリにいるＡ君のもとへさっそく航空便で送り届けるだろう。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅を申せ、見送り届けるであろう。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも郵便で送り届けるのであるが、そのためには、目方のかゝらない、嵩張らない紙質で、強靭なものゝ方がよいのである。",
              "citation": {
                "source": "文房具漫談",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどひどい神経衰弱だったらしく、知り合いの後藤という津山の医者が、好意から父の所持金を預かって、後で送り届けるような方法がとられたそうである。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十年前、稲妻組と言った三人組の泥棒が、常盤橋で金座の後藤から勘定奉行へ送り届ける六千両の小判を盗ったが、極印が打ってないので費うわけに行かなかった、――それにしても、賽銭箱へ金を匿すという悪智恵には驚いたよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、まず当座の慰安として書籍五百冊を送り届ける準備を整えている。",
              "citation": {
                "source": "十三夜",
                "author": "――マニラ籠城日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ迷惑千万ながら、兵馬としては、やはりこの駕籠を江戸まで送り届けることを、ともかくもしなければならないなりゆきになってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかに能登守の本邸へ送り届けるわけにはゆくまいし、さりとて、江戸はこの女の故郷ではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その金は、そっくり故郷の足利にいる妻子に送り届けることにしておいて、またも例の額面と睨めっこです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
