    "definitions": [
      {
        "index": 1,
        "gloss": "to rake over the coals",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「to rake over the coals」である。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「to rake over the coals」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「to rake over the coals」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "to rake over the coals」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "七　灸治　子供の時分によくお灸をすえると言っておどされたことがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では子供をおどかすのに、お灸をすえるぞ、という脅迫の言辞を慣用するところを見ても、お灸は自発的にやらない限り愛嬌のあるものではない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、唯単に、悪い事をした者に、こらしめのためにお灸をすえると言う意味に、また、その程度にとどめて置いてはならぬ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが水疱瘡を治すには、おきゅうがいいということであったのだが、現人神たる玉体におきゅうをすえるということは許されないという異議が出たために、ついに譲位をなさって、おきゅうの治療を受けられた。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
