[
  {
    "uuid": "4988c193-f271-59f3-8a3d-493dfcfe1566",
    "entry": "戦く",
    "reading": {
      "primary": "おののく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
      ],
