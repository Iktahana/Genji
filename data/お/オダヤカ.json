        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "浪が穏やかで船の揺れぬ時でもこの微動だけは免れぬ不愉快である。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかな日光が広い園にいっぱいになって、花も緑もない地盤はさながら眠ったようである。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度見ても寝顔は穏やかに静かで、死という色ざしは少しもない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかで、パッシイヴで、そしてどこか涼しい感じのする人であった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどたれあってこの老人を気に留める者もなく、老人もまた人が通ろうと犬が過ぎ行こうと一切おかまいなし、悠々行路の人、縁なくんば眼前千里、ただ静かな穏やかな青空がいつもいつも平等におおうているばかりである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道や教えを宣べ伝えるという事は、取りようではたいへん穏やかな仕事のように思われる。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同じ事でもプロパガンダというとなんだか少し穏やかでないような気持ちがする。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般的に宣伝というものの手段方法が必ずしも穏やかで物静かであってはいけないという事は考えられない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと穏やかでないものならいくらでもあることは言うまでもない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点でも市会議員の選挙運動などよりはよほど穏やかでいいものである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に静かな穏やかな朝であった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな声で穏やかに何か云っていたが、結局別に新しい切符を出して車掌に渡そうとした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は相手の今までの話を、そうおもしろがってもいないが、そうかと言って全然興味がなくもないといった穏やかな表情で耳を傾けていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを極まり悪そうにもしないで、彼の聞くことを穏やかにはきはきと受け答えする。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない穏やかなある日あの火口丘の頂に立って大きな声を立てると前面の火口壁から非常に明瞭な反響が聞こえた。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると今まで針のように鋭くなっていた自分の神経は次第に柔らいで、名状のできない穏やかな伸びやかな心持ちが全身に行き渡る。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は蒸暑い雲が湧きいでて、雲の奥に雲が隠れ、雲と雲との間の底に蒼空が現われ、雲の蒼空に接する処は白銀の色とも雪の色とも譬えがたき純白な透明な、それで何となく穏やかな淡々しい色を帯びている、そこで蒼空が一段と奥深く青々と見える。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは穏やかな罪のない眠りで、夢とも現ともなく、舷側をたたく水の音の、その柔らかな私語くようなおりおりはコロコロコロと笑うようなのをすぐ耳の下の板一枚を隔てて聞くその心地よさ。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言った文造の心は何となく穏やかでなかった。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『死ぬるほどの傷を受けた人はちょうどこんなふうに穏やかなものさ』とかれは思った。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるから、自分の目には彼が半身に浴びている春の夕陽までがいかにも静かに、穏やかに見えて、彼の尺八の音の達く限り、そこに悠々たる一｜寰区が作られているように思われたのである。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなんの歌だかわからないが、二部の合唱で、静かな穏やかな清らかな感じのするものであった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして伊吹の見える特別な日が、事によると北西風の吹かないわりにあたたかく穏やかな日にでも相当するので、そういう日に久々で戸外にでも出て伊吹山を遠望し、きょうは伊吹が見える、と思うのではないかとまで想像される。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　＊　　　　　　　＊　寒く、淋しく、穏やかに、晩秋の田園の黎明が来た。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠らのある者は沈痛に、ある者は憂慮わしげに、はたある者はあわただしげに、いずれも顔色穏やかならで、忙しげなる小刻みの靴の音、草履の響き、一種｜寂寞たる病院の高き天井と、広き建具と、長き廊下との間にて、異様の跫音を響かしつつ、うたた陰惨の趣をなせり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は姉と二人きりで、何年か前に、青い穏やかな海峡を渡って、この街へ来たのであった。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも懐素のような奇怪な又｜飄逸なものではありません、もっと柔らかに、もっと穏やかに、そうして時々粋な所を仄かすといったような草書です。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏やかな秋の陽射しの中に伸び伸びと枝葉を拡げてゐる萩。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有難いことぢや、しかしな、わしにはこの本堂で沢山ぢや、一つには、この古色を帯びたところがわしの好みぢや、それからまたわしとこの本堂とは、また格別な因縁もあるのぢや」　老師は穏やかに宗右衛門の言葉を退けた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しん、とした此の光線の落ち著きのなかに、穏やかに明るく画像は彼の前に展けた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
