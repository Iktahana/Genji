    "definitions": [
      {
        "index": 1,
        "gloss": "top (of a flight of stairs)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見せ申すべきものありとて、われを本堂の内陣に誘ひ、壇に登りてマリア像の肩に両手をかけ、おもむろに前へ引き倒ふすに、その脚の下の蓮台と思しきものの辺、左右に引き開け、階段の降り口、大きく開けたり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡持を提げた女房の体は、勾配の急な坂をおりて、坂の降り口にあるお寺の石垣に沿うて左へ曲って往った。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手にしろ、おッ母さん、とんだお邪魔をしました」　薊は身を飜して降り口へ出る、母はあとからすがりつく、お千代も泣きつく。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は着物を着換えて、奥の下座敷へたずねて行こうとすると、階下の降り口で宿の女中のうろうろしているのに逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "山祝いの夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして階子段の降り口の所でつやに食い止められてしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しかうなると僕も少々気になり始めたので、机の前を離れてそつと階段の降り口に忍び寄り、階下の様子を窺つた。",
              "citation": {
                "source": "晩秋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川はズブぬれの身体を、元気よく起すと、先刻上って来た降り口の方へと闇の中へ消えて行った。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その降り口の交番の巡査がその女に敬礼をしたから、これは珍だとついて行ったら、或る門構えの家へ這入った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い機関室への降り口で、漁夫と水夫が固り合って騒いでいた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅川監督　　　　　　　　　　　　　　　　　　　　　雑夫長　この大きなビラが工場の降り口に貼られた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その降り口が丁度「ラバー小屋」になっていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして降り口は一つしかなかった。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――普段から職工仲間に信用のある「細胞」を階段の降り口に立たせて置いて、職工を引きとめた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はとつぜん鍵穴から眼をはなし二秒ほどその場に電気にでも打たれたようになってじっとしていたが、女中が階段を上がってくる跫音を聞くと、やっと起ち上がって、しのび足で、階段の降り口まで歩いて行った。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の降り口は石逕になっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかり過ぎて、盛装した娘は林檎の食いあましの皿を持って階下へ行こうとしたが、段々を二つ三つ降りたかと思うと、足をふみ辷らせたと見え、「ドドドン」という音が家内中に響き渡ったので、青年も校長夫人も、思わず立ち上がって階段の降り口へ駈けつけたそうだ。",
              "citation": {
                "source": "段梯子の恐怖",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は階段の降り口の上で参木の片腕をつかまえた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の降り口にある乾き切った石段の横手の芝なぞもそれだ。",
              "citation": {
                "source": "秋草",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の降り口にある乾き切つた石段の横手の芝なぞもそれだ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャペルの扉の外から階段の降り口へかけて休憩する人達が集っていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがた部屋にいる時も、ふいに電話がかかって女中の取次ぎで下へおりて行ったが、やがて部屋へ来て坐ったと思うと、間もなく廊下へ出て行き、しばらく帰って来ないので、庸三が胡散に思って出てみると、葉子は階段の降り口を偸むようにして、うろうろしているのだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段の降り口に来ると、スーラーブはそのまま黙ってシャラフシャーの肩から手を離し、先に立って段々を降りた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バスを降りようとすると、沢山の支那人が降り口に押し合っていて年寄りの私などなかなか降りることが出来そうもない。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ、御ゆるりと」　敷居のところへ片手をついてこう辞儀をすると梯子段の降り口の唐紙をぴたりと閉めて下った。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はちょうど軌道の降り口のまっ正面に座席をひとつ取って、そこをたった一人で占領した。",
              "citation": {
                "source": "或る精神異常者",
                "author": "モーリス・ルヴェル",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の降り口の所で、塩野は自動電話のボックスを見付けると矢代を外に残して中へ入った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（乙）被害者千世子は同夜午前二時――三時の間に、背面より絹製の帯締を以て絞殺され、寝具を蹴散らし、畳の上を輾転して藻掻き苦しむなど、甚しき苦悶の跡を残したるまま絶命せるものを、更に階段の処に持行きて手摺より細帯にて吊し下げ、階段の降り口に正面させて縊死と見せかけたる事明らかなり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあとから続いてぞろぞろと出て来た十名の先に立って、階段の降り口の処まで来ると、懐中電燈の光りで床の上の女の靴痕を指し示して、「これをよく御覧なさい」　と云った。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "癪に障るから後姿を睨み付けてやりましたら、その痘痕面の奴がひょいと降り口で振り返った拍子に私の顔を見ると、慌てて逃げるように降りて行きました」「ハハハハ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "折口は、木津の地では、一切おりぐちと濁つて言ふ事はない。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
