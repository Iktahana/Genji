        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お近づきのしるしに、乾杯！",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく、お近づきになったのですし。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く立話をしているうちに、お貞が「あなた岡田さんがお近づきですね」と云った。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お近づきのしるしとして、お父さんの家の晩ごはんによぶことにしました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「先生とは、もうお近づきの光栄をいただきました。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご令息とお近づきになっても？",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が地方に土着した田舎者だといっても、その古い縁故でお近づきは許してくださるだろう」　などと入道は言っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてお近づきになったものだから、私の為にその箱をあけて、青蛙神を一度拝ませてくれませんかね。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみはおかみさんのお近づきの方の世話で、おかみさんの立たれるのと共に、さし向或西洋人のところに子供のお守に這入つて、そこに七八箇月ゐた後に、青山にゐる養母のつてで、この間まで四年足らずの間、山の手の、或、外務省に勤めてゐられる人の邸へ小間使ひに上つてゐた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪気に寒いようだから、お近づきのしるしにお関取りといっしょで寄せなべでもつつこうじゃねえか」　言いおくと、ふところ手の中からあごをなでなで、ゆうぜんと歩み去りました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "控えろッ」　鳴りだそうとした出鼻を、やにわに頭が高いとしかりつけられたので、なにごとならんかとちぢこまりながら、おそるおそる伺うと、頭の高かったのも道理、こちらへ急ぎ足でお近づきになってきたのは、だれならぬ名宰相｜伊豆守です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは明け放した障子の敷居のところに胡坐をかいて、いろいろな世間話をしましたが、突然紳士は真面目な顔をして、「今日、一緒に風呂へお入りになった女の人はお近づきなのですか」　と訊ねました。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上糸子とあなたとはお近づきなのですか」「はあ、川上さんは一週間に一度か二度は必ず美容術を受けに見えます。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕があなたとお近づきになったことで、もしあなたに御迷惑をおかけするような結果にでもなりますなら、どうぞ、御遠慮なく仰言って下さい。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに仰有るからには、此方様は何でも仏蘭西の兵隊さんにお近づきでもお有りになるんぢやありませんか。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『知る人ぞ知る』（色をも香をも）」　こう子供に言いながらまた、大納言は、「光源氏がいわゆる盛りの大将でいられた時代に、子供でちょうどこの子のようにして始終お近づきしたことが今でも私には恋しくてなりません。",
              "citation": {
                "source": "源氏物語",
                "author": "紅梅",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも明るくなっていくことは恐ろしくて、「お近づきしてかえってまた飽き足りません感を与えられましたが、もう少しおなじみになりましてからお恨みも申し上げることにしましょう。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛頭栴檀の香とかこわいような名だけれど、私たちは大将様にお近づきできることで仏様のお言葉に嘘のないことをわからせていただきました。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮様が一度お近づきになった以上、ここにおいでになってよいことはございませんよ。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、こんな御縁でお近づきになれて、大変うれしいんです。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実業家や学者にもお近づきがあるでしょうから。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではありますが狭山様は成るべく危険な区域にお近づきにならぬようにしてあげねば……という志村未亡人の御注意がありましたのでその方の手配を嬢次君とお母様の思い通りにして頂く事にして計画を立てました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お近づきがまことにござりません。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあし男さんにはお近づきにならなかった。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとお近づきに」秀子は近くへ進みより。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた様のお力にて、江戸一ばん、心強い御贔屓さまがたのお近づきになれまして、一生の面ばれ、御恩は決して忘れませぬ」「そのように申してくれると、わしも何ぼうかうれしいのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒などと申すものは、みな、気持に後れがござりますゆえ、案じたものではありませぬ」「でも、これからは、決して、そのような危い場所に、お近づきなされてはなりませぬぞ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はあなたとお近づきになれて、とても嬉しいんです。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するに、プルウストの御婦人とのお近づきぶりは、君にちよつと勇み肌をつけたすと、ほぼ同じ恰好になるらしいですね。",
              "citation": {
                "source": "かげろふ談義",
                "author": "――菱山修三へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや、だれか大奥お坊主衆におちかづきはござりませぬか」「あるとも！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
