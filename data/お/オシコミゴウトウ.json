          ],
          "literary": [
            {
              "text": "スコットランドで押し込み強盗をしたと思えば、次の週はコーンワルで孤児院の設立資金とかぬかして金を騙し集めていたりしやがる。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくするとあなたが私の所へ来て、押し込み強盗の話をしました。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生は、野暮な押し込み強盗よろしく、アネットの寝室に忍び込み、持ち物を調べるなんて御免こうむりますよ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし押し込み強盗をやらかすのなら、阻止に間に合った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
