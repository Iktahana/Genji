          ],
          "literary": [
            {
              "text": "嘘言も不人情もお互い様よ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ急に出そうもない」と一人が呟けば、田舎女房と見えたるがその前面にいて、「憎々しく落ち着いてるじゃありませんかね」　最初の発言者はますます堪えかねて、「ときに皆さん、あのとおり御者も骨を折りましたんですから、お互い様にいくらか酒手を奮みまして、もう一骨折ってもらおうじゃございませんか。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "困った事が起った時には、お互い様さ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お留守ですか……それはかえって好都合でした……もう夏らしくなって来ましたね、隣の薔薇も咲き出すでしょう……遠いようだがまだ去年の事ですねえ、お互い様に太平洋を往ったり来たりしたのは……あのころがおもしろい盛りでしたよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塗師重兄弟も嘆息しながら、「まずお互い様に生命に別条なく不幸中の幸い……しかし、我々は逃げ損くなって実に酷い目に逢いやした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "焼け跡の身惨なはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、民主主義とかいろいろなことが申されておりますけれども、私共は何しろお互い様にこの五ヵ月ほど前には、見ざる、言わざる、聞かざるででくの坊になって暮していたのです。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「う、ただお互い様もたねえのでな。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、財産を独占するために、ボクを殺しさえしなければね」「お互い様よ。",
              "citation": {
                "source": "影のない犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪党のわりに垢抜けねえや」「お互い様さ、不思議はねえ」　宗俊はノコノコ歩き出した。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "介抱するのもされるのも、お互い様のことじゃないか。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ればつまり、日支国民はお互い様ということになるのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互い様に薄気味悪くなるのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ちゃんと着いているのはお互い様に助かります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "御幣をかつぐ訳じゃないが、物は縁起ということもあるし、お互い様に明日の首の座は分らない。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が会いたがっております」「えーと、たしかコベントリさんでしたね、お互い様ですよ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋肉質で大柄な男プレスコットを好きになり始めたが、それはお互い様だった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前には二度と会いたくなかった」「お互い様ですよ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、君を見つけたときは驚いたなあ」「お互い様ですよ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも朝夕、御奉公大事と思う、お互い様のことでな。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやお互い様に」　と、西と東へ袂を分った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがお互い様のこった、そんな詮議立てはやめとして、時に、てめえ今夜はどこへ行ったんだ」「あっしですか」「そうよ」　九兵衛の眼ざしに、寺男の八助はまごついて、生酔の首を振りうごかしながら、「このとおり、ちょっと馴染みの家へ、飲みに行った帰りなんで」「ばかをいえ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみませんです、ほんとにご親切様な」「どういたしまして、お互い様ですもの」「おかげ様で今夜ばかりは」「おう、外へ出るといい気もち――赤児もスヤスヤ寝ていますよ」「まア、のんきなものでございます。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度はおたがいさまに、飛んだ迷惑で困りました。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レポート提出はおたがいさま」　と、柾生がうけあう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おたがいさまよ、それは。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおたがいさまに、得のいくことではないのです。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたがいさまだ」　戸倉老人が、はじめて口をきいた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々は、外へおいでになることがおたがいさまに保養でございます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おたがいさまに、よかつたですな。",
              "citation": {
                "source": "燃える電車",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎ちゃんのお母さんも、お父さんも、はじめてそのことを知って、すぐにいいお返事もできず、ただおたがいさまどうしですからと、笑っていられました。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
