          ],
          "literary": [
            {
              "text": "東大寺の大きな鐘楼の傍から、石段を降りますと、「大湯屋」という古い建築物に突き当ります。",
              "citation": {
                "source": "「奈良」に遊びて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良で大湯屋の辺を歩いたときのとおり、生活の余韻をしみじみと感じた。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "為勧進方沙汰、以大湯屋門扉等、暫時渡橋訖。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
