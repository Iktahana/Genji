[
  {
    "uuid": "9805d010-9afd-5b93-9bf8-ae6d71c67aee",
    "entry": "お母様",
    "reading": {
      "primary": "おかあさま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
