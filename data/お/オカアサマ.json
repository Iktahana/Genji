    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母は毎日朝早く起きる。",
              "source": "幻辞"
            },
            {
              "text": "母の料理は美味しい。",
              "source": "幻辞"
            },
            {
              "text": "母が心配してくれている。",
              "source": "幻辞"
            },
            {
              "text": "母との時間を大切にしたい。",
              "source": "幻辞"
            },
            {
              "text": "母の教えが人生の基礎になった。",
              "source": "幻辞"
            },
            {
              "text": "母に感謝の気持ちを伝える。",
              "source": "幻辞"
            },
            {
              "text": "母の優しさに甘えたい。",
              "source": "幻辞"
            },
            {
              "text": "母が応援してくれているおかげ。",
              "source": "幻辞"
            },
            {
              "text": "母のアドバイスを聞く。",
              "source": "幻辞"
            },
            {
              "text": "母になる覚悟を決める。",
              "source": "幻辞"
            },
            {
              "text": "母との関係が深まった。",
              "source": "幻辞"
            },
            {
              "text": "母の言葉を思い出す。",
              "source": "幻辞"
            },
            {
              "text": "母のようになりたい。",
              "source": "幻辞"
            },
            {
              "text": "母が懐かしい。",
              "source": "幻辞"
            },
            {
              "text": "母に助けてもらった。",
              "source": "幻辞"
            },
            {
              "text": "母の手作りが好きだ。",
              "source": "幻辞"
            },
            {
              "text": "母を大事にしよう。",
              "source": "幻辞"
            },
            {
              "text": "母の声を聞きたい。",
              "source": "幻辞"
            },
            {
              "text": "母と久しぶりに会う。",
              "source": "幻辞"
            },
            {
              "text": "母の苦労が報われた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私たち二人は、今から、あの大きな船の真正面に在る高い崖の上に登って、お父様や、お母様や、救いに来て下さる水夫さん達によく見えるように、シッカリと抱き合ったまま、深い淵の中に身を投げて死にます。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、お父様と、お母様に懐かれて、人間の世界へ帰る、喜びの時が来ると同時に、死んで行かねばならぬ、不倖な私たちの運命を、お矜恤下さいませ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様からも人間からも救われ得ぬ哀しき二人よりお父様お母様皆々様◇第二の瓶の内容　ああ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、外衣も裏衣も、雨や、風や、岩角に破られてしまって、二人ともホントのヤバン人のように裸体になってしまいましたが、それでも朝と晩には、キット二人で、あの神様の足※の崖に登って、聖書を読んで、お父様やお母様のためにお祈りをしました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、それから、お父様とお母様にお手紙を書いて大切なビール瓶の中の一本に入れて、シッカリと樹脂で封じて、二人で何遍も何遍も接吻をしてから海の中に投げ込みました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人とも、聖書を、神様とも、お父様とも、お母様とも、先生とも思って、ムシメガネや、ビール瓶よりもズット大切にして、岩の穴の一番高い棚の上に上げておきました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い王様はその後、暇さえあれば森に行ってお母様に会うのを何より楽しみにしておりました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎さんと花子さんは、お父様とお母様に手を引かれて東京の近所のばあやの処へ逃げて来ました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様とお母様とは顔を見合わせて、「犬とお人形の夢を見ているのですよ」「どちらも焼けてしまっただろう。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、太郎さんと花子さんは二人揃ってお父様とお母様の前へ出て、「どうぞも一ペン東京に連れて行って下さい。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様もお母様も花子さんも驚いてみんな表へ出ますと、泥棒のようななりをした大男が犬に食いつかれて跛を引き引き向うへ逃げて行きます。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅で縫い物をしていらっしたお母様はお父様の様子に気がついて、どうしたのかと思って窓の外を見ると、猫は金魚をねらい、犬は猫のすぐ後に近寄り、坊ちゃんは犬のお尻を狙って引き金を引こうとし、お父様は坊ちゃんの襟を捕まえようとしておられます。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様はどうしてよいやらわからなくなりました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様はホッとしました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時お父様もお母様も坊ちゃんも楽しいお昼の御飯を食べていました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで面当てがましいような素振りさえするのでございます」「どんなふうにだね」「今日のお昼に、わたくしが、親身のような愛情を示そうと、試しに娘の食べかけの残したお菜に箸をつけようとしますと、娘はその皿を急に引ったくりまして、お母様、これは私の食べかけでございます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様のは、そちらにちゃんとございますと言って、その食べかけのお菜を猫にやってしまいました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間が迫るのに仕度をして貰うお母様も女中も帰らない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ちょうどそこへ、お母様がお見えになりました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やは大助りの思いで、お母様にこのわけを申し上げました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様は、お母様がふいにお出でになったので、びっくりして、ばったり泣きやんで、ぼんやりとしている二人を、しばらく見くらべていらっしゃいましたが、やがて婆やの袂のなかをのぞきこんで、しきりに子ひばりをお眺めになりました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、お、お」とそれをおいたわりになってからお母様は、「だがね、これはまだ親のひばりのお乳をほしがっている赤ちゃんひばりですよ。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やもまた、「さようでございますね、ですから、これは元の処へ置きに行ってやりましょう」と申しますと、「そうですとも、それがよい、それがよい、ね、一郎さん、たえ子さん」とお母様は、優しく優しくおさとしになりました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は便なげに、「お母様に叱られら。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様も家が貧乏な丈けにこれを聞くにつけてもお玉の美しいのがいぢらしくてなりませぬ。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見るとお母様は不図思ひ付いてこれこそ神様から娘によい着物を下さると云ふ体徴であらうと思ひまして其卵のかへるのを待つて居りますとやがて沢山の蠶が生れまして床の上を這ひ初めました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見るとお母様は直に隣りの金持ちの裏の畠から桑の葉を千切つて来て床の上に撒いて遣りますと蠶は皆桑の葉の香気を慕ひ寄つて来ましたから床の上に仕切をしてすつかり其中に集めてしまひました。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお母様は毎夜毎夜出て行つて隣の家の裏畠から桑を千切つて来ては蠶に遣りました、他所の物を盗むといふことは悪い事には違ひありませぬがお玉の可愛さが胸一パイになつて居るお母様の身に取つては善い事も悪い事も考へる隙がありませんでした。",
              "citation": {
                "source": "金銀の衣裳",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その失敗者が同じ失敗者のあなたをお迎えに来るなんて妙なわけですが、おかあさまがお気の毒なので、お頼みをそのまま引受けてお迎えに参りました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかあさまはわかったよ、あれねえ、ひきざくらの花」「なぁんだ、ひきざくらの花だい。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
