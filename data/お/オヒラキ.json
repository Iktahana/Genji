        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お開きについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お開きがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お開きというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお開きの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお開きが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お開きを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お開きの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お開きはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお開きがあります。",
              "source": "幻辞"
            },
            {
              "text": "お開きは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お開きについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお開きの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お開きの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお開きが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お開きについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお開きは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお開きについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お開きという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお開きの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お開きを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「さあ口をお開きなさい。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様が、烏は脚では受取らない、とおっしゃって、男が掌にのせました指環を、ここをお開きなさいまして、（咽喉のあく処を示す）口でおくわえ遊ばしたのでございます。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "箸を持って、婿をはさんで、アンとお開き、と哺めてやるような縁談ですから、否も応もあったもんじゃありません。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の中でお目にかかった事から、都合があってこちらで塾をお開きなさるに就いて、ちっとも土地の様子を御存じじゃない、と云うから、私がお世話をしてなんて、そこはね、可いように手紙を出したの、その返事、」　と掌に巻き据えた手紙の上を、軽く一つとんと拍って、「母様が可い、と云ったら、天下晴れたものなんだわ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）亀姫　ああ、お開き。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴下が御自分でなくっても、貴下が許して、錠前をさえお開き下さるなら――方法は択びません。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "命は弟宇迦斯が献上したごちそうを、けらい一同におくだしになって、お祝いの大｜宴会をお開きになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさかんなご宴会をお開きになって、そのお席で曾婆加里を大臣の位におつけになり、すべての役人たちに言いつけて礼拝をおさせになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまは声を立てておよろこびになって、いそいで、まどをお開きになりました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様が、烏は脚では受取らない、とおつしやつて、男が掌にのせました指環を、此処をお開きなさいまして、（咽喉のあく処を示す）口でおくはへ遊ばしたのでございます。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "らっこの襟巻の中から、長い尖った顔を出して、奥様がニヤリと笑っておいでのが、仰向けながらね、屹とお開きなすったお嬢さんの目に、熟と留ったとおっしゃるんですよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私の期待は外ずれて、貴女は仲々その堅い蕾を、お開きにならないように、私には思われたのでした。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、洗吉さんは子供のやうな事を仰りながら、帯の間の時計を見て、風呂敷包みを持つた手に洋傘をお開きになる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ、お開きにするか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お姿はふためと見られないむごたらしさで、両のお眼を、なにかまるで、ひどく凄いものでもご覧になったらしくカッとお開きになったまま、お眼玉が半分ほども飛び出して、お顔の色が土色に変わっているではございませんか。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、鳥渡お手を拝借」答「さあさあ夫れでは〆めましょう」御両人「シャンシャンシャンシャンシャンシャン……さあ、お開きになりました」",
              "citation": {
                "source": "大衆文芸問答",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎松も招ばれて末座に割のわるい一役をつとめさせられたが、お開きと共に折詰を下げてイの一番に帯刀の邸をとび出した。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようお座をお開きなされました。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある箇所で気分的に亢ぶったようなものがあると思うと、最後は、落語の下げのような文句が云われて問題は出発点へ逆もどりしたまま、おやかましゅう、とお開きになった形であった。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "客がみなお開きになってからも、それだけは新調したらしい黒羽二重の紋附をぬぐ間がなく、新郎の鶴さんは二度も店へ出て、戸締や何かを見まわったりしていたが、いつの間にか誰が延べたともしれぬ寝床の側に坐っているお島の側へ戻って来ると、いきなり自分の商売上のことや、財産の話を花嫁に為て聞せたりした。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもそのお客様は小型の鞄をもっていらっしゃいまして、それを台の蔭でお開きになり、それからニッケルを取出されましたが、応接台の上に二十枚ずつキチンと積みあげたものを私どもの目の前にお並べになりました。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の日お帰りになりましても一言も口をお開きになりません。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると瞽いたお父様のお眼が、急にポッとお開きになる。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此方が神経過敏になっているせいで、先方でも責任を重んぜられるが故に、無暗にお口をお開きにならぬのでしょう。",
              "citation": {
                "source": "職業の苦痛",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお開きといふことになつたが、家へ帰るものはほんの僅かで、多くの者は居残つて、大尉の家の広い庭で夜を明かすことにした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間ではかれこれいうが、吾々は見る所が違うぞ、失望するなと、いう趣意で、この歓迎会をお開き下されしことは、全く感謝の念に堪えません。",
              "citation": {
                "source": "人格を認知せざる国民",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家は、賑やかな事がお好きでございましたから、何かにつけて宴をおひらきなされて、皆の遊びたはむれる様をしんから楽しさうに、にこにこ笑つて眺めて居られます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひらきが済んで、他吉が〆団治といっしょに帰ろうとすると、次郎と君枝は引き止めて、「お祖父やん、今日は家で泊ってくれはれしまへんのんか？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、婚礼の席がおひらきになるころ、文吉は腹が痛み出した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の年を聞けば吃驚するほどの大年増の朋輩が、おひらきの前に急に祝儀を当てこんで若い女めいた身振りをするのも、同じヤトナであってみれば、ひとごとではなかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
