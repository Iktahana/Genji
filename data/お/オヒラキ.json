    "definitions": [
      {
        "index": 1,
        "gloss": "breakup (of a ceremony, wedding, party, meeting, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
