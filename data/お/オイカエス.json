        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いくら月夜でも、これから夜道を追い返すわけにも行くめえ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ひとりなら、無理も云えるのだが、といって、娘を追い返すわけにもいかない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、こんなまずい弁当を作ってくれたら、おれはもうこの女を東京へ追い返すことは出来なくなった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あんまり見っともない真似をすると、ほんとに追い返すわよ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一岩谷もあの時分お金に困っていたんだか何だか、解決するなら前借を払うのならいいんだけれど、そうでもないし、帰るも帰らないも私の肚一つだというんだから、わざわざお母さんまで来たのに、追い返すのもどうかと思って、一緒に帰ってしまったの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドケナ（如何なる）名士が来ても頭ゴナシに叱り飛ばして追い返すという話じゃったが、俺は南洲の遺愛の机の上に在る大塩平八郎の洗心洞※記を引っ掴んで懐中に入れて来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうどんなことがあっても、一通りの事情を話して、いやでも応でも、ホームズの助力を得ようと、その婦人は死に物狂いの決心をきめて来たので、引きずり出しでもすればともかく、さもなければ、もうとても追い返すことなどは出来そうも無い容子であった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が普通の押借りであるならば、一人｜頭五両ずつも呉れてやって、体よく追い返す目算であった番頭も、人間の首、殊に異人の首を眼のさきへ突きつけられて、俄かに料簡を変えなければならなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといっても親は泣き寄りで、まさかに情なくも追い返すまい。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、わざわざ来たものを、追い返すにも当らないじゃありませんか。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女も一度僕と会った以上、自分の用事丈が、済んだと云って、そう手軽に僕を追い返す権利はありません。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だいたい、ここは高志のうちじゃないんだから、追い返すわけにもいかないじゃん」　慶一は、この組合せが面白くて、ちょっと遊んでみたくなった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この論法で、きょうも不可ない、あしたも不可ないと云って、二度も三度も追い返すと、しまいには相手も飽きて、来なくなる。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は生ける天女のようなこの女人を、無下に叱って追い返すに忍びなくなった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは福の神はこの婆さんの内の門口まで行くのであるけれど、婆さんの方で、福なんかいらないというて追い返すような人相とも見える。",
              "citation": {
                "source": "熊手と提灯",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が御飯はと云って来たから、めしは後で食うと追い返す。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは明かに可笑しさのあまり駈け出して来ようとする泪を睫毛の境いで追い返すための努力を示していた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "追い返すことができないのですか」「破産してしまえば、オレのウチも、オレの物もあるものか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手になる房吉は、事情を知らないから、さすがに江戸の剣客は研究熱心、勉強のハリアイがあると大いに喜んで、毎日せっせとぶん殴っては追い返す。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いつも舐められていたくないから、タダ追い返すのは面白くない。",
              "citation": {
                "source": "神サマを生んだ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で餌物がなくなろうものなら、あの兇暴な人猿どもはまたもや遠慮会釈なく小屋へ追い返すに違いない。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢うて懲らしてさてその上で円坊主にして追い返すまでよ――して主馬之介、そちの眼には、邸を囲んだ討手の兵幾百騎ばかりに見ゆるかな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "命知らずの連中でね、追い返すことだって訳はありません。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、君の眼鏡で、全く見込みがないと思つたら、十分その非をさとらせた上で、田舎へ追い返すよう、くれぐれも配慮を頼む、というような、のつぴきならぬ交渉をして来た。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "怠けて腹いつぱいためて来ない奴がいると、番兵がいて、入口で追い返すんだぜ」「へえ、厳しいのね」「厳しいさ。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "少い手勢で雲霞の如き大軍を相手に戦って追い返すこと五、六度に及んだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中世以前の武家は、防禦工作物と住宅とは別であって、寄手を野外で追い返すことのできぬ場合には、きまってわが屋敷に火をかけて、後の山に駈け上って防戦をしたのに、だんだんと財貨が城下に集り経済組織が緻密になるにつれて、平日の生活を重んじた結果、城下の民を合せて防衛する必要が起った。",
              "citation": {
                "source": "家の話",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな怪しい客はおいかえすにかぎる。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はおんぼろ自動車を見られてはたいへんだと思い、道の途中でネッドをおいかえすのに骨を折らねばならなかった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
