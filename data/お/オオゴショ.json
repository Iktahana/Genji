        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "後進の能力を認めこれに信頼することの出来ない大御所的大家ではなかったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎楽堂氏は現代能評界に於ける一方の大御所で、単純率直、達弁の士である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二月七日辰刻、将軍家｜渡御中泉｜先献御膳｜暫有於奥之間大御所御対面本多佐渡守｜同上野介召御前｜御密談移刻」　四月初旬には、多くの諸侯に、出征準備の内命を発している。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度之御勝に罷成候へども大御所様御運つよきにて、御勝に罷成候」と『薩藩奮記』に出ている。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、冬の陣の当初、大阪方が堺に押し寄せた時、且元、手兵を派して、堺を助け、大御所への忠節を見せた、など『本光国師日記』に見えている。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんな不始末が大御所に知れてはどんなことになるかも知れない、とあって、彼等は、その場を繕うために、雑兵の首十三ほどを切取り、そこにあった真田の旗を証拠として附けて、家康に差出した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村はここで一先ず息を抜いて、その暇に、明石｜掃部助全登をして今宮表より阿部野へ廻らせて、大御所の本陣を後より衝かせんとしたが、この計画は、松平武蔵守の軍勢にはばまれて着々と運ばなかった。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし意味ありげな大御所のことばを聞いて、皆しばらくことばを出さずにいた。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "本多は何か問いたげに大御所の気色を伺っていた。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうお目見えをした者の中に大御所のお見知りになっている人はなかったかと問わせたのである。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "膳部を引く頃に、大沢侍従、永井右近進、城織部の三人が、大御所のお使として出向いて来て、上の三人に具足三領、太刀三振、白銀三百枚、次の三人｜金僉知らに刀三腰、白銀百五十枚、上官二十六人に白銀二百枚、中官以下に鳥目五百貫を引物として贈った。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその少しばかりの見所のある作品で奇怪なことには、画壇の大御所的地位を保つてゐるといふことが更に不審といへるだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて以来、叱られるなどという感情を夢にも経験したことのない主君に対して、大御所の激しい叱責がどんな効果を及ぼすかを、彼らは恟々として考えねばならなかった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大御所様には、今日越前勢が合戦の手に合わざったを、お怨みにござります」といったまま、色をかえて平伏した。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "速かに戦いを取り結びて然るべし、と大御所に伝えよ」と怒鳴った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、今は天下の諸侯の何人よりも真っ先に、大御所から手を取って歓待を受けている。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の将軍家｜家慶公は、前の大御所｜家斉が女の唇が好きだつたのと違つて、若芽薑が何よりも好物であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗白鳥は自然主義時代からの作家として今日も評論に小説に活動して一種の大御所のような風格をもった存在となっているのであるが「ひかげの花」について菊池寛の見解に反対した意見（十一月号『改造』）の中には、その矛盾においてなかなか教えるところがある。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケールの大きなこと、日本医学の大御所と云うべき処で、リベラリストとしての名も高い。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の洋画家で戦争に比較的動員されなかった人たちは洋画界の大御所である梅原龍三郎や安井曾太郎および軍部にとってまだ利用価値のなかった若い画家たちばかりである。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に大御所とよばれ、徳川幕府をひへいさせた近因だともよばれたほど、派手な時世だった。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の時世に、維新の元勲元帥の輝きを額にかざし、官僚式に風靡し、大御所公の尊号さえ附けられている、大勲位公爵を夫とする貞子夫人の生立ちは、あわれにもいたましい心の疵がある。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩年こそ謹厳いやしくもされなかった大御所古稀庵老人でさえ、ダンス熱に夢中になって、山県の槍踊りの名さえ残した時代、上流の俊髦前光卿は沐猴の冠したのは違う大宮人の、温雅優麗な貴公子を父として、昔ならば后がねともなり得る藤原氏の姫君に、歌人としての才能をもって生れてきた。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、」修理はじっと宇左衛門の顔を見ながら、一句一句、重みを量るように、「その前に、今一度出仕して、西丸の大御所様（吉宗）へ、御目通りがしたい。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大御所吉宗の内意を受けて、手負いと披露したまま駕籠で中の口から、平川口へ出て引きとらせた。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "古参は不審を起し、向島にそんな所は無いはずだがといったが、間もなくそれはその頃即ち十一代将軍の大御所様の御愛妾の父なる人の別荘とわかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月三十日の未の刻、彼等の軍勢を打ち破った浅野但馬守長晟は大御所徳川家康に戦いの勝利を報じた上、直之の首を献上した。",
              "citation": {
                "source": "古千屋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大御所ほどの弓取もやはりこれだけは下々のものと少しもお変りなさりませぬ。",
              "citation": {
                "source": "古千屋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「塙団右衛門ほどの侍の首も大御所の実検には具えおらぬか？",
              "citation": {
                "source": "古千屋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと昔からいっておるのう」　　　　大御所家斉公　ある日、紋太郎は吹筒を携え多摩川の方へ出かけて行った。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
