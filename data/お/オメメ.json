          "literary": [
            {
              "text": "おとなりの　よしおさんと　あそんで　いると、かぜが　ふいて　きて、ごみが　お目目に　はいりました。",
              "citation": {
                "source": "おっぱい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "つね子ちゃんは　よく　お目目を　あらいました。",
              "citation": {
                "source": "おっぱい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つね子ちゃんは　おかあさんに　だかれて、おっぱいを　たらたらと　お目目に　いれて　いただきました。",
              "citation": {
                "source": "おっぱい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが皇子さまは、可愛いお目目を見はつて、「では、しかたがない。",
              "citation": {
                "source": "岩を小くする",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お嫂さんは笑いながら立って私の肩に手を置き、「おめめを、いったい、どうなさったの？",
              "citation": {
                "source": "雪の夜の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめめを　つむって　いなさいよ。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも――」「さあ、もう　いっぺん　おめめを　とじて、ぼうや、とう　かぞえなさい。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おめめつぶりましょう。",
              "citation": {
                "source": "父と子供たち",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひやくしやうさんが　やつてきておめめ　ぱちぱち　おどろいた。",
              "citation": {
                "source": "かかし",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あら、おばあさん、なんて大きなおめめ。",
              "citation": {
                "source": "赤ずきんちゃん",
                "author": "ROTKAPPCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きなおめめで、大きなおぽんぽんね。",
              "citation": {
                "source": "少女と老兵士",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「とも子ちゃんのおめめみたいよ。",
              "citation": {
                "source": "少女と老兵士",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと　おめめが　あかくない？",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "（しろウサギって　みんな　おめめが　あかいと　おもうんだけど。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひょっとすると　あかい　おめめは　まえが　あんまり　みえないのかも。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おかあさんの言葉に調子を合せて、産婆さんも白いエプロンをきながら、「あしたの朝おめめがさめると、ちゃんと赤ちゃんがいますからね、たのしみにしておやすみなさい。",
              "citation": {
                "source": "柿の木のある家",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
