          ],
          "literary": [
            {
              "text": "「おいちょっと借せ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の前を離れながら、三四郎に、「おいちょっと来い」と言う。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいちょっと待て」　父の声である。",
              "citation": {
                "source": "父",
                "author": "金子ふみ子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おいちょっと、地面へ耳をつけて聞いて見たまえ」「どんなだい」「非常な音だ。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまた待ち受けてでもいるごとくに、連中は「おいちょっとおいで、好いものあるから」とか何とか云って、女を呼び寄せようとする。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも始の内は滑稽も構わず暇がかかるのも厭わず平気でやっていたが、しだいに僕の好奇心を挑発するような返事や質問が千代子の口から出て来るので、僕は曲んだまま、おいちょいとそれを御貸と声をかけて左手を真直に千代子の方へ差し伸べた。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤城の中腹から一里半の路のりを、子供三人と風呂敷とを提げて、粕川駅まで辿りつき、前橋中央駅の改札口を出て、やれやれと思った途端に、おいおいちょいと待てである。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいちょっとお借しの。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると窓の外から橋本の声で、おいおいちょっと出て見ろと呼んでいる。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいちょっと御見せと云うのに」「まあ待っていらっしゃいよ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいちょっと待ってくれ、話してえことがあるんだ」　参太は立停って振向いた。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう絶息していた……そのとき、うしろから覗きこんでいた孫次郎が、なにをみつけたか伊兵衛を押し除けて、「おいちょっと見せろ」　と前へ乗出して来た。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
