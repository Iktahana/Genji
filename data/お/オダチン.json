        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "……お二人でね……」　お駄賃に、懐紙に包んだのを白銅製のものかと思うと、銀の小粒で……宿の勘定前だから、怪しからず気前が好い。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一つは、夏休みに、仲好しになつたいとこの克巳にあへるといふこと、もう一つは、あまり、はつきりいひたくないのですが、お駄賃をもらへることです。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも五十銭くらゐお駄賃をくれたのです。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、帰りは、もらつたお駄賃で電車に乗ることができると思つて、わづかに心をなぐさめました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すむとお母さんは、「ぢや、お駄賃をあげよう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、御免よ」吉弥は初めて年増にふさわしい発言をして自分自身の膳にもどり、猪口を拾って、「おッ母さん一杯お駄賃に頂戴よ」「さア、僕が注いでやろう」と、僕は手近の銚子を出した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の身に附くお稽古なんだに、人の仕事でもして来たようにお駄賃をくれいですもの。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駄賃に駕籠をおごってやるよ」「かたじけねえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駄賃にこれをあげますから」　婦人の指の間には、五十銭銀貨が光つてゐました。",
              "citation": {
                "source": "黒猫",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四条御幸町の角に吉勘と言って錦絵の木版画や白描を売っている店がありましたが、使い走りをした時などここで絵を買うて貰うのが一番好きなお駄賃でした。",
              "citation": {
                "source": "今日になるまで",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と優しく劬はるやうに言つて、帰りしなに十銭玉を一つお駄賃にくれた。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも単に、ラムネを御馳走になつたとか、お駄賃を貰つたとかいふことの為ではない。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みさちゃんにお駄賃がなかったなむ！",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "安麦でうまいのが一升十六銭だぜ」　本屋の主人は店先きでもぞもぞしてゐる子供相手が面倒になつたのか、銅銭を二ツ出して、「ほれ、お駄賃だ、この雑誌は屑屋へでも持つてきな」と言つた。",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この娘が私にいわれた通り、無理に親分に会わせてもらって、口上を間違いなく述べたから、親分は笑って、そうかい、よしよし、お駄賃をくれて帰して、その日のうちに相当の乾児を使者に破約を告げて、お嬢さんへ親分からの志といって、まるで結納のように飾りたてた高価な進物をくれた。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駄賃にちょっと返事をして下さい」と風間記者は鉛筆を舐め舐め格子の間から顔をあげた。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は物持ちのお神さんで、野菜を残らず買つた上に、これはお駄賃だと云つて、二銭玉をくれたもんだ。",
              "citation": {
                "source": "医術の進歩",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駄賃をあげるから、……。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "念吉　　それはね、パパが毎日学校で英語を教へて、そのお駄賃に貰ふんだ。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いとは存じながら、いつもタンマリお駄賃を下さるので、奥さんのイイツケに背くことができませんでした」「二人はどこでアイビキしていたね」「私はお師匠さんの家に置いて行かれて、どこへいらッしゃるのやら、存じません」　これでヒサと敏司がアイビキをつづけていたことがハッキリした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこれはお駄賃」「まア、こんなに沢山、どうも有難う存じます」　小腰を屈めたお六の後ろへ、ヒラリと廻ると、女の左手は後ろから前髪に掛りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "呪いの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこれはお駄賃」「まア、こんなに澤山、どうも有難う存じます」　小腰を屈めたお六の後ろへ、ヒラリと廻ると、女の左手は後ろから前髮に掛りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "呪ひの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘエヘエ――こんなにお駄賃を頂いてはすみません」　二人の駕籠屋は、余分の駄賃を貰った上、所、名前を言って帰ってしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の精",
                "note": "青空文庫"
              }
            },
            {
              "text": "お駄賃がうんと出ているんだ。",
              "citation": {
                "source": "大江戸黄金狂",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら有っても邪魔にならないのは、お財というもの、これはあなたがお使いなさるが当然のお駄賃。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが母は「ありがとうよ」と、お礼をいいながら、「それは、あんたへお駄賃に上げる」と、かんざしは、その者に与えてしまったというのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お駄賃の５ポンド紙幣です。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、お駄賃に、オレが久々に可愛がってあげるかな」　彼はツカツカとあやかさんの方へ歩いて行った。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭さんは二人に金平糖のお菓子をくれて、そのうえはじめさんには拾銭白銅を一つお駄賃にくれた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭さんはぼくがお使いをするたんびにお駄賃をくれるんだ。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
