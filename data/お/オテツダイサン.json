        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「兄さん、ここは、お手伝いさん用の防毒室なのかい」「そうじゃないよ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手伝いさんも皆と一緒だ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホホホホ」　お手伝いさんは笑ってつげた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は空襲の知らせを聞くと、病める両親をはじめ家族たちをすぐ防毒室の中に入れ、あとのことをお手伝いさんと竹男に頼むと、自分は少年団の一人として、町にとびだしてゆくところだった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこには年の若いお手伝いさんが、蒲団にくるまって寝ていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちと静かにしないと、起きられるんじゃないか」「なんの、起きるものか」　そういった速水は、蒲団の間から、ヌッと出しているお手伝いさんの白い腕を握って激しく動かしたが、お手伝いさんの表情には何の変りもなかった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしベッドはキチンとしていまして別に入った様子もありません」「灯りは点いていたかネ」「いいえ、点いていませんでした」「お手伝いさんかなんかは居ないのかネ」「一人いたのですが、前々日に親類に不幸があるというので、暇を取って宿下りをしていました。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手伝いさんや娘の真弓子も知らぬと言った。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "針目博士邸において、お手伝いさん谷間三根子が密室においてのどを切られて死んでいた事件である。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷間三根子はお手伝いさんであった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お三根は、ほかのお手伝いさんとはちがい、ひとりだけ針目博士の研究所である煉瓦建の建物の中に部屋をあたえられて住んでいた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞造という男と、お松とおしげというふたりのお手伝いさんの三人が、このドアにぶつかったのだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金属Ｑは、お手伝いさんの谷間三根子の部屋にもぐりこんでいた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しこれはあたらしい小間使の光枝に対してだけの話で、その他のお手伝いさんや使用人は、方言まじりの言葉で、こっぴどく叱りつけられていた。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ責任者のお紋をはじめ、お手伝いさんの一隊がばらばらと駆けつけた。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子は大広間へのレモナーデの準備をお手伝いさんたちとしていたと言いました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子と一緒に働いていたお手伝いさんは、百合子が別に勝手元を離れたことはなかったようだと証言しました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合子はお手伝いさん達を駆りあつめて自分の室に共に寝をとらせましたが、どうしても寝つかれません。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内を乞うと、太ったお手伝いさんが出て来たが、丘田氏は幸い在宅とのことだった。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三階へ上り、部屋からお手伝いさんを追い出すのももどかしかった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿泊料とチップを受けとって、ふくら雀のようなお手伝いさんが出てゆくと、私は外套を脱ぎ、上衣を脱いだ。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はお手伝いさんのキヨに、一応その女流探偵の身形その他を訊きただした上で、客間に招じて逢ってみた。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、廊下にバタバタと跫音がして、お手伝いさんのキヨが飛ぶように走ってきた。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお手伝いさんのキヨの部屋へ行って、「キヨ。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は玄関を上ると、今まで速水女史の家で、女史が再び帰ってくるかと待ち合わせていたものの、待ち倦んで引返してきたのだと声高に述べたてていたが、真一の突然の死をお手伝いさんから聞くと、驚いて離座敷に駈けつけてきた。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を焼いてんねやろ」　旅館の裏口を開いて外へ出たコックとお手伝いさんとは、鼻をクンクンいわせて、同じような渋面を作りあった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お手伝いさんは白いエプロンを急いで鼻にあてた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お散歩どすか」　奥から飛んで出てきた仲働きのお手伝いさんが、慌てて宿屋の焼印のある下駄を踏石の上に揃えた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも元は由緒あるドクトルかなんかやったということだす」「外に同居人はいないのですか、お手伝いさんとか」「そんなものは一人も居らへんということだす。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェーンも　おてつだいさんなのに、　やっぱり　おりょうりしなくて、　いつも　ディナーに　でてくるのは　できあいのもの、　おがくずいっぱいの　はこで　とどくのでした。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
