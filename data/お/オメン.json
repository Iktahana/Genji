        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なお面白いのは日が高くなるにつれて椎茸が次第に縮んで、おしまいにはもう椎茸とも何とも分らぬものになって石ころ道の上を飛び飛び転がって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの事実は、これよりもなお面白く珍しいものであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお面白いのは一つ一つの煙の団塊の変形である。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに連れて煤けたお面を冠った、奇妙な着物を着た人間が、ノロマが蜘蛛の巣を取るような恰好でソロリソロリとホツキ歩くのだから、トテモ退屈で見ていられない。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに維新前はお面お籠手の真の道場であった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "深張の涼傘の影ながら、なお面影は透き、色香は仄めく……心地すれば、誰憚るともなく自然から俯目に俯向く。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お面お籠手の声が止むと間もなく、道場の電燈がフッと消えて人声一つしなくなった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、私は怪談が好きで、おそろしさの余りめそめそ泣き出してもそれでもその怪談の本を手放さずに読みつづけて、ついには玩具箱から赤鬼のお面を取り出してそれをかぶって読みつづけた事があったけれど、あの時の気持と実に似ている。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお面をかぶったら大丈夫、もう、こわいものはない。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、雨露に黒髪は霜と消え、袖裾も苔と変って、影ばかり残ったが、お面の細く尖った処、以前は女体であったろうなどという、いや女体の地蔵というはありませんが、さてそう聞くと、なお気味が悪いではございませんか。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はらりと、やや蓮葉に白脛のこぼるるさえ、道きよめの雪の影を散らして、膚を守護する位が備わり、包ましやかなお面より、一層世の塵に遠ざかって、好色の河童の痴けた目にも、女の肉とは映るまい。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱右衛門は静雨に不吉なお面の話をして別れたが、翌日になって静雨から夫人の歿くなったと云う通知を受け取った。",
              "citation": {
                "source": "お化の面",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行の小切手になると、なお面倒だ。",
              "citation": {
                "source": "鬼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一そのお面ぢやはじまらないんだから」　それをきいたかぼちやの怒つたの怒らないのつて、石のやうな拳固をふりあげて飛び懸らうとしましたが、蔓が足にひつ絡まつてゐて動かれない。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに連れて煤けたお面を冠った、奇妙な着物を着た人間が、ノロマが蜘蛛の巣を取るような恰好でソロリソロリとホツキ歩くのだからトテモ退屈で見ていられない。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿囃子　　　　　　　――鼻の動的表現（四）　昔から認められている「鼻の表現」の数々をここまで研究して参りますと、どうしても問題にしない訳に参りませぬのは、「おかめ」と「ヒョットコ」と「天狗」のお面であります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも子供衆のお相手｜位のもので、真面目腐って研究するのは馬鹿馬鹿しいようでありますが、お伽噺の中に人生の大問題が含まれているように、この三通りのお面にもなかなか容易ならぬ意味が含まれているのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等のお面の表現の中心になっておりまする三様の鼻の表現は、人間の性格を三つの方面に分解して、その一つ一つの方面を芸術的に誇張された鼻の表現に依って代表させたものと見るのが最も早わかりで面白くて、しかも意味が深長なようであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りこの三つのお面が自覚さえすれば直に進歩発達の道に入ることが出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風に観察して参りますと、この三つのお面が活躍する「お神楽」というものは、鼻の表現によって象徴された無自覚な性格の分解踊りとも見られるようであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生だった豊田正子の作文を集めた『綴方教室』や『続綴方教室』、『粘土のお面』を読み返してみると、書くという行為の積み重ねが一人の少女のものを見る目をどう鍛えていったかが、みずみずしい手触りと共に伝わってきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあとりあえずマッキントッシュとその真似っこであるＷｉｎｄｏｗｓの使いこなしの流儀をコンパクトにまとめて、電脳家電のお面に使うのが早いのではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "家電製品が横並びでずらりとかぶるお面の候補に、一番近いのはＷｉｎｄｏｗｓだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアウトラインを報じる記事を読んで、「家電製品が横並びでずらりとかぶるお面の候補に、一番近いのはＷｉｎｄｏｗｓだ」と書いたこの原稿のことを思い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの箱のなかの古いお面をさがして居りますうちに、二朱銀ひとつ見つけ出しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が眩むほどに門弟らのお面やお胴をなぐり付けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "――併し、編輯に於いては原稿の計算方法から教え導かれ、小説に於いては、処女作以来今日もなお面倒を見てもらっている加藤武雄氏への恩義を思わずしては、私はいつも自分の過去を顧ることが出来ない。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、剣道の試合のとき、撃つところは、お面、お胴、お小手、ときまっている筈なのに、おまえたちは、試合も生活も一緒くたにして、道具はずれの二の腕や向う脛を、力一杯にひっぱたく。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔のはばが広くほっぺたが真っ赤に光っている助手さんがあって、いかにも赤鬼のお面を聯想させるのだが、さすがに、そこは遠慮して避けて、鬼の霍乱というわけで、カクランだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と私は彼が何かのはずみに、私に、おめんしですよと云つた時、さつぱり意味が解らずに訊きかへしたのであつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
