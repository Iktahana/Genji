    "definitions": [
      {
        "index": 1,
        "gloss": "grace (of God)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんまり勝手を云うんじゃない、その身体は全体みんな、学校のお陰で出来たんだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、お陰で昨晩戻って参りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰様で八時には今市へ着いた。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰様で……」と平身低頭礼を言っている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああら有難し、これも腹式呼吸のお陰、強健術実行の賜物ぞと、勇気日頃に百倍し、半身裸体に雨を浴びてぞ突進する。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて少女のお陰である。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、僕自身の気持ちが、僕にはっきり判ったのも、矢張りあなたが仲に入られたお陰なんです。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに私はそんな遠い學校へ毎日あるいてかよつたお陰で、からだも太つて來た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『真個にお陰さまであした。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君と歩いていると、とかく乞食が眼につくね」と啓司が笑って言えば、花田は漸く笑って、「君も、僕のお陰でルンペン以下の人間層に視野が開かれたのさ」　と言って自分の住んでいる町外れの小橋の方へ歩いて行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新三郎も老婆も祈祷のお陰であると思って悦んだ。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢様が御厄介をかけまして、なんともお礼の申しようもございません、今晩お酒宴をしておりますうちに、興にまかせて、お歩きになったために、こんなことになりました、お陰様でお怪我もせずにすみました、奥様がどんなにお喜びになるか判りません、お立ち寄りを願います」　十丁あまりも往くとまた林がきた。",
              "citation": {
                "source": "崔書生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お陰で早く判ってありがたい、きっと報います」　侍臣の一人が傍へ寄ってきた。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころは、ぼくが顔を出すのは幸福な小鳥の巣を鷹が覗くようなもんだと思って、そのまま黙って帰ってしまったんですが、そのお陰でぼくはすっかり神経衰弱になってしまったんですよ」「兄から聞きましたわ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、てめえらはだれのお陰で育ったと思っているんだ？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそれなり夜になろうが、それだけに、なお陰気で、星は出そうにもなし、雨になると戸を閉めるから、遠い灯の影も見られなそうな夕暮だった。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお陰でからだのほうは大いによろしく候う。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の性欲的生活が繰延になったのは、全くこの三角同盟のお陰である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に前人の植福のお陰である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "有福は祖先のお陰に依るので尊ぶべきところはない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは曰く、私は父祖のお陰で家と広い土地と公債が若干ある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな内に居るのは可厭だ、別居して独で遣る、と我儘を言つて、どうなりかうなり自分で暮して行けるのも、それまでに教育して貰つたのは誰のお陰かと謂へば、皆親の恩。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は金に窮つて心中なんぞを為た、と人に嗤れましても、情婦の体を売つたお陰で、やうやう那奴等は助つてゐるのだ、と一生涯言れますのは不好で御座います。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の航海にはしかしお陰様で大助かりをしまして、ゆうべからきわだってよくなりましてね」　と付け加えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の性格はこの暗闘のお陰で曲折のおもしろさと醜さとを加えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれつき機敏に働く才気のお陰で、見たり聞いたりした所から、美術を愛好する人々と膝をならべても、とにかくあまりぼろらしいぼろは出さなかったが、若い美術家などがほめる作品を見てもどこが優れてどこに美しさがあるのか葉子には少しも見当のつかない事があった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもみんなお前のお陰だぞ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは年齢のお陰もある。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰様でわたしはさびしい世の中から救い出されました。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな工合いの名前のおかげで、おめえの恰好もどうやらついて来たじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
