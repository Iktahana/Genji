    "definitions": [
      {
        "index": 1,
        "gloss": "maid working in the domestic quarters of a shogun or daimyo (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "奥女中の指には撥胝がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は安蔵を供の武士に仕立てて、自分は奥女中に化けてお蝶を受け取りに来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はお俊のような偽物でなく、たしかに或る大名の江戸屋敷につとめている奥女中であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "年頃も顔かたちも丁度註文通りに見えたので、かれは更に奥女中の雪野というのを連れて来て眼利きをさせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥女中の雪野がその使をうけたまわって、きのうも親許へたずねて来たのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、不断は千本格子を境にして、やけな奥女中の花見ぐらい陽気な処へ、巡査と見ると騒動が豪い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おなじく奥女中）女の童、禿、五人。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈甲の突通し、御殿奥女中のこしらえ。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "城主たちの夫人、姫、奥女中などのには金銀珠玉を鏤めたのも少くありません。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅から帰つて来てからでは、例の奥女中の条が好い、春画を見る条、つゞいてあのくさりかたびらの条、あれが滑稽に書いてあつて、そしてちつとも滑稽でない。",
              "citation": {
                "source": "西鶴小論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが、大殿様のお小姓をしていた時に、奥女中がお箸箱に恋歌を添えて、送って来たという話があるんや。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご城内奥女中のご用品でござりまするな」「な、なぜおわかりじゃ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜこれが奥女中の品とおわかりじゃ」「この紅いろ扇子がその証拠。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅いろ透かし骨の扇子といえば、日本橋石町たらちね屋が自慢の品物、たしか大奥にも出入り御用を仰せつかっているように聞いておりましたゆえ、奥女中の持ちものとにらんだだけのことでござります」「灯台もと暗しとは、まさしくこれじゃのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に、手続きもめんどうならば、詮議手入れはさらにめんどう、奥女中総手入れとなると、数そのものがあだやおろそかな人数ではないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "上はお局から下お末端女まで数えたてるとざっとまず六、七百人、手続きを踏む段になれば、松平伊豆守という鬼に金棒のうしろだてがあるにはあるが、しかし、六、七百人からの奥女中をひとりひとり吟味するとなると、容易なわざではないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万石の奥女中が、そればかりの手ぬぐいを急いでとは、またどうしたわけだ」「あす、上野でお腰元衆のお花見がございますんでな、そのご用を仰せつかったんですよ」「ウフフ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは江戸城に勤めている音羽という奥女中の拝領地で、音羽の地名はそれから起こったのであると云う。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語をこのむ江戸庶民の感覚で、奥女中あがりを女房にした長屋の男の困却を諧謔の主題にしたものだった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥女中だった女が、長屋ものの女房になってもまだ勿体ぶったお女中言葉をつかっている。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて輦から降りて、匍匐して君側に進むと、阿部家の奥女中が目を見合せて笑った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百は姉小路という奥女中の部屋子であったという。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の姉、黒田家の奥女中｜幾勢は茶山に餞をした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其二は某の大名屋敷の奥女中の部屋の怪異を記したものである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時は非常に美しい御姫様または奥女中風の後姿をしているが、それがふとふり向くと目も鼻も口も何もない、顔をしている。",
              "citation": {
                "source": "ばけものばなし",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先妻に縹緻よしの娘を生ませたが、奥女中｜上りの後妻が継児いじめをするので、早くから祖母の手にひきとられ、年下のあたしの父の許婚となった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女の心がけがわるいからだが――」　だが、奥女中姿の裲褂で嫁に来た時はうつくしかったと、不便がって貢いでいた。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、蒔絵の文箱を持った奥女中が矢立に帯を結び、水際の睡蓮の傍でそっと蓋を抜いてみている、その手紙の中の文章を想像した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程のう……ところで加賀の国の何代目かの殿様は、家老や奥女中から笑われるのも構わずに鼻毛を一寸以上伸ばして御座ったという話だが、アレは君が教えたのか」　バレンチノが長い、ふるえたタメ息をした。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論土地の売れっ妓たちは総縫の振袖や、袿を着た、腰元や奥女中に、他の土地の盛り場の妓たちと交っていたので、その通行のおりには大変な人気であった。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
