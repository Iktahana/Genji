[
  {
    "uuid": "fc328522-b1b3-5562-8afb-0d0bfefcaba5",
    "entry": "お寒い",
    "reading": {
      "primary": "おさむい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "poor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お寒いという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお寒いの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お寒いを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお寒いという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お寒いの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お寒いは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お寒いの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お寒いと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お寒いは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お寒いはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お寒いの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お寒いの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お寒いが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お寒いを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お寒いのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お寒いに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お寒いの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お寒いの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お寒いは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お寒いの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "富士山中で、大宮口の森林として、もっとも名高いモミ、ツガ、ナラ、モミジ、ブナなどの、夏なお寒い喬木帯を通過する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寒いのに、なぜ、おとり申上げた村里の宿へお出でになりませんの」　翁は頑是ない子供が、てれながら駄々を捏ねるように、掌に拳を突き当てつつ俯向き勝ちにいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とても隠すなら金屏風で、」　と唄うかと思えば、「おお、寒い、おお寒い、もう寝ようよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お糸さんは枕をさがしてきて、お寒いからつて私のマントを取つて上へかけてくれた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで可しと、掻合せてやんなよ、お寒いのに。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寒いので、炭をどつさりお繼ぎ申しあげたものですから、先生樣はお歸りがけに、もう一度よく埋けなよ、と確に御注意遊ばしたのでございますものを、つい私が疎雜で。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世の中にゃ、こんな炭火があると思うと、里心が付いてなお寒い。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寒いんですから、本当に、そのままで、お願いします。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、おお寒い、おお寒い、風邪揚句だ不精しょう。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客さん、二階はお寒いでせう。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てれかくしと、寒さ凌ぎに夜なしおでんで引掛けて来たけれど、おお寒い。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春でもお寒いわねえ。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨年よりもお寒いようでございます。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨吉は袖を交わして、ひやりとした風、つっけんどんなもの謂で、「何だ、」「はい、もしお寒いこッてござります。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果的に生じたのは、ＤＯＳマシンの最先端から比べればかなり貧弱な機械に法外な値札がついた、お寒い日本市場の現実だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日お寒いことでございます」と熊蔵はわざと笑顔を粧って挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "）○あれニャン君が今　フフつて笑つたぞいま泣いた烏が笑ひだした　ハハハだつて　あんなところに映つたりして　おかしいんですものニャンちやん　仲直りしやうね○あら変だわ　わたしなんだか寒くなつてきたわどうしたんだらうね僕は少しも寒くはない○おお寒い！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おお寒い寒い　これはたまらん○あッ！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何といふお寒いのでございませう」「さやう」「貴方、間さん、貴方そんなに離れてお歩き遊ばさなくても宜いぢやございませんか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、お寒いようなら、褞袍になさいますか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "面目ない……面目ない……お寒いところおきのどくじゃが、お力お貸しくだされい」「ようござる。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らずお寒いことでございます」「ほんとうに寒いね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあ、お寒い時分はまるで閑でございます。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙　　ほんたうにお寒いことでございます。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまはさぞお寒いことであらう。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）先生、お寒いことでございます。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お寒いのに遠方御信心でございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろお寒いもんですから」と、女房は茶を運びながら答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変おさむいでしょうけれども。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六畳一間でおさむいが、さほどひどくもなさゝうだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
