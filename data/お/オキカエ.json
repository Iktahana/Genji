          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、生涯、山に親しみ山に冥通する何ものかを得たこどもたちは、老年に及び死を迎えるまえに生命を自然の現象に置き換える術を学び得ていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンスクリトの krudhyati のｋをｈで置き換えるとともかくも hrdt という音列を得られる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この置き換えは無理ではない。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｙをｊに、語尾のｒをｔにすると（この置き換えもそれほど無理ではない）シナの現代音になる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がじいっと耳を澄ますと、納屋で蓆や空俵を置き換えている気配がした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年に至って原子は電子とプロトーンによって置き換えられ、ごくごく最近に波動力学の出現によってこれら物質的素量に関する観念に始めて目立った変化をきたしつつある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の言葉の音波列を分析して、その組成分の中からその基音ならびに低いほうの倍音を除去して、その代わりに、もとよりはずっと振動数の大きい任意の音をいろいろと置き換えてみる。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはただ一つの疑問を他の言葉で置き換えたに過ぎない。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲を一、乙を二、丙を三と順々に置き換えてしまえば、たとえば二十三と言う代わりに乙丙と言っても文字がめんどうなだけで理屈は同じである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は蓄音機や活動写真器械で置き換え得られるような講義はほんとうの意味の教育的価値のないものだろうと思っている。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、これらの原始的な世界像構成要素が映画ではどういうふうに置き換えられて代表されているかを考えてみる。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って一つの楽曲のおもしろさを貧弱な人間の「言葉」と名づける道具で現わすことが困難であると同様にこの映画の律動的和声的要素の長所を文字の羅列で置き換えようとすることは、始めから見込みのないことでなければならない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際プドーフキンでもエイゼンシュテインでも、ボラージュでもそれらの人々のモンタージュに関する論述を読むに当たって、その記述の表面に現われた具象的なものを適当にムタティス・ムタンディスに置き換えさえすればそれはほとんど完全に他の芸術の分野に適用されうることを見いだすであろう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた短歌や俳諧を論じて「フレーセオロジーに置き換えられた象形文字」であると言い、二三の俳句の作例を引いてその構成がモンタージュ構成であると言っている。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最後のリフレーンで「イズンティット・ロマーン」まで歌った最後の「ティック」の代わりに、バルコンの下から忍びよるド・サヴィニャク伯爵の梯子が石欄に触れる「ティック」の音を置き換えてある。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は白露と水光との饒舌を惜しげなく切り取って、そのかわりに姿の見えぬ時鳥の声を置き換えた。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ親の情痴を離れ得ぬとしても今までの情痴を次の情痴に置き換えよう。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから、かの女は地球上の土地を、自分の気持の親疎によって、実際の位置と違った地理に置き換えていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は作品の誠実を、人間の誠実と置き換えようとしています。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえその石が金に置き換えられようと銀に置き換えられようと、それが事実の道端に転がっている以上、僕に取って一顧の価値もないことは石同様なのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日が悪い」という漠然とした「説明」が、この場合には立派に科学的の言葉で置き換えられるのである。",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単語に区切って、未知の文字を点に置き換えてみると、次のようなものになる。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルチメディアと電子本　電子本では、文章がコンピューターの扱えるデジタル形式の情報に置き換えられている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちがやろうとしていることの本質は、文章の並んだ本をコンピューターの上に置き換えること、そのものにあると感じていたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "原稿の最後で〈読む〉立場から、〈作る〉立場に身を置き換えて、「電子本は大量の部数を望めない出版物を少ないリスクで刊行する手段としても活かされるだろう」と私は書きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま日本語に置き換えれば、「机上出版」。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字数の多い漢字をアウトラインフォントに置き換える作業が進められていたこの時期は、業界の半歩先の動きをレポートしようと狙っていたその雑誌が特集を組むには、実に適当なタイミングでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリックや下線、太字といったものもすべて、大文字に置き換えてしまいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ目の点訳とは、文章を点字に置き換える作業を指す。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして椎茜という言葉を造って下の五におきかえ嬉しい気がしました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
