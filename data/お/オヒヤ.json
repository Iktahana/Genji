      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold (drinking) water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お冷について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お冷がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お冷というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお冷の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお冷が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お冷を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お冷の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お冷はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお冷があります。",
              "source": "幻辞"
            },
            {
              "text": "お冷は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お冷について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお冷の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お冷の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお冷が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お冷についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお冷は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお冷について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お冷という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお冷の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お冷を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "湯殿から蒸しかかる暖い霧も、そこで、さっと肩に消えて、池の欄干を伝う、緋鯉の鰭のこぼれかかる真白な足袋はだしは、素足よりなお冷い。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "簾に寄る白浪は、雪の降るより尚お冷い。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お冷し申して……」　女房は土間へ片膝を下ろした。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴席どなりの空部屋へ轉げ込むと、ぐたりと寢たが、したゝか反吐をついて、お冷水を五杯飮んだとやらで、ウイーと受持の、一番さんへ床を取りに來て、おや、旦那は醉つて轉げてるね、おかみさん、つまんで布團へ載つけなさいよ。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お冷えなさるようなら、貴僧、閉めましょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沢山、そんなことを云ってお冷かしなさいまし。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど今ここに心づきて、わが心はなお冷然たりしか。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして当時を顧みれば、なお冷汗の背を湿おすを覚ゆるぞかし、安藤氏は代々薬屋にて、当時熱心なる自由党員なりしが、今は内務省｜検疫官として頗る精励の聞えあるよし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今お冷を持つて……」　言ひ捨てゝ急いで臺所に行つて金盥へ水を一杯汲んで來た。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのうランプを持參しましてございますから、エヽ御用の節は何時でもどうぞベルをお押し遊ばして……エヽ便所はすぐこちらでございますから……エヽ明日は汽車にお召しになりませんでエヽ左樣でございますか……それではお冷を只今持參させますからエヽそれではごゆつくり……」　といつて番頭は去つた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚ですがお冷を一つ下さいましな」　静緒は驀地に行かんとす。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人ともそのぬれた召し物ではお冷えなさりましょう。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｆ子は女中を振返つて、「すみませんがお冷を一杯。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢一郎　（なお冷静に）おたあさんは女子やけにどう思っとるか知らんが、俺に父親があるとしたら、それは俺の敵じゃ。",
              "citation": {
                "source": "父帰る",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると美禰子は、なお冷やかな調子で、「責任をのがれたがる人だから、ちょうどいいでしょう」「だれが？",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お目醒めでござりましたか」「京弥か」「はッ」「菊に用なら、ここには見えぬぞ」「何かと言えばそのように、お冷やかしばかりおっしゃいまして、――お目醒めにござりますれば、殿様にちと申し上ぐべき事がござりまして参じましたが、ここをあけてもよろしゅうござりまするか」「なに、殿様とな？",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かと言えばそのような御冗談ばっかりおっしゃいまして、あまりお冷やかしなさりましたら、いっそもうわたしは知りませぬ」「なぞと陰にこもったことを申して、その実少し妬いているようじゃが、煮て喰いも焼いて喰いもせぬゆえ、大丈夫じゃ。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこではお冷えなさいます。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「コーヒーは、咳によくないから、わしはお冷水を貰おう」「そうでしたわね、せっかく三つこしらえたんですけれど、それじゃそうなさいまし」　二人の、コーヒーを啜る音を聞きながら、玄石は、邪悪な満足の微笑を浮かべた。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お千代　お冷を汲んでまゐりました。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかめ　お冷でございますか。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中を呼んで、お冷を一杯、と云つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急き込んだ口調で、水に氷が入つてゐないぢやないか、お冷を持つて來いと云つたら、ブツカキを入れて持つて來るなあ、云はなくつたつてわかつてることなんだ、間拔け奴、と聲變りのした聲で怒鳴るのであつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　主人は卓子の上の葉巻入と一緒に、吃驚して椅子から飛び上らうとする、松下はじろりとそれを尻目にかけて、「お気の毒だがお冷水を一つ下さい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合お冷水だらうが持参金つきの娘だらうが、相手の気に入る事なら、主人はどんな物でも調へようと思つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小発明家はお友達に沸騰散をしこたま飲ませておいて後からお冷水をぐつと一杯｜煽飲らせた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "からいおひやをよばれる、ペハアミントをよばれる、いやはや。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叮嚀に謂ツたかと思ふと、「ですが、其樣なにおひやらないで下さいまし。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もおひやりはしないよ。",
              "citation": {
                "source": "青い顏",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は確におひやられたのであツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
