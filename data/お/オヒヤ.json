[
  {
    "uuid": "bb8141f9-8277-52d6-8a12-3687f2590eac",
    "entry": "お冷",
    "reading": {
      "primary": "おひや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
