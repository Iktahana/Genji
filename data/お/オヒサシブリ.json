        "examples": {
          "standard": [
            {
              "text": "お久しぶりについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お久しぶりがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお久しぶりの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお久しぶりが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お久しぶりの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお久しぶりがあります。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お久しぶりについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお久しぶりの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお久しぶりが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお久しぶりは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお久しぶりについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお久しぶりの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お久しぶりを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それだって、様子を見ただけでも、お久しぶりとも、第一、お早う、とも言えた義理じゃありませんわ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分お久しぶりにお目にかかります」「田舎へ入って仕舞ってどちらへも御無沙汰ばかりです。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お久しぶりで御座いました」　宮は懽び勇みて犇と寄りぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り口ですまそうとするのを、「まアまアほんとうにお久しぶりでしたね」と無理に奥の座敷へと請された。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、梅本さんお久しぶりねえ」　突然、通りかかった一人の女給が声をかけた。",
              "citation": {
                "source": "被尾行者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お久しぶりですね」おひろは瘠せた膝をして、ぴったりとそこに坐った。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりやお久しぶり。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヨ、君、お久しぶりぢやの。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、お久しぶりですのう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "由っちゃん、お久しぶり……せいぜいその不具の化物を可愛がってやってくださいね、あたしもね、退屈だから、一寸｜揶揄ってやろうと思って来たんだけど、先約があっちゃねエ……ごゆっくり――さよなら――」「あ、葉ちゃん！",
              "citation": {
                "source": "夢鬼",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久しぶりでございます。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、お久しぶりでごぜえます。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日の夕方、お久しぶりで、ダンチョン様が参られました。",
              "citation": {
                "source": "西班牙の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お久しぶりでございますこと」　梶子が近々と立っていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「霜降様、お久しぶり」「や、これは梶子様！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久しぶりで」――「お忙しいですか」「いや別に忙しいこともありませんですよ」　房一はその黒い顔に微笑をうかべながら今泉を見た。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は母親と肩を並べるように懐かしく傍に寄り添いながら、「おかあはん、ほんとうにお久しぶりでした。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "えらいお久しぶりどす」と、いって、打ち融けて挨拶をして、「えらい端の方でお気の毒さんどすが、今ちょっと奥が取り込んでいますよって、ここで失礼いたします」と、いって、婢衆に座蒲団を持って来さして、私にすすめる。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあんなにお唱歌なんぞお歌い遊ばしましたのは、本当にお久しぶりでございますねエ」と幾はうれしげに浪子の横顔をのぞく。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯りの少い夜道を駅に向って歩いていると、後から若い女が追ってきて、いきなり彼の腕をとり、「お久しぶりね、吉田さん」「人ちがいですよ」「黙って！",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、お前さんは……」「あなたはお君さん」「ずいぶん、これはお珍らしい」「まあ、なんというお久しぶりな」と言って二人ともに面を見合せたなりで、暫らく呆気に取られていました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お母様、お久しぶりねえ」「…………」「お別れしたのは十年前の、雪の積もった日でございましたが、……お母様もお変わりなさいましたこと。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「観世様、お久しぶりで」その小男はいったものである。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玻璃窓の旦那、お久しぶりで」「おっ、貴様は和泉屋次郎吉！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎悪に顫えて）お久しぶりでございます、成吉思汗様。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久しぶりでござる」「や！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "アコ長の顔を見るより懐しそうに走りよって来て、「おお、これは阿古十郎さん、お久しぶりで。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関に来客があるらしく、取り次ぎに出た多津が、大形に、「まあ、まあ、よくいらしつたわね……随分お久しぶりじやないの……」　と、言うのに、「ほんとに、ご無沙汰してしまつて……みなさま、お変りありません？",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お久しぶりなのね。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ひと息で言ってしまって、それから急に固くなり、「ほんとうに、おひさしぶりでございました。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
