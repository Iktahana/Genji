        "examples": {
          "standard": [
            {
              "text": "おべべについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おべべがありますね。",
              "source": "幻辞"
            },
            {
              "text": "おべべというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおべべの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおべべが好きです。",
              "source": "幻辞"
            },
            {
              "text": "おべべを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おべべの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おべべはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおべべがあります。",
              "source": "幻辞"
            },
            {
              "text": "おべべは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おべべについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおべべの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おべべの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおべべが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おべべについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおべべは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおべべについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おべべという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおべべの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おべべを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「兄さんなぜあたいの青いおべべ裂いたの。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に赤ちゃんの着る花模様のおべべを着て、でんでん太鼓など振って、その九十歳だか百歳だかの御両親のまわりを這いまわって、オギャアオギャアと叫び、以て親の心を楽しましめたり、とあります。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十の老人が、赤ちゃんのおべべを着て、でんでん太鼓を振りまわしている図は、むしろ醜悪で、正視にたえないものです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると婦人は私の肩に手をかけて、「綺麗におけい／＼（お化粧）が出来て、おべべ（着物）もよくお似合い」　そう言って夫人はわたくしの袂の八ツ口の根元を指先で抓み、指先の早業で下着の裏や襦袢の地質を検め見ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青縞、茶縞、茶縞のおべべ、ちゆうちゆうぱたぱた、何反織れたか。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでお前さん、さらのおべべが揃うだけの儲かり話があるんだが、よもや遠慮するまいね？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみやげどっさり、うんとこしょお菓子におべべにキスにキス踊って待てよ待てよ、魔子、魔子。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おべべを着更えましょうね」と節子は二人の子供を呼んだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、もうすぐ朝鮮に行くんだから、そのおべべを着てそこいらへ挨拶に行って来るんだ」　と、みんなのものに言われて、私は叔母と一緒に学校や近所の家へ暇乞いにまわった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "甜めろ、甜めろ、泥をなめろ、飴を甜めろ、牛のけつを甜めろ、赤いおべべを着て踊れ。",
              "citation": {
                "source": "佐渡が島を出て",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子にとっては桃の花のつぼみのような年ごろから、男の子にとってはしょうぶの葉のような伸びゆくさかりの年ごろから、山のものを祝い、海のものを祝いして、新しいおべべに着かえながら、そういう節句にめぐりあうというのも楽しいではありますまいか。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、寝ている勇ちゃんのお母さんは、「みい子のお好きな赤いおべべが、はいっているというのですよ。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、みい子ちゃんの赤いおべべが。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「赤ちゃんのおべべよりも、きれいだといっていただきたいのですよ。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎ちゃんのお母さんは、たんすを開けて、みい子ちゃんの、きれいなおべべをごらんになりました。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きれいな、いいおべべですこと。",
              "citation": {
                "source": "小さな妹をつれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「坊や、すわると、おべべが、よごれるよ。",
              "citation": {
                "source": "鳥鳴く朝のちい子ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊お洗濯知つてるの……』『ぼうしつてる、おべべばつちくなつたとき、じやく／″＼してきれいにすることでせう』『あゝさうです／＼、坊よく知つてゐるわね。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんがばつちくなつたおべべを川へ持つて行つてお洗濯をしてゐるとね、向ふの方から大きな桃が、どんぶらこ／＼と流れてきました』『おばあちやん、そのもゝどんなにおほきかつたの？",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "おべべをよごしたのが悲しいのだろう。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりたたずんでいるお艶へ、「小母ちゃん、そのおべべを持ってどこイ行くの？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当だよ、――赤いおべべを着た小母さんが突き飛ばしたよ」「まア」　お角はゾッと身を顫わせます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "受難の通人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが太郎にとって先生というのはこれまでの生涯に医者しかない、白いおべべの先生と云う言葉のために、欲しいお菓子もやめさせられたのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "豈おべべのみならんや。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それに、そんなことをすりゃ赤いおべべも着なきゃならんし。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あとでね正子、右文のおべべを縫うの手伝っておくれよ。",
              "citation": {
                "source": "一つ身の着物",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
