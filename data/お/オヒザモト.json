    "definitions": [
      {
        "index": 1,
        "gloss": "beside a nobleman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お膝元について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お膝元がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お膝元というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお膝元の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお膝元が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お膝元を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お膝元の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お膝元はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお膝元があります。",
              "source": "幻辞"
            },
            {
              "text": "お膝元は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お膝元について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお膝元の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お膝元の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお膝元が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お膝元についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお膝元は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお膝元について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お膝元という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお膝元の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お膝元を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "将軍家のお膝元という江戸も頗る物騒で、押込みの強盗や辻斬りが毎晩のように続く。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ等のような無落戸漢が八百八町にはびこればこそ、公方様お膝元が騒がしいのだ」と、彼は向き直って相手の顔を睨んだ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて侍が町奴の真似をして、八百八町をあばれ歩くは、いたずらにお膝元を騒がすばかりで何の役にも立つまい。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）仔細もなしに喧嘩を売る、おのれ等のやうなならずものが八百八町にはびこればこそ、公方様お膝元が騒がしいのぢや。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、この頃はお膝元が太平で、八丁堀の奴らも閑で困るもんだから、そんな、詰まらない事を云い触らして、忙がしそうな顔をしているのだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "公方さまのお膝元じゃあないか。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丑満時であったから、将軍お膝元の大江戸もひっそりとして物寂しく、二十日余りの晩い月が雪催いの空に懸かっているばかり往来には犬さえ歩いていない。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに十日間ばかり滞在して、江戸の情勢を窺っていたが、差閊えなしと見て、十一月の五日にはとうとうお膝元へ乗りこんできた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「考えてもみい、今の浅野の浪人どもがそのような暴挙に出て、お膝元を騒がしたら、戸田のお家はどうなると思う？",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一度幼い子にかへって、御両親様のお膝元へ帰りたうございます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の矢にタタられた人々はおのずからタタリの神のお膝元に集らずに居られない気持が起るのであろうか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の矢のお膝元では誰もオレを珍しがらないね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸は将軍家のお膝元。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、お膝元を離れ麦田と桑畑に囲まれた農村へ帰り住むと、白雲が流れる東南の方、都の空がなつかしくもある。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏れ多いことだが、お膝元はしつかりしてるか？",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレは山の神の行者だから、山の神のお膝元へおびきよせてやらなければならぬぞ。",
              "citation": {
                "source": "山の神殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇治山田の米友は、伊勢の大神宮のお膝元で生れたから、神様の有難いことを知っている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "時勢は、どうか知らないが、お膝元のこの醜態はどうだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お膝元に東北大学という官立の総合大学があって、市史のヘンサンがないのだから、気風の一斑を知るべきだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「全く、これじゃ公方様のお膝元はひどい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは天皇歴代のお膝元たる大和平野に近く住んでいても、峯嶮しく谷深くして、道路狭くさがしく、ゆえに都に遠からずといえども、本より朝来すること稀なりとある。",
              "citation": {
                "source": "日本における史前時代の歴史研究について",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国でも天皇のお膝元なるヤマトに当つるに、「大倭」の文字を以てした事は、この慣用に従ったものであったと察せられる。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "国定忠次の置き土産　上州の侠客国定忠次が、江戸へ姿を現わしたのは、八州の手に追われたからで、上州から信州へ逃げ、その信州の追分で、甚三殺しと関係い、その後ずっと甲州へ隠れ、さらに急流富士川を下り、東海道へ出現し、江戸は将軍お膝元で、かえって燈台｜下暗しというので、大胆にも忍んで来たのであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名に負う将軍お膝元、八百万石のお城下だからな。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その近くに彼の根拠地があれば話が分るが、そのへんはすべてを暗んじている菅谷の城下お膝元、自慢ではないが、自分の土地について、自分の知らないことを人が知っているような不案内な所が、一ヶ所でもあろうとは思われぬ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくお膝元江戸灣に乘りこんだ最初の船であらうが、まつたく「突拍子もない船」である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍さまのお膝元とて、名だたる見世物も数あるなかに、これこそは真の眼学問。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "12015お膝元で※気を吸って、お恵を仰いでいる優しい群です。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲者は昌平橋を見張つて居る、仲間の彌吉を川へ投り込んで、明神下に逃げ込んだことは確かだが、それつきり行方がわかりません」「明神下といふと、此邊ぢやないか」「親分のお膝元ですよ、曲者が潜り込んだのは間違ひもなく此町内だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お膝元を荒されるのを見ちやゐられないよ――平次は何をして居るんだ――と御町内の衆から顏を見られさうで」「そんなものですかえ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
