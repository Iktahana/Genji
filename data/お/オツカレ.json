[
  {
    "uuid": "2d351263-5681-5994-a438-ca4fdba5c7f1",
    "entry": "お疲れ",
    "reading": {
      "primary": "おつかれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thanks (for coming, helping, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けふはあなたもお疲れでせうし、それに、おなかも空いてゐるでせうから。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お疲れでしたらう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたもお疲れでしょう。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、本日はお疲れでございませう。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩開廷の運びになっている件が二つございますが、いかがでございましょうお疲れでいらっしゃいましょうか。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お疲れさま」　それだけ言って、女房の産が近づいた人のようにさっさと帰って行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとう」　マッチをすっていると、「お疲れさま。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "出て行くのであろう、「お疲れさま」の「ま」の尻を上げた言い方は、信吉を意織しない調子に聴えた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉へ来たのかという意味のことを訊かれたので、そうだと答えると、もういっぺんお辞儀をして、「お疲れさんで……」　温泉宿の客引きだった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて座談会の筈でありましたが、委員は、お疲れのようですから、少し休憩なさい、と私にすすめてくれましたが、私は、「いいえ、私のほうは大丈夫です。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた達のほうがお疲れだったでしょう。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお疲れのお顔を見ると、私までなんだか苦しくなります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旅でお疲れぢやろ、まあ足を洗つておあがりなされ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまり歩いてはお疲れでしょう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旅で、みなさんお疲れじゃろ、わしはいまいい酒をひとびん西の館の太郎どんからもらったので、月を見ながら縁側でやろうとしていたのじゃ。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　将軍家は、その日どこやらお疲れになつて居られるやうな御様子でございまして、黙つてお首肯きになられただけでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして肩をもんでいると、お母さんのお疲れが、私のからだに伝わって来るほど、よくわかる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おからだがいよいよお弱りになっていらっしゃるのが私にはちゃんとわかっていましたが、何せ奥さまは、お客と対する時は、みじんもお疲れの様子をお見せにならないものですから、お客はみな立派そうなお医者ばかりでしたのに、一人として奥さまのお具合いの悪いのを見抜けなかったようでした。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、お一つ」　わたくしは好むものでもないので「さあ」と渋面作っていますと、「旅のお疲れ直しに、また、ひと口ぐらい、いゝものですよ」　と押し勧めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも鉄道局との打ち合せも済んでいたものと思われたし、東京の旅客課のＫ君も附いていることなり、や、お疲れさま、どうぞとあったので、そこで一同が安心して鞄を投げ出し、埃っぽい編上げの紐も解いたのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一木殿お疲れでございましょう、さあ、どうぞお食事を」「飯は後でええ、此処をかたづけてくれ」　そこで総之丞はじめ下僚は幔幕を畳み、祭壇の始末をはじめた。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お疲れでもあろうが、辛抱してそこまでお出でなされたがよろしゅうござります。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえはお疲れであろう、早くお休みなさい。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お疲れでござりましょう。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつかれでなかったら、ご案内しましょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "植ゑて見し花の主人もなき宿に知らず顔にて来居る鶯　春の空を仰いで吐息をおつかれになった。",
              "citation": {
                "source": "源氏物語",
                "author": "まぼろし",
                "note": "青空文庫"
              }
            },
            {
              "text": "田圃道で出あふ人が、みんな、「おつかれ。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、おつかれでしょうねえ」　ニーナ嬢が、いつの間にか階段を下りて、房枝の横に立っていた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかあさんは、御病気ではないけど、おつかれでおやすみよ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）『おつかれ』（今晩は）と逢ふ人毎に声を掛けるのは山家の黄昏の習慣である。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
