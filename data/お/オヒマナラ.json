          ],
          "literary": [
            {
              "text": "一人で参っておりますから、お暇ならいらっしゃいましな」「さようですね。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お暇ならお遊びにいらっしゃいと、坂井さんが仰ゃったと云うのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お暇なら一つ御覧を願いましょうかな。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を返しさま柱の電鈴に手を掛くれば、待つ間あらせず駈けて来る女中の一人、あのね三好さんのところへ行ってね、また一席負かしていただきたいが、ほかにお話しもありますから、お暇ならすぐにおいでを願いたい。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お暇なら、これからきかせてあげる」「どこで」　阿難は笑ったが何も云わずに冷いのみもののストローに口をつけた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、気を取り直して、「ねえ、園子さん……今夜お暇なら、そちらとご一緒に、あたしたちの方へ参加しない？",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば小手調べに活動の切符などを持って来て、お暇ならどうですという。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これから新開地の聚楽館の屋上にあるスケート場へ行くのだと云って、あなたもお暇なら是非いらっしゃいと頻りに誘った。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかの吉奈温泉から、病氣でいま此處に來てゐる、おひまならお遊びにおいで下さいませんかといふ思ひがけない手紙がＦ――さんから來ました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "温泉宿の庭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひまなら、今日どうです、いっしょに行っちゃ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "登志子　　（それにはなんの反応もみせず）月ノ木先生、あさつての日曜、もしおひまなら、ちよつと午前中にお目にかかりたいんですけれど……。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひまなら論語の講義でもいたしましょうか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
