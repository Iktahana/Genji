        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "」「この五日の休みは、検査でお流れか。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「この五日の休みは、検査でお流れか。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日の晩は雨でお流れになるかと思ったらみんな本館の大広間へ上がって夜ふけるまで踊り続けていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしは見れると思って来たのだが、この豪雨のためにお流れになってしまったらしいのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお流れをみんな健啖な道化師の玉が頂戴するのであった。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御酒のお流れを一つ進じよう。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……吃驚なすって、貴方は、小雪さんの胸を敷いて、前へお流れなさいましたってね。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴球部の夏休みの合宿が、お流れになりそうだ、大事件だ、と言って興奮している。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、恋には丸木橋を渡って落ちてこそしかるべきを、石の橋を叩いて、杖を支いて渡ろうとする縁談だから、そこいら聴合わせて歩行く中に、誰かの口で水を注せば、直ぐに川留めの洪水ほどに目を廻わしてお流れになるだろう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことに邪魔をされて、今夜の歌留多会はとうとうお流れになってしまった。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔色が可恐しく悪いぜ、花札が走ったと見える、御馳走はお流れか、」と円輔はてかてかした額を撫でた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……）と、おくれて来た妹が、いきなり、（明日が可い、明日になさい、明日になさい、ああこう云ってると、またお流れになる。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御歓迎なり、有志の御紹介なり、昨日も三つばかり、そのための会合がお流れと申す始末――　これから、誰彼口々の口上は、読者諸君の想像にまかせた方が可い。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶などは固よりお流れである。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたの小金井行きはあぶのうござんすよ」　雨はあしたの日曜まで降りつづいて、わたしの小金井行きはとうとうお流れになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "アその痩せて増すべからず、肥えて減ずべからざる肉付きの妙なるに、心悸｜臂揺し、茫然自失して筆を落し続け、写生はお流れ、それからちゅうものは日々憂鬱して神定まらず「浅茅ふの小野の笹原忍ぶれど、余りてなどか人の恋しき」てふ態となる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの花火はお流れであろうと、林之助は雨の音をわびしく聞いた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの雨で花火はお流れになって、列び茶屋も大抵休んでいることを彼はさっき見て知っているので、お里は家にいるに相違ないと思った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの花火がお流れになって、お前ばかりでない、みんなも陰気な顔をしているだろうなどと、林之助も言った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "中二　わたしも蝦蟆のお流れ頂戴ですか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」縦令父が承知してゐても酔が醒めた時になると、お互に金のやりとりが気拙くなつて、其儘お流れになることは屡々なので、それを慮つて彼は斯う云つた。",
              "citation": {
                "source": "熱海へ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "めでたいお流れ様がまたかかったぞう！",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お流れいじりは商売のようなおれらじゃねえかよ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市の真実の主人たる市民は、そのお流れを頂戴するために高い税金を払っているということになる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、舐め筆の娘との縁談も無論お流れになってしまいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちには自然の邪魔がはいって、植疱瘡もお流れ……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、はつきりした日本語で言つてゐたが（念のため言つておくが、上田博士も谷本博士も数個国の国語には通じてゐたが、談話をする時には一番不完全な日本語でしてゐた）色々都合があつて、その御馳走もお流れになつたらしかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう、太郎をつれて国と三人で国府津へゆこうということになって、国は植木屋の用事、私はすこし片づけもの（この間から私たちの話に出ていた）をして来ようと思ってあらまし仕度したら、この天気でおながれよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おあとの、おながれを頂戴いたしたいので」「後と前、どちらでも、同じことじゃろ」　返してやると、その杯を、額にいただいて、「時に、ご老公」「なにか」「……あ、あなた様は」「どうした？",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おながれを」「そちも泣き上戸ではあるまいな。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一献、お祝いのおながれ戴こう」「うむ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
