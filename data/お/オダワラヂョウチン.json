    "definitions": [
      {
        "index": 1,
        "gloss": "(collapsible) cylindrical paper lantern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
