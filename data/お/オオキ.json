    "definitions": [
      {
        "index": 1,
        "gloss": "great",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこに此の世の喜びの話や悲しみの話は、彼のためには大きすぎる声で語られ、彼の瞳はうるみ、語り手は去つてゆく。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞きながら、大きいガツテンガツテンを、アクセントをつけてやつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分類が終るや能事足れりとなす所に、現代インテリの過ちがあり、恐らくこの過ちが彼を不幸にした大きい理由であつたと云へよう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ是等三様式は極めて短い詩形であるから、語自体の力が、語を駆使する作者の力よりも存外に大きいものであることは明瞭であらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論僕は、愉快な男といふのでもないから、さうなるのでもあるけれど、なんとなくその夜学といふのは、妙に互ひにそはそはした気持でゐる所であり、其処での知合ひだといふことが僕達を打解けさせない大きい理由のやうに思はれるのであつた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいトランクを二つ持つて、お土産物も沢山棚に積んでゐる此の男は、神経が太くて、まづまづ彼の親戚間では成巧者であるのに相違ない。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕ァね、こなひだン所で昨日またうんと飲んぢやつたよ」またしても三田村は大きい声で笑ふのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教会は板で囲つてあり、六百坪位の庭園を有し、フランス人のからだの大きい、学者肌の神父がゐて、その神父は大きい望遠鏡を持つてゐて、甞て夏の静かな夕べ、その庭に立つて空の星を見せて呉れた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側壁に一つの大きい窓。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔の旗本が住んでた屋敷で、大きな武家風の門があり、庭には蓮池などがあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の大きい、鼻の高い、よき坊さんです』『その同じ時、あなた比丘尼となりましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あなたの鼻高い、あなたの眼大きい』などという時、夫人はいつも指でヘルンの顔を突ついたりして、子供を扱うようにして戯れからかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の玄関へつくと、車夫がとても威勢の好い大きな声で、『オ帰リイ』と叫ぶ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人にとってのヘルンは、最も信頼する良人であったと共に、一面ではまた『大きな駄々ッ子坊や』でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時夫人が、江の島に遊んだ土産として、大きな法螺貝を買って帰った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この痛み、もう大きの、参りますならば、多分私は死にましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、大きいだろう、ね、海だよ。",
              "citation": {
                "source": "海",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大きな声を挙げて泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿は、こんな大きさで、こんな色をして、しかも秋に実るものであるから、これこれの意味であろうなど、ああ死ぬるほどいやらしい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛嬌もそっけもない、ただずんぐり大きい醜貌の三十男にすぎなくなった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお手紙の文面が、やさしく正直なのも大きな悦びでありましたが、それよりも何よりも、私にはあのお手紙の長さが有難かったのです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「われは横綱らしく強いところを見せようとして左の腕を大きくぶるんと振って相手を片手で投げ飛ばそうとしたが、相手は小さすぎて、われの腕はむなしく相手の頭の上を通過し、われはわが力によろめき自ら腰がくだけて敗れたのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの不幸が大きくなればなるほど、そうして僕の愛情が深くなればなるほど、僕はあなたに近づきにくくなるのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が赤毛氈の縁台のまんなかにあぐらをかいて坐ったまま大きい碾茶の茶碗でたいぎそうに甘酒をすすりながら、ああ、片手あげて私へおいでおいでをしたでないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い声で、「きょうは八十八夜」そうひとこと呟いたかと思うともう、てれくさくてかなわんとでもいうようにむっくり立ちあがって両肩をぶるっと大きくゆすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、まだですね」うしろむきのペリカンを紙面の隅に大きく写しながら、「馬場がむかし、滝｜廉太郎という匿名で荒城の月という曲を作って、その一切の権利を山田耕筰に三千円で売りつけた」「それが、あの、有名な荒城の月ですか？",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼黒くでらでらした大きい油顔で、鼻が、――君レニエの小説で僕はあんな鼻を読んだことがあるぞ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
