[
  {
    "uuid": "4603b55c-df6b-5223-8eee-6ae6def19f28",
    "entry": "踊り狂う",
    "reading": {
      "primary": "おどりくるう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to dance in ecstasy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ジャズも客観的に鑑賞するものではなくて、自分で踊り狂うと同価値の活動そのものだからである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓子があっという間にホールを出て行ってしまうと、小郷は軽い当身をくらったような、すかされた気持になったが、すぐまた背中をむき出しにしたダンサーをつかまえて、踊り狂うて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は篝火のまわりに踊り狂う村人達の目を避け手を携えて間道から浜に出ると、先程繋いでおいた独木舟に乗り、夜の海に浮かび出た。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、掌で以て胸や腕のあたりを叩いてパンパンという烈しい音を立て、腰をひねり奇声を発しつつ、多分に性的な身振を交えて踊り狂うのである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜五｜更になれば変化出て踊り狂う。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒になつて踊り狂うた茂作爺は、それでも獨り舟に寐に行つた。",
              "citation": {
                "source": "水郷めぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物してならぬと言うなら、遊山致してつかわそうぞ」　あちらへのそり、こちらへのそり、ウチワ太鼓、踊り狂ういやちこき善男善女の間を縫いながら、逃げのびた女やいずこぞとしきりに行方を求めました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "物すさまじい光景の中、幕府の権勢を空しゅうし、踊り狂う天狗舞い！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもは道路という道路は、踊り狂う人波で自動車も電車も通らないとの事だが、今年は、モンパルナス一帯常の日とどこも変りはない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその深夜十三世紀の円塔内のキャバレで、貧しい音楽に悲しいまでにたのしげに踊り狂う兵士とその恋人や、売子娘とその相手や、町の女、町の男達をぼんやりと眺めながら――異国者はつねに浮気だ――私はすでに帰りの旅を思っていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "96　舞い男――イスラム教の教団の一つに歓喜して踊り狂うことによって神との合一の三昧境を現出しようとするのがあるが、この教団に属する修道者がカランダールである。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、その園生の精のような溌剌とした美少女の群れが、まる一年、陽の目も見なかった貴重な肢体を、今、惜気もなく露出し、思い思いの大胆な色とデザインの海水着をまとうて、熱砂の上に、踊り狂うのである。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年このあたりの通りは踊り狂う群衆で、もう電車なんか通れたもんじゃなかったんだが、どうだ、このさびれ様は。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り狂う雪足の紊れながらも、幽かに梅の匂いも漂っている雪明りである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ終日終夜、全市の老若男女が入り乱れ踊り狂うのだから、あんな愉快な大騒ぎこそ羨ましく思う。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日の西村と彼女との闘争、解け難い疑問として残っている奇怪な出来事、それから野田の拘引、それらのことがひと呼吸のたびに艶子の脳裡で踊り狂うのだ。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄りに踊り狂うとき、人をして生の境を踏み外して、死の圜内に入らしむる事を知る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も民共は、財宝を捨て、酒・薬・六畜を路側に陳ねて「新富入り来つ」と歓呼したとあるのは、新舶来の神を迎へて踊り狂うたものと見える。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ広いところへ練り出して、馬をとどめて立つと、その周囲を輪になって、人という人が夢中になって踊り狂うのは、冷やかに見ていると、物につかれたとしか思われない振舞です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもお気の毒ながらこうなっては、それらの人の力で差しとめることはできませんね、音頭を取る茂ちゃん、踊り出さないわたしでさえも手がつけられないのに、留守をしている人たちに、どうしてこの踊り狂う人たちの血気を抑えることができましょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けても彼等の踊り狂う熱は醒めない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめのうちは頬冠りをしている者も多かったが、いつか知らずそれも脱けて落ちて、果ては自分の帯の解けて落ちたのを知らないで、踊り狂う女もありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り狂う行列のにぎやかさ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方を黒木の深林に囲まれた原の中央に立って眺めると、ここは衣姫の機織る場所ではなくして、森の精――サチルスやジレニ――が恣に踊り狂う饗宴の場所であるように想われる。",
              "citation": {
                "source": "秋の鬼怒沼",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の悪い人が、ジャズに踊り狂う一座に入って居たら、どんなに見じめなものか。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夜中の墓場から抜け出した骸骨の群れは、冥府の青白い灯を掲げ、その骨と骨を鳴らし乍ら夜と共に踊り狂う様は、サン・サーンの驚く可き技巧で、存分過ぎるほど丁寧に描き出されて居るのです。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り狂う数十百の骸骨は、その虚の眼を見開き、耳まで開いた口を鳴らして、青白い死の笑いを、――妖悪極まる死の笑いを――笑いかけます。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り狂う佐良井の身体は、一パイに開いたフランス窓から、傷いた昆虫のように跳躍して、広いバルコニーの上へ出ました。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲は益々熱を帯びて、百人の妖魔が、さながら空中に踊り狂うとばかり、鼓を鳴らして、此の世の正しからざるもの、偽れるもの、汚れたるものにいどみかかります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "結婚ラプソディ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにものッ」　豊後守が一刀をひきよせた時は、つづいて汁椀も、香のものも一汁三菜のしっそな膳までが、あやつり人形芝居の糸にあやつられたように、フワフワと宙につりあげられて、そのまま大きい部屋を、右から左へ上から下へと、おどりくるうのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
