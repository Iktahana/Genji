      {
        "index": 4,
        "gloss": "you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "君の意見は大事だ。",
              "source": "幻辞"
            },
            {
              "text": "君はどう思うか？",
              "source": "幻辞"
            },
            {
              "text": "君のおかげで成功した。",
              "source": "幻辞"
            },
            {
              "text": "君と一緒にいると楽しい。",
              "source": "幻辞"
            },
            {
              "text": "君の頑張りに感動した。",
              "source": "幻辞"
            },
            {
              "text": "君にお願いがある。",
              "source": "幻辞"
            },
            {
              "text": "君の夢を応援したい。",
              "source": "幻辞"
            },
            {
              "text": "君は素敵だと思う。",
              "source": "幻辞"
            },
            {
              "text": "君に任せて大丈夫だ。",
              "source": "幻辞"
            },
            {
              "text": "君の才能はすごい。",
              "source": "幻辞"
            },
            {
              "text": "君といるのが幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "君のアイデアが役に立った。",
              "source": "幻辞"
            },
            {
              "text": "君を信頼している。",
              "source": "幻辞"
            },
            {
              "text": "君の笑顔が大好きだ。",
              "source": "幻辞"
            },
            {
              "text": "君との時間を大切にしたい。",
              "source": "幻辞"
            },
            {
              "text": "君のサポートに感謝する。",
              "source": "幻辞"
            },
            {
