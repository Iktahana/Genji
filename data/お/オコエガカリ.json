    "definitions": [
      {
        "index": 1,
        "gloss": "recommendation (of an influential person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あの、大博覧会の出品ね――県庁から、この錺職へお声がかりがある位ですもの。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とたしなめられて不承々々、「こうこう夫人のお声がかりだ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神世の昔××××様のお声がかりの港なんだから、いつから初まったか解かれねえ位だ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイこの頃まで生きていた太田｜道灌のお声がかりなんてえシミッタレた町たあ段式が違うんだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱えて突出すと、（かけてお上げ、）　というお声がかり。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にお声がかりで招き呼ばれたとは言い条、町方勤めの八丁堀ものが、城内の変事に手を染めたことからしてが、そもそも異常事なのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧正天海が将軍家お声がかりによって建立したその天海寺の中に、十手を必要とすべき下手人がいるとするなら、これはじつにゆゆしき一大事だったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "神妙に申し立てぬと、生きのいい啖呵が飛んでいくぞッ」「それならばこちらでいうこと、かりにも加賀｜大納言さまお声がかりの御用商人でござんす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仙もあやうく放逐されそうになったが、これはお嬢さまのお声がかりで僅かに助かりました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔なら、退引ならぬお声がかりの婚礼だぞ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "願いというのは――」「雪之丞も、いそがしい間を盗んで、折角お顔出しをいたしたいと申すのでござりますゆえ、お声がかりで、お病間まで、招き入れてやりましたら、どのようによろこぶかわかりますまいと存じますが――」　それこそ、浪路にとって、わたりに船であった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "隊長のお声がかりで、新しい防寒服はすぐ出来たし、その上、毛皮がそとについている防寒帽をつくってもらうやら、靴もエスキモーにならって外を魚の皮でつくり、内にはやはり毛皮を張ってあるものを貰うようにしてたいへんな可愛がられようであった。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、きっとお上のお声がかりということになるにきまっている、お役人が出向いて来て力ずくで差しとめるということにきまっているよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には江戸に時めくお役人に取り入り、そのお声がかりから尾州侯の御用達を勤めるほどのものも出て来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "学界のために喜ぶべきであるが、本人が困っているなら自費でやることは出来なかろうから、むしろ新たに、大学で植物志を出版するように計画したがよかろう」　こういう事で、浜尾さんのお声がかりで『大日本植物志』がいよいよ大学から出版される事になった。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、どなりつけるようなお声がかり。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、丹波をはじめ一同は、いぶかりながらも、とにかく主筋となっているお蓮さまのお声がかりだから、みんな不平そうに刀を引いた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるお方からお声がかりがあるまではあたしが預かっているようなものなのさ」と十二分に要心して「お礼をいわしてちょうだい。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来が引っ込んで行くと、「面を上げい」　というお声がかりだ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か茶番でもやらぬか」　院のお声がかりで、平判官康頼がついと前へ出てきた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来なれば利根を渡って縄張り違えなこの辺の百姓一揆なんどに引張出されるのは少し筋の違った話だが、水戸の天狗があばれ出すのなんのと噂のあるご時世だ、八州様お声がかりとあって、代官お手代役浜野様のいいつけで弥造の方から話がありゃ、まさかに懐手して佐貫の方から眺めてもおれねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、吉村さんは公方様並びに一ツ橋様お声がかりの、大事な、大事な人だぞっ！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その直接のお声がかりというので、私は恐る恐る前へ進み出た。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今から三年も前のこと、当時はまだ元気の良い石原の利助は、町奉行から特別のお声がかりで、勘定方の役人と一緒に、東海道宇津谷峠まで出張し、十日あまりも滞在して調べましたが、何の得るところもなく帰って来たことは、平次もよく記憶しております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来なれば利根を渡って縄張り違えなこの辺の百姓一揆なんどに引張り出されるのは少し筋の違った話だが、水戸の天狗があばれ出すのなんのと噂さのある御時世だ、八州様お声がかりとあって、代官お手代役浜野様の言い付けで弥造の方から話がありゃ、まさかに懐手して佐貫の方から眺めても居れねえ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川家の世になって甲州の仕法は、いっさい信玄の為し置かれたままを襲用して差支えなしということであったが、ただ一つ、甲州の軍勢が用いた毒矢だけは使用相成らずと東照権現のお声がかりであった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは、贔屓のひき倒しというやつでござるの」「そうそう、それに、書見のほか、ほとんど身動きもせぬ体じゃ」「ところが、二汁五菜は、太守のお声がかりでござれば、これや、一存で減らすわけにはゆかず……。",
              "citation": {
                "source": "べんがら炬燵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがもし事実なら、馬鹿囃しの笛を吹いたり、藩主のお声がかりで求婚したりしたことは、松尾のような気性の者には屈辱だったに違いない。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、そのときから半年ほどまえに、岡村八束が藩主のお声がかりで、馬廻りにあげられ、なお食禄を二百石加増される、という出来ごとがあった。",
              "citation": {
                "source": "竹柏記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
