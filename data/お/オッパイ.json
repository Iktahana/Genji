          ],
          "literary": [
            {
              "text": "さあ、おっぱいやろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、暑さと、それから心配のために、食べものが喉をとおらぬ思いで、頬の骨が目立って来て、赤ん坊にあげるおっぱいの出もほそくなり、夫も、食がちっともすすまぬ様子で、眼が落ちくぼんで、ぎらぎらおそろしく光って、或る時、ふふんとご自分をあざけり笑うような笑い方をして、「いっそ発狂しちゃったら、気が楽だ。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、一歳の次女におっぱいを含ませながら、そうして、お父さんと長女と長男のお給仕をするやら、子供たちのこぼしたものを拭くやら、拾うやら、鼻をかんでやるやら、八面六臂のすさまじい働きをして、「お父さんは、お鼻に一ばん汗をおかきになるようね。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか赤坊の時から、紫式部や、おっぱい御上り、清少納言や、おしっこをなさい、ワンワン来い来い、などと云われたので無かろうことは分っているが、仙人の女王、西王母の、姓は侯、名は婉泥滞水の挨拶を以て其場を済ませて置くというようなことも仕無かったろうから、次第次第に夫婦の間は険悪になっていったであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母様のおっぱいが飲みたくはないの」　女は小声で笑った。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「のの様、おっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……のの様、おっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、欲くないの、坊、のんだの、のの様のおっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お雛様のような、のの様のおっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角が、方角が違ったぞ、と慌てる処へ、おっぱいが飲みたい、とあびせたのがあります。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯛もしおっぱい海の水を出て、じかに空気に触れるので、よく風邪でも引いて充血したように、真っ赤な眼をしているのがよくある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、あのおっぱいは下を向いてるだろうけどな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後生ですから、そこから鋏をもってきて頂戴な、ね」こんどはだまっていましたが、いそいでそこにあった人形を抱きあげて、「あたし、いま、人形におっぱいあげていますの……」と言いました。",
              "citation": {
                "source": "人形物語",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "小娘の癖におっぱいがぶらぶらしてゐる。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃き火のまわりで、子供におっぱいをやっているひともあったりして、そのきっちりと手拭でくくられた頭の上に大きい水中眼鏡がのっている。",
              "citation": {
                "source": "漁村の婦人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時頃に一度お乳を遣った丈だったので、空おっぱいをあずけたまま、先ぐお乳を作りに配膳室へ出て行った。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はまことに涼やかで、私のおっぱいが一貫目もあるほど重い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汐汲み」を踊って、楽屋で乳母やのおっぱいを飲んだことを朧気に覚えています。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれをたかちゃんのおっぱいだといって、何か気ちがいのようにきゃっきゃっといってふざけながら、その乳汁を方々へこすりつけたりした。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おっぱいの匂いだろう。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おう可哀そうに、おっぱいの時間でしょう。",
              "citation": {
                "source": "裸木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとお母さんのおっぱいでも吸う気でいるのでしょう。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、よし、お兄さん、おっぱいにさわってはいけませんよ。",
              "citation": {
                "source": "お母さんのお乳",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「赤ちゃんが生まれるまでは、坊やが、毎日こうして、母さんのおっぱいにぶらさがっていたの。",
              "citation": {
                "source": "お母さんのお乳",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　つね子ちゃんは　おかあさんに　だかれて、おっぱいを　たらたらと　お目目に　いれて　いただきました。",
              "citation": {
                "source": "おっぱい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　きいて、そばで　みて　いた　よしおさんも　おっぱいを　こいしそうに　ながめて　いました。",
              "citation": {
                "source": "おっぱい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ちゃんは、泣きさえすれば、いつも、おっぱいがもらわれるものだと思っていました。",
              "citation": {
                "source": "はてしなき世界",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、お母さんがそばにいなかったときでも、おっぱいがほしいといって、すぐにもらわれないと怒って泣いたからです。",
              "citation": {
                "source": "はてしなき世界",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは、すぐにここへきて自分を抱いて、おっぱいをくださることがわかったからです。",
              "citation": {
                "source": "はてしなき世界",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
