        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "華族様の御台様を世話でお暮し遊ばすという御身分で、考えてみりゃお名もまや様で、夫人というのが奥様のことだといってみれば、何のことはない、大倭文庫の、御台様さね。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "震える手で明い処へ持出して、顔を見られまいと、傍目も触らず、血の上った耳朶を赧うして、可愛らしく畏って、右見左見、「おやおや、大倭家内松山峰子様行と書いてあるねえ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯も蛙も同じ歌仲間というが敷島の大倭での事、西洋では蝮が唄を作るのじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "其大倭王居邪馬臺國。",
              "citation": {
                "source": "後漢書倭傳",
                "author": "范曄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから四五尺の長さにメッキリと書き詰めた漢文の上を形式ばかり眼を通して、その結末にある、大倭朝天平宝字三｜年癸亥五｜月於西海火国末羅潟法麻殺几駅大唐翰林学士芳九連二｜女芬　識　という文字を二三度繰り返して読んで、いくらか気を落付けてから、もとの通りに巻き返して箱の横に置いた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "古記に云はく、遊部は、大倭国高市郡に在り。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "古事記と日本紀では、これ亦表現が違ひまして、日本紀は還らず、大倭葛城の故郷に帰られ、古事記の方は途中から引き返して来られたやうです。",
              "citation": {
                "source": "真間・蘆屋の昔がたり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大倭の朝廷の語部は、征服の物語に富んで居る。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "松尾が日吉と同じ神とせられてゐるのは、平野が大倭神であり、加茂が三輪系統のあぢすきたかひこねの命としての伝へもあつたからであらう。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此群をあんがまあと言ひ、大倭から来るものと考へてゐるが、其は海の彼方の理想郷からであらう。",
              "citation": {
                "source": "鬼の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ひを継承せられるのが、大倭の君であつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "国の組織が出来てからは、大倭国内の豪族は、皆｜大身を意味する敬称を以て、君から遇せられた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした人々の間にも普通になり、大倭宮廷の諸部民なるかきべ、大身の部民なるともべにも、一貫して行はれた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和の北と真中の平原にあつた村々を支配するまでに、づぬけて勢力を持つて来たのが、山辺郡｜大倭を土台にした村だつたのである。",
              "citation": {
                "source": "万葉びとの生活",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏々の誄・百官の誄など奏したのも、或期間、魂の生死に弁別がなかつた為だ――にも共通の慣用句であつたらしい「現御神大八洲国所知食大倭根子天皇云々」と言ふ讃詞は、天子の神聖な資格を示す語として、賀正事から、此に対して発達したと思はれる詔旨（公式令）の上にも、転用せられて行つた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "神人は、大倭の顕つ神の宰たる国司等の下位になつた神の奴隷として没収せられ、虐使せられる風があつた様だから、どうしても亡命せねば居られなかつた地方もあつたであらう。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国民に向つて仰る時には、「大倭根子天皇」とお称へになるのです。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷に行はれた四種の鎮魂儀礼の中、鎮魂祭は、大倭宮廷の旧儀である。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯大倭宮廷に古くあつた鎮魂術の形式上の制約に入つて、舞踏を主として、反閇の効果を挙げようとしたのが、かぐらであり、「言ひ立て」によつて、精霊を屈服させようとする事と、精霊が「言ひ立て」をして、服従を誓ふのと、此二つの形を一つにごつたにして持つものが、「ほかひ」であつたとは言へる。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、外蕃に対しての関心を持たない時代の詔詞は、大倭根子天皇なる御資格を以て、大儀礼を宣せられたのだ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で「大倭根子……天皇」と謂つた御諡を持たれた御方々がおありになる訣だ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、其時代は何時かと言ふに、我々が普通、日本有史時代と考へてゐる大倭宮廷の発祥時よりも、或はもつと古く考へて、世間では、既に純文学の現れた事を予期し勝ちな時代においてすら、尚徐々と、文学及び文学的なものに向つて行つて居た、と言はれるのである。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大倭宮廷の歴史を中心にして考へても、我々は、奈良朝以前を一括して、発生時代と見てもよいと思ふ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しひねつ彦とおとうかしとが、爺婆に扮して簑笠を着て、敵の中を通つて天香具山の土を盗んで来た（神武紀）と言ふ伝へは、実はまれびとに扮した村々の事実を、大倭の象徴たる山の土を以てした呪咀に結びつけて、二人の姿が考へ出されたのである。",
              "citation": {
                "source": "まれびとの歴史",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、作者も単一でなく、中には京から来た役人、旅人等の作もあろうし、京に住んだことのある遊行女婦のたぐいも交っていようし、或は他から流れこんだものが少しく変形したものもあり、京に伝達せられるまで、（折口博士は、大倭宮廷に漸次に貯留せられたものと考えている。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙の包みをあけてみると、中味は金メッキのお守りで、大倭大根大神とあるのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大倭大根大神とは聞きなれない神名ですね」　新十郎がこう呟くと、古田は答えて、「左様です。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の先祖は大倭大根大神という神で、日本全体の国王であったが戦い敗れて一族を従えてこの地に逃げ住んだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "布留の市もさうで、大倭の社に関係があります。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大倭根子天皇」といふのは、万代不易の御名で、元朝の勅にも、即位式の詔にも、皆此言葉が使はれてゐたが、此は云ふ迄もなく、やまとの国の、最高の神人の意味である。",
              "citation": {
                "source": "神道に現れた民族論理",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
