            }
          ],
          "literary": [
            {
              "text": "オルドヴルとオニオングラタンとビーフピカタ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリルで、オルドヴルとオニオングラタン、コールドラブスターを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢はうと思ってた森岩雄も発熱して帰っちまったので、すっかりあぶれ、ホテルのニューグリルで一人で食事、オルドヴルに、オニオングラタン、雛のココット、こいつはうまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュはオニオングラタン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱になり、ホテルニューグリルで、オニオングラタンに、オルドヴル、コールビーフで食事し座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタン、舌平目の洋酒煮に、クラブハウスサンドイッチ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
