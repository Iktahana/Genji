        "examples": {
          "standard": [
            {
              "text": "おぼこ娘について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おぼこ娘がありますね。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおぼこ娘の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおぼこ娘が好きです。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おぼこ娘の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおぼこ娘があります。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おぼこ娘について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおぼこ娘の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおぼこ娘が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおぼこ娘は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおぼこ娘について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおぼこ娘の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おぼこ娘を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんならと云って、小切れで肘衝でも縫って上げたら、岡田さんにはおぼこ娘の恋のようで可笑しいと思われよう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんなにやかましい注意をうけても、今度が初めての店出しというおぼこ娘のお染には、どうしていいかちっとも見当がつかなかった。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう言ふ心に住しはじめた彼は、芝居の世界に曾てなかつた驚くべきおぼこ娘を表現することが出来るやうになつた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、おぼこ娘の出来ぬ――無邪気な芸質の乏しかつたといふ点――其がすべてを説明するやうに思はれたのであらう。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ恋心に眼のくらんだ、嫉妬することをさへ忘れたおぼこ娘の純情でせうか？",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もただ今ならば、なかなかこれらの事に得心は致しませんが、その時はほんのおぼこ娘であつて、そしてまたとても一度はどこへか遣らるものと覚悟してをりましたから、心弱くもうけひくとはなしに、うけひきました。",
              "citation": {
                "source": "こわれ指環",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼこ娘はあんなのが好きでしょうか、――もっとも芝居に出てくる、二枚目のような、侍のくせに弱々しいところがありますがね」「主人の造酒助はどうだ」「初めてしみじみ話してみましたが、良い男ですね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のタレにもいろいろ階級があって、若い小娘、おぼこ娘を「シンダレ」、年増を「マダレ」、年寄り「バアダレ」、芸者が「シャダレ」、女郎は「チョウチョウ」、女郎買いは「チョウマイ」。",
              "citation": {
                "source": "符牒の語源",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼこ娘の初恋と云ふものを人格にして見せたらこんなだらうと思はれる程である。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「娘のゆかりさんに訊いて見ようぢやないか」　平次は早速お勝手からゆかりを呼び出しましたが、十七になつたばかりのおぼこ娘は、「父さんは、お金を持つてゐるやうでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "門野家へ私がお嫁入りをしましたのは、どうした御縁からでございましたかしら、申すまでもなく、お嫁入り前に、お互に好き合っていたなんて、そんなみだらなのではなく、仲人が母を説きつけて、母が又私に申し聞かせて、それを、おぼこ娘の私は、どう否やが申せましょう。",
              "citation": {
                "source": "人でなしの恋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
