            }
          ],
          "literary": [
            {
              "text": "よくいう思い上がるということ、それはこんなことを指すのではないかと思えてならないくらいである。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十歳そこそこでご家老の職をけがしては、思い上がるも無理はないとな。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし――　うっかり、それで思い上がることは出来ないぞということを、彼は今、見せられていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
