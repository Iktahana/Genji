          ],
          "literary": [
            {
              "text": "君は弟月のことをいっているのだろう。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟月が、だんだんあやしい光を強め、大きくふくれて来るわ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸の最後「こんどは、弟月の方をおっかけよう。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟月はもっと左の方にある」　画面が横にうごいて行く。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれはちょうちんではなく、弟月の方だった。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが弟月ですか。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜこんなに大きくなったんです」「弟月はだんだん下ってきたのだ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に弟月は地球にぶつかるから……」「おじさん。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたんびに弟月は化物のように大きくなった。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟月が地球に触接したよ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも弟月は自転をつづけているんだ」　おじさんの説明の声がふるえている。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、弟月は地球にぶつかっている。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、弟月の最後が近づいた。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大爆発をして、こなごなにとび散るよ、あの弟月が……」　おじさんの声が終らないうちに、画面は目もくらむ閃光で、ぴかぴか、くらッくらッと光り、画面に、ものの形を見わけることができなかった。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟月は、かげも、形もなくなったよ。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
