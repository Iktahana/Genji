        "examples": {
          "standard": [
            {
              "text": "お釈迦さんという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお釈迦さんの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお釈迦さんという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お釈迦さんは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お釈迦さんの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お釈迦さんは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お釈迦さんはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お釈迦さんの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お釈迦さんが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お釈迦さんのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お釈迦さんに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お釈迦さんの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お釈迦さんは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お釈迦さんの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もつたいなくも本堂の広い涼しいところで会食、酒、ビール、てんぷら、さしみ、お釈迦さんもびつくりなすつたらう、観音さまはいつもやさしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釈迦さんでもやっぱり縮れているじゃないか、と良人に笑われて姑は納得したものの、今度は良人のほうが後あとまでも清子へ恩をきせる始末に、有難迷惑なようでもあった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の事が信じられなくて、たとえイエスであろうと、お釈迦さんであろうと、貧しい者は信じるヨユウがない、宗教なんて何だ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にゃあ、神の道があるし、唐天竺にゃあ孔子、孟子、お釈迦さんもおいでなのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご覧よお釈迦さんは家を出てしまった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも裏の事実は一人の例外なしに、堂々、不正の天才、おしゃかさんでさえ、これら大人物に対しては旗色わるく、縁なき衆生と陰口きいた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストも、おしゃかさんも、ごちゃまぜになった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
