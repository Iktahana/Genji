        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "板は唯一枚しかなかつたから、さつきの繪の裏へ極めて大まかに描き始めた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は身体を車体に揺られながら自分のような平凡に過した半生の中にも二十年となれば何かその中に、大まかに脈をうつものが気付かれるような気のするのを感じていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　現代作家の文章を考へてみても、ごく大まかな詞ではあるが、志賀直哉は驚くほど神經質に鋭く簡潔、菊池寛は無駄なく直截適確、谷崎潤一郎は莊重で力強く、佐藤春夫は典雅纎細、里見※は流麗精緻、――一一擧げたらきりがないが、さういふ特色は言ひ換へれば、作者の氣質持前の現れに外ならない。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿本は、少し、馬鹿で、大まかな高取のことを思った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "板はただ一枚しかなかったから、さっきの絵の裏へきわめて大まかにかき始めた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げて来る潮で波が大まかにうねりを打って、船渠の後方に沈みかけた夕陽が、殆ど水平に横顔に照りつける。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、山代の温泉のこの近江屋は、大まかで、もの事おっとりして、いま式に余り商売にあせらない旅館だと聞いて、甚だ嬉しくて来たのであるが、これでは余り大まか過ぎる。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――実は旅の事欠けに、半紙に不自由をしたので、帳場へ通じて取寄せようか、買いに遣ろうかとも思ったが、式のごとき大まかさの、のんびりさの旅館であるから、北国一の電話で、呼寄せていいつけて、買いに遣って取寄せる隙に、自分で買って来る方が手取早い。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體父は、余り物事に頓着せぬ、おつとりした、大まかな質でありながら、金といふ一段になると、體中の神經がピリ／＼響を立てて働くかと思はれるばかり、遣口が猛烈となる。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "大まかな百姓仕事や、飯爨や、副食物の世話ぐらいは、どうにかこうにか人間並に出来るには出来たが、その外の読み書き算盤はもとより、縫針なんか一つも出来なかった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』となっているのでありますが、その間に私の下手な蛇足を挿入すると、またこの「女の決闘」という小説も、全く別な廿世紀の生々しさが出るのではないかと思い、実に大まかな通俗の言葉ばかり大胆に採用して、書いてみたわけであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの定形律は、韻文として極めて大まかのものであって、一般外国の詩に見るような、煩瑣な詩学上の法則がない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝の水は増したが、溢れるほどでもなく、ふだんのせせらぎはなみなみと充ちた水勢に大まかな流れとなって、かえって間が抜けていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大まかな菜根の匂いがする。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸前のきりりとして、しかも大まかな女形男優顔の女が、前髪を額に垂らしたり、束髪に網をかけたりしていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人、芹川進君を紹介します、先生の御指南を得たい由にて云々という大まかな文章である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのかわり大まかなものだよ。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大まかに掻捜して、御飯、お香こう、お茶の土瓶まで……目刺を串ごと。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で想像して居たより独逸人の技巧は大まかだ。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理的の欠陥者が、その不自然な動作ゆえに却って名優が大まかに工んだ芸をしてるようにも受取れるあの様子を、男女、二人、しかも手つなぎで揃って行くものですから、もちまえ芝居がゝつて見える遊郭風景に加えて、大歌舞伎の道行姿を切抜いて貼付けたような、際立たしさで浮きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汚のうございますよ」　平べったくて眼鼻のつけどころが大まかな、そして顎だけしゃくれている顔が母親そっくりですが、こどもの顔にすると愛嬌がありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背に腹は代えられぬ情なさだが、しかし「セントルイス」は女の経営にしては、万事大まかに穴があいて、ちゃっかりした抜け目のなさが感じられぬのは、さすがに本妻の気品で、他の京都人経営の喫茶店を嗤っているところもあり、「おれ京都がいやになったよ」　と、京吉が言いに行くには、ふさわしい店でもあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何と、ロスキーの大まかで、善良で、無邪気で、一本気で、また開放的でやりっぱなしであろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜　以上は現在私が抱いてゐる詩についての見解と要求とを大まかに言つたのであるが、同じ立場から私は近時の創作評論の殆んど総てについて色々言つて見たい事がある。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の事は大まかに見逃していたものが、能前の昂奮期に入ると、「それはいかん」と云う口の下から自身で立上って始末したという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大まかに不ぞろいに刈り散らして虎斑をこしらえる者もあれば、一方から丁寧に秩序正しく、蚕が桑の葉を食って行くように着々進行して行くものもあった。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがあれの粗なのですが、大まかに見りゃあ、いい仕事をしとります。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど大まかなことしか指定しないＨＴＭＬでは、画面上での読みやすさが配慮できません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおまかで如何にも寛々とした無智。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜〜　以上は現在私が抱いている詩についての見解と要求とをおおまかにいったのであるが、同じ立場から私は近時の創作評論のほとんどすべてについていろいろいってみたいことがある。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
