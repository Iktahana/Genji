        "examples": {
          "standard": [
            {
              "text": "おふざけについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おふざけがありますね。",
              "source": "幻辞"
            },
            {
              "text": "おふざけというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおふざけの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおふざけが好きです。",
              "source": "幻辞"
            },
            {
              "text": "おふざけを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おふざけの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おふざけはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおふざけがあります。",
              "source": "幻辞"
            },
            {
              "text": "おふざけは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おふざけについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおふざけの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おふざけの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおふざけが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おふざけについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおふざけは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおふざけについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おふざけという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおふざけの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おふざけを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」と言つて噴き出し、「おふざけでない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふざけでないよ、寝ているかとおもえば眼が覚めていて、出しぬけに床ん中からお酒を買えたあ何の事たえ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふざけで無いよ馬鹿馬鹿しい。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悪癖が身に付いたのは学生時代のちょっとしたおふざけかららしい。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ホームズはこう言って、机に椅子を引き寄せ、踊る人形のおふざけを記録した紙切れを、最初から最後まですべてその前に広げた。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい何のおふざけ――ネェ？",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果的にしょっちゅう辞書ばかり引いて、しかもおふざけか否か判然としないまま、宙ぶらりんで読み進むことが何度もありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も見ていなかったところで、年長の九歳の方の娘のメイが、おふざけで、アガサを金庫の中に閉じこめてしまったのだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふざけでないよ」　女の右の手は頭にかかって黒いピンが抜かれた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝ加減におふざけなさいツ。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の木をおいたわりになる責任もお忘れになるくらいにおふざけになった。",
              "citation": {
                "source": "源氏物語",
                "author": "まぼろし",
                "note": "青空文庫"
              }
            },
            {
              "text": "……たんとおふざけなさい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえに祈られちゃア、うまくゆく日光も、ぐれはまになるだろうテ」「おふざけでないよ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お藤姐御だけはすましたもので、しゃがんで背をむける一人を、「おふざけでないよ」　とこづいたまま、白い脚もあらわにピョイととび越して、ほほほと笑ったものだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふざけ召さるる場合でない。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめえといっしょに湯にへえるのも、楽屋風呂以来、久しぶりじゃあねえか」「おふざけでないよ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふざけじゃないよ。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふざけでない、行ってみせる！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーンウォールの漁師は、苦境にあってもスコットランド人より冗談を飛ばすけれども、この種のおふざけはしないから、メアリが堂々と笑うのを聞いちゃ、精神的にも道徳的にも耐えられなかったのだろう。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が外国人でなかったら「おふざけなさんな」と肩でも叩いて笑い転げてしまうところであったが、大真面目で話しているカ氏の顔を見るとそれもできなかった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと半時間後かそれぐらいに、今晩のおふざけは終わったと言って、お抱え運転手を探すふりをして、抜けだして、ここへ来て、わたくしを連れ出してください。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事もおふざけ遊ばされておいでですが、殿下の行いが重大な損害を与えたことを少しでも思し召されるなら……」　レックミア侍従が両肩をすくめて言葉を止めた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の目的とやらが、おふざけで遊ぶことだ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでもおふざけを引き受ける事情がお分かりでしょう。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふざけをやると、何も考えられなくなるのが私の悪いところです。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふざけは済んだのですから」「そのおふざけは修復の域を超えています。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に、自分が行ったおふざけを倍返しする方法があります。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
