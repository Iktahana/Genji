        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何故というに、キャリフォルニアからオレゴン州への、境近い街道に、山が聳えて、複式二重の成層火山、シャスタとシャスチナと、二人の容姿端麗なる姉妹が、見る角度に依っては、並んで手を繋ぎ合ってもいるし、また背中合せに丈くらべをしているようでもあり、何となく人｜懐かしい山に見えるからである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャスタへ行くには、私たちの居住地、桑港から、オレゴンへと北向する南太平洋鉄道の便を借りるのである。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドから帰るとオレゴンの果樹園でリンゴ作りにせいをだし、今度はエレクトロニクス仕掛けのリンゴ作りに転向した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレゴン松がすくすくと白波の激しくかみよせる岸べまで密生したバンクーバー島の低い山なみがそこにあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち月は益々冴え、庭のオレゴン杉の柔かな茂みの蔭に、白い山羊が現れた。",
              "citation": {
                "source": "黒い驢馬と白い山羊",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白山羊と黒驢馬とは月の光に生れて偶然オレゴン杉のかげで出会った。",
              "citation": {
                "source": "黒い驢馬と白い山羊",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になって、ジョブスはオレゴン州のリード大学に進んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルーボックスの商売から足を洗ったあと、スティーブン・ジョブズは一九七二年に、オレゴン州ポートランドのリードカレッジに進学していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "快楽主義――これだけが人間の最後の目的なのだろうか」　九月二十五日の頁を見ると、ただ一行、「今日で丁度、病床生活一年間」　アグネス・アン・ルロイは、オレゴン州テラムウクの生れで、本名は、アグネス・イムラア。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年、一九三一年の夏、ルロイ夫人は親戚の用で、一寸故郷のオレゴン州ポウトランドへ帰ったことがある。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パナマ」「オレゴン」「ゴールデン・ゲート」「コロンビア」などの当年切っての優秀船が就航して太平洋横断いつでも来いと待構えた。",
              "citation": {
                "source": "汽船が太平洋を横断するまで",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌二十八日を終日、オレゴンの森林帯で過し、落葉林に美しく霜の置いた朝景色を、ワシントン州に這入って見た。",
              "citation": {
                "source": "南路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜米利加のオレゴン州ポートランドのオッサンは、いかにもヤンキーらしく、まず貴下の学界における地位を明示せよ。",
              "citation": {
                "source": "雷嫌いの話",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで須磨の大村さんの家へころげこんで、ちょうど大村さんはオレゴンの支店長になってアメリカへいっていた留守のところさ。",
              "citation": {
                "source": "陽気な客",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "メキシコとの戦争で西はカリフォルニア、南はテキサス、北はオレゴンまで、広大な領土をいちどに自分のものにしたアメリカは、モンロー主義によってメキシコ、中南米、カリブ海の島々を、次々にねらいうちしていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
