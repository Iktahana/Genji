        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今日の実習は陸稲播きで面白かった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一（登場　枯れた陸稲をもっている）「稲の伯楽づのぁ、こっちだべすか。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「陸稲のごとでもわがるべすか。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「はあ、おりゃの陸稲ぁ、さっぱりおがらなぃです。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「厚ぐ蒔ぐて全体陸稲づもな、一反歩さなんぼごりゃ蒔げばいのす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "品種や土壌によりますがなあ、さうですなあ、陸稲一反歩となるというと、可成いろいろですがなあ、その塩水撰したやつとしないやつでもちがいますがなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」爾薩待「ははあ、塩水撰した陸稲の種子と、土壌や肥料にもよりますがなあ。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民二「陸稲のごとでもわがるべすか。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民二「はあ、おりゃの陸稲ぁ、さっぱりおがらなぃです。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと、陸稲が枯れるんですか。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民三「おれぁの陸稲ぁ、さっぱりおがらなぃです。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた方は陸稲の枯れたことに就いて相談においでになったのでしょう。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾薩待「ああ、（証明書を書く）この証明書を持って薬屋へ行って亜砒酸を買って水へとかしてあなたの陸稲へおかけなさい。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの陸稲はすっかり枯れたでしょう。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（農民二　登場）農民二「陸稲さっぱり枯れでしまったます。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「虫も死ぬ位だから陸稲さも悪いのでぁあるまぃが。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民四「全体、みんな同じ陸稲だったがら悪がったもな。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦刈れば戦ぐさみどり、畝の間にすでに伸びつる陸稲ならしも。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の外では庭で傭人が陸稲を扱きはじめたと見えてぼり／＼と懶相な音が聞える。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "傭人は四人で向合になつて陸稲を扱いて居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "各左手に積んだ陸稲の束をほぐしてはぶり／＼と扱いて居る。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりの手入れの行届いた畑には、薯、菜、大根、黍、陸稲なんかが育ってる。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も陸稲の大束を四｜把づつも背負つて通つたぢやなえかね。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の尾をいくめぐり、谷にそひ、谷をわたり、森のかげ路のをぐらきには、落葉ふむ跫音にもおびえつゝ、やゝ里近くなりたる処に、山畠の陸稲の、方一反、波うちかへすが中に交りて、大きなる柿の木の枝もとをゝに実りたるが、折からの入日をうけて立ちたる。",
              "citation": {
                "source": "筬の音",
                "author": "――わが幼時の記憶――",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸稲、いも、甘藷だが灰色がかって白いまずそうなの、ナス、大根、ギョク（トーモロコシの一種）、軒下に下ってる玉もろこし。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷のあとは鋤きかえされて、今は陸稲が緑々と茂って居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早｜早生の陸稲も蒔かねばならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸稲や黍、稗、大豆の中耕もしなければならぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑ではズボラの武太さんは褌一つで陸稲のサクを切って居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "望台を中心としてほゞ大円形をなした畑地は、一寸程になった麦の緑縞、甘藷を掘ったあとの紫がかった黒土、べったり緑青をなすった大根畑、明るい緑色の白菜畑、白っぽい黄色の晩陸稲、入乱れて八方に展開し、其周囲には霜に染みた雑木林、人家を包む樫木立、丈高い宮の赤松などが遠くなり近くなりくるり取巻いて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
