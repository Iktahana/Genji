        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれどもそこからボートまでのところにはまだまだ小さな子どもたちや親たちやなんか居て、とても押しのける勇気がなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそこからボートまでのところには、まだまだ小さな子どもたちや親たちやなんかいて、とても押しのける勇気がなかったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそこからボートまでのところには、まだまだ小さな子どもたちや親たちやなんか居て、とても押しのける勇氣がなかつたのです。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、又次郎は若い女中を押しのけるようにして玄関へ出てゆくと、父はもう草鞋を穿いていた。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「源ちやん、」「なんだ、」「源ちやん、」「もう好い、何も云ふな、綺麗に別れよう、」　源吉はその手を無理に押しのけるやうにした。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は子供が可愛くないのか、何故そんな馬鹿な真似をする、しつかりおし、すぐ癒してやるから、」　省三は玄関の方へ走つて行つて先つき自分が脱ぎ捨てたままである駒下駄を急いで履いて格子戸を開け、締めずに引いてあつた雨戸を押しのけるやうに開けて外へ出た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズバンドの音が気おくれした豹一を押しのけるようになかからきこえて来て、道頓堀のアスファルトを寒く乾かしていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はどこかカフェーへ入って、ソーダ水へウイスキーの佳いのを割って飲みたいと思ったが、やっと懐へ入って来た女を逃がすような隙を作ってはならないので、すぐその気もちを押しのけるようにして歩いた。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの奥さまを押しのけるなど、それはあさましい暴力みたいで、私はいやなんです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は小供が可愛くないのか、何故そんな痴なまねをする、しっかりおし、すぐ癒してやるから」　省三は玄関の方へ走って往ってさっき己が脱ぎ捨てたままである駒下駄を履いて格子戸を開け、締めずに引いてあった雨戸を押しのけるように開けて外へ出た。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは神田の半七だよ」　半七の名を聞いて、女は俄かに驚いたらしく、あわてて彼を押しのけるようにして逃げ出そうとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "何思ったか例の案内人は、宇利氏の背後から押しのけるようにして柵を飛び越そうとしたが、宇利氏に引きとめられて、しばらくゴテゴテと押し合い揉み合い、やがて馳けつけたほかの駅員達に取押えられて、どうやら観念したらしく、事務室のほうへ連れて行った。",
              "citation": {
                "source": "三の字旅行会",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」新一郎は、そういって、山田を押しのけると、「伯父上、御免！",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――またしてもその手がわたしを押しのける。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも愛想のいい、もの柔らかな手つきだが、とにかく押しのけるのである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は一寸ペンを止めて、毬の方へ目を逸らしたが、指先でそれを押しのけると、黙つてまた書き物を続けた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は馳けていって姉を押しのけると自分でその躑躅をひいてみた。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の晩、突然、腹部に激烈な疼痛が起ったので、家人が寝台に寝かしたそうですが、それ以来｜間断なしに呻いていて、ときどき吃逆がまじって、人が手でものべると、触られるのを嫌がって、一生懸命に押しのける身振りをする。",
              "citation": {
                "source": "麻酔剤",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして看護婦を押しのけるように、ずかずか隣の座敷へはいって行った。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、気まずさを押しのけるためか、急にまた快活に話し続けた。",
              "citation": {
                "source": "母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は曲げた片肱で反絵の胸を押しのけると静にいった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ――子宮、血の道には、このオイチニイの薬ほど効くものはござりませぬ」　私は材木の上に群れた子供達を押しのけると、風琴を引き寄せて肩に掛けた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞鍋は思ひきつて球江の躯を押しのけると蚊帳から出ていつた。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕上げミシンの急所のところで、多喜子が、「あ、ちょっと、そこはこうした方がいいんじゃないかしら」　自分でミシンを踏みかけたら、小枝子が、「私、下ふみますから……」　多喜子を軽く押しのけるようにした。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚釜しく、人を押しのける事ができないで、苦笑しながら、自ら引退る傾向をもっている。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄明は、どこか永劫の彼方から来て、暗い夜を押しのける。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしクラバツクはこの河童たちを遮二無二左右へ押しのけるが早いか、ひらりと自動車へ飛び乗りました。",
              "citation": {
                "source": "河童",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしクラバックはこの河童たちを遮二無二左右へ押しのけるが早いか、ひらりと自動車へ飛び乗りました。",
              "citation": {
                "source": "河童",
                "author": "どうか Kappa と発音してください。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと、望遠鏡をわしに貸しなさい」　蟻田博士は、新田先生の体をおしのけるようにして、望遠鏡に目をあてた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠坂峠へかかろうとするころ、とつぜん、重い足音がうしろに迫ってきて、四人の男がキャラコさんをおしのけるような乱暴な仕方で追いぬいていった。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
