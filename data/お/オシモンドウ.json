    "definitions": [
      {
        "index": 1,
        "gloss": "arguing back and forth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
