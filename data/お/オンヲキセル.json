    "definitions": [
      {
        "index": 1,
        "gloss": "to make one feel grateful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
