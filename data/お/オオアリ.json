          ],
          "literary": [
            {
              "text": "「大ありのコンコンチキ……」「ふーん。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少、思い当ることがないでもありません――いや実は大ありなのですが――清水君。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実と違うところでもあるのか」「……大ありだ……」「エッ……」「しかも今のところでは全然事実無根だ」　私はドキンとして飛び上りそうになった。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その蝶合戦が何か捕物に関係があるんですか」「大ありで、それが妙なんですよ」　これが口切りで、わたしは今夜もひとつの新らしい話を聴き出すことが出来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は色気が無いどころか、大ありだった。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大あり、大あり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、なにかい、その日にかわかしていたとかいう子どもの足にゃ、ほかに何か不審と思える節は気がつかなかったのかい」「ところが、それが大ありなんでがすよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、なにか仕切りがござるか」「大ありでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "つじ切りと申しますると、いくらでも世の中にためしのあることでござりますゆえ、別段事変わっているようには思われませぬが、なんぞ奇怪な節でもがござりまするか」「大ありなのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろでどこぞにご内命をうけて、内偵に参られたことござりましたか」「大ありじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かご用でも――」「大ありじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、あいつになんか恨みでもあるのか」「大ありですよ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな流名があるのかい」「私のつけた流名で」「よりどころでもあるのかい」「そりゃアありますとも、大ありで。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「有るともさ、大ありだ……」と美以美派の田舎政治家は立ち上つて演説でもするやうに手真似をした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が、秋川家の者を恨む理由は何もないじやありませんか」「ないどころか、大ありさ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごわすとも、大ありでな。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "大あり、小あり、高あり、低あれども、皆巖也。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "覗いて聞いていた奴もタイシタ奴に違いないが……」「しかし、それが絵巻物とドンナ関係があるんですか」「大ありだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も直接にお前たちと関係のある話じゃないだろう」「それが大ありなんですよ、馬鹿馬鹿しい」　と女将が大見得を切った。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "是実に死して猶生けるもの、彼の三十一年の生涯は是の如くにして始めて光栄あり、意義あり、雄大あり、生命ありと云ふべし。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ありましたとも、大ありだったんですけど……ほんとうに思い出しても腹が立っちゃあうんですよ」「逃げられたんでしょう」「にげ様にもよるじゃあありませんか、マア、斯うなんですよ、私がネ、こないだ新橋に行った時、ステーションにですよ、その時あの玄関に二人女が立ってたんです。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あるともあるとも大ありだ」「人を切ったこともない癖に」「小篠！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるともあるとも大ありだ。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中川君、広海子爵は近日何か食物研究会のようなものを開かれるとお登和さんに伺ったが今日はその御相談もあったかね」中川「大ありさ。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、オレの立場になった人は誰だって里に住むのがイヤになるね」「他国へ働きにでることを考えてみなかったかね」「考えたことは大ありさ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "賀美村へ戻って定助の殺された時の様子をこまかく調べてみると何かが分るかも知れませんね」　新十郎がこう云うと、花廼屋は、「それも大ありだが、私は二ツの屍体が天狗の面をかぶされていたのが奇妙だと気がついたね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "大ありおほ有り、毎日々々、其ぢや。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうと睨んだ稲荷カンスケの第六感、はずれたタメシは――」「大ありだ」「その通り！",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど検印がもらえないという心配もあるわけだね」「大ありナゴヤだよ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おおありましたか、もう大丈夫！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
