[
  {
    "uuid": "cafc8f6a-7298-561c-b1c3-82b8e444ee52",
    "entry": "大水",
    "reading": {
      "primary": "おおみず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flood",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一めん波が菱立って来た放水路の水面を川上へ目を遡らせて行くと、中川筋と荒川筋の堺の堤の両端を扼している塔橋型の大水門の辺に競走のような張りを見せて舟々は帆を上げている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪のあるのは旧大きいお邸の医者様の跡でな、ここいらはこれでも一ツの村でがした、十三年前の大水の時、から一面に野良になりましたよ、人死もいけえこと。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其謡は何人が作つたか知らぬが、童幼皆これを口にするに及んで、俄然として江東大水、家流れ家洗はれ、婦女も裳裾をかゝげて右往左往するに至つたのである。",
              "citation": {
                "source": "震は亨る",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度は、富士吉田で、私は大水に遭い多少の難儀をした。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邊は去年大水の出た跡だつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此奴、狡猾い奴だ」と、兵站係の衣水子、眼玉を剥き出し、「八人前八銭ではないか、余分を返せ」と談判に及べば、船頭は一旦握った金を容易に放して堪るものかと、「この大水だで――」と頑強に抵抗したが、「馬鹿をいうな。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "川名はこの夏大水で堤防がくづれ、家がみな流れ、田や畑は砂にうまつてしまつただ。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ大水でもと、私はおもふ橋が流れて呉れゝばいゝにだが、河の神さまはいふ橋を流すより、身を流せ。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある廊下の一角＝＝白磁の大水盤に紅白カーネーシヨンの群花入り乱れたる「戦ひの図」　食堂＝＝ミユンヘン国立ビール飲用場の陶製ジヨツキーに石楠花、すかし百合、耳付一輪挿にマーガレツト、スヰートピー。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしたちは果して生きて向う岸に行き着けるかどうか、この大水では、心もとない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――川こ大水で、行かえない。",
              "citation": {
                "source": "雀こ",
                "author": "井伏鱒二へ。津軽の言葉で。",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この辺が、大水の跡です。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲を取って、ころり投げ出されたと思って目さあけると、船の中は大水だあ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顔の大井川は、あれは大水で、それに朝顔は、めくらの身なんだし、あれには多少、同情するが、けれども、あれだつて、泳いで泳げないことはない。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊枝　加旃また加茂川の大水。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し夫れ、銅絃鉄撥、劈雲の調に激して黒竜江畔にひゞけば、大水忽ちに止まつて血涙の色をなせりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝｜須らく汝の自負に傲慢なれ、不遜なれ、大水の声をあげて汝みづからの為に讃美し、謳歌して可也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪のあるのは旧大いお邸の医者様の跡でな、此処等はこれでも一ツの村でがした、十三｜年前の大水の時、から一｜面に野良になりましたよ、人死もいけえこと。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月はじめの大水のとき以来、使わなかったアセチレンの照光器を灯してお秀は待っているのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが熱き炎の都、都なる煉瓦の沙漠、沙漠なる硫黄の海の広小路、そのただなかに、饑ゑにたるトリイトン神の立像、水涸れ果てし噴水の大水盤の繞には、白琺瑯の石の級ただ照り渇き痺れたる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "命はそのときにはさっそく満潮の玉を出して、大水をわかせてお防ぎになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までひでりでさわいでゐた村の人は、今度はまた急に大水におどろかされてあわて出しました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが明治の初年、ここらでは何十年振りとかいう大水が出たときに、小袋明神もまたこの天災をのがれることは出来ないで、神社も神体もみな何処かへ押流されてしまった。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "万軍の敵も味方も汝が矛地に伏せて、今、大水の響に我が呼ばふマカロフが名に暫しは鎮まれよ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにもここにも、たいへんなよろこびが、大水のようにあふれました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下には、豐に水を湛へたる大水盤あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に我眼をひきしは、一間の中央なる大水盤なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、在来の社殿、音無川の小島に在せしが、去る二十二年の大水に諸神体、神宝、古文書とともにことごとく流失し、只今は従来の地と全く異なる地に立ちあり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく合祀励行のために人民中すでに姦徒輩出し、手付金を取りかわし、神林を伐りあるき、さしも木の国と呼ばれし紀伊の国に樹木著しく少なくなりゆき、濫伐のあまり、大水風害年々聞いて常事となすに至り、人民多くは淳樸の風を失い、少数人の懐が肥ゆるほど村落は日に凋落し行くこそ無残なれ。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "すめらみことは戦に、おおみずからは出でまさね。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
