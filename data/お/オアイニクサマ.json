        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「sorry」である。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「sorry」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "sorry」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "sorry」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「sorry」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "sorry」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「強い、お生憎様で。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それはお生憎様でござりまするな。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人には気の毒だが、こればかりはお生憎様だ。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この後猴声を入るるなりとあるを読んで、何とか実地研究と志しいたところ、右の報告を見てお生憎様と知った。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの身体が三つあるなら、三方へ走ってゆくのだが、お生憎様、一つしかねえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へ、こいつはお生憎様だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は真剣事でお光さんに言ってるんだぜ」「私に言ってるのならお生憎様。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄席で、下足でもいじってやすめえか」「深雪って、娘が、来なんだかい」「ここの長屋は、皆、下地っ子に売っちまって、娘は只今、お生憎様だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今度はお生憎様さ、ちょっとも引け目なんかないんだからな」　こんなように考えた。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、随分大勢じゃないか」「そうさね、随分大勢だね」「荷物だって沢山じゃないか」「そうさ随分沢山だなあ」「どんな人達だか見たいものだね」「お生憎様、駕籠が閉じている」「これでマア別荘も賑やかになるね」「化物屋敷でなくなるわけさ」「それにしても妙だったね。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればガン首も手足も無事じゃないか」「ヘエ」「それとも何か動きのとれない証拠でも押えて来たのか」「お生憎様で」「お生憎様てえ奴があるか、馬鹿だなア」　平次もとうとう噴き出してしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お生憎様ですが、元日一日で出払ってしまいました」「何、出払ってしまった。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけれど、私が、密輸入の信号をしているわけじゃないから、お生憎様ね！",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っているならば、くどく聞き給うな」「お生憎様。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「秦野の古葉は小出しがしてなくてお生憎様ですが、薩摩じゃ如何でございましょう」「薩摩はどうも好き嫌いがあって売りにくい。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「見えない」――と金右衛門は谷底へ手をかざして、「まだまだとても下までには余程な距離がありそうだ」「谷河の水音がする……」「ウム、遠雷のように」「うまく、水の上に落ちていれば助かるだろうが」「おッと、兄貴」「どうした、金右衛門」「お生憎様、道はここで行き止まりだ」「なに、行き止まりだ？",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもおあいにくさまだが吾家の母様はおまえの心持を見通していらしって、いろいろな人にそう云っておおきになってあるから、いくらお前が甲府の方へ出ようと思ったりなんぞしてもそうはいきません。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おあいにくさま、あんな池はとっくにうまってしまいましたよ」「じゃア、うまった跡にぐらつく安借家が出来た、その二軒目だろう？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「烏賊があるなら、烏賊をもらおうか」「烏賊はおあいにくさま、がんもどきならありますが」「じゃ、がんもどきと、はんぺんにしてもらおう」　老人が鍋の中からがんもどきとはんぺんを挟んで山西の前へ出し、それから盃も出したところで、もうお燗が出来た。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がたつたこれ一ツしか授からないから、先づおあいにくさまといふ処だ、貴様がうつちやる権理のあるのはこれ一枚限りだ、おあいにくさまだナア、アハヽヽヽでも、私だつてうつちやると諦つてはしませんよ、なにか好ことにつかふかも知れませんもの。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、菊廼屋歌吉っていうやつあ男の野郎なんですかい」「女は女だがね、おあいにくさまなことに、もう七十に近い出がらしの梅干しばあさんさ」「ちえッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "「火事に慣れないものなら、仏壇と石うすをまちがえてかつぎ出すということもあるが、おあいにくさまにきさまは鳶頭だったんで、あわてましたと申し開きのできないことがおきのどくだな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "能書きはあとにして、急所だけてっとり早く話したらどうだ」「ところが、そいつがくやしいことにはおあいにくさま。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッ、ホッ、ホッ、ホッ、おあいにくさま！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おあいにくさま」と八左衛門、あごを前方へ突き出したが、「似合わないなあ、え丸橋。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし間もなく錦紗の絞りの風呂敷包みが届いて、葉子がそのつもりで羽織を着て、独りで燥ぎ気味になったところで、今夜ここで一泊したいからと女中を呼んで言い入れると、しばらくしてから、その女中がやって来て、「今夜はおあいにくさまですわ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨野　おあいにくさま。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おあいにくさまだよ」と米友が言いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天気だと枝豆にゆで玉子いろいろこしらえて置きますが今日は何もおあいにくさまでと色の白い円顔の年は二十四五の女房。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老の種切れは天麩羅屋の口癖にして鮪のおあいにくさまは鮨屋の挨拶。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
