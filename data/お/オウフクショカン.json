          ],
          "literary": [
            {
              "text": "往復書簡は自然、その一年間の出来事にもふれているので、「十二年の手紙」とされている。",
              "citation": {
                "source": "はしがき（『十二年の手紙』その一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本年三月号の『文芸』で森山啓氏と伊藤整氏とが、森山氏の「収穫以前」について文壇的な礼譲ある往復書簡体の感想を書かれたことがあった。",
              "citation": {
                "source": "数言の補足",
                "author": "――七日附本欄伊藤整氏への答として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ雑誌などに発表される高木との往復書簡には、一つとして宛名の千恵子に様がついていない。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑摩書房で出した、チエホフとゴルキイの往復書簡を送ってくれたこともある。",
              "citation": {
                "source": "風貌",
                "author": "――太宰治のこと",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
