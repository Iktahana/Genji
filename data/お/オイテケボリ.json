    "definitions": [
      {
        "index": 1,
        "gloss": "leaving someone behind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今度はわたくしを連れて来たのを忘れたと見え、わたくしは置いてけぼりです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は乞食に拾われた捨子の成り上り、置いてけぼりを喰った私生児、迷児の拾い落しなぞもあろう。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前、石本君とも話したが、鈴木は可哀相に置いてけぼりばかり食ってる。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年前の安吉のように、子供を置いてけぼりになど絶対にしないのである。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう年をとってしまいまして、モダンな現代から置いてけぼりを食ってしまったのやと思います。",
              "citation": {
                "source": "帝展の美人画",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして乗つてしまつたら、あとは置いてけぼりにされるんですか。",
              "citation": {
                "source": "夢の国",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり私を置いてけぼりにして、何処かへ立ち去って了ったのです。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は主膳に酒を飲ませておいて――ではない、主膳が昨晩から酒浸りになって、今は熟睡しているのをよいことにして、体のいい置いてけぼりを食わせて、みんな出払ってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "快適もいいが、こうなってみると、なんだか置いてけぼりにされたような気持もしないではない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかそうか、悪い時には悪いものだ、グレる時には一から十までグレるものだ、ここでも、みんごと、置いてけぼりにされてしまった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「友達に置いてけぼりにされた、独りぼっちの子がまだそこに残っているよ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある聖降誕祭の時節に、あそこにいるあの独りぼっちの子がたった一人ここに置いてけぼりにされていた時、始めてあの老爺さんがちょうどああ云う風をしてやって来たのだ。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "と――思いもかけず、吹貫亭の四畳半へ置いてけぼりにしてきた勅使河原静江の黒目がちの眼差が、幻燈の画面のように眼先へちらついてきた。",
              "citation": {
                "source": "圓朝花火",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきおいあたしは置いてけぼりを食い、あわれっぽいようすでうろうろと求婚者をさがしまわる。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それはそうと、どうしてあたしをこんなところへ置いてけぼりにしたんだろう？",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分だけ一人が置いてけぼりにされたのを口惜しがって、情婦のミリアムのところへ嫌味をいいに来たのだった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ムク、昨夜、手前なんだっておいらを置いてけぼりにして、どこかへ行っちまったんだ、先廻りをしてこんなところへ来ているとは人が悪いな、人じゃなかった、犬が悪いんだ――だが、お前は良い犬だ」　米友はムク犬の頭を撫でてやりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに、こんな親切な人を置いてけぼりにしようとか、まいてしまおうとか考えた自分というものの薄情さを、お雪ちゃんはクドいほど悔む気になってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "未練の充分にある、自分には過ぎ者の女に置いてけぼりを食って、事実、お絹のいう通り、別れる時は泣いてあやまったかも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲馬団の親方は、わざとラン子を置いてけぼりにしてしまったので、彼女は当分パトロン老人との共同生活を続ける外はなかった。",
              "citation": {
                "source": "江川蘭子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十滴を理想としていた太宰は、井伏さんを置いてけぼりにして、駈け足でこの世からさよならしてしまった。",
              "citation": {
                "source": "井伏鱒二によせて",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく使いこまれた雰囲気や、置いてある物の古びた影のなかに、朝の六時三十分から午後三時までの営業を三十年にわたってくりかえしてきた時の流れの、置いてけぼりになってそのままそこにとどまっているごく小さな断片が、ひっそりとあった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さんを置いてけぼりにして、主人が外出すると思うのか」　きめつけられた助手先生は、頭を掻きながら、お人好しに笑った。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、用事を先にすまさなくっちゃだめだから、おまえたちはそこいらで待っておいで」「いやだわ、置いてけぼりなんか……」「誰が、そんなことをするもんか、すぐそこだよ」「どこ？",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしをおいてけぼりにして。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "去勢牛どもは軛を外して草を食まされ、荷物は道路においてけぼりにされた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたおいてけぼりになったの。",
              "citation": {
                "source": "博多人形",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしい横転の始まった瞬間には、僕の身体は、機外においてけぼりにされたように感じた。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜久しぶりにバーにはいり、分別盛りの年甲斐もなくいい気持になつちまつて藤枝においてけぼりを食わせられてから、まだおそくまで残つていて大分酔つて戻つたのだが、酒のために床に入るとそのまま、恐ろしい殺人事件も何もかもすつかり忘れてぐつと一息に眠つてしまつたらしい。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨のつぶてのように、私一人を東京においてけぼりにすると、いいかげんな音信しかよこさない男だった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
