[
  {
    "uuid": "685bbd8c-4e7c-5bc8-b5db-1f1f60b210f8",
    "entry": "音源",
    "reading": {
      "primary": "おんげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
