[
  {
    "uuid": "c79152c3-018e-577f-878f-c258fee86b8b",
    "entry": "陸湯",
    "reading": {
      "primary": "おかゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
