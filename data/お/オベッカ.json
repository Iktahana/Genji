        "examples": {
          "standard": [
            {
              "text": "おべっかについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おべっかがありますね。",
              "source": "幻辞"
            },
            {
              "text": "おべっかというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおべっかの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおべっかが好きです。",
              "source": "幻辞"
            },
            {
              "text": "おべっかを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おべっかの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おべっかはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおべっかがあります。",
              "source": "幻辞"
            },
            {
              "text": "おべっかは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おべっかについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおべっかの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おべっかの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおべっかが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おべっかについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおべっかは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおべっかについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おべっかという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおべっかの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おべっかを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おべっかを使って、落ちこぼれをめぐんで貰おうと心がけている手あいだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社員に、おべっかを使うように、ペコペコ頭を下げた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あンちき生、課長や、山長さんにゃおべっかばっかしこけやがって！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この猫は鼠を一匹も捕らぬくせに泥棒猫で、近所から嫌われていましたが、「ニャーニャーゴロゴロ」とおべっかを使うのが上手なので、この家の人に可愛がられていました。",
              "citation": {
                "source": "どろぼう猫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "カステラも、パンもあるよ、などと言って騒ぎますので、自分は持ち前のおべっか精神を発揮して、おなかが空いた、と呟いて、甘納豆を十粒ばかり口にほうり込むのですが、空腹感とは、どんなものだか、ちっともわかっていやしなかったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた達は、お金持の奥さんに、おべっかを言っていただけなんだ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの習慣については、実は内心大いに閉口しているのだが、しかし、これとても、私のつまらぬおべっかの報いに違いないのだから、誰をも恨む事が出来ない。",
              "citation": {
                "source": "黄村先生言行録",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来や小者はもうみんなが母様におべっかッてるんだから、誰一人｜執成してくれようと云うものはなし、しかたがないので、そっとね、姉様が冤の罪を被せられて――昨夕話したッけ――冤というのは何にも知らない罪を塗りつけられたの。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり現在の人間がやっているおべっかやお追従は、人間が動物から進化して純愛の一大団結たるべき下稽古――霊的文化の世界を組織すべき手習いをやっているものと見るが至当でありましょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "星者は曾の気位の高いのを見ておべっかをつかった。",
              "citation": {
                "source": "続黄梁",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、フランスは旧教の国だから、「アジアの嵐」のなかの最も皮肉で愉快な場面、よだれをたらした赤坊のラマに帝国主義国の将軍が勲章をつけてお辞儀したり、おべっかつかったりする場面、反宗教的な場面をあらかた切ってしまってあった。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方のより金の力のつよい側に一方の悪口をいったりするのは、おべっかか、お追従として、日本の気質が下劣と認めている態度である。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがクヴシンニコフの奴は、ああいう恥知らずだから、その女の傍へ擦りよりゃあがって、フランス語なんかでジャラジャラおべっかを使やがるんだ……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」少佐は、この言葉でもわかるとおり、今度は少しおべっかを使う気になったのである。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下 p.83 p.85p.85　しかし一方民衆におべっかを使うなどということは、おれの力じゃ到底出来ん。",
              "citation": {
                "source": "「緑の騎士」ノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おべっかりがあんまり過ぎて。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに限らず、すべての点で彼が非常に卓越した人間であるということを、気が弱くてついおべっかを言う癖のある私は、酒でも飲むとつい誇張してしまって、あとでは顔を赤くするようなことがあるので、淋しくても我慢してひとりで飲む気になるのである。",
              "citation": {
                "source": "遊動円木",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の多助の気の利くことは、主人の用向ばかりでなく、番頭から小僧から、家へ出入る者一同から、おさんどんにまでも宜く勤めますが、決しておべっかでするのではなく、信実に致しますので、番頭が肩が張ったと云えば直ぐに後へ※って打きます。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この憎むべき老いぼれの悪漢が、私に使ったのとそっくり同じ言葉のおべっかを、他の人間に言っているのを聞いた時の私の気持がどんなだったかは、諸君も想像出来るであろう。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりにまみれ、どろ臭く、金と数字と目上の人へのおべっかしきゃない。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によってお役人にソッと頼んで、緩い手錠に取替えてもらうように運動をしようとすると、本人の道庵先生が頑として頭を振って、「俺ゃ、そんなことは大嫌いだ、そんなおべっかは、おれの性に合わねえ、これで構わねえからほうっておいてくれ」と主張します。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "露台が一杯に見える一段高くなった所には、半円形にずらりと列んだ、悪い顧問官達や、おべっか使いの廷臣達にかこまれて、えらいポリデクティーズ王が着座していました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "従來、文相は橋田、岡部、二宮、兒玉というように、右翼のイデオローグばかりで、軍部へのおべっかが彼らの仕事だった。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのおべっかなの？",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは私よりもその妾の方へおべっかをつかい、奥様々々と云っていました」「とかくそんなものですよ。",
              "citation": {
                "source": "あの顔",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの丹下左膳てえ隻眼隻腕の化け物は、なるほど世の中に役にたたぬ代物じゃが、しかし、農工商をいじめながら徳川におべっかをつかう武士という連中にあいそをつかし、世を白眼視しておる点で、吾輩と一脈相通ずるところのある愉快なやつじゃ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "良民をとらえて人柱などと、これも、この徳川へのおべっかか。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体が、近江之介におべっかを使うための喬之助いじめである。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本におべっかを言うことを知っておりますが、貧乏人を見舞うことを知りません。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ア）帽子屋変だし　　　意味もないのに　　　おべっかなんて言いたくない（全）そうさ、そうさ、そうだ！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
