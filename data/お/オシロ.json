        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "朝顏・晝顏・夕顏等、其名の如く其時に開き、西洋でもオシロイ花を、開く時に因んで、四時（フオワ・オークロック）と呼ぶ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケジュールに追われて、休日、自宅でオシロスコープを睨みながら試作機の回路をいじっていたとき、後藤氏もまたラジオを聞いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな女社長ないですよ」　アキ子は鼻をピクピクさせて、よろこび、約束の日に鼻の頭に粉オシロイをペタペタたゝきつけ、タケノコで資金を作って、でかける。",
              "citation": {
                "source": "遺恨",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくまアあんな馬鹿騒ぎができたものだと夏川は思ふが、あれぐらゐ傍若無人の馬鹿騒ぎになると、あたりが呑まれてその気になつてしまふもので、オコノミ焼の母親まで一ぱし芸者めく気持になつてオシロイもぬりかねない打ちこみ方になつたから笑はせる。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大は反物、オムツカバー、メリヤスシャツの類からポマード、オシロイ等の化粧品、シャボン、ブラシ、鋏、ナイフ、ヘアピン等の日用品一切にわたって売り歩く。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "香具師の親分ときいて、このバカな内儀が何年間つけたこともないオシロイなどぬりたくり、チヤホヤしたから、それからは親分が見廻りにくるたび御休憩の家となり、親分御食事中はほかのお客はお断り。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "オシロコ屋というのが二軒だか三軒あったよ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "のぞいて歩いたら、オシロコ屋というのにビールがあったよ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "オシロコを食わなくっても、チャンとビールをのませてくれた。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンスホール、ハレム、オシロコ屋、三ツとも違う。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールで二百五十円、ハレムで三百円、オシロコ屋で二百円だったかな。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オデン屋ぐらい、ないのかな」　と呟いたら、支配人が、「ええ、手前どもは、できるだけ優美典雅に、又、できるだけ安直に、美とたわむれていただきますために、男子用の散財店をさけまして、実用品店と、女子必需品店、オシロコ屋でありますな、そういった気分であります。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "オシロコは胃にもたれるし、ビールは高いし、頭かるのは実用的で、全然もうかッとるですから」　アプレゲールは全然エライよ。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで花が咲いたような美しい特別の着物を年中着せられている上に、七ツ八ツから紅オシロイまでつけているのである。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "花天狗流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣するものが、みなオシロイの粉をふりかくることになっている。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女はオシロイや香油などの化粧料の匂いのために、似たような匂いの人がウンと居ますが、ルリさんはあまり化粧はしないと見えて、ハッキリとそれがかげるのです。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "景子は、そのまま僕の方へは目もくれないで、ゴシゴシとじやけんにオシロイのハケを動かしていましたが、急に「困るなあ、立川なんて言つて、やつて來られたんじや！",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかたが無いからシワやブクブク太りを、オシロイやドウランでごまかして、ハダカになつたり、腰を振つたりしてね、フフフ！",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の下をグイと伸してオシロイのパフを叩きつけたり、思いきり目をむいて横を見たり、實にコッケイなことをします。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の隅に置かれたオシロスコープは今のところほとんど使ったことがないが、将来的には合成音声を自分たちのサウンドに取り入れていくつもりなので、結局は楽器の仲間入りをすることになるだろう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "また丹波のヒコタタスミチノウシの王の女のヒバス姫の命と結婚してお生みになつた御子はイニシキノイリ彦の命・オホタラシ彦オシロワケの命・オホナカツ彦の命・ヤマト姫の命・ワカキノイリ彦の命のお五方です。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でオホタラシ彦オシロワケの命は、天下をお治めなさいました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、景行天皇・成務天皇景行天皇の后妃と皇子女　オホタラシ彦オシロワケの天皇（景行天皇）、大和の纏向の日代の宮においでになつて天下をお治めなさいました。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた樣はどなたでいらつしやいますか」と申しましたから、「わたしは纏向の日代の宮においで遊ばされて天下をお治めなされるオホタラシ彦オシロワケの天皇の御子のヤマトヲグナの王という者だ。",
              "citation": {
                "source": "古事記",
                "author": "現代語譯　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿波でも吉野川の上流ではシロイ、隠岐の島にもまたシロエの名があり、対馬でもこの草の葉をオシロイグサというを見れば、シレイは必ずしも元の音とも言えない。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
