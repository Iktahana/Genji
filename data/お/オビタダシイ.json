        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "玉島のあたりははらかた釣りが夥しいが、女子供が大半を占めている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間、全一週間、そのために寝たっきり呻いていた、足の傷の上にこの体を載せて、歩いたので、患部に夥しい充血を招いたのに違いなかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、改札口へ登つて行く階段だか斜面だかには夥しい人の群が押しかけてゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日｜夥しい花が咲いては落ちる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに映画の場合では撮影者が長い時間とフィルムを費やして撮影した夥しい材料の中から、無駄なものを省略し、最も重要なものだけを選び出し、それを巧みに編輯してあるから、観客は極めて短い時間の間にこの動物のあらゆる特徴を最も純粋にまた最も強調された形において観察することが出来るのである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年三月二十日『東京朝日新聞』）　　　　　　　　　六十八　　　　　　真珠の採取にＸ光線の応用　世界中の真珠産地で年々に採る母貝の数は夥しいものであるが、その中で真珠を含んでいるのは比較的に少ない、それで母貝の多数はつまり無駄に殺されてしまう事になる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、私は文通の夥しい遲滯からやつと救濟されたのです。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "広東香港間の電信が切断されてその後の消息は不明なのですが、恐らく明日は外国人は南方に於ける商業上の前途を楽観して、交易所では支那へ夥しい投資が行われるでしょう。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次はウォール街に電流を通じて円価で夥しい投機をやる筈だ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　酒と歌と踊のなかからでてきた男女が熱い匂のする魅力にひかれて、洪水のようにながれる車体に拾われると、夥しい巡査がいま迄の蛮地のエロチシズムの掃除を始めて、街は伝統とカルチュアが支配する帝王色に塗りかえられた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "前門の経済通報社の万事相談室には早朝から夥しい人がつめかけていた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切った者があるにもかゝわらず、放たれた豚の数は夥しいものだった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に含まれている Pb と Zn だけでも夥しいものであろうと思われた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夥しいかもめの群れが渦巻いている。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　御勝手になさい、膠のないこと夥しい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓をたよるほど暗さが増して気の滅入る事又夥しい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女房めが、風流を解しないこと夥しい。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夥しい星が白熱した花火のように輝いていた。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義末期の社会層には、不景気に反逆する上流社会の堕落例が夥しいものだ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にせい筑紫次郎という筑後川の水上に在る山奥の町じゃけに、四方の山々から切出いて川へ流す材木というものは夥しいものじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "分けて雨催ひで風の死んだ、羽蟲の夥しい夜であつた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の商店の、夥しい、瓦斯、洋燈の灯と、露店のかんてらが薄くちらちらと黄昏の光を放って、水打った跡を、浴衣着、団扇を手にした、手拭を提げた漫歩の人通、行交い、立換って賑かな明い中に、榎の梢は蓬々としてもの寂しく、風が渡る根際に、何者かこれ店を拡げて、薄暗く控えた商人あり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか臭いようで、その塩からいこと夥しい。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜田門へ来ると夥しい巡査だ。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくの間に、俥のふえた事は夥しい。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つて氣焔が夥しい。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮のさゝない中川筋へ、夥しい鯔が上つたと言ふ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古色の夥しい青銅の竜が蟠って、井桁に蓋をしておりまして、金網を張り、みだりに近づいてはなりませぬが、霊沢金水と申して、これがためにこの市の名が起りましたと申します。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四日前からはそれが実におびただしい速度と量を増して来た。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験としての文学と科学　たとえば勢力不滅の方則が設定されるまでに、この問題に関して行なわれた実験的研究の数はおびただしいものであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
