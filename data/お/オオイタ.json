        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれどももう今は大分打算的な頭に、これでも以前に比べれば余つ程なつてゐるのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "額縁も古ぼけ、紙も大分｜煤けたようだが、「森の絵」はいつでも新しい。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源のすぐ傍に丞相の郭光はもう大分酩酊したやうにして膝をくづして、ひかへて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はあれからは大分老いて見えた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九合目に来た、もう一杯の雪で、コンクリートで堅めたように凍っているから、鳶口ででもなければ、普通の金剛杖では、立ちそうにもない、胸突八丁、大ダルミなどは、大分息苦しく、殊に足の辷り方が烈しかったが、それでも思いの外に、怯まずに登りついた。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "フン、俺も大分焼が廻ったな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の従来の「短歌」とは形式ばかりでなく内容的にも大分ちがった別物とは思いますが、こういう新しい詩形に固有な新しい詩の世界を創造して行くのは面白いことだろうと思われます。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○百貨店○○支店の一行は和服が多く、此方は藝者を揚げて三絃の音を響かせて居るが、肝心の本職の藝者の歌謠の節※はしが大分危なつかしく、寧ろ御客の中に一人いゝ聲を出すのが居て、それがやゝもすると外れかゝる調子を引戻して居るのは面白い。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の秋になつて病氣の工合が大分よくなつたし、醫者も許し又すゝめてくれたので、何處かへ試しに行つて見ようと思ふと、生憎なもので時候外れの霖雨がしばらくつゞいて、中々適當な日は來なかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此邊の子供には大分專門的の知識があつて「チューブ」だの「パレット」だのといふ言葉を云つて居るのが聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白痴ですが、普通の馬鹿とは大分変っておりまして、みんなに、とても大事にされました」　そして、これも遠来の講演者に対する馳走とでも思ったように四郎馬鹿について話してくれた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな大分溯ったな。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もう大分のぼっていました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦斯ストーヴでもあると助かるが、さもなくて、大分しばらく待たされてから、やっと大きな火鉢の真中に小さな火種を入れて持参されたのでは、火のおこるまでに骨の髄まで凍ってしまいそうな気がする。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の『古言清濁考』はその後の学界に大分反対が出ているのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの龍麿の研究を見ますと、その中には今申した事に対する例外と認められるものが大分出ているのでありまして「何々とあるは正しからず」という風に、右のようなきまりに合わない例があげてあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは通行本と言われているもので、江戸時代の学者は大抵そればかり見ておったのでありますが、それは相当誤字のある本で、近来ずっと古い『万葉集』の写本が大分出て来ましたが、それと比べて見ると処々字が違っている所があります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に平安朝ばかりでなく奈良朝の末の方になると大分混乱が見えて来ているのでありまして、殊に或る仮名になると奈良朝の中頃から終頃になると全く区別がなくなったのではないかと思われるものもあるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「日記」を「にき」と書いてあるのも、これはすこぶる疑問でありまして、文字通り「ニキ」であったか「ニッキ」であったか、「ニッキ」というような促音は、これを書きあらわす方法がなかったものでありますから「にき」と書いていたのか、これは大分疑問だと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから前に申しました通り、平安朝に入るとこういう特別の仮名の遣い分けは乱れて来たのでありますが、平安朝の初の暫くの間はまだ多少混乱してはおりますが形の上においては大分保たれている。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば近頃世上で大分もてはやされる色々の社会的の問題に関する弁論や主張や宣伝中の一、二パーセント、あるいは二、三十パーセント、事によるともっと意外に大きいパーセントがやはり一種のシッタシズムの産物ではあるまいかという疑いが起った。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年文展が帝展に変った時には大分色々の批評があった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、批評というものの意味はもう昔とは大分違ったものになってしまう。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手の方はすらすらと無事に出来たが、計算尺を持った左の手がどうしても思うようにならなくて、これに大分時間をかけたようであった。",
              "citation": {
                "source": "中村彝氏の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対する向い側の壁に大分猛烈な絵が並んでいるので、コントラストの作用で一層この人の絵が静かに上品に見える。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他にも大分同類がある。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "博覧会の工事も大分進行しているようである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁を燃やした屑にはまだ大分に炭素が残って黒い色をしているが火鉢に入れておくとこの灰はだんだんに燃えて灰ばかり残る。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真の無線電送　近頃写真電送という事が大分評判になったが、従来の法はみな電線によって電流を伝えるのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この酒癖の惡さには、大分友人たちも參つたらしいが、彼をさうした孤獨の境遇においたことに、周圍の責任がないでもない。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
