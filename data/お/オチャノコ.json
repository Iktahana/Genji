          ],
          "literary": [
            {
              "text": "闊歩横行、登攀、跋渉、そんな事はお茶の子で。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……我人ともに年中｜螻では不可ません、一攫千金、お茶の子の朝飯前という……次は、」　と細字に認めた行燈をくるりと廻す。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金目の懸った宝なんざ、人が大切がって惜しむもので、歩るくにも坐るにも腰巾着につけていようが、鎖を下ろしておこうが、土の中へ埋めてあろうが、私等が手にゃあお茶の子さ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火遁だって、土遁どろどろどろ、すいとんだって、焼鳥だってお茶の子だわ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな品は盗っても、売るのに六ヶしいから見逃がして置くものの、盗ろうと思やお茶の子でさあ。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……手前、幼少の頃など、学校を怠けて、船で淡島へ渡って、鳥居前、あの頂辺で弁当を食べるなぞはお茶の子だったものですが、さて、この三津、重寺、口野一帯と来ますと、行軍の扮装でもむずかしい冒険だとしたものでしてな。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父に電話をかけて来るお客の声を、モシモシのモの字一字で聞き分けたり、受話機の外し工合で男か女かを察したり、両方から一時に混線して来た用向きを別々に聞き分けて飲み込んだりする位の事はお茶の子サイサイであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もなかなかの悪戯もので、逗子の三太郎……その目白鳥――がお茶の子だから雀の口真似をした所為でもあるまいが、日向の縁に出して人のいない時は、籠のまわりが雀どもの足跡だらけ。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処を沖へ出て一つ暴風雨と来るか、がちゃめちゃの真暗やみで、浪だか滝だか分らねえ、真水と塩水をちゃんぽんにがぶりと遣っちゃ、あみの塩からをぺろぺろとお茶の子で、鼻唄を唄うんだい、誰が沖へ出てベソなんか。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金や女の幽霊なら、お茶の子サイサイ狃れ切っとるが、今度の奴は特別｜誂えの日本の水雷艇みたような奴じゃ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも微塵も鼻の表現をたじろがせずに常に先方に遺憾なき感動を与えるのをお茶の子仕事と心得ているのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ドウダイ……事実とピッタリ一致するじゃないか」「相変らず素早いんだね君は……」「これ位はお茶の子さ。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　坐睡をしていたのか、寝惚面で承るとむっくと立ち、おっと合点お茶の子で飛出した。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃腸なぞはそりゃに、お茶の子じゃぞ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本伝寺の大屋根へ足場なしに上るんやもの、こなな低い屋根やこしはお茶の子や。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "千人、二千人おりましょうとも、この可賀が引きうけましたからには、お茶の子さいさいでござりやす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻雀の聴牌を当てるぐらいの事はお茶の子サイサイで、職業紹介欄の三行広告のインチキを閑暇に明かして探り出す。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや叔母の意見に負く位の事は朝飯前の仕事、お茶の子さいさいとも思わない。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "時速四十｜哩などは、お茶の子サイサイであった。",
              "citation": {
                "source": "西湖の屍人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな故障なんか直すことは彼には、お茶の子さいさいである。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こんなものはお茶の子です。",
              "citation": {
                "source": "動く海底",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども上村少佐にだつてそんなことはお茶の子さい／＼だつた。",
              "citation": {
                "source": "風変りな決闘",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の身体なんかお茶の子サイサイである。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠江灘オタケは口に二十七貫の土俵をくわえたそうだが、花嵐オソメにとってはそれぐらいお茶の子サイサイであったろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この精神病院なぞと申しまして、鉄の格子に、扉に錠など物々しくやっておりますが、私共の方では、お茶の子なんでございます。",
              "citation": {
                "source": "日月様",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、天性敏活で、チョコ／＼と非常線をくぐるぐらいお茶の子サイサイの運動神経をもつ小林秀雄が大ヤジウマなのにフシギはないが、幼稚園なみのキャッチボールも満足にできそうにない福田恆存が大ヤジウマだとは意外千万であった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボク達はガイヤアル君という足手まといがあったので、とうとう目的を遂げずに降りて来たけど本気で登ろうと思ったらだね、モン・ブランだろうがモン・ルウジュだろうが、お茶の子サイサイなのよ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それに靴下だっても、お茶の子さいさい手にはいるぜ」と、セルゲイが相槌をうつ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、いざとなつたらその名のごとく海人のたつきにも堪へようし、杣人の暮らしなんぞはお茶の子に相違あるまい。",
              "citation": {
                "source": "春泥",
                "author": "『白鳳』第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッ、お茶の子さいさい」　例によって安請合い、おおいに丹波の前にいい顔をしておいて、それからずっとこのトンガリ長屋を夜となく昼となく、見張りはじめたというわけ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
