        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と、また私たちは、高原の、一路坦々たる、大虎杖の林の中に在る私たちを見出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鹿児島産の大虎だよ。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし例の大虎列剌が流行した時には、江戸児もこれには辟易したと見えて、小春とも梅川とも名付親になる者がなかったらしい。",
              "citation": {
                "source": "二階から",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず本を開かぬ時にも替天行道の旗や景陽岡の大虎や菜園子張青の梁に吊った人間の腿を想像した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "――或精神的風景画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず本を開かぬ時にも替天行道の旗や景陽岡の大虎や菜園子張青の梁に吊つた人間の腿を想像した。",
              "citation": {
                "source": "大導寺信輔の半生",
                "author": "―或精神的風景画―",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に対手は年経し大虎、其方は犬の事なれば、縦令ひ怎麼なる力ありとも、尋常に噬み合ふては、彼に勝んこといと難し。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "名に負ふ金眸は年経し大虎、われ怎麼に猟に長けたりとも、互角の勝負なりがたければ、虫を殺して無法なる、他が挙動を見過せしが。",
              "citation": {
                "source": "こがね丸",
                "author": "巌谷小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "永代橋の「都川」で例会があった時、倉田白羊が酔っぱらって大虎になり、橋の鉄骨の一番高いところへ攀じ登ったが川風で酔いが醒めて、さてこんどは降りられない。",
              "citation": {
                "source": "ヒウザン会とパンの会",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記者連がゴロゴロ酔いただれているところへ、檀君は食堂車でのみつづけて大虎となって現れ、一団に合流していずれへか車で去ったという。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃はメッタに大虎にもならないが、昔はよくやった。",
              "citation": {
                "source": "九段",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "姥百合、大虎杖、水芭蕉、夜衾草、矢車草等の巨大なるものが見られたのも、このあたりからであったが、最早原始の面影を失ってしまった。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸に生えている大虎杖の若芽が噛み切られている跡を注意して見ると、初めは切り口が褐色に変っていたのが、上るに従って次第に新しいものとなり、雪渓の間近では生々しい液が未だ乾かないでいた。",
              "citation": {
                "source": "北岳と朝日岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は荷造りの座員をねぎらうため、酒を買わせて楽屋で酒宴をひらき、明るいうちに大虎になって、みんなと寝こんでしまった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "草間を押し分けて河原に下ると、大虎杖の叢が一斉に闊い葉を拡げて、強烈な日光を浴びながら懶そうに首垂れている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大虎杖の叢は北アルプス北部の渓間に特有の景象で、南アルプスの渓を埋むる深い森林とは、また異った快感を私達に与えるものである。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金作が大虎杖を切って釣竿を作ると、源次郎が蚯蚓を掘って餌にする。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この下りは相当に急な黒土道で、木の根が蟠っている、私達は五時十分に下り始め、六時二十分に濁沢に下り着いて、大虎杖の中を流に沿いて下り、濁ノ小屋の前に出た。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抜足で縁を通りながら叢を通り抜け、大虎杖を薙ぎ倒して、横に長く河岸に蟠っている大磐石の背に躍り上った。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸の大虎杖の林の中では珍らしく鶯が囀っていた。",
              "citation": {
                "source": "黒部川を遡る",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田の大虎事件では、泰軒は説諭放免となり、その後数年にして大岡さまは、八代吉宗公に見いだされて、この生き馬の眼をぬく大江戸の奉行、南北にわかれて、二人ございますけれど、まあ現代で申せば警視総監と裁判所長をいっしょにしたような重職におつきになったのです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪い殺されるどころか、大虎になって、大変な話を手真似でやり出す始末なんだ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚り乍ら磯の安松、三尺高い木の上から小唄の良い喉を海の向うの房州の阿魔つ子に聽かせてやり度えくらゐのものだ」　まさに大虎です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐ三河町へ行くと、仲吉の父親の市五郎は、早くも伜が縛られたと聞いて、冷酒をあふつて、大虎になつて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "酒屋火事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝鮮大虎」「大入り大入り」「大人一｜文小児半文」と書いた札を背にしてしきりに客を呼んでいる男が一方にいる。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝鮮大虎」「大入々々」「大人一文小児半文」と書いた札を背にして切りに客を呼んでゐる男が一方にゐる。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ三河町へ行くと、仲吉の父親の市五郎は、早くも倅が縛られたと聞いて、冷酒をあおって、大虎になっております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "酒屋火事",
                "note": "青空文庫"
              }
            },
            {
              "text": "――念のために後をつけて歩くと、お由良は一軒々々男を訪ねて、キビキビと片付けて歩いた上、先々で一杯づつ引つかけて、水道橋へ來た時は女のくせに大虎だ」「――」「こんな女と無理に一緒になることを考へると、治三郎は心の底から怖くなつた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "――念のために後をつけて歩くと、お由良は一軒一軒男を訪ねて、キビキビと片付けて歩いた上、先々で一杯ずつ引っかけて、水道橋へ来た時は女のくせに大虎だ」「…………」「こんな女と無理に一緒になることを考えると、治三郎は心の底から怖くなった。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら磯の安松だ、三尺高い木の上から小唄の良い喉を海の向うの房州の阿魔っ子に聴かせ度やりてえくらいのものだ」　まさに大虎です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "二分後、わめき暴れる大虎はコートを大きくはだけ、路上に手荒くつまみ出された。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
