[
  {
    "uuid": "334337a1-022d-5284-ae90-f128481651de",
    "entry": "大切り",
    "reading": {
      "primary": "おおぎり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "largely cut (e.g. of cabbage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "前の十場面は脚本で読ませておいて大切り一場面だけ見せてもいいかもしれない、とも考えられるが、それでは登場人物が劇中人物に成り切るだけの時間が足りないであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切りにナポレオンがその将士を招集して勲章を授ける式場の光景はさすがにレビューの名に恥じない美しいものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おさいが何もありませんが……』『澤庵をどつさり、大切りにして入れておいて呉れ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "或る日の晝餐",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父さんの墓参をかねて、九十九里へいってみようと思って……」「ああそうかい、なるほどそういえばだれかからそんな噂を聞いたっけ」　手拭を頭に巻きつけ筒袖姿の、顔はしわだらけに手もやせ細ってる姉は、無い力を出して、ざくりざくり桑を大切りに切ってる。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お退屈でござりましょうが、ハネるまでこの楽屋ででも御待ち下さりませ」　その大切りのひと幕が終ったのは、街にチラリ、ホラリと夏の灯の涼しい夕まぐれでした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに沢庵が大切りにして附けてある。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉はあまり大切りにて、拙者のごとき歯の弱いものには閉口であった。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十三日は、やがて『週報』で御覧になりましょうが、日本の国民が初めて経験するような生活の大切りかえの方針が公表され、昭和文化史の上に一つの記念すべき日となりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太夫は綾瀬、播磨、岡、相生、柳適、祖太夫、花太夫、人形は吉田国五郎に二代目伊三郎の合併一座でまず総動員、狂言は「忠臣蔵」「吃又」「日向島」その他で大切りが「羽根のかむろ」。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切りの国五郎の「羽根のかむろ」は、左が重三郎で小さい人形を巧みに使い、羽根をつく間の所作など細かく行き届いて活けるが如く、こればかりは文楽でも見られぬと大評判、そのくせ大入りとも行かず確か二回限りで中止、人形は東京の水に合わぬと決った。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは牡丹の花の開く工合、本所七不思議の化物、大切りには「鏡山」のお初岩藤、「累」の土橋の殺しなど怪談めいた狂言で、セリフや鳴物入りの大車輪、いわばトーキーの魁け。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大切りには宙乗り所作事、奴凧や雷公が呼び物、もちろん本衣裳で振りも確か、奴凧の狂いなどはらはらさせた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか例の際物好きの五代目菊五郎、さっそく十一月の千歳座で大切りの浄瑠璃に仕込み、みずからチャリネ、一本足、象使い、虎使いの四役に扮して珍妙な所作事、いかに名人でもいささか恐れをなしたが、この時の名題がいっそう珍妙、曰く、「鳴響茶利音曲馬」。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
