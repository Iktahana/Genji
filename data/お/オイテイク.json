    "definitions": [
      {
        "index": 1,
        "gloss": "to leave behind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "目を細くしてよく見きわめをつけてから一筆ごとに新しく絵の具を交ぜては置いて行くのだそうである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里と云う子の恋人の許へ置いて行くよりほかはあるまいものを。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこの五十銭を置いて行く。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人放り出して置いた處で、留守に山から猿が來て、沸湯の行水を使はせる憂慮は決してないのに、誰かついて居らねばと云ふ情から、家中野良へ出る處を、嫁を一人あとへ殘して、越中の藥賣が袋に入れて置いて行く、藥ながら、其の優しい手から飮ませるやうに計らつたのである。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うちへも集めに来なさるわ」　おかしいことに、半年に一度か二度珈琲を飲んで行くが、そのたび必ずこんな純喫茶だのに置かなくても良いチップを置いて行くのだと、お内儀はゆっくり笑った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪野は今一年有余の体刑を被ても、襤褸を出さないだけの綿密な仕組の下に、生涯裕福に暮らせるだけの用意をしたのであり、体刑は覚悟の前であったはずだが、金を隠匿しない反証にもと、退かして芸者屋を出させ、抱えも二人までおいてやった女を、たとい二年たらずの刑期の間でも、置いて行くのは心残りであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の男は、自分に漫画をかかせては、わずかなお金をもったい振って置いて行く三十歳前後の無学な小男の商人なのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、おれの身代りにも、むす子を置いて行く」　だが、こう筋立った逸作の言葉の内容も、実は、かの女やむす子と同じく巴里に憑かれた者の心情を含んでいた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というよりも、夜にでもなったらモンパルナスのキャフェへでも出掛けて行き分相応愉快に過しなさいという気持で、一人置いて行く子のアパートを、モンパルナスからあまり遠くない地点に選んでやったくらいだ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の味はモンパルナスのキャフェにあるとさえ云われて居るところをむす子から封じて、巴里へ置いて行く意義はない。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子は稍々内足で学生靴を逞しくペーヴメントに擦り叩きながら、とっとと足ののろい母親を置いて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、親一人子一人の淋しい母親を置いて行くのだからお風呂の日だけは実家へ戻して母親と会はせて呉れろといふ条件も直ぐ近所のお邸なので聞きとゞけられたのさ。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "睦子を置いて行く気か？",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "と徳利と味噌漉を置いて行くは、此家の内儀にいいつけられたるなるべし。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "香典千円ここへ置いて行くぜ。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "置いて行く祝儀もすくなく、一代は相手にしなかったが、十日目の夜だしぬけに結婚してくれと言う。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "欲しければ置いて行くぞ。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は彼女に頼みもしなければ口にもしないのだが妻は時々自身の為に買つたのであらう本を私の机辺に置いて行く。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうですなあ」巡査は首を傾けていつて更に帶劍の鞘を膝へとつて「どうだ勘次、以來愼めるか、此の次にこんなことが有つたら枯枝一つでも赦さないからな、今日はまあ此れで歸れ、其の櫟の根は此處へ置いて行くんだぞ」勘次は草刈籠を卸さうとした。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつたやうな気もするが――」「君に置いて行くよ。",
              "citation": {
                "source": "ブロンズまで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞かれないで帰るのではあまりつまらないから」　と強いて望まれて、この貴公子を取り散らした自身の部屋へ置いて行くことを済まなく思いながら、命婦が寝殿へ行ってみると、まだ格子をおろさないで梅の花のにおう庭を女王はながめていた。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな可憐な人を置いて行くことは、どんなに恋しい人の所があってもできないことであると源氏は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "私領の荘園、牧場、そのほか所有権のあるものの証券も皆夫人の手もとへ置いて行くのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗に逢ったら僕の名を言いたまえ、毎度逢って善い顧客だから麁略にすまい、貴下のような文なしには、少々置いて行くかも知れぬと教えくれたが、まだ一度も逢わぬから、折角の妙案も実試せぬ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに八橋の起請を置いて行くがいい」　ここで持っていないと言うのは余り卑怯だと思って、栄之丞は掛守から女の起請を取り出した。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの奥さん子供はないし、美しいし、置いて行くわけにも行かないでせうからな」　Ｂは黙つて聞いてゐたが、しかもさうした会話の中に若い美しい細君を発見せずにはゐられなかつた。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『をかしいですね、風呂に持つて行くのが危險なら、人のゐない家に置いて行くのはなほ危險ぢやありませんか、殊にちやぶだいの上なぞに……』『それが、忘れてまゐりましたんで……』『ですが危險を感じて忘れるとは受け取れませんね。",
              "citation": {
                "source": "女",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの知らんうちに、おいていくんだ」　ごんは、ふたりのあとをつけていきました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子は、「そんなら私たち三人や、小さな赤ちやんをみんなおいていくの？",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃいじゃいあたりゃいいんだ、早くしなよ」「いやですよ」「じゃ、おいていくぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
