        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「father」である。",
              "source": "幻辞"
            },
            {
              "text": "「father」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "father」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「father」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「father」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "father」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「father」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "father」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「father」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "father」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「father」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "father」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「father」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "father」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「father」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "father」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「father」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "father」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「father」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "father」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――さて、春松は、「おやっさん、本当でっか」　といって、まさかとは思いながら、ひょっと権右衛門が破目を外して芸者遊びをするところを見たらどんなに痛快だろうと期待した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は他吉の異様な気配をあやしんで、「おやっさん、どないしてん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ほな、おやっさんがそない行けというねやったら、マニラへ行くわ」　おとなしく、言うことをきいた新太郎の言葉が、にわかに耳の奥できこえた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユニコーン　プラムケーキを持ってきてくんな、おやっさん。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
