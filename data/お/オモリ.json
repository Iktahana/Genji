[
  {
    "uuid": "20cc81ae-b098-5ed2-a274-28bf5cd1c342",
    "entry": "重り",
    "reading": {
      "primary": "おもり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
