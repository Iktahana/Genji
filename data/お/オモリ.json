    },
    "definitions": [
      {
        "index": 1,
        "gloss": "weight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "先刻の誤解が度重り、Ｂがなんとか伸理解明せんものとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはひょっとしたらいくつかの山の麓が重り合っているのではないかと翁は疑った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてみると、昨日あの大きな石を用もないのに動かそうとしたのもその浮標の重りに使う心組からだったのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来て見れば、ただの世界で、物が重りを持っていたり、日がさせば影を落したり致しますのでございますからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹と幹、枝と枝との重りの間から、青い牧草の原と山の方へ登る道が見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔小きメリヤス塩の魚〕小きメリヤス塩の魚、　　藻草花菓子烏賊の脳、雲の縮れの重りきて、　　風すさまじく歳暮るゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」博士たすけよ、と呼ばむとする時、何と、……頸寄り、頬重り、脚抱くと視るや、尾を閃めかして接吻をした。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして見ると、昨日あの大きな石を用もないのに動かさうとしたのもその浮標の重りに使ふ心組からだったのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松の皮でもこう重り重りして堆いのを見るとね、あんまり難有いもんじゃあない、景色の可い樹立でも、あんまり茂ると物凄いさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は一統、女中たち男衆まで、挙って式台に立ったのが、左右に分れて、妙に隅を取って、吹溜りのように重り合う。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この通り、山ばかり、重り累る、あの、巓を思うにつけて、……夕焼雲が、めらめらと巌に焼込むようにも見える。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃い靄が、重り重り、汽車と諸ともに駈りながら、その百鬼夜行の、ふわふわと明けゆく空に、消際らしい顔で、硝子窓を覗いて、「もう！",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、軒に乾した煙草の葉と、蕃椒の間に、山駕籠の煤けたのが一挺｜掛った藁家を見て、朽縁へ道を向うへ切って、樗の花が咲重りつつ、屋根ぐるみ引傾いた、日陰の小屋へ潜るように入った、が、今度は経肩衣を引脱いで、小脇に絞って取って返した。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂山の波が重り重って、余りに二人のほかに人がない。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の情の火が重り、白き炎の花となって、襖障子も燃えましょう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "憐れむべし過度の馳※に疲れ果てたる馬は、力なげに俛れたる首を聯べて、策てども走れども、足は重りて地を離れかねたりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼なんぞは馬鹿だけれども剛直な奴で、重りがあった。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼の重りの象徴にする積りと見える。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暗い淋しい中に、私のそれと明らかに意識する事を怖れる、數限りない小さい失望と怒りが、重り合つて騷いでゐた。",
              "citation": {
                "source": "不穩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "田の奥は山が又迫つて、二三十の屋根が重り合つて見えた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もっとも持重りがしたり、邪魔になるようなら、ちょっと、ここいらの薄の穂へ引掛けて置いても差支えはないんだがね。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はね、いつごろからという確なことは知らないけれど、いろんな事が重り重りしてね、旦那が、旦那が、どうにかして。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢や銃弾も中らばこそ、轟然一射、銃声の、雲を破りて響くと同時に、尉官は苦と叫ぶと見えし、お通が髷を両手に掴みて、両々動かざるもの十分時、ひとしく地上に重り伏せしが、一束の黒髪はそのまま遂に起たざりし、尉官が両の手に残りて、ひょろひょろと立上れる、お通の口は喰破れる良人の咽喉の血に染めり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打棄らしつたえ、持重りが為たゞかね。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫像一個抱いて歩行くに持重りがして成るものか！",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目はしょぼしょぼして眉が薄い、腰が曲って大儀そうに、船頭が持つ櫂のような握太な、短い杖をな、唇へあてて手をその上へ重ねて、あれじゃあ持重りがするだろう、鼻を乗せて、気だるそうな、退屈らしい、呼吸づかいも切なそうで、病後り見たような、およそ何だ、身体中の精分が不残集って熟したような鼻ッつきだ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをするにはまた、あまりに心臓は重り、首筋の骨は硬ばってしまっているのだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、其の好意に感謝しながら、手に持ちおもりのした慾を恥ぢて、やせた杖をついて、うつむいて歩行き出した。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔦　まあ、お位牌はちゃんと飾って、貴方のおふた親に、お気に入らないかも知れないけれど、私ゃ、私ばかりは嫁の気で、届かぬながら、朝晩おもりをしていますわ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで葛飾の留守の間は自然小野が美代子のおもりをつとめなければならなかった。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
