          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "年の頃だってそうでございます、まあ、この兵助と、おっつかっつでございますね、かなり甲羅は経ていますよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども法科とおっつかっつに行くというのはもう紛れもない事実であった。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "留守中の来客というのは、年配もほぼ道庵先生とおっつかっつであって、道庵より少し背は低いが、よく肥って、人品も悪くない一人の老紳士でありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈だけはほぼ当主とおっつかっつだったが、やっと長｜洋袴になったばかりの子供。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "君達とおっつかっつだ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
