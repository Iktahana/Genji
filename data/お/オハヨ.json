        "examples": {
          "standard": [
            {
              "text": "朝、私が湯殿へ行く途中、逢う女中がすべて、「先生、おはようございます。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "朝、私が湯殿へ行く途中、逢う女中がすべて、「先生、おはようございます。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は私を見るよりいと懷かし氣に倚子から立つて『おはよう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしの大好きなヤギさん、おはよう！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、アシがおじぎをして、「おやすみ」とか、「おはよう」と言っていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはよう、おはよう。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そこにいる人々に、あいそよくあいさつしてから、ヨハンネスに手をさし出して、「おはようございます」と、言いました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、その人に好意を感じていたのだから、早速にっこり笑って、「おはようございます。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ新調したばかりのぼうしのひさしを光らせながら、「おはよう」と、元気よく近づいてきた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが「おはよう」というとお秀も「ぼんやりのお喋かい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おはよう、ラーナ。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはようございます。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはようございます、大佐。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだおはようの挨拶はもらえないのかな。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなのもの、おはよう。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面所のかわりには、小川が水晶のようなきれいな水をながしてくれましたし、そこにはあしがこっくり、おじぎしながら、おやすみ、おはようをいってくれました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ヨハンネスには、わざわざ手をさしのべて、「あら、おはようございます。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かわいい、めやぎさん、おはようございます。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはようございます」とかすかに言って、両親のことばをまつ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはようこれへお出会いめされいッ」　声にあわただしく姿を見せたのは、番頭次席あたりとおぼしき関所役人です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはようございます」「ウッフフ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門のだんなさまのお屋敷と知って、お力借りに駆けつけました者でござりますゆえ、おはようお取り次ぎくださりませ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへへ……へへへ」　不審に思って、のっそりと手を伸ばしながら障子をあけてひょいと見ると、「へえ、おはよう！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は何事もなかった前のように、にこやかに「おはよう」を仰有った。",
              "citation": {
                "source": "先生の顔",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてうれしさに忙しくて、悪い気ではなく光子に「おはよう」を言うのを忘れていた。",
              "citation": {
                "source": "先生の顔",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「葉子さんおはよう！",
              "citation": {
                "source": "先生の顔",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おはよう、おはよう」という人間に似て人間でない声が、隣の方から庭ごしに聞こえてきた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理人の人が「おはよう！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
