        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "Ｓ＝茶店内部　夜更けて――　表戸を開けて七五郎のお袋のお勘婆さんが顔を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚も表戸がドンドン叩かれる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋　三次はお絹の家の表戸に凭れて呆然として居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してお末の非常な誇りとして、表戸が青いペンキで塗り代へられ、球ボヤに鶴床と赤く書いた軒ランプが看板の前に吊された。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は早起きして表戸の野に新聞紙を拾いに出ると、東にあった二個の太陽を見出した。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表戸によりかかって春の日を浴びながら彼女はぼんやり畑の方を見込んで立っていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお夜食を食べ終る頃、火の番が廻って来て、拍子木が表の薄｜硝子の障子に響けば看板、時間まえでも表戸を卸すことになっている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って待っといでなさい」　と言って老人を送り出してから表戸を卸す。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜番の拍子木が過ぎ、店の者は表戸を卸して湯に出かけた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂田はなにかほっとして、いつものように身をかがめてゆで玉子屋の表戸に手をかけた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の途中でマスクを外して、一息つき、そして名曲堂の前まで来ると、表戸が閉つてゐて「時局に鑑み廃業仕候」と貼紙がある。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "河靄が立ち籠めてきた河岸通りの店々が、早く表戸を降している通りへ私は出た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その取着らしいのの表戸を、きしきし、その若い人がやるけれど、開きますまい、あきません。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "謎をこころの住家となし、この住家に於て太古の湖の静けさにも通ずるほどの憩いを希うわたくしに取って、感覚的にも外界への交通を遮断することは表戸を卸すと共に四方の窓の戸をも閉めるほどの細心緻密な心使いです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日に二三度も号外がけたたましい鈴の音を表戸にうち当てて配達された。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど表戸を閉めている中に一軒だけ、遣手婆が軒先で居眠りしている家を見つけ、あがった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆んど表戸を閉めている中に一軒だけ、遣手婆が軒先で居眠りしている家を見つけ、登席った。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時前、表戸の鍵が音を立てた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜十一時ごろ、ボーレンの表戸をあけた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムさんは之を聞いて「それはあぶない所から這入つて来ましたね、一寸表戸をトントン叩いて下されば直ぐ開けるのでしたのに」と云ひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこの激しい暴風雨の中に、トムさんの家にはこの一、二年この方、猫の子一匹訪ねてきたことがないのに、トントンと表戸を叩くものがあるではありませんか、トムさんは大変不思議に思ひまして、兎に角表戸をそつと開きますとドッと吹き入る雨風と一緒に一人の若い女が室の中に転りこみました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムさんはあまりの物凄さに、炉の焚火によつて、小さくふるへて居りました、するとこの激しい暴風雨の中にトントンと表戸を叩くものがありました、トムさんは不審に思ひながら、そつと戸を開きますと、雨風といつしよに一人の若い女が室の中に転げこみました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけに表戸の前で、「あの若僧すっかり震え上って了いおった。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まがりかどまで来て、ヒョイと銀座のおもてどおりのほうを見ると、ずっと向こうのかどに、へんてこなものが、うごめいているではありませんか。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
