        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "覚えてろ」Ｓ＝亀崎の宿の旅籠「大野屋」（夜）　土間が居酒屋になって居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　グッと詰って眼を白黒さす五郎蔵、怒って、Ｔ「ドドどうするか　覚えてろ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴は真っ青な顔をして、「覚えてろよ」とでも言うみたいに目をぎらつかせて、向こうへ行ってしまった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちどんなお礼をするか覚えてろ！",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此奴、乗打ちをしたナ、覚えてろ！",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "べらぼうめ、どうするか覚えてろ」　さっと駆けだした伝六を露払いに、あとからゆうぜんとして訪れたところはその一真寺です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするか覚えてろッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、どうするか覚えてろッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く握りなよ」「ちくしょうめ、どうするか覚えてろッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするか覚えてろッ」「いえ、もし、ちょっとちょっと、血相変えてどこへいらっしゃるんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "当節は江戸で、女の色忍びがはやるっていうからね、べらぼうめ、べっぴんのくせに、ふざけたまねしやがって、どうするか覚えてろ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに、どうするか覚えてろ」　捜しているうちに、はしなくも見つけ出したのは、そこの縁起だなの上になにごとか秘密を包みながら、子細ありげに置かれてあった変なものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「色よい返事」が来なかったら、「覚えてろ！",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起でもない、おかげで俺はすっかり負けてしまった、覚えてろ！",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "オノレ祈り殺してやるから覚えてろ」　ドアをぶッたり蹴ったりして帰った。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物の中へ猫イラズを仕込んでやるから覚えてろ！",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よし、覚えてろ」に至つては、明らかに、復讐の宣言である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生、おたあは字を書くふりをして、こんな坊主頭を書きました」「いけません……それから周造さん、お前さんも、人のいいつけ口をするものじゃありませんよ」「先生、おたあがおいらを睨みました、帰りに覚えてろといって、拳固をこしらえて見せました」「静かになさい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪次郎　　（低い声で）覚えてろ！",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「よおし覚えてろ！",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「覚えてろ、この女め！",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓鬼時分からの恩をも忘れちまいやがって、俺の頭を打ち割るなんて……覚えてろ！",
              "citation": {
                "source": "眼",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "（セレブリャコーフに）畜生、覚えてろよ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「覚えてろ」と、兄貴はいう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその翌晩もまたその翌晩も、十二時といえば「覚えてろ」の声を合図に姿を現し、ついには娘や女中の目にも止まるようになったので、十日あまりで匆々越してしまった。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜ちゃんも覚えてろ！",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎、飛んでもねえ、呑んでかかったのがこっちの落度だ……覚えてろ、よくも俺を斬りやがったな」　細引をもう一捲き、金蔵の首に捲いた時は、乳のあたりをまた深く一つ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも私はその人達に、『覚えてろよ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うぬ、覚えてろ」　土匪は、逃げはじめた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚原あ――大人はみんなお内儀さんがあってな、そんでお前大人は、な、お内儀さんばっか可愛がってんだぞお……」　塚原は自分の瞼をぐいと操りあげ「野郎――」と罵りかえした、「八幡さまに手前のことを呪ってやるから、おぼえてろお…………」　順序も連絡もなくその子供らの考はぷくぷくと浮びあがった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
