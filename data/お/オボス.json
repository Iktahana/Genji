    "definitions": [
      {
        "index": 1,
        "gloss": "to think",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "断行するにも沈思するにも精いっぱいできる。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰々しく馬車を走らして往来を妨げんは、老人の娑婆塞と後指指されんも憂たてし、髪切払いて仏に仕うる身の徒歩歩こそ相応けれ、つまりは腕車も不用なれど、家名に対してそうもならねば、止むことを得ず三吉の健脚を労するだに心苦しく思すとなむ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書　（沈思す、間）美しく、気高い、そして計り知られぬ威のある、姫君。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の比倫なき（仏の児）は山窟に入りて禅思す。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向に心得ねば、笑つて翁に言ひけるやう、御先祖其角の住家より狭しと思すにやと。",
              "citation": {
                "source": "秋窓雑記",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱烈の舌一世を罵り、勇猛の気英雄を呑み、豪快天地を嘲るが如き挙動を為しながら、別に一片の真率無慾なるところ、専念｜回向するところ、瞑目静思する処ろ、殆数個の人あるが如き観あるもの、何ぞや。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家　（あるいは頷き、また打傾き、やや沈思す）奥さん、更めて、お縫さん。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の思いだけで妄思すれば、或いは流れて異端を求めるようになってしまう。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖教を受けず、大道に由らず、自分の思いを師として苦思するのは、例えば太陽が空に在るのに、その明光温熱の益を受けないで、窓を閉じて独り座し、灯りを点して作業するようなものである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また書抜きを開いてじっと見詰める）死出三｜途の道なりとも、御身とならば厭わばこそ……（また絶望したるごとく、書抜きを投げ捨てて頭を抱えて沈思する。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "コリャ寧そ叔母の意見に……」　が猛然として省思すれば、叔母の意見に就こうとすれば厭でも昇に親まなければならぬ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語材料｜尽く分明に解し得ながら一句の意味に解する能はざる所あらば自ら熟思すべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁子は白い肩掛に身を包んで何事かを沈思するように唯｜俯向いたままで乗って行った。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根はふっと沈思する。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "年中有意義無意義に繁忙で、本を読む時間も沈思する時間も持たない日常のひとたちは、全くたまの休みには家へかえって本でも読むのが最上のことである。",
              "citation": {
                "source": "「健やかさ」とは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう深思する心は岸本を導いた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは、苦痛と期待との間で揺れる心で沈思するのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的悲劇の発生も、その血腥い過程とよりよき芽を育てようとする結果とを通して、一つの重大な、沈思すべき「現象」に対する平静と公正とを以て向われとうございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自の心が、真剣に鞭撻し沈思すべき一生の問題でございます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから早速今昔を見ると、本朝の部｜巻六、従鎮西上人依観音助遁賊難持命語の中に、「転て思すらむ。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、著述書の如きも、近来、世に大部の著書少なくして、ただその種類を増し、したがって発兌すれば、したがって近浅の書多しとは、人のあまねく知るところなるが、その原因とて他にあらず、学者にして幽窓に沈思するのいとまを得ざるがためなり。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　合点をして、「今度で小一万はたしかに儲けちょる」　おさやは、上被の合わせ目に片手をさし入れてちょっと沈思する顔つきであった。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是等を観察し、彼を沈思す。",
              "citation": {
                "source": "大久保湖州",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "李林甫の半夜高堂に黙思するや、明日必殺ありしと云ふが如き、豈此間の消息を洩すものにあらずや。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山前首相が、帝銀事件の犯人について、未曾有の兇悪犯であり、すべてに代えて逮捕せよ、などと警官を激励するのはオコの沙汰と申すべきで、これが警視総監の言ならば当然であるが、首相たるもの、その政策のいたらざるをまずもって三思すべきではないか。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生らは誠に親類少なく、千々岩はその少なき親類の一｜人なれば、母上も自然頼みに思す事に候。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さな句碑の前に、無限の感慨をこめて黙思する人は、果していくたりゐるだらう。",
              "citation": {
                "source": "九月朔日",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、次郎は沈思するように答えて、ややしばらく物も言わずに、私のそばを離れずにいた。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "御道理でござりまする、まことに斉名以言の君の御文章の宜しからぬということは無いことと存じまする、ただし公任卿はゆゆしく心高き御方におわす、御先祖よりの貴かりし由を述べ立て、少しく沈滞の意をあらわして記したまわむには、恐らくは意にかないて善しとせられなむ、如何におぼす、と助言した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "上庄の江崎氏を訪ふに酒屋には酒屋よけむと嫁に来しお加代姉さもただの古嬬空飛ぶを弟があやつる翼かと早やおぼすらし声おろおろに御許には童女童数群れて亦若かりしけぶりだになし童女柳河午後、いよいよ郷里に入る。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
