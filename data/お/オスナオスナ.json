[
  {
    "uuid": "e3dba217-2afd-5ad6-85ab-31e183b18812",
    "entry": "押すな押すな",
    "reading": {
      "primary": "おすなおすな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
