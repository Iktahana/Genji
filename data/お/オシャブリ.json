    "definitions": [
      {
        "index": 1,
        "gloss": "teething ring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おしゃぶりという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はおしゃぶりの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではおしゃぶりという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、おしゃぶりは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、おしゃぶりの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、おしゃぶりは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、おしゃぶりはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、おしゃぶりの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、おしゃぶりが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、おしゃぶりのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、おしゃぶりに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、おしゃぶりの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "おしゃぶりは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、おしゃぶりの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "庄内の小芥子人形は遠い土地だけに余り世間に知られていないようですが、木製の至極粗末な人形で、赤ん坊のおしゃぶりのようなものですが、その裳の方を持って肩をたたくと、その人形の首が丁度いい工合に肩の骨にコツコツとあたります。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏が来ると、柿の枝などの年々なつかしい蔭を作る廂のなかで、織機に上って、物静かにかちかち梭を運んでいる陰気らしい母親の傍に、揺籃に入れられた小さい弟がおしゃぶりを舐って、姉の自分に揺られていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、おしゃぶりなさい。",
              "citation": {
                "source": "七階の住人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこれはゴムのおしゃぶりが出て来る前には、どこにでも見られた品である。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手にはなにかの骨でできたおしゃぶりを、片手にはブリキ製のがらがら箱を持っている。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおそのほかに、籠の左右にこぼれたものを見ると、でんでん太鼓だの、風車だの、ピーピーだの、おしゃぶりだの、そりいうものが積まれているのみか、徳利の頭へ管をつけて、その管の一端が、子供の口許にまで導かれて結えられている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃぶりも、ピーピーも、風車も、でんでん太鼓もケシ飛んで、ミルクであり、摺粉であるべき徳利はくわえ出されて、その余瀝が餓えたる犬の貪り吸うところとなりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃぶりをしゃぶって宮参りの犬張子、お祝物の鯛車で育て上ったわんぱくどもが、おいみんな遊ぼうよ、とひっくり返すおもちゃ箱の中は、芳藤のおもちゃ絵そのまま。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
