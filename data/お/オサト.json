[
  {
    "uuid": "d4710743-afd8-5a47-8e92-4a4787c4e246",
    "entry": "お里",
    "reading": {
      "primary": "おさと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's parents' home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お里という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお里の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お里を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお里という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お里の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お里は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お里の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お里と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お里は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お里はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お里の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お里の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お里が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お里を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お里のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お里に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お里の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お里の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お里は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お里の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お里の知れた少しの涙でしめされるな。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度嫁に来られるお嫁さんのお里もわたくしは知っています。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は、家計をやりくりして行くのに一層苦しみだした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はすぐ賛成した。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から海岸まで出すのは、お里が軽子で背負った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は常からよく働く女だった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お里の方では、そんなことで良人が心を使って病気が長びくと困ると思っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里が別に苦しそうにこぼしもせず、石が凸凹している嶮しい山路を上り下りしているのを見ると、清吉はたまらなかった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の常着も一枚、お里は、ひそかにそう思っていたが、残り少ない金を見てがっかりした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　正月二日の初売出しに、お里は、十円握って、村の呉服屋へ反物を買いに行った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時過ぎにお里が帰って来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は、よく物を見てから借りて来たのであろう反物を、再び彼の枕頭に拡げて縞柄を見たり、示指と拇指で布地をたしかめたりした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ二反借って来たんは、丸文字屋にも知らんのじゃけど……」　もう行ったことに思っていたお里が、また枕頭へやって来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は何か他のことを二言三言云った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は、善良な単純な女だった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　お里が家から出て行ったあとで、清吉は、眼をつむって妻の心持を想像してみた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には、お里が子供のように思われた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこに、お里もしょんぼり立っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はいつのまにかお里の心持になっていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はそういう場合を想像してびく／＼している。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は待っても待っても機会が来ない。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里がびく／＼しながら、番頭の方へ近づくと、「あ、そうですか。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は金を出す。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は嵩ばった風呂敷包みを気にしながら、立っている。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はぐら／＼地が動きだしたような気がする。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも……」　お里が俯向いて、困惑しながらこう云っている……　　　　　　五　清吉は胸がドキリとした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、お里が喉頭に溜った痰を切るために「ウン」と云って、それから、小便をしているのが聞えて来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は小便をすますと、また納屋へ行って、こそ／＼していた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみにゃこれ……」　お里は風呂敷包みの一方だけ開けて、品ときみに反物を見せた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お里はビクッとして「忘れてしもうとった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
