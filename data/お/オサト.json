    "definitions": [
      {
        "index": 1,
        "gloss": "one's parents' home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お里の知れた少しの涙でしめされるな。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度嫁に来られるお嫁さんのお里もわたくしは知っています。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は、家計をやりくりして行くのに一層苦しみだした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はすぐ賛成した。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から海岸まで出すのは、お里が軽子で背負った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は常からよく働く女だった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お里の方では、そんなことで良人が心を使って病気が長びくと困ると思っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里が別に苦しそうにこぼしもせず、石が凸凹している嶮しい山路を上り下りしているのを見ると、清吉はたまらなかった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の常着も一枚、お里は、ひそかにそう思っていたが、残り少ない金を見てがっかりした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　正月二日の初売出しに、お里は、十円握って、村の呉服屋へ反物を買いに行った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時過ぎにお里が帰って来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は、よく物を見てから借りて来たのであろう反物を、再び彼の枕頭に拡げて縞柄を見たり、示指と拇指で布地をたしかめたりした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ二反借って来たんは、丸文字屋にも知らんのじゃけど……」　もう行ったことに思っていたお里が、また枕頭へやって来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は何か他のことを二言三言云った。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は、善良な単純な女だった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　お里が家から出て行ったあとで、清吉は、眼をつむって妻の心持を想像してみた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には、お里が子供のように思われた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこに、お里もしょんぼり立っていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はいつのまにかお里の心持になっていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はそういう場合を想像してびく／＼している。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は待っても待っても機会が来ない。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里がびく／＼しながら、番頭の方へ近づくと、「あ、そうですか。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お里は金を出す。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は嵩ばった風呂敷包みを気にしながら、立っている。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里はぐら／＼地が動きだしたような気がする。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも……」　お里が俯向いて、困惑しながらこう云っている……　　　　　　五　清吉は胸がドキリとした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく、お里が喉頭に溜った痰を切るために「ウン」と云って、それから、小便をしているのが聞えて来た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お里は小便をすますと、また納屋へ行って、こそ／＼していた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみにゃこれ……」　お里は風呂敷包みの一方だけ開けて、品ときみに反物を見せた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お里はビクッとして「忘れてしもうとった。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
