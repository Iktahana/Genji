    "definitions": [
      {
        "index": 1,
        "gloss": "older sister",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どてらのように身体に添っていない着物から「お姉さん」のような首が生えていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこわして上げるから、お姉さんやお兄さんと一緒におやつに食べておしまいなさい」　と言って金槌を持って来て、パラパラと打ちこわしておしまいになりました。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお父さんとお姉さんの眼鏡も探し出して一所に懐に入れて、どこかへ遊びに行きました。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんが買いものから帰って来られますと、これも眼鏡がありません。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに御飯の火を焚き付ける段になると、お姉さんはマッチの箱の蓋がすこし開いているのを気が付かずにマッチを摺ったために、マッチ箱の中のマッチに火がついて一時に燃えて、姉さんは手にやけどをしてしまいました。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんは泣いています。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとノリ子さんの代りに、ノリ子さんのお姉さんが、「はーい」と返事なさいました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、と思つてゐるとお姉さんが玄關から出ていらして、「ノリちやんはお熱があるので學校へいけませんのよ。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭にはピジヤマを着たノリ子さんがお姉さんに手をひかれて、そろりそろり歩いてゐました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんや、別れた人や、長いあいだ逢わずにいる人たちが懐かしい。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おととしの夏休みに、北海道のお姉さんの家へ遊びに行ったときのことを思い出す。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫小牧のお姉さんの家は、海岸に近いゆえか、始終お魚の臭いがしていた。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんが、あのお家のがらんと広いお台所で、夕方ひとり、白い女らしい手で、上手にお魚をお料理していた様子も、はっきり浮かぶ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、いいお家には、お父さんもいらしったし、お姉さんもいた。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が学校から帰って来ると、お母さんと、お姉さんと、何か面白そうに台所か、茶の間で話をしている。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやつを貰って、ひとしきり二人に甘えたり、お姉さんに喧嘩ふっかけたり、それからきまって叱られて、外へ飛び出して遠くへ遠くへ自転車乗り。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんは、優しく、私は、いつもお姉さんにぶらさがってばかりいた。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんは、お嫁にいってしまったし、お父さんは、もういない。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、お姉さんから、もらったんだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "へんな事を言わないで、お姉さんに叱られますと言ったほうが、早わかりだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "信行君のお姉さんは歌った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんなんか、芝居なんかを熱心に研究したって、どうにもなるもんですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんには、またお姉さんとしての考え方があるのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私、話がきまってから、お姉さんに報告するわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんはお姉さん、私は私だわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、お姉さんの番人じゃないことよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、お姉さん、わたしとてもいい人に逢っちゃったのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくおおねえさんのとこへ行くんだよう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は表通りへ出て、二階を仰ぎ、奥さん、おねえさん、奥さん、おねえさん、と小声で呼んでみましたが、もう眠ってしまったのかどうだか、二階はまっくらで、そうして何の反応もございません。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りのからだに秋風がしみて、ひどくいまいましい気持になり、私はゴミ箱を足がかりにして屋根へ上り、二階の雨戸を軽くたたいて、奥さん、おねえさん、とまた低く呼びましたら、だしぬけに内から女房が、どろぼう！",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
