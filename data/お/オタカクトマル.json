          ],
          "literary": [
            {
              "text": "私はいったい画伯とか先生とかのくっ付いた画かきが大きらいなんだけれども、……いやよ、ほんとうにあいつらは……なんていうと、お高くとまる癖にひとの体にさわってみたがったりして……けれどもお金にはなるわね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし君子さん女給になったからって、何もそうお高くとまるには及ばないでしょう。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、今度はエリザベスが、お高くとまる番になった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
