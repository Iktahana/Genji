          "literary": [
            {
              "text": "「水はおとろしいもんぢや。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民組合やこし何がおとろしいもんかい。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――○――　○参って来ますわいの（女が行く）　○参りんなさらんけ（誘う女）　○おとろしい＝恐しい　○おおけに＝大きに　○やあ、困ったもんが出ちもうたやらと思うてようく見ると、……じゃったんだそうだ。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
