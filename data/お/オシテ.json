    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forcibly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "看護婦が手押車に手術器械薬品をのせたのを押して行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私はここにくどいくらゐに念を押して置きたいのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何世紀も前の過去から刻みつけられた印象は、都会という大なる集団の上にも、不可拭の焼印を押していなければならないはずだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の人が、杖に「大願成就」という焼印を押してくれた上に、小御岳の朱印を押した紙に、水引を添えてくれた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ザネリがね、舟の上から烏うりのあかりを水の流れる方へ押してやらうとしたんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてザネリを舟の方へ押してよこした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして口紅は唇の重要性に印を押している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ泊れるかい」　母は猶念を押して「おまえが泊ると極ればお母さんは出かける、えいだっペねい」と云った。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の我がままも、彼の一國も、彼の自己を押して行くエゴイズムも、彼は皆自分でよく知りながら、そのくせまた一方では知らないのである。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一人の女が小さな手押車を押してゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何代か前からきっと立派な血が流れて来ていて、それが子孫に現われて来るんですね」「これは家内とも相談ですが」と貝原は再び儀式的の掛け合いのように念を押して、「小初先生。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、蜂の子供には御馳走なんだよ」　穴の二三｜寸手前に降りた蜂は、やがて頭と前脚で蜘蛛の死骸を穴の深みへ押して行つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同じように、にこ／＼しながら看護長は扉を押して次の病室へ出て行った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃をとると、彼は扉を押して、戸外へ躍りでた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、六日経つと、おれが様子を訊きに来るから」　半七は念を押して帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、まことに勝手がましゅうございますが、あしたにもちょいとお出でを願いとうございます」　お亀はしきりに念を押して頼んで帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所働きはお由とお庄というんですが、これは飯炊きや水汲みに追い使われているだけで、奥の方のことは何も知らないようです」「ゆうべも云ったことだが、祈祷をたのむ者のほかに誰も出這入りするらしい様子はねえのか」と、半七は念を押して訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "塵埃の色をした苦力が一台に一人ずつそれを押していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山がむきになると、幹太郎は、ワザと、于の尻を押してみたい気持を感じるのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」市三が、さきに押して来てあった鉱車を指さして、役員の阿見が、まつ毛の濃い奥目で、そこら中を睨めまわしていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　監督は念を押して、繰かえした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ザネリがね、舟の上から烏うりのあかりを水の流れる方へ押してやろうとしたんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの処へただちょっとお前の前肢の爪印を、一つ押しておいて貰いたい。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃の死亡承諾書ね、あいつへ今日はどうしても、爪判を押して貰いたい。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じ論法で押して行くと結局アインシュタイン自身もまだ徹底的には相対性原理を理解し得ないのかもしれないという事になる。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の距離の感ぜられるのは、像が飛んで来る時に前面の空気を押して目におしつけるためである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の飽くことなき欲望がこの可能性の外被を外へ外へと押して行くと、この外被は飴のようにどこまでもどこまでも延長して行くのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫のオルガン六つですか」と何遍も駄目をおしている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日と十六日とは、食事の外用事もないままに、書室へ籠りとおしていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人がよみつる歌の事などさま／″＼胸に迫りて、ほと／＼涙もこぼれつべく、ゆかしさのいと堪へがたければ、閨の戸おして大空を打見あぐるに、月には横雲少しかゝりて、見わたす岡の若葉のかげ暗う、過ぎゆきけんかげも見えぬなん、いと口惜しうもゆかしうも唯身にしみて打ながめられき。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
