        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "うんすら妬いてこすに、一押し手を貸すもんだよ」「口はばったい事べ言うと鰊様が群来てはくんねえぞ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……誰かいっそ強い押し手で、押し立ててくれたら飛び込んで行くよ」「え？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんのことでげす、押し手とは？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山道軍の一行が活気に満ちていたことは、あの重い大砲を車に載せ、兵士の乗った馬に前を引かせ、二人ずつの押し手にそのあとを押させ、美濃と信濃の国境にあたる十曲峠の険しい坂道を引き上げて来たのでもわかる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その兵馬の押し手を受け受け、紋也はしだいに下がって行く。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹林派の押し手弓、キリキリキリと引き絞り、満を持して放たない。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫のオルガン六つですか」と何遍も駄目をおしている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日と十六日とは、食事の外用事もないままに、書室へ籠りとおしていた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "故人がよみつる歌の事などさま／″＼胸に迫りて、ほと／＼涙もこぼれつべく、ゆかしさのいと堪へがたければ、閨の戸おして大空を打見あぐるに、月には横雲少しかゝりて、見わたす岡の若葉のかげ暗う、過ぎゆきけんかげも見えぬなん、いと口惜しうもゆかしうも唯身にしみて打ながめられき。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "平常から自分はその男に悪感をもよおしていた。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "」啜泣くのをやめると、栗鼠の毛皮の外套をつけた女は、コンパクトで化粧をなおしてから、「――あたし神戸だわ、でも明夜の十時五十五分の列車で妾帰ります。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんべん読みなおしてもあきることがない。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一廻り壁が継ぎ足されたと思うと、蜂はさらにしっかりとからだの構えをなおして、そろそろと自分の頭を今造った穴の中へ挿し入れて行った。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしがはたらきながら、また重いものをはこびながら、手で水をすくうことも考えることのできないときは、そこから白びかりが氷のようにわたくしの咽喉に寄せてきて、こくっとわたくしの咽喉を鳴らし、すっかりなおしてしまうのです。",
              "citation": {
                "source": "イーハトーボ農学校の春",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒天みたいなすきとおしてそらも見えるようなものがたくさん落ちているからそれをひろってはいけないよ。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　校長はぎくっとしたが気をとりなおしてこう云った。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の火は衰えはじめて、硝子窓を潤おしていた湯気はだんだん上から消えて来る。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は長谷川君とは対面するような何等の機会をも有さなかったので、親しく語を交えた事はありませんが、同君の製作をとおして同君を知った事は決して昨今ではありません。",
              "citation": {
                "source": "言語体の文章と浮雲",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴たおして、それから澄んだ三白眼をくり抜く。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと息を呑んだ女の、そのかすかな気配が、闇をとおして隣室の私の呼吸にぴたりと合った感じがした。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、おりるんですよ」青年は男の子の手をひき姉は互いにえりや肩をなおしてやってだんだん向こうの出口の方へ歩き出しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、この児があんばいがわるくて死にそうでございますが先生お慈悲になおしてやってくださいまし。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、それはうそでございます、先生は毎日あんなに上手にみんなの病気をなおしておいでになるではありませんか。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって先生先生のおかげで、兎さんのおばあさんもなおりましたし狸さんのお父さんもなおりましたしあんな意地悪のみみずくまでなおしていただいたのにこの子ばかりお助けをいただけないとはあんまり情ないことでございます。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはみみずくの病気なんどなおしてやったことはないからな。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その絶頂に立っておりました棒切れと、その尖端に結びつけてあるヤシの枯れ葉を、一思いに引きたおして、眼の下はるかの淵に投げ込んでしまいました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今きれいにしてきずをなおしてやるからな」　おとうさんが人間に物をいうようにやさしい声でこういったりした。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度分解した項式が結合をしなおして、だんだん単純化されていくところからみると、ついには単一の結論的項式に落ちつきそうにみえた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の間の情愛は肉をとおして後に開かれるのだと、今までの経験からも決めている渡瀬には、これほど嵩じてきた恐ろしい衝動を堰きとめる力はもうなくなりかけていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼界がだんだん狭まって、火鉢にかざされた、長い指の先がぶるぶる震えどおしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
