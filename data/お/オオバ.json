        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "顧れば峡間から東方の霞沢岳連峰の木山には、どす玄い雨雲が、甘藍の大葉を巻いたように冠ぶさって、その尖端が常念一帯の脈まで、包んで来ている、雪の峡流は碧い石や黄な石をひたして、水嵩も多くなって、樺青く雪白い間を走って行くのが、遙かに瞰下されて、先は森林の底に没している。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根は根よりも葉が出来て、これでは大根という代りに大葉とよびたいほどです。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側には山毛欅、いたやかえで、斎※樹、おおなら、大葉柏などの落葉喬木類が密生していた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩と茅と野茨ばかりの枯れ叢の中に、寿命を尽くして枯れ朽ちた大木を混ぜて、発育のいい大葉柏が斑らに散在していた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大葉黄すみれ人待つ宵を、日のかたみ、大葉黄菫花さきぬ、愛での盛りに言ひ知らず、物さびしさの身にぞ沁む。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大葉黄すみれ人待つ宵を、日のかたみ、大葉黄菫花さきぬ、愛での盛りに、言ひ知らず、物さびしさの身にぞ泌む。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の大根は葉ばかり出来て根が出来ない、大根でなく大葉だ、それでも今朝おろしにして食べたらうまかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏軒先生は講書の日を定めてゐても、病家の歴訪すべきものが多かつたので、日歿後に至つて帰り、講説は縦ひ強て諸生の求に応じても、大抵粗枝大葉に過ぎなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもわずかに粗枝大葉の論を終えたるにとどまり、説のいまだ尽くさざるものなお多けれども、駄目を推さばひっきょう限りなからん。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "地境には、隣家で植ゑた改良の大葉が牛蒡の葉ほどもある大きな葉を茂らせてゐる。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴンと立った大葉子の穂が草鞋に蹴られて小さな実を散らした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手のひらを力士の如くひろげたるシヤボテンの樹に積るしら雪　唯だ大きいだけでなく、厚味も豊かな相撲力士の拡げた指のやうな大葉のシヤボテンの樹に雪が白く積つて居る。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはこの大葉のシヤボテンは嫌ひなものの一つであるが、この歌を見ると、雪の白く積つた何処かの朝の庭でもう一度この木を見直して見ようかと云ふ気がする。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば、有名な調伊企儺の妻、大葉子が詠んだ歌、韓国の城の上に立ちて、大葉子は領巾振らすも。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "にも拘らず、後の人が大葉子を詠んだ歌だと説明するが、此だけの説明では安んぜられない。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此歌を大葉子につける理由がもつとなければならない。",
              "citation": {
                "source": "「八島」語りの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "調伊企儺の妻｜大葉子も神憑りする女として、部将として従軍して、俘になったものと考えられる。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "調伊企儺の妻｜大葉子も神憑りする女として、部将として従軍して、俘になつたものと考へられる。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず秋田ブキの話はこれ位にしておくが、兎に角数尺の広さある大葉面を展開し、数尺の高さ数寸の径ある長葉柄を挺立さすとは、他に比類のない壮観で、その偉容は優に他の百草を睥睨するに足り一面また我が日本植物の誇りでもある。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも展開した広やかな谷、それから無色に近い水の色、深淵に泳ぐ岩魚の姿、みずみずしい大葉柳や楢、椈の森林、片桐松川の鬼面に脅かされた目には、飯田松川の流れは高雅にすぎたのかもしれないのだ。",
              "citation": {
                "source": "二つの松川",
                "author": "細井吉造",
                "note": "青空文庫"
              }
            },
            {
              "text": "温室内にあるタイヨウベゴニア（大葉ベゴニア）は、大なる深緑色葉面に白斑があって、名高い粧飾用の一種である。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその攘夷なるものは、無謀の攘夷に非ず、いわゆる敵愾的精神を発揮して、遠馭長駕を事とし、溢れて疎枝大葉の侵略論となるも、決して自屈籠城の鎖国的｜臼※に陥らざりしなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "千八百米附近から伊吹麝香草、深山茴香、大葉黄菫、高根薔薇、姫石楠、四葉塩竈、高根撫子、深山沙参、白根人参、真柏などがつぎつぎと目に入る、立派なお花畑である。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近には大桜草、白山小桜、深山毛莨、大葉の黄菫などが、空疎ではあるが思ったより水気のある地膚の所どころを美しく飾っている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し出過ぎたかも知れぬが、或る日老師に、「野田と云う人は、所謂る昔風の豪傑で、※枝大葉、今日の政治家に適して居るか、どうです」と云った。",
              "citation": {
                "source": "釈宗演師を語る",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あいつの仕事は、いつもおおばちだから、浸点で屑が出来るこた知っとるだろうね？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは大場宇兵衛殿の葬式でござる」「なに、おおばうへえ」「そうでござる」　行列は通りすぎた。",
              "citation": {
                "source": "葬式の行列",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおばこ来たかやと……　たんぼのはんずれまで、出てみたば……」　清江の歌が聞えて来た。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "地しばりやおおばこなど、葉末に露をたたえた雑草をはだし足袋に蹴立てて歩いて行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
