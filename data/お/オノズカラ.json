        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ドイツの学者のアルバイテンという言葉の意味がここに一年半通って同学者のやり方を見聞している間に自ずから会得出来たような気がした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし個人的には、たとえそれは自覚されないにしても、何かしら自ずから一定の標準をもっていて、それに当嵌めて口調の善し悪しを区別している事だけは否定し難い事実である。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都野さんの歌の音調にはやはり自ずからな特徴がある。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば凶作問題なども自ずから解決の途につくはずであろう。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃｜和蘭グロニンゲンのカプタイン博士等は、従来多年の観測の結果を綜合して精細な研究を遂げた末に、天体に散布せる諸恒星は自ずから二派の流れに分れている事を発見した、すなわち天体各部の星の運動が目指す方向を反対に延長して見るとほぼ定まった二つの星座に集注する。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の胸中も自ずから平らかなるを得たようである。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にユダヤ人の後裔にとっての一つの神なるエホバは自ずから姿を変えて、やがてドルになりマルクになった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ことによるとこの姓名札の汚し方の同じ型に属する人には自ずから共通な素質があるかもしれない。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、何かしら一つ仕事をすれば学位が必ずとれるとなれば志望者も自ずから増すであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この前提が実用上無謀ならざる事は数回同じ実験を繰返す時は自ずから明らかなるべきも、とにかくここに予言者と被予言者との期待に一種の齟齬あるを認め得べし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱力学にエントロピーの観念の導入され、またエントロピーと公算との結合を見るに至りし消息もまたここに至って自ずから首肯さるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう疑問が自ずから起らぬを得ないのである。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに生徒の方でも実験というものの性質がだんだん分って来ようし、教員の真価も自ずから明らかになろうと思う。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点において人間以外のものを取扱う場合とは自ずから異なる取扱い方の区別が生じる。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "優れた観察力をもった漫画家が街路や電車の中で十人十色の世相を見る時には、複雑な箇体が分析されて、その中のある型の普遍的要素が自ずから見出される。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体学級の出来栄えには自ずから一定の平均値があってその上下に若干の出入りがある。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　キュリー夫人などが居るではないかという抗議に対しては、「そういう立派な除外例はまだ外にもあろうが、それかといって性的に自ずから定まっている標準は動かされない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震の科学的研究に従事する学者でも前述のような自己本位の概念をもっていることは勿論であるが、専門の科学上の立場から見た地震の概念は自ずからこれと異なったものでなければならない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "想うに、少なくもある地質学的時代においては、起り得べき地震の強さには自ずからな最大限が存在するだろう。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーが深くヤングに私淑していたであろうということは、二人の仕事の一体のやり口を比較すれば自ずから首肯されるであろう。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "型式的概念的に堕した歌人の和歌などとは自ずからちがった自由な自然観が流露している。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかくも芸術家のうちで自然そのものを直接に見て何物かを見出そうという人があれば、その根本の態度や採るべき方法には自ずから科学者と共通点を見出す事が出来てもよい訳である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの試験の結果から考えると心臓の鼓動するのは塩のごとき化学的の刺戟物が心臓の神経に作用するためで、この種の刺戟がなければ自ずから鼓動する事は出来ぬだろうという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んで立っていた若い会社員風の二人連れが話しているのを、聞くともなく聞いていると、毎朝同じ時刻に乗る人がみんなそれぞれ乗り込む車の位置に自ずからきまりがあると見えて、同じ顔が同じところにいつでも寄り合うようだと云っていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはあまり頭も苦しめなくて、ただ器械的に仕事を進めて行くうちに自ずから興味の泌み出して来るようなことが適当である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "差別にも平等にも、自ずからそれ相当の価値と限度があって、病に対する対症療法のようなものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七三課　仏陀　宇宙には自ずから真理が備わっております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を覚ったのかと言うと、先程述べましたように、「宇宙には自ずからなる真理が存在していて、それはとてもよいものだ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信」の中身――そこに自ずから開かれる智慧の光を湛えつつ――は人に伝えるべく、あまりに微妙｜幽邃を極めております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから自ずから彼は表具もやれば刀を採って、木彫｜篆刻の業もした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
