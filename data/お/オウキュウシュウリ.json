          ],
          "literary": [
            {
              "text": "ラヂウスも応急修理で何とか燃え出したので明日は登高とする。",
              "citation": {
                "source": "槍ガ岳",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "総員で応急修理中ですが、当分第三舵はききませんよ」「ああ、わかった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶、その後の報告によると、応急修理に高い所へ登った一技手は、奇怪な配線のあるのを発見した。",
              "citation": {
                "source": "白蛇の死",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか、空気服をつけている者は、破損の箇所を応急修理するために活動ができる。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壊された線路や車輛に応急修理を施しただけで使っていると云うことだから、設備の整った内地の鉄道より、戦場のそれの方がずっと厄介にちがいない。",
              "citation": {
                "source": "指導物語",
                "author": "或る国鉄機関士の述懐",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
