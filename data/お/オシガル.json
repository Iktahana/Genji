[
  {
    "uuid": "81cbce0a-8afe-5c94-ace8-3f936f7eb384",
    "entry": "惜しがる",
    "reading": {
      "primary": "おしがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行"
      ],
