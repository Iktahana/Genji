        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お日様について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お日様がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お日様というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお日様の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお日様が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お日様を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お日様の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お日様はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお日様があります。",
              "source": "幻辞"
            },
            {
              "text": "お日様は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お日様について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお日様の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お日様の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお日様が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お日様についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお日様は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお日様について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お日様という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお日様の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お日様を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お日様はもえる宝石のように東の空にかかり、あらんかぎりのかがやきを悲しむ母親の木と旅にでた子どもらとに投げておやりなさいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お日様がまっ白に燃えて百合の匂を撒きちらし又雪をぎらぎら照らしました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、お日様がカツカツカツと厳かにお身体をゆすぶって、東から昇っておいでになった時、チュンセ童子は銀笛を下に置いてポウセ童子に申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様もお昇りになったし、雲もまっ白に光っています。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様が丁度空のまん中においでになった頃蠍はかすかに目を開きました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうお日様が西の山にお入りになる所です。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様がもうサッサッサッと三遍｜厳かにゆらいで西の山にお沈みになりました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様は燃える宝石のやうに東の空にかかり、あらんかぎりのかゞやきを悲しむ母親の木と旅に出た子供らとに投げておやりなさいました。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　丁度その時、霧が晴れて、お日様の光がきん色に射し、青ぞらがいっぱいにあらはれましたので、稜のある石どもは、みんな雨のお酒のことや、雪の団子のことを考へはじめました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　丁度その時、霧が晴れて、お日様の光がきん色に射し、青ぞらがいっぱいにあらわれましたので、稜のある石どもは、みんな雨のお酒のことや、雪の団子のことを考えはじめました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみれや、たんぽぽが咲き乱れて、お日様の光がのどかに照りわたった西田甫の畔道に、子ひばりを抱いた婆やのあとから、睦しく声をそろえて唱歌をうたいながら行く一郎さんとたえ子さんの姿が見えました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原を行ったり来たりひとりごとを言ったり、笑ったりさまざまの楽しいことを考えているうちに、もうお日様が砕けた鏡のように樺の木の向こうに落ちましたので、ホモイも急いでおうちに帰りました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は長くお日様を見ますと死んでしまいますので」としきりにおわびをします。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木の下で、一人の子供の影が、霧の向こうのお日様をじっとながめて立っていました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様は霧がかかると、銀の鏡のようだね」「はい、また、大きな蛋白石の盤のようでございます」「うん。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様があまり遠くなりました。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気を出して、物干場へあがってお日様を険しく見つめ、思わず、深い溜息をいたしました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お日様がもうお隠れやるかいな。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か、いろんな恐しいものが寄って集って苛みますような塩梅、爺にさえ縋って頼めば、またお日様が拝まれようと、自分の口からも気の確な時は申しながら、それは殺されても厭だといいまする。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝寝坊をしないで、早くから眼をさましておられると、朝の六時か七時｜頃、冬ならば、まだお日様が出ていない薄暗い時分から、「なっと、なっとう！",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日もいいお天気で、お日様が青い牛蒡の葉にきらきら射してきました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどお日様が今、きらきらする雲の間に隠れた後、水草の中から、それはそれはきれいな鳥のたくさんの群が飛び立って来ました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、お日様が温く照っているのを見たり、雲雀の歌を聞いたりして、もうあたりがすっかりきれいな春になっているのを知りました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "接骨木までが、その枝をこの新しい白鳥の方に垂らし、頭の上ではお日様が輝かしく照りわたっています。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "もぐらもちがお日様に眼を射られた時のやうに、あわてゝ下水溝の中へ悲鳴をあげて裸を隠すだらう。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひさまがその葉をすかして古めかしい金いろにしたのです。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さした　さしたおひさま　さしたゆきが　やんだらきら　きら　さした。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるあさ、そのにわとりが、おひさまの　でてくる　すがたを　みると、しらないうちに、くちがおほきくあいて、こんなこえが、のどのおくから　でてきました。",
              "citation": {
                "source": "にはとり　は　みんな　しあわせ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、もうすぐ、はるがやってくるというころに、おひさまのひかりで、みんなとけてしまいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひさまが顔を出すまえにめをさまして、水くみ、かまどのたきつけ、ごはんづくり、皿あらい。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
