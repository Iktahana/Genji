    "definitions": [
      {
        "index": 1,
        "gloss": "extreme foolishness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
