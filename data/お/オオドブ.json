        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "土用が明けてまだ間もない秋の朝日はきらきらと大溝の水に映って、大きい麦藁とんぼが半七の鼻さきを掠めて低い練塀のなかへ流れるようについと飛び込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側に軒の並んだ町ながら、この小北の向側だけ、一軒づもりポカリと抜けた、一町内の用心水の水溜で、石畳みは強勢でも、緑晶色の大溝になっている。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に大溝の幅広い溝板が渡っていて、粋でがっしりした檜の柾の格子戸の嵌った平家の入口と、それに並んでうすく照りのある土蔵とが並んでいた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どことも覚えない大溝が通っていて小橋がまばらに架り、火事の焼跡に休業の小さい劇場の建物が一つ黝み、河沿いの青白い道には燐光を放つ虫のようにひしゃげた小家が並んでいる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　電車を赤十字病院下で下りて、向うへ大溝について、岬なりに路を畝つて、あれから病院へ行くのに坂がある。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……川も此の邊は最う大溝で、泥が高く、水が細い。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町ばかり、麹町の電車通りの方へ寄つた立派な角邸を横町へ曲ると、其處の大溝では、くわツ、くわツ、ころ／＼ころ／＼と唄つて居る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅坂の方面から参謀本部の下に沿って流れ落ちる大溝は、裁判所の横手から長州原の外部に続いていて、昔は河獺が出るとかいわれたそうであるが、その古い溝の石垣のあいだから鰻が釣れるので、うなぎ屋の印半纏を着た男が小さい岡持をたずさえて穴釣りをしているのをしばしば見受けた。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞ましい水音を立てて、崖とは反対の道路の石垣の下を大溝が流れている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和七年の晩秋に京浜に大暴風雨があって、東京市内は坪当り三｜石一｜斗の雨量に、谷窪の大溝も溢れ出し、せっかく、仕立て上げた種金魚の片魚を流してしまった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝の水は増したが、溢れるほどでもなく、ふだんのせせらぎはなみなみと充ちた水勢に大まかな流れとなって、かえって間が抜けていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小径の途中の土の層から大溝の浸み水が洩れ出て、音もなく平に、プールの葭簾を撫で落し、金網を大口にぱくりと開けてしまっている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に大溝の幅広い溝板が渡つてゐて、粋でがつしりした檜の柾の格子戸の嵌つた平家の入口と、それに並んでうすく照りのある土蔵とが並んでゐた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どことも覚えない大溝が通つてゐて小橋がまばらに架り、火事の焼跡に休業の小さい劇場の建物が一つ黝み、河沿ひの青白い道には燐光を放つ虫のやうにひしやげた小家が並んでゐる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐内坂の崖下、大溝通りを折込んだ細路地の裏長屋、棟割で四軒だちの尖端で……崖うらの畝々坂が引窓から雪頽れ込みそうな掘立一室。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただいま御当家へまいる途中で、あの鬼婆横町を通りぬけると、丁度まんなか頃の大溝のふちに一人の婆が坐っているのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらの坂下は谷と呼ばれるほどの低地で、遠い昔には柳川という川が流れていたとか伝えられ、その川の名残りかとも思われる大溝が、狭く長い横町の北側を流れて、千鳥ヶ淵の方向へ注ぎ入ることになっている。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出先によんどころない用が出来て、時刻がすこし遅くなったので、急いで家を出て、鬼ばば横町にさしかかると、横町の中ほどの大溝のきわに、ひとりの真っ白な婆が坐っているのです。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか焦らされているようで、おれも癪に障ったから、穿いている足駄をぬいで叩きつけると、婆の姿は消えてしまって、足駄は大溝のなかへ飛び込んだ。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の小屋敷の板塀や生垣はすべて白いなかに沈んで、北側の大溝も流れをせかれたように白く埋められていた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神南も森積もおどろいて前後から支えようとすると、石川は身をひるがえして大溝へ飛び込んで、川獺のように素ばやく西のかたへ逃げ去った。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝のふちには白い物が坐っていた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度此時、丹羽長秀、高島郡大溝の城を出でて、小船で賤ヶ岳の戦況を見に来合せたが、賤ヶ岳の辺で矢叫び鉄砲の音が烈しいのを聞いて、さては敵兵｜早急に攻むると見えた、急き船を汀に付けよと命じた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は霽れた、人は湯さめがしたように暑を忘れた、敷居を越して溢れ込んだ前の大溝の雨溜で、しっくい叩の土間は一面に水を打ったよう。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に大溝があって、雪を被いで小家が並んで、そして三階｜造の大建物の裏と見えて、ぼんやり明のついてるのが見えてね、刎橋が幾つも幾つも、まるで卯の花｜縅の鎧の袖を、こう、」　借着の半纏の袂を引いて。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災に焼けはしなかった土地と思うが、往来もあわただしく、落着きのない店屋が並んで、湿地か、大溝を埋めたかと見え、ぼくぼくと板を踏んで渡る処が多い。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝の愛宕山の下〔桜川の大溝〕などでも、よくかわうそが出たということです。",
              "citation": {
                "source": "江戸の化物",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大溝渠を前にした一室を仕事場にして、其所で二年ぶりに手入れをした道具を備え、いよいよ本職の木彫りをもって世に立つことにしたのであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "象牙彫り全盛時代のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宅坂の方面から参謀本部の下に沿って流れ落ちる大溝は、裁判所の横手から長州ヶ原の外部に続いていて、むかしは河獺が出るとか云われたそうであるが、その古い溝の石垣のあいだから鰻が釣れるので、うなぎ屋の印半纏を着た男が小さい岡持をたずさえて穴釣りをしているのをしばしば見受けた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又そのなかを自動車、自転車、人力車、荷車が絶えず往来するのであるから、油断をすれば車輪に轢かれるか、路ばたの大溝へでも転げ落ちないとも限らない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
