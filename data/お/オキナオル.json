        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし時を逆行させる場合にはいろいろな向きに倒れた鉛筆がみんな垂直に起き直るから事がらは簡単になる。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "活惚、活惚……　三味線がハタと止む……　と、くるくると転がつてゐる俺自身が俺にももう恐ろしくて恐ろしくてたまらなくなつた、思はず投げつけられた盗賊猫のやうにぽんと起き直るとその儘パタパタと二階に駈け上つた。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは寝すごしたと慌てて起き直ると、いつも自分を起してくれるはずのお駒は正体もなく眠っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さまはお床の上に起き直るお元気もなくなったようで、いつもうつらうつらしていらして、もうおからだをすっかり附添いの看護婦さんにまかせて、そうして、お食事は、もうほとんど喉をとおらない様子であった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワノウィッチは、寝台の上に起き直ると、両手を思い切り広げて大きい伸びをしようとした。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで寝入ったように黙っていた父が、急にむっくりと床の中で起き直ると、蒲団の中から顔を出して、私の方をじっと見ました。",
              "citation": {
                "source": "勝負事",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足のまだ痛むのを堪えながら、留吉は寝床の上に起き直ると、枕もとの煙草盆には新らしい火が入れてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "起き直るのも大儀そうであった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあこれは……」　僕はガバと起き直るなり、頭を掻いた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし床の上に起き直ることさえ人手を借りなければならぬ彼には容易にその機会も得られなかった。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、見る通り、最早、己一人で、起き直る力も無うなった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの来たのを見て、起き直るが早いか、坊っちやん何時家を御持ちなさいますと聞いた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シヤツは馬鹿あ云つちやいけない、間違になると、船縁に身を倚たした奴を、少し起き直る。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの来たのを見て起き直るが早いか、坊っちゃんいつ家をお持ちなさいますと聞いた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツは馬鹿あ云っちゃいけない、間違いになると、船縁に身を倚たした奴を、少し起き直る。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は祖国の伝統からもまた自らの生活からもはぐれてしまつた孤独の思ひや敗北感と戦つて改めて起き直るためにあらゆる努力をしたやうです。",
              "citation": {
                "source": "女占師の前にて",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に投げ倒されたのがまた起き直る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、酔っぱらっている道庵は、ともかくも起き直る余裕があるのに、向うへ打倒れたさむらいは、起き上る気力がありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、米友は、半ば以上無意識の朦朧たる眼をもって、「やんなっちゃあな」と言いながら室内を見廻したけれど、うたた寝では毒だと気がついて、あわてて起き直るでもなし、辛うじて、自分の寝そべっているところと向う前の隅に、きちんと、寝床がのべられてあり、枕が据えられてあることを、まず見出したもののようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里の宿屋に朝目をさましショコラを啜ろうとて起き直る時窓外の裏町を角笛吹いて山羊の乳を売行く女の声。",
              "citation": {
                "source": "砂糖",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども床の上に起き直る気力すらないものが、どうして汽車に揺られて半日の遠きを行くに堪え得ようかと考えると、帰りたいと念ずる自分がかなり馬鹿気て見えた。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お若ハツと起き直る。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（春子がムックリと起き直る気配）春子　うん。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る蔭もなくやつれ果てて、明日も知れぬ命と見えた大病人が、半身を起き直るやうに枕の上に乘り出したのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る影もなくやつれ果てて、明日も知れぬ命と見えた大病人が、半身を起き直るように枕の上に乗り出したのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だい、ありゃ、えらく騒がしいじゃねえかな」　寝ていたおやじが起き直ると、がんりきは、さあらぬ面をして、「お爺さん、気をつけな、府中の宿は今、上を下への大騒ぎだぜ」「え、府中の宿が上を下への大騒ぎだってな？",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴倒されたお浜は、むっくりと起き直るや、前に用意して明けておいたと見える表の戸から外の闇へ転げ出してしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛に打たれて後ろへ飛び退いたムクは、起き直るや、驀然に七兵衛の跡を逐いかけます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "激しい喉の渇きで眼がさめたらしいが、起き直るとすぐに、岡野と口論をしたことが思いだされ、われ知らず苦悶の呻きをもらした。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、やっとのことでまともに起き直ると、じっと虎の方を見つめていたが、ああ、これはどうしたというのだ、熊はまるで気でも違ったように檻の隙間からそとへ逃げ出そうと、みじめにもがきはじめるのであった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
