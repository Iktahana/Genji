        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「どうもお待たせしました。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしました」　そう言いながら、椅子に腰を掛けると、宮子はいきなり両手を頭のうしろで組んで、両足をすっと伸ばした、二の腕が白い。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしました」　そして、鶴雄を促して、玄関へはいった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お待たせしました」　と云いながら真正面の座布団に坐り込んだが、火鉢の縁へ手を載せたトタンにヒイヤリとしたので、ちょっと驚いたらしく掌を見ると、白い柔らかい、平べったい、豆腐の破片みたようなものが手の平へ二三枚ヘバリ付いている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもお待たせしました。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしましたね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしました。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあお待たせしました、村口さんです。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしました」　定七は一方の手に神酒徳利と洗米の盆を乗っけた三宝を持ち、一方の手に土蔵の鍵を持っていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしましたこと。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分お待たせしましたわ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中島さん、随分お待たせしました。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｐのおじさん、どうもお待たせしました。",
              "citation": {
                "source": "現場の写真",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今晩は、どうもお待たせしました……さあ松本さん出かけましょう」　障子を開けて閾際に立ったまま私は張りつめた気持ちで玄をせき立てた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エー、お待たせしました。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、もしもし、お待たせしました。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お待たせしましたな、恐縮恐縮、が首尾は上々吉で」　坐るとべらべら喋舌り出した。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「お待たせしました。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで、この家自慢の薄茶でも服って、おくつろぎなさるがよい」　雪之丞がよいほどに、長崎屋と世間ばなしをつづけていると、その中に、廊下でしとやかな足音がして、「お連れさま、お見えなされました」　と、知らせる、女中のあとから、「やあ、おまたせしましたな。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇怪な眠り「や、おまたせしました……」　と、博士は部屋にはいると、まず平松看護婦が記しておいたカルテをとりあげました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
