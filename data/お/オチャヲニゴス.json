        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、これはおかしい程売れず、結果、学校、官庁、団体への大量寄贈でお茶を濁すなど、うわべは体裁よかったが、思えば、醜態だったね。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云ってお茶を濁す。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いづれ、ゆつくり考へて見申さむ』と、お茶を濁す。",
              "citation": {
                "source": "夜の高尾山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "何人にも程よくお茶を濁すものは、憎まれもせぬ代りにはびこりもせぬ。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして、人生、「苦しみ」の中にこそ「楽しさ」があるなどゝ好い加減な当て推量をしてお茶を濁すことはできない。",
              "citation": {
                "source": "「明るい文学」について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業化して多作を強いられると、勢い推理小説以外の怪奇小説とか、スリル小説、ユーモア探偵というようなもので、お茶を濁すということになる。",
              "citation": {
                "source": "探偵小説とは",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこが間違つているのか、どこが工合がわるいのか、なんとなく面白くないが、どこをどうしていゝかわからぬまゝに、まあまあ、こんなことだろうとお茶を濁すことになるのです。",
              "citation": {
                "source": "Ｓ夫人への手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家その筆漸く意の如くならずその作また世に迎へられざるを知るや転じて批評の筆を取り他人の作を是非してお茶を濁す。",
              "citation": {
                "source": "一夕",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "重点的もいいが、形だけととのえて、お茶を濁すのでは、意味が無い。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう委員会というものは、大抵の場合は、よろしくやって「不可抗力」ということにしてお茶を濁すのが礼儀なのである。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学と芸術、科学と宗教、云々と並べて見た処で、ありふれた連関づけをしてお茶を濁す他に知恵は出ないだろうと思う。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の知識でお茶を濁すのが楽でいいもんだから……すっかりそれが慣れっこになってしまった！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "本物にもならず、酒席の座興で、お茶を濁すのが関の山だった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
