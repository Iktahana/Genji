    "definitions": [
      {
        "index": 1,
        "gloss": "train of dress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お引きずりについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お引きずりがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお引きずりの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお引きずりが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お引きずりの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお引きずりがあります。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お引きずりについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお引きずりの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお引きずりが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお引きずりは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお引きずりについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお引きずりの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お引きずりを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おれのやうに上着から、シャツ、股引、褌まで新しい奴に着換へるなんててめい等は一生かかつてもできまい、今頃は、お前は相変らずオンボロ、オンボロ、長いボロ着のお引きずりワカメの行列だ、舗道に唾をベッとはいてぶつぶつ呟やいてゐるだらう。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝間着のお引きずりのまま、二人が腫れぼったい目にもう強過ぎる日光で、顔をしかめながらお湯を沸かしに台所へ出ると、中央の大テーブルの真中に妙なものが、のっかって居る。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええおめえ、とんだお引きずりだなあ、お裾の邊りが泥んこだあね！",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まったくあの二人みたいなお高くとまったお引きずりとは、比べものになりゃしませんよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌や俳句がちやんとした娘ならば、詩の多くは云つてみればおひきずりであつた。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ン坊の泣声や、おひきずりの靴の音や、昆布や烏賊や洟紙や首巻や、みんなみんな、街頭沿ひの電線の方へ荷馬車の音も耳に入らずに、舞ひり吁！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひきずりの着物をきて、坐ったまま、花活けを膝近く置いて、梅の花かなんか手にしている。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "母にたいしては「おひきずり」という言葉を以て、たえず身だしなみを、うるさく云った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなどを当時のことばで「おひきずり」と云ったのであろうと思う。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
