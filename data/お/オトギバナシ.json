        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私にはただなんとなくそれがおとぎ話にあるようなさびしい山中の妖精の舞踊を思い出させた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとぎ話や伝説口碑のようなものでも日本の自然とその対人交渉の特異性を暗示しないものはないようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年雑誌やおとぎ話の本などというもののまだ一つもなかった時代では、こんな粗末な刷り物でも子供には珍しかったのであろう。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる人間的なるものが、暑さのために蒸発してしまって、夢のようなおとぎ話の世界が残っているという気がするのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイのおとぎ話に牛乳の白色という観念を盲者に理解させようとしてむだ骨折りをする話がある。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の子供らがおとぎ話の中の化け物に対する感じはほとんどただ空想的な滑稽味あるいは怪奇味だけであって、われわれの子供時代に感じさせられたように頭の頂上から足の爪先まで突き抜けるような鋭い神秘の感じはなくなったらしく見える。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋のおとぎ話に「ゾッとする」とはどんな事か知りたいというばか者があってわざわざ化け物屋敷へ探険に出かける話があるが、あの話を聞いてあの豪傑をうらやましいと感ずべきか、あるいはかわいそうと感ずべきか、これも疑問である。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではゲーテの「ライネケ・フックス」や、それから、そのころようやく紹介されはじめたグリムやアンデルセンのおとぎ話や、「アラビアン・ナイト」や「ロビンソン・クルーソー」などの物語を、あるいは当時の少年雑誌「少国民」や「日本の少年」の翻訳で読み、あるいは英語の教科書中に採録された原文で読んだりした。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるおとぎ話がそうである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを、花やかに美しい、たとえばおとぎ話の王女のようなベコニアと並べて見た時には、ちょうど重々しく沈鬱なしかも若く美しい公子でも見るような気がした。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の夜の銀座はいつもの人間臭いほこりっぽい現実性を失って、なんとなくおとぎ話を思わせるような幻想的な雰囲気に包まれる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとぎ話というものは、だいたいにおいて人間世界の事実とその方則とを特殊な譬喩の形式によって表現したものである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとぎ話というものは、そういう人間世界の事実と方則を教える科学的な教科書である。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをいいかげんなほんの一面的なやぶにらみの注解をつけて片付けてしまうのではせっかくのおとぎ話も全く台無しになってしまう。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとぎ話はおとぎ話でよいのである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとぎ話は物理学の教科書と同じく石が上から下へ落ちるという事実を教える。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おとぎ話に下手な評注を加えるのはほとんどこれに類した滑稽に堕しうる可能性がある。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとぎ話も植物の標本もわれわれに教うるものは人間と自然との事実である。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの子供の時分にはおとぎ話はおとぎ話としてなんらの注釈なしに教わった。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこれらのおとぎ話を、尻の曲がったごうなの殻にでも詰め込んで丸のみにさせられていたのであったら、とうの昔に体外に排泄されてどこかよその畑の肥料にでもなっていたことであろうと思う。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）を連ねるだけであるからせっかくの現実映画の現実性がことごとく抜けてしまって、ただおとぎ話の夢の国の光景のようなものになってしまうだけである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「漢楚軍談」「三国志」「真田三代記」の愛読者であったところの明治二十年ごろの田舎の子供にこのライネケフックスのおとぎ話はけだし天啓の稲妻であった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洪水のように押し込んで来る西洋文学の波頭はまずいろいろなおとぎ話の翻訳として少年の世界に現われた。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三人が、姫君のためにはハッピーエンド、彼らの目には悲劇であるかもしれない全編の終局の後に、短いエピローグとして現われ、この劇の当初からかかっていた刺繍のおとぎ話の騎士の絵のできあがったのを広げてそうして魔女のような老嬢の笑いを笑う。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ウィンディバンク氏は椅子から跳び上がり、帽子をつかんで、「そんなおとぎ話で無駄にする時間はありません、ホームズさん。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、分らせたい、おれの心のうちにある――それこそ大したおとぎ話を――むすめがやさしい心をみせりゃ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "が一口に説明すれば、おとぎ話的伝説を持った、宝探しの材料で。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち巻軸にまつわっていた、おとぎ話的伝説は、文字通りおとぎ話的伝説となり、ここに一場の夢物語、サラリと幕を閉じにけり。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩にねる時には、いつも祖母の「昔話」「おとぎばなし」をきゝながら、いつのまにかねむってしまった。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとぎばなし」は、えゝかげんに作ったものばかりだったらしい。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
