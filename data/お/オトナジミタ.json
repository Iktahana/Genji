          ],
          "literary": [
            {
              "text": "どっちが不幸か分るもんか）　豹一は父親に愛されている赤井と、憎まれている自分とどっちが幸福かと、大人じみた思案をした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういう彼の変に大人じみた凸額を、周平はじっと眺めた。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きよ子の性質として妙に大人じみた考えをよく話し出すことをお俊は気に煩っていたから、――お俊は最う一度たずねて見た。",
              "citation": {
                "source": "童話",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はもう大人じみた真面目な心配そうな様子をしている。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八公麿のような、小ましゃくれた、子どものくせに、大人じみた、俺ではない。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
