        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "相手が深く切り込んでも、こちらが途中で押しとどめる。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奔馬の首に縄をかけ、狭い柵のうちに押しとどめることなどできはしないのだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの死んだ娘の来ることがあらうかと、合邦は慌てふためいて押しとどめる。",
              "citation": {
                "source": "文章その他",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの死んだ娘の来ることがあろうかと、合邦は慌てふためいて押しとどめる。",
              "citation": {
                "source": "文章その他",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中に鳳輦を押しとどめるものもあるやの流言もしきりに伝えられる。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、早速ですが、まず第一に……」　小波は、やさしい仕草で、ちょっと押しとどめるような手真似をしながら、「でも、それでは困ります」「へえ、まだ、なにかいけませんか」「お殿様のお申しつけでは、存分にお寛がせ申せということでございました、もっとお寛ぎくださいませ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（いわれて気は立っているし、党員の一人は抜刀を振りかぶりかけるが、他の者がそれを押しとどめる。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていかに切なる戒めも、もはや憧憬のみなぎりを押しとどめる力はなかった。",
              "citation": {
                "source": "トリスタン",
                "author": "TRISTAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "言われて気は立っているし、党員の一人は抜刀を振りかぶりかけるが、他の者がそれを押しとどめる。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、青嵐が、それを押しとどめるようにして、「まあ、いいじゃないか、ゆっくりして行き給えよ」「ゆっくりしていると、日が暮れらあ」「日が暮れたら、泊って行き給え」「そうしちゃいられねえんだよ、おいらはこれから人を探さなくちゃあならねえ」「誰を？",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体的な清潔さはこれだけでこの病気の殺人的な攻勢を押しとどめることができるが18世紀に素晴らしい光を照らした政治的、哲学的、科学的な著しい目覚めもこの清潔さに影響することができなかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくのところ、海底超人の通過をおしとどめる如何なる武器も方法もなかった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は、なぜわたしを殺そうとするのかと問われて、「これよりほかにお前の止めどのない悪逆をおしとどめる方法がないからだ」と言ったのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼の陣の一角が崩れたときは、彼が剣を手にして馬に乗ろうとするのを誰もおしとどめることができなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
