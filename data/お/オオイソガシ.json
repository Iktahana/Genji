          ],
          "literary": [
            {
              "text": "運転手は子供を叱るので大忙しであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は目下大忙しで、邪魔はご勘弁を。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうと眼がつきゃ、大忙しだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、大忙しなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころじゃねえ、いま大忙しなんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト同盟のあらゆる工場・役場・学校の文化宣伝部委員たちは大忙しだ。",
              "citation": {
                "source": "勝利したプロレタリアのメーデー",
                "author": "――モスクワの五月一日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったら旦那さまには前掛けをさせてお米とぎから火おこし、それから出前持ちをして頂きますわ」「おやおや、女房の煙管で亭王こき使われかい」「煙管どころか、わたし算盤で大忙しよ」　思えばこうした楽しいやりとりも今となっては詮ない繰り言になってしまった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鐘が谷の方で鳴り渡って、山尼の徒がそっちへ走って、そうしてそのまま大忙しに、山を下って行ったことだけは、桔梗様にも解っていたが、その他のことは解らないのであった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いゝえ駄目――ハナァと一緒にゐると大忙しだし、あなたを粉だらけにしてしまふわ。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供たちの母さんは『婦人之友』への小説できのうは大忙し。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀ちゃんが目白にいた時代は私の大忙しの時代で、ああいう活気はこの半盲さんには望めませんから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子のよいときはあっちの鈴も鳴り出す、こっちの鈴も鳴り出すで、大忙しだ。",
              "citation": {
                "source": "瀬戸内の小魚たち",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日は一馬の誕生日で、母屋の方の台所でも赤飯をたいたりしていたが、洋館の方の調理場では、夕食の支度に大忙しで、加代子さんも今日は珍しくこっちの食卓へお客にくることになっていた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰さん、あちこち大忙し。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の編集者の方達もみえて、太宰さんはその接待で大忙し。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの日、ニクシミーはおおいそがしのお城にもぐりこんで、サンタクロースの前に行くと、こういいました。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
