        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "他の敵機が横合からとび出してこようが、高射砲や高射機関銃陣地に近づこうが、また地上とすれすれの低空飛行になろうが、どこまでも追って追って追いまくる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで病み呆けた野良犬を追いまくるような汚ならしさで、支那語と露西亜語で喚めき立てた。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が悪いや、あっしをこんなに追いまくるなんて――ねえ、旅は道づれ世は情けって言いまさあ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちを何か邪魔者みたいに、あっちへ行け、あっちへ行けって、追いまくるんですからね」「フーン、それは妙ね。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる敵の悲鳴か、追いまくる味方の声か、ごうごうと曠野の闇をふく風のような震撼が、しばし何処ともなく揺るがしていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "窪地の茂みへ一散に駈け下りて、逃げゆく影をのがさじと追いまくる。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "鳴門の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――董卓を追いまくるのだっ」と、叫んだ。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "のがさじと、史渙は追いまくる。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
