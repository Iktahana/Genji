    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seeing someone off and later welcoming them back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "食うや食わずで昨日今日を送り迎えている。",
              "citation": {
                "source": "述懐",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに、お城の中も、またデンマークの国も、希望に満ちて一日一日を送り迎えしていたような時代は、もう二度と帰って来る事はありますまい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私自身は、以前と少しも変らず、やっぱり苦しい、せっぱつまった一日一日を送り迎えしているのであるから、北さん中畑さんが来なくなったのは、なんだか淋しいのである。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にも山賊の父から兇悪の血を受け、いまは父の真似して女だてらに旅人をおどしてその日その日を送り迎えしている娘だ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはいま、気分が流れ出すまゝに身も心も軽々と、空｜逝く雲か、浪乗る船のようなうき／＼した不安に送り迎えされ始めました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどものとき小学校へ送り迎えをして呉れたり、わたくしの好きな鯔のお臍を焼いて呉れたり、母がわたくしを乞食の裔と罵るのを庇って呉れたり、想い出せば親切だったと思うことも沢山あります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日々に多くの市民の男たちを送り迎えして、その一々に心からなる親切で応待し、心を和めさせ、元気づける倶楽部の娘こそ、わたくしに相応わしいものでありましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "贄川は後に山を負い前に川を控えたる寂びたる村なれど、家数もやや多くて、蚕の糸ひく車の音の路行く我らを送り迎えするなど、住まば住み心よかるべく思わるるところなり。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "召されることがあまり続くころは、打ち橋とか通い廊下のある戸口とかに意地の悪い仕掛けがされて、送り迎えをする女房たちの着物の裾が一度でいたんでしまうようなことがあったりする。",
              "citation": {
                "source": "源氏物語",
                "author": "桐壺",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして少し上目をつかって鏡のほうを見やりながら、今まで閉止していた乱想の寄せ来るままに機敏にそれを送り迎えようと身構えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、むしろフラウの方がオッカナ、ビックリ仕掛けで、御主人の機嫌を取り取り送り迎えをしておられるように見えました。",
              "citation": {
                "source": "奥様探偵術",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "路には榛のまばらな並木やら、庚申塚やら、畠やら、百姓家やらが車の進むままに送り迎えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校は私の家から五町ほど隔ったところにありますが、途中に十丈ほどの険阻な断崖がありますから、入学して一ヶ月ほどは女中のお清に送り迎えさせましたが、後には義夫一人で往復するようになりました。",
              "citation": {
                "source": "安死術",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、皆より二つ年が上で、お家が大層なお金持で、いつも俥夫が二人がかりで送り迎えをする友子さんは、級中で、一番着物の好きな人でした。",
              "citation": {
                "source": "いとこ同志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いわたしの家に生れたものは、祖父も、父も、みな往時旅人の送り迎えに従事した人達であったから、雪が来るたびにわたしはいろいろなことを思い出す。",
              "citation": {
                "source": "雪の障子",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方々は、どういう思いで、今日を送り迎え、自分の投票を考えていらっしゃるでしょう。",
              "citation": {
                "source": "幸福のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩の舎へ行かないときは、上野の図書館へ調べものに行ったり、夜はたのまれた仕立物にせいを出したり、そういう朝夕も、小説のことが念頭からはなれない一葉にとって決しておだやかに送り迎えられる一日一日ではなかったろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみは林町にやるスエ子の送り迎えのため　博覧会　父の到着（父への話。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一台自動車を買って、シュナイダア夫人がドロシイを乗せて学校の送り迎えをするようにしたいと、夫婦で寄りより話し合っていたが、二台の自動車を置くことは、一職工のシュナイダアにとって鳥渡重荷なので、そのままになっていた。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵物語式の大屏風になると、一曲縮図をとるのに三年もの祇園祭を送り迎えたこともある。",
              "citation": {
                "source": "屏風祭",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、この時代には箱屋というのではなく、単にそうした傭女なり老母なりが送り迎えをしたに過ぎない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなく穏やかに御同意をなされればあちらへのお送り迎えを私の手でどんなにでも都合よく計らいますのにはばかりがあるものですか。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "池に面した揚出しの古びた格子窓を眺めやりながら、ふっと、その内らから老人ふたりの徐かな話し声が洩れてくるような気がして耳をすましてみたが、聞えるのは客を送り迎える小女たちの嗄れて甲高い声ばかりであった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう楽しい、平和な月日を送り迎えするうちに、今年は子供がもう七つになりました。",
              "citation": {
                "source": "葛の葉狐",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして全くの遁世の生活を、人里離れた大原山の雪深い所に送る様になってからもう長い間の時が経ち、何回かの春秋を送り迎えした解である。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論学校へ行くには女中や雇人の男衆が送り迎えをする。",
              "citation": {
                "source": "私の貞操観",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って見ると、スエ子の送り迎えにきみを七日からかせとのこと。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その三つ股道の左右に、鍵屋と、万屋と、二軒の茶店が、角店として、旅人を送り迎えしていた（右角が、鍵屋であったという説もある。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の中の村に私達四五人の日本人の子供の為めに整えられた教場へ五脚ばかしの机をならべて、そこへならいにゆくのにも二人は、土人の子の寮外に送り迎えされていた。",
              "citation": {
                "source": "梟啼く",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い欅が白茶けた幹を路の左右に並べて、彼らを送り迎えるごとくに細い枝を揺り動かした。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
