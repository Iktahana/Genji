[
  {
    "uuid": "30e9aa6b-c77a-5441-94c0-abe3fb3192cd",
    "entry": "送り迎え",
    "reading": {
      "primary": "おくりむかえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
