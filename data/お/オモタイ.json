        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「この秋は何で年よる雲に鳥」という句は、「何で年よる」という言葉の味気なく重たい調子。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ときびしい口調で命令し、浦島は素直に眼をつぶると夕立ちの如き音がして、身邊ほのあたたかく、春風に似て春風よりも少し重たい風が耳朶をなぶる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある有名なロシヤ人の小説、非常に重たい小説をよむと厭人病者の話が出て居た。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畫集の重たいのを取り出すのさへ常に増して力が要るな！",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "重たい大地の下になつてゐるかのやうに、ものみなが重苦しく、不安で。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊も苦笑しながら相手の客に一礼して自分の席に向き直り、重たい湯呑み茶碗に手をかける。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの蘆洲は重たい露でしどろもどろに倒れている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人の大蒜や葱の匂いと、兵士の汗と革具の匂いが交錯して、寄宿舎の厚い重たい壁についているようだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "画集の重たいのを取り出すのさえ常に増して力が要るな！",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉笛を吹くなえゝシューベルトのセレナーデこれから独奏なさいますやかましいやかましいやかましいいその葉をだいじにしまっておいて晩頂上で吹けといふ先生先生山地の上の重たいもやのうしろから赤く潰れたをかしなものが昇てくるといふ　　　（それは潰れた赤い信頼！",
              "citation": {
                "source": "春と修羅　第二集",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "重たい画帳を載せると同時に両方の膝頭がガクガクと戦いているのに気が付いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、変な人ねえ、アンタは……何をソンナに怖がるの……何処へ行くのイッタイ……おかアしな人ねえ……ホホホホホホホホ……」　しかし部屋を出て行った青年が、応接間の重たい扉を、向側からバタンと大きな音を立てて閉めると、眉香子の笑い顔が、急にスイッチを切り換えたように冷笑に変化した。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてあの娘は重たい島田を振立てて壺を振りまする以上、鉢巻を致しておりませぬ事には、第一、盆茣蓙の景気が立ちませぬ」「何と……あの娘が壺を振ったと申すか」「振りますとも、振りますとも。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕のこの頑固な胸を君に開いて貰いたいのだ」　ああ、それは実に開くに骨の折れる重たい樫の木の扉である。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の時世に、またとない結縁じゃに因って、半日も早うのう、その難有い人のお姿拝もうと思うての、やらやっと重たい腰を引立てて出て来たことよ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "扱帯は一層しゃらどけして、褄もいとどしく崩れるのを、懶げに持て扱いつつ、忙しく肩で呼吸をしたが、「ええ、誰も来てくれないのかねえ、私が一人でこんなに、」　と重たい髷をうしろへ振って、そのまま仰ざまに倒れそうな、身を揉んで膝で支えて、ハッとまた呼吸を吐くと、トントンと岩に当って、時々｜崖を洗う浪。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう何十年もの昔から使ったことのない古い窖へ忍び込んで、そこの北の隅の埃だらけの重たい床石をやっと持ち上げてみました。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、重たい、首の骨が折れて了ひさうだ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "生い茂った草藪が、象の重たい足に踏みつけられています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "重たい花輪なども、取ってしまいたいと思いました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは人の三倍も四倍も重たいんだぞ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればわかる」「そうだそうだ」　と云ううち、大勢寄ってたかって引っぱり初めましたが、身体が井戸の口にシッカリはまっている上に重たいのでなかなかぬけません。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根から屋根、軒から軒と、重たい豚吉を背負ったまま飛んでは走り飛んでは走りします。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは途方もなく重たいぞ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これは何か重たい刃物か何かの柄を、抜けないように嵌込た証拠らしいぞ……そう思い思い草川巡査は、自分が犯人であるかのように青褪めた、緊張した表情で、そこいらを見まわした。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に不似合な大きな戸棚の並んでいる間から、中の間に通う三｜尺間を仕切っている重たい杉の開戸を、軍隊手袋を嵌めた両手で念入りに検査した。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも極めて鋭利な重たい刃物で、アッと云う間もない唯｜一撃ちに片付けられたものと見えた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして夜になると一知を、わざと蚊帳の無い台所に寝かし、マユミを中の間の蚊帳の中に寝させて、境目の重たい杉扉にガッチリと鍵をかけたものであった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スブリをかけている中に、さしもの重たい藁切庖丁が、さまで重たく感じないようになった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とうとう鼻を抓まれても解らない真の闇になると、そのうちに重たい靴底がフンワリと、海底の泥の上に落付いたようである。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
