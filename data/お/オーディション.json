        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「やれやれ、オーディションは合格らしいぞ」　高志が、片手をあげて拍手にこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしたちのサイバネティック・スキゾイドがオーディションに合格したの知ってる？",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "計画しよう」「実現すると、私はうれしいわ」「僕だってうれしい」「現地に到着して、日常生活が落ち着いたら、その局で簡単なオーディションを受けて、すぐにいま言ったような仕事を始めることになると思うのよ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年、彼らのグループ名がまだザ・シルヴァー・ビートルズだったころの写真で、ラリー・パーンズのためにオーディションしたときのものだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真にうつっているドラマーは、オーディションの現場で代役をつとめたジョニー・ハッチだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ザ・シルヴァー・ビートルズは、オーディションにドラマーなしでやってきた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このオーディションのとき、ザ・シルヴァー・ビートルズがなにを演奏したかを知るためだけに『ザ・ビートルズ』を読んでもいいのだが、ひょっとしたら書いてないかもしれないし、書いてあればあったで、なるほどと思うだけだから、やはりやめておこう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエル・ヤングやロバート・シェルトンのあとおしで、ディランは、ゲルデス・フォーク・シティで、オーディション的にうたった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
