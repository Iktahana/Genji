[
  {
    "uuid": "4a8f227a-aff2-50ac-a5b3-9cd7514274a6",
    "entry": "悪露",
    "reading": {
      "primary": "おろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
