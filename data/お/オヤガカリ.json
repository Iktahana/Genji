[
  {
    "uuid": "446556f5-dcd1-5153-8c9a-e82d4c6056fe",
    "entry": "親がかり",
    "reading": {
      "primary": "おやがかり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
