[
  {
    "uuid": "417e059f-6250-5196-af81-542253b16f4e",
    "entry": "幼い頃",
    "reading": {
      "primary": "おさないころ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
