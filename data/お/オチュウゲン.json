        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「私のお母さんなんか、来るたびにちやほやされて、盆暮には家中めいめいにうんとお中元やお歳暮をもらうもんだから、あんな話のわかる御主人はないと言って、有難がっていたものよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでのてがら金だといって、きのう五十両ばかりお中元にくだすったのでね、おれのてがらはおめえのてがらなんだから、半分そっちへおすそ分けさ」「ちッ、ありがてえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "お中元用の配り物に新花屋のこの女から頼まれて、ちっとばかり鼻毛をのばしながら、せっせとかいたもんだよ」「パカにしちゃいけませんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "お盆のとき浅吉とおゆきとは連立ってお中元に来た。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お中元岸田國士　中元歳暮の贈答を廃止するとかしないとかいふことが問題になつてゐる。",
              "citation": {
                "source": "お中元",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、当局はこれをどう見てゐるか、一切盆暮の贈答は罷りならぬといふ布令を出したところで、単にお義理の贈答なら、お互ひやめればそれで済むのであるが、少くとも「報酬」の意味を含めたお中元の進物などは、贈る方でもなんとか別の手段を考へねばならず、受ける方でも、予め「貰はぬ」とは宣言はしかねるであらう。",
              "citation": {
                "source": "お中元",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にまた出入りの商人が、手拭を持ってお中元にくる。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は隨分暑かつたが、それにしても縁側を開けたまゝで金の勘定をしてゐたのは、少し用心が惡過ぎましたね」「八五郎なら叔母さんから貰つたお中元の小錢でも、用心深く便所の中へ持込んで勘定する」「冗談でせう」「ところで加島屋の後家の傷は？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "縞の財布",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昨夜はずいぶん暑かったが、それにしても縁側を開けたままで金の勘定をしていたのは、少し用心が悪すぎましたね」「八五郎なら叔母さんから貰ったお中元の小銭でも、用心深く便所の中へ持込んで勘定する」「冗談でしょう」「ところで加島屋の後家の傷は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縞の財布",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐原屋の茂吉は、金に糸目をつけない代り、青瓢箪が化けて出たような男で、これもあまり問題にならず、――もっとも本人は佐原屋の身上をお中元に持って行ってしまいそうな意気込みでしたが、見識の高いお勇は、白い歯も見せたことはなかったでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "欄干の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「去年の盆に、御藏前の板藏屋から、お中元に出た浴衣だ」「えツ」「五十反は出てゐるさうだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家さんへお中元をあげるのに買物に出かけたら途中で又うちへ来る女の人に出会って。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもないと青いものを入れられませんし、なるたけ早いうちにお中元をすましてしまいたいから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやんなっちゃう、というのは、この間、お中元の買物をしていて、偶然出会って、丁度私お金が不足して、あっちはボーナス間ぎわだからと大見得切って十円かりていたのよ、いやねえ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お中元やらお歳暮に来たのやら、季節もはっきりは覚えてはいない。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
