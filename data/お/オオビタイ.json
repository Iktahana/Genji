    "definitions": [
      {
        "index": 1,
        "gloss": "men's hairstyle with small sideburns and a wide forehead (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "面の長さは三｜尺ばかり、頤の痩た眉間尺の大額、ぬつと出て、薄霧に包まれた不氣味なのは、よく見ると、軒に打つた秋祭の提灯で、一｜軒取込むのを忘れたのであらう、寂寞した侍町に唯一箇。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はつと立ち上り、その大額面の下に立ってやや小腰をかがめ、「これ、規矩男さんの、おとうさまでいらっしゃいましょうか」と云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵馬には独立ちの馬を画けるもの、或は二頭立ちのものあれども、その中に特に異彩を放てるは大額一面に数百となき放牧の馬を画けるものならん。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの歌は主として大額の絵馬の記憶について歌へり。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "Tonka John の部屋にはまた生れた以前から舊い油繪の大額が煤けきつたまま土藏づくりの鐵格子窓から薄い光線を受けて、柔かにものの吐息のなかに沈默してゐた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには目も眩む金色燦然たる大額が、壁間にズラリと並んでいた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外家元門弟中より紅白｜縮緬の天幕、杵勝名取男女中より縹色絹の後幕、勝久門下名取女｜中より中形縮緬の大額、親密連女名取より茶緞子丸帯の掛地、木場贔屓中より白縮緬の水引が贈られた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年忌には金百円、幕｜一帳男女名取中、葡萄鼠縮緬幕女名取中、大額｜並黒絽夢想袷羽織勝久門弟中、十三年忌が三世の七年忌を繰り上げて併せ修せられたときには、木魚一対墓前｜花立並綫香立男女名取中、十七年忌には蓮華形皿十三枚男女名取中の寄附があった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には村第一の書家だといふ天滿宮の神主の手で、「白砂青松何とかして貧亦可也」と意味の解らぬ愚文を長つたらしく書いた大額が、金紙で立派に裝はれて掲げられ、床には住吉派の繪師の書いた見事な清少納言の大幅が、緞子の表裝に、牙軸でゆツたりと掛かつてゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階がなくなつてから、玄關の軒へ持つて來て窮屈に掲げた貴い人の手蹟、「天滿校」の大額の眞下へ行つて、太政官はまた突つ立つて動かずにゐた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "太政官は昨晩の姿其のまゝで、玄關の「天滿校」の大額の下に、縊れて死んでゐたのである。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の新聞｜原紙で貼り詰めた壁の上に「南船北馬……朴泳孝」と書いた大額が煤け返っている。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――箇展で赤札つけといてね」「こっちは光子さん」　自分の肖像　　　対照　大掃除　サイドボードを動かす　上の下らぬ大額をおろす。",
              "citation": {
                "source": "生活の様式",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面には生産力の大額を強壓的に破壞し、一面には新市場を征服し、および舊市場の搾取を一そう根本的にやる。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今も豊能郡｜熊野田村の祭礼に舁ぐがく（額）と言ふ立て物と比べて見ると、或は大額の義かと思はれぬでもない。",
              "citation": {
                "source": "だいがくの研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの交換は幕府にとって大額の赤字になった。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "「忠勇」と大書した佐久間象山の大額が、厳めしく欄間にかかっていた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは記者の問に應じて身を起し、先づ南面の壁上に掛れる金縁の大額を説明して曰く、是れ普佛戰爭後に於ける第一囘の佛國國民議會なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは記者の問に応じて身を起し、先づ南面の壁上に掛れる金縁の大額を説明して曰く、是れ普仏戦争後に於ける第一囘の仏国国民議会なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には、故司馬先生の筆になる十方不知火の大額をかかげ、その下の、一段小高い畳の壇上、老先生、老先生ありし日には、あの白髪｜赭顔のおごそかな姿が、鉄扇を斜に構えて、そこにすわっていられたものだが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "商工奨励館（昔の郡庁）に掲げられた大額、「豊沛之館」と共に忘れ難い美しさである。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面には緑葉の地に「聖壽萬歳」と白く菊花にてぬきたる大額をかゝげ、天井には隙間もなく列国旗を掛けて、五色のアーク灯の光もあやに、床は鏡の如く磨きたればきら／＼しく照り渡りて、燕尾服、桃紅色服、水色服、扇影、簪光参差として床の上に落ち散りたり。",
              "citation": {
                "source": "燕尾服着初の記",
                "author": "徳富盧花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が、また重なり合って立ちどまったのは、以前の柱よりは少し右の方、菊池容斎の描いた武人の大額の下。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この白熱の興味が、ついに白雲をして五日の間に「妖童般若」の大額を完成させてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜痴居士はあまりに有名ですが、明治十四年に吉原大門の鉄柱に現わした聯句の大字をもって知られ、歌舞伎座の新築当時には舞台上の大額や表看板の大名題の文字も居士の直筆であって、当時評判のものでした。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その祝祭を催したおり、明治十八年四月、直接海舟伯にお願いして揮毫して戴いたのが右の大字、白縮緬大巾二幅、長さ二間余の大額面。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の大額面を、園の入口へ磨丸太の足場を組んで掲げたところ、果して雅俗の衆目を惹いて、さすがは海舟先生と、おかげで祝祭も大当り、もちろん家宝としてその後大切に秘蔵した。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "史館の大額の下には、次のような館則が、壁に貼ってあった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ば朽ちかけた額堂の欄間には、琵琶を抱いた蝉丸の像や、関寺小町の彩画や、八｜景鳥瞰の大額などが、胡粉に雨露の気をただよわせ、埃と蜘蛛の巣の裡にかけられてあった。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
