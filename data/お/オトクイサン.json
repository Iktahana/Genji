        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あまりの低額予算にお得意さんの頭の中身を疑い、やなことはみんな押しつける出版社の社員の品性を奥歯でなじり、こんな額で仕事を請けてくる親父の卑屈を呪った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お得意さんに恥をかくからな！",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばをおおぜいの≪お得意さん≫たちが、ひっきりなしに行き来して、カシタンカを足でつきとばしたり、目の前に立ちふさがったりした。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "（≪お得意さん≫というのは、カシタンカが人間全体を、主人とお得意さんとにわけていたからである。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人とお得意さんとのあいだには、ひじょうな違いがあった――主人は、カシタンカをぶつ権利があるが、反対に、お得意さんに対しては、カシタンカのほうで、そのふくらはぎにかみつく権利があるのだ。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "）お得意さんたちは、どこへ行くのか、ひどくいそいでいて、カシタンカには目もくれなかった。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の中からは、≪お得意さん≫の部類にはいるひとりの男が出てきた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋の寝台の上には、ラシャの毛布にくるまった、ひとりの≪お得意さん≫がねむっていた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "カシタンカは、ひと目で、そのお得意さんがゆうべの見知らぬ男だと気がついた。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国では遠くの方から注文があると名誉と心得て、炭一俵、牛乳一本の注文でも喜んで持って行く店があるが、その間にかえって大切な近所のお得意さんを他の店に取られるといったようなことになり、結局においてかえって損をすることとなるのであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「違いません」「そうすると、玉井君、君の組合を作る運動ちゅうのは、お得意さんに、弓を引くことになりゃせんか？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本だよ」「日本はぼくのお得意さんのひとつだ」　と、彼は言った。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "北さんは、特定のおとくいさんの洋服だけを作るのだ。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいだけの店を張つてさ、そいで、やつとおとくいさんも出来たと言ふのは、なかなかの苦労ぢや無かつたんですよ！",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
