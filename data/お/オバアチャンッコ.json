    "definitions": [
      {
        "index": 1,
        "gloss": "child who loves their grandmother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おばあちゃんっ子について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おばあちゃんっ子がありますね。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおばあちゃんっ子の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおばあちゃんっ子が好きです。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おばあちゃんっ子の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおばあちゃんっ子があります。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おばあちゃんっ子について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおばあちゃんっ子の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおばあちゃんっ子が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおばあちゃんっ子は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおばあちゃんっ子について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおばあちゃんっ子の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おばあちゃんっ子を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
