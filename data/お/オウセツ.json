    "definitions": [
      {
        "index": 1,
        "gloss": "reception (e.g. of visitors)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
