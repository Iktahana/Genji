    "definitions": [
      {
        "index": 1,
        "gloss": "to ride on a person's shoulders",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
