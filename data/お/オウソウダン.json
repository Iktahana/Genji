        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして子どもは予定どおり日本に残して学校を卒業の上代り合って洋行と一応相談を極めた。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし昼間はすべて私が積りをして、これこれの目算を立て、政吉に一応相談をすると、それが好いだろうと同意している。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "身を引いた時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ君はその事情を彼に話して、ともかくもその病人に一度逢わせてもらいたいと言うと、老人はすこぶる難儀らしい顔をして、しばらく思い煩っているらしかったが、こっちの言い分にも無理はないので、それでは主人とも一応相談してみようということになって、彼は他の少年と一緒に奥へ引っ返して行った。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、そうするとなれば、お若は、やっぱり師匠の気息の掛かっているものであるから、師匠にも一応相談をしなければならないが、そこを何んとなく、母から師匠に、母だけの考えとしてお若を貰いたい旨を話してもらうようにたのみました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "家内を貰った頃のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは親分に一応相談して、いいお知恵を拝借した方がよかろうと申されましたので、お忙がしいところをお引き留め申しまして、まことに恐れ入りました」「そこで、どうでしょう、親分」と、庄太は引き取って云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吹未亡人や、楠本の細君に、一応相談をしてみる必要があるかも知れぬ。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私達の要求は殆ど学校当局にはきき入れてもらえず職員会議で一応相談の上という逃げ口上ですべて校長の独断で事ははこばれた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どうせ三味線は後から付けたものであろうから、そのふしは然るべき音楽家に一応相談した方がよさそうである。",
              "citation": {
                "source": "勝太郎",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい保子の心から出たことだとしても、横田には一応相談があってる筈だった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことわるにことわれず、村の者と一応相談してからというて戻って来ただよ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ相手はあの調子の恐もてで来るしょ、ことわるにことわれず、村の者と一応相談してからと言うて戻って来ただよ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
