    "definitions": [
      {
        "index": 1,
        "gloss": "large attendance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "芝居はどこでも大入りで、見物の血を湧かせた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば他はみな晩景の開場なるにかかわらず、これのみひとり昼夜二回の興行ともに、その大入りは永当たり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればいたるところ大入り叶わざるなきがゆえに、四方の金主は渠を争いて、ついに例なき莫大の給金を払うに到れり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三月、新富座の一番目「赤松満祐」中幕「勧進帳」二番目リットンの翻案「人間万事金世中」、大入りにて、六十余日を打ち続け、京浜在留の外国人より、引幕を贈りて総見物あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月の興行大入りを続けて、他の大歌舞伎も一時圧倒されたる観あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○六月、川上音二郎、藤沢浅二郎の書生芝居が中村座に乗込み、意外の大入りを占む、東京における書生芝居の始めとす。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて団十郎は歌舞伎十八番の「暫」を勤め、連日売切れの大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優は沢村小伝次、中村吉右衛門にて、意外の大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○近来、川上その他の新派劇は毎回大入りを占めて連戦連勝の勢いを示し、団菊の両名優をうしないたる歌舞伎劇はとかくに圧倒せらるるの観あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治は左団次一派、本郷は新派の深沢恒造らにて、いずれも大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主なる女優は森律子、村田嘉久子、初瀬浪子らにて、女優劇の名が好奇心を誘い、意外の大入りを占む。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで毎日大入りならば、こんなボロイ商売はない。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その由兵衛の耳にはいったのが両国の『虎の子』で、友蔵の小屋は毎日大入りだという評判。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その入場券を買ってはいると、建物はあまり立派でないが、原住民七分、外国人三分という割合で殆んどいっぱいの大入りであった。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「観世物の方はあの一件が評判になって、毎日大入りです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "幽霊の観世物",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は二日がわりで、はじめの二日は盆前のために景気もあまり思わしくなかったが、二の替りからは盆やすみで木戸止めという大入りを占めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠蔵と紋作の執念が残っているのか、人形にも魂があるのか、みんなも思わず慄然としたそうですが、興行中は別に変ったことも無くて、大入りのうちにめでたく千秋楽になりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて毎度弾ずるごとに大入り故、獄吏に請いて猫を隠し置き、音楽で鼠を集めて夢中になって感心しいる処を掩殺させたとある。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにそれが評判になって、包孝粛の芝居は大入りというのだから、李香は実に大当りさ。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは余り名の売れていない一個の旅役者に過ぎなかった彼が、その名声も俄かにあがって、李香が包孝粛を出しさえすれば大入りはきっと受合いということになったのだから偉いものさ。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎右衛門　それにしても、春以来大入り続きの半左衛門座の中村七三郎どのに、今度の狂言で一泡吹かせることができると思うと、それが何よりもの楽しみじゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな大入りの時に限って、火事盗難なぞの過ちがありがちでのう。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小屋が、割れるような大入りと見える。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎五郎　（相手の源次を失うて、ぼんやり立っていたが）江戸の少長に、この大入りの様子が見せたいのう。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう中日はすぎていたが、団十郎と上方くだりの女形、上村吉三郎の顔合せが珍しいところへ、出しものの狂言そのものが団十郎自作というところから、人気に人気をあおって、まこと文字通り大入り大繁昌でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとこわれましたね、しかし、こういう大入り繁昌の人込みなんだからね。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはまえと違って、いかさま、江戸のお盆人気をひとりで占めているらしく、わんさわんさの大入り繁盛です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間は全部開放して大入り場として、入場料は六銭というのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきゃくさんは　まいにち　おおいりで、　キャラメルが　とくに　たくさん　うれていきます。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
