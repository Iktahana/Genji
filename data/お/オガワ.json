        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "威勢よく流れる小川だけがその日の記憶として残つてゐる。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の直ぐ向ふの笹籔が、サワサワと秋風に吹かれて音立てゝゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち冬の寒い日に、葱などの流れている裏町の小川を表象して、そこに人生の沁々とした侘びを感じているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を切りそうな五円札を一重ねに折りかえして銅貨と一緒に財布へ押しこんだのを懐に入れて、神保町から小川町をしばらくあちこち歩いていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの屋根の下に賄いの小川の食堂があって、谷中のお寺に下宿していた学生時代に、時々昼食を食いに行った。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川を渡って三軒家の方へ出る。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "えびのいる清洌な小川の流れ、それに緑の影をひたす森や山、河畔に咲き乱れる草の花、そういうようなもの全体を引っくるめた田舎の自然を象徴するえびでなければならない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかするとこの影が小川へ飛込んで見えなくなったと思うと、不意に向うの岸の野菊の中から頭を出す。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗惡のポンチ畫には、笑ひたくても笑へないが、小川芋錢の山水に噴き出すことがあるのと、同斷である。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森谷沢という一筋の小川が、左から流れて、落ちるところあたりから、谷というよりも、沢の方へ近くなり、両側の山の頭が低くなって、天が俄に高くなった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮町への道も、玉を転がす里の小川に沿うてゆく、耳から眼から、涼しい風が吹き抜ける。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸後の森からは、小川が一度邸内の泉水を潜って、前の田へと灑がれていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の岸に茂る色々の灌木はみんなさま／″＼の秋の色彩に染められて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川と丘との間の一帶の地に、別莊らしい家が處々に建つて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には森を背負ひ、門前の小川には小橋がかゝつて居る、何となしに閑寂な趣のある好い土地だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此の小川の流が衞生の方から少し氣になる點もあると思つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝門前　左膳と山左が七兵衛の手と足を持って一、二、三で側の小川へボチャンと投げ込んだ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝村の小川の水車の辺りで　六助とお絹のラヴシーン。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "春さきの小川の淀みの淵を覗いていると、いくつも鮒が泳ぎ流れて来て、新茶のような青い水の中に尾鰭を閃めかしては、杭根の苔を食んで、また流れ去って行く。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、左手の方に人家の燈灯がぼんやり光つてゐた――Ｆ町かな‥‥と思ひながら闇の中を見透すと、街道に沿うて流れてゐる狹い小川の水面がいぶし銀のやうに光つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、變化のない街道は相變らず小川に沿うて、平な田畑の間をまつ直ぐに走つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち夜の暗闇の中に劇しい水煙が立つて、一人の兵士が小川の中にバチヤンと落ち込んでしまつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川の油のやうな水面は大きく波立つて、眞黒な人影が毆れた蝙蝠傘のやうに動いてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川を渡って、乾草の堆積のかげから、三人の憲兵に追い立てられて、老人がぼつ／＼やって来た。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川が静かに流れていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川町で用を足して帰りにまたそこを通った。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川米吉は、そこへ便所を建てた。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、助役の傍に来て腰掛けている小川という村会議員が云ったのだ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、源作は、小川に気がつくと答えた。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川は、自分が村で押しが利く地位にいるのを利用して、貧乏人や、自分の気に食わぬ者を困らして喜んでいる男であった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
