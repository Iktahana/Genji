    "definitions": [
      {
        "index": 1,
        "gloss": "princess",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのなかで、まず有名なのは日野家のお姫様一件でしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、公家のお姫様が女郎になったというのですから、みんな不思議がったに相違ありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の行者はお局様とかお姫様とかいっているだけで、ほんとうの名はわかりません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは当家の伜久次郎どのがお姫様に対して無礼を働いたというのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はお姫様に懸想していたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にゆうべの祈祷の休息のあいだに、彼はお姫様をとらえて猥らなことを云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫様は勿論それを取り合われる筈はなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "久次郎どのは何と云っているか知らないが、事実は全くこの通りであって、お姫様を涜そうとするのは神を涜そうとするも同じことである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部は容易にそれに手を触れなかったが、結局お姫様の思召しをうけたまわるまで、ともかくもお預かり申して置くということになって、その二百両を受け取って帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお姫様をさらって行ったばけ物を退治するんだ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕は出て来て杏のお姫様を連れてお城に帰るんだ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお姫様を貰ふんだよ。",
              "citation": {
                "source": "いてふの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫様の様なのは出来る筈は無えが、胆が太てえんだからあの大かい眼で見据えて見ねえ、男の心はびりびりっと震え込んで一たまりも無えに極まって居らあ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お粥腹のお姫様を饂飩で口説いて、八頭を見て泣いたって、まるでお精霊様の濡場のようだね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　お姫様、お聞きの通りでござります。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴女様に、御挨拶申上げて……お沢　（はっと手をつかう）お姫様。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お沢　（涙ぐみつつ）お姫様。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫様なんざあ学者の先生だけれども、こいつあ分らない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……魔のお姫様の直伝ですから。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いえ、こりゃお姫様。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）椿　あれ、お姫様。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿　百万石のお姫様。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石の身体に金銀の羽根を持った鳥や虫、または何とも云いようのない程美事な月の御殿の中の有り様や、そこに大勢の獣や鳥を連れて迎えに出て来た美しいお姫様の姿なぞが、ズンズン眼の前に近づいて来ました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり不思議なことばかり続くので、リイは肝を潰して立っていますと、そこへ最前の美しいお姫様が来まして、「まあリイさま、よく入らっしゃいました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御褒美で、アアは王様の国を半分と一番目のお姫様を、サアはまた残りの半分と二番目のお姫様を貰って、二人共王様になり、お父様とお母様を半月宛両方へ呼んで、大威張りをしているところまで見えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ははあ、それからあのＳ家のお姫様のおはなしになる段どりですな。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、髭そうろうの大尽は、かの五人の手下に言いふくめて、金銀｜綾錦のたぐいの重宝をおびただしく持参させ、かの土塀の家に遣し、お姫様を是非とも貰い受けたしと頗る唐突ながら強硬の談判を開始させた。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこの趣を――お艶様、その御婦人に申しますと、――そうしたお方を、どうして、女神様とも、お姫様とも言わないで、奥さまと言うんでしょう。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃ昔のお姫様さ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ王さまのおひめさまともなれば、たいして人にえんりょする必要はありませんでした。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
