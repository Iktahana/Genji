        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この時はむしろ進んで、先生はこれを知らない、よく調べて来ましょう、皆さんもまたよく考えてお出でなさい、いろいろ六ヶしいまた面白いことがあるだろうと思いますといった風に取扱ってほしい。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴所下りてお出でなさいよ」と母が呼ぶ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――まあ折角連れていらっしたのですから、縁側でなりと休んでお出でなさい。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物をしてお出でなさい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと甲板へお出でなさい。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、お出でなさいまし。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああよく通ったね」「また壅ったときは、いつでも持ってお出でなさい」　大口｜開いて馭者は心快げに笑えり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸は事もなげに、「じゃあなた、お出でなさいな、ねえ、東京へさ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、よく気をつけてお出でなさい。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃がして仕舞うといけないから、直ぐに追っかけてお出でなさいよ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん、気を注けてお出でなさいよ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さまは療養所へ行ってお出でなさいますがね、もうお帰りなさる時分ですよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がお弁当を上げますからそれを二人で食べて、それから私についてお出でなさい。",
              "citation": {
                "source": "二人の男と荷車曳き",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ここでは忙しくてお話が出来ませんから、こちらへお出でなさい」　と、夫婦を自分達の宿屋へ連れてゆきました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚吉とヒョロ子夫婦はその夜遅く動物の見世物小舎の前まで来ますと、もう見物人も何も居ず、音楽隊やそのほかの雇人も皆一人も居なくなって、表には主人がたった一人番をしておりましたが、二人を見ると、「サアサア、こちらへお出でなさい。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらへお出でなさい。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女これからおいでなさるなら、早瀬の許へお出でなさい、あすこに居ましょうで。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで宜しくばお稽古にお出でなさい、早瀬主税は攫徒の補助をした東京の食詰者です。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍女一　度々海の上へお出でなさいますもの、よく御存じでおあんなさいましょうのに。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それともお湯へお出でなさいましてですか、お座敷には居らつしやいませんですよ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへお出でなさい。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「灰色のぶちの牝牛よ、　大きなぶちの牝牛よ、　小さなぶちの牝牛よ、　白いぶちの牝牛よ、　みんなここへお出でなさい。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生にいる、　その四ひきもお出でなさい。",
              "citation": {
                "source": "湖水の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもう一度どうにかして上げますから、王さまに銀のびんを二つもらってお出でなさい。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてゐると、その鳥のやうな声は、「蜘蛛のはしごが下りてゐる、早くかへつてお出でなさい。",
              "citation": {
                "source": "星の女",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行きませう、お出でなさい、」「すみませんね、」　譲はもう歩き出したがはじめのやうにとつととは歩けない。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日を過ぎてお出でなさい」　それでは十日の後に再び来ると約束して、※の一行は立ち帰った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところへ來るにはね、まづ齒醫者にひとつき通つてから、おいでなさいだ。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、生きておいでなさい。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は私が粗末ながら運んで来ますから、しばらくこの辺のどこかに忍んでおいでなさい。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
