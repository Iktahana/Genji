    "definitions": [
      {
        "index": 1,
        "gloss": "to get up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昼間は落付かないし、出掛けてもさして面白くないので、私には朝早く起きることは大変時間の損失なのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きるとから、――下宿には眠りに帰るばかりだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十六日政夫民子様　学校へ行くとは云え、罪があって早くやられると云う境遇であるから、人の笑声話声にも一々ひがみ心が起きる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今私も起きるからお前御飯前なら御飯を済ましてしまえ」　僕は何のことか頻りに気になるけれど、母がそういうままに早々に飯をすまして再び母の所へくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝七五郎の家　七五郎、起きる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って、──いつも家へ着くのは晩だが、その翌朝、先ず第一に驚くことは、朝起きるのが早いことである。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も皆について起きる。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体豚のごとき何ぞよく死のごとき高等なる観念を有せんや　そはたゞ腹が空った、かぶらの茎、噛みつく、うまい、厭きた、ねむり、起きる、鼻がつまる、ぐうと鳴らす、腹がへった、麦糠、たべる、うまい、つかれたねむる、との如き一一の〔〕小き現在の連続のみ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は遲く歸つたので、をぢさんは明日の朝早く起きるのが辛かつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれをいつまで持ち耐えなければならないかということはまったく猫次第であり、いつ起きるかしれない母親次第だと思うと、どうしてもそんな馬鹿馬鹿しい辛抱はしきれない気がするのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝られない夜のあとでは、ちょっとしたことにすぐ底熱い昂奮が起きる。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きるとすぐ波を見ようと裏の土堤へ出た。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きるとから夜おそくまで入れ代わり立ち代わり人に攻められた。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供らはもうすっかり歌詞や旋律を覚えてしまって、朝起きると床の中からあちらでもこちらでもそれを歌っているのであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きると寒暖計が八十度近くに来ているようになると、もう水で顔や頭髪を洗っても悪寒を感ぜず、足袋をはかなくても足が冷えない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きるんだ、おい」　と清逸は弟の蒲団に手をかけてゆすぶった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の足をふむんだもの」　朝起きると花子は自分の部屋の前でぼんやり立ってました。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂の抜きようが足りんだった処へ、寝るにも起きるにも脱がねえもんで、こりゃ、雨な、埃な、日向な、汗な、膏で熊の皮に湧いた蛆だよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはただ腹が空った、かぶらの茎、噛みつく、うまい、厭きた、ねむり、起きる、鼻がつまる、ぐうと鳴らす、腹がへった、麦糠、たべる、うまい、つかれた、ねむる、という工合に一つずつの小さな現在が続いて居るだけである。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎いと云うては、悲しいと云うては、人のものが欲しい、おのれの身がかはいいと云つては、寝ると起きると、心の鬼が責めたてる。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経が起きると又いけないから。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "神經が起きると又いけないから。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣紋を細く、圓髷を、おくれ毛のまゝ、ブリキの罐に枕して、緊乎と、白井さんの若い母さんが胸に抱いた幼兒が、怯えたやうに、海軍服でひよつくりと起きると、ものを熟と視て、みつめて、むくりと半ば起きたが、小さい娘さんの胸の上へ乘つて、乘ると辷つて、ころりと俵にころがつて、すや／＼と其のまゝ寢た。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　起きるのに張合がなくて、細君の、まだ裸体で柏餅に包まっているのを、そう言うと、主人はちょっと舌を出して黙って行く。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "△日が暮れたら寝る、夜が明けたら起きる、食べたくなつたら食べる、歩きたくなつたら歩く、――さういふ生活へ私は入りつゝある、それは無理のない、余裕のある、任運自在の生活である。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "といっても此頃で八時九時には起きる。",
              "citation": {
                "source": "私の生活",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きる直ぐ、新聞を丸めた上へ木炭を載せかけた七輪を煽ぎ立てる。",
              "citation": {
                "source": "私の生活",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼覚めたらすぐ起きるのが私の癖だ、起きたのは四時頃か、そこらを片付ける、さつぱりする、気持がいゝな。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "從ツて飯を食ふ、寢る、起きる、総べて生活が自堕落となツて、朝寢通すやうなこともある、此くして彼は立派な怠者となツて、其の居室までもやりツぱなしに亂雜にして置くやうになツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それこそ未決騒ぎがおきるよ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
