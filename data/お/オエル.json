        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "息詰まるような長い接吻を終えると、彼は絶望的な声を挙げて妾を突きとばしたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂刳磔の苦労をして、一作、一作を書き終えるごとに、世評はともあれ、彼の屈辱の傷はいよいよ激烈にうずき、痛み、彼の心の満たされぬ空洞が、いよいよひろがり、深まり、そうして死んだのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は仕事が終えるとずいぶん疲れるだろうな」　といってやった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読み終えるとおぬいは眼に涙をためていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子はピンをさし終えるが早いか、突然いやに冷めたい手で私の両耳にぶら下がると、私の唇に接吻して、どんどん暗やみの方へ逃げて行ってしまったではないか。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下デザートを終えるまでのコースにも、何一つ不足と思えるものもなく、いわゆる善尽し、美尽しで、感嘆の中に食事を終えたことである。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして親しげに話していて、隣に座っている娘と、何か紙一重｜距てたような、妙な心の触れ合いのまま、食後の馥郁とした香煎の湯を飲み終えると、そこへ老主人が再び出て来て挨拶した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はこの所作を終えると、自分のしたことを自分で興がるように、また抹殺するように、きゃらきゃらと笑って立上った。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マタイ伝二十八章、読み終えるのに、三年かかった。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぼくは直ちに職場に組織を作り、キャップとなり、仕事を終えると、街で上の線と逢い、きっ茶店で、顔をこわばらせて、秘密書類を交換しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きりゝしゃんとして」　母はわたくしに十二分の粧いをさせて帯を結び終えるとこう言って背中を一つ叩きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその説明を終えるときこういう言葉をつけ足した。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年たち、紀元節の大赦で二日早く刑を終えると読み上げられた時、泣いて喜んだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、庄之助は長いお祈りを終えると、「さア帰ろう」　と、寿子の小さな手を握った。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　事実、作品を書終えるや否や、彼は作者たることを止めて、其の作品の愛読者になった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯うして、中学を終えると直ぐに東京へ出て了った私は、其の後、杳として彼の消息を聞かないのだ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして輝かしい熱帯の太陽の下に、唯物論も維摩居士も無上命法も、ないしは人類の歴史も、太陽系の構造も、すべてを知らないで一生を終えることも出来たはずではないのか？",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年経ち、紀元節の大赦で二日早く刑を終えると読み上げられた時、泣いて喜んだ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女は、手紙を読み終えると同時に、わーっ！",
              "citation": {
                "source": "錯覚の拷問室",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事をやり終えると急いで逃げて、玄関は共犯者に内側から閂をかけてもらった、というわけです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と手紙を読み終えるとホームズが悩ましげに言った。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "一両日中は二人とも荷ほどきしたり、私物をうまく置こうと悩んだりしながら時間をとられたが、終えると徐々に腰も落ち着いてきて、新しい環境に慣れ始めていった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "終えると、我々は息も切れ切れに立ち上がった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことを終えると、フェリアの気はいくぶんか落ち着き、少し心も軽くなって家路についた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が仔細のすべてを話し終えると、相手も降参して、あとはもう自分が無事に逃れるすべばかり考えていたね。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "母ガエルはかざり終えると、みにくいむすこを連れて、はっぱの上に一人でいるかわいそうなおやゆび姫のもとへ泳いでいきました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつあ全く別の話というもので、どうもまるでおれにゃあ合点のいかねえことでねえ」　彼はこの言葉を静穏の中に言い終えることができなかった。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句付け合わせの付け心は薄月夜に梅のにおえるごとくあるべしというのはまさにこれをさすのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マタンは小学校をおえると、木ぐつ師になりたいと思いました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪の桔梗の紫の影に映えて、女はうるおえる玉のようであった。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
