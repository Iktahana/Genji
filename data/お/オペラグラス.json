        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「まあ、見にいくんだろうが、見るにしても、あの場にいたんでは、オペラグラスでもなければ、見えないだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少年は、私が舞台を見ているオペラグラスが珍しいのであった。",
              "citation": {
                "source": "時計",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日オペラグラスを持って見に行ったもんだよ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はシュミッド特製のオペラグラスを眼に当てた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイカはオペラグラスを膝の上に落した。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は早速にポケットからオペラグラスをとり出して見ると、実に肉付きのよい美しい女の手で、その小指には大きいダイヤモンドが異様にかがやき、その白いふくよかな腕には宝石をちりばめた腕環がかがやいていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "廃宅",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はオペラグラスを取り出して、それからの毎日、窓を通る一つ一つの帆カケ舟を点検したのですが、帆影はつひに見出せなかつたのです。",
              "citation": {
                "source": "帆影",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "火口ではオペラグラスの賃貸料がもうかる始末で、後始末の方は全然手間賃もいらないのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一度ならず目に映じたものだから、Ａは急に好奇心をおこして、そばにあったオペラグラスを取り出して一生懸命にピントをあわせて見たのです。",
              "citation": {
                "source": "正義",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらいらっしゃらないわ」「本当ね」「あたし探してあげましょうか」　百合子はすぐ自分の手に持ったこっちのオペラグラスを眼へ宛てがった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鳥子さん、うまく行けば藤井さんを救えるかも知れない、――オペラ・グラスがあったら見付けて来て下さい」「え」　鳥子は出て行きましたが、やがて、若菜の愛用だったらしい、象牙に金の柄の付いた、豪勢なオペラグラスを持って来ました。",
              "citation": {
                "source": "音波の殺人",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の窓から日本女はオペラグラスで午前二時半の字面を読むこともある。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、オペラグラスを眼へあてがいながら、彼は精々できるだけ、気楽そうな観照の態度を示すことに努めた。",
              "citation": {
                "source": "餓えた人々（習作）",
                "author": "DIE HUNGERNDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペラグラスのかけてある毛皮の外套を伝わって、塗り靴のところまでおりて行ったかと思うと、今度はまたさっきの求めむさぼるような探りかたで、突き刺すようにデトレフの眼を見つめるのであった。",
              "citation": {
                "source": "餓えた人々（習作）",
                "author": "DIE HUNGERNDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あらゆるオペラグラスは、平土間のも桟敷のも、舞台のすぐ右側の特等席十三号へと、ことごとく向けられていた。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "座席の方からは貴婦人達のオペラグラスが一斉に彼の方へ向けられた。",
              "citation": {
                "source": "のんしやらん記録",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "薔薇は変形させられるために裸にされた時、四方から彼の上にそゝがれた貴婦人たちのオペラグラスを思ひ出して、赧くなつた。",
              "citation": {
                "source": "のんしやらん記録",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が正面の桟敷席に入ろうとした時、どういう若いツバメだろうと思われたのだろう、彼はこの上なく魅力的な化粧をしていた子爵夫人と共に、総てのオペラグラスが一斉に自分達に向けられているのを感じた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "見て、どうしたのかしら、彼女ったらオペラグラスをかざして、また外したわ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かにボーセアン夫人はその桟敷にオペラグラスを向けながら、ニュシンゲン夫人には注意を払わなくなったようだった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし劇場のバルコニー席に坐っている若者が、はっとさせるようなチョッキを着て、綺麗な女性達のオペラグラスの視線を集めたとしても、彼がちゃんと靴下を履いているかどうかは疑わしいのである。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペラグラスを絶えず使っている。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
