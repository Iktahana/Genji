        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あるいは一歩さかのぼって、裾野がいまだ生成しないうち、富士と、愛鷹と、箱根が、陥没地帯の大海原に、火山島のように煙を吐いて、浮かんでいたところを想像すれば、今日の豆南諸島の大島、利島、三宅島などが、鋪石のように大洋に置かれているのと似て、更に大規模なる山海の布置を構成するであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "天に年わかき男星女星ありて、相隔つる遠けれど恋路は千万里も一里とて、このふたりいつしか深き愛の夢に入り、夜々の楽しき時を地に下りて享け、あるいは高峰の岩｜角に、あるいは大海原の波の上に、あるいは細渓川の流れの潯に、つきぬ睦語かたり明かし、東雲の空に驚きては天に帰りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "此珍事のあつた翌日は私は、日出雄少年と唯二人で、長さ卅｜呎にも足らぬ小端艇に身を委ねて、水や空なる大海原を浪のまに／＼漂つて居るのであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "第九回　大海原の小端艇亞尼の豫言――日出雄少年の夢――印度洋の大潮流――にはか雨――昔の御馳走――巨大な魚群　恐しき一夜は遂に明けた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い樣でも海上の三｜里は容易でない、無限の大海原に漂つて居つた間こそ、島さへ見出せば、直ちに助かる樣に考へて居つたが、仲々左樣は行かぬ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の江丸とは、例の反古新聞に記されて居つた名で、はじめ、大佐の一行を此島へ搭せて來た一大帆前船、あゝ、あの船も、今は何かの理由で、此海岸にあらずなつたかと、私は窓の硝子越しに海面を眺めると、星影淡き波上には、一二｜艘淋し氣に泛んで居る小端艇の他には、此大海原を渡るとも見ゆべき一艘の船もなかつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大海原の東の極から、うら／＼と昇つて來る旭の光も、今日は格別に麗はしい樣だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐る／＼搖籃から半身を現はして下界を見ると、今は何處の空に吹流されたものやら、西も東も方角さへ分らぬ程だが、身は矢張渺々たる大海原の天空に飛揚して居るのであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は昼に大抵帆船「ビアフラ」の甲板に出で、左に烟のごときアフリカ大陸を眺め、右に果しなき大海原を見渡し、夜は月なき限り、早くより船底の寝室に閉じこもって眠る。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、セント・ヘレナの島に幽閉された英雄が、荒寥たる岩頭に立って、胸に雄志を抱きながら大海原をながめやっている姿を見たこともあるのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "日盛りの蝉の声々が大海原の暴風を思わせる村の四方の山々を通抜ける幾筋もの小径を基線にして、次第次第に捜索の範囲が拡大されて行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一国、一島、津や浦の果から果を一網にもせい、人間｜夥間が、大海原から取入れます獲ものというは、貝に溜った雫ほどにいささかなものでござっての、お腰元衆など思うてもみられまい、鉤の尖に虫を附けて雑魚一筋を釣るという仙人業をしまするよ。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にそれ等が渋堅い形を取っていようと、蒼空と大海原のような限りもなく窮まりもない時空の引伸し器に挟まれたなら、まるで縁日の芭蕉せんべいを焼くように、平たく展ばされ、脆くも軽く膨らまされて、もし割って食べられたら淡い甘みも付いていて、こどもの口にさえ、さぞおいしいようなものでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺むれどものうし、のぼる日のかげも、大海原の空｜燃えて、今日も緩ゆる縦にのみ湧くなる雲の火のはしら重げに色もかはらねば見るもものうし。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はばたき聞けとある大海原のただなかは終日重きあかがねの霧たちこめてゆたゆたに濤こそうねれ、日輪は凄まじ、黒き血の塊と焦げて暈めく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はろばろや大海原、涯なしや青水沫、揺りとよめ大き国民、大君に、この神に、讃へ言、寿詞申せや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はろばろや大海原、涯なしや青水沫、搖りとよめ大き國民、大君に、この神に、讚へ言、壽詞申せや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青焔に揺れる大海原が瑠璃色の空と続くあたりは、金粉を交えた水蒸気にぼかされて白く霞んで見えた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右舷は渦巻に近く、左舷にはいま通ってきた大海原がもり上がっていました。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡し舟に乗つて水族館を見物に赴くと、千種万別の魚介も、水槽の水に、尨大極まりもない大海原の夢を掬つて、生々と蘇みがえつてゐる。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち寄せる大波の底を目がけて砲弾のやうに飛び込み、波向ふに進む時は、大海原を征服したやうな誇りを感ずる、などと云つてＦに舌を巻かせた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――七年前までは、自由に浮んだものだ、そして私に大海原の聯想をさせたものだ、短い年月が過ぎ、盥は今では走らなくなつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "大海原の聯想も出来なかつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの愛に満ちて流れ漂ふ大海原に溶けこんで、　あなたの法楽の洪水に有頂天になつたその死者を唄はう。",
              "citation": {
                "source": "運命と人",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "放埒な、移り気な、想像も及ばぬパッションにのたうち回ってうめき悩むあの大海原――葉子は失われた楽園を慕い望むイヴのように、静かに小さくうねる水の皺を見やりながら、はるかな海の上の旅路を思いやった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白樺よ、蓬生の大海原に浴する女の身震、風がその薄色の髮に戲れると、おまへたちはなにか祕密を守らうとして象牙の戸のやうに脚を合せる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはブランコが揺れるままに、何時かしら、藍色のキモノに身を包んで藍色の大海原を帆走る一個の船夫であった。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、再び、何んなに私達が多くの思慮深い額をあつめて、事を謀らうが、長夜の寄合ひを続けようが、相手が深淵極りなき大海原であり、大ネプチューンの支配下である限り――嗚呼！",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎もあれ、われらの眼に映る大洋は、最早｜涯も無く續いてゐる大海原ではなくて、彼岸へ渡ることの出來る大洋である。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "高千穂峯で最初の火を燃したわれ等の祖先が、どんなに晴れやかさの好きな自然人であったか、またこの素朴な大海原と平野に臨んでどんなに男らしく亢奮したか。",
              "citation": {
                "source": "九州の東海岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
