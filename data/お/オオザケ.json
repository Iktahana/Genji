[
  {
    "uuid": "b63bfd0e-0516-524b-b371-b6ae07e87cf8",
    "entry": "大酒",
    "reading": {
      "primary": "おおざけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
