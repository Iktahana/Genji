        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この混合した粉を硝子板の表面に一様に篩いかけて後押し付けると三色の粉を不同なく板の上に密布し、顕微鏡で見れば全体がモザイックのようになっている。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の青い娘は、着てゐる薄い茶色のジヤケツを、分厚に出来た、黒い※の木のベンチの、一番暗い隅に押し付けるやうにして坐つてゐる。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく「無弦の琴」とか、「無声の韻」とかいう言葉がありますが、これはその心境を解したもの同志の間で言うことであって、これを生のまま人に理解を押し付けるといわゆる「野狐禅」とか「生悟り」とかいうものになりまして、却って仏教が世間から誹を招く基になるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "商品に手数料の利徳といふものをつけるのは当りまへであるには違ひなからうけれど、性分だ、その利徳はただ儲けの為に人に押し付けるやうで、客に価値を訊かれても、さそくに大きい声では返事も出来なかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その無謀な叫びをこちらへ押し付けるやうに目をしツかりつぶつてまで見せた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その婿には池田屋十右衛門の次男を押し付けるという段取りで、だんだんにその計略を進行させることになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村にでも未練があれば知らない事」　こういって不敵に笑いながら押し付けるように葉子を見た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "張訓が夜寝ていると大きいがまがその胸のうえに這いあがって、息が止るかと思うほどに強く押し付けるのである。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して娘さんは煙草のお釣りを、「はい一銭のお返し」と云って、私の掌の上に押し付けるようにして渡してくれた。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども變な氣持ちは、彼れの頭を押し付けるやうで、肝心の羊羮を盜むことを忘れたまま、ぼんやりと家へ歸つて來た。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし若林博士は、そうした私の疑いを押し付けるかのように静かに私の顔を見据えた。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その店で私は、動物、植物あるいはまた滑稽人形の絵を切って湯に浮かせ、つぶつぶと紙面に汗をかくのを待って白紙に押し付けると、その獣や花や人の絵が奇麗に映る西洋押絵というものを買いに行った。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と押し付けるような声で、吉次はグッとたしなめにかかった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、御拭き」と云いながら糸子の胸の先へ押し付ける。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "マアこれを持って往って御覧なさい、向うの人がどんなに悦ぶでしょう」と言葉巧みに押し付ける。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その薄い膜を破って腸を胴の方へ押し付けると背中の骨の処人間ならば腰という処に色の白い玉子形の米粒位なものが一つ見える。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、そんな押し付けるようなことをいうもんじゃないわ、何か買って来た時は――『お前にこんな物を買って来てやったが、どうだい、気に入るか』って、まず訊くものよ」　そんなことをいった。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずこのような物は、無理に押し付けることも出来ねばまた差押えることも出来ない。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "名付けようのない反撃があるかもしれないし、仮にこの邪悪な野郎が言うことを聞いたとしても、それじゃ汚らしい厄介者をよその土地に押し付けるだけだろう。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼同様に、悪夢のような太古から生き残ってきたこの病的な遺物のもつ数多くの特徴が我々に押し付けるいくつかの結論を受け容れざるを得なかっただけに尚更だ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「混合体、とくに腐敗しているもの、からの種々の蒸発物、発散で満ちた周囲の空気をある量の均一溶液に入れて外の毒気または有害な素質を局所に激しく押し付ける。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中を木に押し付けるようにして、後ろ手に縛ったロープを例の鉄の環に結んだ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女は椅子の隅へ男を押し付けると、男は素直にそこへ坐って、なんだか正気になろうと努力するような様子で、周囲を見廻した。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰茎と睾丸は包にくるんで恥丘の近くで一刀のもとに切断し、傷口に１掴みの止血粉末を押し付ける。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "……本当に足軽なかまの或る者はそう云って嗤い、感心するよりも軽侮した態度で、遠慮もなくかれに仕事を押し付けるのだった。",
              "citation": {
                "source": "足軽奉公",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲も結局同じことだが、これは両力士が同体に倒れながら上になり下になり、床へ肩を押し付けるのが最後の勝負とあって、双方肩を気にしながら上を下へと揉み合う有様はむしろ柔道式、華々しい日本の相撲を見馴れた目には、ただもぐもぐと埒の明かぬこと夥しい。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村はいつもになくまじめな、人をおしつけるような声で、「君はベツレヘムで生まれた人類が救い主エス、クリストを信じないか。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の距離の感ぜられるのは、像が飛んで来る時に前面の空気を押して目におしつけるためである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今小児を受取るであろう、――彼女は小児を自分の胸におしつけるであろう、――その小さな体にしがみつき、息もつけなくなるほどに愛撫を浴びせかけるであろう。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、今宵こそは兄弟のいきほひで飲み明さう――などゝ彼等は、わたしが、ぼんやりと飲んでゐるのは、あまりその酒が不味いからなんだといふのには気づかず、無闇と大コツプをわたしの口さきへおしつけるのであつた。",
              "citation": {
                "source": "書斎を棄てゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
