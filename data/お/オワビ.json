            }
          ],
          "literary": [
            {
              "text": "私共は如何様にもあなたにお詫びを致します。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたにお詫びをするのが何より民子の供養になるのです」　僕はただもう胸一ぱいで何も言うことが出来ない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですからお詫びを申す様な訣……」　僕は皆さんにそんなにお詫びを云われる訣はないという。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子のお父さんはお詫びを言わしてくれという。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考えるほどあの児が可哀相で可哀相で居ても起っても居られない……せめてあなたに来て頂いて、皆が悪かったことを十分あなたにお詫びをし、またあれの墓にも香花をあなたの手から手向けて頂いたら、少しは家中の心持も休まるかと思いまして……今日のことをなんぼう待ちましたろ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、僕の失禮をお詫びします。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家諸氏や編輯者にお詫びをしなければならない。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さういふ姿をお眼に掛ける失禮をお詫びしながら、暫くアストオル吸入器を用ゐた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端氏に對してはその作品を汚したことを幾重にもお詫びしたい。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ、貴兄に機会があればお詫びするとして取敢えず原稿を御返却いたします。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、父は学校のおつとめの帰りに、岩見先生のお家へ、お礼とお詫びにあがったようでした。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまこそ私は、いつか叔父さんに教えられたように、私の見た事、感じた事をありのままに書いて神様にお詫びしたいとも思うのですが、私には、その勇気がありません。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレ……この通りお詫びを申上げます。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして万事落着しますれば、私が今度の遣り損いのお詫びの印に、今一人そのような曰くのミジンも付かぬ清浄潔白。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳はおろおろ声になって、「後生だからそんなこと言わないで、あなたはお父様にお詫びして姉様と一緒になって――」　千歳が思わず取縋った慶四郎の手から、却ってぴりぴりするような厳しい震えを千歳は感じた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の失策で、貴方や日出雄少年を殺したとなつては大佐閣下に言譯がない、此お詫びには成るか、成らぬか、一つ命懸けで猛獸共を追拂つて見るのだ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は貴方にお詫びします。",
              "citation": {
                "source": "計畫",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前勝手、申訳のないお詫びに剃ったような坊主。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子之介　隙もあらばかたきを討たうと、刃を呑んで住み込みましたが、あくまで前非を悔いた佐々木どの、この子之介のまへに兩手を突いて、ゆるしてくれとお詫びなされた。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間住所も知らせず、手紙も差し上げず、怒っていらっしゃることと思いますが、そのお詫びかたがたお便りしました。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ今まで何一つ立派な事もして来なかった体、死んでお詫びしたくとも、矢張り死ぬまで一どお眼に掛りたく。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君は不良少女なぞと云ったことを、勿論みんなの前でお詫びする気でしょうね。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお前の親御様へお詫びにゆく。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞそのお薬を教えて下さいませ」　とあやまりますと、ほかのものも地びたに手を突いて一生けんめいお詫びをしました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかな事ばかり、やらかしたがそのお詫びに、学校だけは卒業して見せてくれるだろう。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、毎夜、神様に、お詫びを申しました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロセチの霊にも、お詫びしなければならぬ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、まだ私に、すみませんというお詫びをさえ言っていません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットさまも、あたしも、このごろ考えている事は、どうして王妃さまにお詫びをしようかという苦しみだけでございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――きょうは、あなたにおわびを申し上げます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
