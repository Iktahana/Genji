    "definitions": [
      {
        "index": 1,
        "gloss": "filthy water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "水の清浄法　近頃汚水から清水を得るのに電気分解を用いる法が出来た。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚水中にアルミニウムの電極を入れて電流を通ずれば、過酸化アルミニウムを生じ、これが種々の汚物に結合して固まってしまう。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで色々試験をしてみた結果だというのを聞いてみるに、普通下水溝渠のごとき汚水中では精々四日間くらいしか生きていぬが、水が清浄なほど永く生きているそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くたびれるから抜手を切っちゃいかん」　河口西側の蘆洲をかすめて靄の隙から市の汚水処分場が見え出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一夜で、黄色い汚水に変ってしまいました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは市中の汚水を集めて濁っている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時すぐ下の崖の中途の汚水の溜りから金魚の餌のあかこを採って降りようとした復一がふとそこを見上げたが、復一はそれなり知らぬ振りでさっさと崖を降りてしまった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方近くあかこを取ることを装って、復一はこそこそと崖の途中の汚水の溜りまで登って、そこで蹲った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの露地からも、ちょろ／＼流れ出る汚水が道の割栗石の窪みを伝って勝手に溝を作って居る。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その波濤の面の金と紅とが乳黄となり、やや寒い瓏銀となり、ブリュブラックとなり、重く暗くなり、そうして今は舷下の飛沫と潮※とがただ白く青く駛って、擾れて、機関部の汚水がタッタッと吐き出されてゆく。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳を取ったどすぐろい汚水、死に馬の眼のような水溜まりだった。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "溜り水を瀦というも豕が汚水を好むからだろう。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "過日のしけの時などは、下水を溢れて滝のように流るる汚水の中に、押し合いヘシ合って電車に乗る人々、自動車のタイヤの両側に破れむしろを袴のように垂らして、その中を押しわけて行く自動車の笛、雨の音、叫び声なぞいう修羅場が東京市中到る処に展開された。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一方、あの謹厳な正直者の風間看守は、たしかに怪異の姿を見たと言うし、ランプ室の床に四散していた汚水といい、妙な唸り声や、鳴き声といい……ああとにかく、もう一度塔の上へ登ってみよう」　そこでわたし達は、ふたたび塔上のうす暗いランプ室へやって来た。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "水勢はげしく、遂に地下室を破壊して、汚水が花壜録音器を濡したるため、機能停止したるものと思われる。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汚水をくぐりて浄き蓮の花」と、古人もいっていますが、そうした尊い深い意味を説いているのが、この『法華経』というお経です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに違ひない、アノ洋服の色は、饐えた、腐つた、溝の中の汚水の臭氣で那※に變色したのだ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の前の狹い溝には、流れるでもない汚水の上に、薄曇つた泡が數限りなく腐つた泥から湧いてゐて、日に晒された幅廣い道路の礫は足を燒く程暖く、蒸された土の温氣が目も眩む許り胸を催嘔せた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに違ひない、アノ洋服の色は、饐えた、腐つた、溝の中の汚水の臭気で那※に変色したのだ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の前の狭い溝には、流れるでもない汚水の上に、薄曇つた泡が数限りなく腐つた泥から湧いてゐて、日に晒された幅広い道路の礫は足を焼く程暖く、蒸された土の温気が目も眩む許り胸を催嘔せた。",
              "citation": {
                "source": "二筋の血",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて、女が一言二言何かつぶやきながら、廊下へ出て行くと、パチンと頬を殴る音が続けざまに聞えていたが、やがてまた外は無気味な、汚水のような寞々とした静かさになった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚水の底のどろどろとこの胃袋の衰弱を笑いも出来ぬ人ばかりおのが思いも肩掛けにはかなき世なりと神に問う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀には汚水がいつぱい溢れてゐた。",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床屋を出て雨傘を低く差しかけ、刈つて貰つた短い髪の毛にさはりながら歩いてゐると、後からぴちやぴちや汚水をはねて、「おばさん！",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふてぶてしさがあつて、時々立ちどまりながら、私の袖につかまり、ゴム長の靴をぬいでは、汚水を道へあけるのであつた。",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い道を歩いたのか、その汚水にまぢつて、葉つぱのやうなものも靴の中から出るので、私は、すこしばかり止まつてその子供のすることを眺めてゐた。",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女が、一言二言つぶやきながら、廊下へ出ると、パチンと頬を打つ音が続けざまに聞えて、無意味な、汚水のような寞々とした静かさが続いて、女の乱して行った空気が、仲々しずまらなかった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人が一銭を水中へ投げると海女は巧に拾うのだ、その時海女は倒立ちとなって汚水から二本の青ざめた足を突き出した、その足の裏は萎びて、うすっぺらで不気味で、青くて、堅くて動物的で、実用で、即ち人間の立つ台の裏という感じなのであった。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服と皮膚との間に一つの汗という汚水の層を持つ事は全く不愉快な事だ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れも彼も悉く汚水の層を馬の如く着用しているのかと思うと私は甚だ気の毒に思えてならない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
