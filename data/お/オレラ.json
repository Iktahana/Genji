      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "we",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "でまあ、このやうに悲愴げに読むところで、まあ俺らしい勉強なんだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、もう十三寝たら浦潮へ出て行けるんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、今日帰るんだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺らは、ただ金を取るために、危いことだって、気にむかないことだって、何だってやっている。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺ら、なんぼなんだって、こんなにひどいとは思わなかったよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺らにゃ、そんなことナニヌネノだ、とよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その一番下は俺らじゃないか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、その俺らの上にゃ、重い石が、三重も四重もにのっかっていら！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつらは俺らが怖いんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺ら、あいつが憎らしいんだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺ら、あの長い軍刀がほしいんだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、田地を買うて呉れたって、いらん。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、キキンで親爺やおふくろがくたばってやしねえか、それが気にかゝってならねえや！",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、なにも、嘘を話してるんじゃねえんだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、若しもの場合に、銃を持って行くから、お前、手ぶらで来て呉れんか。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、トロ押せねえだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺らあ、嚊がまた子供を産んで寝よるし、暇を出されちゃ、困るんじゃがのう。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「嚊の産にゃ銭が要るし、今一文無しで仕事にはぐれたら、俺ら、困るんじゃ。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、俺ら、初めからそんなこた皆目知らんじゃが、なんとかならんかいのう。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらは朝から晩まで、俺らの耳のそば迄来て、世界の平和の為に、お前らの傲慢を削るとかなんとか云ひながら、毎日こそこそ、俺らを擦って耗して行くが、まるっきりうそさ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらは朝から晩まで、俺らの耳のそば迄来て、世界の平和の為に、お前らの傲慢を削るとかなんとか云いながら、毎日こそこそ、俺らを擦って耗して行くが、まるっきりうそさ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おんつぁん俺らこと連れて行つてくれ、なあ」　と甘えかゝつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺らあいつが憎めて／＼仕方がないべ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどあいつに『おんつぁん』と来られると俺らぺつちやんこさ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "額と手とがまるっでめんこくて俺らもう少しで舐めるところだつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度俺ら方が泣けてしまつて、机の板で頭をなぐりつけてやつたら、板が真二つになつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ俺らこと死ぬまで恨むのだべさ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "したら俺の叔父さんが、盲目の叔父さんが小樽から俺らことおんつぁんのとこに捜しに来たつけ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれらをダシに使って記事を書こうとしてやがんだ！",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶望の逃走おれらは絶望の逃走人だおれらは監獄やぶりだあの陰鬱な柵をやぶつていちどに街路へ突進したときそこらは叛逆の血みどろで看守は木つ葉のやうにふるへてゐた。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
