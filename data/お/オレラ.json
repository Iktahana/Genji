[
  {
    "uuid": "04a5a473-11a1-5127-a2ee-0ed4f6f25a1b",
    "entry": "俺ら",
    "reading": {
      "primary": "おれら",
      "alternatives": [
        "おいら",
        "オレら"
      ],
      "is_heteronym": false
    },
    "grammar": {
