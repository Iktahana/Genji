        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どてらのように身体に添っていない着物から「お姉さん」のような首が生えていた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どてらのように身体に添っていない着物から「お姉さん」のような首が生えていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこわして上げるから、お姉さんやお兄さんと一緒におやつに食べておしまいなさい」　と言って金槌を持って来て、パラパラと打ちこわしておしまいになりました。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生は」「丈夫よ」「お姉さまは」「丈夫よ」「塾の凡庸な音楽家の卵たちは」「相変らず口が悪いのね、みんな丈夫」　それより千歳は、病気といって自分を呼び寄せた慶四郎の事情をも一度訊く気になった。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉さまも一緒に来ればよかった？",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さま旅行すきでしたわね」　すると慶四郎は、一寸たちどまってまじまじ千歳の顔を見たが、「仲子嬢の話は、きょうはこれ以上、して貰い度くないな」　と言って、またむっつり慶四郎は歩き出した。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美代子をむしってはいやあよお姉ちゃん」　ここに居るのは一番小ちゃい花子の妹でした。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い、お姉ちゃん。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、滝の家のお姉様、どうぞこちらへ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの高田に汚されぬ先に、いっそこのまま死にたいなあ、お姉様はどう遊ばしたかしら、定めし私と同じ様に。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小母さんも變だ、第一「嬌瞋」を發しようし……そこンところが何となく、いつのまにか、むかうが、姉が、姉が、といふから、年紀は私が上なんだが、姉さんも、うちつけがましいから、そこで、「お姉上。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とその時いふと、お姉上も若かつた。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月ばかり経って、すっかり兄嫁に馴染んだ頃、道子は、「お姉様は、なぜ御婚礼の晩あんなに悲しそうにしていらっしたの？",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉さま、只今、お会いしたかったわ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、お姉さまの手、とっても熱い。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉さまがご自分の命と引きかえに貰って下すったあの卒業免状を、お国の役に立てることが出来るのだわ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉さまもきっと喜んで下さるわ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉さまはなぜこの御本を返さなかったのだろう？",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「けれど、お姉さまが待っていらしったのは、やはりこの人の便りだったのだわ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子はお姉さまに代って、お見送りしましたわよ。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお父さんとお姉さんの眼鏡も探し出して一所に懐に入れて、どこかへ遊びに行きました。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんが買いものから帰って来られますと、これも眼鏡がありません。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに御飯の火を焚き付ける段になると、お姉さんはマッチの箱の蓋がすこし開いているのを気が付かずにマッチを摺ったために、マッチ箱の中のマッチに火がついて一時に燃えて、姉さんは手にやけどをしてしまいました。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんは泣いています。",
              "citation": {
                "source": "三つの眼鏡",
                "author": "無署名（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人のお姉様がお可哀想です。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうお母様に見せていただいた活動のわるい王様でも、綺麗なお姉さまの顔でも、キットどこかにあってよ。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとノリ子さんの代りに、ノリ子さんのお姉さんが、「はーい」と返事なさいました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、と思つてゐるとお姉さんが玄關から出ていらして、「ノリちやんはお熱があるので學校へいけませんのよ。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭にはピジヤマを着たノリ子さんがお姉さんに手をひかれて、そろりそろり歩いてゐました。",
              "citation": {
                "source": "チユーリツプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女に握手をして素直にかの女の隣に坐った娘は、「お姉さま？",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そして、このお姉様も、およそ面倒くさい、うざうざじゃないかねえ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
