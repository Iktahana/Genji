        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "婆さんは酔ぱらいの水兵連が、乱暴に戸を押し開ける途端、腕にかけた籠を落してしまった。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "離室から一寸木戸を押し開けると、私の家の裏口に出られた。",
              "citation": {
                "source": "黒点",
                "author": "――或る青年の「回想記」の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は原っぱの界の木戸を押し開ける。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜太郎は、一挙に扉を押し開けると、部屋の中におどり込んで、机の抽斗に跼み込んでいる男の肩の上へ襲いかかった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……犯人は身をもがく鶴子を左手で押えつけて置きながら、右手で窓掛けをはね上げ、窓の回転部を押し開けると鶴子を差し上げて窓から投げ出し、瞬間後スイッチを押して玄関の間の電燈を消しました。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒイ、フの、ミと強引に押し開けると、輪鍵はカラリと土間に飛んで、格子はどうやら口を開けます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い瞼をやっと押し開けると、四方は急に明るくなって、眼の前に、恐ろしく贅沢な電灯が立って居ります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し開けると手紙というのは半切が一枚。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二服の薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地紅の色つぽい結び文、押し開けると、プーンと掛け香の匂ひ、女文字の散らし書きで『ぜひ／＼お出で下されたく、命にかけて御待申上參らせ候』と、參の字が、小首をかしげて、愁を含んでゐる」「名前は？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置の床を刳いで、暗い段々を下ると、中は石と材木で疊んだ道で、それを二三間行つたところに樫の朽ち果てた扉があつて、押し開けると中は四疊半ほどの黴臭臭い穴倉、一方の隅に寄せて、四つ五つ重ねた箱があります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置の床を剥いで、暗いだんだんを下ると、中は石と材木で畳んだ道で、それを二三間行ったところに樫の朽ち果てた扉があって、押し開けると中は四畳半ほどの黴臭い穴蔵、一方の隅に寄せて、四つ五つ重ねた箱があります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを眺めて、不断の微笑を送って居るのは、仏蘭西の古典らしい油絵の少女で、その隣の扉を押し開けると、次の間は小さく纏まった寝室、所謂ハイカラにした紅閨で、小卓にも、寝台にも、羽根布団にも、若い娘の好みらしい、可愛らしさと、金持の一粒種らしい豪勢さが溢れます。",
              "citation": {
                "source": "笑う悪魔",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑倉の板扉をおしあけると、久しく閉めきったままになっていたので、えもいえぬ臭気がたちこめ、ほとんど目もあけられない。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……葵は紗のカーテンをいっぱいにおしあけると、晴ればれとした声で唄いだしてしまった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口を蹴りつける音がし、はげしく扉をおしあけると、ふらりと鶴がはいってきた。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "無言で扉をおしあけると、眼の前にいささか常軌を逸した光景が展開した。",
              "citation": {
                "source": "黒い手帳",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
