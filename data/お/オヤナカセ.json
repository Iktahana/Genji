        "examples": {
          "standard": [
            {
              "text": "彼は若い頃、かなりの親泣かせだったと聞いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そんなことをしたら、また親泣かせになるよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親泣かせの息子が、ようやく自立してくれたと両親は安堵していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実に仕様のない奴で、親泣かせ、兄弟泣かせ、なんともお話になりません。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "親泣かせというのは全くあの娘たちのことで、どうしてあんな人間になったのか判りませんよ。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "親泣かせ兄弟泣かせもいい加減にしろ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら洋次郎は母親泣かせで、母親の言葉で云えばフハイダラクした人物だったからである。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばあさん、ひどくおめえ悄気てるが、おめえの子も、極道者とみえるな」「あいつこそ、親泣かせの骨頂。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
