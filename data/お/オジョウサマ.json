    "definitions": [
      {
        "index": 1,
        "gloss": "(another's) daughter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「かの子さんはお嬢様育ちだから一平さんが世話をしないと他所へ出られないからいつでもついて行って貰って居る。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "）も少しで余所余所しくお嬢様とでも仰ゃりそうな処でしたね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様、どうぞこちらへお通りあそばしませとでも仰ゃりそうでしたのね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "出來ることならば獨身におなり遊ばすとよいが、左もないと貴方ばかりでない、お嬢様にも、おそろしい災難が落ちて來るかも知れない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は兎もあれ、せめて娘だけでも災難を逃れる工夫はございますまいかと押返して伺ひますと、和尚様は『お氣の毒であるが、母子は一體、あなたが禍を避ける工夫をしない限りは、お嬢様も所詮逃れることはできない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "根ッから早や狐でなければ乗せ得そうにもない奴じゃが、そこはおらが口じゃ、うまく仲人して、二月や三月はお嬢様がご不自由のねえように、翌日はものにしてうんとここへ担ぎ込みます。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様とおっしゃって下さいましたお礼に、叔母さんが世話を焼くのでござんす、お人の悪い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大好物で晩飯の菜になさる、お嬢様を一体何じゃと思わっしゃるの）。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側へやって来て、お嬢様面白いことをしてお目に懸けましょう、無躾でござりますが、私のこの手を握って下さりますと、あの蜂の中へ突込んで、蜂を掴んで見せましょう。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様の生命に拘わっても言われぬと言う固い口ぶりで……ヘイ」「ふうむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに最早、年頃のことじゃけに、早よう何処かへ嫁に遣って一刻も早くお嬢様の足を洗わせねば、わたしゃ心配で心配で夜の目も寝られませぬという、乳母のお島どんの涙ながらの物語……」「う――むむ」　松倉十内は腕を組んで今一度太い、深い溜息を吐いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町人百姓の子に、お嬢様たあ勿体すぎる」　斯う苦り切って云うお爺さんの前では止めたけれども、蔭へ行くと婆やはかやを、かやちゃまだの、お嬢様だのとよく呼んで居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあ、お嬢様あ、磨かなきあなんねえものよ」　婆やは斯う答え乍ら、洗い立てたかやの体を、磨き済ました球の様に大切相に抱いて、もやもやと湯気の立つ風呂桶のなかへ這入った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢様ばかりけい、自分だって、てらてら、するほど洒落るじゃねえかな」　おすめはなお、負けぬ気に云い返すのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間使は詮方なげに、向直って、「お嬢様、お茶を入れて参りましょう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも知らないから、小腰を屈めて、「お嬢様、例の花売の娘が参っております。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お嬢様が急に、御用がおあんなさいますッて。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様の御用とって、お前、医者じゃあなし、駕籠屋じゃあなし、差迫った夜の用はありそうもない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、お嬢様が御用があるッて、僕がわざわざ迎に来たんだが、御免蒙る、ふん、それで可いのか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう前後も弁えず、しばらくも傍には居たたまらなくなって、そのまま、「島野さん、お連様もお見え遊ばしたし、失礼いたしますから、お嬢様にはどうぞ、」も震え声で口の裡、返事は聞きつけないで、引返そうとする。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お嬢様、何ですか、その事でこちらへお越しなんですか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢様、どういたしましょう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様が御褒美をお賭けなすったのを、旦那様がお聞遊ばすと、もっての外だ、間違いに怪我でもさせたらどうする、外の内の者とは違うぞ、早く留めろと有仰るの。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高慢なことをお言いでない、お嬢様がいらっしゃるよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ですからさ、そっちにお嬢様がいらっしゃりゃ、こっちにゃあまた滝公、へん、滝の野郎てえ豪傑がついてまさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様は御心配を遊ばしていらっしゃるんですよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、そういたしましょうねえ、お嬢様。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お皿を洗ったり、おぜんごしらえをしたり、おくさまのおへやのそうじから、おじょうさまたちのお居間のそうじまで、させられました。",
              "citation": {
                "source": "灰だらけ姫",
                "author": "またの名「ガラスの上ぐつ」",
                "note": "青空文庫"
              }
            },
            {
              "text": "」すると、こうなるのかなって、あれやこれや思いうかんできてね、「アリスおじょうさま、ただちにこちらへ、おさんぽのごしたくを！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」すると、こうなるのかなって、あれやこれや思いうかんできてね、「『アリスおじょうさま、ただちにこちらへ、おさんぽのごしたくを！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
