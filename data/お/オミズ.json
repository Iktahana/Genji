        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お墓を作るのはおよしなさい」　と慰めましたが、太郎さんはきかずにお墓を作ってお水を上げて拝んでいました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……小いお娘様もその御縁で、学校のお帰りなんぞに、（小母さんお水を一杯。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお水菓子が好きだと云う、三歳になる男の児の有ることを、前の条にちょっと言ったが、これは特に断って置く必要がある、捨児である。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく、お前、呼吸を殺していられてね、苦しいだろう、湯か、お水でも上げようかい。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）……（お水を取かえて参りましょうか。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、兄さんの部屋へついて行って、「兄さん、お水を持って来てあげようか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金光教に凝って、お水をいただいたりしているうちに、衰弱がはげしくて、寝付いた時はもう助からぬ状態だと町医者は診た。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明王のお水でござる……しっかりなされ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者では不可ん、加持祈祷と、父親の方から我を折ってお札、お水、護摩となると、元々そういう容体ですから、少しずつ治まって、痙攣も一日に二三度、それも大抵時刻が極って、途中不意に卒倒するような憂慮なし、二人で散歩などが出来るようになったそうです。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆のことで、両親の小屋へ持って行って、ものをいう前にまず、お水を一口という息切のする女が、とても不可ません、済ないこッてすがせめてお一人だけならばと、張も意気地もなく母親の帯につかまって、別際に忍泣に泣いたのを、寝ていると思った父親が聞き取って、女が帰って明くる日も待たず自殺した。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その饂飩屋へ入った時は、さすがにお悦が「お水を、お水を。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お水でも無いらしかった。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「毎朝毎晩、お水をあげるのもわたくし、お花を進ぜますのもわたくし。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥様の御実家の、御墓所の位置は、以前にもおいでになったことがございまして、旦那様はよく御存知でございますので、早速お花を持ってそちらへお出掛けになるし、私は、井戸へお水を汲みに参ったのでございます。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがお水を汲みまして、私が、一足遅れて御墓所のほうへ参ろうといたしますと、たったいまそちらへお出掛けになったばかりの旦那様が、こう、青いお顔をして、あたふたと逃げるように引き返しておいでになり、「急に気持が悪くなったから、これで帰ろう。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽喉がひりひりする」「それだけか」「おお水戸。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご洗足のお水、取りましょうで」「何さ、裏に清水がある」「へい」とトチッてまたお辞儀。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお水わが上を溢れ過ぐ。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁酒のお水５・27（夕）　一心寺に元和の往時、天王寺で討死した本多｜忠朝と家来九人を葬つた墳のある事は、誰もがよく知つてゐる筈だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気はそのエーテルより重きことはなお水の土よりも軽きがごとし、神はこれを雷電の座と定めければ、このときより多くの人の心はそのために安からず恐れ悩めり。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "『御医者様が入来ッしゃるとお水を下さる』そんなこと言って欺しましたら、漸くそれで温順しく成ったところなんですよ……」　お菊は大きな眼を開いて医学士の方を見たが、やがて泣出しそうに成った。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「菊ちゃん、御医者様に診て頂くんですよ……ね、お水を頂くんでしょう……そうすると直に癒りますよ」　と母に言われて、お菊は漸く学士の方へ小さな手を出した。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎爺の加持のお水を頂いて飲んでいるところだの、蝋燭のあがった多くの大師の像のある処の前に彳んでみたりした。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前、お水を頂いて来たかい」「ええ、どっさり頂いて来ました」　お島はそうした嘘を吐くことに何の悲しみも感じなかった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御殿の閨を覗かれ、あまつさえ、帳の奥のその奥の産屋を――おみずからではあるまいが――お煩い……との事である。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は宮中に育ちまして、世間知らずに御前で教養されたものでございますから、陛下おみずから師になってくだすったのですが、やはり刻苦精励を体験いたしませんでしたから、詩を作りますことにも素養の不足を感じたり、音楽をいたしますにも音足らずな気持ちを痛感したりいたしました。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "女人答えていわく、わが家大小ともなおみずから知らず、いわんや汝よく知らんや、と。",
              "citation": {
                "source": "易の占いして金取り出だしたること",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもいっしょにお見せ申したら、罪ないお父御の閉門も解かれましょうし、お殿さまおみずから残った悪人ばらをご成敗あそばすでしょうから、お家もこれでめでたしとなりましょうよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "恩顧の隠密古橋専介のむくろに並べて、善光寺辰こと辰九郎のなきがらをもいっしょに、お屋敷内の藩士たまりべやに安置しながら、香煙｜縷々としてたなびく間に、いまし、おみずからご焼香あそばさっていられるところでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "すめらみことは戦に、おおみずからは出でまさね。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
