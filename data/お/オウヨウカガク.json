[
  {
    "uuid": "a6bf6d1b-515c-5b45-a4d4-e39a42e00847",
    "entry": "応用科学",
    "reading": {
      "primary": "おうようかがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
