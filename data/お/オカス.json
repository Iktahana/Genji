        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to invade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "恍惚としていた時に雨を侵す傘の音と軽い庭下駄の音が入口に止んで白い浴衣の姿が見えた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　聞けば、聞けば聞くほど、おのれは、ここだくの邪淫を侵す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "塵心　消尽して　些子も無し、受けず　人間の物色の侵すを。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の容貌は、過般深川の橋の上で、女中に取巻かれて火を避けたのを愛吉が見たそれのごとく、ほとんど侵すべからざる、威厳のあるものであった。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権保護期間の延長は、憲法が「侵すことのできない永久の権利として、現在及び将来の国民に」与えると約束している、基本的人権を制約しかねない。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後多年経て隣国また来り侵す。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動向を満足する為めに人類は道徳的努力を伴う苦痛を侵すことを意としない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地の胸に横たえられた葉子の顔は、綿入れと襦袢とを通して倉地の胸を暖かく侵すほど熱していた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、誰も欧州列強の間の協約の効力を十分に信じて、ベルギーの中立が絶対に安全であることを信じていたが、兵営の士官たちの間には、独軍がベルギーの中立を侵すという説を唱うる者があった。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が何故法王ウルバン二世を大外交家であるというかというに、当時の封建武士がこの時代に流行した騎士道に心酔し、兎もすると法権を侵す態の行動をし英気を他に洩らす術なき脾肉の嘆をかこっていたのを認め、この十字軍の挙によってその英気を宗教戦に洩らさせ、キリスト教興隆に役立てようとしたその点からである。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと反對に、少しでも自分を侵すやうな、氣に食はんことが有ると、急に氣が滅入つて下らない欝霽らしでもやつてみたくなるんだね。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティアマートはこの神々の群衆が次第に自分の領域を我がもの顔に侵すのを見て、己が主権を擁護するために、人首牛身、犬身魚尾などという怪物どもの軍勢を作り集めた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三節　満州国の責務　ソ連が東亜連盟を侵す径路は三つある。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "姦淫する勿れ、処女を侵す勿れ、嫂を盗む勿れ、その他一切の不徳はエホバの神の誡むるところである。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもこのお爺さんは、温厚らしいうちにも、どこか知らに侵すことのできない威厳をもっていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚を侵す病は最早彼女の掌全体に渡っていて、神経の鋭くなった指のあたりからはどうかすると血が流れるとのことであった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぐの年、春暖漸く催うして鳥の声いとうらゝかに聞えしある日病の窓を開きて端近くにじり出で読書に労れたる目を遊ばすに、いき／＼たる草木の生気は手のひら程の中にも動きて、まだ薄寒き風のひや／＼と病衣の隙を侵すもいと心地よく覚ゆ。",
              "citation": {
                "source": "小園の記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に當りて、客觀想なる詩の美は、かの客觀實なる字形若くは聲波に即きて、吟者讀者を侵すなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小儒養老處　　小儒老を養ふ処、明月獨侵廬　　明月ひとり廬を侵す。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし男女の性別に由って歴史的に定まった分業の領域が永久に封鎖されているものなら、男子が裁縫師となり、料理人となり、洗濯業者となり、紡績工となることは、女子の領域を侵すものとして、「男子の中性化」が論じられなければならないはずです。",
              "citation": {
                "source": "「女らしさ」とは何か",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらんなされませ、あのように申しておきましたので女大使めは、わが国が太青洋を侵す意志がないとの秘密電話を、大統領にかけましたようでございます。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は侵すべからず近寄るべからざるもの、あらゆる現實的存在、世間的又は世俗的と呼ばれる存在、より全く隔離したるもの、自己を主張しつつそれへと近寄り侵し來りそれをわが内に取入れようとする人間的主體に對しては、本來の極みなき尊嚴と威力とを發揮して惜氣もなくこれを壞滅の中に葬り去るものである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことはそれの媒介者に侵すべからざる權威を與へる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "人倫的共同の種々の特殊の具體的形態の背後にあつてそれを制約し規定し促進し支持する、しかして多くの場合むしろ事實的勢力として主體を支配する諸の法則や秩序も、かくの如き建設的意義を有する限り、神聖なる愛の光を浴びて、一方侵すべからざる權威を發揮するとともに、他方恩として惠みとして仰がれるであらう。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは仏の領土を侵すおそろしい間違いだ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに翌四月八日に平ノ左衛門尉に対面した際、日蓮はみたび、他国の来り侵すべきことを警告した。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで憲法は、この自由は、けっして侵すことのできないものであることをきめているのです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたらしい憲法は、この基本的人権を、侵すことのできない永久に與えられた権利として記しているのです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来、南太平洋の戦局いよいよ切迫、敵の機動艦隊は遂に深くわが内南洋を侵す形勢となり、刻々、全国民の耳朶を打つ重大発表を待たなければならなかつた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足をぶるぶる震わせながら、私は壁の方へ手さぐりで戻った、――私の想像力がいまこの牢獄のいろいろな位置にたくさん描き出した落穴の恐怖をおかすよりも、むしろその壁のところで死のうと心を決めながら。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
