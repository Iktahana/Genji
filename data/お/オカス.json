[
  {
    "uuid": "f6bdb4b9-7048-5f99-8ad6-27c568bedb7c",
    "entry": "侵す",
    "reading": {
      "primary": "おかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
