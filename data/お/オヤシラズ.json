        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は親知らずの身だが、育ての親に深く感謝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その孤児は、親知らずのまま成長し、強く生きてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親知らずとして育った彼は、いつか実の親に会いたいと願っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
