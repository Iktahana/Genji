        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何にも聞こえはしませんよ、……お休み、それあおまへの妄想ですよ！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りて出るは例の池の岸なり、木の切株の平らなるに御座を拂ひて此處にお休みなされよと言へば、嬉しきことよの今朝は弟の介抱をうくるやうなり、其方も此處へ休まばよきにと半分を讓らるれば、何として勿躰なきことゝ直次は別なる枯草の中へうづくまりぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句はとうとうお休みである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句をお休みにしてその代りにレビューを見物しながら、この二つの芸術の比較といったようなことを考えてみた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明ける迄あっしの処でお休みなすっちゃ如何で御座います」　「……そうだな。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ此處で暫くお休み下さい。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうお休みなさるがよい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあいかがです、そろそろお休みなさいませ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴僧ももうお休みなさいますか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "我儘ばかり、お寝って在らっしゃったのを、こんな処まで連れて来て置いて、坐ってお休みなさることさえ出来ないんだよ。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはお休みの間に、何が一番楽しかったのですか。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなさん、長い夏のお休みはおもしろかったですね。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこのお休みの間にみなさんのお友だちが一人ふえました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では二年生のひとはお休みの前にならった引き算をもう一ぺん習ってみましょう。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝大へん早く起きたものがありますから、太郎さんは飛び起きますと、お母さんが坐って、「太郎さん、今日は雨がふって運動会がお休みになったのだよ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりお休みなさい」　と言われました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会がお休みの時の用心に鞄をちゃんと持って行ったんだ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動会がなければ学校はお休みですよ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで昨日の日記がお休み。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩のことに私が床を延べていますと、お俊が飛んで参りまして、『どうせ私じゃお気に入りませんよ』と言いざま布団を引ったくって自分でどんどん敷き『サア、旦那様お休みなさい、オー世話の焼ける亭主だ』と言いながら色気のある眼元でじっと私を見上げましたことなどは、ただの仕草ではなかったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老僧　――どれ、お休み。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――お休みなさいまし。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞ御都合がおありなさりまして、私どもにお休み遊ばします。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お掛けなさいまし、お休みなさいましと、間近な氷店で金切声。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お休みなさいまし、お懸けなさいまし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらの姫様ですか存じませんが、どうぞあちらへいらっしゃいましたら、私どもへお休み遊ばして下さいまし、後生でございます。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十八「女中さん、降って来そうでございます、姫様におっしゃって、まあ、お休みなさいましな」と米は程合を見計らう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「乙姫がひとりおやすみになるのに、大きい御殿なんか要らないぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ帰っておやすみ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやすみなさい、お母さん」　撃柝の音は坂や邸の多い堯の家のあたりを、微妙に変わってゆく反響の工合で、それが通ってゆく先ざきを髣髴させた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
