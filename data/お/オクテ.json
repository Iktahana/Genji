    "definitions": [
      {
        "index": 1,
        "gloss": "late-growing rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たしかにその小屋の奥手から岩を切ってこさへた室があって大ていの仕事はそこでやってゐるらしく思はれた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来からは何の仕切もない広前が少しばかりあつて其正面の奥手に御堂がある。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ならば神※鬼斧の奥手を尽したる也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥手はこれからだのう。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "役員の過半が、奥手へ土地をもっている連中なのが、やはり暗黙に邪魔しているとも思える。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その未明おのづと草吉が目を覚して暫くの時がすぎたとき、ほのかな一ときれの白が空の奥手に浮かびでたやうな気配がした。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、見えない奥手の気配に向つて鋭く叫んだ。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで絶望の苦痛をみせた小さなどす黒い海、暗い沖にも高いうねりがつづいてゐるし、白い牙がそんな奥手の暗い沖にもちらめくのだつた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――思ひ出の、遠い幽かな、物に怯えた夜更けのことや、炉辺夜話、夜鴉や梟の啼く悲しげな闇夜のことや、さては又古い数々の夢の奥には、少年の歎きに沁みた嵐の叫びが顳※の深い奥手にきこえはしないか？",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ一つの竹藪の深い奥手の方であるが、二人の位置はかなり離れてゐるものと見える。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、この露路の入口に立ち止つて奥手の方を眺めると、結局高さの目立つものは何一つとして見当らず皆一様にブス／＼と光を燻し返してゐる低い屋根ばかりで、殊のほか空が大きくマンまるく覗かれた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奥手には、これも一種の屑のやうに、凡そ物憂げに蠢いてゐる女房達が隠見してゐた。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その路は、それは次第に邸宅の並んだ睡つたやうな街になつて、門燈の奥手の方に黒く大きく建物が輪廓だけの塊りとなつて見えたのである。",
              "citation": {
                "source": "群集の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い奥手まで我慢して歩いた。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひつそり静まつた寺院の奥手を眺めてゐると、絶望に近い悲惨な心を感じてきた。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鮫島は闇の奥手へ振向いて、深く息を吸ひ入れた。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイ、そっちの部屋も、そうか」　三村刑事は廊下の奥手に張り番している巡査の方に怒鳴ったが、自分で立ち上って、とんで行った。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇居内と云つても大手門をくゞつて、とッつきに在るのが済寧館で、誰でも行けるパレスコートがもッと奥手にあるやうである。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏像は物置の奥手に、埃のいつぱい積つた長持に、凭れるやうにして立つてゐました。",
              "citation": {
                "source": "南風譜",
                "author": "――牧野信一へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥手の方に姿の見えない客がゐて、これも姿の半分見えないひとりの女とまつたく言葉を無視しきつて相抱擁してゐるらしい。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて最も奥手の方に、ひとりの小坊主が立ち上つた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "田にある稲穂も奥手の分はおおかた実らない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来の繁栄は奥手の発展にかかっている。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "下座の奥手に、何かポーズしているらしい女の素足がてらされている。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし下座の奥手には誰の姿もなかった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び下座の奥手をてらす者がある。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隧道はまわりどおくて、往来が不便だ、自分で門を啓けるがいいじゃないか」　右の目の中からそれに答えた。",
              "citation": {
                "source": "瞳人語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うと、われわれの平生は、ただ方便を主とすることばかりおおくて、かえってこの花前に気恥ずかしいような感じもする。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "院の陛下はおそれおおくて数に引きたてまつるべきでない。",
              "citation": {
                "source": "源氏物語",
                "author": "匂宮",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくには気持がよほどおくてだったのだろう、夫婦とはどういうものか、よく知らないままで富三郎の妻になった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
