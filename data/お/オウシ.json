[
  {
    "uuid": "b9bd5428-6379-59a0-86d7-43300ad2a5f1",
    "entry": "奥旨",
    "reading": {
      "primary": "おうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
