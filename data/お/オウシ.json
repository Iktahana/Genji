  {
    "uuid": "7c6818eb-3c29-51fd-9e96-6df280dea01a",
    "entry": "牡牛",
    "reading": {
      "primary": "おうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bull",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "またその※のうつくしさふと物音におどろきて午睡の夢をさまされし牡牛のごとも、あどけなくかろやかにまたしとやかにもたげられ、さてうち俯しぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、去勢された牡牛のように、鞭を恐れた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡牛の死ぬる前後のところも単なる実写的の真実に対する興味のほかに、映画としての取り扱い方のうまさは充分にある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い髪の毛のまわりに銅のボタンをつけて、あい色のスカートをはいた女たちが、重い荷をつんだ牡牛を追っています。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "どどォと牡牛のやうな波が、この岩にぶつかつて、真白になつてとびちるとき、その辺にうろうろしてゐるなら、岩の面に叩きつけられて、すぐ死んでしまふだらう。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方の山地に住む三十人の剽盗の話や、森の夜の怪物の話や、草原の若い牡牛の話などを。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも鷹や牡牛の話では聴衆が満足しなくなって来たからである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、自分が神前に捧げた犠牲の牡牛の、もの悲しい眼が、浮かんで来た。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時迄も鷹や牡牛の話では聽衆が満足しなくなつて來たからである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か書類をいっぱいに拡げて、それは精密に書いたり調べたりしている格好を見ていると、まるで白い牡牛のような活気と精力とが充ち満ちていそうであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん牡牛を家へ連れて帰るようにとでもいいつけたことと思われた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "逞ましく牡牛のような巨獣の王が、また　首を高くもたげて仰いだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "膃肭獣の成牡（ブル）、年齢八、九歳、体重八十貫、牡牛のごとき黒褐色の巨躯、　ハーレムの王である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその時、牡牛のごとく猩々熊のごとき巨大なブル、　たちまちにして天を仰いで咆哮すると見るや、※然とばかり飛び入った、たたた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と思ふ間に、からだがすつかり牡牛になつてしまひました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その若ものをやとつてゐる百姓は、翌る朝おきて牛小屋へいつて見ますと、寝てゐた間に、見つけない大きな黒い牡牛が一ぴきふえてゐたので、ふしぎに思ひました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおぢいさんのくびには、これまで、例のふしぎな黒い牡牛のくびにつけてあつた綱がまきついてゐました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴメズは屠牛所の血の匂いを嗅ぎつけた牡牛のように咆え続けた。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、一匹の牡牛であつた。",
              "citation": {
                "source": "夜に就て",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分より更に活溌な連れの男の胴衣にすがりついて、声楽ではその仲間の奮闘的の努力にも遙かにまさって、力のある肺の底から低音で牡牛の吼えるような声を出しながら。",
              "citation": {
                "source": "ペスト王",
                "author": "寓意を含める物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡牛のうめき声、子牛の鳴き声等あい混じてにぎやかである。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も手こずったのは大きな牡牛であった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで荒れそうにしていた大きい牡牛も、土手を倒したようにころがってしまった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡牛蛇も米国産で、善く牡牛のごとく鳴くと虚伝さる。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋肉で盛り上がった肩の上に、正しくはめ込まれた、牡牛のように太い首に、やや長めな赤銅色の君の顔は、健康そのもののようにしっかりと乗っていた。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日ごろの柔和に似ず、傷ついた牡牛のように元どおりの生活を回復しようとひしめく良人や、中にはいっていろいろ言いなそうとした親類たちの言葉を、きっぱりとしりぞけてしまって、良人を釘店のだだっ広い住宅にたった一人残したまま、葉子ともに三人の娘を連れて、親佐は仙台に立ちのいてしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いらっしゃいな」　そういって少女が少女を誘うように牡牛のように大きな倉地を誘った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道の牧場では、よく牡牛と羆とが格闘するそうです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "煤の面も洗おうし、土地の模様も聞こうし……で、駅前の旅館へ便った。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといっしょに、一人の神さまは、女神のおうしろへまわって、「どうぞ、もうこれからうちへはおはいりくださいませんように」と申しあげて、そこへしめなわを張りわたしてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
