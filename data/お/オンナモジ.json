    "definitions": [
      {
        "index": 1,
        "gloss": "woman's handwriting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女文字で御心配御無用に御座候。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "折釘のやうな男文字のなかに絲屑のやうな女文字もまじつてゐる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七はその結び文をあけて見ると、女文字で「十五や御ようじん」と書いてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには女文字の文がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、これは女文字で書かれた手紙だ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは貴女の御父上、英臣さんが、御出征中、貴女の母様が御宅の馬丁貞造と……」　早瀬はちょっと言を切って……夫人がその時、わななきつつ持つ手を落して、膝の上に飜然と一葉、半紙に書いた女文字。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の方へうしろ向けに、大な賽銭箱のこなた、薬研のような破目の入った丸柱を視めた時、一枚｜懐紙の切端に、すらすらとした女文字。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯の花の影が、ちらちらと砂子を散らして、絵も模様も目には留まらぬさきに――せい……せい、と書いた女文字。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「商談、お待ち合わせにお利用下さい」　という女文字の貼紙の下で、あたかも誰かを待ち合わせているかの如き顔をしているのだが、むろん誰を待ち合わせているのでもない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん状袋は濡れていたが女文字で○之助様、ふでよりというだけは明らかに読まれた。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが皆、長崎から来た女文字の手紙ばかりで、金釘流の年増らしいのは母親の筆跡であろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罫のあるレターペーパーに万年筆で書いた女文字の手紙であつた。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに添へたる紙片に二三行の女文字あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宛名は、大臣に宛てたもので、細かく女文字で書いてあるし、あのほうの表書は、さる王族に宛てたもので、とても太い、しっかりした字で書いてある。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "折れ釘のような男文字のなかに糸屑のような女文字もまじっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "暢達な女文字が、半ば血迷っている信一郎の眼にも美しく映った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "みせい」　手に取りあげて見調べていましたが、脇差はとにかくとして、不審を打たれたものは手紙の裏に小さく書かれてあった、菊――と言う女文字です。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "見取りの図面はめっぽうまずいが、ところどころへ書き込んである字は、このとおりめっぽううまいお家流の女文字だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "それへもっていって、お寺さんのお線香がしみついているうえ、あの手紙が紛れない女文字だったから、お妙さまの尼美人ぶりにお目にかかれるだろうと眼がついたんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、紙片には次のようなうるわしい女文字の水茎のあとが、はっきりと書かれてありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その紙片には、じつにいぶかしいことにも、あきらかな女文字で、次のごとき文言が書かれてあったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙の中には、女文字の男の手紙がいくらもある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が女文字の女名前、女が男文字の男名前なぞいうのは古手で、この頃は邦文タイプライターを利用するのもある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罫のあるレターペーパーに、万年筆で書いた女文字の手紙であった。",
              "citation": {
                "source": "水郷異聞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週に二度も訪れるのだから手紙などは用もなさゝうなのに、村瀬が朝目醒めると扉のポスト口から女文字の封筒が滾れ落ちてゐるのであつた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三囲の堤下を歩いていると、一軒の農家の前に十七、八の若い娘が白い手拭をかぶって、今書いたばかりの「久松るす」という女文字の紙札を軒に貼っているのを見た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
