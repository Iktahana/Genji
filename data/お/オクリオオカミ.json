[
  {
    "uuid": "d87bdef4-20dd-59e7-b715-863b762f91ef",
    "entry": "送り狼",
    "reading": {
      "primary": "おくりおおかみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
