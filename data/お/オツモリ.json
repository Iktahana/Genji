    "definitions": [
      {
        "index": 1,
        "gloss": "last drink (of sake)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
