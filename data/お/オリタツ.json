    "definitions": [
      {
        "index": 1,
        "gloss": "to go down and stand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "駅に降り立つと、くろぐろとした山の肌が突然眼の前に迫った。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い駅に降り立つと、駅員が、「信濃追分！",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくない乗客はたいてい一つ手前の駅で降りてしまうので、その寂しい小駅に降り立つ人影は跫音もせぬくらいまばらである。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間の後、新吉が清荒神の駅に降り立つと、さっきの女はやはりきょとんとした眼をして、化石したように動かずさっきと同じ場所に坐っていた。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（かつらは誇りがに見かへりて、庭に降り立つ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "弥太郎がまだ火蓋を切らないのは、鳥がどこへか降り立つと見ているからであった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は晴れた朝夕は、そろつてシヤツ一枚になつて浜辺へ降り立つては諸種の運動に吾を忘れて身神の鍛練に余念ありませんでしたところ、或頃から満里子君は、赤と白の旗を持つて言葉を描く信号体操といふものをはぢめました。",
              "citation": {
                "source": "満里子のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心ぶかい彼は寝る前にかならず庭先を一応見まわるのを例としているので、今夜も縁先の雨戸をそっとあけて、庭下駄を突っかけて、大きい銀杏の下に降り立つと、星の光りすらも見えない暗い夜で、早寝の町はもう寝静まっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "手槍を取って庭に降り立つとき、数馬は草鞋の緒を男結びにして、余った緒を小刀で切って捨てた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日目かに君達の庭に降り立つだらう。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も裸形の、あの美しい百合子の五体が、爪先から順々と降つて僕の顔を撫でゝ行くやうなものだから、――そして彼女は、庭に降り立つと、母屋の方へ向つて会心のウヰンクを投げたかと思ふと（ペロリと赤い舌を出すこともあつた。",
              "citation": {
                "source": "女優",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨は庭下駄をはきて降り立つ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（かつらは誇りがに見かえりて、庭に降り立つ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小雪は一種の好奇心にうながされて、これも足音をぬすんでそのあとからそっと庭に降り立つと、玉藻に似た姿は植え込みの間をくぐって行って、奥庭の大きい池の汀にすっくと立った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "折りからそよそよと吹いて来る秋風に袴の緋を軽くなびかせて、彼女は牛車からしなやかに降り立つと、門前にたたずんでいた一人の侍がつかつかと歩み寄って来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいたましい姿を和吉はしばらく無言でじっと眺めていたが、やがて庭に降り立つ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛鳥が恋人のすがたを見つけて庭に降り立つと、これには新駒屋とよぶ声がしきりに浴せかけられたが、かれの姫はめずらしくない。",
              "citation": {
                "source": "島原の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊柩の直ぐ後の馬車から、降り立つたのは、今日の葬式の喪主であるらしい青年であつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、続いてどの馬車からも、一門の夫人達であらう、白無垢を着た貴婦人が、一人二人宛降り立つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者の注視を引いた事などには、何の恐れ気もないやうに、翼を拡げた白孔雀のやうな、け高さと上品さとで、その踏段から地上へと、スツクと降り立つたのは、まだうら若い一個の女性だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子が、夫に扶けられて、自動車から宏壮な車寄に、降り立つた時、遉にその覚悟した胸が、烈しくときめくのを感じた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　美奈子等の自動車の着くのを、先刻から待ち受けてゐたかのやうに、駅の群集の間から、五六人の青年紳士が、自動車から降り立つたばかりの、瑠璃子夫人の周囲を取り囲むのであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "国府津のプラットフォームに降り立つた時、瑠璃子は駆け寄つた赤帽の一人に、命令した。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "美奈子が、廊下から、そつとその庭へ降り立つたとき、西洋人の夫妻が、腕を組合ひながら、芝生の小路を、逍遥してゐる外は、人影は更に見えなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時たゝぬ中に、婢女ばかりでなく、自身たちも、田におりたつたと見えて、泥だらけになつて、若人たち十數人は、戻つて來た。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時たゝぬ中に、婢女ばかりでなく、自身たちも、田におりたつたと見えて、泥だらけになつて、若人たち十數人は戻つて來た。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時立たない中に、婢女ばかりでなく、自身たちも田におりたつたと見えて泥だらけになつて、若人たち十数人は戻つて来た。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時たゝぬ中に、婢女ばかりでなく、自身たちも、田におりたつたと見えて、泥だらけになつて、若人たち十数人は戻つて来た。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にドッとあおりたつ煙につつまれた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェマイマは　こころもち　もたもたと　おりたつと、　そのあとは　うむのに　ちょうどいい　からっとしたところを　さがして　あたりを　よちよち。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            }
          ]
        }
