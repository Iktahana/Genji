    "definitions": [
      {
        "index": 1,
        "gloss": "crest (of a waterfall)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "天子山脈の上に、湖水をたたえたような雲は、山の落ち口に添うてはい下る。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょせん手の着けようもねえので、おれも途方に暮れてしまったが、それでも川下の方へ流されて行くうちには、どこかの岸へ泳ぎ付くことがあるかも知れねえと、暗い堤下を探るようにして、どんどんの堰の落ち口まで行ってみたが、真っ暗な中で水の音がどんどときこえるばかりで、為さんの上がって来る様子はねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川の落ち口はまだだろうか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の川の落ち口よりお前らの落ち口を見ろ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ遁れぬ滝の落ち口なら、われも人も手を取り合って落ちて行こうよ」と。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野はその晩｜渓の落ち口で持宿をした。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ川の落ち口で流れの早いところですから、あるいは海の方へ押しやられてしまったかも知れないというので、伊助も途方に暮れてしまいましたが、今更どうすることも出来ません。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場から馬車は、ロォヌ河の落ち口を、ルゥソォの小島を、レェマンの湖岸を、オテルデザルプへ導いて行つた。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてちょうど、カプールを発った五十日目あたりに、温霧谷の速流氷河の落ち口にでたのだ。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその時刻に、湖畔の暗い道を十二三町、湖水の落ち口、湯瀧の上に新道でかけられた巖丈な荒削りの橋の上に立つた。",
              "citation": {
                "source": "湖畔手記",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この芹が恒吉の自慢で、池の水の落ち口あたりに自生してるのでした。",
              "citation": {
                "source": "崖下の池",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローンの水の落ち口である。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だかしんみりして、月夜ではないかと橋まで出たが、雪明りのどことなくうっすらして、ローンの落ち口の水底は、昼よりかえって白く光っている。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "メル・ドゥ・グラスの落ち口も、今日は朝靄の上にはっきりと、クレヴァースのぎざぎざに降り置く雪の、上なるは白く、氷は水色に輝いている。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローンの落ち口の碧い水に、ポプラの茂った小さな中の島がある、所在なさに橋を渡って、そこにあるルーソーの像などを見た、島は名によってイル・ルーソー Ile Rousseau と呼ばれる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のすぐ裏はアーレの流れで、ブリエンツの湖の落ち口になる、私と外に三、四人の御客は、深い朝霧の間につながれてあった汽船に乗り込んだ。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビュフェーで昼飯をすませて、バーンノーフ・シュトラーセをまっすぐに南にぬけると、ツューリッヒゼーの水際で、アルペン・クェイ Alpen-Quai の左は、リムマート Limmat の水の落ち口に、クエイ・ブリュッケと云うのがある。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水の西北のはずれ、リムマートの水の、落ち口に建てられたツューリッヒの街に着いたのが二時少し前で、通りに出ると、驚いた、何の御祭りだか知らないが、人波に埋められた大通りは、国旗や花で飾られて、あっちでもこっちでもブーブー楽隊がはやし立ててるんで面喰らった。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の瀑はその落ち口にあるらしいが、ここからは裾が白く見えるばかり、トリッセルコッフ Trissel Kopf, 3078m. が眼の前に屹えて、村から日がえりに登れそうに思われる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニーセンの西は、シンメンタールの落ち口から、山は一文字に屏風を建てつらねて、シュトックホルンの尖峰が、雪は消え失せた鋭い輪廓を、蒼空に刻んでいる。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一時頃赤石沢の落ち口の下で（通称「ノド」という狭いところ、小屋から十町ばかり上）第五回目かのキック・ターンをしようとしている時（渡辺氏はすでにターンをおわり右に向っていた）リーダーの近藤氏が風のような音を聞いた。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一時ごろ赤石沢の落ち口の下で（通称「ノド」という狭いところ、小屋から十町ばかり上）第五回目かのキック・ターンをしようとしている時（渡辺氏はすでにターンを終わり右に向かっていた）リーダアの近藤氏が風のような音を聞いた。",
              "citation": {
                "source": "針の木のいけにえ",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れが西沢に相違あるまいと断定して、不安と期待とに騒ぐ胸を押し鎮めながら、落ち口の大きな岩を蹈み越えて、其方へと足を向けた。",
              "citation": {
                "source": "釜沢行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し爪先が仰いで山の鼻づらを川なりに辿ると、坂様谷の落ち口に来た、草や灌木の生えている稍や平な砂地で、伊折へ踰えられるという路の跡が草間に取り残されて却て淋しい。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち口の大きな岩の上に腰を下して、後れた人達を待ち合した、一むらの虎杖が背後からてんでに翠蓋を翳して、涼しい蔭を作って呉れる。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満谿を傾け尽して狭い落ち口から一度に切って放たれた水が、ドット迸り出でさま虚空を跳って末広がりに滾々と落ちて来る。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪田を横切って南に行くと、五、六の巨岩が重り合って水の落ち口を示している、渦を巻いて雪の下に走り入った池の水は、滾々として湧き上る噴泉の如くに一度に迸り出て、※々と其処を流れている。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸から落ち込む沢は、皆落ち口に滝を懸けている、高いものは四、五丈もあろう。",
              "citation": {
                "source": "秩父の渓谷美",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝の落ち口のお亭の前を通つたときに、この春芥川君が来て泊つたお亭を覗いてみたが、秋深く松葉が散らばり二三本の篠竹の青い色を見られる格子戸に、人のけはひすらしなかつた。",
              "citation": {
                "source": "名園の落水",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
