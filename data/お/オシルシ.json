[
  {
    "uuid": "b682814f-3baf-5302-b6ca-b50a55c7a63a",
    "entry": "お印",
    "reading": {
      "primary": "おしるし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
