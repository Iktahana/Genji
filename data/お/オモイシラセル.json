[
  {
    "uuid": "70509c26-427a-5867-a545-c57a13727e7b",
    "entry": "思い知らせる",
    "reading": {
      "primary": "おもいしらせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
