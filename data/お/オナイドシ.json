        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「中津は、俺と同い年だから、もう五十三になるんだぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳は、松吉と同い年の、小学校五年生でした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳は、松吉と同い年の、国民初等科五年生でした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢや、わしと同い年ぢやね。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同い年ときくと、人は急に相手と自分の身の上を、較べて見るものである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わしと同い年のこの牛飼は、望んでをつた田と牛を買ひ、望んでをつた子供を一人前に育てた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは三人同い年だった。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "祥子と同い年でも、ずっと小柄な、いたいけな幼子が、白く濃く白粉を塗り、青く光るほど紅を塗って、人形のようなおかっぱで、重たい衣裳をつけて、踊る舞台は、佐四郎人形を見るようであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは私はまだ二人が同い年であるというたいへんな事実を発見していなかった。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあ老少不定で寿命ずくなら仕方もねえわけだが、その死んだのが丁度十七の年で、先のお安という娘と同い年だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしが店の前の縁台に腰をかけて涼んでいると、白地の浴衣を着た……丁度あたしと同い年くらいの娘が家の前に立って、なんだか仔細ありそうに家の中をいつまでも覗いているんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に惣領娘のお清があたかもお安と同い年で死んだので、彼はいよいよそれを気に病んで、おりおりには菩提寺の住職に向って懺悔話をすることもあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉田屋には二人の娘があって、姉のお紋は今年十八で、妹のお力はお直と同い年の十三である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだも大きくって、なあちゃんと同い年ですけれど二つぐらいも年上にみえます」「そうか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえなどは同い年でまだまったくの子供じゃないか」　とほめた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は二十二だといいますから、甚吉や伊兵衛と同い年で、容貌はまんざらでもない女でした。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹とお花はその茶屋の門をくぐって奥の小座敷へ通されると、林之助と丁度同い年ぐらいの町人ふうの若い男が、女中を相手に杯をとっていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちも同い年で、宿帳には二十二歳としるしてありました。",
              "citation": {
                "source": "山椒魚",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "同い年の私の児供は魔子を不便がったと見えて、大切にしていた姉様や千代紙を残らず魔子に与ってしまった。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、今井健次郎という今年十二になる男の児が三河屋綱吉という同い年の児の強飯のなかへ自分の箸を突っ込んだ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三津子さんはわたくしと同い年の廿一で、年よりも若くみえる質の人でしたが、一年あまり逢わないうちにめっきりと老けたようで、眼の美しい下膨れの顔が少し痩せたようにも見えました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は富子と同い年の廿四で、眼の細いのと髪の毛のすこし縮れているのとを瑕にして、色白の品の好い立派な女振りであった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その利助に藤次郎は幾つだね」「どっちも同い年で十六でございます」「どっちがおとなしいね」「藤次郎の方が素直でおとなしゅうございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここへ来かかった二人の娘は、その賄組の瓜生長八の娘お北と、黒沼伝兵衛の娘お勝で、いずれも明けて十八の同い年である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いおかみさんの里は、岩井町の田原という材木屋でございます」「お乳母さんは」「お福と申しまして、若いおかみさんと同い年でございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "平七はお国と同い年の二十三歳で、まだ独り者である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "同い年で小学校を卒業し、同い年で同じ学校に入り、両人は真個の仲よしで行く筈なのでした。",
              "citation": {
                "source": "いとこ同志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋の三｜郎さんは近所の子供の中でも父さんと同い年でして、好い遊び友達でした。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隣りの鐵さんは、父さんのお家の友伯父さんと同い年ぐらゐで、一緒に遊ぶにも父さんの方がいくらか弟のやうに思はれるところが有りました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "束髪の娘は英語の教師に走り、結綿は駈落ちするところを、小僧の亀どんが見つけて騒ぎ出したので、かえっておおかめさんに叱られたのだといったが――末の子の、おっちゃちゃんが亡くなると、思い出してしようがないから、おないどしのあんぽんたんに遊びに来てくれと、贈りものをよこしては迎いにきた。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
