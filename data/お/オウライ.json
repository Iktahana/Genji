    "definitions": [
      {
        "index": 1,
        "gloss": "coming and going",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "往来の片側の店にはみんな夕陽が射し込んでゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は、十一月の曇つた午後に、風が往来の砂塵を巻きあげてゐるやうなもんだと、僕の、心はともかく肉体は、左様に今はや観念してゐるやうな具合だ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は夜の町を仰向勝ちにスタスタと歩きながら、「……あなただけに言ふんだから、誰にもスベらせちやあ嫌ですよ……」つてことばがヒツキリなしに頭を往来した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "片町に更紗染めるや春の風　町の片側に紺屋があって、店先の往来で現に更紗を染めているという句であるが、印象としては、既に染めた更紗を、乾燥のために往来へ張り出していると解すべきであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏畑の竹藪の中の小径から我家と往来が出来て、垣の向うから熟柿が覗けばこちらから烏瓜が笑う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一人親しく往来していた同窓の男が地方へ就職して行ってからは、別に新しい友も出来ぬ。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も夕刻から神楽坂へ廻って、紙屋の店で暮の街の往来を眺めていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の往来が織るような街の両側の人道の並木の下には手を組んだ男女の群が楽しそうに通っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君はこの空ら風の中を突兀として、忙しそうな往来の人を眺めて歩く。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の下から三｜間とはなれぬ往来で、森田屋の病院御用自動車が爆鳴する。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園裏にて下り小路を入れば人の往来織るがごとく、壮士芝居あれば娘｜手踊あり、軽業カッポレ浪花踊、評判の江川の玉乗りにタッタ三銭を惜しみたまわぬ方々に満たされて囃子の音ただ八ヶまし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀さんは眼をつむっていてもその心の眼には森の奥における鳥の行動や水底の魚の往来が手に取るように見えすくかと思われるのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "月夜に往来へ財布を落しておいて小蔭にかくれて見ている、通行人があたりを見廻わしてそれを拾おうとするときに、そっと手許の糸を手繰ると財布がひとりでするすると動き出すというような深刻な教育法をも実行した事があったようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰掛の一番後ろの片隅に寄りかかって入口の脇のガラス窓に肱をもたせ、外套の襟の中に埋るようになって茫然と往来を眺めながら、考えるともなくこの間中の出来事を思い出している。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "都鄙両方に往来する人は両方を少しずつ知っている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば雨のふる日に傘をささないで往来を歩きたいと思ったとしても、なかなかそうはさせてくれない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の店頭には、かがり火をたき、白木の金剛杖をたばに組んで、縄でくくり、往来に突きだしてある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年六月『経済往来』）",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "救護隊の屯所なども出来て白衣の天使や警官が往来し何となく物々しい気分が漂っていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人がじろじろ見て通るからしかたなしに歩き出す。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マロニエの茂みを分けて、紅色の翼が斜に往来へのっと現れた。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の道が拓けるにつれ、東国の西の方よりこの東国の北部の方へ入り込んで来る旅人が多くなった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い海を控え雲の往来の絶え間ない山があった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八年前まで元気でおりまして、相変らず東海道を往来しておりましたが、神経痛が出ましたので流石の父も、我を折って私の家へ落着きました」　小松技師の家は熱田に近い処に在った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのテーブルにもアペリチーフの杯を前にした男女が仲間とお喋りするか、煙草の煙を輪に吹きながら往来を眺めたりしている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれに刺され、あるいはそれを除けて行く往来の人はまだ篩にかけられていなかった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに山は山だけに風が強く、湖水には白波が立って、空には雲の往来が早い。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが降ると道路はもちろん樹木の枝でも電線でも透明な氷で蔽われるために、道路の往来は困難になり電線の被害も多い。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす暗いおうらいのまん中で、二、三人の子どもが、こまをまわしています。",
              "citation": {
                "source": "のら犬",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
