        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――「今度這入つて来た細つそりした女ねえ、横着なのよ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうに、私がまだ若くて横着であつた頃一度光栄の上に目を見据えたことがあつた。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と拔からず横着な申し出をして、「おれは恩に着るぜ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと學問なんかすると、誰でもそんな工合ひに横着な氣取り方をしてみたくなるものらしいのね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小初はぐっと横着な気持になって、化粧の出来上った顔に電球を持ち添えて「これでは、どう」と窓の葦簾張りから覗いている貝原に見せた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、なお行きにくい」「嘘言え、横着をしてもっと上流の方を廻らんからだ」「大人、行ったことがない。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様ら、横着をして兵タイのいるいい道を選って行っとるんだろう。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいつの代にも横着者は絶えないもので、その禁断を承知しながら時々に阿漕の平次をきめる奴がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、生意気者で、油売り、横着者で、悪者で……これが見せしめ……これが見せしめ……。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも道理千万な談で、早い譬が、誤植だらけの活版本でいくら万葉集を研究したからとて、真の研究が成立とう訳はない理屈だから、どうも学科によっては骨董的になるのがホントで、ならぬのがウソか横着かだ。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャラメルなんて高慢チキな面をしやがって、日本にいるのならもっと日本らしい名前をつけろ」「こん畜生、横着な事を言う。",
              "citation": {
                "source": "キャラメルと飴玉",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は少し変りもので、横着もので、随分人をひやかすような口ぶりをする奴ですから、『殴るぞ』と尺八を構えて喝す真似をしますと、彼奴急に真面目になりまして、『修蔵様に是非見てもらいたいものがあるんだが見てくれませんか』と妙なことを言い出したのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは忙しいから帰れと言われても、なんとか、かとか勝手な事を言っては横着にも居すわって、先生の仕事をしているそばでスチュディオの絵を見たりしていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろもお前、家にいて、毎日の家の様子は見ているくせに、箒一つ取るでもなく、家いっぱいにひろがって横着をきめている始末だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあこのくらいな横着は先生にも大目に見て頂くさ」　麒麟児といわれて十四の歳から新日本音楽の権威である千歳の父のもとに引取られ、厳しく仕込まれた慶四郎は、青年になるに随ってめざましく技倆を上げた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "横着にした、楫棒を越えて、前なるがまず下りると、石滝｜界隈へ珍しい白芙蓉の花一輪。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは元来横着だから、川の中へでも追いこんでやりましょう」と言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくも、電燈が點くやうに成ると、人間は横着で、どうしてあんなだつたらうと思ふ、が其はまつたく暗かつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）この横着ものめが……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは仮死を粧って拷問を中止させようとする横着物であることを役人たちはちらと看破して、決してその拷問をゆるめはしなかった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、さあ、寝た振なんぞ為ねえで、起きろ、起きろ、横着な阿魔だ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は中々の横着者で、最初は兎角に自分の素性来歴を包もうと企てたが、要するに其れは彼の不利益に終った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根の中でもここらは交通が不便で、自動車の横着けなどという、洒落れた芸当が出来ないから、成金先生などは滅多に寄付く気づかいがない。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女中の無智は憐むべし、夫人の横着は憎むべし、水の尊さ、勿体なさ……気の弱い私は何ともいえないでその場を立ち去った。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "人並｜外れた身体をしながら当り前の橋賃でこの橋を渡ろうなんて、ずいぶん図々しい横着な人ですね。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と抜からず横着な申し出をして、「おれは恩に着るぜ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと学問なんかすると、誰でもそんな工合に横着な気取り方をしてみたくなるものらしいのね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷刻なる自然がわが知識と情操と意志を侮蔑して勝手に横着に非人間的に社会を動かして行くからである。",
              "citation": {
                "source": "文芸とヒロイツク",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻転ドアの客の出入りも少くなり、その代り、詰めに詰め込んだという座席の客は、いずれもこの悪魔的の感興の時間に殉ずる一種の覚悟と横着とを唇の辺にたたえ、その気分の影響は、広間全体をどっしりと重いものに見せて来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "興照寺のようなおうちゃく寺では、地蔵尊どころか、いまにご本尊さままでも盗まれまするよ」「聞き捨てならぬことを申されまするが、では、あちらのお住職はご行状がちと――」「悪い段ではござりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
