        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は一日五枚書くと大威張りだ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も大威張りで媒妁できる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」男の子が大威張りで云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゅっこが、大威張りで、あの青いたんぱんを、淵の中に投げ込んだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　男の子が大威張りで云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から向う鉢巻の伝六が大威張りです。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋が深くなって、この着物を大威張りで着て歩けるような季節になると、私は、ほっとするのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから線路の左がわで、ぐゎあん、ぐゎあんとうなっていたでんしんばしらの列が大威張りで一ぺんに北のほうへ歩きだしました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こどもが大威張りで云ひました。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も自分は青と黄いろで、とても立派な縞に染めて大威張りでした。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年生があるき出すとさっきの子も嘉助のあとへついて大威張りであるいて行きました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐太郎が大威張りで、上流の瀬に行って笊をじゃぶじゃぶ水で洗いました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私たちは野原でわかれて私は大威張りで家に帰ったのです。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、髪を長くして、だぶだぶのずぼんをはいたあばたな男が、小屋の幕の前に立って、「さあ、みんな、入れ入れ」と大威張りでどなっているのでした。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっぷあっぷ溺れるまねをしたりなんかもするねえ、そんなことをしてふざけながらちゃんと魚をつかまえるんだからえらいや、魚をつかまえてこんどは大威張りで又氷にあがるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきから線路の左がはで、ぐわあん、ぐわあんとうなつてゐたでんしんばしらの列が大威張りで一ぺんに北のはうへ歩きだしました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎はますます壮健になって、牢内の人気役者となって、新しい手拭を使って、うなぎ飯を食って、大威張りで日を送っていたのであった。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "轡虫は大威張りでそこいらの露をヤタラに吸いながら、「それ見ろ。",
              "citation": {
                "source": "がちゃがちゃ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな鞄は大威張りで、「大きな鞄の意気地なし」　と笑っておりました。",
              "citation": {
                "source": "二つの鞄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御褒美で、アアは王様の国を半分と一番目のお姫様を、サアはまた残りの半分と二番目のお姫様を貰って、二人共王様になり、お父様とお母様を半月宛両方へ呼んで、大威張りをしているところまで見えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶先生は大威張りで、又馬を打ちたおしました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶先生は大威張りで、「よしよし。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ると無茶先生は大威張りで、「それ見ろ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒョロ子も来い」　と、大威張りでこの宿屋の一番上等の室へ通りました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにとんとん拍手でてがらたてたこたあめったにねえんだから、あっしもおおいばりでお話ししますがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつ、いいねたあげたと思ったからね、まずだんなのところへ連れてこなくちゃと、おおいばりで非人どもしょっぴいてけえりかかったら、あばたのだんなが息を切りながら駆けつけてきて、いきなりぽかりとくらわしたんですよ」「おめえをぽかりとやったのか」「そ、そうなんです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――待つほどに首尾よくいったとみえて、気早にもあの三宝の飾り橙までもこわきにしながら、おおいばりでその伝六が姿を見せました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先ゃ、伝六様がおおいばりなんだからね、そんなにとんとん足音をさせりゃ聞こえるじゃござんせんか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なにもざまをみろといわなくてもよさそうなのに、ひとたび伝六がてがらをたてたとなると、じつにかくのごとくおおいばりです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、奥山のたった一軒きりきゃねえその玉ころがし屋が、下手人の野郎のうちだといってね、おおいばりに出かけていったというんですよ」「そうだろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
