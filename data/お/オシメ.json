[
  {
    "uuid": "b487cdfe-62cb-5ad9-a348-f6ccd72bfa04",
    "entry": "襁褓",
    "reading": {
      "primary": "おしめ",
      "alternatives": [
        "むつき"
      ],
      "is_heteronym": true
    },
    "grammar": {
