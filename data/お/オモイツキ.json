        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "思い上った思いつきだ。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今朝の思いつきもなんのことはない、ロシアの貴族のように（午後二時頃の朝餐）が生活の習慣になっていたということのいい証拠ではないか。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっさの思いつきで、今度はスキーのようにして滑り下りてみようと思った。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またおもしろいことには、物理学上における画期的の理論でも、ほとんど皆その出発点は質的な「思いつき」である。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん質的の思いつきだけでは何にもならないことは自明的であるが、またこれなしには何も生まれないこともより多く自明的である。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の学界ではこの思いつきを非常に尊重して愛護し、保有し、また他人の思いつきを尊重する学者が多いのであるが、わが国ではその傾向が少ないようである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただの思いつきである」という批評は多く非難の意味をもって使われるようである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いつきはやはり愛護し助長させるべきであろう。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の科学的な利器は単に独創的な素人の思いつきや苦心だけで完成するにはあまりに多くの専門的知識の素養を必要とする、という明白な事実が日本のジャーナリストに一般には認識されていないのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた犯人と目星をつけた女の居所を捜すのに電話番号簿を片端からしらみつぶしに呼び出しをかける場面などもやはり一つの思いつきである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの奉行たちも、これをいい思いつきであるとして期待した。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春、夏、秋、冬、朝、昼、夕、夜、月にも、雪にも、風にも、霧にも、霜にも、雨にも、時雨にも、ただこの路をぶらぶら歩いて思いつきしだいに右し左すれば随処に吾らを満足さするものがある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は一時の思いつきのようなものに過ぎないのであるが、一つの研究題目を提出するような意味で、思ったままをここにしるしてあえて読者の教えをこうことにした。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物を開いて、ものの半ページも読んで行くうちに、いろいろの疑問や思いつきが雲のごとくむらがりわき起こって、そのほうの始末に興味を吸収されてしまうような場合が多かったのではないかと想像される。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎が有難い事を云ったってかんかん虫手合いは鼾をかくばかりで全然補足になら無えってんで、工場長開けた事を思いつきやがった、女ならよかろうてんだとよ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この土地へ来ましてから、つい思いつきで、古着屋から買ったんですから。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……思いつきで、幽霊は、射的店で借りた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那、これがその申上げた洒落というんで、実は、おじいの思いつきでござりやしてね。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と捻平は火桶の上へ脊くぐまって、そこへ投出した膝栗毛を差覗き、「しかし思いつきじゃ、私はどうもこの寝つきが悪いで、今夜は一つ枕許の行燈で読んでみましょう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井も振袖の女の子の事なぞは最初から考えていなかったのでしょうが、そんな噂が広まったのを幸いに、当座の思いつきで、「実は引っ越しの日の夕がたに」なぞと、いよいよ物凄く持ち掛けたのでしょう。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっというようなことを……」　考えているうちに、「――そうだ、あの男を川へ突き落してやろう」　豹吉の頭にだしぬけに、そんな乱暴な思いつきが泛んだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だしぬけに泛んだ思いつきの甘さに自らしびれていたのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その二人を連れて来るという思いつきを豹吉に泛ばせる胸底には、たしかに雪子のことがあった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、「何かこう人をあっといわすような、意想外の、破天荒なことをしてみたい」　という単純な思いつきに過ぎなかったのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて言えば、雪子を警官の手から奪うという、大それた暴挙が「何か人をあっといわせるような破天荒なことを今直ぐしてみなくっちゃ、おれの気が済まない……」　という、たった今さき腹の虫を動かせて来た不意の思いつきに、ピッタリ合っているではないかと咄嗟に自分に云いきかせる余裕だけは、さすがに残っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その警察署へ、単身乗り込んで行って、雪子を救い出す――という計画、いや思いつきは、むろん向う見ずであった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、今や、薄井と会った直後に『赤と黒』のジュリアンが始めてレナール夫人の手を握ろうという思いつきを自分に課し実行するというくだりを読んだ事は信吉を決然とさせた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "君恋し唇合わせねど、涙はあふれて想いは果てなしというその頃流行していた唄からの思いつきで、豹一は、その夕方、簡単に紀代子に接吻をした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "井深君はこの思いつきに嬉しくなって水兵服の少女の方をみた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは何を云おうかと暫く考えていたが、大したおもいつきでも無いようなことを、とうとう云い出した。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
