    "definitions": [
      {
        "index": 1,
        "gloss": "to feel indebted (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
