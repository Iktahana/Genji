    },
    "definitions": [
      {
        "index": 1,
        "gloss": "court physician (of the Shōgun and his household, Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "素より躋寿館に勤仕する医者には、当時奥医師になっていた建部内匠頭政醇家来｜辻元が襲いだ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽真院は※庭、安良は暁湖で、並に二百俵の奥医師であるが、彼は法印、此は法眼になっていて、当時｜矢の倉の分家が向柳原の宗家の右におったのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "公儀へ召されるといったのは、奥医師などに召し出されることで、抽斎はその内命を受けていたのであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくはそのまさに奥医師たるべき時であっただろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えて安政五年に至って、七月三日に松平｜薩摩守斉彬家来｜戸塚静海、松平肥前守｜斉正家来｜伊東玄朴、松平三河守｜慶倫家来｜遠田澄庵、松平駿河守｜勝道家来青木｜春岱に奥医師を命じ、二百俵三人扶持を給した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日また有馬｜左兵衛佐道純家来｜竹内玄同、徳川｜賢吉家来伊東｜貫斎が奥医師を命ぜられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉永三年に二十九歳で奥医師になっていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊沢柏軒はこの年三月に二百俵三十人扶持の奥医師にせられて、中橋埋地からお玉が池に居を移した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柏軒は正月のにはまだ奥詰の部に出ていて、三月以下のには奥医師の部に出ている。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "保さんは今一つ、柏軒の奥医師になった時の事を記憶している。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "福山侯の家来成斎が、いかに幕府の奥医師の子を尊敬しなくてはならなかったかという、当年の階級制度の画図が、明に穉い成善の目前に展開せられたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの年の三月になって、鉄砲さんの父柏軒が奥医師になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "栲窓は抽斎の歿した頃奥医師を罷めて大塚村に住んでいたが、明治七年十二月に卒中し、右半身不随になり、此に※って終った。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此年十二月十九日に、蘭軒は阿部｜正精に請ふに間職に就くことを以てし、二十五日に奥医師より表医師に遷された。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥医師より表医師に遷るは左遷である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時小川町住の奥医師であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "武鑑を検すれば、奥医師に「養安院法印、千九百石、きじはし通小川町」があり、奥詰医師に「曲直瀬正隆、父養安院、二十人扶持、きじはし通」がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "順成は其後を襲いで表医師となり、文化九年奥医師に進み、文政十一年に歿した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "成美は文政元年に出仕を命ぜられ、四年に表医師となり、十年に医学世話を命ぜられ、十一年に順成の後を襲ぎ、十二年に奥医師となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此より後の武鑑には同名、同禄、同住所の人が奥詰医師となり、奥医師となつてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時宜山は儒者奥詰、角兵衛は使番格、周迪は奥医師であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で閏四月二十九日に宝素が歿し、七月三日に抱沖が家督相続をし、十月二十八日に奥医師になつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして柏軒は何の咎をも受くることなく、只奥医師より表医師に貶せられたのみであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥医師木挽町の柴田芸庵は安政元年に至るまで武鑑に見えてゐて、二年以後｜刪られてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "多紀氏宗家では暁湖元は此年の武鑑奥医師の下に「多紀安良法眼、父安元、二百表、向柳原」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月九日に棠軒は又阿部｜正教の奥医師にせられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二十一日に柏軒が奥医師に陞つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柏軒先生は多紀｜※庭、辻元冬嶺等の没後に幕府の擢用を蒙り、職は奥医師たり、位は法眼に叙せられ、又市中に病家千戸を有し、貴顕富豪の治を請ふもの多く、お玉が池明誠堂の門には車馬の跡が絶えなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「徳川十四代将軍（家茂）が上洛の供を命じた奥医師は戸塚静寿院法印、竹内｜渭川院法印、本康宗達法眼、三上快庵法眼と先生とで、これに奥外科見習村山伯元が副へてあつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「老中水野は奥医師に汽船咸臨丸に陪乗することを命じた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
