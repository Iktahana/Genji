        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「君ちやん（僕の名、実は君介、どうもブラ公みたいな名ですよ）どうも遅くなつて御免よ、富田の奥さんがいろんな話をしなさるから、あとからあとから話しなさるから。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時、妻はわざわざ私の所へやって来て、『遅くなりますから、お先へ休ませて戴きます』と言う、丁寧に三つ指をついてお辞儀をし、それから自分の寝床へ入る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "来診を報知らせる電鈴がその時鳴つた、「夜遅く………」と唸きながら父は立つて行つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "月天心貧しき町を通りけり　月が天心にかかっているのは、夜が既に遅く更けたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我を厭ふ隣家寒夜に鍋を鳴らす　霜に更ける冬の夜、遅く更けた燈火の下で書き物などしているのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所への人づきあいもせずに、夜遅くまで書物をしていた蕪村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の一日こんな朝、遅く目覚める人達は戸にあたる風と轍との音によつて、サイレンの棲む海に溺れる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が薬師岳で観察した所に依ると、凡べてのカアル皆然りとは言われないが、カアルの初期は、雪が横一文字に堆くなっているに過ぎないが、その両端の垂下力が遅く、中央が速いためか、第二期には三日月形に歪み、更に拡大して勾玉形になって来ている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い事あ、もっと早くか、もっと遅く言ったらどうだい。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り帰りが遅くなるので、秋山の長屋でも、小林の長屋でも、チャンと一緒に食う筈になっている、待ち切れない夕食を愈々待ち切れなくなった、餓鬼たちが騒ぎ出した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを云う事を覚えるのが普通より遅く、そのために両親が心配したくらいで、大きくなってもやはり口重であった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は山から採ってきた、あけびや野葡萄やを沢山座敷｜中へ並べ立てて、暗に僕がこんな事をして居たから遅くなったのだとの意を示し無言の弁解をやっても何のききめもない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日にゆくとしろ……えいか、そのつもりで小支度して置け」　学校へゆくは固より僕の願い、十日や二十日早くとも遅くともそれに仔細はないが、この場合しかも今夜｜言渡があって見ると、二人は既に罪を犯したものと定められての仕置であるから、民子は勿論僕に取ってもすこぶる心苦しい処がある。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "またあの奴民子が居ないから考え込んで居やがると思われるも口惜しく、ようやく心を取直し、母の枕元へいって夜遅くまで学校の話をして聞かせた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても遅くおはします事かな、いつも九時のかねは膳の上にて聞き給ふを。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この調子で進んで行ったらあるいは近いうちに「仕上げ」のかかった、しかも魂の抜けない作品に接する日が来るかもしれない、自分はむしろそういう時のなるべく遅く来る事を望みたいと思うものである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある人の話によると、落葉樹の葉の中で遅く発育したのがまだ十分成熟しないうちに早い霜に痛んでしまうと、それきり発育が止まって、コルク質の出来る間がなく、梢に枯れたまま淋しい趣を見せるという事である。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚図々々して親爺が帰って来ると、又叱言の一つもきかなくちゃならねえからな」　「兄さん、此頃毎晩遅いのね」　「今夜も亦、遅くなるから戸じまりはしねえで置いてくれ」Ｓ＝茶店の表　石松、出て来て、　「あッ、帰って来た。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝店　入って来た石松、　「遅くなりました。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩か、遅くとも明日の晩だから、そのつもりで……」　「御親切に有難う御座いました。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには夜遅くお帰りなさるせいもあるでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあ遅く帰るせいもあるだろう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一今夜は帰が遅くなるのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり遅くなるからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅くなりはしなくって。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも遅くなってからだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、だいぶ遅くなった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し遅くなりましたが、街へ踊りに出かけましょう。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、いま時分、こんなに遅く、いいのかしらん」「なに、ちっとばかり、資金を廻してある家なので、自由が利くんです」　涼しい食物の皿が五つ六つ並んで、腹の減った小初が遠慮なく箸を上げていると、貝原はビールの小壜を大事そうに飲んでいる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遅く来って御気毒様、」と来た少女は軽く言った、奥に向て。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
