        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夜、なお行きにくい」「嘘言え、横着をしてもっと上流の方を廻らんからだ」「大人、行ったことがない。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "包まず云ふが、私自身はこれでかなりの嘘言家なのである。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の中はソンナ様な神秘めかした嘘言ばっかりでみちみちているんですよ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘言も不人情もお互い様よ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤそれは嘘言だ、上村君にもし相手があったら北海道の土を踏ぬ先に変節していただろうと思う、女と言う奴が到底馬鈴薯主義を実行し得るもんじゃアない。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、べつに……」「嘘言いなはれ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そう言う腹の底で、轡川にのせられたのは残念ではあるが、轡川の言葉は嘘言であり明日子は矢張り彼の言う様な女ではないと思えることが些か嬉しかった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはもはや明日子を彼の言う様な女でないと信じた以上、再び当然の成行として、彼を嘘言を弄した男であると思わねばならなかったのだが、彼のそんな顔を見ていると、どうしてもその様に思うことは出来なかった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて、いまだ一度も嘘言というものをついた事が無いと、躊躇せず公言している。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れて、いまだ一度も嘘言というものをついたことがないと、躊躇せず公言している。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いながら厳粛のことを語っていても、それは、笑いながら語っているから、ばかばかしい嘘言である。",
              "citation": {
                "source": "一歩前進二歩退却",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い懸けず、余り変ってはいたけれども、当人の女の名告るものを、怪しいの、疑わしいの、嘘言だ、と云った処で仕方がない。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いやしい嘘言である。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速やが、他あやん、その子うちへ呉れへんか」「ほんまだっかいな」「嘘言うもんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん爺さん嘘言いいたい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）最も嘘言を吐かぬ人間だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の知らん事あ、何でも嘘言と思いなさんな」「……フーム。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もうその心の乾かぬ間に、忽ち彼の顔が「嘘言者の面」たる偶像として、はつきり其処に在るのを、見ぬ振りが私には能はなかつたのだ。",
              "citation": {
                "source": "疑惑の城",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『嘘言つてらア、御らんよ、ぺんきが白ぢやァないか。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜソンナに恐ろしい嘘言をついたのか、その時の気持がどうしてもわからないんですけど、真暗な雨風の中をすごいスピードで走る自動車の中で、すっかり憂鬱になっていた妾が、新高さんと一緒に死んだ方がいいような気持になっていたせいでしょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して先生のお心にそむくような事は致しませんから……」　これは私が生まれて初めて吐いた嘘言でした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞かせて頂戴な」「嘘言だよ」　もう足かけ四年前になる、おときさんが僕の家に來ておときさんの絃で金公が「紙治」を語つたのは――。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは文士の嘘言だと笑う者さえあろう。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただみんなが平和な怠惰と不潔な食物と無害な嘘言とに楽しく肩を叩きあっているばかりだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は家のものを手当り次第盗んで持ち出して与へたが、しまひには手頃の品物がなくなつて約束が果されず、嘘言ひ坊主といふ綽名を被せられた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「嘘言え、手めえの面にきいてみろ。",
              "citation": {
                "source": "鬼眼鏡と鉄屑ぶとり",
                "author": "続旧聞日本橋・その三",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母たちの子供の責め方は、事実私を、ねじけた嘘言いにさせた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
