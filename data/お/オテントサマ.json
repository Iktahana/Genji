        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「やっぱりお茶に縁が有らあね、……世間じゃお天道様と米の飯は附いて廻ると云うけれど、お前さんにゃ、貰水とお茶がついて廻るんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、お天道様は性急だっさ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体｜法網を潜るものは、お天道様が罰する筈だけれど、それも片手落な事もあって、北向の家はいつもいつも寒いようでは、あてになったもんじゃない。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達を、連れて行きてえのは山々だが、お役人をたたっ斬って、天下のお関所を破った俺達が、お天道様の下を、十人二十人つながって歩くことは、許されねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "口先だけの嘘を平気で云う弥助でさえが考え付かないほど、自分は卑しいのだと思うと、頭の上に輝いている晩春のお天道様が、一時に暗くなるような味気なさを味った。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとやがてあたりが明るくなって、まだ見た事もない山や河や森や家が見えて来ると一所に、向うの雲の間から真赤なお天道様がピカピカ輝きながら出て来ました。",
              "citation": {
                "source": "オシャベリ姫",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、事件と云うのは……日附を忘れましたが、なんでも七月の、まだお天道様がカンカンしてる暑い頃のことでして……日本橋の北島町で、坂本という金貸の家が空巣狙いに見舞われたんです。",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つた程、お天道様に惚れてゐる人なのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は心理学者だけに人間の事はよく注意してゐるが、お天道様は雨降か雪降かで無ければ余り気には掛けてゐなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウヰルソンの義弟といふのは、身の丈七尺もあらうといふ背高男で、道を歩く時にはお天道様が頭に支へるやうに、心持｜背を屈めてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "造船所の上には鳶が鼻唄を謡つてゐたが、お天道様や鳶に用事の無い広海氏は掛りの顔を見ると直ぐと切り出した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡てに公平なお天道様は、禅坊主が来たからといつて、取つて置の風を御馳走する程の慈悲も見せなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "・私共はお天道様の光と親の光で育ちました、――と前の家の小母さんが誰かと話してゐたが、今だつてさうである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "・私が貧乏してゐるので、おまけに病気で働けないので、お天道様が水だけは涸らさないで下さる、――と前の家の小父さんの皮肉見たいな挨拶、なるほど、近所の井戸は涸れて、人々が貰ひに来るほどよい水が絶えないのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桟橋から水に映つたお天道様を見るやうに光るぜ。",
              "citation": {
                "source": "聖ニコラウスの夜",
                "author": "SANKT NIKOLAUS BEI DEN SCHIFFERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、まだ明けきらない東の空、眺めてゐるうちに、いつとなく明るくなつて、今日のお天道様がらんらんと昇る、それは私には荘厳すぎる光景であるが、めつたに見られない歓喜であつた、私はおのづから合掌低頭した。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "云えば、雌｜山羊の乳をしぼれば、他の者が篩をその下に差し出していると云う、そんなはかない生活なので、躯工合でも悪くなると、あれこれと考えるのだが、まあ、米の飯とお天道様はついてまわるだろうと思っている。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お天道様の出ないうちに、ここから、逃げ出さなくちゃあ――）　男達の怒鳴る声、荒い足音は、すっかり無くなって、女中が、寝間着のままで、時々、うろついて出て来るだけになった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の黒い悪魔の吐く息は、雲か霞のやうに空を立こめて、まだ生れてから若い、お天道様の美しい光りも覆ひ隠し、地上はまだ世界がひらけない前のやうに真暗になりました。",
              "citation": {
                "source": "悪魔の尾",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、お天道様」と彼女は微かに呟いたが、光を浴びた中から冬子を認めて淋しく笑った。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云って見りゃあ毎朝お天道様のお出なさるも有難い事ですねえ。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちに扇が上るかはお天道様の御心次第ですからね。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も雨かと思うたりゃ、さあお天道様が出なさったぞ、皆来うと呼ばって、胡麻塩頭に向鉢巻、手垢に光るくるり棒押取って禾場に出る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰気というのは、つまりけがれのことで、けがれは、つまり気を枯らす気枯れということでござってな、お天道様の御陽光が消えると、けがれが起るのじゃ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの神尾主膳でさえが、このカンカン照っているお天道様の前に、ぬけぬけと、恥かしい色も更になく、起きぬけの、だらしのない姿をさらしている女の醜態に、目を蔽わないわけにはゆきませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうです、お天道様はムダ光りはござんせんや、とうとう白骨の谷で神隠し、沼へ落ちたとか、岩にぶっ裂かれたとかいって、今日まで行方知れず、ほんとに天罰は争われないものだと、皆様もおおっぴらにおっしゃった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと隣へ行って来ねえ」「何しにさ」「夜のこたァ、こっちが寝てるうちだから、何をしても構わねえが、お天道様が、上ったら、その匂だけに止めてもらいてえッてよ。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天道様は、もうとっくに朝湯を済まして、あんなに高く昇ってるじゃねえか。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天道様のかげんなんですよ」「鎧戸が閉めてあっても？",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "名古屋の金の鯱にお天道様が光らない日があっても、釘抜藤吉の睨んだ犯人に外れはないという落首が立って、江戸の町々に流行りの唄となり無心の子守女さえお手玉の相の手に口吟むほどの人気であった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
