          ],
          "literary": [
            {
              "text": "女の子の方ではその強弱をおっかなびっくりに期待するのがおもしろいのらしかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と今は、おっかなびっくりで尋ねる。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、おっかなびっくり、マッチの棒のはしの方をもってすりました。",
              "citation": {
                "source": "ひとつの火",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は手酌が習慣だと言って、やっと御免を蒙ったが、はじめて落着いて、酒量の少い人物の、一銚子を、静に、やがて傾けた頃、屏風の陰から、うかがいうかがい、今度は妙に、おっかなびっくりといった形で入って来て、あらためてまた給仕についたのであった。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と居候の弟は、おっかなびっくり合槌を打つ。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたって、そうしなければ、いけない」　と、母の機嫌を損じないように、おっかなびっくり、ひとりごとのように呟く。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか落ちつかなくて、おっかなびっくりの気持で、本当に、勿体なくて、むだな事だと思いました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだって、おっかなびっくりで、なるべく静かに呼吸しながら一歩一歩、こわごわ芝生を踏んでいます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、あの人たちを信頼し、心の隅では尊敬さえしているのに、あの人たちは、へんに僕を警戒し、薄汚いものにでも触るような、おっかなびっくりの苦笑の態度で僕に接して、ああ、あの人たちは、そんなに上品な人たちばかりなのかねえ、いつでも見事に僕を裏切る。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしい顔つきにも似ず、人の気持ばかり、おっかなびっくり、いたわっている男だ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ映画の予告篇、結果に於いては、宣伝みたいな事になってしまうのだから、出版元も大目に見てくれるにきまっていると思われる、などとれいの小心翼々、おっかなびっくりのあさましい自己弁解をやらかして、さて、とまた鉄仮面をかぶり、ただいまの抜書きは二枚半、ついでにもう二枚ばかり抜書きさせていただく。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と枇杷の宿にいすくまって、裏屋根へ来るのさえ、おっかなびっくり、（坊主びっくり貂の皮）だから面白い。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ストイックな生活をしている人を、けむったく思いながらも、拒否できず、おっかなびっくり、やたらに自分を卑下してだらだら交際を続けているものである。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん大きくなるにつれて、私は、おっかなびっくりになってしまった。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、いつでもおっかなびっくりで、心の中で卑怯な自問自答を繰りかえし、わずかに窮余のへんてこな申し開きを捏造し、責任をのがれ、遊びの刑罰を避けようと致しますから、ちょっとの遊びもたいへんいやらしく、さもしく、けちくさくなってしまいます。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もかれも、おっかなびっくりじゃないか。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の、後で洗うまでには、蛇が来て抱くか、山しましたが、おっかなびっくり。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頗るしょげて、おっかなびっくり、わが家の裏口から薄暗い内部を覗くと、「あら、おかえり。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、はにかみながら悪童たちの後について行って、おっかなびっくりテントの中を覗くのだ。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初めは、おっかなびっくり、おっかなびっくりでしていたが）――そういうようにして、「サボ」を続けた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その運転手も一図に私を警察の刑事と勘違いしたおかげで、おっかなびっくりで、すっかり話してくれた。",
              "citation": {
                "source": "私はかうして死んだ！",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは、おっかなびっくり立ち上がって、見るからぶきような手つきをして、でたらめな踊りを踊りました。",
              "citation": {
                "source": "瘤とり",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そんなものを抵当に、国庫から金を借り出すなどということは、その頃はまだ珍らしいことであっただけに、借りる方でも聊かおっかなびっくりの為体であった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかなびっくりで這入って行くと、女中さんはきさくに案内してくれる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、何ものかの命令で、おっかなびっくり、押しつけて来るものに相違ないのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく、てっきり幽霊かと、おっかなびっくりで近所のひとにきいてみたんやが、なんと、店にすわっているのは、チャンフーやのうて、チャンフーの双生児の兄弟で、チャンウーちゅうのやそうな」「へへえ、チャンフーには双生児の兄弟があったの」　春木少年は眼をまるくした。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、どうしていらっしゃるかと、おっかなびっくり来たんです。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかなびっくり、という表現が何だか耳と心にのこった。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは何時の間にかとんでもない場所へ来てしまったような不安な気持になって、お互に無言のまま、おっかなびっくりそんな場所を歩き続けて行ったが、そのうち再び驚かされたのは、そんな寺の裏なんぞの、恐らく四方から墓ばかりに取り囲まれているであろうようなところに、一軒ぽつんと小さな家が見え始めたことだった。",
              "citation": {
                "source": "三つの挿話",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
