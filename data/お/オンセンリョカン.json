    "definitions": [
      {
        "index": 1,
        "gloss": "inn with hot spring facilities",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
