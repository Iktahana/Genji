        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「でも福岡市でも竹原といへば知らない人もないつて言つて好い位な家なんですから、余りお粗末にやれば……」　それは奥さんに従いて来た奥さんの声だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前ミサコさんに世間ありふれたお粗末な友情でおつきあいしては不可んよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、その時代には温泉宿にかぎらず、すべての宿屋が大抵古風なお粗末なもので、今日の下宿屋と大差なきものが多かったのであるが、その土地一流の温泉宿として世間にその名を知られている家でも、次の間つきの座敷を持っているのは極めて少い。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お粗末さまでした。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の服装も、お粗末である。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お国は、料理の国だそうですから、日本へ来ても、たべものがお粗末で困るでしょうね。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は化粧栄えのする顔立ちで、ホテルの食堂へはいっても人目を惹くだろうが、それにしては身につけているものがお粗末すぎる。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥寄りの壁際には、これもお粗末な木のベッドが寄せてあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの家も平家で、半ばはお粗末なバラック風であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服がお粗末だったので、にやけて見えることも免れていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果的にはやっぱり「ＯＳ割る２」になっちゃったというお粗末。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭の小三が和藤内に扮して、お粗末な縫いぐるみの虎を相手に大立ち廻りを演じていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六文の宮芝居だから、衣裳なんぞは惨めなほどにお粗末な代物で、虎狩や楼門に出る唐人共も満足な衣裳を着ちゃあいねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――妾のところには神棚もお仏壇もありませんので、お札を頂戴してお粗末になつてはかへつて勿体ないと思ひますので。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の西洋家屋はお粗末で却て感じが悪うございます。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれはマアいゝとして、『隱居』と『熊公』とが分らないとは、君の頭は隨分お粗末なブロツクだね。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯も書生時代から持古るしたお粗末のものなら、墨も筆も少しも択ばなかった。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "有合せの枯っ葉を縫いつづくった草庵とでもいうべきお粗末な住家で、庵の主人は印度人のような鳶色の体を少しばかし、まだ開けっ放しの入口の孔から突き出したまま、ひょくりひょくりと頭をふっている。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、その時代には温泉宿にかぎらず、すべての宿屋が大抵古風なお粗末なもので、今日の下宿屋と大差なきものが多かったのであるが、その土地一流の温泉宿として世間にその名を知られている家でも、次の間つきの座敷を持っているのは極めて少ない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒けずりの荷物箱の板を釘でうちつけたようなお粗末な扉だ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "公爵夫人……」と言ったが、やがてこう付け足した、――「きっとどこかの貧乏貴族だろうよ」「三台の辻馬車で越していらっしゃいました」と、うやうやしく皿を差出しながら、侍僕頭がしたり顔に、――「自家用の車はお持ちでありませんし、家具もごくお粗末で」「そう」と、母は答えた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の食事は一人前一ヶ月百円以上も仕払つたが、料理はお粗末な物づくめであつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、馬のやうにくすくす笑ひ出すかも知れないが、これまで年末賞与なぞ、つひぞ貰つた事の無い大学教授にとつては、百円の金もお粗末には出来なかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "取次ぎの書生が出てみると、玄関には、瓦で拵へたやうなお粗末な坊さんが一人｜衝立つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お粗末な坊さんは、汗ばんだ額へ掌面をやつて、ぐつと考へ込んでゐたが、急に獣のやうな悪意のある眼で書生の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、お粗末でございますが、これを召しあがりながら何か一つ……」「有難う。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当にお粗末な部屋ですけれど、父がいつけたところですの。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　なおこの時代の野蛮人は、一般にごくお粗末な霊魂不滅観を抱いていた。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四字削除）の室と言っても、ごくお粗末な汚ない机一つと幾つかの椅子と寝台一つのファニテュアで、敷物もなければカーテンもない、何の飾りっ気もない貧弱極まるものだった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「飛んだ、おそまつでございます。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
