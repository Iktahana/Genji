        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "所でもし感情喪失が原因なれば、人は先づ退いて心身を休めるの必要があるのであらう点で、前二者とは趣を異にするのである。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルビエールは遂に当時の趣味には合はなかつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の趣味は他人に請ひては不可ないものよ――教へてあげるわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　あゝ覚えた覚えた、他人の――いや、自分の趣味はか、他人に請ひては不可ないもの、さうかな。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の趣味は――女　（男の言はうとするのを遮つて）不可ないと何時いつたの？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "年久しくも友の求めて居たものは、高貴なる貴族的の人格とその教養ある趣味性であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の貴族めいたエゴイズムの思想と、一種の偏重した趣味性とは、不思議にも我が友のいたく悦ぶ所となつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "また他の者たちは、西洋詩の生硬な直訳を思はせるやうな、息苦しい悪い趣味の詩を発表して新らしがつて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやしくもその詩興を損い、趣味を害するようなものは――人でも、家具でも、物音でも――絶対にその家庭に入れなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一方また室生君の方では、自分で深くその野性を羞恥して居り、常に「教養ある紳士」といふやうなことをイデアにして居たので、教養や趣味性の上で文化的にレフアインされた芥川君が、世にも珍しく理想の人物に思はれたのである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年に於ける室生君の教養と趣味生活とは、芥川君との交際によつて學ぶ所が確かにあつた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の新しき日本詩壇が、芥川君と同趣相通ずるのも、實にただこの一點にある。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星君の如く、感情の趣くままに自由な本能的行動をしたいこと。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから最後の結論として、皆が一緒に歎息したことは、昔の馬グソ臭い新宿情趣が、近代文明の爲に次第に廢滅して行くといふことだつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはからだのぐるりを趣味でかざっているのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は趣味で小説を書いているのではない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、衣食住に就いては、全く趣味が無い。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が刹那主義といふ時、恰かも私が上に述べた如き趣意にあるやうに見える。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "依つて本校の創立趣旨を出来る限り屡々生徒に聞かせ、又編入者に対しては速かに本校の空気に馴れしめるやう努めて戴かんければならないと考へられるのである」　彼は、「私は考へるのである」とか、「私は思ふのである」とかを、成可く交互に使はうと苦心した。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの少数の作品を通じて、大体の趣味、傾向、句風等、及び俳句に対する氏の主観態度が、朧げながらも解らないことはない。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "言はばこれ等の人々の俳句は、多く皆「文人の余技」と言ふだけの価値に過ぎず、単に趣味性の好事としか見られないのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「侏儒の言葉」は、言はば頭脳の機智だけで――しかも機智を誇るために――書いた文学で才人としての彼の病所と欠点とを、露骨に出したやうな文学であつたが、同じやうにまた彼の俳句も、その末梢神経的の凝り性と趣味性とを、文学的ヂレツタンチズムの衒気で露出したやうなものであつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば彼の詩文学は、生活がなくて趣味だけがあり、感情がなくて才気だけがあり、ポエヂイがなくて知性だけがあるやうな文学なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて人はその第一義的な仕事に於て、思想と情熱の全意力を傾注し、第二義的な仕事即ち余技に於ては、単に趣味性のみを抽象的に遊離して享楽する。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生氏の場合も亦これと同じく、彼の句作の態度には、趣味性の遊離した享楽（ヂレツタンチズム）が多分にある。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれにも拘らず、彼はその趣味性の享楽を生活化し、ヂレツタンチズムを肉体化することによつて、不思議な個性的芸術を創造するところの、日本茶道精神の奥義を知つてる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば彼が陶器骨董を愛玩する時、その趣味性の道楽が直ちに彼の文学となり、陶器骨董の触覚や嗅覚がそれ自ら彼の生きた肉体感覚となるのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにその後、勝太郎の「ハア小唄」になつてくると、もはや「酒は涙か」のロマネスクや青年性は失はれて、年増女の淫猥な情痴感や感傷性やが、大衆の卑俗趣味に迎合するやうになつて来た。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれもまた前時代の歌曲に比すれば、その品位のないことに於て、野趣的に卑俗化したことに於て、時代の文化的低落を語る一実証と見るべきだつた。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
