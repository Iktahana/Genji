    },
    "definitions": [
      {
        "index": 1,
        "gloss": "luxury",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自動車で田舎へ遊山に出かけるというようなことは非常な金持のすることで吾々風情の夢にも考えてはならない奢りの極みであるような気が何となしにしていた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを籬にしたるは奢りがましけれど、処子が家にもさばかりの奢りはありてこそ宜かるべけれ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い素足と真紅のスリッパにゴチック式の豪華を極めた応接間をモノともせぬ勝気さを見せて、これも炭坑王の奢りを見せた真綿入｜緞子の肘掛椅子に、白い豊満な肉体を深々と埋めている。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちの花見酒で酔い潰れ、こっちのお祝い酒で奢り潰されてなあ」「太平楽なにも程がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて値段の高い晦日蟹の塩茹となりゃあ、どうしても三杯酢で一パイと言う処で、誰が聞いても恵比寿講の何厘何毛という利前｜勘定とは思われませぬ奢りの沙汰で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん奢り贅沢はいけませんが、身分不相応な切り縮め方をして、子供や使っている人を、営養不良色にして得意になっているのは、これまた贅沢の一つです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを付け合せの茸の淡白の味が飄逸に取做す、山野の侘びとフランス人工の奢りとの取合せだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　島野は苦々しい顔色で、「奢ります、いずれ奢るから、まあ、君、君だって、分ってましょう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、だから奢りますよ、奢りますよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦勝つて国民の気奢り、知らず識らず亡国の悲境に陥る国あるを思はざる可からず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の費用を出さうと云つては奢り花などを引いた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳ぐらいかと想った」「何か奢りましょうよ」　白糸は帯の間より白｜縮緬の袱紗包みを取り出だせり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやもう、これはなかなか大変な奢りの気持になったものだ。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸駒が俗慾の奢りを極め、贅沢な普請をして同功館などと大そうもない名をつけたのも癪に触つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に活計に困る訳じゃなし、奢りも致さず、偏屈でもなく、ものはよく分る、男も好し、誰が目にも良い人。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのと呆けて無邪気を装う様子には何となく灰汁ぬけした甘ったるいものがあって、「そら、また、おばさんの食い辛棒が始まった」　と苦笑しながらも誰かゞ奢ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは路傍なり、猫目石の奢りかがやく夕暮の崖の下なり、熱くちらばる花の中に、流石女の稚けなけれどなまめかしく、而も無心に、童は薔薇色薄きシヤツをかきあげつる、尻も真白く、病める、悲しき、取りみだしたるその溜息。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労と来たね、畜生、奢りたまえ、奢りたまえ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で天気がよければよいが天気が悪ければ、とても茶を飲むなどいう奢りは許されない。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "姐さんの奢りというので、みんながここを先途と色気なしに、むしゃむしゃ食っているのを、お絹は箱に倚りかかりながら黙って離れて眺めていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら傍で見てゐればいゝ、どうせ妾の奢りなんだからね、などゝ冗談を云ひながら照子は先へ立つて其処の店へ入つて行つた。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿、容子、化粧の奢り、身分のあるもののおてかけか寵姫か、およそ容易ならぬ女でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が如何に奢りを極めたか、彼等の主人が如何に甚だしい道楽を試みたか、彼等の妻子や召し使いなぞが如何に風俗を乱したかは、江戸時代に現われた小説や芝居や絵を見てもわかる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうお静、お銚子のお替り持っといで」　「お、爺っつあん、俺ァもう酒はいいんだよ」　「なーに儂がおごりまさァ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふまでもなく先生は私の三田｜文科生時｜代からの先生であるが、球突では始終喧嘩相手で、銀座裏の日｜勝亭で勝負を爭つて、その成績で風月｜堂の洋食のおごりつこをしたなどもしばしばである。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそのひかりの中でならば、人のおごりからあやしい雲と湧きのぼる、塵の中のただ一抹も、神の子のほめたもうた、聖なる百合に劣るものではありません」　「私を教えてください。",
              "citation": {
                "source": "めくらぶどうと虹",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　春次は銀子と風呂からの帰り路、蜜豆をおごりながら言うのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時仏にも供え看護婦をもおごり、みんなで天丼を食べたことがあったが、それは仏が生前に食べたいと言うので、取ってみたが蓋を取って匂いをかいだばかりで食道はぴったり塞がり一箸も口へもって行くことができなかったのを思い出したからで、寝ついてからはずっと食慾がなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなが私の靴を見つめているような、たいへんな、おごりの気持よ。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ一杯、おごりものだぞ」「いえ、そんなことじゃないのよ。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
