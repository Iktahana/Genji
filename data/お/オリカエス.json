        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ごわっごわっと時々新聞を折り返す音だけが聞こえて、積み荷があらかた片付いた船室の夜は静かにふけて行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長がまた新聞を折り返す音を立てた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度襲おうとサメが折り返すたびに、ちぎられた肉片が輝いて見えた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五メートル・プールで四十回も折り返すのは、馬鹿げていると僕は思う。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百メートルで折り返すあたりで、僕としてはもっとも速いクロール泳法となっている。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
