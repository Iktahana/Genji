        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いま、この仕事を大急ぎで片づけてしまいますから、それまで鳥渡、待っていて下さいね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小僧も大急ぎで、その方に頭を突きだして笑つた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ナストウリ、モノサシトハサミ、カガミガアリマス、イケニフネ……」大急ぎでそれだけ読んだが、そこで息が切れた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて傘持たぬ一同、たとえ張子ならずとも風邪など引いては面白からねば大急ぎにて雷門前まで駈け付く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彩色と云っても絵具は雌黄に藍墨に代赭くらいよりしかなかったが、いつか伯父が東京博覧会の土産に水彩絵具を買って来てくれた時は、嬉しくて幾晩も枕元へ置いて寝て、目が覚めるや否や大急ぎで蓋をあけて、しばしば絵具を検査した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ともつともらしい顏で言ひ、「どれ、それではおれも刈つた柴を大急ぎで集めて、下山としようか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」牝狐は赤面して、大急ぎで巣の方へ走つた。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の方のバックには構内の倉庫の屋根が黒く聳えて、近景に積んだ米俵には西日が黄金のやうに輝いて居り、左の方の澄み通つた秋空に赤や紫や色々の煙が渦卷き昇つて居るのが餘りに美しかつたから、いきなり繪具箱を柵の上に置いてＷＣの壁にもたせかけ大急ぎのスケッチをしようとした。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大急ぎで此の瞬間の光彩を攫まうとして藻掻いて居る私には、とてもそんな人達にかまつて居るだけの餘裕はなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うから二人の役人が大急ぎで路をやって来るのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし何か自分の悪事が見付かって罰せられそうになると、大急ぎでその毒を仰いで自決をしようとする。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家は画室をあちこち駈け廻り枠なぞを倒し、紙の張りある板何枚かをひっくり返して、その一枚を画架に載せ、箪笥を引開け、チョオクの入れある箱を取出し、大急ぎにてかき始む。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）大急ぎでやらなくっちゃあ、駄目ですよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱心に、大急ぎで、切れ切れに話すうちに、何もかも不思議に向うに分ったのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、また私は幌無しの辻馬車が――臨終前の一時間といへども、ふだんの賃金どほりに二法で走るところの、幌をすつかり上げた、時間ぎめの辻馬車が、大急ぎでやつて來るのを一度ならず見かけたものだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓はじきそこに見えていても容易には村へ出ないので、日は暮れかかるし僕らは大急ぎに急いでしまいには走って下りた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　理学部会委員に約束しておいたのを忘れていて、今日最後の通牒を受けて驚いて大急ぎで書いたので甚だ妙なものになった。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　畜産の教師は大急ぎで、教舎の方へ走って行き、助手もあとから出て行った。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "慾張抜いて大急ぎで歩いたから咽が渇いてしようがあるまい、早速茶を飲もうと思うたが、まだ湯が沸いておらぬという。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで某殺人事件の種取りを命ぜられた記者は現場に駆けつけて取りあえずその材料を大急ぎでかき集めた上で大急ぎでそれを頭の中のカタログ箱の前に排列してそうしてさし当たっていちばんよいはまりそうな類型のどれかにその材料をはめ込んでしまう。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天災の起こった時に始めて大急ぎでそうした愛国心を発揮するのも結構であるが、昆虫や鳥獣でない二十世紀の科学的文明国民の愛国心の発露にはもう少しちがった、もう少し合理的な様式があってしかるべきではないかと思う次第である。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の中を駅前まで引き返し、自動車を見つけて、上諏訪、滝の屋、大急ぎでたのみます、と、ほとんど泣き声で言って、自動車に乗り込み、失敗、こんどの旅行は、これは、完全に失敗だったかも知れぬ、といても立っても居られぬほどの後悔を覚えた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩、私が黙って居ても、夕食のお膳に大きい二合徳利がつけてあって、好意を無にするのもどうかと思い、私は大急ぎで飲むのでありますが、何せ醸造元から直接持って来て居るお酒なので、水など割ってある筈は無し、頗る純粋度が高く、普通のお酒の五合分位に酔うのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三兄は、決してそのお仲間に加わらず、知らんふりして自分の席に坐って、凝ったグラスに葡萄酒をひとりで注いで颯っと呑みほし、それから大急ぎでごはんをすまして、ごゆっくり、と真面目にお辞儀して、もう掻き消すように、いなくなってしまいます。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大急ぎで扉をあけますと、その裏側には、「クリームをよく塗りましたか、耳にもよく塗りましたか、」と書いてあって、ちいさなクリームの壺がここにも置いてありました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親方のアーティストは、大急ぎで、フラスコの中の水を綿にしめしてその眼の下をこすりました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーティストたちは、あるいは戸口に立ち、あるいはたき火のそばまで行って、外の景色をながめてゐましたが、この時大急ぎでみんな私のうしろに集まりました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」楢ノ木大学士はびっくりして大急ぎで又横になりいびきまでして寝たふりをしそっと横目で見つゞけた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　嘉助は大急ぎで教室をはねだして逃げてしまいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と雀は、一銭銅貨をくわえて、おおいそぎで水車小屋の方へとんでいきました。",
              "citation": {
                "source": "落とした一銭銅貨",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
