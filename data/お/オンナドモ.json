    "definitions": [
      {
        "index": 1,
        "gloss": "women",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなかに男振りが少し佳く生れて來たばかりに、女どもが、かへつて遠慮しておれに近寄らない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一方には又これに反対して、なにを云うにも相手は茶店の女どもである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、不束なる女ども、猥に卿等の栄顧を被る、真に不思議なる御縁の段、祝着に存ずるもの也。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、女どもの言い争いは、いつまでもごたごた続いている。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キャ――ッ……」「おそろしいッ……」　と言う震え声の中に女どもが二、三人バタバタと遠退いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、そこで女どもをもちまして、お支度の儀を伺わせました処、誰方もお見えなさりませんそうでござりまして。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸は内へ、左右から、あらかじめ待設けた二｜人の腰元の手に開かれた、垣は低く、女どもの高髷は、一対に、地ずれの松の枝より高い。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姦通かな、親々の目を盗んで密会するかな、さもなけりゃ生命がけで惚れたとか、惚れられたとかいう奴等、そして男の方は私等構わんが、女どもはいずれも国色じゃで、先生｜難有いじゃろ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呆れたものいいと、唐突の珍客に、茶屋の女どもは茫乎。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷店、休茶屋、赤福売る店、一膳めし、就中、鵯の鳴くように、けたたましく往来を呼ぶ、貝細工、寄木細工の小女どもも、昼から夜へ日脚の淀みに商売の逢魔ヶ｜時、一時鳴を鎮めると、出女の髪が黒く、白粉が白く成る。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女郎屋の朝の居残りに遊女どもの顔を剃って、虎口を遁れた床屋がある。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一女どもが寄着かない。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遣手も、仲居も、女どもも驅けつけたが、あきれて廊下に立つばかり、話に聞いた芝天狗と、河太郎が、紫川から化けて來たやうに見えたらう。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女どもが、畏まると、「翌日は又おみおつけか。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩、腕車でお乗込み、天上ぬけに美い、と評判ばかりで、私等ついぞお姿も見ませなんだが、下男下女どもにも口留めして、秘さしったも道理じゃよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから下男下女どもがぞろぞろと従きました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火燧々々、と女どもが云う内に、（えへん）と咳を太くして、大な手で、灰吹を持上げたのが見えて、離れて煙管が映る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の女どもは門に立ち、または途中まで見送って「御機嫌よろしゅう……来年もどうぞ」……など口々にいっている。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙｜脆い女客などは、朝夕｜親んだ宿の女どもといい知れぬ名残の惜まれて、馬車の窓からいくたびか見送りつつ揺られて行くのもあった。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなかに男振りが少し佳く生れて来たばかりに、女どもが、かへつて遠慮しておれに近寄らない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつぱい女どもの愛からのがれてなにかの職業でもさがしてみよう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甍が翼を張りひろげて夏の烈日の空にかがやくとき僕等は繁華の街上にうじやうじやしてつまらぬ女どもが出してくれる珈琲店の茶などを飮んでる始末だ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和の高｜佐士野を七行く少女ども、誰おし巻かむ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つきまして、……ただいま、女どもまでおっしゃりつけでございましたが、鶫を、貴方様、何か鍋でめしあがりたいというお言で、いかようにいたして差し上げましょうやら、右、女どももやっぱり田舎もののことでございますで、よくお言がのみ込めかねます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、親仁がもっともらしい顔色して、ニヤリともしないで吐くと、女どもは哄と笑って、線香の煙の黒い、吹上げの沫の白い、誰彼れのような中へ、びしょびしょと入って行く。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳しゅうて笛吹は眇、女どもは片耳｜殺ぐか、鼻を削るか、蹇、跛どころかの――軽うて、気絶……やがて、息を吹返さすかの。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも無邪気に、すッと愁眉をひらいたのはおんなどもであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かのおんなどもがその芸名に仏くさい名前をつけていたのは婬をひさぐことを一種の菩薩行のように信じたからであるというが、おのれを生身の普賢になぞらえまたあるときは貴い上人にさえ礼拝されたという女どものすがたをふたたびこの流れのうえにしばしうたかたの結ばれるが如く浮かべることは出来ないであろうか。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
