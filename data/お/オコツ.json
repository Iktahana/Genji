[
  {
    "uuid": "ac3611e8-0df4-5a3e-9bf3-11a562875d13",
    "entry": "お骨",
    "reading": {
      "primary": "おこつ",
      "alternatives": [
        "おほね"
      ],
      "is_heteronym": false
    },
    "grammar": {
