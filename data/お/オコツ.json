    "definitions": [
      {
        "index": 1,
        "gloss": "cremated remains (esp. the bones)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すべて、山田君のお骨折のおかげであろう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きつとどこかの林の中に、お骨があるにちがひない。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方のお骨が納っているんですってね。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすれば、あたくしが引っぱってまいりますから」「おや、お嬢さんに、そんなお骨折りをしていただいては、申しわけありません」と、ヤルマールは言いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概な金持の子も引き上げさしてしまうというのに、よくもねえ、さぞ、お骨が折れましょう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこへあなたのご周旋だったので、ありがたくお骨折りを受け容れた次第です」　ここで私は更に男に訊ねて見なければ承知出来なかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中畑さんのお骨折りです。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それに、その細君というのが、はじめ画師さんには恋人で、晴れて夫婦になるのには、この学士先生が大層なお骨折りで、そのおかげで思いが叶ったと申したようなわけだそうで。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いいえ、技師の先生の方ですが、その方のお大事なものが残らず、お国でおかくれになりました奥様のお骨も、たったお一人ッ子の、かけがえのない坊ちゃまのお骨も、この中に入っていらっしゃるんですって。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "技師の旦那の奥様と坊ちゃまのお骨と聞いて、安心したも、おかしなものでございますがね、一軒家の化葛籠だ、天幕の中の大革鞄じゃあ、中に何が入ってるか薄気味が悪かったんで。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いずれ、あの糸塚とかいうのについての事だろうが、何かね、掘返してお骨でも。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもお骨折りでした」　Ａさんはにこにこして、封筒の中から原稿を取り出そうとした。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、近江から一人の卑しい老婆がのぼって来て、「王のお骨をお埋め申したところは私がちゃんと存じております。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお歯をご覧になりませば、王のお骨ということはすぐにお見分けがつきます」と申しあげました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お骨休めに一杯召上がって下さいまし。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角お骨折りなすったのに……」　多鶴子はそう言いながら、ふと、（結局この人は昨夜私を救うために、骨を折ってくれたということになるのだわ）と、思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、その証拠に、明日か明後日までにお骨を届けますから」「灰を見ても、わたし、やっぱり信じられないだろうと、なんか、そんな気がしてなりませんのよ」「とにかく、これは慰藉料、これは口止料というわけで、それから、これは給料の残り分です」　監督は三つの封筒を彼女の前に押し出して帰っていった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが熱心にお骨折り下すって、会社の有為な主脳部になっていただきたいんです」　私はその大きな本を小側に抱え、胸の中に矛盾した困惑した感情を持ちながらホテルに帰って来たのです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがあなたはそのステッキの頭に穴をおあけになって、それを頑丈な武器にお作りになるため、その穴の中に鉛をおつぎ込みになるには、ずいぶんお骨折りになったでしょう。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはお骨折をして下すつただけのお礼はしなくてはなりません。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃあさぞたいへんなお骨折りだったでしょうなあ」「そうでしたよ。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、仏様に御丹精は、それは実に結構ですが、お礼がお礼なんですから、お骨折ではかえって恐縮です。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先生、おつきあい遊ばすのに、貴方、さぞお骨が折れましょう。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非一つお骨折りをねがいます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がかりになどは少しもお思いになることはありませんよ」　などと源氏が言うと、「でもなかなかお骨の折れることでございますよ。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしお骨折により、拝見が叶いますならば、今生の面目この上もない事かと存じます。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お稽古に来る近所のお弟子にお教えになる外は、極く上等の押絵や刺繍のようなものばかりを作っておいでになりましたが、それでも中々沢山ある上に、手間の安い仕事の五倍も十倍もかかるような物ばかりなので、お忙がしくないように見えて、なかなかお骨が折れるのでした。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角のお骨折りでしたがね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Que veux-tu?」猫のおこつたやうな声で、子供が云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつはをとゝひから、めんだうなあらそひがおこつて、ちよつと裁判にこまりましたので、あなたのお考へを、うかがひたいとおもひましたのです。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
