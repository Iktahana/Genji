    "definitions": [
      {
        "index": 1,
        "gloss": "delicious-looking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "葛岡は、胸に溜まっていた誰にも話せない鬱積を漸く吐き出す緒口がついて来たので、とても元気が出たらしく、出た最初の皿をいかにも美味しそうに食べながら話し続けます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていかにも美味しそうに食べた。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう真黄に熟れて居る金柑が、如何にも美味しそうに見える。",
              "citation": {
                "source": "南風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそくなって、野菜スープやサラドを運んで行ったが、まさ子は、悦び、「美味しそうだこと――御馳走になって見ようか」と云うばかりで、ほんの一口飲み下しただけであった。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家政婦のお菊さんが、台所で美味しそうな五目寿司を拵えているのを見てとても嬉しくなった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "街中が美味しそうな食物で埋っているではないか！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉を焼く美味しそうな油の匂いがしていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の台所から夕方の美味しそうな匂いと音がしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十年配のいちょうがえしの女が、寝床に坐ってバットを美味しそうに吸っている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "店さきには、たらこや、鮭、棒だらなぞの美味しそうなものがぎっしり並んでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家政婦のお菊さんが、美味しそうなゴモク寿司をこしらえているのを見て、嬉しくなった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空っぽの茶碗を唇へあて、さも美味しそうに一吸いしたが、「上様お重ねなさりませ」　いってまたもや欠け茶碗を、上様の方へ押しやった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東さんは話終ると一服煙管にきざみをいれて、ぷうっと美味しそうに吸いました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは濛々と大きなお鍋から湯気が立って、傍目にはひどく美味しそうだったが、取柄といえば温いばかり。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るから美味しそうなものを召し上がっておいでなすってて、お給仕してても心持がいいや。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこのごろのひどい霜夜、師匠の供をしてかえってくるとき、きっと師匠は途中でそばやへ入る、でなければやた一のおでんやへ飛び込む、そうして熱燗でいっぱいやりながらそばやなら鴨南蛮か天ぬき、おでんやなら竹輪かがんもへ辛子をコテコテと付けてさも美味しそうにそいつをたべる。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと華奢な象牙の箸でギヤマンの大鉢の中の銀のような鱸の洗いのひと切れを、さも美味しそうに口へ運んだ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして迢空博士も客にすすめたからには、これも美味しそうに食べざるをえなかったらしい。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の絶間を見すまして、橋桁の下の闇へ這い込むと、「三ちゃん待って居たよ」　半面美人のお若が待って居て、「…………」　不機嫌な私に構わず、「今日は貰いがどっさりあったから、天プラを買って来たよ、お上り」　お若は私の身体へ凭れるように、鼻の先へ美味しそうな竹の皮を開くのでした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「立ってるのはこたえるもんさ」　美味しそうに素子がタバコを吸いはじめた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名だけきくと美味しそうだと大笑いです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからともなく肉の焼ける美味しそうな匂いがして来る――フト顔をあげると、それは宿屋の外壁で、窓の中には山のような御馳走と、温かい火と、楽しい歓談とがあった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ふるえつくように、彼女は二タくち三くち……四くち……さも美味しそうに飲みつづけた。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポーセはおいしそうに三さじばかり喰べましたら急にぐたっとなっていきをつかなくなりました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいしそうだったからな。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『おいしそうだね、お父さん』『待て待て、もう二日ばかり待つとね、こいつは下へ沈んで来る、それからひとりでにおいしいお酒ができるから、さあ、もう帰って寝よう、おいで』　親子の蟹は三疋自分｜等の穴に帰って行きます。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ああ、おいしそうだ、頬辺から、菓汁が垂れているじゃありませんか。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上には、いかにもおいしそうな、サクランボがのっていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンゴが、ジュージュー、おいしそうに焼けていました。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ガチョウの焼肉のおいしそうなにおいが、通りまで、ぷんぷんとにおっています。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
