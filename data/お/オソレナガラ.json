        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「恐れながら申し上げます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が浪打際で寄せたり退いたりしている浪に追いつ追われつしながら遊ぶように、自分は鏡のなかの伎楽の面を恐れながらもそれと遊びたい興味に駆られた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へゝゝゝ、恐れながら御意にまかせ、早速おん対手」と按摩が云ふ。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに心のさびしい暗い人間は、人を恐れながら人を恋しがり、光を恐れながら光を慕う虫に似ている。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と、と殿樣、片膝屹と立てたまへば、唯唯、唯、恐れながら、打槌はづれ候ても、天眼鏡は淨玻璃なり、此の女、夫ありて、後ならでは、殿の御手に入り難し、と憚らずこそ申しけれ。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　ははっ、ははっ、恐れながら、御神に伺い奉る、伺い奉る……謹み謹み白す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "媛神　（――無言――）神職　恐れながら伺い奉る……御神慮におかせられては――畏くも、これにて漏れ承りまする処におきましては――これなる悪女の不届な願の趣……趣をお聞き届け……媛神　肯きます。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "神職　これは、はや、恐れながら、御声、み言葉とも覚えませぬ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れながら、此時、先生の風采想ふべしで、「懷中はいゝぜ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時余は坪井学長に書面を奉て、恐れながら御成敗を願った。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家には、恐れながら未だ、真の恋のこころがおわかりなさらぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれにしては何様も様子が腑に落ち兼ねたから、恐る恐る進んで、恐れながら我が君には御落涙遊ばされたと見受け奉ってござるが、殿下の取分けての御懇命、会津四十二万石の大禄を被けられたまいし御感の御涙にばし御座すか、と聞いて見た。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この毒薬の瓶をもって、ちと古風な事だけれど、恐れながらと、遣ろうと云うのだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士　は、恐れながら、それぞれの予備の知識がありませんでは、自然のその色彩ある活字は、ペエジの上には写り兼ねるのでございます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿禰はそのおおせを聞いて、「では、恐れながら、今、皇后のお腹においでになりますお子さまは、男のお子さまと女のお子さまと、どちらでいらっしゃりましょう」とうかがいますと、「お子はご男子である」とお告げになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　恐れながら早急には……。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイカー街一一月二一日　　　吸血鬼の件拝復　一九日付のご来信について、当方、貴社依頼人ロバート・ファーガソン氏（ミンシン横町の紅茶卸ファーガソン＆ミュアヘッド経営）の調査を請け負い、案件を無事解決したことを恐れながらここに申し上げます。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあまりに短時間内に幾度も目をさました時には、もうこの暗い夜が再び明けないのぢゃないかと恐れながら、白く垂れ下ったカーテンの奥に目をすゑて、しのびやかに訪れて来る暁の足音を聞かうとした。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかすかな、そして最後と思われる希望が破られるのを恐れながらも、私は胸のところをはっきり見られるくらいにまで頭を上げてみた。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「恐れながら、恐れながら拙者とても、片時も早く、もとの人間に成りまして、人間らしく、相成りたう存じます。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは津の国屋の一件について、なにかの係り合いになるのを恐れながら、一方には常吉の来るのを迷惑には思っていなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし高島ほど根強い理由をもっていない梶井は、国へ返されるのを恐れながらも、さすがに思い切って浪人する気にもなれなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と呼びかけて、「恐れながら陛下には勇にのみ走つて仁を施すことをお忘れになつては居りませぬか。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "君も家へ退っていてくれ」　源氏が熱心に言うので、大輔の命婦は迷惑になりそうなのを恐れながら、御所も御用のひまな時であったから、春の日永に退出をした。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目につくことがあったらと恐れながら、例の癖で、六の君が後宮へはいった時から源氏の情炎がさらに盛んになった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が大金を所持しているのを知って、誰かうしろから追ってくるようにも思われて、かれは眼にみえない敵を恐れながら湯島から本所までひと息に駈けつづけた。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れながら殿様のお心を試そうとて……」「うむ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はお絹の怨みを恐れながらも、とうとう両国橋を渡る機会がなかった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおそれながらと罷り出て、汝の悪事を訴えて、首にしてやる覚悟しやあがれ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそれながら、陛下には、お着物をおぬぎくださいますよう」と、うそつきどもは言いました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
