        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "文六が一同に、Ｔ「各々方　此奴が　真の敵！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度秀吉方につくならば、各々方も大名に取立て、勝豊はゆくゆく、北国の総大将になるであろうなど、朝夕説くので、家老達の心も次第に動いて勝豊にまで励めることになった。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方平壌の二の舞を踏みたいわけではあるまいと。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや各々方、なかなかうまく、仕組んだと云うわけですか、――これはとんだ災難に遭ったものだ。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方に御披露するものがござった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、各々方が、志を合せて下されば何よりの幸いじゃ。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「各々方、静まられい！",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さて各々方、酒も大分廻つたやうだから、もう一ト踊りをどらうかえ……」「それとも犬奴の仕置にかからうかえ……」　……私は跫音を忍ばせて楽屋へ廻ると、賑ひは正しく縁の下なので、床にそつと腹匍ひながら板の間から覗き見た。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると中で一人がずいと進み出て、「静まれ、静まれ」と両手を高く挙げて一同を制し「さように各々方が争っては、誰がゆくことに相成っても不服の残るは当然のこと。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では申そう」と憎々しいまでに勿体をつけて「――実は、各々方は誰方も此拠に足をとめて行かぬこととなさるので厶る。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方近うお寄り下されい」　一座の人々は、甚之助を取り巻いた。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方も、御異存はないと思う」「異議なし」「異議なし」「同感」　銘々、口々に叫んだ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「各々方、今夜はお別れでござる。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方が、平生の覚悟を拝見しとうござる」　十二人までは、さすがに悪びれたところはなかった。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士は敵味方に別れても相身互いじゃと存じたによって、かほどまで寛大な取扱いをいたしたのは、われらが寸志じゃに、それが各々方に分からなかったとは心外千万じゃ。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方を信用したのが、拙者の不覚でござる」　隊長は、かなり憤慨して、開き直った。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拙者の計いで、各々方に、かほど自由を与えてござるのが分からないのか。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを立ち居も、各々方の随意にさせてある。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士たる各々方が、一旦、恭順を表せられた以上、万に一つ間違いはないと思ったからじゃ。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方にあのような不吉なものを見せて、なんとも申しわけがござらぬ。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方を処刑、そのような御沙汰は気もないことじゃ。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方、左様では御座らぬか――というんで、当時の人たちが寄ってたかってさんざんピンスボルグをきめつけて異端者あつかいにしたので、可哀そうなピンスボルグはそれを苦に病んだ末、とうとうこの自分の建てた塔のてっぺんから地上へ身を投げて儚ない最期をとげたとのこと。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方、よろしく」　一人の浪人が「一大事とは？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと各々方、この敵の仕打ちはまことに卑怯には相違ないが、この際平馬どのにもしものことがあっては、われわれ一同はまことに困却つかまつる。",
              "citation": {
                "source": "平馬と鶯",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんら無謀ではないのだ」「と、いって、敵は朝夕つけ狙っているし、平馬どのは平気だし、これは困ったことができたなあ――」　こう言ってみんなが考えこむと、すぐに平馬の声があとを引き取って、「各々方の忠言、まことにありがたい。",
              "citation": {
                "source": "平馬と鶯",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はこの鏡之介を相手にするから、各々方はこやつらを斬り散らして下されい」　すると、この声に応じて、橋の下の横柱から無数の黒装束が蟻の群のように、橋の上へ這い上った。",
              "citation": {
                "source": "平馬と鶯",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあ、各々方」「言うにや及ぶ、大岡は大岡、吾れわれは吾れわれ、ま、ここだけの話じゃが、拙者は、あの大岡殿の利才ぶった様子が、日頃から気に食わぬのじゃ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "各々方の船に灯をつけると平家方の目にもとまり、すわ、大勢押し寄せた、と警戒されるであろうから、この義経の船を本船として灯をつけるから、それを目標に航行せよ」　と義経は命令を下した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると実盛は、又昨日と同じ様に一膝のり出すと、「昨日、わしの言ったこと、各々方、どのようにお考えじゃ？",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「各々方、ご覧下されい、彼ら幼き者たちが余りに慕いまするので、あれこれなだめすかしているあいだに、気になりながらも遅れをとりました」　この言葉に並みいる一同は、鎧の袖を拭うばかりであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
