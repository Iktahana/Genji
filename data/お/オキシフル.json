        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ひどいのになると一日に五六度オキシフルか、昇汞水で手を消毒しないと、落付いて仕事が出来ぬというようなのがある。",
              "citation": {
                "source": "良人教育十四種",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝美さんは色が黒いので、オキシフルを綿につけては顔を拭いている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、アルコールランプや、オキシフルや、醤油や、アルコール、塩などは、溝口と云ふ商品陳列館の人に貰つて、これは大変役に立ちました。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の髪は毎日オキシフルで洗っておりますとあのように赤黄色くなるそうでございます。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてオキシフルの壜を手にしたまま、ステイムで蒸されてゐる息苦しい廊下のなかを歩きだす。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭いナイフ……安全剃刀の刄……アドルムの錠剤……オキシフル……絆創膏……繃帯……。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから落着いて、手首を洗い、オキシフルをふりかけ、絆創膏をはり、繃帯を巻き、その端を登志子に結わかせた。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてオキシフルの壜を手にしたまま、スティムで蒸されている息苦しい廊下のなかを歩きだす。",
              "citation": {
                "source": "恢復期",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女丙　　ちよつと、オキシフル、もうないぢやないの。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は指先をオキシフルで拭い、ピンセットを取って、妻の傷口からガーゼを取り出す。",
              "citation": {
                "source": "日を愛しむ",
                "author": "外村繁",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
