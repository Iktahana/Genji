        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "適切な予防措置および適切な役務との交換を条件に、大型飛行船ないし、大道を行くボートに似た形の原子力駆動の大型車に搭乗して、居住地区全部を彷徨することが認められ、この惑星の過去と未来の記録を収めた図書館で思うがままに没頭することができた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型車だって、ゆっくり這入れる。",
              "citation": {
                "source": "記憶",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型車が騒音をたてて到着すると、助手席に飛び乗った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "突っ立って見ていると、大型車だ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型車がデンと置かれ、棚には始動に必要な部品があった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "直後、スペンサ愛用の大型車がフェアフォードへ走り去った。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の通りで金色と緑色に塗られた大型車が待っていた。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "大型車を走らせ一時間ばかり在宅し、気分を変えることが最高の強制剤だといつも言っていた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時近くになり、ルペラ男爵が大型車でご帰還になり、遅れたことをわびた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに小屋はとても温かいですよ」　大型車が道路を行けども行けども無人だ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
