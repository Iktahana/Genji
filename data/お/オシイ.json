[
  {
    "uuid": "490aab36-9e4e-5269-88af-a6e319537379",
    "entry": "惜しい",
    "reading": {
      "primary": "おしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
