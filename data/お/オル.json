[
  {
    "uuid": "5d0eef32-e132-5054-89eb-bfa22347bdbc",
    "entry": "織る",
    "reading": {
      "primary": "おる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
