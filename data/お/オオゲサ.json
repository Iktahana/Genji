        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大げさな言ひかたをすれば、人間の生き拔く努力への聲援である。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無責任に大げさな、甘い觀念論で、諸君を騙さうとして居るのでは無い。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と書きたてるほど大げさなことでもないのに、それをそれほど有名にしたのは、まつたく、その男の――つまり、その歴史の時間での先生である溝口文学士の性格によるのでした。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と大げさに贊めそやす。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「支配人がやる商売ならどんなに大げさにやらかしたって、一向、見て見ぬ振りをしとくって云うんだが、親爺のようなぴい／＼のするこたア、いけねえって云うんですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でもあの音を思い出すとなんとなく一種の――神秘的というのはあまり大げさかもしれぬが、しかしやはり一種の神秘的な感じがする。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、大げさではない、妙な歩行きかただ、と、誰方も思はれようと考へる。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりが、なにか言いだすと、そのたびに、だんだん大げさになっていきました。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしたちのくちばしには、大げさな言葉はないけども、同情する気持においては、負けやしないよ。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿世紀の写実とは、あるいは概念の肉化にあるのかも知れませんし、一概に、甘い大げさな形容詞を排斥するのも当るまいと思います。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大げさな言いかたで、自分でも少からず狼狽しながら申し上げるのであるが、謂わば、詩と真実以外のものは、適度に整理して叙述した、というわけなのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながい遠吠えやら、きゃんきゃんというせわしない悲鳴やら、苦痛に堪えかねたような大げさな唸り声やら、様様の鳴き声をまぜて騒ぎたてた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と松さんは大げさにいつて、酔で赫らんだ顔を向けてそちらを見た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」数枝は、ことさらに大げさなあくびをした。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大げさな身振りでなくともよい。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて、がらっと机の引き出しをあけ、くしゃくしゃ引き出しの中を掻きまわして、おもむろに、一箇の耳かきを取り出し、大げさに顔をしかめ、耳の掃除をはじめる。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹越氏が正直に下げる頭が大げさでもわざとらしくはなかった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは額を押されてよろめく風を大げさに見せながら「ひどいわ」といった流眄をこの少年期から青年期へかけて育ち盛りの白痴の乞食に浴せます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」するとかの女はそういうわたしの顔を怪訝に見上げながらわたしの襟を揺り「どうしてこれっぽっちの事で、そんな大げさなことを言うの。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子夫人は黄い声になり大げさに梯子の必要を前の家の左官のおかみさんに説き、中位なのを一つ借りて来て男に手伝わせ国枝さんの湯殿の上部の硝子窓に届かせ、少し腰弱そうな男のために梯子の下部まで押えてやり、硝子戸をうまくこじ開けさせて、男を家の中にいれてやりました。",
              "citation": {
                "source": "おせっかい夫人",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大げさに言えば此処の宗祖――とも言うべき寺のあるじのダルケ氏は、もう歿して居ないのである。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社がありましてね、そこで大げさに製らえて分けるんです。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話す時、大げさな身振りをするので此方が恥かしくなるわ。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな雑沓の中でも平気で京子は歩くかと思えば、たまにたった一人に逢って斯んな大げさな驚きをすることもある。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めその婦人達は先客としての日本の男女を紹介されてちょっと気負いを挫かれた形だったが、直き又揃えたような美貌を正面に立ててガルスワーシーに逢えた光栄を得意の英語の大げさな口調でしゃべり始めた。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "声も大きいが、身振りも大げさで、何か身につかぬ笑い方だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　　　＊　と、町へ入る左口、とある広場に、これはまた大げさな灰色の天幕。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分大げさな出立をしたものとみえ、『多聞院日記』に「東国御陣立とて、万方震動なり」とある。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の生徒たちは、「おおげさなまねをする奴だ」というように、柿江の笑いに同じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　青扇は、うしろにひっそりたたずんでいたやや大柄な女のひとを、おおげさに顎でしゃくって見せた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
