[
  {
    "uuid": "8c7626e3-b2aa-5c63-a7fa-e52368c7370e",
    "entry": "女山",
    "reading": {
      "primary": "おんなやま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gently sloping mountain (of the less rugged mountain of a pair of mountains)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「くいし（山名）へ行くにはどっちですか」「神社」「アツマコート」「小女山道」「昼飯」「牛を追う翁」「みかん」「いこいつつ水の流れをながめおれば、せきれい鳴いて日暮れんとす」など、とり止めもない遠足の途中のいたずら書きらしいものもある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あれあれ、」　女山伏の、優しい声して、「思いなしか、茸の軸に、目、鼻、手、足のようなものが見ゆる。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見さくるや童が眉に、霞引く女山・清水。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯山に出でた謙信は、善光寺にも止らず、大胆不敵にも敵の堅城たる海津城の後方をグルリと廻り、海津城の西方十八町にある妻女山（西条山ともかく）に向った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国街道の一軍は、善光寺近くの旭山城に一部隊を残し、善光寺から川中島を南進し、海津城の前面を悠々通って妻女山に到着した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の名将｜高坂弾正昌信の守る堅城の前後を会釈もなく通って、敵地深く侵入して妻女山に占拠したわけである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし妻女山たる、巧みに海津城の防禦正面を避け、その側背を脅かしている好位置で、戦術上地形判断の妙を極めたものであるらしい。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十六日妻女山に着いた謙信は、日頃尊信する毘沙門天の毘の一字を書いた旗と竜の一字をかいた旗とを秋風に翻して、海津の高坂昌信を威圧したわけである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、上田に於て、軍議をこらして、川中島に兵を進めるや、これまた謙信に劣らざる大胆さで、謙信の陣所たる妻女山の西方を素通りして、その西北方の茶臼山に陣した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄大いに喜び、斥候を放って、妻女山の陣営を窺わせると、小鼓を打って謡曲『八島』を謡っている。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の方が、妻女山と旭山城との敵軍に挾撃される事を心配したのかも知れない。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、信玄は海津城に謙信は妻女山に相対峙すること十余日に及んで、いつか九月九日｜重陽の節句になった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二万の御人数の裡、一万二千を以て、西条村の奥森の平を越え倉科村へかかって、妻女山に攻めかかり、明朝卯の刻に合戦を始める。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄、高坂弾正、飯富兵部、馬場民部、真田幸隆等に一万二千を率いしめて、妻女山の背面を襲わしめ、謙信が巣から飛び出す処を打とうと云うのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しのびの兵」（透波間諜）のもち来る情報も入ったので、甲軍が隊を二分し、一は妻女山の背後に廻り、一は川中島に邀撃の計画であることが分ったので、我先ず先んじて出で奇襲を試みようと決心した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "全軍粛々妻女山をくだり其状長蛇の山を出づるが如くして狗ヶ瀬をわたった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "只、甘粕近江守は妻女山の北赤坂山に止り、後押として敵を警戒しつつ、十二ヶ瀬を渡って小森附近に止った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方妻女山には陣中の篝火は平常通りにやかれつづけ、紙の擬旗が夜空に、無数にひるがえっていた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘粕隊は遠く南方小森に於て妻女山から来るべき敵に備えた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻女山に向った甲軍は、地理に明かな、高坂弾正が先導で、月の西山に没する頃には海津を発し倉科の山越しに妻女山へむかった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、一万二千の大軍であるから夜明け前に妻女山に到着する筈であったのが、はるかに遅れた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ信玄は腰をかけたまま妻女山をにらんで何等かの変化を期待している。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "原大隅守は殊勲の槍を高くあげて、「今妻女山より味方の先手衆駈けつけたぞ、戦いは味方の勝ちぞ」と叫びまわった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方妻女山に向った甲軍は午前七時頃妻女山に達し足軽を出して敵に当らしめたが山上｜寂として声なく、敵の隻影もみえない。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで主将謙信は広瀬の方面に敵を圧迫していた諸将に速に兵をおさめて犀川方面に退却するよう命じ、親らも柿崎等と共に背後の妻女山を迂廻して来た甲軍に当りつつ退いた。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "高坂は妻女山より自分の持城たる海津城を気づかってこれに向い、それより八幡原に出たので、時すでに敵を犀川方面に追討している時だったので、甘粕隊をみてよき敵にがすなとばかりどっと突撃した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六世紀にレオ・アフリカヌスが著した『亜非利加紀行』に婦女山中で獅に出会うた時その陰を露せばたちまち眼を低うして去るとある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "男山、金峯山、女山、甲武信岳、などの山々も残りなく顕れました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
