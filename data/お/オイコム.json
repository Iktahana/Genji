[
  {
    "uuid": "8a96a17c-4f69-5d57-bc79-ceece3770ab1",
    "entry": "追い込む",
    "reading": {
      "primary": "おいこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
