    "definitions": [
      {
        "index": 1,
        "gloss": "to grow old",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "膝關節疼痛さへ起すこと多きに、あゝわれは既に老いたるか、もはや高山に上る能はざるかと、自から歎息せしが、いや／＼まだ老い込む年でも無し。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした、いやにしょげてるじゃないか」「どうかしたか」「まだ老い込むには早いぜ！",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれが老い込むと、色鍋島は亡びるぜ、つまりは、そっちの損にもなる」「分っておりまする」使者の頼母は、さっきからムカムカしている我慢が、フッと顔に苦く出たので俯向いたが、ぴったり、胸を張って改まった。",
              "citation": {
                "source": "増長天王",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぼそい少年正太と、傷ついている帆村とを洞穴においこむことぐらいなにほどのことでもなかった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "林さんは、ふたりをそこへおいこむと、いり口のとびらにガチャンとかぎをかけました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（c）わたしの腎石はしつこいやつで、特に尿道に引っかかると、往々にして三日にも四日にもわたる長い小便づまりに、わたしをおいこむ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
