        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お互ひ批評が多すぎるよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これらの作家によって、現在までに生産された文学は、単に量のみを問題としても、我国人口の大部分を占める巨大な農民層に比して、決して多すぎるどころではない。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チット人数が多すぎるぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甦生した新しい茂兵衛が出現して対面してから、この思い出す瞬間までのカットの数が少しばかり多すぎるから思い出しがわざとらしくなるのではないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいてお金を絶対に取らないのかというと、どうしてどうして、どんなに差上げても多すぎるとは言わない。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」教授には、そのあくびの多すぎる囘數を事實かぞへてみたやうな氣がしてゐるらしかつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これくらいならば普通であるかもしれないが、岱水の場合は少し多すぎるように思われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には下足番みたいなコセコセした批評家が多すぎるよ」　そこでまた新しい煙草に火をつけて、「――だから、僕アこんどの小説でもだね……」　と、ちらりと机の上の原稿用紙を見た。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小言幸兵衛が多すぎる。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る農家で、おかみさんが皿に米をいつぱい盛つてくれた、くれやうが多すぎるから何かあるなと思つてゐたら、果してさうだつた、小さい子に鉄鉢をいたゞかせてくれといふ、消災呪を唱へてあげた、此頃は鉄鉢をさゝげてあるく坊主も稀だし、また子供が頭剃を嫌はない禁厭として鉄鉢をいたゞかせてくれといふ事も稀である。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、それさえも、きびしくいえば、まだまだ多すぎるというのです。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェの場合にあつては、この禁物が多すぎる為、詩がまるで理窟っぽい警句のやうなものになつてしまつて居る。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人が今日の社会に望むものは、民衆と同じ側に立って演説する人――彼等はあまりに多すぎる――でなくして、むしろ彼等に対抗し、反対の側に立っていながら、しかも根柢の足場に於て、民衆と同じ詩的精神の線上に立っているところの、一の毅然たる風貌を有する人物である。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多すぎるぞ、これあ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "観瀾山から、それが全部見えるといふわけではないが、蟹田には、どうも建設の途中で投げ出した工事が多すぎるやうに思はれる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、津軽には、義経の伝説が多すぎる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がねちねちして理窟が多すぎるし、あまりにも私を意識しているゆえか、スケッチしながらでも話すことが、みんな私のことばかり。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は、いい人なんだろうけれど、ゼスチュアが多すぎる。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいお前は駄洒落が多すぎる。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行の一支店が保有するには、あまりにも多すぎるものですから……重役会でも問題になっていたんですが。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い気もちになった」「まだお酒がすこしありますが、沸かしましょうか」「もうけっこう、わしは一合で多すぎるくらいじゃ」「では、ここへ飯鉢と茶を置きますから、どうぞごゆっくり」　女は艫の方へ引きさがって往った。",
              "citation": {
                "source": "参宮がえり",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みじめな人が多すぎるよ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮にお預けしておくことは安心なようではあるが、年の寄った女房があちらには多すぎるから、同化されて若い人の慎み深さがなくなってはと、もうそんなことも考えなければならない年ごろになっていますから」　こんなことを言って、にわかに雲井の雁を迎えることにした。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸なことには我国には、あまりに超現実派の立派な絵画が多すぎる、日本画の伝統は将にそれであつて、日本画の中には、実にすぐれたシュルレアリズムの絵画が多い、現在の若い洋画家は、日本画の超現実性は勿論否定もするだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在はあまりに半日本人や、変形日本人が多すぎるとき、彼放庵に逢ふと、やれ／＼こゝに「日本人の典型」が残つてゐるといふ安心さへ湧く。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞に、佐藤君が稿料が多すぎると云ふのなら、云ひ出し鬼と云ふこともあるから佐藤君自身稿料を制限してその俑を開いて貰ひたい。",
              "citation": {
                "source": "よしなし事",
                "author": "〔源内の手紙、原稿料のことなど〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間を見渡すに、実に、批評が多すぎる。",
              "citation": {
                "source": "批評的精神を難ず",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせつかいが多すぎる。",
              "citation": {
                "source": "批評的精神を難ず",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "政策　社会の為めにする政策は多すぎるほどある。",
              "citation": {
                "source": "野の花を",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一年にたったいちどだけ、うたわせることになったのですが、それさえ、おおすぎるというのです。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
