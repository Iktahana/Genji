    "definitions": [
      {
        "index": 1,
        "gloss": "son of a distinguished family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
