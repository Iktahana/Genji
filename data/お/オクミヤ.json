    "definitions": [
      {
        "index": 1,
        "gloss": "rear shrine (located behind the main shrine, but dedicated to the same deity)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
