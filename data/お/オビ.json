    "definitions": [
      {
        "index": 1,
        "gloss": "obi (kimono sash)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "例へば茲に一農学士があり、非常に立派な耕作法を学び、百姓に教へに行く任務を帯びるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に透明な青味を帯びた、美しい貝のやうな詩である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどいのになると、独身だか妻帯者だか、わからない人物もあります。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も山も新緑で、はだかになってしまいたいほど温く、私には、新緑がまぶしく、眼にちかちか痛くって、ひとり、いろいろ考えごとをしながら帯の間に片手をそっと差しいれ、うなだれて野道を歩き、考えること、考えること、みんな苦しいことばかりで息ができなくなるくらい、私は、身悶えしながら歩きました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の足もとに、真赤な麻の葉模様の帯をしめ白い花の簪をつけた菊ちゃんが、お給仕の塗盆を持って丸く蹲って馬場の顔をふり仰いだまま、みじろぎもせずじっとしていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで綺麗な着物と帯とを買えば、きっと佐野次郎のことを忘れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はわけのわからぬ言葉を発して、携帯の風呂敷包を下駄箱の上に置き、素早くほどいて紋附羽織を取出し、着て来た黒い羽織と着換えたところまでは、まずまず大過なかったのであるが、それからが、いけなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯も、緑色の兵古帯でした。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは好いが君、君その指の繃帯は如何した」「一寸ナイフで切りましたから……」「Ｓ子は今内にゐませんから夕方いらつしやい……」　さう言つて二人は別れたが、彼にはその従兄の言葉が何時までも問題になつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう「御大事になさい……」といふ挨拶をされた晩から、三週間ばかりも経つてゐるが、そして指のキズは従兄のためにはもはやトツクに癒つて好い頃だが、いまだにＳ子の所に行く時、彼は繃帯をして行く……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で悪い屑屋に雑誌を出すと、いきなり帯をしてハカリに掛ける。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この股旅小唄の主旋律は、概して皆尺八的、浪花節的哀傷を帯びてるもので、日本人の民族的リリシズムとも言ふべき、旅への放浪情操をよく表現して居た。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが最後の絶筆でなかったならば、更生の蕪村は別趣の風貌を帯びたか知れない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にその飛翔している空を通して、遠望に富士を描き出しているので、山麓の小屋と関聯して、平原一帯の風物が浮びあがって来るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に夏の部で評釈した句「五月雨や御豆の小家の寝醒めがち」も、どこか色っぽい人情を帯びてはいるが、詩情の本質においてやはりこれらの句と共通している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愚に耐えよ」という言葉は、自嘲でなくして憤怒であり、悲痛なセンチメントの調を帯びてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スケッチ風のさらりとした句で、しかも可憐な詩情を帯びてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに好い加減古びてゐるのと場所柄とで、何となく物寂びた雅致を帯びて、静かな廃屋といつたやうな情趣がある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服屋には美しい帯が飾ってあった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日ちらと見た紙屋の娘の帯に似ている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために物語はいっそう古雅な詩的な興趣を帯びている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は黄金を飾った兜をきて、白地に金の十字をあらわした盾と投げ槍とを持ち、腰にはネーテと名づける剣を帯び、身には堅固な鎖帷子を着けていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして顔の血潮をぬぐって見ると頬は紅を帯びて世にも美しい顔ばせに見えた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の血がフンドの指の間を伝い上って彼の傷へ届いたと思うと、傷は見るまに癒合して包帯しなくてもよいくらいになった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八の屋根に鶏鳴きて雨を帯びたる風山田に青く、車中には御殿場より乗りし爺が提げたる鈴虫なくなど、海抜幾百尺の静かさ淋しささま／″＼に嬉しく、哀れを止むる馬士歌の箱根八里も山を貫き渓をかける汽車なれば関守の前に額地にすりつくる面倒もなければ煙草一服の間に山北につく。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時山奥のまた山奥から出て来た病人でどの医者にも診断のつかない不思議な難病の携帯者があった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿命と言い、縁と言い、こんな言葉を使うと、またあのヒステリックな科学派、または「必然組」が、とがめ立てするでしょうが、もうこんどは私もおびえない事にしています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ蕭条たる秋の夜半に、長く悲しく寂しみながら、物におびえて吠え叫ぶ犬の心は、それ自ら宇宙の秋の心であり、孤独に耐え得ぬ、人間蕪村の傷ましい心なのであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を入れば萩先ず目に赤く、立て並べたる自転車おびたゞし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
