[
  {
    "uuid": "39873880-cc5c-59bc-aab4-b2f375876e65",
    "entry": "怒らせる",
    "reading": {
      "primary": "おこらせる",
      "alternatives": [
        "いからせる"
      ],
      "is_heteronym": false
    },
    "grammar": {
