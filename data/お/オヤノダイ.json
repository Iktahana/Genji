[
  {
    "uuid": "b35f767c-fac2-51d7-85cd-b5e21a7cbe1f",
    "entry": "親の代",
    "reading": {
      "primary": "おやのだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
