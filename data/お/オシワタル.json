        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "月や星の光もぼやけ、闇の黒さも艶を失い、大地の上を押し渡る微風も息をつき、あらゆる物音が消え失せる。",
              "citation": {
                "source": "真夜中から黎明まで",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなつまらぬ事でも名人となると、それで世界を立派に押し渡ることが出来るものだとつくづく感心したよ。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽道へ向い進発した討手は、備中の水島の瀬戸に着いた、ここから屋島へ一気に押し渡るつもりである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その水幅は五十間足らずであるが、人馬の背丈であるから押し渡るとすれば、ぜひともそこでは、多数の犠牲者を出さねば渡河は難しかろうという。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そのうち物見の情報に「数里の先にも敵を見ず」とあったので、全軍、夕川を押し渡る。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
