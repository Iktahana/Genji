    "definitions": [
      {
        "index": 1,
        "gloss": "kitchen maid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
