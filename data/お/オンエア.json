        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これで、九月になったら、ＫＷＴＳは、日本の局ではあまりかからないめずらしい曲や、八月に出たばかりの最新の曲を「オンエア」できるだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが通常オンエアできる範囲を超えて「ハイブロウ」な番組を作るための口実になったのだ。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "オンエアされる詩、それは縞々のズボンを履いた美神たちのように聞こえる。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
