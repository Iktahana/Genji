        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「failing to recognize someone」である。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「failing to recognize someone」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「failing to recognize someone」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "failing to recognize someone」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お見それ申しましたよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見それ申して相済みません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに、お見それ申したわけであった。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あら、お店の前の袖垣に、朝顔の咲いた、撫子の綺麗だった、千草煎餅の、知っていますとも――まあ、お見それ申して済まないことねえ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　良寛さんは改めてお辞儀して、お見それしましたと挨拶した。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……失礼だが、まるっきりお見それ申したがね。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――貴女は、（おなじく眠れるがごとき目のまま）つい、お見それ申しましたが、おなじ宿にでもおいでなのですか。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見それ申しやした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご評判は存じながら、お見それいたして失礼つかまつった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえどうぞして逃げ出そうと思うておりましたところへ、この騒動が降って湧きましたゆえ、これ幸いとあそこの蔭まで参りましたら――お見それ申してお恥ずかしゅうござります。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついお見それ申しやして、とんだ口をききました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうとは知らず、わちきにも似合わないお見それをいたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘太郎　とき／″＼錢湯でお目にかゝつてゐながら、ついお見それ申しました。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、どうもお見それ申しまして、とんだ失礼をいたしました。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か御用でお出でですか」と、いったようなことで、ちょっと挨拶に困ったが、実は踊りの稽古をしてもらいたいので出ました、と自分が直ぐ表通りの仏師屋の弟子であることを話すと、なるほど、お見掛けしたお顔だが、お見それして失礼です。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "遊芸には縁のなかったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもお見それ申しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見それ申して、飛んだ失礼をいたしました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうちゃんもぼんぼんも成人しやはりまして、ほんまにうっかりするとお見それいたします。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははは、何もああまで誤魔化そうとするにも当るめぇに」　　　　　四「望月の旦那ぇ」「へぇ――おや、お見それ申しやして、へっへ、何誰さまでげしたかな」「いや、年は老り度くねえだよ。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶の者は、そう聴くと、これは、悧巧な江戸ッ子流――三郎兵衛の側に近づいて、鉢巻を外して、「こいつは、お見それいたしやした。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しいともなつかしげに、「これはこれは露月先生、ついお見それいたしました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、これはお見それいたしまして、たいへん失礼しました」　帆村はそういって、頭を掻いた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すつかりお見それして居りましたの……こんどお閑でしたら、宅へもお遊びにいらしつて下さいませ」　扁理は、自分が夫人に思ひ出されたことを知り、その上さういふ夫人からの申し出を聞くと、一そうどぎまぎしながら、何かしきりに自分もポケツトの中を探し出した。",
              "citation": {
                "source": "聖家族",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くどいねえ、その通りさ」「お見それ致して申し訳もない儀」　と不意に小平が一礼した。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらの姐御か知りませんが、とんだお見それ致しました。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、これはお見それしました。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "失敬じやないか」といつた時に熊は、やつと気がついて「やあ、ライオン様でございましたか、昨日まで、お見受け致してゐた、あなたのあごひげがないので、ついお見それしたのです。",
              "citation": {
                "source": "ライオンの大損",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも道づれになつてやる」　全然落付き払つて、退屈しきつて、見たこともないタイプだから、薄気味悪くなつて、お見それしました、と引上げる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こんな藝者は珍らしいねえ」「えゝ、田舍もこのへんになると、變り種なのがゐますわ、わたしみたいに……」「いや、おみそれいたしましたよ」　土龍は、大判の麻のハンカチで、つるりと顏を拭きながら、小糸に酌をさせて、ぐつと二三杯あふつてゐる。",
              "citation": {
                "source": "雪の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん粋な恰好でいらつしやるから、ついおみそれしました。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
