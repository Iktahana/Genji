        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "晩夏の一日、私が奥社に詣でたとき、逆川のほとりの茶店に、新聞紙の上に一杯黄色い小さな蕈を干しているのを見た。",
              "citation": {
                "source": "月夜のあとさき",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが本社で、頂上が奥社になつて居るのであらう。",
              "citation": {
                "source": "初旅の残像",
                "author": "安倍能成",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
