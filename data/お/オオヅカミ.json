        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "下編　其の適用　　　　　　　　　一　近代の文学を最も大づかみにわけるならば、古典主義、浪漫主義、自然主義の三つに分けることができるであらう。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は文学は科学的に、方法的に研究し得ることを前提として、如何なる方法を適用すべきかを明かにし、極く大づかみにこれが応用を試みたのである。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその目安書というのが今日の刑法などに比べると余ほど大づかみに出来ていますから、なにか毛色の変った不思議な事件が出来すると、目安書だけでは見当が付かなくなって、どんな捌きを下していいのか、係りの役人どもはみんな頭を痛めてしまうんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年間の多産豊饒な漱石の文学作品を見渡すと、ごく大づかみないいかたではあるが、藤尾風な趣味的・衒学的女は初期の作品に現れただけで姿を消し、藤尾の性格の中から、ゴーチェの「アントニイとクレオパトラ」を愛読するロマンティックな色彩をぬき去った女の面が、次第に現実的に発展させられて来ている。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には、小説は学問や教養で書くのではない、という、創作における教養の役割を否定的に見た人々があり、その大づかみな分けかたの中には自然主義から発足した作家たちも、白樺のように人間性にじかに立って自分の声を生のままで育てようと努めていた人々も入ったと云える。",
              "citation": {
                "source": "作家と教養の諸相",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明というと、たとえば十六世紀の日本の文明に二十世紀日本の文明を対比しているように、非常に大づかみにある時代なり社会なりの到達した人智開発の水準を概括して呼べると思う。",
              "citation": {
                "source": "婦人の文化的な創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつながった運命の大づかみな色合いというものも、周囲としては略想像することが出来る。",
              "citation": {
                "source": "知性の開眼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディフォーメイションは大づかみにいえばそのものとして発展する新しさを失った、近代の資本主義の社会の現実の中で、それを本質的に飛躍させる力をもたない精神が物憂く非人間的な現実からの脱出をもとめてもがきまわった、落着きない眼玉にうつった事象である。",
              "citation": {
                "source": "ディフォーメイションへの疑問",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、何ということもない雑談の間に、夫人が西村家の明治時代らしく、大づかみで活溌な日常生活の中で成人された幼女時代の思い出や、妻となり母となってからの生活の感想を理解するようになった。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大づかみに、ぐんと人生を掴まず視点が揺れ、作家としての心が弱すぎた。",
              "citation": {
                "source": "有島武郎の死によせて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし日記ていに記すことは正確なかわりに、読者にとつて煩わしいと信ずるから、大体のことを大づかみに述べておく。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを大づかみに一括して「趣味」といふのだらうが、自分に出來ないことを羨ましがるのも、いい意味での趣味だ。",
              "citation": {
                "source": "水",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙覧は、それでも、この大づかみなもの言ひを自分の代表的なものと考へたのであらう。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が、祭りについての大づかみな話である。",
              "citation": {
                "source": "ほうとする話",
                "author": "祭りの発生　その一",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、甚だ大づかみな観方から、此の問題に答へることを許されるならば、私は次の如く答へよう。",
              "citation": {
                "source": "過渡時代",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私はこれから、自分の専門である仏蘭西劇を中心として、できるだけ大づかみに、近代劇の血統を尋ねてみることにしよう。",
              "citation": {
                "source": "近代劇論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "きわめて大づかみの分り方しかできないのである。",
              "citation": {
                "source": "将棋の鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで此一首の調べも、重厚で、浮々していないし、また憶良の歌にしては連続流動的声調を持っているが、ただ後代の吾等にとっては稍大づかみに響くというだけである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大づかみに結末だけおつたへしておかう。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう大づかみの説でやって行ければ、万事Ｏ・Ｋですむであろう。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "天真らんまんな、大づかみの美が、日常性の健康さを以て表現されている。",
              "citation": {
                "source": "美の日本的源泉",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝費も割り安で当たり外れのハバの小さい作家にたよって、そう大づかみでなくとも、確実な利益を得る近道を行くよりほか、資本の安全の保証はない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "細かい点は抜きにして、大づかみに説明することにしますが、まずこの地所は、平均して二分以上の利をあげてはいない。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上が原子構造論、即ち近代原子物理学の素描であるが、この学問は案外歴史が浅く、極めて大づかみにいえば、今世紀にはいって軌道に乗り、約三十年のうちに、一応の完成を見るまでに発達したのである。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上が私の最も大づかみな観測だ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、大づかみに地理を見ます。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが、本をよめなかった間に得たものの価値について云ってらっしゃることは、大づかみではあるが私にも推しはかることが出来ないとは思いません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば一つの大づかみの創作の理論と方向とは何人かに共通なものとしてあるわけですが（今日でも）そのなかで、チェホフの所謂自分の線というものを、持味という範囲より高めて文学史的見地から描き出してゆくものは、なかなかないわね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、丈夫な人が病きの人を思いやる時は、大づかみで楽天的で、何となし何とかなるやっで呑気でいいことね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "物慾も大いにありますし、何か大づかみな計數は持つてをるつもりなのです。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
