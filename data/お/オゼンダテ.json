        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「まだほんとうにお膳立てが出来ねえからな」　庄太に案内させて、半七はまず馬道の鼻緒屋をたずねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄哥のために姉さんが、お膳立てしたり、お酒買ったりよ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何のことはない、お膳立てをして、御馳走にあづからなかつたも同然だ、なア」と老人もがツかりした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあの娘さんはウードレーを、飲んだくれの悪漢ときめてしまって、てんで相手にはならない、――その中に君があの娘さんに恋をしてしまって、君たちのお膳立ては、すっかりと覆ってしまうこととなった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず早ければあすの朝、お膳立てに手間をとれば夕方あたり、――果報は寝て待てじゃ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイトなら、じぶんでお膳立てしろよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とはいえ、わたしがしきりに気をもんで、いろんな計画を立てているうちに、運命はちゃんとお膳立てをしてくれたのである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして書記會議で何から何までお膳立てをして中央委員を虱つぶしに説いてまはつて無理矢理に島田支持にして了つてさ、あの日の中央委員會を自分たちの都合のいいやうに牛耳つたんだ。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の話もある程度お膳立てして、村當局の力を借りなくても私自身の力でもやれるといふ所を見せるんでなくちや、熱心にはなるまいと思ふんです。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　クルベーという独逸の貴族は、新しい軍器などを取扱って盛大にやっていたものらしいが、支那の当路へ軍器を売り込もうとして、財産のほとんど全部を品物の購入や運動費に投じて、すっかりお膳立てが出来たところで、政府筋と支那との直接契約が成立してしまった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの勢力の強力な牽引力に打ち勝つことの出来ない民衆をして、その牽引力の一応の支配下にも拘らずなおかつ自主的な結合のプログラムを進め得させるために、社大党は一定のお膳立てをしなければならぬだろう。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、すべては私達商売人にとって、あまりに幼稚なお膳立てでした。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に作り上げたり、お膳立てをしてやつたりする方法は避けたいと思ひます。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸のものずきが行って、あらかじめお膳立てをしておいて、それを上州名物の名で、江戸へ繰込ませようという寸法であるとは受取れる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで料理を根本的に進め、本格的なお膳立てをしようと思えば、どうしても、それらの骨董品でも使用するか、然らずんば、みずから雅陶をつくるよりほかはないというのが現状であります。",
              "citation": {
                "source": "食器は料理のきもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから困るのは、生物、煮物、焼物の類をうつかりその辺へ置くことが出来ない、ぼんやりしてゐると直ぐ食べられてしまふので、お膳立てをするほんの僅かな間でも、水屋か蠅帳へ一応入れて置かなければならない。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから困るのは、生物、煮物、焼物の類をうっかりその辺へ置くことが出来ない、ぼんやりしていると直ぐ食べられてしまうので、お膳立てをするほんの僅かな間でも、水屋か蠅帳へ一応入れて置かなければならない。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お膳立てから、煮物、燒物の世話まで」「それから」「私が、旦那樣のお膳を運んで行くと、御隱居樣は、御自分のお膳を、離れに持つていらつしやいました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "五月人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮に文芸評論家自身は自分では気づかなくても、世間ではそういう風にチャンとお膳立てをしている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "但しそのお膳立てをする任務を某方面から委任されていると云われる松本警保局長は益々健在で、荒木や直木の損失を補って余りあるかも知れないのであるが。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "お靜は呑込んで要領よくお膳立てをして居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――じゃあ直ぐ仕度をするといいわ、私がお膳立てはしてあげるから」「そうでございますか？",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹がここへ押しかけて来るまでには、さまざまの表裏もあれば魂胆もあって、糸をひく奴もあるし、引かせる奴もあって、お膳立ては以前から、ちゃんと出来ていたものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに、おまえさんがそこまでお膳立てをしてくれるつうなら、ためしにやってみてもいいと思うだ、そう思うだが、間違っても災難ごとなんぞ起こりやしねえだべえな」「そんなことはない、そんなことはある道理がない」　飯篠老人は言葉を強めて否定した。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは敏子が勝手にお膳立てをしたので、「僕は据え膳の箸を取っただけだ」と、木村は云っていたけれども、真相はどうなのであろうか。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀子は行きたいとも何とも思っていないんですよ」「…………」「それだのに寄って群って渋谷の伯父さんまで引っ張って来てお膳立てをしてさ」　と大奥さんは果してそのことだった。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺がちゃんとお膳立てして置いたところへ、先生の方で飛び込んで来たのさ。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ウェルギリウス）（b）運命はいかにも彼女にふさわしいお膳立てを調えて、彼女なりにわたしの任命に協力してくれたのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもおぜんだてができていればこそ、せきたてるんだッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
