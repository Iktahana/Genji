        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうしてすべての人達が屋外へ飛び出してしまった後に一人残って飲み残りの紅茶をなめながら振動の経過を出来るだけ詳細に観察しようと努力していた。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩の時間が来たとき私は離れた席にいる友達に目※せをして人びとの肩の間を屋外に出た。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋外は雨の音、ザアッ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山を望めば、心も消え入らんばかり懐し」同二十六日――夜十時記す「屋外は風雨の声ものすごし。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋外の風声をきく、たちまち遠くたちまち近し。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と今一度言って、「お清様は今日｜屋外の炭をお出しになりや仕ませんね？",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の中にいても火種の足りない火鉢にしがみついて、しきりに盗風の忍びこむのに震えていなければならぬ清逸にとっては、屋外の寒さもそう気にならなかったが、とにかく冬が紙一重に逼ってきた山間の空気は針を刺すように身にこたえた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建てつけの悪いガラス窓が風のためにひどい音を立てて、盗風が屋外のように流れこんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火を点じて後、窓を展きて屋外の蓮池を背にし、涼を取りつつ机に向いて、亡き母の供養のために法華経ぞ写したる。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋外は、凄いどしゃ降りだ。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては、襖の蔭で縫いものをしている家の者に迄あなどられる結果になるやも知れぬという、けち臭い打算から、私は友人を屋外に誘い出し、とにもかくにも散策を試み、それでもやはり私の旗色は呆れる程に悪く、やりきれず、遂には、その井の頭公園の池のほとりの茶店に案内するという段取りになるのであった。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凱旋の女王の如く、誇らしげに胸を張って、ドミチウスや、おまえの世の中が来た、と叫び、ネロを抱いて裸足のまま屋外に駈け出し、花一輪無き荒磯を舞うが如く歩きまわり、それから立ちどまって永いことすすり泣いた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の下は、左右の植木屋、屋外に足場を設け、半纏着の若衆蛛手に搦んで、造菊の支度最中なりけり。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜の紙帳は広くして、我と老侠客と枕を並べて臥せり、屋外の流水、夜の沈むに従ひて音高く、わが遊魂を巻きて、なほ深きいづれかの幻境に流し行きて、われをして睡魔の奴とならしめず。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "服の濡れているのは、前夜の強い雨のなか屋外にいたことを物語る上、頭にこぶのある杖は南国産の棕櫚製、鉛入りで重みがあるから、繰り返し殴打すれば調教師の受けた深い傷も無理なくつけられる。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "厩番の青年に薬を盛った疑惑があり、強い雨のなか屋外にいたことも確実、鈍器になる杖も所持、あげく死体の手には彼の首巻き。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋外でやることが必須だったのです。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下の室には人多くゆききする足音頻に、屋外の大渠には小舟の梶音賑はしかりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二　もとより自ら進んでも、かくはなるべき運命であったろうけれども、さまでとはさすがに思い懸けなかった、積年の憂苦辛酸、一｜日の安き暇もないので、お絹は身も心も疲れ果てて、その一月ばかり前から煩い出し、床に就いて足腰の自由が利かなくなると、夫｜狂犬源兵衛は屋外にこれを追出した。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこそ遂に狂したれと、妾は急ぎ書生を呼び、好きほどに待遇わしめつつ、座を退きてその後の成行きを窺う中、書生は客を賺し宥めて屋外に誘い、自ら築地なる某教会に送り届けたりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベース・ボールの選手が乾燥したグラウンドに各自その膂力を振つて居る外屋外に人を見ることが少なくなつた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体の危険と、船体と共にする自分自身の危険と、そして、てきめんに自分の凍えんとする肉体に対する危険とは、火事が中風の婆さんに、石臼を屋外まで抱え出させたほどの目ざましい、超人間的な活動を、水夫たちに与えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "利き過ぎた薬　当局の「作家忌避」　▼屋外労働者の生活問題に触れてゐる俗謡『土方殺すにや刃物は要らぬ、雨の三日も降ればいゝ――』を文筆労働者である作家に、あてはめてみると、或る作家の書いたものに、一度二度の発禁があれば、その作家を土方の雨同様、生活を乾上らすには充分だらう。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど顧みれば、吾れ敗残の生、枯槁の躯、一脚歩を屋外に移す能はざるの境に在りて、能く何をか為さむ。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「屋外写生の時に用ひる、あのパラソルを買つて来て軒先きに差しかけようかしら、あれなら柄が伸縮自在、折曲も自由になるから具合好く陽を避けることが出来るだらう、こんなに陽脚の慌しい日にも？",
              "citation": {
                "source": "悪筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前の夜は志戸平温泉に泊つたが、かなりに深い山の中であつたに拘らず、また豊沢川の水声が淙々として終夜屋外を繞つてきこえてゐたにも拘らず、暑くつて、暑くつて容易に眠むれなかつた。",
              "citation": {
                "source": "水源を思ふ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「ゲダイ」というは馬喰町の郡代屋敷へ訴訟に上る地方人の告訴状の代書もすれば相談｜対手にもなる、走り使いもすれば下駄も洗う、逗留客の屋外囲の用事は何でも引受ける重宝人であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、屋外であれ程判然たる他殺の痕跡を加えて殺害したものを、わざわざ運び込んで屋上から投げ墜し墜死に見せかけよう、なんてナンセンスは信じられない。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のいい事をいうにしても大概にしておくがいい。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「同じ事を……いとしい方にしておくがいい。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
