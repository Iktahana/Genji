          ],
          "literary": [
            {
              "text": "草藪の陰でその体はよく見えないが角ばかりを見たところで非常な大鹿らしい。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鹿の群れが走って行ったって、そういう徴候は見られるんだからなあ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと見るとずっと下の方に、大鹿が長い列をつくり、トットと走っていましたっけ……。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遥かの山の中腹を、大鹿の列が走って行った。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の如き未熟の腕にて余の如き大鹿がどうして打とめ得られようぞ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頭の大鹿を横に喰わえた一匹の蟒蛇が蜿蜒と目の前の雑草を二つに分けて沼の方へ駛っているではないか！",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして崩れ切った谷底には大河が流れているらしいが水は氷に鎖ざされて木の間を洩れて射す陽光にわずかにキラキラと輝くばかり、谷を隔てた向こうの峰までは三町余りもあるだろうか、峰の斜面は陽光を受けて虹のように燦然と輝き返り、その岨道を大鹿の群が脚並み軽く走ってはいるが、人の姿は影さえもない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、岨道を走っていた大鹿の群が何に驚いたか、算を乱して谷の方へ飛んで下りようとしたかと思うと、その幾頭かは悲鳴と共に朱に染まって地に斃れた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、その恋人が、職業野球チェスター軍の名投手｜大鹿だという。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「葉子さんの愛人はチェスターの大鹿投手なんです」「やっぱり、そうか」「家出なさった時から、私、相談をうけて、かくまってあげたり、岩矢天狗さんと交渉したりしたのですが、天狗さんは、手切れ金、三百万円だせ、と仰有るのです。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鹿さんは、昨日、関西へ戻りました。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、大鹿さんに選手としての名誉を汚させるぐらいならと、社へ借金にいらしたのです。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鹿は灰村カントクの子飼いだから、動かないものだと、各球団で諦めていた男だ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、大鹿は三百万の金がいる。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都には、大鹿と葉子が愛の巣を営むための秘密の隠れ家があるのである。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、大鹿と葉子だけしか知っていない。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鹿は敬意を払って迎えた。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いのに、たのんだなア」　大鹿は煙山に顔を見つめられて、あかくなった。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鹿が顔をあからめているところをみても、彼も亦誘惑にまけた一人だと見当がつくのである。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新聞の記者が朝日撮影所の門前に葉子をはりこんでいるのを見ても、この新聞は大鹿の噂を知ったらしい。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの社の暁葉子と大鹿さんのロマンス、ちょッと教えてよ」「え？",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子が関西の球団を当る限りは、大鹿の身売りは成功の見込みがない。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "社へ戻ると、大鹿の意向を社長につたえ、又、上野光子が上京して、大鹿売りこみのカクサクをしていることも言い添えた。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしラッキーストライクに大鹿が加入して、三番にピースの国府一塁手、四番にキャメルの桃山外野手がとれたら、攻守ともに百万ドル。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを条件に、大鹿に三百万、やって下さい。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もスカウトをやるからには、絶対とれないという大鹿をとりたいのですよ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万ずつで二人がとれたら、大鹿のことも考えてみよう。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人がウンと云ったら、大鹿はキットですね」「まア、二人のウンを先にきかせてくれ」「よろしい。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日のうちに金をそろえてくるから、ほかの契約は断ってくれと念を押して、安心して、大鹿を訪ねた。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
