        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "書斎の壁にはなんとかいう黄檗の坊さんの書の半折が掛けてあり、天狗の羽団扇のようなものが座右に置いてあった事もあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも黄檗宗の名僧｜独湛の嗣法の弟子で、性格も世離れしているところから互いは親友でありました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛學の方では此の他に難波に居た鐵眼和尚といふのがある、彼の有名な「黄檗の藏經」の出版は全く鐵眼によつて出來たもので、それも大阪の町人の後援があつて初めて完成したものであらうと思ふ。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も此の鐵眼の黄檗の藏經は四角い册子の形をして居る、これは明の萬暦年間に出來た藏經と同じ形をして居るものであつて、由來藏經の折本は寺等に保存して置く上にはさしたる不便を感じないが、之を世間に流布する上には折本は嵩張つて不便であるから、是を册子としたことは藏經を世間に流布する上に效果があつたであらう。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論此の黄檗の鐵眼板は鐵眼存生中に完成したものではあるまいが、此の計畫は鐵眼によつて達成されたものである。",
              "citation": {
                "source": "大阪の町人と學問",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石氏と黄檗５・18（夕）　京都に今歳八十幾つかになる老人で、指頭画の達者な爺さんがある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目漱石氏が先年京都に遊びに来てからは、「京都では別にこれといつて気に入つた物もないが、唯黄檗と指頭画とには悉皆感服させられた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故黄檗が好いんだらう。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこになると、黄檗はあの通り平地に建つてゐるので、廓然と気持がいゝつたらない。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ひ／＼、子供のやうに長く寝そべつて、だらけた胃袋を畳の上に投げ出しながら、何ぞといふと黄檗のやうなお寺の屋根瓦を一枚一枚｜描きにかゝる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが出来上ると、今度は黄檗で見たやうな松の樹を描いて、克明にも松の葉を一本々々つけてゆく。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふと、にやりと笑つて、黄檗の禅坊主がするやうに、いかにも意味がありさうに一寸指先きで自分の胸元を指して見せる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには黄檗に似てもつかない弱い胃の腑が溜息を吐いてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗の隠元が日本へやつて来た折、第一に払子を受けたのは、この独照だつたといふからには、満更の男では無かつたらしい。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」文豪の原稿７・30サンデー毎日　紀州に光明寺といふ黄檗の寺がある。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この鳥が啼く頃になると、いつも青葉若葉の滴るやうな黄檗の空が思ひ出される。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗といへば、あそこには名高い鉄眼和尚の一切経の木板が遺つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "崇福寺は、黄檗宗の由緒ある寺だが、荒廃し、入口の処、白い築地の崩れた間を通って行くようになっている。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職がばたばた扉を閉めて行った本堂前の、落葉のある甃を歩き廻りながら、私共は、懐しく京都の黄檗山万福寺の境内を思い出した。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗の建物としてはどちらが純正なものなのか。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり黄檗宗で、明の帰化人、陳冲の子頴川藤左衛門が尽力して盛大ならしめた寺だ。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今籠町の黄檗宗崇福寺へ行って、唐門前の石欄から始めて夕暮の市を俯瞰した時、その心理的効果がはっきり感じられて面白かった。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の黄檗山万福寺と同様、大雄宝殿其他の建物を甃の廻廊で接続させてあるのだが、山端で平地の奥行きが不足な故か、構造の上でせせこましさがある。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、南京寺の一つ、黄檗宗に属す。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから黄檗山にも行つて居られたし、若王子にも居られたが、私共が車屋町に居た時分は、八百三に永く居られた。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗山の頃は、なんでもあすこが大変涼しいと云ふので行つてゐられたらしく、寺の大きな広間の事ですから、風通しもよかつたのでせうし、ひどく其処が気に入つてゐたやうですが、そのかはり、やぶ蚊が大変だと云ふので昼間でも大きな蚊帳をつつて、その中で絵を描いてゐられたと云ふ事です。",
              "citation": {
                "source": "思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "興教大師御誕生地御誕生院、また黄檗宗支所並明寺などがあつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も黄檗の衣鉢を伝えた身であって見れば、独立の遺蹟の存滅を意に介せずにはいられない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "想うに独立は寛文中九州から師｜隠元を黄檗山に省しに上る途中で寂したらしいから、江戸には墓はなかっただろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗福巌鉄文といふ元禄年中の僧の書なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
