        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "以上はただ全くの素人の想い出話のついでに思い付くままの空想を臆面もなく書付けて見ただけである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで書いて来て振り返ってみると自分ながら随分臆面もなくよくこれだけ書いたものだと思う。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は暇さえあれば母をつかまえて小言と自慢話ばかりしているし、弟は誰の神経でもいらだたせずにはおかないような鈍いしぶとさを臆面もなくはだけて、一日三界人々の侮蔑と嘆きとの種になっている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の醜い部分に臆面もなく注意を向けていたのを……そのつもりではなかったのだが……すまなく思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに日本橋の上へは、困った浪花節の大高源吾が臆面もなく顕れるのであるが、いまだ幸に西河岸へ定九郎の出た唄を聞かぬ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の庭は美しかろう、散歩の時は寄ってみるよ、情郎は居ないか、その節邪魔にすると棄置かんよ、などと大上段に斬込んで、臆面もなく遊びに来て、最初は娘の謂うごとく、若山を兄だと思っていた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお丹の指揮に手空の奴等、一足先に駈出だして、派出所の前にずらりと並び、臆面もなく一斉に尾籠の振舞、さはせぬ奴は背後より手を拍きて、「鳴るは滝の水。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は臆面もなくＨ老人を責めＳ夫人を責めて饒舌であり過ぎた。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "で臆面もなく米も借りに來れば小遣も借りに來た。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジャネットは此の人混みにあおられるとすっかり田舎女の野性をむき出しにしてロアール地方の訛りで臆面もなく、すれ違う男達の冗談に酬いた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、教室よりも夜倶樂部の御常連で、爛れた歡樂の擧句に懷胎を知るとイングンはその子の父親がフレデリツクであることを臆面もなく兩親に打ち明けた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と臆面もなく言うて退けつ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夫と誤り、良夫と見て、胸は早鐘を撞くごとき、お貞はその良人ならざるに腹立ちけむ、面を赤め、瞳を据えて、屹とその面を瞻りたる、来客は帽を脱して、恭しく一礼し、左手に提げたる革鞄の中より、小き旗を取出して、臆面もなくお貞の前に差出しつ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "想えばげすの口の端に、掛って知った醜さは、南蛮渡来の豚ですら、見れば反吐をば吐き散らし、千曲川岸の河太郎も、頭の皿に手を置いて、これはこれはと呆れもし、鳥居峠の天狗さえ、鼻うごめいて笑うという、この面妖な旗印、六尺豊かの高さに掲げ、臆面もなく白昼を振りかざして痴けの沙汰。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から（徳川時代から）忌避され軽蔑されていた肉慾描写や不倫の世相が、自然主義の輸入以来、臆面もなく逆照され初めて、往昔、最低級の芸術として扱われていた作品が、堂々として一般民衆の趣味傾向の王座を占むる事となった。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は臆面もなく云った。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　美和子も、ハッとするほど、その瞬間に、姉の顔にはげしい影が通り過ぎ、嫉妬と憤りと悲しみの色が満ち溢れたので、さすがの妹も、それ以上臆面もなく、物をいい続けることが出来なかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "作業遲々たる時は、是等の隱れた見物人が、壻を難じ、嫁の母、臆面もなく室に侵入して、世話をやくに及ぶ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と素頂天にぞんざいな口を切って、袂の下を潜らすと、脱いだ羽織を前へ廻して、臆面もなく、あなた方の鼎に坐った真中で、裏返しにしてふわりと拡げた。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作さんがいれば、おとよさんもはま公も唄もうたわねいだもの」　満蔵は臆面もなくそんなことを言って濁笑いをやってる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを臆面もなく行つたのは僕の頭も變に成つて居たのである。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆さんは臆面もなく素裸であちこち歩き廻つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を見飽きたり、知り飽きたりしたと臆面もなく言ふ男が多いのに私は驚いた、うつくしさの再吟味を理論でやつてから改めて女の美しさを発見しようとする気の長い男達が少くないのだ。",
              "citation": {
                "source": "小熊秀雄全集-10",
                "author": "詩集（９）流民詩集２",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識とか、感じとか、存在とか、何々的だとか、そんな言葉を臆面もなく彼は、母親などの前で使つた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘つたるき口付にて、『宿は客を好めど、妾はうるさくて堪まらず』など、はしたなきことを、臆面もなく吐露す。",
              "citation": {
                "source": "月の東京灣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那の仰しやる通り日本のやうな猶だ男女七歳にして席を同ふせざる封建道徳の遺習が牢乎として抜くべからざる国で、若い女の許へ臆面もなくノコ／＼サイ／＼やつて来るはどうせ軽薄な小才子か、女の御用を勤めて嬉しがる腰抜の無気力漢だ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の冷却した夫婦の結合は不自然であるとか虚偽であるとかいう勝手な理窟を附けて不条理極まる破縁を不人情とも没義道とも思わず、あるいは三角や四角の恋愛を臆面もなく手柄顔に告白するのを少しも怪まない今から考えると、ただこれだけで葬むられてしまったのは誠に気の毒であった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、勝平は相手の容子などには、一切｜頓着しないように、臆面もなく話し続けた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "被告の少年も、臆面もなく犯罪事実を述べたてました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が今ここでこんな空想を起こしているのも、事によると子供のけがでびっくりして少し頭が変になったせいかもしれないし、それならばまた、こんな事をおくめんもなく書く気になるのは、その天然自然の治療法を無意識に実行しているのかもしれないのである。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
