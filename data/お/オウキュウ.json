[
  {
    "uuid": "aa3b873e-b78b-5aa1-9201-9013b689b709",
    "entry": "応急",
    "reading": {
      "primary": "おうきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
