        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうすると、あるおじいさんとおばあさんとが、まん中に一人の娘をすわらせて三人でおんおん泣いておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うさぎはそのひりひりする、ひどい痛みにたまりかねて、おんおん泣き伏しておりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると若日子の父と妻子たちは、「おや」とびっくりして、その神の手足にとりすがりながら、「まあまあおまえは生きていたのか」「まあ、あなたは死なないでいてくださいましたか」と言って、みんなでおんおんと嬉し泣きに泣きだしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとうとう悲しさに堪えきれないで、おんおんお泣きだしになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、命のご陵をお作りになって、そのぐるりの田の中に伏しまろんで、おんおんおんおんと泣いていらっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妃は潮の中を歩きなやみながら、おんおんお泣きになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "海人はあっちへ行ったり、こっちへ来たり、それが二度や三度ではなかったので、とうとう行ったり来たりにくたびれて、しまいにはおんおん泣きだしてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてシャベルの土をおとしおとししていましたが、とうとうたまらなくなって、おんおん泣き出しました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護者にはぐれた子どもたちが、おんおんないてうろうろしている。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア、みいちゃん、こんなになって、って、おんおんお泣きになるんですもの、あたし御挨拶のしょうがなくて、弱ったわ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここまで目あてにして来たヤナギの木群れは、そびえた梢でおんおんと呻いていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の頸を抱きしめておんおんと泣きだした。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちに、だんだん大きな声になって、おんおん泣きつづけるうち、じぶんでじぶんをどうしていいか、わからなくなってしまいました。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムトムぼうずトム、トム、トムぼうず、笛ふきのむすこ、ぶたをぬすんでにげたはよいが、ぶたはたべられ、トムぁぶったたかれ、ないておんおん街をかけた。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんおん泣きながら大吉は、八津がいつもほしがっていたチエノワを思いだし、かしてやらなかったじぶんの不親切をじぶんでせめながら、いまあらためて、それを八津にやろうと思った。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、どうすべえなァ、どうしたらええべなァ……なにもおら悪いこともしねえだになァ……」　おんおんと声をあげて泣きだしてしまいました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの方は、夫婦猫なので、別にして、花を供えてやりました」　金五郎を見ると、マンは、そういって、また、手ばなしで、おんおんと、泣いた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所の前で、秀子が、おんおん泣いている。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
