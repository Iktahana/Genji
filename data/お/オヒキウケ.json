        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お引き受けについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お引き受けがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお引き受けの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお引き受けが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お引き受けの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお引き受けがあります。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お引き受けについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお引き受けの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお引き受けが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお引き受けは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお引き受けについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお引き受けの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お引き受けを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この次の切符、お引き受けすればいいんでしょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と答えると、「じゃ一円の十枚、二円の五枚お引き受けしますわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全な所に送り込むまではいったんお引き受けした手まえ、気がすまないといい張った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「確にお引き受けいたしましたわ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お引き受けした以上、万事作法通りになさい！",
              "citation": {
                "source": "吉良上野の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速お引き受けは致したが、何しろ押し詰まってのことでその年はどうにもならず、明けて明治二十一年、新春早々から取り掛かりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちがこのように立派になりましたにつれて、お母様も前のように安いお仕事ばかりをお引き受けにならぬようになりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだその時は時間も早うございましたし、二時間もすれば充分帰って来られると思いましたので、早速お引き受けいたしまして、田端駅から早稲田まで出掛けたのでございます。",
              "citation": {
                "source": "幽霊妻",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お引き受けしましょう。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さてご老人、助太刀の儀は、拙者誓ってお引き受け致す。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私のところも、入る割りには交際は多いもんでね、せっかく正ちゃんをお引き受け申しても、お世話が出来ることやら出来ぬことやら、……。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "また今後とても、他からの依頼は何んなりとお引き受け下すって、それを学校で拵えて下さい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれだけあとへお残りする自信をもって御後事がお引き受けできると思うかね。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは低い更衣腹の内親王であったから、心安い気がして格別の尊敬を妻に払う必要もないと思って、院からお引き受けをしたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "院がお引き受けになりましたのもその気持ちでなすったことですもの、つまらないことを言って、結局は宮様を悪くあなたはおっしゃるのですね」　ついには腹をたててしまった小侍従の機嫌を衛門督はとっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に正木先生はもしこの恩が報じたければ福岡へ住んで俺が帰るのを待っておれと云われまして沢山の旅費まで頂きましたので、帰国｜匆々当地の英和学院の柔道師範を奉職していたのですが、正木先生が大学に来られるとすぐに辞職して治療場の監視をお引き受けした位です。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしから進んでその仕事をお引き受けした位でございます。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると西郷は膝へ手を置き黙って終いまで聴いていたが、『いろいろ議論もございましょうが私が一身にかけましてお引き受けすることに致しましょう』と卒直に一言云ったものだ。",
              "citation": {
                "source": "開運の鼓",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大任をお引き受けした貴郎に向かっての私の然諾！",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妾から渡すのでござりますのね、ハイハイ渡すでござりましょうと、妾お引き受けいたしまして、今日までお預かりいたしましたが、いまだに妾越中に、お逢いしないのでございますの」　困ったようにお浦はいって、また可憐しそうに上様を見やった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……道中の苦患はこのお玉が、身に換えお引き受けいたしまする」「何んの！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女の身にして菊女殿は、難役をお引き受けなされました。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ついては拙者萩丸殿を、虫部屋に入れて一種の拷問、――拷問をして是が非であろうと、宥免状書かせるよう致すでござろう」「おおそれでは貴殿において、萩丸殿を虫部屋に入れる役目、お引き受けくださると仰せられるか」　喜ばしそうに兵庫は云った。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さよう拙者お引き受け致す」　云いすてると民弥は刀を提げ、襖をあけて外へ出た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐにお引き受け致し、わざと捕虜の身となってここへ参ったのでござります」奇道の守り本尊　こういう会話の話されているのは岩石ヶ城内｜白虎城砦のオースチン老師の居間であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "快くお引き受けくだされた。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から風邪気で引つ籠り中だつた司教の意向をただすまでもなく、「よろしい、わたしの責任でお引き受けしませう」と相手のお役人に答へると、言下に本堂の正面の扉を真一文字に開かせたと言ふことです。",
              "citation": {
                "source": "死児変相",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、そんなきたない考から出立したのではありません、金なぞは一さいもらはない条件ならばおひきうけしますと、二人はふりかへつて言ひました。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又おひきうけしたことも事実であります。",
              "citation": {
                "source": "大正十二年九月一日の大震に際して",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや一人より二人がよろしい、そちの見立てでしかるべきものを二人ほど連れて房州へ帰りたいものじゃ」「よろしうございます、たしかにおひきうけ申しました」　寅吉は、甚三郎の頼みを快く承知する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
