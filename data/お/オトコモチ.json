          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「男持ちの蝙蝠傘を出して下さい。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に男持ちのような小型の嚢を提げていた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからゴアの名物は間男持ちの女で角を切ってもまた根ざすと苦笑いながらの評判だとある。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "目立たぬ黒絣の単衣のうえに、小柄な浅山のインバネスなどを着込んで、半分｜窄めた男持ちの蝙蝠傘に顔を隠し、裾を端折って出て行くお庄のとぼけた姿を見て、従姉は腹を抱えて笑った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "また暫らくして、リグレイ印のチュウイング・ガムの包み紙一枚と、男持ちの血染めの手巾が、附近の残雪にまみれて発見された。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、現場のブレント入江の草原で残雪にまみれて発見された「男持ちの血染めの手巾、白地に青い線で縁取った大判の、木綿の安物」と、完全に同種のものである。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の刑事が手を伸ばして拾上げると、まだ水につかって間もない男持ちの皮財布だ。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
