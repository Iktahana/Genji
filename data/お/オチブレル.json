        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「いいえ、デストゥパーゴが落ちぶれるもんですか。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那の大阪が焼けて、落ちぶれてしまうと、当然妾の京都も一緒に落ちぶれるかと思われたのに、旦那と別れた妾の京都は今は以前にもまして美くしく若返り、日本一の美人になってしまっている。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うも、人間といふものも、国があんな風になるとあゝも落ちぶれるものかと思ふと、日本なんか難有いと思ひましたよ。",
              "citation": {
                "source": "一少女",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらが先に落ちぶれるか、それは解らないが所詮は落ちぶれるものなのである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ私どもは落ちぶれるのでせうが、あなたから解放して頂けるのでしたら、さうなるのも私には却つて有難い位ですわ。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、上流社会で落ちぶれると、ほかの階級では見うけられないようなつらいうき目がいくつもおこってくる。",
              "citation": {
                "source": "妻",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も落ちぶれることがないとも限らない。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちぶれる経路は手紙にルルしたためてあり、それは陰惨そのものであるが、これも書くわけにはいかない。",
              "citation": {
                "source": "巷談師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "金吾君、人間も落ちぶれると自分の娘から、こんなことまで言われるよ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな風にして、彼が落ちぶれるような目にあったのやら、それはだれも知らぬ。",
              "citation": {
                "source": "トビアス・ミンデルニッケル",
                "author": "TOBIAS MINDERNICKEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、落ちぶれる――をひどく恐れた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮らしむきは、落ちぶれる一方であった。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに又、もはや此の世に何の望みもないと云うあきらめもあったであろうし、生きて関白家一門の落ちぶれる様を眺めるよりは、寧ろ舊主の怒りに触れて殺された方がよいと云う腹もあったであろう。",
              "citation": {
                "source": "聞書抄",
                "author": "第二盲目物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちぶれるのを防いでくれる唯一の存在だ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "人もひとたび、心まで落ちぶれると、味気ない迂愚と堕落を、恬として辿るものではある」　全徳川の将士は、一益の行方に、こんなことばを餞別した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど衰えた主家に、この上ともおちぶれることがわかっていてもなお側に仕えようと思う彼らの愛情であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間はおちぶれて乞食となりますが、彼女に限つておちぶれることがないから、乞食にもならない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こう虐待をされるような、こんな身分におちぶれるほどなら、何も人一人たたっ切って、巻き奉書など奪わなければよかった」「青地清左衛門を叩っ切ったことかな」「うん」と源兵衛は不気味そうにいった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以下におちぶれることはなかろうし、おちぶれても嫁の実家の財産を目当てにするような貴公ではない。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "この李応もまだそんな日蔭者の仲間におちぶれるほど身を持て余してはおりません」「でも、今日は遁れても、いつかは必ず官憲はあなたを不問にしておきますまい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
