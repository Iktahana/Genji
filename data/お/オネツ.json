[
  {
    "uuid": "199c39f0-e433-5ba1-a05e-3900ec76c582",
    "entry": "悪熱",
    "reading": {
      "primary": "おねつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fever following a chill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あれあれ、とばかりに学士は目も眩れ、心も消え、体に悪熱を感ずるばかり、血を絞って急を告げようとする声は糸より細うして己が耳にも定かならず。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪熱のあらむ時三ツの水のいずれをか掬ばんに、わが心地いかならむ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身には悪熱悪寒が絶えず往来する。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "がまん強い父が悪熱にふるえて、腕まで紫色に腫れ上ってしまっても、彼は貝殻の膏薬を貼りちらした。",
              "citation": {
                "source": "西洋の唐茄子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪熱のゑがく夜の幻想ほど絶望的なものはなかつた。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の悪熱は、私からあらゆる力をはぎ、ものうさと、とがつた感情だけを残す。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の外套を持たぬのだ、勿論それが第一の理由であらう、しかし又、与里はここ数日以来激しい発熱を訴へて乾いた唇を噛んでゐたから、この種の重い冬の衣裳が、高い悪熱に要求せられた結果でないと言ひ切ることも出来はしない。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の悪熱は、私からあらゆる力をはぎ、ものうさと、とがった感情だけを残す。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "無心の鳥まで悲しむというので、戸口に立て空を見た時、雲は悪熱で煮えるように薬色となっていた。",
              "citation": {
                "source": "不思議な鳥",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪熱のようなこの静寂の中に、戸外から舞いこんだ桜ふぶきが悩ましく乱れ飛んでいる。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで兵馬は衣裳を改めて、床の間を前に端坐して、この、まだるい、悪寒の、悪熱の身を、正身思実の姿で征服しようと企てたのらしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "床に寝かされたオーブレイは猛烈な悪熱に侵された。",
              "citation": {
                "source": "吸血鬼",
                "author": "ジョン・ポリドリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱脈な世の大患を、ふかくそのお心に煩って、悪熱をやどし、一面には、漢室の衰えに痛恨して、お食もすすまぬ重態となられたのでござろうが」「……えっ」「おかくしあるな、それも病を篤うさせた原因の一つです。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもまあ、云ってご覧なさい」　となおねつく訊くと「やっぱり世間通りよ。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
