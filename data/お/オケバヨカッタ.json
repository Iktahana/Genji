        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「きょうは、はずして置けばよかったのに。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "云はないで置けばよかった。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことなれば、もっと早く小説を書いて置けばよかったと、現金に考えた。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年も劇を勉強して純粋戯曲論などに凝っている間に、小説を勉強して置けばよかったと、私は未だ読みもせぬ小説家の数を数えて、何か取りかえしのつかぬ気がした。",
              "citation": {
                "source": "わが文学修業",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大喝して女を力まかせに殴り、諸行無常を観じ、出家にならねばならぬと覚悟を極めた次第で、今日つらつら考えると私のような野暮で物欲しげで理窟っぽい男は、若い茶屋女に好かれる筈はなく、親爺のすすめる田舎女でも、おとなしくもらって置けばよかったとひとりで苦笑致して居ります。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "も少し、親しくして置けばよかったと思った。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もっと、埋めて置けばよかったね。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、意識が不明になって見ると、正気の裡に、何か話して置けばよかったと云う後悔も残っていた。",
              "citation": {
                "source": "碁の手直り表",
                "author": "菊地寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうと知ったら、いっそお吉の奴を引き揚げて置けばよかった」　彼はまた引っ返して、番台の男にお吉の家を訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、こうした機会もあるのだから、仏語を少しでも覚えて置けばよかった、学生時代にお役目のように、講義を聴き放しにしたことが、一寸残念のように思われました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうと知ったら、きのうのうちに三町ほど先の牡丹餅屋にあつらえて置けばよかったが、まさかに売切れることもあるまいと多寡をくくっていたのが今更に悔まれた。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりあれっ切りにして置けばよかったのですわね。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は単なる興味丈で、そう云う事を探るのは罪だと思いましてね、その先を突き詰めて聞くのを態と避けたのですが、今になって見ると、もっと深く知って置けばよかったと悔いているのです。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ったら猶更のこと、帳場の者にまかせて置けばよかったのですが、そこが矢はり殿様で、自分がつか／＼と入口へ出てゆきました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も銀座の宅へ時々は訪ねて行ったが、だんだんに足が遠くなって、あのときにこういうことも訊いて置けばよかったと、今さら悔まれることがしばしばある。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだ小梅の長五郎の話を聴いた時に、すぐに旦那に知らせて置けばよかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "新カチカチ山",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時、友人の言葉に従って置けばよかったものをと今から思えば後悔の至りです。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "またわれわれにもこういうことに経験があったら、前に注意をして置けばよかったのに、経験のないため、飛んだ無駄骨を折ることになりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "栃の木で老猿を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし時間に余裕があればね」「そんな大事なことなら、今日のうちに調べて置けばよかったのに」「なあに、ピストルを何処から撃ったかという問題は、大して重大なことじゃないんだ。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……俺は実際惜しいことをしたよ、あの時見せられた雄蝶の斑紋を、もっと詳しく見て置けばよかった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も豆腐屋へ年期奉公に住み込んで置けばよかった」「君は第一平生から惰弱でいけない。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も貰って置けばよかった。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、すぐさま車掌に申告するとか、バーミンガムの駅で証明をとって置けばよかったのだ。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂村は今砂町と改称せられているが、むかしの事を思えば「砂村町」とでも言って置けばよかったのである。",
              "citation": {
                "source": "元八まん",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと根掘り葉掘り聞いて置けばよかったと後で気が付きました。",
              "citation": {
                "source": "登山談義",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう少し踏み込んで沢山僕の名にして置けばよかった」と禿は三万二千五百円以外に残念がっている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小波山人が死ぬ時、「江見、己は先に行くよ」といったという話を聞いているから、当時水蔭はまだ生きていたはずなので、会って置けばよかったといまだにそう思う。",
              "citation": {
                "source": "文壇昔ばなし",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も早く学者になって置けばよかった、学問をして置けば、新井君美ぐらいにはなれたろう、戯作をやらせれば馬琴はトニカク、柳亭ぐらいはやれる筆を持っていたのを、今まで自覚していなかった、我ながら惜しいものだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いて置けばよかったという気持、いや、ぼんやりした気分が、今の彼にはある。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わないでおけばよかった。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
