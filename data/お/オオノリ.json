          "literary": [
            {
              "text": "でサ」　コン吉は、もはや大乗り気。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "池田は『ふん、なかなかおもしろそうだ』と大乗り気である。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は、いつにするの」「はやいがよい」「では、明日にも」　大乗り気である。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しょに行ってやるから」　蕭譲はもう大乗り気なのである。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……いやもう、信雄様には大乗り気でいらせられました。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、いたさぬことには、鎌倉殿へも相すむまい」　と、大乗り気で励ました。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
