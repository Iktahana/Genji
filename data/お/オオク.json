    "definitions": [
      {
        "index": 1,
        "gloss": "many",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしともかく、それらの音楽によつて多くの人々が、好い気持にされてゐるのだから文句はないのだが、然しもと／＼気分の暈縁なぞといふオボコイものを聴いて喜んでゐる連中が取引のこととなると俄然骨ばつてくるし、而も楽々骨ばれるやうに前以て備へてゐるので、「音楽と世態」なぞと今並べてみたくなるのである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら詩性に乏しい現今は、兎角、あまりに貧弱なモチーフを取上げることから、多くの詩が妙な複雑に堕しがちである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は多くを申しません。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに茲に、観念的な、或ひは宗教的な要求の達成といふことよりも、修辞的、心理的要求の達成といふことの方が、遥かに多くの人の歯に合ふといふことがある。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、私はさう思ふと同時に、多くの躊躇をも感ずるものだ。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くのカマはその条に似てゐる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "開化の段階の低いことが、一朝一夕にして高まることはなく、多くの個人の不撓の努力を要することは勿論でありますが、何れにしろ事態打開の先づ第一歩は、「若い身空でイヤな病気」と感ずる前に、「病気の軽重と処分の軽重」が判明に頭なり良心なりに来ること、それに違ひはないと思ふのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造の多くの友は、三造が外で無口だから家では可なり話すのだらうと思つてゐる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康や、生活の向上をしか念としない多くの人々は、つまり多くの幸福論者達には、実験室で働いてゐる者は愚と見える。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し実験室で可なり熱中する人々から最も専念する人々を身近に眺める時に、多くの幸福論者は兎も角一応の反撥を感ずるのが事実である。",
              "citation": {
                "source": "西部通信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの場合彼の話は話に終るのだが、偶には美事にやりおほせることがある。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど私は彼に就いて多くを知りすぎて居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あの偉大なるトルストイを始めとして、世の多くの貴族と生れながらのエゴイストとが、悩み苦しみて求めるものは、実にこの「生えざる」苗を求めんとして嘆き訴ふる悲しみの声に外ならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、此の国の自由詩と称するものは、多くは旧来の形式を完全に脱して居ない、極めて幼稚な口調本位のものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ、彼等の表現の多くは、乞食壮士の大道演説に類したものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼の夫人にとって――世の多くの若い女性と同じく――東京はあこがれの都であり、そこでの生活は一生最高の理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そうした彼の習慣は、普通に多くの西洋人が、彼等の風習によってするごとき、単なる形式的のものではなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（子供と会話する時には、ヘルンは多く英語を用いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭離一切娑婆世界の厭世観は、ヘルンの多くの作品中に一貫して、その特殊な文学情操の基調となってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故多くのヘルンの著作は、書物から得た材料ではなく、その妻によって主観的に飜案化され、創作化されたものを、さらにまたヘルンが詩文学化したものであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ヘルンは――多くの天才的な詩人と同じように――本質的に子供らしい純情さと無邪気さを持った性格者だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に老の近づいたことを知った彼は、自分の残されてる短かい時間に、なおまだ書かねばならない大事の事が、あまりに多くありすぎるのを考えて愁然とし、『人生は短かすぎる』と幾度も言って嘆息した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の多くの友人に對して、芥川君は常に都會人的な洒落や笑談を言つたらしい。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その點で僕の思想は、芥川君に共鳴する所が多くあつた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は床に起きあがつて、殆んど例外なしに悲慘である所の、多くの天才の末路について物語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみと、なやみにせめつけられ、真善美についてなにをいったところで、おおくの人には、牝牛にばらの花をくれたようなものでした。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
