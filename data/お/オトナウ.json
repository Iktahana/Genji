          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "我も死して碑に辺せむ枯尾花　金福寺に芭蕉の墓を訪うた時の句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの「春風馬堤曲」は、蕪村がその耆老を故園に訪うの日、長柄川の堤で藪入りの娘と道連れになり、女に代って情を述べた詩である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば小督局の廃跡を訪うて咏んだという句、うきふしや竹の子となる人の果　の如きも、理解のない鑑賞で見る限りは、単なる観念的の俳句であって、子規のいわゆる月並臭の駄句にしか感じられない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北原白秋氏が氏を訪うた時、氏は心から悦んで客をもてなし、年來の長い鬱憤をもらされたさうである。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が前に高村氏を訪うたのは、三年以前、田端に居た時であつたが、何時來ても氏のアトリエは同じであり、思ひ出が非常に深い。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥の山上武は二三日前、石井翁を訪うて、口をきわめてその無為主義を攻撃したのである。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹巴は時※この公を訪うた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時長頭丸即ち貞徳が公を訪うた時、公は閑栖の韵事であるが、和らかな日のさす庭に出て、唐松の実生を釣瓶に手ずから植えていた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮に僕は横浜｜野毛町に桂を訪ねると、宿の者が「桂さんはまだ会社です」というから、会社の様子も見たく、その足で会社を訪うた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮に僕は横浜野毛町に桂を訪ねると、宿の者が「桂さんはまだ会社です」というから、会社の様子も見たく、その足で会社を訪うた。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき霧の晴れぬ間に家を出で野を歩み林を訪う」同二十六日――「午後林を訪う。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の中ごろから冬の初め、試みに中野あたり、あるいは渋谷、世田ヶ谷、または小金井の奥の林を訪うて、しばらく座って散歩の疲れを休めてみよ。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　十月二十五日の記に、野を歩み林を訪うと書き、また十一月四日の記には、夕暮に独り風吹く野に立てばと書いてある。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　その次が十一月二十六日の記、『午後｜土河内村を訪う。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を尋ねたり、墓を訪うたり、美しい夢ばかり見ていたあの頃の自分には、このイタリア人は暗い黄泉の闇に荒金を掘っている亡者か何かのように思われた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と音訪う処へ、新聞配達、牛乳配達、往来を掃きに出でたる向の親仁、隣の小僧、これを見付けて寄集り、「なるほどこれじゃ、道理で恐しく犬が吠えた。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと私どもの、この旅客は、その小学校友だちの邸あとを訪うために来た。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　土間はたちまち春になり、花の蕾の一輪を、朧夜にすかすごとく、お町の唇をビイルで撓めて、飲むほどに、蓮池のむかしを訪う身には本懐とも言えるであろう。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其友｜王賓を訪う、賓も亦見えず、但遙に語って曰く、和尚誤れり、和尚誤れりと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其説に拠ると小十郎は何等の言をも発せずに終ったので、政宗は其夜｜窃かに小十郎の家を訪うた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷は約に従って政宗を訪うた。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時寂心は横川の慧心院を訪うた。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三先輩は打揃って茅屋を訪うてくれた。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一浴して晝餐を取ると、村の人々が東京日日に對する好感を表示して訪うてくれた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "音訪う間も無く、どたんと畳を蹴て立つ音して、戸を開けるのと、ついその框に真赤な灯の、ほやの油煙に黒ずんだ小洋燈の見ゆるが同時で、ぬいと立ったは、眉の迫った、目の鋭い、細面の壮佼で、巾狭な単衣に三尺帯を尻下り、粋な奴を誰とかする、すなわち塾の（小使）で、怪！",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近県近郷の学校の教師、無論学生たち、志あるものは、都会、遠国からも見学に来り訪うこと、須賀川の牡丹の観賞に相斉しい。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頃は訪う人どころか、苔の下に土も枯れ、水も涸いていたんですが、近年他国の人たちが方々から尋ねて来て、世評が高いもんですから、記念碑が新しく建ちましてね、名所のようになりました。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論大学に居た時分、一夏帰省した時も訪うた事はある。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の八時頃、ちょうど富岡老人の平時晩酌が済む時分に細川校長は先生を訪うた。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "松平のお殿さまからのお差し紙でござえますから、きっとまた何か突発したにちげえござんせんぜ」　しかし、案に相違して、そのお差し紙は、あすの吉例上覧お能に、警固のため出頭しろとのご命令書でしたから、ようやく納まりかかった伝六太鼓がまた鳴りかけようとしたとき――、今度はやさしくおとなう声がありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
