          "literary": [
            {
              "text": "人から、お元気ですか、と問われても、へどもどとまごつくのである。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お元気ですか、と何気なく問われても、私はそれに対して正確に御返事しようと思って、そうして口ごもってしまうのだ。",
              "citation": {
                "source": "作家の手帖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが買ってくると思ったからさ」「お母さん、お元気ですか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん、お元気ですか」　と高志が、慶一のことばをひきとる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんはお元気ですから御安心下さい。",
              "citation": {
                "source": "二人の弟たちへのたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "●昭和二十三年二月六日　東京都神田神保町三ノ六より　杉並区阿佐谷　永井善次郎宛　お元気ですか。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お元気ですか、いつもお案じ申しています。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャツをもらったぼっちゃんお元気ですか。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――東京は大変な暑さです、そちらはきっと東京より涼しいことと思います、お元気ですか。",
              "citation": {
                "source": "宇宙爆撃",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お元気ですか、ご無沙汰ばかししてをりました、呼び出したりして……。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はお元気ですか」　さう云はれゝばさうにちがひない。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さんもお元気ですか？",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お元気ですか」　笑顔で、ぼくは言った。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お元気ですか」「なんとか元気よ。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿新どのは、お元気ですか」　そのことばで、ここの親子が何者か、素姓も分るというものだろう。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
