        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父は仕事で忙しい。",
              "source": "幻辞"
            },
            {
              "text": "父の背中で学んだ。",
              "source": "幻辞"
            },
            {
              "text": "父との関係が改善した。",
              "source": "幻辞"
            },
            {
              "text": "父になるための準備をしている。",
              "source": "幻辞"
            },
            {
              "text": "父の助言を聞く。",
              "source": "幻辞"
            },
            {
              "text": "父のようになりたいと思う。",
              "source": "幻辞"
            },
            {
              "text": "父に感謝の気持ちを伝える。",
              "source": "幻辞"
            },
            {
              "text": "父と久しぶりに会った。",
              "source": "幻辞"
            },
            {
              "text": "父の故郷を訪問する。",
              "source": "幻辞"
            },
            {
              "text": "父の仕事の秘密を知った。",
              "source": "幻辞"
            },
            {
              "text": "父が自慢できる成績を取る。",
              "source": "幻辞"
            },
            {
              "text": "父の経験が役に立った。",
              "source": "幻辞"
            },
            {
              "text": "父との思い出は宝物だ。",
              "source": "幻辞"
            },
            {
              "text": "父が応援してくれている。",
              "source": "幻辞"
            },
            {
              "text": "父の言葉を思い出す。",
              "source": "幻辞"
            },
            {
              "text": "父に頼りたい時がある。",
              "source": "幻辞"
            },
            {
              "text": "父との約束を守る。",
              "source": "幻辞"
            },
            {
              "text": "父になった喜びを感じる。",
              "source": "幻辞"
            },
            {
              "text": "父の遺産を受け継ぐ。",
              "source": "幻辞"
            },
            {
              "text": "父は我が家の柱だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「さう早く出るもんか」「だがね、今日はもう何も云つては駄目ですよ、今急病人があつてお父様は気が立つてるからね」　その時、俄然台所の方から、牛肉か何かを叩く音がして来ると、そゝくさと蒼い顔の妻君は長男の部屋をも立ち去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじゃ野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち二人は、今から、あの大きな船の真正面に在る高い崖の上に登って、お父様や、お母様や、救いに来て下さる水夫さん達によく見えるように、シッカリと抱き合ったまま、深い淵の中に身を投げて死にます。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、お父様と、お母様に懐かれて、人間の世界へ帰る、喜びの時が来ると同時に、死んで行かねばならぬ、不倖な私たちの運命を、お矜恤下さいませ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様からも人間からも救われ得ぬ哀しき二人よりお父様お母様皆々様◇第二の瓶の内容　ああ。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには、外衣も裏衣も、雨や、風や、岩角に破られてしまって、二人ともホントのヤバン人のように裸体になってしまいましたが、それでも朝と晩には、キット二人で、あの神様の足※の崖に登って、聖書を読んで、お父様やお母様のためにお祈りをしました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、それから、お父様とお母様にお手紙を書いて大切なビール瓶の中の一本に入れて、シッカリと樹脂で封じて、二人で何遍も何遍も接吻をしてから海の中に投げ込みました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人とも、聖書を、神様とも、お父様とも、お母様とも、先生とも思って、ムシメガネや、ビール瓶よりもズット大切にして、岩の穴の一番高い棚の上に上げておきました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "相尋ねたいことがある故、至急出頭せいとの……」「エッ御差紙が……至急出頭せい……貴方のお父様へ……そ……それは実正……」　赤猪口兵衛は余りに唐突な話に肝を潰したらしい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎さんと花子さんは、お父様とお母様に手を引かれて東京の近所のばあやの処へ逃げて来ました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様とお母様とは顔を見合わせて、「犬とお人形の夢を見ているのですよ」「どちらも焼けてしまっただろう。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、太郎さんと花子さんは二人揃ってお父様とお母様の前へ出て、「どうぞも一ペン東京に連れて行って下さい。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事がすっかり済んでから、お父様は一人でお家の焼けあとを見にいらっしゃいましたが、夕方になると急いで帰って来て、「うちはたった一軒焼け残っていた。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様もお母様も花子さんも驚いてみんな表へ出ますと、泥棒のようななりをした大男が犬に食いつかれて跛を引き引き向うへ逃げて行きます。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅で縫い物をしていらっしたお母様はお父様の様子に気がついて、どうしたのかと思って窓の外を見ると、猫は金魚をねらい、犬は猫のすぐ後に近寄り、坊ちゃんは犬のお尻を狙って引き金を引こうとし、お父様は坊ちゃんの襟を捕まえようとしておられます。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊ちゃんはガッカリしてうしろを見ますと、お父様が怖い顔をして立っておられたので、「あれ。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アハハハハハ」　とお父様はお笑いになりました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時お父様もお母様も坊ちゃんも楽しいお昼の御飯を食べていました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳はおろおろ声になって、「後生だからそんなこと言わないで、あなたはお父様にお詫びして姉様と一緒になって――」　千歳が思わず取縋った慶四郎の手から、却ってぴりぴりするような厳しい震えを千歳は感じた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじや野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様やお母様や兄様たちにだまっておうちを出て月の世界に来たのですから、リイは心配で心配でたまらなくなりました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御褒美で、アアは王様の国を半分と一番目のお姫様を、サアはまた残りの半分と二番目のお姫様を貰って、二人共王様になり、お父様とお母様を半月宛両方へ呼んで、大威張りをしているところまで見えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもうお父様やお母様も自分のことを忘れておいでになるだろう。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くうちへ帰ってお父様やお母様にお眼にかかりとう御座います。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ほかの人には話してわるいかも知れないけれども、豚吉さんとヒョロ子さんのお父様になら話した方がいいのだ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オオ、お父さん」「そう云う声は豚吉か」「アレ、お父様」「そう云う声はヒョロ子か」「お眼にかかりとう御座いました」「おれも会いたかった。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまあ何という立派な姿になったものだろう」「お父様、お許し下さいませ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様はお船に乗って西洋へ行っていらっしゃるのです。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "露子さんは尋常の四年生でしたが、六年生にも負けぬ位学校がよく出来ましたので、今年から女学校に這入りたいと思って、或る日思い切ってお父さまやお母様に願って見たのですが、お父様は宜しいとおっしゃっても、お母様がお聞きになりません。",
              "citation": {
                "source": "キキリツツリ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結局、おとうさまは、山の祖神の癖にこの福慈神だけはお知りになっていないことに帰着いたしますわね。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
