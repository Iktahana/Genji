        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "首里の名主といはれて居る謝源は大広間の上座にうちくつろいで座つて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間の酔ぱらつて居る家来も流石に王のこの様子に気づいたのか急にヒツソリとなつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「密謀の集会」「大広間の評定」「道中の行列」これには大抵同じ土手や昭和国道がつかわれる。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門宅の大広間　なりひら小僧が中央に座している。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門宅大広間の次の室には　ふんぞり七兵衛の率いる捕方が合図如何と待ちかまえる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ　斯くて――Ｓ＝大広間　殿様の御座へ、殿様がお座りになる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間からは時々賑やかな朗らかな笑声が聞こえていた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿はもと料理屋であったのを、改めて宿屋にしたそうで、二階の大広間と云うのは土地不相応に大きいものである。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に客のない時は大広間の真中へ椅子を持出して、三十畳を一人で占領しながら海を見晴らす。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五日の晩は雨でお流れになるかと思ったらみんな本館の大広間へ上がって夜ふけるまで踊り続けていた。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新噴水は大広間の床を大きく楕円形に掘り窪めて、その底に据えられてあった。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばけもの世界長は、もう大広間の正面に座って待っています。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夕日は言に色を添え、「鶏が銀に輝やいて、日の出の紅の漲るような、夜の雪の大広間、蒔絵の車がひとりでに廻るように、塗膳がずらりと並んで、細工場でも、運八美術閣だから立派なのよ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――考えても――上り端には萌黄と赤と上草履をずらりと揃えて、廊下の奥の大広間には洋琴を備えつけた館と思え――彼奴が風体。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見た処、大広間、六七十畳、舞台を二十畳ばかりとして、見物は一杯とまではない、が賑であった。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　王さまと大臣全員が大広間に集まりました。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日じゅう、お姫さまたちは、海の底の、お城の中の大広間であそびました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、御殿の門をくぐって、銀色の服を着た番兵を見たり、階段をのぼって、金ピカのお役人を見たり、キラキラした大広間へ通されたりすると、ぼうっとなってしまうんだよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、かぎりなく広々とした、雪の大広間のまんなかに、こおった湖が一つありました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、カイは、たったひとりのこされて、何マイルも何マイルもある、広々とした、氷の大広間のまんなかにすわっていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ゲルダは、寒々とした、なに一つない大広間にはいりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察へ行くと、二人は警察の大広間で一人の警部さんに調べられました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "数限りない南京玉が一つ残らず消えてしまうと一所に、警察の大広間には這入り切れぬ程大勢の女の児が机の上や床の上から一時に現われて、警部さんも巡査さんも春夫さんも支那人も身動き出来ぬ位になりました。",
              "citation": {
                "source": "クチマネ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　見渡すかぎり平坦の、曠野と言つていいくらゐの鈍く光る大広間で、御殿らしいものの影は、どこにも無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "立て籠めた莨の煙は上から照り澱められ、ちょうど人の立って歩けるぐらいの高さで、大広間の空気を上下の層に分っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大広間一面のざわめきが精力を出し切って、乾き掠れた響を帯び、老芸人の地声のように一定の調子を保って、もう高くも低くもならなくなった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝肉祭　もう、そのとき、クラッカーを引き合って破裂させる音は、大広間一面を占領し、中から出た玩具の鳴物を鳴らす音、色テープを投げあうわめき、そしてそこでも、ここでも、※々として紙の冠りものを頭に嵌めて見交し合う姿が、暴動のように忽ち周囲を浸した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　エルシノア王城　城内の大広間　王。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　九　城の大広間　ハムレット。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょう、此の大広間で、何か儀式でもあるのかしら。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
