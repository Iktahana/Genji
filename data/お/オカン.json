    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chill",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は全身に悪寒を覚えた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、こうなりゃやけくそだ）　恐愕の悪寒が、激怒の緊張に変った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は判っててよ」　女は、この類いで、この若き獣神が生きとし生けるものの醜悪の底の味いを愛惜し、嘗め潜って来たであろうことを察して、悪寒のある身慄いをした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷のような悪寒が、電流のように速かに、兵卒達の全身を走った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪寒に慄えながら秋の頭は何度も浴槽を想像する。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私は寝床のなかで満潮のように悪寒が退いてゆくのを待っている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少しきたない話ではあるが、昔｜田舎の家には普通に見られた三和土製円筒形の小便壺の内側の壁に尿の塩分が晶出して針状に密生しているのが見られたが、あれを見るときもやはり同様に軽い悪寒と耳の周囲の皮膚のしびれを感ずるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "にこにこ卑しい追従笑いを浮べて、無心そうに首を振り、ゆっくり、ゆっくり、内心、背中に毛虫が十匹｜這っているような窒息せんばかりの悪寒にやられながらも、ゆっくりゆっくり通るのである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、悪寒が身うちに行きわたって、ぶるぶるッとふるえた、そして続けざまに苦しい咳をしてむせび入った。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きると寒暖計が八十度近くに来ているようになると、もう水で顔や頭髪を洗っても悪寒を感ぜず、足袋をはかなくても足が冷えない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……全身は悪寒ではなく、病的な熱感で震えはじめていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだも何だか悪寒がして来た。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日も銀子は、朝から熱を感じ悪寒がしていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそうした気分の底に、どこか或る一つの点で、いつもとちがった不思議の予感が、悪寒のようにぞくぞくと感じられた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新次は、泥棒を見つけた以上にはつとして、頭が白くなる様な悪寒に近い或物におそはれた。",
              "citation": {
                "source": "鍛冶屋の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、一つ食べたら、胸が悪くなって、へんな悪寒がして来て、また蒲団にもぐり込む。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「方なしじゃ、」　思いの他、声だけは確であったが、悪寒がするか、いじけた小児がいやいやをすると同一に縮めた首を破れた寝ン寝子の襟に擦って、「埒明かんで、久しい風邪でな、稼業は出来ず、段々弱るばっかりじゃ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はつくづくと其顔を見てゐると、何といふ事もなく無気味になつて来て、怎うした連想なのか、髑髏といふものは恁※ぢやなからうかと思つたり、紅い口が今にも耳の根まで裂けて行きさうに見えたりして、謂ひ知れぬ悪寒に捉はれる事が間々あつた。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時山中君は、ただ一人台所へ往って立っていたが、何かしら悪寒を感じて眼をあげた。",
              "citation": {
                "source": "天井からぶらさがる足",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、ひどい悪寒がするといって、引被って寝ましたきり、枕も顔もあげられますもんですか。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪寒どころですか、身体はやけますようですのに、冷い汗を絞るんです。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小宮山はそれを聞くと悪寒がするくらい、聞くまい、聞くまいとする耳へ、ひいひい女の泣声が入りました。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は肉身の家族を見ると脱ぎ捨てた殻に纏われるようを悪寒を感ずるらしく、絶対に打ち解けなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "咽喉が痛くて、悪寒がする。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘蕕という所へ狩りに行った帰りに悪寒を覚えて寝付いてからは、ようやく足腰が立たなくなって来る。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゾッと悪寒が背を走った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が、もう一足進めば、すぐ顔を見られる衝立の陰なので、新子は急に悪寒が、胸に上って来た。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山杖を目にした私は、悪寒と吐き気に襲われた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から半次「おかんむりや」と続いて去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "サアそれもチャンと返して帳簿を整理しておかんと今のうまい口に行く事ができない。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
