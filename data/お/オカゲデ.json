          "literary": [
            {
              "text": "あんまり勝手を云うんじゃない、その身体は全体みんな、学校のお陰で出来たんだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい、お陰で昨晩戻って参りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて少女のお陰である。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに私はそんな遠い學校へ毎日あるいてかよつたお陰で、からだも太つて來た。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君と歩いていると、とかく乞食が眼につくね」と啓司が笑って言えば、花田は漸く笑って、「君も、僕のお陰でルンペン以下の人間層に視野が開かれたのさ」　と言って自分の住んでいる町外れの小橋の方へ歩いて行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新三郎も老婆も祈祷のお陰であると思って悦んだ。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お陰で早く判ってありがたい、きっと報います」　侍臣の一人が傍へ寄ってきた。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころは、ぼくが顔を出すのは幸福な小鳥の巣を鷹が覗くようなもんだと思って、そのまま黙って帰ってしまったんですが、そのお陰でぼくはすっかり神経衰弱になってしまったんですよ」「兄から聞きましたわ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、てめえらはだれのお陰で育ったと思っているんだ？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお陰でからだのほうは大いによろしく候う。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の性欲的生活が繰延になったのは、全くこの三角同盟のお陰である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に前人の植福のお陰である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは曰く、私は父祖のお陰で家と広い土地と公債が若干ある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は金に窮つて心中なんぞを為た、と人に嗤れましても、情婦の体を売つたお陰で、やうやう那奴等は助つてゐるのだ、と一生涯言れますのは不好で御座います。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の性格はこの暗闘のお陰で曲折のおもしろさと醜さとを加えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれつき機敏に働く才気のお陰で、見たり聞いたりした所から、美術を愛好する人々と膝をならべても、とにかくあまりぼろらしいぼろは出さなかったが、若い美術家などがほめる作品を見てもどこが優れてどこに美しさがあるのか葉子には少しも見当のつかない事があった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰で、かような会いがたき企てに与り申して、大慶に存じおるところでござる」　そう、真正面から感謝されると、玄白は自分の今までの良沢に対する心持を、心のうちでやや恥しく思わずにはおられなかった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚旅行も唐崎さん――ではない新妻みどりの稼ぎ貯めた財布のお陰で南伊豆まで遠出をし、温泉気分と夫婦生活とを満喫することができた。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに自慢で招んだだけあって彼女の持っている名画の翻刻はいずれも立派な物ばかりでお陰で私は其日一日眼の正月を致しました。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰で美満寿屋も繁昌しお寿賀さんの女将｜振が自然に精彩を加えるようになった。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお陰で道夫は入学試験のとき、どんなに楽だか知れません。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又、近頃は毎日君のお陰で麥酒は買はずに飮めるが辭令を出して了へば、もう來なくなるだらうから、當分俺が握つて置かうかと思ふと言つたさうである。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もお陰でだいぶん迷惑をさせられたが、オルガという女も、つまり、木村から処分されて来たもんさ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角四面の地主屋敷に生い立って、一人ぼっちの生真面目な教育を受けてきた少年のわたしは、こうしたらんちき騒ぎや、ほとんど狂暴ともいうべき無遠慮な浮かれ気分や、見ず知らずの連中との臍の緒切って初めての交際やのお陰で、たちまち頭がカーッとなった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰でわたしは、全身の血がカッと燃え立つような思いをすることが、よくあった。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもねお陰でもうすっかりいい様になったんです。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺の家がこの童のお陰で非常に福々になるが、爺は野良から還ってくると、かならずデコにいって、にこりと微笑して出てくるので、婆はへんに思い気を悪くする。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "お陰で今も足はたいへん丈夫でございます。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がいささかでもこの気魄と克己心を持っておりますのは、母から受けついだ血であり、母の励ましのお陰であろうと思っております。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな工合いの名前のおかげで、おめえの恰好もどうやらついて来たじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
