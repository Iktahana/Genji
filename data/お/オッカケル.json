        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしあまりあせり過ぎては、却って自分にある好い物を捨てて自分にないものを追っかける恐れがありはしないか。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画はあひる泥坊を追っかけるといったようなたわいないものであったが、これも「見るまでは信じられなくて、見れば驚くと同時に、やがては当然になる」種類の経験であった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の村には燃えさしの家が、ぷすぷす燻り、人を焼く、あの火葬場のような悪臭が、部隊を追っかけるようにどこまでも流れ拡がってついてきた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、皇子は王様がお亡くなりになってから暫く私に会いませんので、会いたくてたまらず、猫を追っかけるふりをしてここまで来られたのだそうで御座います。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多数の人の血眼になっていきせき追っかけるいわゆる先端的前線などは、てんでかまわないような顔をしてのんきそうに骨董いじりをしているように見えていた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、我慢できない胸くその悪さを覚え、その熨斗袋を懐にし、青扇夫婦のあとを追っかけるようにして家を出たのだ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は瓦が落ちやしないかと思って出て往く一行の後を見送りながら、土間へおりて下駄を履き、追っかけるように玄関口へと出た。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかしな奴だな」「なんだ、あれは」　村の者は老人の正体を突きとめようと思って追っかけたが、別に悪いこともしていないから、悪人を追っかけるように追っかけることもできない。",
              "citation": {
                "source": "虎杖採り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "追っかけると、また逃げだしたが、足をゆるめると、また足をゆるめて顧眄ったが、そのうちに一本杉の方面へ姿を消して往った。",
              "citation": {
                "source": "虎杖採り",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫌がる、追っかける。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花田が烏を追っかける姿を腹を押えて笑いこけて見ていた啓司は親指で眼がしらの涙をこすりながら言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女はその馬車に乗って、停車場に向ったのでしたが、やはり私は不安だったので、自転車で後から追っかけることにしたのですが、しかし彼の女は早く発ってしまって、私が追いつかない中に、この不幸が襲いかかってしまったのでした。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「往ってやるとも、こんな家に、何人がいるもんか」　長吉はお鶴を追っかけるように体を浮かしたが、さすがに起っては往けなかった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音蔵の後から音蔵を追っかけるようにして四五人の者が来ていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四分の一マイルほどあるこの通りを、彼はそんなに年をとった人間には全く思いもよらない敏捷さで駈け下り、追っかけるのに私は非常に難儀をしたほどであった。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋を穿いて追っかけるほどの兇状でもないので、まあ其のままに捨て置きましたが、あとで聞くと木更津の方で変死したそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追っかけるのはいや」「なぜ」「なぜって――こんなにおおぜいの人がいるんですもの。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると貧乏爺め、追っかけるようにまた一句投げつけるじゃないか。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここからすぐに追っかけるんだ」「ちくしょうッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、ふたりのあとを追っかけるようにして、もう一組みの駕籠が同じ仁光寺の門前へ止まったと思われましたが、中から降り立った人の姿をみると、意外やそれはつい先の先まで木魚庵に居合わした同心主席の、あばたの敬四郎とその配下だったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱりさ、これを追っかけるのはムリだよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろからはお爺さんが青い眼玉を血走らして――「藍丸王様……王様……藍丸様ア」　と呼びながら追っかける。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもお爺さんは追っかける事を止めなかった。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「妾を追っかけるのでございますの」「なるほど、そいつは悪い奴だ」広太郎愉快に笑ってしまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キー、キー、キー」となきながら、猿がその後を追っかける。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠三は鸚鵡を追っかける。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそポカリとやられるかもしれねえ」　飛鳥の後を追っかける。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり勇気づいたお町と忠三、歯跡歯跡と追っかける。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそいで、おっかける　子供部でカンゴ婦と一緒のを見つけ買いものすまして、カンゴ婦をかえし、車へのせてかえし、自分たち（寿）マデレーヌの角から Taxパリからモスク※へ打った電報が南米をまわったとは！",
              "citation": {
                "source": "「道標」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏はいつも牝鳥をかばってやって、人がいたずらをするとみの毛をさかだてておっかけるが鴨は置いてきぼりにして夢中になって自分からにげ出してしまう。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
