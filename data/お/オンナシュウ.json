        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女衆が大勢居ても、一人抜けてもお座敷が寂しくなるもの。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "参詣の女衆が、忘れたればとって、預けたればとって、あんだ、あれは。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もくりと、掻落すように大木魚を膝に取って、「ぼっかり押孕んだ、しかも大い、木魚講を見せつけられて、どんなにか、はい、女衆は恥かしかんべい。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おお、それからいまのさき、私が田圃から帰りがけに、うつくしい女衆が、二人づれ、丁稚が一人、若い衆が三人で、駕籠を舁いてぞろぞろとやって来おった。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男衆も女衆も、その火を消す間に、帳場から、何から、家中切もりをしてござった彼家のお祖母様が死なしゃった。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫さまえ、あのよなお方、世界中の女衆が……ほんに奇麗な、蝋細工見たやうな。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の裏口に出てカルサン穿きで挨拶する養子、帽子を振る三吉、番頭、小僧の店のものから女衆まで、殆んど一目におげんの立つ窓から見えた。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "源は煤けた障子を開けて、ぬっと蒼ざめた顔だけ顕しながら、「私は女衆ばかりかと思って」「女衆ばかりかと思ったら――御生憎さま」　と、炉辺で男の笑声が起る。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "女衆だすで、女中さんだツせ。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸口毎に女衆がしゃがんで、菜っ葉を洗ったり米をといだりしていた。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端に水を汲んでいる女衆や、畑から帰って来る男衆は、良平が喘ぎ喘ぎ走るのを見ては、「おいどうしたね？",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が余り激しかったせいか、近所の女衆も三四人、薄暗い門口へ集って来た。",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜釣りの魚を晩選りと云って漁師町から女衆が売りに来るのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ、宮さんがお通りじゃンすでエ……近所の女衆が叫んでいる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女衆がナフタリンを入れといたとみえて、ナフタリンの香りがぷんぷん匂つてゐる。",
              "citation": {
                "source": "雨",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「米英げきめつツ、えいツ、えいツ」といふ女衆の聲が村の上を彈ぜてゐる。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと竹槍けいこが終つて、またひとくさり講演になると、女衆は我家の忙しさを思つて氣もそゞろになつてくるのであつた。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端に水を汲んでゐる女衆や、畑から帰つて来る男衆は、良平が喘ぎ喘ぎ走るのを見ては、「おいどうしたね？",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が余り激しかつたせゐか、近所の女衆も三四人、薄暗い門口へ集つて来た。",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕈を売る女衆が、ひっきりなしに呼びかける。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女衆は、嫁菜や芹つみに、ずくずくする畔道や堀の岸に集った。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仙太さんでねえしか」　女衆は手のひらで額へ陽かげをつくりながら声をかける。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しようむないうちの女衆や、淫賣娘みたいなもんを連れて御芝居見に行つて、何が面白いのでつしやろ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの女衆で間に合ふ事でしたら、どないになりと御隨意に願ひますと、こない云ふてゐやはりました。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三田さん、昨晩は女衆の寢言や齒ぎしりやおならをきかされて、ようやすまれへんでしたやろ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あては、あんさんがうちの女衆になくなつたお金の行方を訊ねてゐやはるのやと思ふて、お客さんの手をからんでも、自身たづねてあげるのがほんまやろと考へましてなあ、三人とも裸にむいてお目にかけようとしたのですが、そんならとつとと去にまつさ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女衆どもは、少し大げさに云えば、待機していた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
