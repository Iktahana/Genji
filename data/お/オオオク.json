          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "己に毒薬を装らせたし、ばれかかったお道さんの一件を、穏便にさせるために、大奥方の計らいで、院長に押附けたんだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、ときどき上流の家庭にも、しのび込んで、そうして、そこの大奥様の財布なんか盗んで家へ持ってかえり、そのお財布の中に、奇妙な極彩色の絵なんか在る場合、亭主とふたりで、大いに笑って得意らしいが、何もあれは、大奥様の好色の念から、その絵をいれて置くのじゃないのだぜ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうした、早く言ってくれ」「旦那様、びっくりなされちゃいけません、大奥様は御病気でお亡くなりになりますし、若奥様は苗軍の盗人のために、迫られて亡くなられました、なんとも申しあげようがございません」　趙は青い顔をして立ったままで何も言えなかった。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の頃の恁うした場合の、江戸の将軍家――までもない、諸侯の大奥と表の容体に比較して見るが可い。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍の住居は大奥まで湧上つた。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、村の名医が、また白足袋をはいてお見えになり、私が昨日の強い注射の御礼を申し上げたら、効くのは当然、というようなお顔で深くうなずき、ていねいにご診察なさって、そうして私のほうに向き直り、「大奥さまは、もはや御病気ではございません。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中疱瘡は津々浦々まで種痘が行われる今日では到底想像しかねるほど猛列に流行し、大名高家は魯か将軍家の大奥までをも犯した。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家大奥の台一式の御用を勤めるお台屋の株を買って立派な旦那衆となっていた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅いろ透かし骨の扇子といえば、日本橋石町たらちね屋が自慢の品物、たしか大奥にも出入り御用を仰せつかっているように聞いておりましたゆえ、奥女中の持ちものとにらんだだけのことでござります」「灯台もと暗しとは、まさしくこれじゃのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "大奥であろうが、天竺であろうが、人を殺した女をのめのめ見のがしておいたら、八丁堀の恥になるんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、こと大奥にかかわりができたとなると、むっつり右門、いかに捕物の名人であったにしても、たやすく乗りこんでいかれるわけがない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや、だれか大奥お坊主衆におちかづきはござりませぬか」「あるとも！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃべり者はあっしばかりと思っていたのに、大奥にもそんなたのもしいのがいるとはうれしいね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬまでにいっぺん大奥の女護の島へお参りしてえと思ってたんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "なろうことなら、年の若いべっぴんからお引き合わせを願いますよ」　やかましくさえずりだしたのをしりめにかけて、右門、平七のふたりは一ノ橋ご門から左へお薬園の前に抜け、ぐるりと回ってご本丸大奥外のお番屋を訪れました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここはいわずと知れた大奥警備の番士たちの詰め所です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきべやを借りうけて、伝六ともども待ちうけているところへ、まもなく三宅平七が伴ってきたのは、大奥｜名代のおしゃべり坊主｜可賀でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏は唐の金鶏鳥、四国土佐のおながどり、あるはまためじろ、ほおじろ、うぐいすならば鳴き音が千両、つるに、ひばりに、恋慕鳥、別して大奥のお女中がたは、この恋慕鳥が大の好物でござりやす。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぜひとも今明日中に、大奥仕えのお女中残らずをお詮議いたさねばなりませぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんぞお考えあってのことでござりましょうが、城内の手入れはいうまでもないこと、大奥お手入れとならば、手続きがなおさらめんどう、あのように吹聴させて、大事ござらぬか」「そのご懸念ならば、手つづきせずとも、たぶん伊豆守様が――」　莞爾と笑っていったことです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大奥付の腰元らしい者は者でしたが、ようよう二十になるやならずの、目ざめるばかりの美形がいち人、突如として正面お座席近くに姿をみせて、文字通り万緑叢中紅一点のあでやかさを添えましたので、いぶかしさに打たれながら主水之介も目を瞠っていると、四人の騎士がさらに奇態でした。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸大奥お出入り、お手当米二百石、後藤縫之介と、名字帯刀までお許しの呉服師だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとそろいの着手も、おそらくは城中お出入り、大奥仕えに縁のある者にちげえねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋たもとに、総格子六間の間口を構えて、大奥御用呉服所と染めぬいた六間通しののれんが、堀から吹きつける風にはたはたとはためきながら、見るからにいかめしい造りでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "城中お出入りの坊主衆、大奥仕えの腰元お局、あるいはまたお旗本の内室といったような身分｜由緒のいかめしいお歴々ばかりなのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠宅というとふた間か三間の小さな家にきこえるが、法眼といえば位は最上、禄は百五十石、はぶりをきかした大奥仕えのお鍼医の未亡人がこの世を忍ぶ住まいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家は大奥入りをしていられるとみえて、お坊主の顔がのぞいては消え、消えてはまたのぞきながら、しきりと豊後守の青い顔と何か囁き合っていたが、やがてのことにお廊下をこちらへ、高々と呼び立てた声があがりました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
