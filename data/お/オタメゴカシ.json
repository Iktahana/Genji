    "definitions": [
      {
        "index": 1,
        "gloss": "self-interested show of kindness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
