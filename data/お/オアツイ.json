        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "明治三十八乙巳年十月吉日鏡花　　　　　　　一「はい、貴客もしお熱いのを、お一つ召上りませぬか、何ぞお食りなされて下さりまし。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十八乙巳年十月吉日鏡花一「はい、貴客もしお熱いのを、お一つ召上りませぬか、何ぞお食りなされて下さりまし。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうぞ、唯今お熱いお湯を。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十目の見るところぢやございませんか」　富山は頷きつつ、「さうだらうね」「あれは宜うございませう」「一寸好いね」「まづその御意でお熱いところをお一盞。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に今日はお熱いくらゐでございます。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、お糸さんが軈てお燗を直して持って来て、さ、旦那、お熱い所を、と徳利の口を向けた時だった、私は到頭｜耐らなくなって、しかし何故だか節倹して、十円の半額金五円也を呈して、不覚又敬意を表して了った。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今お熱いのを持って参ります」　と言いながら女中はそこにある徳利を持添えて岸本に酒を勧めた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、お熱いのが参りました」　女中の一人が勧めてくれるのを盃に受けて、岸本は皆の楽しい話声を聞きながら、すこしばかりの酒をやっていた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、お熱いところを」と、徳利を金鎖の親爺の前へ、つと差し出した。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お暑う御座いますが、お暑い時には、かえってお熱いお茶を召上った方が、かえってお暑う御座いませんで……」「酷くお暑い尽しの台詞だな。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ濃い泥の海となって、深さが膝の辺まで来る、なお熱い事は熱いけれど火傷するほどの熱湯では無い。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあお熱いところでも召上れ。",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「おお熱い！",
              "citation": {
                "source": "球突場の一隅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だか額がお熱いようで心配だから、熱を測ってごらんなさらない。",
              "citation": {
                "source": "愚かな一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は燗、さかなはきどり、酌は髱なアンてことを申しながら、野郎のおしゃくで恐れ入りますが、どうぞお熱いところをお重ねなさいまし。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "パセリなどをお添えしてどうかお熱いうちに召し上がって下さいませ。",
              "citation": {
                "source": "オフ・ア・ラ・コック・ファンタスティーク",
                "author": "――空想半熟卵――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのチョイと姉さん、お熱いのを一つ」と言つた。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は「すぐお熱いのが來ますけれど」と言つて燗徳利を取上げて三藏の顏を見た。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何卒おついでの節よろしく、また何かいゝものが有りましたら頂かして下さいますよう仰言つて下さいまし、こちらもまだなか／＼あつうございます　東京もおあついでせうね。",
              "citation": {
                "source": "消息",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおあついッ」　芳ちゃんが笑った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この　あついのに、かさなしでは　さだめし　おあついことで　ございましょう。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
