    "definitions": [
      {
        "index": 1,
        "gloss": "style of Japanese folk song associated with Niigata Prefecture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まだ宵のうちは帳場の蓄音機が人寄せの佐渡おけさを繰り返していると、ぽつぽつ付近の丘の上から別荘の人たちが見物に出かけて来る。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝、八時に夷港から、おけさ丸が出る。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さまよ、お山の道は、おけさが擦れるよ、ほい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏で飲んで食べる、おけさ飯とアブサン。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭子のところで、いつも謳つてゐた「奴さん」だとか、「おけさ踊るなら」も、人々の笑ひの種子だつた。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡の夏期大学云々というのは全くウソで、所謂大佐渡のシベリヤ寄りの海岸線を彷徨したり、偶然来合わせた一組の女学生上り達と一緒に「おけさ」を見たり御馳走にあずかったり（尤も一夕座談会はやったが）しただけだったが、何にせよ之は大変なことになったと思ったのである。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口の監守はと見ると、扉につかまったまま、靴尖でコツコツと佐渡おけさを叩き鳴らしていた。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おけさ節も出れば、いそ節、ほうかい節、しののめ節も出る。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみしい夜が、お隣の蓄音器によつて賑つた、唐人お吉、琵琶歌、そして浪花節だ、やつぱりおけさ節が一等よかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "知性が知性を滅ぼしておけさ踊りをしてるんだ」「しかし、日本も累進率の税法で、これから文化がどしどし上る一方だよ。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそのことおけさでもやるか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃の人ならおけさを思ふであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、不意に、（意見せられて、さし俯向いて――）という、おけさの一節が、頭に浮びました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "おけさ節に、インタアナショナル、北大校歌に、オリムピック応援歌、さては浪花節に近代詩といった取り交ぜで、興がわくままに大声はりあげ、しかも音痴はこの上なしというのですから、他人には見せも聞かせもしたくない、のんびりした阿呆らしい風景でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜七時過、祖母、おけさ、ばあやをつれて帰って来られる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、厄介なことに、私は東京を出る時分から腰のあたりに小さな腫物ができて、どうもこのまゝうつちやつておけさうもないので、宿へ外科専門の瀬尾博士が寄つて下さつたのを幸ひ、その自動車で一緒に南市の同仁会病院へ連れて行つてもらつた。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ったから、僕はますます落着きはらっているところを見せるために、泳ぎながら佐渡おけさを歌ったり、草津節を呻ったりした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以前は、この附近に三光節なるものがあつた由で、太田氏の説によると、三光節は唄の調子から判断して「佐渡おけさ」の流れを汲んだものだとされてゐる。",
              "citation": {
                "source": "出雲鉄と安来節",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、サン子といふ美声の妓が境港にゐて、北国船から「佐渡おけさ」を聞き、これに独創を加へて三光節といふ一種の俚謡を完成し、これがこの地方に流行したのだといふ。",
              "citation": {
                "source": "出雲鉄と安来節",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おけさ、安來節、追分などが重なもので都都逸二上り新内のやうなものは滅多に聞かれません。",
              "citation": {
                "source": "佐渡が島のこと",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐渡に來ておけさをどりをせぬやつは木佛金佛石ぼとけなり小佐渡來よ大佐渡も來よ文三とおけさをどりを共にをどらむ　最後に親よりまして自分を慕つてくれる四十人あまりの青年と輪を作つて踊りました。",
              "citation": {
                "source": "佐渡が島を出て",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本國どうなるとても佐渡が島おけさをどりて文三を待て日本國どうなるとても文三はおけさをどりてまた歸り來む　おけさと言ふ民謠はもともと新潟縣の出雲崎邊から佐渡に傳つたものらしいのですが、今では佐渡、佐渡のうちでも相川が本家のやうになつて居ります。",
              "citation": {
                "source": "佐渡が島を出て",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "相川の古いおけさ、小木の古いおけさ、新潟の新潟おけさと言ふのを年寄から聽きましたが、今の出雲崎おけさ及び柏崎おけさとよく似たものです。",
              "citation": {
                "source": "佐渡が島を出て",
                "author": "江南文三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
