    "definitions": [
      {
        "index": 1,
        "gloss": "dance where a female dancer dresses up as a man (late Heian to early Kamakura period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
