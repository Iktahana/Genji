      {
        "index": 1,
        "gloss": "visiting a shrine or temple to give thanks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
