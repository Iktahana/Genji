[
  {
    "uuid": "188eb804-db2e-52c2-8864-dff24ebffc55",
    "entry": "汚職",
    "reading": {
      "primary": "おしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
