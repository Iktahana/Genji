      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お前さんについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お前さんがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お前さんというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお前さんの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお前さんが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お前さんを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お前さんの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お前さんはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお前さんがあります。",
              "source": "幻辞"
            },
            {
              "text": "お前さんは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お前さんについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお前さんの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お前さんの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお前さんが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お前さんについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお前さんは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお前さんについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お前さんという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお前さんの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お前さんを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あれは、こなひだの爺さんからあづかつてゐる大事の品だが、しかし、お前さんがそんなに欲しいならやつてもいい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんたちがどんなに田舎者見てえな恰好をしてたって、番頭に化けたって、腰弁に化けて居たって、第一、おめえさんなんぞ、上はアルパカだが、ズボンがいけねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからな、お前さんは、番頭さんにゃ見えねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらあ、一月娑婆に居りあ、お前さんなんかが、十年暮してるよりか、もっと、世間に通じちまうんだからね。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、お前さん、何だぜ、俺と話しをしてるとお前さんの迷惑になるかも知れねえぜ」（此野郎。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だってさ、お前さんのあの人だって、いつまでもリヨン訛じゃやり切れまいさ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全體お前さんの借といふのは今どれ位あるんだい。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ政夫さんのいうのは御もっともです、私共が勝手なことをして、勝手なことをお前さんに言うというものですが、政夫さん聞いて下さい、理窟の上のことではないです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子の死は全くそれ故ですから、親の身になって見ると、どうも残念でありまして、どうもしやしませんと政夫さんが言う通り、お前さん等二人に何の罪もないだけ、親の目からは不憫が一層でな。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かなことでしょうがこの場合お前さんに民子の話を聞いて貰うのが何よりの慰藉に思われますから、年がいもないこと申す様だが、どうぞ聞いて下さい」　お祖母さんがまた話を続ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の一人がつかつかと傍へ寄り、　「失礼だが、若しやお前さん武井の安五郎さんの身内で神沢の小五郎さんとは仰しゃいませんか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「へえ、儂は小五郎だが、そう言うお前さんは誰方で？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝離れ　七五郎、傍の若い者に、　「おッ、兄哥さん、お前さんに訊ねるが、あれァ確か武井の御貸元で御座ンすね」　「そうだ」　石松が、　「そうか、あれが武井のども安親分か」　七五郎が若い者に、　「聞きゃ今日の昼間、町外れの街道で武井の御身内が一人斬られなすったと云う話だが。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前、清水の次郎長、御見知り置かれて幾久しく御別懇に願います」　「ああお前さんか、次郎長と云うのは？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お勘、　「うちの七五郎、若しやお前さん処へ来てやしないかと思ってね」　「まあ七五郎さんもまだなの。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃしばらくお前さん処で休んで行こう」Ｓ＝内部　石松が戸を開ける。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛が、　「清水の次郎長さんとか仰言いましたが、お前さん、やくざ渡世の人だろう」　「そうだ、爺つあん」　お静戻って来て　「はい、縫いますわ」　「あ、こりゃどうも済まない」　源兵衛が、　「失礼だが、此処は堅気の年寄りの住居だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんのような兇状持の来る処では御座いません」　「爺つあん、何んだって？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「石松が今夜お前さんを家へ連れ込んだのは、彼奴がお前さんの身内になりたいからだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松はお前さんの児分になりたいらしい。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さん若しや森の源兵衛さんじゃ御座いませんか」　源兵衛、先刻から知っていたと見え、淋しく笑って、　「半さん……久し振りだな」　「矢っ張り源兵衛さんか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の二十八人の中に次郎長程もえれえのが五六人居るからね」　「お前さん仲々詳しいね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛が店から、　「お客さんお前さん詳しい様だが、余り詳しくないね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「いや、喰い度くねえンだ」　「何処か悪いんじゃない」　「……」　「でも一杯ぐらい、食べて置かないとお前さん」　「喰い度くねえったら」　お民、茶碗を置く。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「お前さん今夜、どうかしてるわ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、どうしたのお前さん」　七五郎、酔いつぶれる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お民の声が、　「お前さん」　七五郎、振りかえる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん、何処でこんなお金を手に入れたの？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんたち」と小そのは総てを語ったのちにいう、「何人男を代えてもつづまるところ、たった一人の男を求めているに過ぎないのだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえさんは、この頃、どうかおしかえ」　と老妓はしばらく柚木をじろじろ見ながらいった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
