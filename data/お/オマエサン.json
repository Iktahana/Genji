[
  {
    "uuid": "b9f126b1-1b2a-5cf7-8c3a-b9dd2993691c",
    "entry": "お前さん",
    "reading": {
      "primary": "おまえさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
