        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陰陽寮で占わすと東西に兵乱の兆があると奏した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の海部の内、亀卜に達したものが、陰陽寮にも兼務する事になつたものと見える事は、後代の事実から推論せられる。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭文の名は、陰陽寮と神祇官とに行はれた名である。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "此卜部が、陰陽寮にも勢力を及ぼしました。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより陰陽寮の陰陽師は声聞師ではない。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、中務省の陰陽寮から出たお話だとすれば、きっとまた何か悪いことが起るに違いないわ。",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、陰陽寮から、中務省のまえまで逃げた。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
