        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「知らんのかお前、あれ叔父ちゃんえ。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前忘れんぼやな、あれ叔父ちゃん。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "最う知って居る事を習いに学校へ行くよりお叔父ちゃんのお話の方がためになると理屈を並べたけれ共とうとう叔父が学校へ迎に来て呉れると云う約束をして貰って出掛ける事になった。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の時分は、今私の書斎になって居る陰の多い、庇が長い為に日光が直射する事のない、考えるには真に工合の好い五畳が空き部屋になって居たので、其処がすぐ「お叔父ちゃんのお部屋」に定められて居た。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お叔父ちゃんの御本」は皆テラテラした紙に面白い絵の沢山書いてある好い香いのするものであった。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お叔父ちゃん、　随分いけないわねえ此那に御本よごして……　先生に叱られない？",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しお叔父ちゃんの話す様に神様は偉いなら、お願いさえすればきっと自分もノアにして下さるだろうと云う事を思わない訳には行かなかった。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の棒を並べた様な垣によっかかって、人の足元の塵を浴びながら叔父ちゃんが苦しがって居るのに、沢山通る人の一人もどうしたのかと云ってさえ上げる人はないのか。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故自分が行ってそんな悪い人達を睨みながら大切にお叔父ちゃんを連れて来て上げなかったろう。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は途方にくれて、きっと気が急に違ったに相違ない叔父の素振りをおずおずながめて居たが到頭堪え切れなくなって、「帰りましょうよ、　ね叔父ちゃん、　帰りましょうってば。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お叔父ちゃんが死んだんだって？",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとといまで彼那にお話をして下すったお叔父ちゃんが死んじゃったって？",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼那強そうな体のお叔父ちゃんが勿論繃帯はして居たにしろ急に死んでもうじきお葬式をして埋めて仕舞うと云う事は、あんまり手順が早すぎる様な心持がした。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだお叔父ちゃんが来たのだ。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を膝にのせてその水色を見つめて居ると、物恐ろしさは段々消えて、「ほんとにお叔父ちゃんは死んじゃった。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、常に叔父の云って居た事が間違わなければ、好い事をした人は好い所へ行く筈だから、　お叔父ちゃんも今にどっか好い所へ行くのだろう。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「叔父ちゃん、ほら、臼だよ。",
              "citation": {
                "source": "人の国",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不審に思った鉄五郎が物蔭から出てノコノコ勝坊の傍へ寄り、Ｔ「あのおじちゃんは何処へ行った？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊フト思い出した様に、Ｔ「おじちゃんは巾着切だね」　と訊く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「巾着切のおじちゃん遊ぼうよ」　これには流石の三次も面喰らった。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊、鉄五郎の肩越しに三次の方を見て、　「おじちゃん何や？",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次、今度は鉄五郎に、Ｔ「旦那子供は正直で御座んすね」　皮肉に言って勝坊の手を取って、Ｔ「おじちゃんとお稲荷さんで隠れん坊をしよう」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「姉ちゃん昨日の巾着切のおじちゃんだよ」　お絹が、えッと驚いた。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、おじちゃん、どうしてそんな脚でいくらでも人を斬ったり、はつッたりすることが出来るの？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじちゃんの顔はこっちだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」葉子は優しく言って、「まま今おじちゃんにお話があるの。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじちゃんは、あたいのお父さんがいい人だと思う。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、おじちゃん。",
              "citation": {
                "source": "やんちゃオートバイ",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弦おじちゃん、大変でしたね」嫂の喜代子も、お妻について弦三を庇った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、ミツ子、おじちゃん、おかえんなさいを、するのですよ」　ミツ子は母の膝の上で、肥った首を、弦三の方にかしげ、怪訝な面持で覗きこんだ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
