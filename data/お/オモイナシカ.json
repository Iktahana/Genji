        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "膚の細い、黄い石や、黒い石の上を辷ると、思いなしか、沈んだ、冴えた声をして、ついと通る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、思いなしか、眼の光にも曇りが出来て、何となしに憔悴した表情がこの人の全外容に表われているのであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋を穿いた足の甲へも落ちた上へまた累り、並んだ傍へまた附着いて爪先も分らなくなった、そうして活きてると思うだけ脈を打って血を吸うような、思いなしか一ツ一ツ伸縮をするようなのを見るから気が遠くなって、その時不思議な考えが起きた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか青年の顔がまっかになっているように思われた。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、そのずっと先の方に恵庭の奇峰が夜目にもかすかに見やられるようだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしかその死んで凍えてしまった小十郎の顔はまるで生きてるときのように冴え冴えして何か笑っているようにさえ見えたのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子を一枚細目に開けてあるのが、縦に黒く見えて、薄か、蘆か揺ぐにつれて、この催とて、思いなしか、長く髪の毛の動くような色が添った。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねつけ蜻蛉が、ふわふわと、その時立ったが、蚊帳に、ひき誘われたようにふわりと寄ると、思いなしか、中すいて、塔婆に映って、白粉をちらりと染めると、唇かと見えて、すっと糸を引くように、櫺子の丸窓を竹深く消えたのである。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "優しい柔かな声が、思いなしか、ちらちらと雪の降りかかるようで、再び悚然として息を引く。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――あれあれ、」　女山伏の、優しい声して、「思いなしか、茸の軸に、目、鼻、手、足のようなものが見ゆる。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "脣の色少しく褪せたるに、玉のごとき前歯かすかに見え、眼は固く閉ざしたるが、眉は思いなしか顰みて見られつ。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、晴れた朝がまた陰って来た。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、不思議に客人の気を悪くして、入相の浪も物凄くなりかけた折からなり、あの、赤鬼青鬼なるものが、かよわい人を冥土へ引立てて行くようで、思いなしか、引挟まれた御新姐は、何んとなく物寂しい、快からぬ、滅入った容子に見えて、ものあわれに、命がけにでも其奴らの中から救って遣りたい感じが起った。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年まえの春から夏まで、百日も経たぬうちに、女の、髪のかたちからして立派になり、思いなしか鼻さえ少したかくなった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、気のせいか、段々｜窶れるようには見えるけんど、ついぞ膝も崩した事なし、整然として威勢がよくって、吾、はあ、ひとりでに天窓が下るだ、はてここいらは、田舎も田舎だ。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、娘は日ごろより少し多く飯茶碗の数を重ねた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、ひえびえとした気流が昨日とは何か変って感じられたものだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　思いなしか、旅人の瞳は鋭くひかった。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、頭の上の電燈が薄暗くみえても、床の間に生けてある茶の花の白い影がわびしく見えても、怪談らしい気分を深めるにはまだ不十分でした。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか、顔のこしらえまで、――傍にならんだのとそっくりなのに、聾桟敷一驚を吃する処に、一度姿を消した舞妓が一人、小走りに駆け戻るのと、花道の、七三とかいうあたりで、ひったり出会う。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛吉は心なく垣間見た人に顔を見らるるよう、思いなしか、附添の婦人の胸にも物ありげに取られるので、うつむいては天窓を掻いた。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんぼろの婆じゃありましてございますが、一生懸命、あんな役雑な三味線でも、思いなしか、あの時くらい、隅田川の水にだって、冴えた調子は出たことがございませんよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか病人の眼は蛇のように忌らしくみえて、口から時々に紅い舌をへらへらと吐く。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしか手あたりの小柄なからだ、そう長くは感じなかったあの人の髪もこれに似ているように思われてなつかしい気がした。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "高雅な所も別人とは思えないのであるが、初恋の宮は思いなしか一段すぐれたものに見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫君を美しいと思って、夫人に劣っていないと見たものの思いなしか、やはり一段上の美が夫人にはあるようで幸福な人と不運な人とにはこれだけの相違があるものらしいなどと右近は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしかその爪音は、人の涙をはじき出すように哀れに顫えていた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子の思いなしかその顔にも少しやつれが見えるようだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私の思いなしか、それともその日その日の気もちから来たことも御座いましたでしょうか。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おもいなしか往来をあるいている人たちでも浮足立って感じられた。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
