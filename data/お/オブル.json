          ],
          "literary": [
            {
              "text": "俊頼の歌に「唐くにゝ有ける事はいざしらず、あづまの奥におぶる石竹」。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "童伊は水の中で易々と大人をおぶることが出来た。",
              "citation": {
                "source": "蕎麦の花の頃",
                "author": "李孝石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじや、わしがおぶるか？",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、黄色をおぶるにもまた濃淡あり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
