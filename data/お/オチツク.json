[
  {
    "uuid": "4239d9d8-89eb-55dd-87f9-f19bb5df5eba",
    "entry": "落ち着く",
    "reading": {
      "primary": "おちつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
