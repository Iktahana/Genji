    "definitions": [
      {
        "index": 1,
        "gloss": "afternoon snack (eaten around 3 o'clock)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お三時でございますよ。",
              "citation": {
                "source": "乞食の子",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒型にかためられた茶色の御飯と、味噌汁のようなものと胡麻塩、そんな風な食事でしたが、真面目に務めているひとたちには、時々お三時があると云うことです。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "お三時に牛乳を飲んでいると、お姉さまはふと手を休めて、お言いなさった。",
              "citation": {
                "source": "牛乳と馬",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中たちから小遣をもらっては、子供たちのお三時のために、或は晩の惣菜のために、勝手なものを買いこんでくる。",
              "citation": {
                "source": "女客一週間",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あひるさんとにはとりさんはなかよし１　お三時に紅茶をのみました。",
              "citation": {
                "source": "あひるさん　と　にはとりさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お三時のチヨコレートを戸棚の中に入れておきますよ。",
              "citation": {
                "source": "お猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お三時ものどに通りません。",
              "citation": {
                "source": "お猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はお三時の茶を植木やと一緒にしながら言った。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は老職人の村さんとお三時の時にいった。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして内所でビスケットを持って来させ、尚お三時まで乃公の帰ったのを黙っている約束をさせた。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことが始まりで、病気の時の介抱、学課の復習、ピアノの練習、弁当のお数やお三時の心づかい、等々の役目がだんだん幸子から雪子の方へ移って行った。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お三時に、と云って冷麦の丼が運び込まれたあとで、幸子だけが打ち合せのために母屋の方の一と間へ呼ばれて、未亡人と対坐したが、正直のところ、彼女は五分か十分も話を聞いているうちに、早くも今日の招待に応じたことを後悔する念が湧いた。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼女はお三時の支度にメリケン粉を捏ねている下働きのお秋に聞いた。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも一つの習慣にはちがいないが、オヤツやお三時の起こりは存外にあたらしいものなのである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしなどの生まれた村では、オヤツだのお三時だのという言葉はなくて、小さい児はこれをナンゾといっていた。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御先祖さまの日、御先代の日、誰の日、彼の日、等々と、精進日つづきで、どんなけちんぼのとこでもお魚をつけるおさんじつ（一日、十五日、廿八日）まで、お精進が繰込んでいる。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "声をかける勇気がなく、躊躇している）政吉　　おさんじゃねえか。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
