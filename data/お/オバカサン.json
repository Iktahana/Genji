        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お馬鹿さんについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お馬鹿さんがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお馬鹿さんの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお馬鹿さんが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お馬鹿さんの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお馬鹿さんがあります。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お馬鹿さんについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお馬鹿さんの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお馬鹿さんが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお馬鹿さんは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお馬鹿さんについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお馬鹿さんの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お馬鹿さんを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お馬鹿さんねえ、アンタは……出て行ったってモウ駄目よ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつや　ほんとうに仕様のないお馬鹿さんだね。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お馬鹿さんなどという愛称は、私には使えない。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のお馬鹿さん　現在の東京には、このような浅ましい傾向が、どれだけ増大して行くかわからぬ勢である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、幸いにしてそのような性格を持った男性とスイートホームを作り得た婦人は、それこそ例の文化生活を徹底的に味わい得るわけであるが、さもない限りこうした要求は、自分の夫以外の「私のお馬鹿さん」や「お人形さん」に求めねばならぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしから見れば、夫なんて紙人形に等しいお馬鹿さんだ。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馬鹿さんでなければ、あんなに昼となく夜となく、研究室で屍体ばかりをいじって暮せるものではない。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆村探偵のお馬鹿さん！",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馬鹿さんが引返して来る頃には、あたしはもう此の世のものじゃ無い。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはお馬鹿さんよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事も察しないで、ほんとにお馬鹿さんねえ。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なんてお馬鹿さんなの、あなたは？",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにお父さんのお馬鹿さんからたんまり取ってきたお金があるからね』と言いながら懐をたたきました。",
              "citation": {
                "source": "塵埃は語る",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の命令で唯の一つも実行されなかったことのないのを見知っているロザリーは、或るひどい嵐の晩、こわさで顫えながら、「お父さんに行ってやめさせて頂いて頂戴よ」と云って、姉達に「お馬鹿さん！",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）【ふん、お馬鹿さん、欲しけりゃパンを食べるがいいさ、こちらにはその方が有難いや。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、あたしも、じゃあ、あのお馬鹿さんがまた退屈をさせにやってきたんだわって言って、もう少しで居留守を使うところでしたわ……。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、心配することはありませんよ、うちのお馬鹿さんは大露西亜人に何かちよろまかされやしないかと思つて、ここの教父といつしよに夜どほし荷馬車の見張りに行つてますからさ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれやれ、こんなお馬鹿さんには全く降参だよ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾がこの手紙を書き上げるまでには、まだどれくらい時間がかかるかわからないけど、その間にこのあたし……疑問の少女エラ子を見つける事が出来なければ、日本の警察も新聞記者も、みんなお馬鹿さんよ……って……ネ……。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳公はお馬鹿さんだから年をとらないだけなんですよ』『ふうん』　弟は腑におちないやうな顔をしてぢつと私の顔を見てゐました。",
              "citation": {
                "source": "白痴の母",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このお馬鹿さんたら、私が惚れてるとでも思つてるのだよ。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てお前さんはお馬鹿さんだらう。",
              "citation": {
                "source": "耳長さん　と　あひるさん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたしが、『いやですわ』と言うと、小母さんは、　――お馬鹿さんだねえ。",
              "citation": {
                "source": "かもじの美術家",
                "author": "TUPEJNYJ HUDOZHNIK",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おだまり、お馬鹿さんね。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぼうや、おばかさんね。",
              "citation": {
                "source": "ひよりげた",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガール」にはおばかさんの意味もある。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、彼女は彼の肩を捉え、抱きかかえんばかりに顔をすりよせて、おばかさんね、とただ一言、彼の耳許に囁き、怒ったように立ち去りました。",
              "citation": {
                "source": "落雷のあと",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「鵞鳥にしろ、驢馬にしろ、ヨーロッパでは、おばかさんという意味にも使われるんでしょう。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、おばかさんか。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、なんておばかさんでしょう！",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
