        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その上に芥川君は、小穴隆一君や堀辰雄君等の、大勢の若い人たちと一緒であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の背後には、大勢の若い壯士が立つてた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの結婚の事に就いては少しも言わず、ひたすら世界の大勢に就き演説のような口調で、さまざま私を教え諭すのであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから今度田中さんが、その家には子供も大勢だし、誰も世話する者がないから自分が世話をしに、満洲のその家に世話に行くんだつて。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は相当に美しいが、何分近在の百姓が大勢詰めかけるので、伊香保そのものの空気が、まるで田舎の温泉場に変つてしまふ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日経て後の夕方、荒物屋の座敷には隣家の誰れ彼れが大勢集まって酒を酌んでいた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳かな入学宣誓式が行われて、自分も大勢の新入生の中にまき込まれて大講堂へ這入ったが、様子が分らないのでまごまごしていると、中に一人物馴れた日本人が居ていろいろ注意してくれて助かった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢で車座に坐って茶碗でも石塊でも順々に手渡しして行く。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒が浜辺に大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船にのるのだか見送りだか二十前後の蝶々髷が大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高阪橋を越す時東を見ると、女学生が大勢立っていると思ったが、それは海老茶色の葦を干してあるのであった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜に村の煮売屋などの二階から、大勢兵隊が赤い顔を出して、近辺の娘でも下を通りかかると、好的好的などと冷かしたり、グズグズに酔って二、三人も手を引き合うて狭い田舎道を傍若無人に歩いたりするのが、非常に不愉快な感じを起させた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦女子ばかりの無防備の家に、夜盜のやうに忍び込んで、爺さんひとりを大勢かかつて殺してしまふのですからね。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島から青年団員が大勢乗込んだ。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば大勢の中にきっと一人くらいは「豪傑」がいて、わざと傍若無人に振舞って仲間や傍観者を笑わせたりはらはらさせるものである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の堂内には年取った婦人が大勢集まって合唱をしていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内に荷馬車の音がして大勢の人夫がやつて來て、材木を轉がしては車に積み始めたので、私はしばらく畫架を片よせて避けなければならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の火事ならば大勢の人が集まっているであろうに、あたりには人影もなくただ野良犬が一匹そこいらにうろうろしていた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の受持の寺院で大勢の聴衆に対して説教すると、その声は同時に電話で市中の各所へ配布された。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲※に拠る住持の三要は正面に控え、東側は大衆大勢。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "札幌から大勢の警官に見送られて二十人余り背広服の壮漢が同乗したのが、船でもやはり一緒になった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた、あれだけ大勢があれだけ多数の大刀を振廻わして、そうして誰も怪我をしないようにするという芸術はおそらく世界にユニークなものであろう。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の踊手が密集した方陣形に整列して白刃を舞わし、音楽に合せて白刃と紙の采配とを打合わせる。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の誇大妄想狂の原因は彼の蒐集した書物にあるから、これを焼き捨てなければいけないというので大勢の役人達が大きな書物をかかえて搬び出す場面がある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三十尺の高さに噴き上げている水と蒸気を止めるために大勢の人夫が骨を折って長三｜間、直径二インチほどの鉄管に砂利をつめたのをやっと押し込んだが噴泉の力ですぐに下から噴き戻してしまうので、今度は鉄管の中に鉄棒を詰めて押し入れたらやっと噴出が止まった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦争直後で負傷者が大勢療養に来ていたのはその時であったかと思う。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し詳しく立止まって見たいと思う者があっても、大勢に追従して素通りをしてしまわなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまり大勢の人間に同時に大体を見せるためには最も適当で有効な方法には相違ない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局大勢かかればかかる程みんなが「検事」の立場になって、「弁護士」は一人もなくなってしまうような状況になりやすい。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや論文が独創的なものであればあるほど、疵やひびが多いのは当然であるから、そういうものが大勢の合議にかかれば無事に通過する気遣いはまず無いと云ってもいい。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
