        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「enjoyment」である。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「enjoyment」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「enjoyment」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "enjoyment」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お楽しみ中を真に恐れ入ります。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い本をお探しになるのが何よりのお楽しみだそうですね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「結構ですな、お楽しみですね、些と拝見いたしたいもんです。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まああなたもお楽しみなさいまし」　渠は直ちに踵を回らして、鼻唄まじりに行き過ぎぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろお楽しみだね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞお楽しみでしょうね。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは雲の上の奥深きお方々が、野辺に咲く四季の花をごらんになる事が少いので、深山の松かしわを、取り寄せて、生きてあるままの姿を御眼の前に眺めてお楽しみなさるためにはじめた事で、わしたち下々の者が庭の椿の枝をもぎ取り、鉢植えの梅をのこぎりで切って、床の間に飾ったって何の意味もないじゃないですか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花嫁さん、ありがとう、お楽しみ光邦様、どろんどろん。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなこと云わないで、鼠とたんとお楽しみ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、ようべはお楽しみ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際上世間では千人中の九百九十八人か九人位までは、生活の問題とその慰安｜或は特別のお楽しみ筋なんぞのために寸暇も無い位頭を使っておられるように見受けられます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは次項を読んだ後のお楽しみだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがお楽しみはここからだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな真実を大きな法螺の貝から鳴らすだけで礼拝される修験者志賀直哉曾て文学の瀧に打たれた経験をしやべることがお楽しみ。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが来年学校を出ると一緒になるんですつてね、チヤンと知つてるわ、お楽しみ……」「さうかも知れないよ、だ。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せっかくお楽しみのようだが、このご用主はおばあさんだぜ」「何を途方もねえことおっしゃるんですかい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「慶一は、ま、はじまってのお楽しみ」「もー、また、そういうふうに、じぶんだけ、いい役なんだからー」　曲が、トロッグズの〈ウィズ・ア・ガール・ライク・ユー〉になった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　慶一は「はじまってのお楽しみ」の意味を知って、怒り狂っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は大きな大きな袱紗に、金や銀や五色の糸で縫い込まれた奇妙な形の花や蝶々が、だんだんと一つにつながり合った模様になって行くその美しさ……お父様は、そのようなお母様のお仕事を、丸い桐胴の火鉢の向うから私と一緒に御覧になるのが何よりのお楽しみのように見えました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは次ぎの章を見てのお楽しみ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、ごゆるりとお楽しみ下さい。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう晩にお通いもまたお楽しみなものでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "お楽しみ……」「ハツハツハ……」と私は、肯定したやうに哄笑しました。",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の諸君、われわれを種にどんなことでも言ってお楽しみなさい。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用足しだか知れたものじゃねえ、こう三公、いいことを手前に訓えてやらあ、今度お上さんが出かけるだったらな、どうもお楽しみでございますねって、そう言って見や、鼻薬の十銭や二十銭黙ってくれるから」「おいらはそんなことを言わなくたって、お上さんにゃしょっちゅう小使いを貰ってらあ」「ちょ！",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろお楽しみで……」と為さんはジリジリいざり寄って来る。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、しばらく‥‥」「橋の上から貴女がよく見えた、――相変らずお楽しみですね」「楽しみ‥‥」　あんなに威張つて、「楽しみに描いてゐる」と云ふ言葉も、――また泡のやうに此男の前では消えてしまつたではないか。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その説明は後のお楽しみ……と申上げたいのですが、実はこの時までは天井裏から覗いておりました正木博士にもサッパリ見当が附ておりませんでしたので……恐らく諸君とても御同様であろうと思います……が……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "話はそれ切りの芽出度し芽出度しになる訳だが、その時はその時として、まずそれまでのお楽しみとして聞いていたまえ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何だ……お楽しみだあ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
