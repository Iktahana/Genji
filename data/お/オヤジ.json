    "definitions": [
      {
        "index": 1,
        "gloss": "entry kanji in a kanji dictionary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当時私は大学の講師をして月給三十五円とおやじからの仕送りで家庭をもっていたのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英吉利の田舎おやじらしい、塔の欄干から外へ墜ちかけた。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは甲蟲のように※く。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじの妻は驚いて卒倒しかけている。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手になっているのは、これも勤勉な隣街の大きな靴店のおやじだ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじゃ野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名画をもじったタブロー・ヴィヴァンの中にダヴィドの「ルカミエー夫人」を模したのなどは美しかったが、シャバの「水浴の少女」をそっくりそのままベッドの前に立たせ、変なおやじが箒で腰をなぐろうとしている光景は甚だ珍妙ないかがわしいものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「今江戸中、　人気の焦点、　評判男の中村仲蔵が……」　「その仲蔵が……」と過去を想い起すらしく、Ｔ「二十年以前、　貧に窮して、　おやじ橋に捨てた　我子、仲蔵とは……」　「わしはこんな嬉しい事はない」　聞いてた雪枝が仕事の手を止めて、Ｔ「今晩にでも、　兄様に会いに行かれては？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "女郎屋のおやじになった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　朝、深沢洋行のおやじは、ねむげな眼に眼糞をつけて支那人部屋にはいってきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは、いきなり、ペーチカの横の水汲みの石油鑵を蹴とばした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへ、自分で持って行くがええや」　おやじが去ったあとで、呉清輝は呟いた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、おやじが、あたふたと、郭を探しにはいってきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」おやじは口をとがらしていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉清輝と田川とはおやじが扉の外に見えなくなると、吹きだすようにヒヒヒヒと笑いだした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ」　一時間して、おやじが支那人部屋へとびこんできた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじは、また、郭進才の場合のように呉の床箆子の附近をさがしまわって、破った、虱のいる肌着が一枚丸めて放ってあるのをつまみ上げ、舌打ちをした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おやじが出て行った後で声をあげて愉快げに笑った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、数日の後、おやじは、別の支那人をつれてきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじにも世話になった。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日も四日も飯にありつけない、彼等のおふくろや、おやじや、妻が、キタならしいなりをして息子に面会を求めに来ても、門鑑はそれを拒絶した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんな業慾なおやじでも、一時間か二時間の後に地獄の門をくゞる囚徒の要求は拒絶しなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼ざめて、骨まで細くなったような、おやじに見える男だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　金モールの額のはげ上ったおやじは、じだんだを踏んで口惜しがった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、池の真中から声を懸けて、おやじは小屋の中を覗こうともせず、爪さきは小波を浴ぶるばかり沈んだ筏を棹さして、この時また中空から白い翼を飜して、ひらひらと落して来て、水に姿を宿したと思うと、向うへ飛んで、鴎の去った方へ、すらすらと流して行く。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢なクジマ、今までに四十人の生命を助け十回も屋根からころがり落ちた札付きのクジマのおやじが屋根裏の窓から一匹のかわいい三毛の子ねこを助け出す。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教類似の信仰に夢中になって家族を泣かせるおやじもあれば、あるいは干戈を動かして悔いない王者もあったようである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、親が多年の辛苦でたくわえた貯金を赤いむすこや娘が運動資金に持ち出したとすれば、その場合のさるは子供でかにはおやじである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事は地震や雷のような自然現象でもなく「おやじ」やむすこのような自由意志を備えた存在でもなく、主としてセリュローズと称する物質が空気中で燃焼する物理学的化学的現象であって、そうして九九プロセントまでは人間自身の不注意から起こるものであるというのは周知の事実である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒で堕落して行くおやじの顔の人相の変化はほんとうらしい。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
