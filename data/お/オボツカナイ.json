[
  {
    "uuid": "2ddbb4c2-7f1c-5ac0-85b2-1faf6971171a",
    "entry": "覚束ない",
    "reading": {
      "primary": "おぼつかない",
      "alternatives": [
        "かくそくない"
      ],
      "is_heteronym": false
    },
    "grammar": {
