    "definitions": [
      {
        "index": 1,
        "gloss": "sworn younger brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
