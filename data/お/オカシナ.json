        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "考えると可笑しなものである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次も五郎蔵も「可笑しな具合」と顔見合わす。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄が三十歳のとき、私たち一家で、「青んぼ」という可笑しな名前の同人雑誌を発行したことがあります。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――可笑しなことがございました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもコンナにお涼しくなりましてから雷鳴入りの夕立なんて可笑しな時候で御座いますなあ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しなもので、すっかり大金持になった気持の僕はそこで、急に日本へ帰りたくなり出したのです。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな可笑しな欠点があるにしても、どこやらに、神の御子のような匂いが致します。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しな言い方であるが、私には、この清国留学生よりは、たしかに日本語がうまいという自信があったのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫又よ、やよ猫又よと申しければ……」と、先生はその中の一句を、田舍訛りの可笑しな抑揚で高らかに讀み上げた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しなどろぼうね。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そのときはじめて、可笑しなことでございますが、そのときはじめて、あの人にとっては、私が最初で無かったのだ、ということに実感を以て思い当り、いても立っても居られなくなりました。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、目でお話をするということも、可笑しなくらい出来ない。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに大人になってしまえば、私たちの苦しさ侘びしさは、可笑しなものだった、となんでもなく追憶できるようになるかも知れないのだけれど、けれども、その大人になりきるまでの、この長い厭な期間を、どうして暮していったらいいのだろう。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しな名詞だな、と気附いた。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土の先輩なんて、可笑しなものさ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "來る日も來る日も彼はこの可笑しな恰好で、瞬きせざる修練を重ねる。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "来る日も来る日も彼はこの可笑しな恰好で、瞬きせざる修練を重ねる。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ふふん、これは何だか可笑しな所だな、羊でも囲って置いた所だろう。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しな事には馬とも話しが出来るの。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隨分可笑しなものであつた。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "かははぎは皮剥ぎの謂で、形の可笑しな魚だが、肉がしまつてゐておいしい。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐月峯とは可笑しな名だと思ひながら問ひかへすとさういふ名のお寺で、もとその寺から例の灰吹を作り始めたとかいふことだといふ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度其頃わたくしひどく困まつてゐまして、可笑しなお話ですが、着物も體に附けてゐるのしきやないのでせう。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが僕の可笑しな絵を見てから実世界の観察をした一つである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には一口噺か何かを書いて、わざと秘密らしく帯封をして、かの可笑しな画を欲しがるものに売るのである。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟派は例の可笑しな画を看る連中である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この抽斗が例の可笑しな画を入れて置く処に極まっていた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "硬派は可笑しな画なんぞは見ない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いてかの可笑しな画なんぞを想像して、反復して見た。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場の蒼黒い顔には弱い西日がぽっと明るくさしていて、夕靄がもやもや烟ってふたりのからだのまわりを包み、なんだかおかしな、狐狸のにおいのする風景であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
