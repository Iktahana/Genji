            }
          ],
          "literary": [
            {
              "text": "「美代子をむしってはいやあよお姉ちゃん」　ここに居るのは一番小ちゃい花子の妹でした。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「痛い、お姉ちゃん。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お滝が、ひょいと、飛んで傍へ来て、「きれいなお姉ちゃん、少しお動きよ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ通訳のお姉ちゃんはアラン・ケイのあまりに翔んだお言葉に何が言いたいのかさっぱり訳分からないようで、白と言ったのが黒になったりグレーになったりと、かつてのオレの「幸せなら手をたたこう」の演奏もかくやと思わせる迷調子（ああ、お姉ちゃんの悪口言うと胸が痛む）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、早く見付けて、伯父さんの拵えたこの電話機でネ、東京に住んでいる人と話をしたいの」「そうか、そうか」「さっき僕と話をした東京の人は、お姉ちゃんだったよ」「電話局の交換手さんだからネ、交換手はお姉ちゃんに極っているのだよ」「そのお姉ちゃんに僕、訊いてみたの。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉ちゃんには、お母ちゃんと、そいからお父ちゃんもいるのッて尋ねたらネ……」「うん」「お父ちゃんも、お母ちゃんも居る筈なんだけれどネ、アメリカの飛行機が爆弾を落として、お家を焼いちゃったもんだからネ、どこへ行っちゃったか、判らないのッて云ってたよ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、お姉ちゃんの大事な人形さんだから、坊が持ってゆくのでないの。",
              "citation": {
                "source": "気まぐれの人形師",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉ちゃん、帰ろうよ。",
              "citation": {
                "source": "芽は伸びる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお姉ちゃんが手を出そうものなら、やはり、こうして顔を真っ赤にして怒ったの……。",
              "citation": {
                "source": "お母さんのお乳",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉ちゃん、見ようよ。",
              "citation": {
                "source": "正ちゃんとおかいこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉ちゃん、持っていっておくれよ。",
              "citation": {
                "source": "正ちゃんとおかいこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉ちゃん、僕にぴかぴかした、シャープ＝ペンシルを買ってきてくれる？",
              "citation": {
                "source": "小さな弟、良ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉ちゃん、いまいらっしゃるの。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたし、お姉ちゃんでないわ。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにたのんでも、赤ちゃんを、だっこさしてくれないのに、なんでお姉ちゃんと、いうのだろう。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、お姉ちゃんといわれても、ちっともうれしいことはないわと、光子さんは、道を歩きながら、思いました。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだも、お姉ちゃんと声をかけますと、下を向いて、にげていって、おしまいなさるのです。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、お母さんに、うながされると、あのときのことを思い出して、つい悲しくなり、目から涙を落としながら、「私、お姉ちゃんでないんですもの。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたし、お姉ちゃんなら、すこしばかり赤ちゃんを、だっこさしてくれたっていいでしょう。",
              "citation": {
                "source": "お姉ちゃんといわれて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "正ちゃんは、やっと、お姉さんに近づくと、「お姉ちゃん、おしるこがあるよ。",
              "citation": {
                "source": "ねことおしるこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、ますます、悲しくなって、姉の手をひき、「お姉ちゃんも、いっしょでなければいや。",
              "citation": {
                "source": "だれにも話さなかったこと",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お姉ちゃんは、どうしたろうね？",
              "citation": {
                "source": "二番めの娘",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太　お姉ちゃん、おばさんの手を引いてやれよ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉ちゃん、先に帰れ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間もわたくしに甘えながら言うには、「わたし早く大きくなってお姉ちゃんの学校へ行きたいの」「今に行けるよ」「今にではなく、すぐ」「どうして？",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、お姉ちゃんの学校では教室でみんなが、犬をたくさん飼っているのですって。",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉ちゃんによく聞いてごらん。",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おねえちゃんみたいだったときもあるし、もっと小さな赤ん坊だったこともあるのさ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の向こうの原っぱで、おねえちゃん！",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を呼んでいるのではないけれども、いまのあの子に泣きながら慕われているその「おねえちゃん」を羨しく思うのだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
