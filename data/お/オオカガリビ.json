          ],
          "literary": [
            {
              "text": "この後まもなく聖ヨハネの祭りにさいして学生たちは大学の前で大かがり火を燃やした。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかめの油を入れた石油｜缶を手ぢかにおいて、いざという時、万年灯から火種をとって、大かがり火をたき油をかけて、どんどん、煙と火をあげようと、待ちかまえた。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばらばらっと、砂山にかけあがり、たちまち、大かがり火をたきはじめた。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "島でたく大かがり火が、雲にうつっているのだ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "火が治療法に違いないのでヒポクラテスは疫病が終わるまで大かがり火を燃やすようにした。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大な大かがり火で空気を浄化することが試みられた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
