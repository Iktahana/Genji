        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "座が白けて、しばらく言葉が途絶えたうちに所在がないので、唄うたいの太夫、退屈をしたとみえて、顔の前の行燈を吸い込むような大欠伸をしたから。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の外套氏が大欠伸をして起きた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち磯が眠そうに大欠伸をしたので、お源は垢染た煎餅布団を一枚敷いて一枚｜被けて二人一緒に一個身体のようになって首を縮めて寝て了った。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上でも今日は大丈夫だろう」と両手を伸して大欠伸をして「何時かしらん」「最早直ぐ十二時でしょうよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して大欠伸をしながら、彼は寝乱れた労働者の間を縫って、オデッサ丸の船階子を上って行った。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮剥一ツ買ったってお前、三銭はするぜ、買っとくんねえ、あ、あ、あ、」　と引捻れた四角な口を、額まで闊と開けて、猪首を附元まで窘める、と見ると、仰状に大欠伸。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と便所の裡で屋根へ投げた、筒抜けな大欠伸。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草ももう吸い飽きて、拱いてもだらしなく、ぐったりと解ける腕組みを仕直し仕直し、がっくりと仰向いて、唇をペろぺろと舌で嘗める親仁も、蹲んだり立ったりして、色気のない大欠伸を、ああとする茜の新姐も、まんざら雨宿りばかりとは見えなかった。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、この猫について、座の一人が、かつてその家に飼った三毛で、年久しく十四五年を経た牝が、置炬燵の上で長々と寝て、密と薄目を※くと、そこにうとうとしていた老人の顔を伺った、と思えば、張裂けるような大欠伸を一つして、（お、お、しんど）と言って、のさりと立った。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "座が白けて、暫らく言葉が途絶えたうちに所在がないので、唄うたひの太夫、退屈をしたと見えて顔の前の行燈を吸込むやうな大欠伸をしたから。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "件の天守の棟に近い、五階目あたりの端近な処へ出て、霞を吸ひつゝ大欠伸を為た坊主がある。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突懸り、端に居た奴は、くたびれた麦藁帽を仰ざまに被って、頸窪へ摺り落ちそうに天井を睨んで、握拳をぬっと上げた、脚絆がけの旅商人らしい風でしたが、大欠伸をしているのか、と見ると、違った！",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父はわたくしの申したことが聞こえた顔もせず、筆を筆立へ納めて、大欠伸をし、母に命じて捲いた書物を待たせて置いた小僧にやらせ升た。",
              "citation": {
                "source": "黄金機会",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と鉄拳将に飛ばんとする時、隅の方に蹌まつた抱巻がムク／＼と持上つて、面長な薄髯の生へた愛嬌のある顔が大欠伸をした。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｃが、素晴しく洞ろな大欠伸と一処に、吾知らず次の章を唸り続けるといふ具合なのだ。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――決心に満足を感じ、せきは誰｜憚るところない大欠伸を一つし、徐ろに寝床へ這い込んだ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "念のために、赤い達磨の灰落しを覗いてみると、中には葉巻の灰の一片すらなく、相も変らぬ大欠伸を続けたまま、黄金色と黒の瞳でグリグリと私を睨み上げている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒井さんは、「ああァ」と大欠伸をしてから、周囲をみまわし、「大坂とか、よし、また、ひねってやろう」とゆっくり立ち上がるのでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに轢死美人でも顔が見えなくちゃなア」　本気か冗談か判らぬようなことを云って、アーアと大欠伸した。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんノンキな牛丸平太郎までが眼をさまして、「なんや、なんや、いまの音……」　寝呆けまなこをこすりながら、顔中を口にして、ううんと大欠伸をした拍子に、またもやドカーン。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の内は麦の芒だらけ、墓地は草だらけで、お寺や教会では坊さん教師が大欠伸して居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽天地の当初のように大欠伸なぞ喰わなかったが、毎日、じつに中途半端ないやないやな思いで舞台を勤めた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ア、ア、ア、ア――」　思わずお種は旧い家の内へ響けるような大欠伸をした。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　莊吉はごろりと起きて、ふんぞりかへり大欠伸をして、それから門を出て行く。",
              "citation": {
                "source": "旱天實景",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と大欠伸をする）お加世はうつ向く。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大欠伸をしながら、「貴様、年寄りだけあって眠がらんな。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と与吉は、わらじをとくまも呼吸を切らしているが、家内のお藤は大欠伸だ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
