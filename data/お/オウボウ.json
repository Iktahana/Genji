        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "例えば美術や音楽の方面においていわゆる官学派の民間派に対する圧迫といったようなことについて、具体的の実例をあげていわゆる官僚的元老の横暴を語るのであったが、それがただ冷静な客観的の噂話でなくて、かなり興奮した主観的な憤懣を流出させるのであった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガヤガヤ、ワイワイ口々に、Ｔ「横暴だ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何のために、横暴にも、こんなものを作りつけたんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の田舎｜老爺もこの事を知らなかったため横暴なる赤馬車に虐められているのであるが、いかに山の中とはいえ、かくのごとき不親切極まる営業振りは聞捨てにならぬ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木炭を持つてきてくれないのにフンガイする、油虫の横暴にもフンガイする、フンガイしたところでどうにもならないけれど。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それから後の、あなたの勇作さんに対する、恩着せがましい横暴な仕うちは、イクラ恨んでも恨み切れません。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎の世間に対する不如意の気持から来る八つ当りは、横暴ないい付けとなって手近かのものへ落ち下る。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日自分が張り渡した窓の装飾の綾模様を透して向う側の妾町の忍んだような、さゝやかな装飾と青い空の色と三色旗の鮮やかな色とが二つの窓から強い朝日に押し込まれて来たように、新吉の眼を痛いほど横暴に刺戟する。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都へ行つて将門の横暴を訴へ、天威を藉りてこれを亡ぼさうといふのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ又後から貞盛は将門の横暴を直訴して頂戴した将門追捕の官符を持つて帰つて来たのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして恥や遠慮を知る大人を無視した横暴な存在主張者だ。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦、戦災、失業、道義心の頽廃、軍閥の横暴、政治の無能。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "國家は少數の君子（貴族）に特權を與へず、自恣を敢てせしめないで、同時に又多數の小人をして横暴ならしめざることを努めなくてはならない。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日から掛かっているサモア紛争史、或いは、サモアに於ける白人横暴史だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白人の横暴、傲岸、無恥。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな連中は有為果敢の材を抱きながら官途に就く事が出来ず鬱勃たる壮志を抱いたまま明治政府を掌握している薩長土肥の横暴振り、名利の争奪振りを横目に睨んでいた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "願文は武井入道｜夕菴に命じて作らしめたと伝うるもので、「現今の世相混沌たるを憂えて自ら天下を平定しようと考えて居ます処、義元横暴にして来り侵して居ます。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、熊襲は、天皇が、大和へお帰りになると、また忽ち、蠢動し始め、横暴｜愈々つのつたので、二十七年八月、天皇は、御子日本武尊をお遣はしになつて、これを征伐させ給うた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に、延喜、天暦の治と申し上げるのであるが、この頃漸く萌したのは、藤原氏の横暴であつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後水尾天皇の葦原やしげらばしげれおのがまゝ　　　とても道ある世とは思はず　の御製に依つても、幕府の横暴が察せられるのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青蓮院の宮、鷹司太閤、近衛左府、一條、二條、徳大寺その他数十家へ、慎み、落飾、辞官、出仕止めなどの横暴な断罪が下された。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしいほど大きな茶色をした親ねずみは、あたかも知恵の足りない人間を愚弄するように自由な横暴な挙動をほしいままにしていた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんでもない人でした――誰にとっても横暴ですが、わたくしに対してははるかにひどく。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "横暴尊大な先ほどの態度もどこへやら、さながら主人に仕える犬のごとく、わが友人のそばでかしこまっている。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも横暴な奴だと、孟はいよいよ不快を感じながら、ひそかにその様子をうかがっていると、暫くして注文の焼餅を運んで来たので、孟はまた覗いてみると、その焼餅を盛った盤にしたがって、一つの黒い物が入り込んで来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "而モ小地主對小作人ノ間ヲ規定シテ一切ノ横暴脅威ヲ拔除スベキ細則ヲ要ス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "且ツ此ノ訴ハ必ズシモ離姻ヲ目的トセズ、實ニ婦人ガ男子ノ勞働ニ衣食スルカノ誤解アリテ、男子ノ勞働ガ其實却ツテ婦人ノ分科的勞働ノ助力アルガ故ニ行ハルルヲ忘却スル横暴ナル行爲ヲ禁ジ、特ニ法律ヲ以テ婦人ノ人權ヲ擁護スル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "保姆ノ一方ガ殘虐ナル苦痛ヲ他ノ一方ニ加ヘテ横暴ト悲慘トヲ居常見聞セシメラルル兒童ノ惡感化ニ對シテ、國家ハ大父母ノ權利ニ於テ殘虐ナル一方ヲ處罰スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "現行法律ガ買淫婦人ヲノミ罰シテ買淫男子ヲ罰セザルハ姦通罪ガ婦人ヲノミ罰シテ男子ニ及バザルト等シキ片務的横暴ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "體刑ト明示セル所以ハ其ノ弊風實ニ體刑ヲ以テセズンバ一掃スル能ハザル官吏横暴國ナルヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
