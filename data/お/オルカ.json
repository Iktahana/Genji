        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プレモ、オオトシヤツタア、ソルントンシヤツタア、フオルカルプレンシヤツタア、カアルツアイス、百分の一、千分の一、テツサア、アナスチグマツト――さういふ寫眞用語がいかに歴亂として私の腦裡を動き、いかに胸躍るやうな空想を描かせ、いかに儚ない慰樂を與へたことか？",
              "citation": {
                "source": "寫眞と思ひ出",
                "author": "――私の寫眞修行――",
                "note": "青空文庫"
              }
            },
            {
              "text": "數日後の夕、寄道してその少許を採取し、クロオルカルキとか云ふもののうちに漬くること一日、之を短く切つて、まだ廚房に少し殘つてゐた油と鹽とを點じて食べ試みた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルカニヤの作といい伝えている画に、死の神が老若男女、あらゆる種々の人を捕え来りて、帝王も乞食もみな一堆の中に積み重ねているのがある、栄辱得失もここに至っては一場の夢に過ぎない。",
              "citation": {
                "source": "我が子の死",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルカーニアの作と伝えられる一つの絵は、死者の群のまんなかに大きな魔ものが、どっしりと坐っていた。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗てオルカーニャ作と言われたピサの共同墓地にある「死の勝利」（図10）で醜い翼を持った死神は哀れなハンセン病患者たちの脇を通って若い男と女の他のグループに近づいている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
