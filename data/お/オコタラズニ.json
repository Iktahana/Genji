        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "政元の魔法は成就したか否か知らず、永い月日を倦まず怠らずに、今日も如法に本尊を安置し、法壇を厳飾し、先ず一身の垢を去り穢を除かんとして浴室に入った。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "本気になって相手をさがせと厳しく云われたので、その後も怠らずに毎晩出あるいているが、月夜のつづくせいか、この頃はちっとも出逢わないで困っている」「それは御苦労さまでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "專念に道を求めて、萬事を抛つこともあれば、日々の務は怠らずに、斷えず道に志してゐることもある。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "座頭は朝から夕まで渡し場へ出て、倦まず怠らずに野村彦右衛門の名を呼びつづけていた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれから一室に閉じ籠って毎日怠らずに経を呼んでいると、三年の後に腫物はおのずから癒えた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "続夷堅志・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅から帰ってからの鶴さんに、始終こってり作の顔容を見せることを怠らずにいたお島の鏡台には、何の考慮もなしに自暴に費さるる化粧品の瓶が、不断に取出されてあった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えずそう思っては注意していますけれども、今のところでは別にそんな感情は少しもまじっていないようですけれど、その反省だけは怠らずに続けています。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、自分が僕の愛を一番多く持っているということに、自分の安心があるのではないかということを、絶えず怠らずに反省している、と言う。",
              "citation": {
                "source": "男女関係について",
                "author": "女房に与えて彼女に対する一情婦の心情を語る文",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした私であったのに、学生としてなすべき勉強を一応怠らずにすることができたのは、前記諸先生の感化によるものである。",
              "citation": {
                "source": "わが青春",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、怠らずに日記も書きました。",
              "citation": {
                "source": "背負ひ切れぬ重荷",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えずさう思つて注意してゐますけれど、今のところでは、別にそんな感情は少しも混つてゐないやうですけれど、その反省だけは怠らずに続けてゐます。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "為山氏は調子に乗つて画く、調子乗らざればいつまでも画かず、不折君は初より終まで孜々として怠らずに画く。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "専念に道を求めて、万事をなげうつこともあれば、日々の務めは怠らずに、たえず道に志していることもある。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯御自身怠らずに、阿弥陀仏の御名をお唱へなされ。",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毎日、怠らずに下水を掃除しなければならない。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで彼は大の英語嫌であったのに、この書物を読むようになってから、一回も下読を怠らずに、あてられさえすれば、必ず起立して訳を付けたのでも、彼がいかにそれを面白がっていたかが分る。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の玉の様になった栄蔵のわきで手拭を代える事を怠らずに、お節は二夜、まんじりともしなかった。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の姿がなんとなく窮屈さうに見えることから、同人の一人がそれとなく注意の眼を怠らずにゐると、やがて彼がシャツの下に何枚かの古新聞紙を着てゐることが分かつたのだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "村に帰ると、その間に、百｜姓は、怠らずに働いていました。",
              "citation": {
                "source": "大根とダイヤモンドの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "明子の母はまだ過敏な警戒を彼女の身辺に怠らずにゐたけれど、村瀬の手紙だけは開封もせずに渡した。",
              "citation": {
                "source": "青いポアン",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼らは毎日怠らずに彼女を見ようと注意していた。",
              "citation": {
                "source": "スザナの物語",
                "author": "――経典外聖書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこのような悪傾向は何とかして一掃したいと考え、絶えず注意を怠らずに居たのであります。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格は恰も之に反して、常に知識学的な又は多少の注意を怠らずに言葉を使用するとして認識論的な、課題を含んでいる。",
              "citation": {
                "source": "イデオロギーの論理学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも彼は毎晩怠らずに祷りをした。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は美角夫人の前で血を漲らせながら、かなりの注意を怠らずに語った。",
              "citation": {
                "source": "あめんちあ",
                "author": "富ノ沢麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな人の与える祝儀が唯一の実入りで、市中で銭を与える人は、前に言う通り極めて少ないものでありましたけれども、弁信は怠らずに、それを語って歩きます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫はその七分通りの成功に勢いを得て、その後も相変らず生物を食べさせることを怠らずにいたので、細君は夏になるとしばしば下痢を起しました。",
              "citation": {
                "source": "途上",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、按吉がこれをひそかに注意を怠らずにいたところが――というのは、これが相当問題が臭いからで――先生がこれらの書物を忙しく取り出してくる場所が、決して本箱の腰から上に当る場所ではないではないか。",
              "citation": {
                "source": "勉強記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は会いたいときにはおこたらずに会い、語りあいたい人とは明日を待たずに語っておくものだ。",
              "citation": {
                "source": "落日の荘厳に似る",
                "author": "――大観画伯の終焉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
