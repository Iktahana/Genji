        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お布施について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お布施がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お布施というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお布施の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお布施が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お布施を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お布施の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お布施はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお布施があります。",
              "source": "幻辞"
            },
            {
              "text": "お布施は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お布施について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお布施の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お布施の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお布施が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お布施についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお布施は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお布施について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お布施という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお布施の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お布施を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鈴木の奥さんに御挨拶する、思ひがけなくお布施を頂戴して恐縮した。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯（鯖の煮付、茄子の煮込、沢庵漬）　朝食（味噌汁、煮豆、沢庵漬）所得（銭三十銭、米三升）今夜はお布施のおかげで、日本酒三合いたゞく。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひるはまたお酒をいたゞいた、行乞米を貰つて下さつてお布施を下さつた、襦袢の手入、浴衣の洗濯、そして褌まで頂戴した、黎々火さんはほんとうによい肉縁の人々を持つてゐる、お父さんの温情、お母さんの慈愛、あゝ羨ましい。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "……めしていらっしゃるんなら、雨なり、露なり、取るのは遠慮だったんですけど、背中に掛けておいでなすったもんだから、外して、本堂へ持って行って、お布施をして、坊さんに授けて貰って来たんです。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三部經あげてもらはうおもうてお布施も世間なみに包んだのぢや。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚したりなんかはするでせうが、謝禮として幾らかお布施を包みや結構ですわ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上人はもしか間違つてゐたら、お布施を返す積りで独断の返事をした。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君からも白米のお布施。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月廿三日　晴、冬至、汽車で三里、山鹿、柳川屋（三〇・中）九時の汽車で山鹿まで、二時間ばかり行乞する、一年ぶりの行乞なので、何だか調子が悪い、途上ひよつこりＳ兄に逢ふ、うどんの御馳走になり、お布施を戴く。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天気はよし、温泉はあるし、お布施はたつぷり（解秋和尚から、そして緑平老からも）、どまぐれざるをえない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、いつしよに仙波さんを訪ねる、こゝでも懇ろにもてなされた、お布施までいたゞいた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜のお布施で買物をする、私がどんなにつゝましく買物をしたか、左の通りだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞米を下さいといつてお布施を下さる、写真をとつてもらふ、端書、巻煙草、電車切符を頂戴する、――何から何までありがたい。",
              "citation": {
                "source": "行乞記",
                "author": "北九州行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつものやうに酒を十分いたゞく、お布施もいたゞく、御馳走はなかつたが、温情があまつた。",
              "citation": {
                "source": "行乞記",
                "author": "北九州行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "おう、蓮芯中の宝玉よ、アーメン」　と、私は祝福され若干のお布施をとられた。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜おう、蓮芯中の宝玉よ、アーメン」　と、私は祝福され若干のお布施をとられた。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "年に一度オレをよんでお布施をくれてタケノコメシをおごってくれるから、心境が変っているのかも知れんが、オレは昔も今も鬼とツキアイがないから知らんな。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お布施とタケノコメシはオレが一人で充分に間に合う」「折ヅメは十四本。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主に払ふお布施も無いや。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の坊さんという坊さんはみんな集まり、神主様という神主様もみんな集まって、読経と、祈祷とに、最も念を入れ、かなり多大なりと覚しいお布施と供物とを持って、大満足で引下りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後四十九日の仏事に、法然が請われて、唱導に行ったが、その時妙心房の弟子が衣裳箱をとり出して、「これは私のお師匠様が、年頃のお持物でございましたが」　といって法然の前へお布施として差出した。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ、信心の手はじめに、わたし、お布施をして来ませう」と、歌子は、木鉢に米を入れて、勝手口から出る。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今のは、せんだつて、お父さまがおでかけになつた日に、お布施をした坊さんですわ」「よく覚えてゐたね」六　丸小路文則の妻琴路は、娘の歌子を相手に、内職の写し物をしてゐる。",
              "citation": {
                "source": "虹色の幻想（シナリオ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には僧侶の真似をして町にお布施を貰ひ歩く立派な顎髯の男も居た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それはそうと、ねえ、阿古十郎さん、ありもしないことを、口から出まかせにしゃべくってこっちを威しあげ、お布施でもたんまりせしめようという魂胆でしょうが、それにしては、すこしやり方があくどすぎるようです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "日高川",
                "note": "青空文庫"
              }
            },
            {
              "text": "お布施なんていうケチなことで、お小夜さんとやらをそうまでいじめつけるわけはない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "日高川",
                "note": "青空文庫"
              }
            },
            {
              "text": "お布施といっても、何もないので、昔からねんごろにしている侍の許に預けて置いた硯を取りよせた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある家でお布施と一緒に渡されたもので、育ち難い弱い子を丈夫に育てたいという親心から、千手観音に頼んだものでしょうが、その赤坊の面差が、振り捨ててきた自分の子供に生き写しだというので、女は里を離れる時から憂鬱だったらしいのです。",
              "citation": {
                "source": "むかでの跫音",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪亡しになる人もありましょうし、中にはまた貴い身分のお方が有名な美人だったある公使夫人にお会いになりたい許りに、坊さんに扮して公使館を訪ね、夫人の手からお布施を貰われたというような話も、いまだに一つの逸話として残っているくらいで、とにかく仏門に入るということは普通の習慣になっています。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の父が、明治の初年に、同縣の友で好い位地を得てゐた某の世話で、月給十五圓の腰辨當を拜命して、東京に住むやうになつた時から、食ふ筈の肴を食はず、着る筈の着ものを着ずに、博士の學資を續けて、博士が其頃の貸費生といふものになりおふせる迄にしたのは、此母君の力である。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
