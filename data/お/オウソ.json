        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一応訴え出ておいた方がいいぜ」　彼は慌ててそれを制止した。",
              "citation": {
                "source": "黒猫十三",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この役人の仲間にはおうおうそういう人たちが多い。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いちおうその指のあせを手拭いで拭き取ってから、どこを風が吹くと言わぬばかりにして、ほうほけきょうとやった。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯罪の予告があつた後、犯罪が行われたとすれば、いちおうその犯罪の予告者を犯人と断ずるのは最も常識的だ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうそれじゃ、一昨年ゆくえ知れずになったので、新聞をにぎわしたサクラ号の少年諸君が、ぶじであったのか」　船長はおどろいていった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは問題をかんたんにするため、いちおうその『骸骨の四』と金属Ｑとが同一物であったと仮定します。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、いちおうそういう風潮に逆ってみたいのです。",
              "citation": {
                "source": "あるニュウ・フェイスへの手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船長が出ました」「おうそうか」　局長は紙片を手にとって、マイクに近づき、「船長、ただ今ＳＯＳを受信いたしました。",
              "citation": {
                "source": "幽霊船の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『おうそれはわしの子、わしの可愛い子にきまっています！",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お庭拝借致しまして、町奴に似つかわしい放れ業、致しますでござります」「おうそうか、隨意に致せ」　そこで藤兵衛庭へ下り、素晴らしい一つの放れ業をした。",
              "citation": {
                "source": "二人町奴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……されど、当方の差し値を決する以前に、いちおうそちら側の希望値だんも承りて宜しく候。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうそんなことは、たといお前にしろ、だれにしろ、できるものかね。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一様な夢の織り物をこしらえ出す昼と夜、美わしい白雲が、眩惑せる人の眼にただ輝ける跡をのみ残して空を過ってゆくように、流れ去る時間、春の懶さで人を包む、なま温かい息吹き、肉体の金色の熱、日に照らされた愛の葡萄棚、清浄な無羞恥、狂おしい抱擁、溜息や笑い、楽しい涙、おうそれら幸福の埃よ、汝から何が残るか？",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも心配することはないと、請け合ってくれた」　ふたりはいちおうそれで満足しておくほかはなかった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんていうやつだ」　それでも彼はいちおうそう云って自分を苦々しく反省したが、車で東京駅へかけつける気持には、すでにどう抗ってみても危篤の友を見舞うにふさわしいものはなくて、抑えても抑えてもふくれあがる女への情熱でいっぱいだった。",
              "citation": {
                "source": "正体",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうそんなことは、私は望みません、けっして望みません。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいけなければしようがねえが、まあいちおうそのようすを見てからにしたらいいだろう」　平作老は、意見をしにでかけていった。",
              "citation": {
                "source": "ゆうれい貸屋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさしつかえござりませぬか」くんくんと何かのにおうそこの室の内から、親鸞の声がすぐ答えた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうそこへまいったもの、はやく拙者の脇差をぬいてこの縄を切ってくれ、早く、早く！",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何といおうそれを。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうそちが、おお、金吾か……」とばかり、ただあきれたように自失している。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうそのダンゴよというのが落ち。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何の何の、今日は昨日と違い、雷鳴り雲も見えませぬゆえ、その二里ほどを、桜狩りしつつまいろうとの心ぐみにござります」「おうそのような、優しい計らいであったのか」　廉子はよろこんだ。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
