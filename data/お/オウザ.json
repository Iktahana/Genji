          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "故に文學の中でのいちばん老成したもの、即ち小説が文壇の王座を占め、次に戲曲、次に評論、そして最後に詩が來るのである。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この経は仏教経典の中では王座を占めている経で大乗仏教哲学思想の中枢になるものだと言われている。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如来正※知はあしたの朝の七時ごろヒームキャの河をおわたりになってこの町にいらっしゃるそうでございます」　「そうか、たしかにそうか」王さまはわれを忘れて瑪瑙で飾られた王座を立たれました。",
              "citation": {
                "source": "四又の百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われ、かつて王座にありき。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から（徳川時代から）忌避され軽蔑されていた肉慾描写や不倫の世相が、自然主義の輸入以来、臆面もなく逆照され初めて、往昔、最低級の芸術として扱われていた作品が、堂々として一般民衆の趣味傾向の王座を占むる事となった。",
              "citation": {
                "source": "甲賀三郎氏に答う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "只顔の真中の王座に反り返っているのでありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダメス王の王座はこの如くにして、埃及の国家組織の中心に自ら胚胎した事でありました。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がそれを聞かしてくれたときそんなに強い印象を受けたのは、おそらく、その詩の意味の底の神秘的な流れのなかに、アッシャー自身が彼の高い理性がその王座の上でぐらついていることを十分に意識しているということを、私が初めて知ったように思ったからであろう。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "三この幸ある渓谷をさまよいし人々は、　輝く二つの窓より見たり、調べととのえる琵琶の音につれ　王座をめぐりて、精霊らの舞えるを。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "その王座には　（｜紫の御子！",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮殿は人の心であり、その王座に坐せる王は理性であり、窓は眼であり、真珠と紅玉とで燐く宮殿の扉は、紅い唇と皓い歯とを持つ口であり、「こだま」はその口から出る美しい言葉であろうか。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "真の格闘技の王座をかけて、冗談抜きに異種格闘技戦をシリーズ化させたアントニオ猪木は、今振り返ってみてもまことにもっておせっかいである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのＨＭＮＭの提案は、空位のままに残されているこの王座をつかもうとする試みだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私が思ひますには、悪魔共がいくら王座にをさまつてゐても、あの見苦しい姿体と顔貌の所有者である以上は到底心からの満足を得てゐる者ではなからう、と信ずるのであります。",
              "citation": {
                "source": "闘戦勝仏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、露伴の名をして一躍芸壇の王座を争うまでに重からしめたのは『風流仏』であった。",
              "citation": {
                "source": "露伴の出世咄",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "動き易い都の人心は、十年｜讃嘆し続けた藤十郎の王座から、ともすれば離れ始めそうな気勢を示した。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在でも小説はなお文学の王座を占めており、特に日本では、文学即小説といってもよい程の現象を呈している。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私はあえて断言するが、近い将来に観念芸術の王座を占めるものは、機械と最も密接に結びついた芸術――さしずめ第八芸術としての映画だろうと思う。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは人間の推理力が王座をしめていなくてはならない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "咎める者がないのを幸いに、人びとは王座のそばまで進み寄ってうかがうと、王は俄かに病いにかかったという騒ぎです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日文明の王座は西洋人が占めており、世界歴史はすなわち西洋史のように信ぜられている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三日――女王座。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧い権威は、王座において個々の家庭において崩れた。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、多数の権威を喪った我国の科学界の王座に直って、あらゆる機関を手足の如くに利用していた。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一層誠らしく、丁寧に、「お若い、雄々しい君様の御将来には、大国の王座が約束されているようなものでございます」　傍に、髭を撫で、注意深く話を聞いていたシャラフシャーが、じろりと、鋭く商人を視た。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその極まる所、そこに天才の高き王座は輝く。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも世界第一でなければ気の済まない亜米利加人のことだから、犯罪でも世界一の王座を占めようと云うので、少し記録に誇張してある嫌いが見える。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "しなやかに、しろくすずしく身ぶるひをする手のむれは、今わたしのあたまのなかの王座をしめて相姦する。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢なる君はホツテントツトの尊長の王座に登るかも知れない。",
              "citation": {
                "source": "解嘲",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
