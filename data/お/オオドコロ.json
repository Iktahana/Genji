    "definitions": [
      {
        "index": 1,
        "gloss": "wealthy family",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ペンタゴンなんか相手にしていたんじゃなあ……柿江なんぞも、田舎新聞にひとりよがりな投書ぐらい載せてもらって得意になっていないで、ちっと眼を高所大所に向けてみろ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高所大所とはいったい何を意味するつもりだというところから柿江は始めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高所は札幌の片隅にもある、大所は女郎屋の廻し部屋にもあると叫んだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」彩ある雲四十六　爺さんは、先刻打撲された時｜怪飛んだ、泥も払わない手拭で、目を拭くと、はッと染みるので、驚いて慌しいまで引擦って、「他所目には大所の御新造さんのように見えます、その貴女が、……やっぱり苦界、いずれ苦の娑婆でござります。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落魄れた華族のお姫様じゃと言うのもあれば、分散した大所の娘御だと申すのもあります。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "個種・個族・個体の内部から憐れな小知恵の灯りで照らし観察・解釈・批判すると、生物の生滅は生存競争の結果だとも言えるのであるが、大所から観れば手を拍って笑ってしまうような人間の勝手な浅論であるに過ぎない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の大所から言えば実にこのようなものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大所から説けば、万象（全ての現象）は皆一気で、一気が百変して百花が開き、一気が千転して千草が萌えているのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬になるなら大所の犬にとね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそれが「無所得の大所得」だ、ということを教えたものであります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ら日本軍人が西洋の軍事学を学ぶについてはよく日本民族の綜合的特性を活用し、高所大所より観察して公正なる判断を下し独自の識見を持たねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋台店の立食は、湯がえりの職人か、お店の人の内密食、そのほかは、夜長の、夜業をしまったあとで時折買うものだと、大問屋町の家庭では下女たちまで、そんなふうに堅気にしこまれていたので、大所の旦那さんの天ぷらの立食は、なんとまあ呆れたものだというわけだったのだ。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、大所は、みんな自宅風呂があるのだが、土一升、金一升の土地に、急にのさばり出したものには、金づくだけではその設備をする場所がないのだ。",
              "citation": {
                "source": "鉄くそぶとり",
                "author": "続旧聞日本橋・その二",
                "note": "青空文庫"
              }
            },
            {
              "text": "すきな芝居すら、年何回と言ふほども出なくなつてゐた頃だつたから、大所の檀那のやうなおちつきで、芸人だからと言ふ卑屈な遠慮などなく、楽しみたいまゝに、楽しんでゐた彼を見て、ほつとした気がした。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して又彼が政治家としての長所は、実に唯此大所を見るの明に存したりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が一度大所へ出でゝ当世才俊と呼ばるゝものと勝負を決したしてふ志願は成れり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくまで書道を純真に芸術的に理解することが出来て、大所高所からそれを見下すことの出来るということは書道を愛好するものの最大理想である。",
              "citation": {
                "source": "良寛様の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上は、国家の食糧事情の大所高所から観てよいあんばいにやっているのであろうから、私如き俄百姓が、疝痛を起こすなど、甚だ僣上至極。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　結局、われわれも茶寮を経営して行かねばならなかったので、利益を度外視して、ものをすることは絶対出来ませんでしたが、われわれがほかと少し違うところは、その経営法が大雑把で、大所高所から見た、すなわち、急がば廻れ式のソロバンをはじいていたことなんです。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに引かれることなく、敢然立って芸術を理解し、大所高所より書道を見下すということは、その人の見識に、余程超邁なところがなくては出来ないことである。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "京大所蔵『竹屋文書』の中、日野資愛卿より竹屋殿に宛てた消息に、一、左散所右散所事、散所神人などの事何か覚申候。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟県方面からは、糸魚川街道の大前｜若しくは平岩から大所に出で、夫より蓮華温泉に至り、蓮華鉱山跡を経て、鉢ヶ岳の南方越中との国境上に出で、山稜を南進して終に頂上に達するのであるが、距離も長く又信州口ほど楽でもない。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次は越後方面の大所から大所川に沿うて登るので、二日を要しましょう。",
              "citation": {
                "source": "日本アルプスの五仙境",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "医術のほうの手腕は大したことはないらしいが、幇間的な、辯巧の達者な男なので、この脇坂山城守をはじめ、こういう大所を病家に持って、無礼御免に出入りしているのだ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、おずおずして見えたのは、濡れた着物と、大所の武家やしきに慣れない幸吉の態度だけで、幸吉の心もちは、ちっともおずおずしてはいなかった。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "大所高所に立つて、あの人物の利用法を考へてくれたまへ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "領土が限られており、それが大所有に分割された肥沃な土地から成る国においては、資本が小である限り、その社会組織は自由と善政とに最も都合が悪い。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "大所高所から見れば君と僕とは共犯者である。",
              "citation": {
                "source": "俳優への手紙",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……急ぐからかいつまんで話すが、去年の春ごろ、関西に何か大きな出物があって大阪貴石倶楽部の大所がだいぶ動いているという噂がチョイチョイ耳に入った。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにもげん公に恩も怨みもあるわけじゃねえが、あんな下等なのがおおどころにブラ下っていると、芝居道の進歩の邪魔になる、芝居の方も、も少し向上させなくっちゃいけねえね」といいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
