[
  {
    "uuid": "eb0f0572-11d8-5e0e-b712-a7c865d9ba13",
    "entry": "お百度を踏む",
    "reading": {
      "primary": "おひゃくどをふむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-マ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to visit repeatedly (to make a request)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お百度を踏むについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お百度を踏むがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお百度を踏むの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお百度を踏むが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お百度を踏むの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお百度を踏むがあります。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お百度を踏むについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお百度を踏むの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお百度を踏むが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお百度を踏むは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお百度を踏むについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお百度を踏むの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お百度を踏むを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "つい此間までお百度を踏むでゐたんですもの………少しお願があツたもんですから。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ただ窓をとおして顔を見あったり饒舌ったりするだけのことだから、まるで動物園にお百度を踏むのと同じで、通うと言ったところで、単に男のほうで、愛の恒久性、恋の保証をこういう手段で見本に示すに過ぎない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてほとんど半日以上も一つのところをお百度を踏むようにして、ついに歩き疲れて屈託しながらひとまず宿まで引き揚げて来た。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに交際のかぎられた都会の人々などはお百度はただ一人で踏むものと思い、なんべんも同じところへ行くことを、お百度を踏むという諺さえある。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to walk back and forth in front of a shrine, praying a hundred times",
