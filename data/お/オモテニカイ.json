        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私は表二階の、おそらくはこの宿屋で一ばんよい部屋なのであろう、二十畳間くらいの大きい部屋のまんなかに、ひとりで寝かされた。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝く胡蝶の翼一尺、閃く風に柳を誘って、白い光も青澄むまで塵を払った表二階。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階にいたんですから。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階にて下男を対手に、晩酌を傾けおりしが、得三何心無く外を眺め、門前に佇む泰助を、遠目に見附けて太く驚き、「あッ、飛んだ奴が舞込んだ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階よりこれを見て、八蔵は手早く身支度整え、「どれ後を跟けましょう。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでもござりましょうか、――先刻の騒動の最中、この家ならびで二軒さきの玉喜屋の表二階で、仁王立になって、ばらばら、ばらばら、大道へ品物を投げ出していた方がござりますそうな。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがたです……　池川さんの、二階で、」　と顔を見合せた時、両方で思わず頷く様な瞳を通わす、ト圧えた手を膝にして巽はまた笑を含んで、「……釣舟にしておきましょう、その舟のね、表二階の方へ餉台を繋いで、大勢で飲酒ながら遊んでいたんですが、景色は何とも言えないけれど、暑いでしょう。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は表二階の空を眺めて、その足で直に裏窓を覗くのを不斷から憚るのである。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも表二階の炬燵から。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と表二階、三十室ばかり、かぎの手にづらりと並んだ、いぬゐの角の欄干にもたれて見まはした所、私の乏しい經驗によれば、確にみゝづくが鳴きさうである。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「表二階の八畳がいい。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階の十畳間にとおされた。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階の小綺麗な部屋に案内された。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、表二階や裏二階や、離れ座敷にもさまよひ出た。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十　時に、間を隔てた、同じ浪屋の表二階に並んだ座敷は、残らず丸官が借り占めて、同じ宗右衛門町に軒を揃えた、両側の揚屋と斉しく、毛氈を聯ねた中に、やがて時刻に、ここを出て、一まず女紅場で列を整え、先立ちの露払い、十人の稚児が通り、前囃子の屋台を挟んで、そこに、十二人の姫が続く。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　で、有無を言わせず、表二階へ引出された。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中の陳述に因れば、女中は彼が、彼の日常の居室になっている、表二階の室に入る気配を聞いたのであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしかもその表二階の室は、女中は前もって火を入れ、煙ったので窓を開けておいたのであったと。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それこそ誰あろう、――あらゆる捜査を、五里霧中に葬り去らせていた、セバスチャン・モラン大佐、――すなわち先月の三十日の夜、レーヌ公園第四百二十七番で、表二階の開いている窓から、柔軟弾を使用した空気銃で、ロナルド・アデイア氏を射殺した、大犯人さ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "午下りに麓から攀上つた時は、其の癖｜汗ばんだくらゐだに……　表二階の、狭い三｜畳ばかりの座敷に通されたが、案内したものの顔も、漸つと仄くばかり、目口も見えず、最う暗い。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いま、また女中が、表二階の演技場で、万歳がはじまるから、と云って誘いに来た。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階の縁と、広く続いて、両方に通口のあるのが、何だか宵から、暗くて寂しゅうございました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すらすらと表二階の縁の端へ、歴々と、円髷と銀杏返の顔が白く、目をぱっちりと並んで出ました。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仙人掌に下駄をつまだて、棕櫚に帽子をうつむけなどして、横に曲り縦に通ると、一軒、表二階の欄干を小さな楓に半ば覗かせて、引込んだ敷石に、いま打った水らしい、流れるばかり雫が漾う網代戸を左右に開いた、つい道端の戸口に、色白な娘が一人、芸妓の住居でないから娘だろう。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは朝帰りの客を送り出して、自分の部屋を片付けていると、表に捕物があるという騒ぎに、ほかの朋輩たちと一緒に表二階の欄干に出てみると、あたかもここの店さきで十手と短刀がひらめいている最中であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階から裏二階へまわって、お駒の部屋も無論にあらためた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しん吉という江戸の落語家でございます」「いつ頃から泊まったね」「しん吉さんは先月からこの近辺をまわって居りまして、ここでも東屋という茶屋旅籠屋の表二階で三晩ほど打ちました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "表二階はどの座敷も満員で、夜のふけるまで笑い声が賑かにきこえていたが、下座敷のどん詰まりにあるこの二組の座敷には、わざわざたずねて来る人のほかには誰も近寄らなかった。",
              "citation": {
                "source": "五色蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は表二階に滞在している某官吏の細君であった。",
              "citation": {
                "source": "五色蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "古河君は表二階の新しい六畳の座敷へ通った。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
