        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さうあるべきがよかつたかも知れない多くの元気な顔たちの中に、私は容易におまへを見付ける。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……２恋人よ、その哀しげな歌をやめてよ、おまへの魂がいらいらするので、そんな歌をうたひだすのだ。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまへはわがままに親しい人だと歌つてきかせる。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに牧野さんが酔ふと発しはじめるのなぞは、当人に自制力がないよりも、周囲が彼にとつてはあまりに不真面目に見える所から起るのであつたと考ふべき点もあるのであるから、さういふ定説が呑気に繰返されることは辛かつたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、Ａは今後益々その志望に於て衰耗してゆくであらうし、Ｂは尠くも、文学の点でだけは発展してゆくであらう。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、それはおまへの今ゐるのが何の変哲もない峠道のことで、闇夜のことだし草一本満足には見えぬ有様だからだらうなぞ思ふ人もあるかも知れぬ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭によくも這入らない時なぞ読書したりして、だからおまへのやることはみなヂグザグになつちまふんだ」。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕としてたゞまだ塵芥箱もないことだし、隅ッコに暫時捨てたわけで、おまけにそこらに前ゐた人が捨てて行つたのだらう、ボール箱や新聞紙のキレが相当散らかつてゐたので、そのお説教が始まつた時は全く意外であつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　それやおまへが出ると、また俺の嫌な人間ばかりを連れ込むからさ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　あれはおまへ、「コハーネ」の話はおまへ、河島がしたんぢやないか。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへも傍にゐて、聞いてたぢやないか。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "『虱や、ご生だからたからないでおくれ、私にしつつこくしないでおくれ、おまへはほんとに不愉快だ』そして痒いところへ手をやらうともしなかつた。",
              "citation": {
                "source": "諷詩",
                "author": "―人魚詩社の人たちに與ふ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に老の近づいたことを知った彼は、自分の残されてる短かい時間に、なおまだ書かねばならない大事の事が、あまりに多くありすぎるのを考えて愁然とし、『人生は短かすぎる』と幾度も言って嘆息した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はわるし、文章は下手、学問は無し、すべてに無器用、熊の手さながら、おまけに醜貌、たった一つの取り柄は、からだの丈夫なところだけであった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と質問され、博士大いに閉口して、奥さま、生れたばかりの赤ん坊に、おまえは何を建設するのだい？",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、――美少年だ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも、「おまえがわるいんだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、この友人と酒を飲んで「おまえは馬鹿だよ」と言った事があるのを思い出して、恐縮した。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の女を私から奪略した男の所へ、女が行くといふ日、実は私もその日家を変へたのだが、自分の荷物だけ運送屋に渡してしまふと、女の荷物の片附けを手助けしてやり、おまけに車に載せがたいワレ物の女一人で持ちきれない分を、私の敵の男が借りて待つてゐる家まで届けてやつたりした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに熾んな社交意識が伴つて、如何に虚栄を演ずるかといふことの中に人格の価値があるかの如く思ひ做される、さういつた風潮は日々に激しい。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけにそれが短歌や俳句の延長でなしに、純然たる詩の様態を持してゐたのならばともかくも、事実それは屡々短歌や俳句の延長であつたといふか、それらの形の崩れたものであつた。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それやあ、おまへは自分を標準にするからのことだけれど、耕二はさうは行かん。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の俺からみてもおまへと耕二は大変な違ひだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おまへみたいにそんな、人を馬鹿にしたやうな笑ひ方をすると余計に自分が馬鹿にされようぜ！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのパツタパツタいつてるのは何かおまへ知らないかい、耕ちやんの部屋らしいが。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度はおまへの番だよ」つて眼で。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、おまへに見せてやるものがある、」彼は父の言葉をこれまで耳にすると、ガクツとたゞ一度だけする身慄ひと共に父の方を瞶めた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへくらゐのものにまだ相対界を尽滅させられて堪るものかいと空で無頼漢が私にいふ。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうか、今度の中にはおまへがをつたといふのか。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
