    "definitions": [
      {
        "index": 1,
        "gloss": "moderate (view, politics, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
