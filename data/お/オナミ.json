          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "那珂川の海に朝する處、女波男波の雪をくづして川流とたゝかふ處、長橋波に俯して、湊町と祝町とを連絡す。",
              "citation": {
                "source": "水戸觀梅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は、古来有名で、叙景歌の極地とも云われ、遂には男波・女波・片男波の聯想にまで拡大して通俗化せられたが、そういう俗説を洗い去って見て、依然として後にのこる歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢上に囀づる小鳥の声も、渓谷を下る潺閑たる流も、山端に吹く松風の音も、浜辺に寄する女波男波のさゝやきも、即ち是れ地のオーケストラの一部奏に過ぎない。",
              "citation": {
                "source": "土民生活",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時母と自分は、これが片男波だろうと好い加減な想像を話の種に二人並んで歩いた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのおなみだこそ、歌をうたうものの、こころをよろこばす、宝石でございます。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはまだ丑之助という子役で、七之助の妹おなみという盲目の小按摩をつとめていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この役は父の菊五郎が羽左衛門といった昔に好評を博したものだそうで、今度は順あがりに父が七之助をつとめ、その子の丑之助がおなみに廻されたのであるが、三日月長屋や七五郎の家などは、本来の役もよく、丑之助の出来もよかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなみ婆さんは地主の今の旦那の婚礼の時の模様を、誰彼となしに、くどくどと物語つてゐた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
