    "definitions": [
      {
        "index": 1,
        "gloss": "to flee",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この時こころの疲れ、身の疲れを一時に覚えて底なき穴に落ちゆく心地し、しばしは何事をも忘れたり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "風吹けばかすかに揺れ、雪ふればいよよしづもり、さむざむと時雨るる夜半も、月あかり落ちゆく暁も、消なんとし消たずかすかに、現にもうつしけなくも、ただ寂し薄し果敢なし。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹角みちのくの谷の若人、牧の子は若葉衣の夜心に、赤葉の芽ぐみ物｜燻ゆる五月の丘の柏木立をたもとほり、落ちゆく月を背に負ひて、東白の空のほのめき――天の扉の真白き礎ゆ湧く水のいとすがすがし。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて北軍の総大将勝家は、今市の北狐塚に陣して居たのであるが、盛政の敗軍伝わるや、陣中動揺して、何時の間にか密かに落ちゆく軍勢多く、僅か二千足らずになった。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や波間では灯もほのかに赤みがかり――時もかすかに浅く息をしている――そして地鳴りもなくこれから下へ下へその街が落ちゆく定めでも地獄はいずれ千の玉座から立ち上がりその都に敬礼してみせよう。",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちゆく杉田の体を、むずと抱きとめた者がいるのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一一『ひとり居馴れた木をおりて、み山の谿に落ちゆくに、尾羽は憂身をさへぎりて、またあり※く、わが世に。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「落ちゆく先きは九州｜相良とか何とかいわなかったかね。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、我は夢に落ちゆく。",
              "citation": {
                "source": "失楽",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこのラヂオを見て、　――国家の地歩はどこ迄落ちゆくのであらう（国家地歩落到那辺）――と、独り問ひ独り嘆じて心中不安に堪へないものがあつた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "山松のあらしのなかに落ちゆく月いかばかりさびしかるらむこんな歌が書いてある。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "──だって遊びたい盛りですもの……」　私は地の底へ落ちゆくような気がした。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に追はれて　　三日月の水に落ちゆく　　影みればなぜか涙の　　さそはるゝ。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「義士伝」の倉橋伝助が、まだ長谷川金次郎といって飲む打つ買うの三道楽であった時分、江戸を食いつめて、落ちゆく先も御多分に洩れず、木更津だったと覚えている。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語家万事、偐紫、江戸紫、古代紫、紫、紫、むらさきのこと――芸の落ちゆく最後のお城、御本丸は、ついに「紫」以外の何物でもない、ないのだ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこを落ちゆくお方、お見受けすれば、平家の大将軍と覚えまするぞ、返し給え、敵に後ろをお見せになるとは何たる卑怯」　六弥太の言葉に忠度はちらりと後ろを振向いた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタンダールは「赤と黒」の主人公に於て、卑小な時代に反覆される野心の落ちゆく先はどこかということを描き出しているのでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、酒に限る――酒に落ちゆくよりほかののがれ場はないというに帰する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「落ちゆく先とて定かでない。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉱山掘夫の知らぬ山一　そのおなじ日の落ちゆく陽脚をいそいで、まだ逆川に夕照りのあかあかと反映していたころ、小夜の中山、日坂の急をさか落としに、松並木のつづく掛川から袋井の宿へと、あたかも鉄球がとぶように、砂塵をついて疾走していく悍馬があった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、ころげ落ちた神童と畸童、どっちも、そこでは健在だったが、落ちゆくまに、竹童はかれの耳タブをギュッとつかみ、蛾次郎はあいての口中へ拇指、もう一本、鼻のあなへ人差指を突ッこんでいた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教頭の王進、追捕をのがれ、母と千里の旅に落ちゆく事　棒鎗術の名人として、王進の名は遠近に高い。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、かれらが落ちゆく先には、上杉方の川中島衆が、要路をふさいで、小鳥の大群を待つかすみ網のように、仮借ない打撃を与えた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お味方です」「探題たちか」「六波羅松原に残余の兵を呼びあつめて、共々落ちゆく者どもでござりまする」　そこではみな、つかのまながらほっとした。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "万が一にも、危うしとなれば、舟で落ちゆく島もあろうというもの」　それからも、両者のあいだには、たれ知らぬ密談が交わされていた。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しく走りつきて石をあわせ、ひたと打ひしぎて蹴飛ばしたる、石は躑躅のなかをくぐりて小砂利をさそい、ばらばらと谷深くおちゆく音しき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しく走りつきて石をあはせ、ひたと打ひしぎて蹴飛ばしたる、石は躑躅のなかをくぐりて小砂利をさそひ、ばらばらと谷深くおちゆく音しき。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、芸術至上主義をそれなり肯定すれば、おちゆく先は、経来ったところを見て明らかなのですから、やはり「人間性一般」的あぶないところに落ちこみます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
