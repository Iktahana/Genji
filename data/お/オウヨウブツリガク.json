          ],
          "literary": [
            {
              "text": "また近年目ざましい進歩をしたいわゆる航空術などもやはり応用物理学の一つと云って差支えはあるまい。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五八（昭和三十三）年早稲田大学理工学部応用物理学科を卒業して日本電気に入社。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五九（昭和三十四）年、日米安全保障条約をめぐって日本が大揺れに揺れる前の年、岩戸景気で企業が活気づく中で、東京大学理学部応用物理学科を卒業して古山良二は日本電気に入社した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで三年になってからの研究実験にも、応用物理学の中で近い将来に大発展をするような方面を選ぼうと思った。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
