    "definitions": [
      {
        "index": 1,
        "gloss": "well-behaved (esp. of children and pets)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "チエ子さんはお利口ね。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（継母のあさの声）　お利口だったねえ、お利口だったねえ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母様のことだの、お友達のことだの、先生の事だの……それあ温柔しい、可愛らしい、お利口な、お人形さんだったのよ。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、まあ、その方がお利口でしょうね。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何々よろしゅうござりまするじゃ、貴方様はお利口なお方様でござりまするもの、わたくしはよろこんでおりますのじゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、お利口お利口！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "脳力、が暑さのため減退してゆくと云うことは、なにより、お利口さんのハチロウをみれば分る。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこと位、お利口な太夫さん、判らないことはなかろう、人間最後の時だ。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、兄と、八郎太とに対して、月丸を獲たことを誇りとするように（よい男で、お強くって、お利口で――本当に、妾を可愛がっていて下すって――どうぞお喜び下さいませ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてミコちゃんを見ると「なんと言うお利口なミコちゃんでしょう。",
              "citation": {
                "source": "可愛いポール",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ五等席にも乗りたがらずに、足で間に合わせるのがなお利口だという考えなんです。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "美紗　えゝ、あなたはお利口よ。",
              "citation": {
                "source": "喪服",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラネーフスカヤ　なんてお利口さんなんでしょう、ペーチャ！",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あたしの坊や、それにほんとにお利口に、ほんとに色白に生まれついたものねえ」「島とは」と少年は声を張りあげて読んだ。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さああなたの許婚とやらはどのようにお美しく、おしとやかで、どのようにお利口かは存じませぬが、そのようなこととて妾にとりましては怖くも恐ろしくもございません。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたもお利口さんで、私の邪魔をなさらないわね。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャ　わたしのあの教師は、大してお利口さんじゃないけれど、なかなかいい人だし、貧乏だし、それにとてもわたしを愛してくれるの。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "」って言うアリスちゃんはお利口さん。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ノンデ」っていうのはたいへんけっこう、でもお利口さんのアリスはあわててそんなことしたりしません。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ほんとうに、お利口なかけすさんだこと」　うしろに、のっそりと人が立った気配がする。",
              "citation": {
                "source": "キャラコさん",
                "author": "ぬすびと",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは、お利口なのね。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は何度となく「お利口だ」といわれたことがある。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはお利口で、私は学校中で一番出来ないのですけど、私はあなたがほんとに好きなのよ。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、皆さん、その石の上で遊んじゃだめ、危いわよ、崩れて下になったら、死んじまう、お利口さんだから別の処に行って遊んで頂戴、ほら、ね、きゅうには降りられないでしょう、さあ、あたいが抱っこして上げるから、彼方に行って。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、とても、お小さいけれどお利口そうだと言っていた。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは次郎ちゃんがお利口におなりだからでしょう。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は自分の口からみんなにそう言っとるじゃないか、いやみんなといっても、あの人のとこへたずねて来るお利口な連中にだけだけれど、県知事のシュルツには明からさまに、『Credo（信じてはいる）といっても、何を信じておるのか、わかりません』と言ったものだよ」「まさか？",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主にはふたりの息子がありましたが、ふたりとも、ものすごくおりこうで、その半分でもたくさんなくらいでした。",
              "citation": {
                "source": "のろまのハンス",
                "author": "――むかしばなしの再話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ねんねんねんねん――ねんねんや――赤ちゃんはおりこうだ、ねんねしな――』　彼女はふと、その唄を聞くと、涙がぼうと浮んで来た。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおりこうなそなたがまた、どうしたわけでお役人のおさしずもきかず、そんなところにすわっているのでござります？",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
