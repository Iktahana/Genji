    "definitions": [
      {
        "index": 1,
        "gloss": "Inari (god of harvests, wealth, fertility, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）Ｓ＝お稲荷さん境内　其辺へ三次はやって来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊は頓着せずに、Ｔ「お稲荷さんで隠れん坊をしよう」　と言うのに三次、今日は駄目だよと振り切って去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次、今度は鉄五郎に、Ｔ「旦那子供は正直で御座んすね」　皮肉に言って勝坊の手を取って、Ｔ「おじちゃんとお稲荷さんで隠れん坊をしよう」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九　子爵千破矢滝太郎は、今年が十九で、十一の時まで浅草｜俵町の質屋の赤煉瓦と、屑屋の横窓との間の狭い路地を入った突当りの貧乏長家に育って、納豆を食い、水を飲み、夜はお稲荷さんの声を聞いて、番太の菓子を噛った江戸児である。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お稲荷講、万年講、お稲荷さんのお初穂。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと先の、小さいお稲荷さんのある近所に、もう一軒ありますから、すぐに行って買って来ましょうね」慰めるようにお玉の顔を見て起ち上がる。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お稲荷さんの堂守を兼ねている。",
              "citation": {
                "source": "前兆？",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋は南向きで日当りがよく、お隣りは宝珠院というお寺の庭に接しているから、充分ゆとりもあり、庭はまたお寺の地所十四、五坪を取り入れてなかなか広く、お稲荷さんの祠などあってなかなか異だということです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "総領の娘を亡くした頃のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭のお稲荷さんもその人がこしらえたものということ……それで、妙だと思った仕事場のことなども分りました（この家の持ち主は御徒町の料理店｜伊予紋であった）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "総領の娘を亡くした頃のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿四人、老人は遊人だらう、若者は行商人、中年女は何だか要領をえない巡礼さん、最後の四十男はお稲荷さん、蹴込んで張物の狐をふりまはす営業、おもしろい人物で、おしやべりで、苦労人で辛抱人だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、山路を歩くともなく歩いて、お稲荷さんに詣でた、行者一人の長日月の努力が、岩を割き地を均らして、これだけの霊場を出現せしめた事実に頭を下げる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は何故にお稲荷さんが、特に女中をしていたお梅さんを抜擢したかということまで、神慮に立ち入って究めることは敢てしない。",
              "citation": {
                "source": "独身",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――さア、出かけよう、君は、何が食ひたい、……さうだね、あまり贅沢なものはいかん、口がおごつて、癖になるからね、お稲荷さん、君は酒好きだから、先づ一ぱいはじめようか」　元気よくしやべり立てる「高等乞食」のうしろから、我々はついて行つた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――さつきから、何だか変だ、変だと思つてたが、お稲荷さんの話を聞きながら、万歳を思ひ出してゐたんだ。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――さあ、病気は早よ快るかどうか、お稲荷さんのお告げはあらたかなもんだつせ、さア」　彼は前置をして、仕事にかかつた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――ああ、やつぱり大凶、ちがひない、……入れといた覚えのないもんが出るとは、こら、お稲荷さんの罰やで、……」　昂奮して独りで云ひつづけてゐたおみくじ屋は、遂に説明のつかない不思議を解きかねて、その彼流に不安なもどかしさを私に対する怒りに代へるのであつた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三光稲荷は失走人の足止の願がけと、鼠をとる猫の行衛不明の訴をきく不思議な商業のお稲荷さんで、猫の絵馬が沢山かかっていた。",
              "citation": {
                "source": "木魚の顔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「知らないよ」「そうか、ま、兎に角七八里歩いたンだから腹も泣くさ……」　チンドン屋が、啓吉達の横をくぐって、抜け道のお稲荷さんの宮の中へ這入って行った。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ついそこのお稲荷さんまでお詣りに来やしたよ。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お稲荷さんを新たにお祭りすること――これは相良家にして貰えばよろしい。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると果して轟音を発して、山崎や若林のお稲荷さんの方が燃え出し、つづいて萩原さんの竹藪の向こうに真赤な火の幕が出来、三軒茶屋方面へ落下したことが確実となった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "春木は、そういう推理にもとづいて、崖の上のお稲荷さんへかけあがったのである。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘリコプターは、このままの方向で飛びつづけると、お稲荷さんのうしろの山に、ぶつかるにちがいなかった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがヘリコプターは、お稲荷さんの方までは飛んでこなかった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先のことは、春木少年がお稲荷さんの崖の上から月明かりに見ていたとおりだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひげ面男の登場　崖の上のお稲荷さんでは、春木少年が黄金メダルを埋めていってしまった後、おかしなことが起った。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、お稲荷さんの荒れはてた祠の中から、一人の人物が、のっそりとでてきたのである。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな一大事が発生しているとは知らず、春木少年は八時ごろにお稲荷さんへのぼってきた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（きっと、あの祠に寝起している男にちがいない）　春木少年は、あれからいくどもお稲荷さんの崖にのぼって、裏手からそっと祠をのぞいた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "絹のハンカチの文句　その夜にも二回、その次の日の朝にも三回、春木少年はお稲荷さんの祠を偵察した。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
