[
  {
    "uuid": "ce98c7a3-a654-583b-8f90-b5c983b1a262",
    "entry": "おさらば",
    "reading": {
      "primary": "おさらば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
