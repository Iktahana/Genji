      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "saying goodbye (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おさらばという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はおさらばの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "おさらばを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではおさらばという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "おさらばの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、おさらばは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、おさらばの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "おさらばと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、おさらばは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、おさらばはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "おさらばの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、おさらばの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、おさらばが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "おさらばを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、おさらばのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、おさらばに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "おさらばの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、おさらばの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "おさらばは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、おさらばの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "入れ違いに今度は二ツ目左膳と、おさらばお小夜御免と内へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜が、Ｔ「確かに此の人の買った品」　と言って、Ｔ「おさらばお小夜が証人だよ」　「サァ刀貰って帰りましょう」と二人が帰ろうとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お小夜がせせら笑って、Ｔ「御冗談でしょう」　なにッと主膳、Ｔ「如何にもあたしァおさらばお小夜ッてしがねえ巾着切サ」　と言って、Ｔ「連判状とか何とか言う」　と言われて主膳ナニッと顔色変えた。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "下からお小夜が、Ｔ「おさらばで御座んす」　と言って立ち去った。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、すっかりおさらばを告げて出て行った筈のベッドへまた逆戻りした。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日来るぜい、おさらばだいと、高慢な毒口を利いて、ふいと小さなものが威張って出る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あい、」「………」「おさらばだよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこかへ行って酒を飲まして、ちょいと例の毒薬を飲ましゃあ訳は無い、酔って寝たようになって、翌日の朝はこの世をおさらばだ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "非人間的な、あの美魔にはもうおさらばだ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の中からおさらばしたいというようなことばかり、子供の頃から考えている質でした。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の力では、この上もう何も出来ぬということを此の頃そろそろ知り始めた様子ゆえ、あまりボロの出ぬうちに、わざと祭司長に捕えられ、この世からおさらばしたくなって来たのでありましょう。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいい、一刻も早く、人柱にしてもらって、この世からおさらばさせていただき、そうして、できれば、そのことに依って二、三の人のためになりたかった。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用事あらばなんぼなりと、お使いなされて下されまし』蓮如『では、おさらば』源右衛門、おさき『おしずかに、おいでなされませ』（蓮如上人は幸子坊を連れて出て行く。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都をおさらばする前に寄って行こうと思ったのは、やはり京都への未練だろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう三高生活もこれでおさらばだと、彼ははじめから受持の教授を訪問する気持もなかったのであった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、旦那、枯れきってまさ、――たしかに参ってますだ、――この世からおさらばしてますだ」「こいつあいったい、どうしたらいいだろうなあ？",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちあぐッと溜飲が下って、おさらばを極めてフイとなって、ざっぷり朝湯を浴びた気さ、我ながら男振を上げて、や、どんなもんだい。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "マウスとキーボードの持ち替えといった、道具の側のつごうに強いられたわずらわしさからは、おさらばだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年留年して一九七六年に大学におさらばしてまもなく、日本電気の半導体屋がマイクロコンピューターにちゃちな16進のキーと８桁のＬＥＤをくっ付けて、トレーニング・キットと称するオモチャを出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのうちに、うんと自分のからだをこき使って、そうしてわずかでも食料の増産に役立ち、あとはもうこの世からおさらばして、お国の負担を軽くしてあげたほうがよい。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く、早く、繊細な神経よ、汀を去つて沖へ出てくれ、早く、早く、コメカミから頭痛膏をはぎとつてくれ、中将湯で体が温まつたら、男よ、女のやうな男におさらばをしてくれ、生きながら刺身になるやうな生活のくるしみで横たはつてゐるじつと動かぬ馬鹿々々しさに誰か醤油をかけてくれ、そして私は弾けたのだ。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねこ伝身内の奴さんたちもおさらばだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさらば、さらば葡萄祭、さらばよ花籠、橡の葉陰の舞踏の庭のワットオぶりの花籠よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「武器蔵か本陣でございます」「では文三さん、おさらばおさらば」　陣幕をくぐって文三が、そとへ出たのを見きわめると、天草時行突っ立った。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予とても、體裁つくり、そなことを言ひはせぬ、と言ひたいは山々なれど、式や作法は、もうおさらば！",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "お内かた、おさらばでござる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おさらばでござる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロミオ　おさらば、おさらば！",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
