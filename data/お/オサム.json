    "definitions": [
      {
        "index": 1,
        "gloss": "to govern",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼灑掃応対進退の節と説き、寡妻に法り、兄弟に及ぶと云い、国を治むるのもとは、家を治むるにありと云い、家整うて国則整うと云い、其の家庭の問題を如何に重大視したか、詩経などの詩を見ても、家庭を謳うたものが多いのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恁くて旦に暮に其の根を治む。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の言に、吾は乱世を治めたれば、刑重からざるを得ざりき、汝は平世を治むるなれば、刑おのずから当に軽うすべし、とありしも当時の事なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱世に於けるかかる形式は、自然と人民をして自ら治むることの有利にして且喫緊なことを悟らしめた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の學を修め身を治むるにも亦的が無くてはならぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の孔明が書を讀み學を治むるに當つて、ゾンザイな事などを敢てしたと思うては大なる誤謬である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の中都を治めし所の法をもって魯国を治むればすなわちいかん？",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下を治むるといえども可ならんか。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御辺の行跡何とも無分別候、行末何になるべき覚悟に哉……弓馬は男の業也器用も不器用も不入候可稽古事也、国を治む文武二道なくては更に叶べからず候、……其上君子｜重ずんば則威あらず義元事は不慮の為進退軽々しき心持候。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "虞夏商周の聖王の天下を治むるに鬼神を先にする者は必ず鬼神を以て有りとするからであると爲し、而して人死して或は鬼神となり、天の化育を贊し施運を輔くるものと爲し、古傳説を援いて之を證し、古儀式を釋して之を通じ、鬼神のまざ／＼と存することを説いてゐる。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『説苑』七に楊朱が梁王に見えて、天下を治むる事｜諸を掌に運らすごとくすべしという。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "梁王曰く、先生、一妻一妾ありて治むる能わず、三畝の園すら芸る能わざるに、さように容易く天下を治め得んやと。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、日の晝にかゞやき、月の夜を照すは、男の外を司り、女の内を治むるに似たり。",
              "citation": {
                "source": "日月喩",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "千明由松といふ老人夫婦、その別莊の番を爲せるが、この由松氏は、豪氣人に絶し、産業を治むるを屑しとせず、劍術に長じ、銃獵を好み、常に山に入りて猛獸と鬪ふ。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「だしまおそうあぢおそい」（この島を治むる君）、「だきよりおそうあぢおそい」（この国を領する君）というようなこともある。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "国を治むる人という意で、くにおそい、くにもり、くにしり、のように名詞法になった例も多い。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "按司添の添はおそいで、治むる人という意味をもっている。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の歴史的事実で浦添に国を治むる所という意味のあることはわかりかけたが、次に浦添の歴史地理を調べて結論を急ごう。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "『遺老説伝』に、尚金福王命国公懐機築建長堤以便往来懐機以海底已深無力可施恭備祭品祈天告神一七日間海水乾涸即国内人民婦女運来石塊云々とある記事や『那覇由来記』に、扨沖道を築ける事は、前代尚金福王の御時国公といふ人有り、人を利し世を治むる故に、斯名付、其比封王有唐家の勅使此首里往復の路不平なり。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下を治むる宰相にその器量なくして、国家まさに亡びんとすればこそ、もろもろの妖異も出て来るのじゃ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そを何ぞといふに、かの相對に對する腹稿の主義を懷きて、現在の小宇宙に對する處分をなすといふ資格の逍遙子は忽ち主人となりて一家を治むるものとなり、人民となりて國に對するものとなり、教師として學校に勤むるものとなりぬることこれなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "われおもふに一家を治むる主人は個人なるべし、國に對する一個の人民も個人なるべし、學校に對する一個の教師も個人なるべし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "奚んぞ礼義を治むるに暇あらんや。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学にいう、「古の明徳を天下に明らかにせんと欲する者は、先ず其の国を治む。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼その説に以為らく、　人は本来自由なり、人によりて治めらるるを甘んぜずして自ら治むるを勉むべし、自ら治むるの方法は代議政体に如くはなし、人は本来平等なり、貧富智愚によりて権利に差違あるべからず、何人も国の政事には参与するの天権あり、これを実行するは代議政体に如くなし、と。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお一歩を進めていわく、　このゆえに国を治むる必ずその法ありて後にその人あり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻をやつままむ眼をやおさむとまたつくづくと打まもりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに、みんな捜し出されて、ぞろぞろ西洋間へひきあげて、「おさむさんは、まだだよ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで研究会の会長さんは元来おさむらいでしたから考えました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いねむりをじゃまされたので、このおさむらいはおこっているのにちがいない、と思いました。",
              "citation": {
                "source": "飴だま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
