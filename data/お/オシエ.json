      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "teaching",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "数十人の智慧ある先賢に手をとられ、ほとんど、いろはから教えたたかれて、そうして、どうやら一巻、わななくわななく取りまとめた。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかつて私たちの敬愛の的であった田舎｜親爺の大政治家レニンも、常に後輩に対し、「勉強せよ、勉強せよ、そして勉強せよ」と教えていた筈であります。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆうべ女のひとがねえ、僕にこういって教えたものだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊のやつが僕にそう教えたことがある。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、かねて山田君から教えられていた先方のお家へ、速達の葉書を発した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また媒妁人は、大学で私たちに東洋美術史を教え、大隅君の就職の世話などもして下さった瀬川先生がよろしくはないか、という私の口ごもりながらの提案を、小坂氏一族は、気軽に受けいれてくれた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの結婚の事に就いては少しも言わず、ひたすら世界の大勢に就き演説のような口調で、さまざま私を教え諭すのであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな大事なことを一言も僕に教えてくれなかったというのは不親切だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の事を、はっきりと教えてくれるので、私も私の疑念を放棄せざるを得なかった。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教えてくれたのは、欧米の人たちであるが、今では、別段彼等から教えてもらう必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "横綱の忍の教えは、可憐である。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に芭蕉も弟子に教えて、常に「俳句は調べを旨とすべし」と言っていたという。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年前に文学士になってから、しばらく神田の某私立学校で英語を教えていた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分にも碌に分らないような事をいい加減に教えていると、次第々々に自分が堕落して行くような気がすると云っていたが、一年ばかりでとうとう止してしまった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時これがまじょりかといって安くないものだと教えられた。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔除鼠除けの呪文、さては唐竹割の術より小よりで箸を切る伝まで十銭のところ三銭までに勉強して教える男の武者修行めきたるなど。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆に墓表とは見えずまた墓地でもないのを見るとなんでもこれは其処で情夫に殺された女か何かの供養に立てたのではあるまいかなど凄涼な感に打たれて其処を去り、館の裏手へ廻ると坂の上に三十くらいの女と十歳くらいの女の子とが枯枝を拾うていたからこれに上根岸までの道を聞いたら丁寧に教えてくれた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も一度運悪くこの難船にぶつかって何かケルクショーズをしなければならないことになったので、そのケルクショーズの思案に苦しんでいたら隣席の若いドイツ人がドイツ語でこっそり「いちばん年とったダーメに花を捧げたまえ」と教えてくれた。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた珪藻のプレパラートを見せられ、これの視像の鮮明さで顕微鏡の良否が分かると教えられた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学時代になってからやっとイソップやグリムやアンデルセンにめぐり合って日本の外に他の世界があること、そこにはわれらとはよほどちがった生活と思想のあることを教えられたのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の軽微な苦痛を己が享楽の小杯に盛ろうとする不思議な心理がいかなる善良な人々の心の奥にも潜在することを教えてくれたようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何というものかと聞くと、レモン油というものだと教えられた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　子規の家から不折氏の家へ行く道筋を画いて教えてくれたものが唯一の形見として私の手許に残っている。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つの子規自筆の記念品は、子規の家から中村｜不折の家に行く道筋を自分に教えるために描いてくれた地図である。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校の頃に、次のような事を教えられた。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常山の花」と題する小品の中にある「相撲取草」とは邦語の学名で何に当るかという質問を受けて困ってしまって同郷の牧野富太郎博士の教えを乞うてはじめてそれが「メヒシバ」だということを知った。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも子供だけにはこんないたずらをさせないように家庭や小学校で教えるといいと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高松という処の村はずれにある或る神社で、社前の鳥居の一本の石柱は他所のと同じく東の方へ倒れているのに他の一本は全く別の向きに倒れているので、どうも可笑しいと思って話し合っていると、居合わせた小学生が、それもやはり東に倒れていたのを、通行の邪魔になるから取片付けたのだと云って教えてくれた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおしえてやりました。",
              "citation": {
                "source": "里の春、山の春",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
