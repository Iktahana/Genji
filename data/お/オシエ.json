[
  {
    "uuid": "5dc866bf-05ea-5b48-a63b-d0b9a8a9316c",
    "entry": "教え",
    "reading": {
      "primary": "おしえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
