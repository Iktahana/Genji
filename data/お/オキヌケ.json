        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "翌朝、起き抜けに、Ｂの細君はＡに案内を頼んで、浜辺へ散歩に出た。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは起き抜けに肩掛けを巻き付け、廊下へ飛び出しました。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は起き抜けに足踏みをし、壁をたゝいた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "実の熟する時分は起き抜けに脊戸を出て落ちた奴を拾つてきて、学校で食ふ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "実の熟する時分は起き抜けに背戸を出て落ちた奴を拾ってきて、学校で食う。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "起き抜けから、自分の鼓膜には、余り刺戟強く少し苦しかった。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝起き抜けに、おいち婆さんが迎えにきた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやあ、今朝は起き抜けからの大活躍でね、二三軒まはつて来たところさ。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起き抜けに浜辺を歩いた時、兄さんは眠っているような深い海を眺めて、「海もこう静かだと好いね」と喜びました。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御米は、「起き抜けにどこへ行っていらしったの」と云いながら奥から出て来た。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は起き抜けに、今朝咲いた花の数を勘定し合って二人が楽にした。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな快適な朝――起き抜けの平次を待ち構えているのは、一体どんな仕事でしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は、珍らしくその日は起き抜けから創作欲の亢奮を覚えていた。",
              "citation": {
                "source": "我に叛く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥沢の馬方が一番先にそれを発見して、忽ち黒山のように、起き抜けの人を集めてしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその母も、長年欠かさない習慣だった起き抜けの薄化粧もいつかしなくなっていた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "築山の向うで……池の方で人声がするような気がして、僕は起き抜けのまま、寝巻き姿のままで行って見たんです。",
              "citation": {
                "source": "棚田裁判長の怪死",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつろの館　起き抜けに、彼は、広い館や柵門を、一巡した。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "具足を出せ」　それは、独り言なのか、そこらの女たちに命じているのか、分らない口調であったし、起き抜けだというのに、ひどく腹立ちっぽい荒々しさがこもっていた。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、　また起き抜け早々、朝ッぱらからの一騒ぎ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目明しの居所知らず、または岡ッ引の起き抜け千里などと申して、職業がら是非ないことだ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは直接に三位卿のところへ持ち込んで、城内で羽振のきく若公卿に取り入ろうと胸算をとったが、それもあまり支配者を出しぬく形になるので、とにかく蒼惶として起き抜けに代官屋敷へやってきたわけ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――で、僕は朝おきぬけにホテルを立てるようにすっかり荷物をまとめ、それからやっと落ちついた気もちになって、君にこの手紙を書き出しているのです。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのう書いた部分をよみ直したりしているうちに、朝おきぬけからの泥棒のさわぎを忘れた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早い手紙ね、おきぬけの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "先のようだと、おきぬけにお客に来られたり、商人にたのみたいものをたのまずかえられたり、間誤付くこと多く、いやでした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、この前私の書いたのは十一日ごろです、そして、風邪で臥てしまって寿江子の代筆で、それから血眼つづきで一日にやっと『新女苑』の小説27枚わたして、二日には（きのう、よ）あの氷雨の中を横浜まで出かけ、かえり寿江子のことで国が用があるというからまわって、けさおきぬけに大森の奥さん来で。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝おきぬけから、おつき合いしてはじまるのでは仕事は出来ません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに村の入り口の関所とあだ名のあるよろずやのおかみさんときたら、岬の村へくるほどの人は、だれよりも先にじぶんが見る権利がある、とでもいうように、朝のおきぬけから通りのほうへ気をくばっていた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
