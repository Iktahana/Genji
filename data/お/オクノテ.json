        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "銀色の絞られた水平線まで彼女は片脚あげて、恋愛の条約による奥の手を英介氏にひらめかすのであった。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼はまた、翻然と、狡猾な奥の手を出した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら逃げても追い駆けて来る体内の敵をまくつもりで最後の奥の手を出してま近な二つの氷盤の間隙にもぐり込もうとするが、割れ目は彼女の肥大な体躯を容れるにはあまりに狭い。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでルラ蛙はもう昔習った六百｜米の奥の手を出して一目散にお父さんのところへ走って行きました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時こそ三十六計の奥の手を出して一散に駆け出し、危うく吾妻川の河底へ生埋めになる急場を辛くも通り過ぎ、四人相顧みて工夫の猛悪なるに驚ろく。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴けば、杉田先生はお年寄役だけに、三十六計の奥の手も余り穏かならじとあって、単身踏み留まり、なんとかかんとか胡魔化して、荷物をことごとく巻上げて来たとの事だ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへ来い」　と云ううちに、無茶先生は豚吉とヒョロ子を連れて奥の手術場に連れ込みました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどうも商売の奥の手で、この手を使わぬ奴は人気が立たず。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ云うてみればこの奥の手を持たん奴は魚売の仲間に這入らんようなもので……ヘヘヘ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あいつらが何をしようたって、まだこちらには奥の手があらあ。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "度胸も信仰も有るのではありません、がすべてこういう場合に処する奥の手が私にある。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつかり挑戦すると美智子は奥の手の泣き虫を発揮するし、美智子の母はさうするとやつぱり其方に加勢して「何だね、小ちやな者を相手にしてムキになるなんて！",
              "citation": {
                "source": "美智子と日曜日の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも名だけえむっつり流の奥の手だ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "右が臭いと思わば左を洗うべし――むっつり右門きわめつきの奥の手だよ」「ちげえねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏表合わすりゃ九十六手、それで足りずばもう一つ右門流というドスのきいた奥の手もそろっているんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこうし眼がつきかけると、じきにむっつり屋の奥の手を出すんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ恐れ入らねえとありゃ、――むっつり右門の奥の手出そうか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いよう、奥の手／＼。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ人間と論理の関係の奥の手を解決した叫びと思う。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴方の奥の手ですよ、　でもあんまりいいこっちゃあありませんねえ。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ことばの判らない時の用意にもと絶えず貯蔵してある奥の手を出して、例のにやにやをやってみたが、先方には一から反響しないどころか、しまいには自分でいらいらして来て何やら耳のそばで我鳴り立てる始末。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで幾許もなく寄席仕込みの都々逸、端唄、鏡板に響いて平生よりは存外に聞きよいのを得意にして、いよいよ唸りも高くなると、番頭漸く倦ざりして熱い奴を少しばかり、湯の口にいた二、三人が一時に声を納めて言いあわしたように流し場へ飛出すと、また入れ代って二、三人、これに対しても番頭の奥の手はきまったものだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、支倉」　根岸は奥の手を出した。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人がいちゃ、素直にここへ来て、仲よく食べて、戻って、寝て、それから、ちくりちくりと、妬くのが奥の手だて。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほら、博士の奥の手が始まった。",
              "citation": {
                "source": "見えざる敵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は要らぬから自分も一緒に引き取って呉れと言って二人してその家に入り込み、知事が江西あたりに赴任する時もついて行ってそろそろ奥の手を出し、金品をかくし始めた。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨て伊之助でございますが、お若さんが連れて逃げてくれろと申しましたを、義理だてをして捗々しく相談に乗らないところから、男を諾といわする奥の手をだし、自害の覚悟を示したのでありますから、伊之助も最う是非がございません。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのアゲクが柳眉を逆立てられることになったら、そこは又そこで、窮余の奥の手にすがるのである。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、着弾百パーセントという特選爆弾を一発、軽巡奴に御馳走して、マスト飛び、大砲折れサ、ヤンキーが血を見て、いよいよ腰をぬかしている隙に、長駆、大航空母艦の上に、五百キロ爆弾のウンコを落とす」「うわーッ、千手の奥の手が始まった。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
