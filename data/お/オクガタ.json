        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御覧ぜよ、奥方の御目には我れを憎しみ、殿をば嘲りの色の浮かび給ひしを」　女子は太息に胸の雲を消して、月もる窓を引たつれば、音に目さめて泣出る稚児を、「あはれ可愛し、いかなる夢をか見つる。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにはみんなも驚いて、さすがは高山の奥方だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その※ 繪は武家の奥方らしい女が座敷に坐つてゐると、その縁先に腰元風の若い女がしよんぼりと俯向いてゐるのであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "草雙紙は、かの薄墨草紙で、酷い主人の手討に逢つて、杜若の咲く古池に沈められたお文といふ腰元の魂が、奥方のまへに形をあらはしてその恨みを訴へるといふところで、その幽靈がもの凄く描いてあつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その挿繪は武家の奥方らしい女が座敷に坐つてゐると、その縁先に腰元風の若い女がしよんぼりと俯向いてゐるのであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の殿様は江戸から北の方にある領地へ帰っているが、奥方は無論に江戸屋敷に残されていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方には最愛の姫様があって、容貌も気質もすぐれて美しいお方であったが、その美しい姫様は明けて十七という今年の春、疱瘡神に呪われて菩提所の石の下へ送られてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの嘆きに取りつめて母の奥方は物狂おしくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "その痛ましさと浅ましさを見るに堪えかねて、用人と老女が相談の末に、姫様によく肖た娘をどこからか借りて来て、姫様に仕立ててお目にかけたらば、奥方のお気も少しは鎮まろうかということになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "物狂おしい奥方は、替え玉のお蝶を夜も昼もときどき覗きに来て、死んだ姫の魂が再びこの世に呼び戻されたものと思っているらしく、それからは忘れたようにおとなしくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の人質となって多年江戸に住んでいることを余儀なくされた諸大名の奥方や子息たちは、われ先にと逃げるように国許へ引きあげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論この屋敷でも奥方を領地へ送ることになったが、乱心同様の奥方が道中に狂い出したらばどうするか、国許へ帰っても今のありさまであったらばどうするか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治になって間もなく、その奥方も亡くなったもんですから、お蝶は初めてお暇が出て、その屋敷から立派に支度をして貰って、相当の家へ嫁いだという噂ですが、多分まだ生きているでしょう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「早速貴殿の奥方様にお目に掛りましょう」　敬四郎が驚いて、　「いいや」Ｔ「身共の家内は身共が調べる」　右門が、　「では」Ｔ「拙者もお立合致します」　と言われては敬四郎も、　「勝手にさッしゃい」という他なし。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、奥方様、あなた様にお客にござりまして。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "またお座敷には、奥方様の他に誰方もおいでがないと、目を丸くして申しますので、何を寝惚けおるぞ、汝が薄眠い顔をしておるで、お遊びなされたであろ、なぞと叱言を申しましたが、女いいまするには、なかなか、洒落を遊ばす御様子ではないと、真顔でござりますについて、ええ、何より証拠、土間を見ましてございます。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はい、何、もうお見上げ申しましたばかりでも、奥方様、お身のまわりへは、寒い風だとて寄ることではござりませぬが、御帰宅の後はおこころにかけられて、さきざきお尋ね遊ばしてお上げなされまし、これはその立花様とおっしゃる方が、親御、御兄弟より貴女様を便りに遊ばしていらっしゃるに相違ござりませぬ。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者と一概に口では云い条、貴女は、それこそれっきとした奥方様も同じ事。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……またある武士が、夜半に前へ立つ、怪い女を、抜打ちに斬りつけると、それが自分の奥方の、夢から抜出した魂だったりしたんですって……可厭な処……　――河童は今でも居ますとさ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、滅相な……奥方様、唯今ではござりません。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君も……何、奥方も……晃　泣く奴があるか、涙を拭いて、整然として、御挨拶しな。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥方の人を離れた美しさを見るにつけても、天がこの村のために、お百合さんを造り置いて、鐘楼守を、ここに据えられたものかも知れん。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円　奥方、お立ちなさるな。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学円　それだと、奥方に済まんぞ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　すると、おくがたの知りあいや、お友だちは、お使を待つまも、もどかしがって、われさきにあつまって来ました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくがたは、夫のほうをふりむいて、今にもたえ入りそうな目つきで、ほんのしばらく、身づくろいするあいだ、待ってくださいと、たのみました。",
              "citation": {
                "source": "青ひげ",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺書を取上げると、遺書の下、疊の上には血飛沫があり、遺書は粗末な半紙に、提灯屋風に、タドタドしい筆蹟でなすつたもので、その文面は、おくがたはじめ、三人もころしたのは、みんなおれのしわざだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            },
            {
              "text": "長政公は二十五六さいのおとしでござりましたろうか、もうそのときは二度めの奥方をおむかえになっていらっしゃいましたが、そのおくがたと申されますのが、もったいなくも信長公のおん妹君、お市どのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不縁におなりなされました前のおくがたは、ものゝ半年と御一緒におくらしはなかったそうで、そのおかたのことは存じませぬが、お市｜御料人はまだお輿入れにならぬうちから世にも稀なる美人のきこえの高かったお方でござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくがたはちょうどそのとしの五月に若君をおうみなされ、さんごのおつかれで一と月あまりひきこもっていらっしゃいましたので、わたくしがしゞゅうごかいほう申し上げ、お肩やお腰をさすりましたり、せけんばなしのお相手をつとめましたりいたしまして、おなぐさめ申しておりました。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
