[
  {
    "uuid": "51b881ed-edd2-5205-a3e6-57805237588b",
    "entry": "奢る",
    "reading": {
      "primary": "おごる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to treat (someone) to (something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "都合のよい御返事を申上げて貰うたなら一杯奢るが……」「成る程なあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の中を草鞋穿いて、蓑着て揖譲するなんざ、惚気て鍋焼を奢るより、資本のかからぬ演劇だもの。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　島野は苦々しい顔色で、「奢ります、いずれ奢るから、まあ、君、君だって、分ってましょう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、帰途、工場に冬村君を訪ね、それから学校に樹明君を訪ねる、樹明君が奢るといふので、酒と豆腐とを買うて戻つた、重かつたが苦にはならなかつた。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "また何だ、その内に一杯｜奢るから。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長歎して別に五百を奢る。",
              "citation": {
                "source": "草あやめ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、奢るべし、今夜の会には非常なる寄附をしろ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは君にこのようにお叩頭をしてから、何でも奢るよ」　次の夜が来たときわたしは秋雄を避けてさめ／″＼と一晩中泣いた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹たちはもう一等当選にきめて奢る約束までするのです。",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はいつもと違って、大いに奢るというので、盲汁ということをするのだそうだ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花がそんな所へ連れ出して奢る筈がない。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後にはまた、成上がり者ながら権勢に奢る腰本治右衛門がいるのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んの其奴が奢るものですか、私の家の食物を、私の家の食卓で、私達と一緒に食べようというので、とても下等の食べ方でした。",
              "citation": {
                "source": "奥さんの家出",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハハハ、こりゃ眼鏡を一つ奢るかな」　終には旦那様も釣込れて、「拝借」と手を御出しなさいました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、樹明君が酒と肴とを奢ることになつて用意してゐると、敬君がまた酒と肴とを持つて来た、三人楽しく飲み且つ語る、過去の物語が賑つた、十時近くなつて快く散会、近来うれしい会合だつた、ぐつすり前後不覚の睡眠がめぐまれた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど奢るは益なし、洋服にてだにあらば、帆木綿にてもよからん。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "種が内職の稼ぎ高のいくらかを別にしておいて、それでこっそり内儀さんの好きな豆餅を奢ることもある。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢ふまでもなく、電話で呼出して奢ることもある。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奢る事をいっそういましめて、もっと壮大な気持ちになろうではないか。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の妻たる者が能く家を保ち万事倹にして費を作す可らず、衣服飲食なども身の分限に随て奢ること勿れと言う。",
              "citation": {
                "source": "女大学評論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔境「蕨の切り株」　そこは、人間の運がいろいろに廻転し、おい、奢るぞ――と勢いよく出てくるのもあれば、曲ってる！",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔境「｜蕨の切り株」　そこは、人間の運がいろいろに廻転し、｜おい、奢るぞ――と勢いよく出てくるのもあれば、｜曲ってる！",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は僕が奢るから。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんとさ、奢るよ。",
              "citation": {
                "source": "静物",
                "author": "十一谷義三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は奢るぞ」柏は楽器を寝台の上へ投出して勢よくいった。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや山嵐の癖にどこ迄も奢る気だな。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「安さんが例の發明や、金儲けの話をするとき、其聞き賃に奢るのかも知れない」と云つて宗助は笑つてゐた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンパンおごる私は得意だ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "二「おごるって、お金あるのか」　鶴雄が言うと、鈴子は、「あてかテ、お小づかい貰うのンどっせ」　と、唇をとがらせた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなに蜜豆をおごるくらいの金はあるよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
