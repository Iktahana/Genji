        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまも、ひとりでオレンジジュースを飲みながら、テラスをめぐる手すりをかかえこみ、幼児期の細部をひとつひとつ思いだそうとしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の折り畳みテーブルには、オレンジジュースの入ったコップがふたつおかれている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉の大和煮、コンビーフ、ウィンナソーセージ、オイルサーディン、シャケの水煮、桃やミカンやパイナプルといった果物類、オレンジジュース、コカコーラ、そういった缶詰がほとんどだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さなちゃぶ台には、コーラやオレンジジュースの缶、ポテトチップスやポップコーンの袋がのっていて、あちこちから頻繁に手が伸ばされている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれ、もう、イヤんなった」　といって、慶一がオレンジジュースの缶を高志にさしだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていると、客はたいていハンバーグとケーキ、それにオレンジジュース、このくらいのものを注文して、またたくうちに食べてしまうと、さっさとまた雑踏の中へ紛れ込んで行きます。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、小児にオレンジジュースと未殺菌牛乳、または未殺菌牛乳だけを与えても治癒することが判った（53）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺菌ミルクを与え続けてもジャガイモ粥またはオレンジジュースを追加するとこの症状は治癒するのでこの考えは支持されなかった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
