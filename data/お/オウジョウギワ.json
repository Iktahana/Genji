        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "實にあなたたちは、往生際が惡い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一｜疋、女の胸中の恋人に幻影化され偶像にされ、病死の往生際の念仏代りになる。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ、まだびくびくするか、往生際の見苦しい奴だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にあなたたちは、往生際が悪い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、愛想の尽きた蛆虫め、往生際の悪い丁稚だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "往生際の悪いことで」　義晴が、カウンターに身を乗りだして、ふたりをのぞきこんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「すると、僕の方はまだ別の美人に希望を持っていいのかな」と、ドレゴは往生際が悪かった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴左衞　その往生際がよくないな。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂を嘗めさせられた蛇のように往生際が悪いと、もうお慈悲をかけちゃあいられねえ。",
              "citation": {
                "source": "半七雑感",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往生際の悪い西洋人だから、地獄振りの限りを尽したといった方が正直でもあり、自然である。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "往生際の悪い奴だ」「いつまでも強情を張ると痛い目を見せるぞ」　渡辺は呶鳴った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「往生際の悪い奴だ。",
              "citation": {
                "source": "牛",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから本国に下って市に出て染物などのようなものを売買して家計をたてつつ独り身で自由に生活していたが、往生際がとても美事で、念仏の声が止まったかと思うと本尊に向って端座合掌したその顔は笑めるが如く、そのままで往生していたので、諸人が雲の如く集ってその奇特に驚きあったとのことである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッサリ遭難しちゃア、つまらない話だな」「往生際はわるいらしいがね」　青木は帽子をつかんで立ち上った。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "往生際がわるいんだから。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "茲から四、五町の間は川沿いの細かい砂地を行くので、伸び放題に蔓を伸して絡み合い縺れ合いながら、太い綱を張り渡した木通や海老蔓や野萄葡などが、鋭い鎌の刃先に懸けられて、気持よく左右に薙ぎ倒されている、中にも往生際の悪い奴は、玉紫陽花などに巻き添いを喰したのもあった。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる往生際の悪い奴だ、と僕は思はず舌うちしたね。",
              "citation": {
                "source": "三つの挿話",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　往生際の綺麗さを賞めてやってもよかった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が彼の意見に渋々ながら従つてくれたことを、心の中で感謝しないではいられなかつたが、一面、近来ますます物質への執着が高じている父の、往生際のわるさにも、やゝ肌寒い思いをさせられた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは、めずらしくその日、荒い縞の、いかにも女形らしいお召の着附に、意気な、幅のやゝ狭い紺献上の帯をかれはしめていた……「往生際のわるい。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は往生際の好いのに感心して聊か物の哀れを催したが、矢っ張り此方は若いってことが後から分った。",
              "citation": {
                "source": "首切り問答",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文太郎　（政吉を押えつけ）これ、往生際が汚ねえぞ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒でも、何かしておかないと、往生際に人に嗤われるよりも、何だか、一生涯を煙にしちまったような気がするものだ」「そうかなあ」「一つ、天下を取ってみようとか、世間の貧乏人を救ってみようとか。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と云うものは往生際が肝腎ですわ。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君の想像に委せる」「何とか言って、否定しても駄目だよ」「別に否定はしない」「案外｜往生際が好かったね」「仕方がないさ」「ところで、君」「何だい？",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "条件つきの後悔　汽車の動き出すのを待っていたように、寛一君は、「君、往生際が好かったね」　と冗談に託して感想を洩らした。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「案外往生際が綺麗だったってことさ」「何を言やがるんでい」　と新太郎君は見かけほどに悄げていなかった。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往生際が好いどころじゃない。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿村、往生際の悪いやつだな。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
