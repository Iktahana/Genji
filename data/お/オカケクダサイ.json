              }
            },
            {
              "text": "まあまあモウ一度ここへお掛け下さい。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあどうか、お掛け下さい。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（まず、お掛け下さい。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どうぞ、お掛け下さい」　名刺の効果はてきめんだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ正午までに宅に届けて呉れるやうに電話をお掛け下さいな。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、御随意にお掛け下さい――。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうか、こちらの安楽椅子にお掛け下さい。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、お掛け下さいまし」　彼は愛想よく云った。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくお掛け下さい」法水がちょっと躊躇ぎを見せたのは、彼女の命令的な語調ではなかった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、そこへお掛け下さい。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ではお掛け下さいませんか。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大庭　　ぢや、まあ、そこいらへお掛け下さい。",
              "citation": {
                "source": "五月晴れ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "［zehn は單に數多きことを云ふ］10．するとこの家の主人が自から入り來つて、私に握手をし、私を親愛なる同僚と呼んでから、お掛け下さいと云つた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まアお掛け下さい。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "女事務員　　あの、そちらへお掛け下さいまし。",
              "citation": {
                "source": "感化院の太鼓（二場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうぞお掛け下さい」とラエーフスキイは言って、ぎごちない手つきで客に椅子をすすめた。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、どうぞお掛け下さい。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月の暮しも不自由な思ひはいたしませんからお心にお掛け下さいますな……。",
              "citation": {
                "source": "母と子",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バアロウさん、どうかお掛け下さい。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、危険を冒して入って来た位だから、並々ならぬ用事があるに違いないと思ったので、洋子は椅子の一つを指差して、「どうぞ、お掛け下さい」と云ってから、改めて、「一体、あなたはどなたなんですか？",
              "citation": {
                "source": "深夜の客",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「舟は私が漕ぎます、――恐れ入りますが、火の粉が飛んで来て、とまへ火が付きそうになりましたら、その水垢くみの長｜柄杓で、水をお掛け下さいませ」　女は何んの躊躇もなく艪に寄ると、至って器用に漕ぎ始めながら、蟠りのない調子で、――こう忠弘に用事をいいつけるのでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "乞食志願",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると天和堂のお内儀さんはかねて知合いと見えて、さっそく椅子を指してどうかお掛け下さいと言って請じたです。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると「あなたは日本人ですか」といって私に椅子を与えて、お掛け下さいといって先生も腰を掛けてジーッと私の顔を眺めて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあ、お掛け下さい。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どうぞお掛け下さいませんか。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、どうぞお掛け下さいまし。",
              "citation": {
                "source": "笑",
                "author": "アルチバシェッフ・ミハイル・ペトローヴィチ　Artsybashev Mikhail Petrovich",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどちらで獲れました鮎でございましょうか」「これは長良川で、………」と、沢崎はだんだん機嫌を直して、「昨夜電話で頼んで置きまして、先刻岐阜の駅で汽車まで届けさせたのでございます」「それはまあ、お手数をお掛け下さいまして、………」「お蔭で初物が戴けますわ」と、未亡人の尾について幸子が云った。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、お掛け下さい。",
              "citation": {
                "source": "秀才養子鑑",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何分宜しくお願い申上げます」「お掛け下さい」「失礼致します」「早速ですが、専務のお指図に従って、真の形式的に考査を致します」「はあ」「有りのまま御腹蔵のないところをお答え下さい」　と委員長は手帖と鉛筆を手にして、堀尾君をジロ／＼見据えた。",
              "citation": {
                "source": "負けない男",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
