          ],
          "literary": [
            {
              "text": "王女御は身にしむ秋というものを理解したふうにお返辞をされたことすらお悔やみになった。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "志貴子さん、お亡くなりになったんですってねえって、久能徳のうしろにくっついて、まっさきにお悔やみに行ったのはあたしなんだから、罪が深いわ。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "お悔やみかた／″＼手伝いに来たのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなってしまえば、いきおい工事もはかばかしくなくなってしまうでしょうし、その時になってお悔やみになられることとなるのを恐れます。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は面を冠ってお悔やみかたがた手伝いにでも来ているに違いない。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃね、僕はこれから下へ行って姉さんにお悔やみを云って来るから、もう君は何も考えないことにしたまえ」　そして彼は、嘗つては無様に辷り落ちたあの梯子段を、意気｜揚々と下って行くのであった。",
              "citation": {
                "source": "灰神楽",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そして、自分が左中将の切ない恋を察して取りもったことも、また、せっかくな主上のおぼしめしも、これでは逆になった、仇になったわえ……と、しきりなお悔やみ。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞこんな事になりましたのを、おくやみなさらないで下さいまし。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくやみを述べるのにも、何かいそいそとしていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜さり呼びつけて、えらい済まなんだけど、話言うのはな、実はおまはんのその孫のことやがな……」　型通りのおくやみを述べたあと、笹原はそう切りだした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくやみを述べるのにも、なにかいそいそとしていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――君枝ももちろん一しょに行くやろ」　蝶子はおくやみが済むと、居合わした人へ遠慮しながら、「ちょっと……」　と、言って、君枝に眼交した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくやみに来て、亭主ののろけを言うのがいかにも蝶子らしいと、今日一日笑う力を失っていた君枝ははじめて微笑した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、近くの大西質店の主人が大きな風呂敷を持ってやってき、おくやみを述べたあと、「じつは先達てお君はんの嫁入りの時、支度の費用やいうて、金助はんにお金を御融通しましてん。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大へん気の毒に思ったものですから、すぐおくやみに行きました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、近所の質屋の主人が大きな風呂敷包をもってやって来、おくやみを述べたあと、「実は先達お君はんの嫁入りのときでしてん。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私改めておくやみを申し上げます」　私はやつとこれだけを云つたけれども、なんと云つてひろ子を慰めてやつていいか全く途方にくれてしまつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱月氏のおくやみにいったのも、月はかわれど今夜とおなじ時刻だと思いながら、偶然におなじ紋附きの羽織を着て来たことなどを気にして芸術倶楽部の門を這入った。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私はおくやみにも、墓参にも行きはしない。",
              "citation": {
                "source": "二十七歳",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭抜けて美しい高貴な娘は、翌日友禅の着物をきて、ダリヤだの何かの花束をもち、改めておくやみに現れてきた。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくやみの時でも笑っているそうだけれども、してみると私なんかが日本人の典型ということになるのか、私は人に話しかけられると大概笑うのである。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は勿論、葬式にも、おくやみにも、墓参にも、行かなかつた。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の以前関係していた会社の人が多勢来て、型通りのおくやみを流暢にのべてくれました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は勿論、葬式にも、おくやみにも、墓参にも、行かなかった。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私おくやみに行かないわ」と由子は木村重吉に言つた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私悲しさうな顔をして、おくやみ言つたり、焼香することほんとに好きだわ」「うちの編輯長も同じやうなことを言つてましたよ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうして時間どのをむだ死にさせて以後、」とおくやみとばかりのぼうし屋、「たのみごとを聞いてくれんようになった！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "捜索　そのあくる朝バルブレンのおっかあの所へ手紙を出して、不幸のおくやみを言って、かの女の夫の亡くなるまえに、なにか便りがあったかたずねてやった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと一所におくやみ申しあげておきました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "別におくやみ申しませんから、よろしく申しあげておいて下さい。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
