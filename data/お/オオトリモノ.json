          ],
          "literary": [
            {
              "text": "大捕り物　いずれ悪漢に相違あるまい、イスラエルお町と早引忠三。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、こいつは大捕り物だ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶安以来の大捕り物「背に幾多の宝玉ありや？",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明智探偵助手　　小林｜芳雄大捕り物　まんまと賊をあざむき、首領をびっくりさせるような手紙までのこして、地下室をぬけだした小林少年は、何よりもまず、その地下室の上には、どんな建物が建っているのか、また、そこはなんという町なのかということを、たしかめなければなりませんでした。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはしごを、帽子のあごひもをかけ、靴をぬいで靴下ばかりになった警官が、つぎからつぎへとよじのぼり、懐中電燈をふり照らしながら、屋根の上の大捕り物がはじまりました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "世にも奇怪な鍾乳洞の大捕り物でした。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
