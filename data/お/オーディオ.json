          "standard": [],
          "literary": [
            {
              "text": "一九八一（昭和五十六）年に関西大学の工学部建築学科に入学し、先輩たちとオーディオミュージック同好会を作りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし電灯産業の誕生期、その延長上に家電産業の勃興と軌を一にした電力産業のダイナミックな展開を見ることや、怪しげな銀座ルネッサンス商会の延長上にソニーのオーディオ・ビジュアル全面展開を予想することは、どんな誇大妄想狂にも不可能だったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどオーディオ・ビジュアルという名の戦場のＶＴＲ戦線で激しい闘いを続けているうちに、両社は共に、急成長した裾野のコンピューター市場を取り逃がした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし参加者の脳味噌にはじめからアルコールをぶち込んでハイな雰囲気を盛り上げ、イベントを回していこうという仕立は、パーソナルコンピューターではもちろん、かつて数年間にわたって総なめにした経験のある栄華を極めた時代のオーディオ業界の発表会でも、まったく経験したことがない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "また電子炊飯機とエアコン、オーディオ機器の使い方が、我慢強い人は当然というかも知れないが、ばらばらであるのも情けない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志は、ビートルズのレコードを貸してくれた、例の生田という若い教師を抱きこんで、放送部とはべつに、「オーディオ部」というクラブをつくるのだそうだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつとは話をつけた」　放送部は校舎のみ、寮は「オーディオ部」の縄張りということにしたという。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしがっても遅いのよ」「それで、オーディオ部は、寮で、なにするわけ？",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからさ、オーディオ部なら、おれとおまえとこいつの三人だけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに高志とワラは、平日に外出許可をとって秋葉原へでかけ、テープやオーディオ・アクセサリーを買いこんできたし、施設課に交渉して、あっというまにオーディオ・ラックと、レコード棚をつくってもらったりした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "掲示板でお知らせしたとおり、本日から、われわれオーディオ部が、起床放送を担当します。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、オーディオ部はどんな調子だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーディオ部は、これからも活撥に活動してほしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは四〇七で、オーディオ部の部室。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにオーディオ部の部室ができて以来、なかにいるより、ヴェランダに出ているほうが多いくらいで、口にだしてはいわないが、全員がここの景色を気に入っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーディオ部が、すでにこのフロアから四階に引っ越していたことも、慶一の判断を左右した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは五年ほど前、私はあるオーディオ誌の編集を行っていたのだが、内外のブランド約四〇を総まとめに紹介する記事の中でも、ＮＥＣのオーディオブランド「ジャンゴ」は取り上げなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＴＫ―80から引っ張ってきた信号線をコンデンサーを一つはさんでオーディオアンプにつなぐ方法を、電子オルガンとして動かすためのプログラムとともにマニュアルに記載し、コンピューター音楽の畑を掘り起こす作業に努めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時点では、八Ｋバイト版の単体価格は五〇〇ドルで、本体、八Ｋバイトの増設メモリー、シリアルＩ／ＯもしくはオーディオカセットＩ／Ｏとのセット価格は七五ドル。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本体、一二Ｋバイトの増設メモリー、シリアルＩ／ＯもしくはオーディオカセットＩ／Ｏとのセット価格は一五〇ドルと設定されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七九（昭和五十四）年秋に京都セラミツクの傘下に入ったサイバネット工業は、すでに着手していたオーディオ機器への進出を進めるとともに、富士ゼロックス向けの普通紙複写機のＯＥＭ生産にも手を染め、しだいに業績を回復していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線通信機やオーディオ機器作りに明け暮れて受験勉強には熱を入れなかったが、群馬県一の受験校とされる前橋高校を受けると合格となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳中のおともは、Naxos Audiobooks のオーディオドラマ朗読ＣＤ（２００６年新録版）でした。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャデラックが空港の構内を出てから、僕は車のオーディオ装置のスイッチを入れた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "手づくりした低い台のうえに、簡単なオーディオ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦そろってオーディオが趣味だとかで、防音の部屋がひとつあった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
