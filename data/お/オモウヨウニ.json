[
  {
    "uuid": "26c6a8c7-009c-5ce5-be7c-9a58729fa1cc",
    "entry": "思うように",
    "reading": {
      "primary": "おもうように",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
