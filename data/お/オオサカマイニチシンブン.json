              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "（昭和九年二月『大阪毎日新聞』）",
              "citation": {
                "source": "ある探偵事件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大阪毎日新聞』で見しに、床次内務次官は神社を宗教外の物と断言し、さて神社崇敬云々と言いおる由。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "附記　　　本文は大正十四年六月三十日と七月一日の大阪毎日新聞に掲載のまゝで、其の引用書目と※註は七月十一、十二日に書き加へたものに本年八月又増補した者である。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一八年四月、大阪毎日新聞に一部所載）",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介氏の事　今は亡き芥川龍之介氏が、大阪毎日新聞に入社したのは、たしか大正八年の二月末だったと思う。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで予は遺憾ながら、当局並びに同僚たる文武教官各位の愛顧に反いて、とうとう大阪毎日新聞へ入社する事になった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "川島忠之助は正金銀行の支配人として活躍したし、東海散士、柴四朗は農商務次官、代議士、大阪毎日新聞初代社長、外務参事官、閔妃事件で下獄したこともある。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪毎日新聞による、黒龍江畔風雲急らしい、どうぞ戦争にならないやうにと人民のために祈る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "露英という号をもって露伴に師事していた田村俊子は、やがて露伴の文学的垣をやぶって一九〇九年大阪毎日新聞の懸賞に「あきらめ」という長篇で当選した。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "□大阪毎日新聞へ「雑音」として今書いてゐますのは私としては非常に自分でもいやでたまらないものです。",
              "citation": {
                "source": "編輯室より（一九一六年二月号）",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪毎日新聞を購読して、記事の進陟を待つてゐるうち、病気が重体に陥つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "発行所大阪毎日新聞社。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ、大阪毎日新聞社、――やはり御専門は政治経済ですか？",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで予は遺憾ながら、当局並びに同僚たる文武教官各位の愛顧に反いて、とうとう大阪毎日新聞へ入社する事になつた。",
              "citation": {
                "source": "入社の辞",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一五年十二月）（『大阪毎日新聞』一九一六年一月一日）",
              "citation": {
                "source": "婦人改造と高等教育",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九一七年四月）（『大阪毎日新聞』一九一七年二月二七日―三月四日）",
              "citation": {
                "source": "選挙に対する婦人の希望",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「大阪毎日新聞」昭和五月）　　　新秋雑想　立秋という日が過ぎて、どれだけ私のパレットの色数に変化を来したか、それはまだはっきりとは現れない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「大阪毎日新聞」昭和九年十二月）",
              "citation": {
                "source": "傘",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正九年三月四―八日『大阪毎日新聞』所載）",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年八月三―五・七日『大阪毎日新聞』所載）",
              "citation": {
                "source": "支那の宦官",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大阪毎日新聞社の命を受け、大正十年三月下旬から同年七月上旬に至る一百二十余日の間に上海、南京、九江、漢口、長沙、洛陽、北京、大同、天津等を遍歴した。",
              "citation": {
                "source": "「支那游記」自序",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪朝日新聞と大阪毎日新聞の記者である。",
              "citation": {
                "source": "貝殼追放",
                "author": "新聞記者を憎むの記",
                "note": "青空文庫"
              }
            },
            {
              "text": "三宮驛から、夕暮汽車に乘る時に、何氣なく大阪毎日新聞の夕刊を買つた。",
              "citation": {
                "source": "貝殼追放",
                "author": "新聞記者を憎むの記",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は此の如き達筆な記者を有する大阪毎日新聞の商賣繁盛を疑はない。",
              "citation": {
                "source": "貝殼追放",
                "author": "新聞記者を憎むの記",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都で梶原氏に別れると直ぐに手帖を取出して、先づ大阪毎日新聞に宛て、夕刊記載の記事の捏造である事、その記事を取消すべき事、その捏造を敢てしたる記者を罰すべき事を書送るつもりで草案を書き始めた。",
              "citation": {
                "source": "貝殼追放",
                "author": "新聞記者を憎むの記",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十四日にはじめて大阪毎日新聞九月三日の号外を手に入れ皆頭を集めて読んだ、『東京全市焦土と化す』といふ大きな見出しがあり、碓氷峠から東京の空が赤く焦げてゐるのが見えるとも書いてある。",
              "citation": {
                "source": "日本大地震",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　自分の長崎時代の歌、即ち大体大正七年八年九年の歌は、アララギ、大阪毎日新聞、大阪朝日新聞、長崎日日新聞、雑誌紅毛船、雑誌アコウ等にたまたま載つたもの以外は、未定稿のものをも交へて手帳に控へ、一部は歌稿として整理してあつたものが、大正十三年の火難に際して焼失してしまつた。",
              "citation": {
                "source": "つゆじも",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大阪毎日新聞附録、昭和三年十一月十三日）",
              "citation": {
                "source": "賢所御神樂の儀",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大阪毎日新聞附録、昭和二年七月二十八日）",
              "citation": {
                "source": "聚樂廻り",
                "author": "羽田亨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
