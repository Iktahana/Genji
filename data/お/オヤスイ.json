        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今朝の新聞では日本向カワセ相場は九六｜両四分の三、千の寝床を得るのはお安いとこが経済ってものだわ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、乳母｜車なんてお安い御用さ。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕はまだこんなりっぱなかたからまのあたりお声をかけられた事がないのでほくほく喜びながら、「それはお安い御用です。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言い懸けて莞爾と笑い、「お安いものよ、ねえ貴下。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お安い御用です、いつでも。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし、たのまれたので、町へ出たついでにここへ来て、あんたを待っていたのよ」「そうですか、そりゃどうも……」「いいえ、お安いご用よ」　宮子は早口に言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あればお安いことなんですが、うちに一羽残っていた奴を今さきつぶしてしまった所なんですよ。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "結構な水の出る古井戸や、深い杉木立や、凝ったお庭｜造の遺跡が、山から参いります石筧の水と一所に附いておりますから御別荘に遊ばすなら手入らずなんで……」「高価いだろう」「それが滅法お安いんで……。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お安いことだが、今日は生憎くお赤飯だといふ。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "源次　おお安いことじゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お高価いようでお安いもの……」「エエ、これが畳針でございます。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「下駄を一つ貸していただきたいんですが……、弥勒から雨に降られてへいこうしてしまいました」「お安いご用ですとも」　かみさんは足駄を出してくれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは譲ってもらいましょう」「それはお安いことです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "猫と鼠のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "こほろぎ　お安い御用だ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「なおさら結構……話して下さい」「お安い御用です……が、困りましたな。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "金春の主人は金でも貸せといふのかと思ふと、香の話なので、「いや、お安い御用で……」と、その場で件の香を小指の先ほど割つて呉れた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴方がそれ迄に懺悔なさいますには、何か理由がお有りでせう、聞かせて戴けないこと……」「お安い御用です。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「え、ようござんすとも、お安い御用です。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「湖を渡って向こう岸へ」「それじゃ俺も行かずばなるまい」「船にお乗りなさりませ」「おおその船へ乗せてくれるか」「お安いご用でございます」　ギーと船が寄って来る。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大工もこれには少し驚きましたが、なにその時はその時でどうにかなるだろうと思って、「よし、よし、お安い御用だ。",
              "citation": {
                "source": "鬼六",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、そりゃあもう、お安い御用でございますとも！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お安い御用だというので見せてやると、読んでいる中に綿貫警部補の顔が真青になって来た。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大男の雷様はポケツトに手を入れて、「お安いことだ。",
              "citation": {
                "source": "虹猫の話",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えゝゝお安い御用です、さあどうぞお持ちなさい。",
              "citation": {
                "source": "竜宮の犬",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ其事情を聞き度いものだ」「お安いご用でござります。",
              "citation": {
                "source": "稚子法師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お値段のお安い話ばかり致しますようでございますが、下駄の鼻緒なども昔は二足で三文でございました、それからこちらへ厄雑のものを二足三文と申す事だそうです。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下統一といふ事業のためなら、家康に頭を下げて頼むぐらゐ、お安いことだと考へてゐる。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長は、お安い御用といいながら、ポケットを探ったが、どうしたものか先刻預って確かにポケットに入れたはずの封筒が、何処へ落としたか見当らないのであった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へい、おやすいことです。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『たいへんおやすい御用です、着物は十枚もいりませうか』　と悪魔がたずねました、『まあ、なんてケチなんでせう、いくら着ても、着ても、着れないほど、たくさんの着物がほしいんですよ』　といひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
