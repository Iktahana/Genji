        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "放送演説の名人といわれていた故永田青嵐ですら、いつ聴いても「私は砕けて喋っていますよ」といった同じ調子が見え透いてうんざりさせられるし、この人を真似た某大官の演説は、砕けすぎて気を許したのか、お国言葉の東北弁まるだしだ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "気心が解って来ると、細君は茶の室へあがって来て、お国言葉丸出しで自分の身のうえを明け透け話した。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも私にはこの人のいってるお国言葉がちっとも分らない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "谷中時代の弟子のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室のお客さん三人は私の同郷人だ、純粋なお国言葉をつかうてゐる、彼等と話しあつてゐると、何だか血縁のものに接してゐるやうな気がする（私としては今のところ、身上をあかしたくないから、同郷人であることが暴露しないやうに警戒しなければならない）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国言葉のせいか、やさしい、ほんとうにやさしい。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お国言葉まるだしで、太いお声。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "前掲お国言葉の実例の中に出て来る「つかアさい」について、古典学究の理窟を一こと述べさせていただかう。",
              "citation": {
                "source": "忘られぬお国言葉",
                "author": "池田亀鑑",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい忘れて）お国言葉で談論風発です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
