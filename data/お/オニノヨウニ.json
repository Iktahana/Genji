        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私どもはははあ、あの男はやっぱりどこか足りないな、だから子供らが鬼のようにこわがっているのだと思って遠くから笑って見ていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の心は悪鬼のように憂鬱に渇いている。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらなんにも知らないおせいにも、自分のような貧乏な、無学な、知り合いもないような人間を正妻に迎えるわけがないのは分りきっているのに、しらじらしい顔つきをして、自分の娘をごまかそうとするらしい父が邪慳の鬼のようにも思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから褞袍に着かえて、チエ子と並んで夕飯のお膳について、何本もお銚子を傾けた父親は、赤鬼のようになりながら大きな声で、今度初めて行った露西亜の話をした。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」声をふるわせて言っている仙之助氏の顔は、冷い青い鬼のように見えた。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鰻を焼く匂いにはげしく誘われて、ままよとはいり、餓鬼のように食べた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギイギイギイ――ッ……」　青鬼のようになった三好の両眼が、酸漿のように真赤になった……と思ううちに鼻の穴と、唇の両端から血がポタポタと滴たり出した。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは南洲が自身で朱筆を入れた珍らしいものじゃったが、その爺が鬼のようになって飛びかかって来る奴を、グッと睨み付けてサッサと持って来た。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鰻を焼く匂いにはげしく誘われて、まゝよとはいり、餓鬼のように食べた勘定を払って出ると、未だ二十七円と少しあった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逃がすものかい」　広巳は悪鬼のようになって追っかけた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして餓鬼のように、死がいのまわりにあつまって、肉をちぎってたべました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳町の女房は――前申したごとくで、これをお夏さんの生命を縮める鬼のように思った。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「箱樋を引いて頂けゃ、水はそれで十分以上でごわすもの、そしたら、肥料もどっさり入れて、田の草取りなんかわらわらと、俺等は鬼のように稼いで、来年こそは、立派な稲にしてお目にかけしてごわす。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛勇の将士が悪鬼のようになる事を考えると解ることである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　荘田は、血の臭を嗅いだ食人鬼のように、満足そうな微笑を浮べながら、肯いた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "強盗に身を落して、利欲のために人を殺しているものの、悪鬼のように相手の骨まではしゃぶらなかったことを考えると、市九郎は悪い気持はしなかった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どんなにお金があっても、都中の人から鬼のように憎まれておる家の婿になっては、どんなひどい目に逢うかも知れぬと思いましたので、一度は断ろうと思いました。",
              "citation": {
                "source": "三人兄弟",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その小さな、謙遜な花から、兜虫のように、鬼のように、いかつい角を生した青黒い顔の菱の実が生れるのだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲に放浪していた頃は、馬賊の群に交って、相応な働をしたと言われるほどあって、筋骨の逞しい、鬼のようにいかつい恰幅をした壮士で、日本に帰って来てからは、そこらの電車に乗るのにいつも切符というものを持たないで、車掌がそれを喧しく言うと、「俺は東馬だ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そのあとはもう、キース・ムーンが悪鬼のように暴れまくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朝事があれば、彼もしくは彼女は畜生のように、又は餓鬼のように昏迷して地面を這いまわる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は鍾馗につかまった小鬼のように吃驚りした。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の底から紅蓮の焔を噴くように、真っ赤な火のかたまりが坑いっぱいになって炎々と高くあがると、その凄まじい火の光りがあかがねの柱に映って、あたりの人びとの眉や鬢を鬼のように赤く染めた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼の鬼のように大きくそうしてかたい手をにがさないようにしっかりつかまえて又あるき出した。",
              "citation": {
                "source": "心配",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船を追って狂奔した昨日の自分までが、餓鬼のようにあさましい気がした。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は以上の言葉をきいて、夫人の執念の恐ろしさに、夫人の顔そのものが、すでに鬼のように見えて来ました。",
              "citation": {
                "source": "印象",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりがかくれんぼのおにのように眼をつむって待っている。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいまつの赤い火に照らされて、西洋悪魔の顔が、赤おにのように恐ろしく見えます。",
              "citation": {
                "source": "魔法人形",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
