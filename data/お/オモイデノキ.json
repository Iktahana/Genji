          ],
          "literary": [
            {
              "text": "彼は今迄讀んだ小説の中の女で『思出の記』に出てゐる敏子といふ女を、一番なつかしく思つてゐる。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時偶母が嫁の話を持ち出すと、甲田は此世の何處かに『思出の記』の敏子のやうな女が居さうに思ふ。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今迄読んだ小説の中の女で、「思出の記」に出てゐる敏子といふ女を一番なつかしく思つてゐる。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時偶母が嫁の話を持出すと、甲田は此世の何処かに「思出の記」の敏子のやうな女がゐさうに思ふ。",
              "citation": {
                "source": "葉書",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三等船客の中に、眼が悪いので欧洲廻りで渡米する一青年があって「思出の記」を持て居た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペナンからコロムボの中間で、余は其思出の記を甲板から印度洋へ抛り込んだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思出の記は一瞬の水煙を立てゝ印度洋の底深く沈んで往ったようであったが、彼小人菊池慎太郎が果して往生したや否は疑問である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の名は「子供世界」と「太陽」と「思出の記」です。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思出の記」というのも、悲しい楽しい本です。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思出の記」の今まで分らなんだ所が、沢山分って来る様に思われました。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
