    "definitions": [
      {
        "index": 1,
        "gloss": "busy (phone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "嘉吉とかを聞くにつけても、よく気が違わずに済んだ事、とお話中に悚気としたよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇を鼓して出掛けた日が、先生は、来客があって、お話中。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話中で、おそれいりますが――」　彼女の声だ。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話中でございますが、司令官閣下、只今、Ｔ三号の受信機に至急呼出信号を感じました。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も申上げようかと思ひあんしたども、お話中に容喙するのも悪いと思つて、黙つてあんしたが、先刻その、号鐘が鳴つて今始業式が始まるといふ時、お出しになりあんしてなす。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も申上げようかと思ひあんしたども、お話中に容喙するのも惡いと思つて、默つてあんしたが、先刻その、號鐘が鳴つて今始業式が始まるといふ時、お出しになりあんしてなす。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸お話中に電話が切れた恰好でござりますが、致方がござりません。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、お話中しつれいですが、じつは二十年じゃなく、あなたが冷凍されてから三十年たっているのですよ。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、お話中ですが、それはまたなぜですね？",
              "citation": {
                "source": "夢がたり",
                "author": "TO, CHEVO NE BYLO",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本とお話中でございます。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話中ですが……」と彼は断った後、大寺警部の前へ白い布に包んだものを出して拡げてみせた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何か、お話中だったんですか。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お話中でありますが」と伝令兵は大きな声で怒鳴った。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまり、僕たちは歩いてばかりいると疲れるから、そこで車がついた乗物に乗って走らせると、疲れもしないし、速いからいいだろうと思うんだが……」「ああ、お話中しつれいでございますが、乗物のことならどうぞご心配なく。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴコク寺で、中外に電話をかけ、事務所にかけようとしたがお話中。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛谷　　お話中ですが、家の中を一寸見せて頂けますまいか。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "袖付や袵の皺が苔でも置いたようなしっとりした青味の谷をつくって、いうにいえないいい味わい……帯はね、蝦夷錦の金銀を抜いて、ブツブツの荒地にしたあとへ、モガルの色糸で、一重蔓小牡丹の紋をいたずらでもしたようにチラホラ散らしたという……お話中……わからないひとねえ、お話中だと言ってるじゃありませんか。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "片倉　　ちよつと、お話中ですが、今の鶏のことでございますがね。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はこの方の名を人に語ったことはついぞ一度だってなかったのに」　と、婦人は顔の色を変えたが、新十郎は彼女のおどろきがたちまち鎮まらざるを得ないような無邪気な様を示して、「いえ、ただ今のお話中ににわかに思いついたのです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お話中だが、イーヌィチ」と私は言った、「ライ麦二十俵は僕のところで盗られたのだ。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "トレープレフ　お話中ですが、ニーナさんはどこでしょう？",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために「お話中」が増え、それがまた人心をいらだたせ、益々電話を繁忙にする。",
              "citation": {
                "source": "硝子を破る者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛取りには昼頃行ったのだが、いま奥さんはお客さんとお話中だからしばらく待ってくれという事であったので、やむを得ず待つことにした。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "身寄りもたよりもみな死に絶えてしまって、内地にブリード（肉親）と名のつくものは」　そこまでいいかけたとき、川田はじれったくなったのか、「お話中だがね、小原君、ミイたちはまだえさについていないんだ。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯はね、蝦夷錦の金銀を抜いて、ブツブツの荒地にしたあとへ、モガルの色糸で一重蔓小牡丹｜文を、いたずらでもしたようにチラホラ散らしたという……お話中……わからないひとねえ、お話中だといってるじゃありませんか。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お話中……お話中ですよ……あたしのおどろきっちゃなかったわ。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
