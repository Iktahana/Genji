        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「chaperoning」である。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「chaperoning」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「chaperoning」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "chaperoning」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だから、ワラはお目付け役だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほどあなたが真っ先に、お住居はお目付けなされたものの、最初に山影宗三郎様へ、正しい道順とあり場所とを、お知らせしたのはこのお吉、したがって山影宗三郎様は、妾のものでございます」　すると浜路が進み出た。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞお願いでございます、お目付けなすってくださいまし。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目付けなすってくださいまし。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
