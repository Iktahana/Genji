        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "後ろで妻が「おや、どんぐりが」と不意に大きな声をして、道わきの落ち葉の中へはいって行く。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、落ち葉に交じって無数のどんぐりが、凍てた崖下の土にころがっている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山にはどんぐりも落ちれば、鵯の鳴く音に落ち葉が降る。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、「六さん、お早う」と声をかけましたが、子供は私の顔を見てニヤリ笑ったまま、草ぼうきで落ち葉を掃き、言葉を出しませんでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "町も辻も落ち葉が散り敷いて、古い煉瓦の壁には血の色をした蔓がからみ、あたたかい日光は宮城の番兵の兜に光っておりました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いていると子供の自分の眼前には山ふところに落ち葉の散り敷いた冬木立ちのあき地に踊りの輪を描いて踊っているたぬきどもの姿がありあり見えるような気がして、滑稽なようで物すごいような、なんとも形容のできない夢幻的な気持ちでいっぱいになるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かな静かな、長い長い落ち葉林の間を中途まで来ると、行く手に立っていた白いシグナルがカタリと音をたてて落ちたあとはもとの静寂にかえった。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄いろくからびた刈株をわたッて烈しく吹きつける野分に催されて、そりかえッた細かな落ち葉があわただしく起き上がり、林に沿うた往来を横ぎって、自分の側を駈け通ッた、のらに向かッて壁のようにたつ林の一面はすべてざわざわざわつき、細末の玉の屑を散らしたように煌きはしないがちらついていた。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年の冬の初め、この庭の主人は一人の老僕と、朝な朝な箒執りて落ち葉はき集め、これを流れ岸の七個所に積み、積みたるままに二十日あまり経ちぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夕は空高く晴れて星の光もひときわ鮮やかなればにや、夜に入りてもややしばらくは流れの潯を逍遙してありしが、ついに老僕をよびて落ち葉つみたる一つへ火を移さしめておのれは内に入りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二人は一山の落ち葉燃え尽くるまで、つきぬ心を語りて黎明近くなりて西の空遠く帰りぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の夜もまた詩人は積みし落ち葉の一つを燃かしむれば、男星女星もまた空より下りて昨夜のごとく語りき。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つの落ち葉の山、六つまで焼きて土曜日の夜はただ一つを余しぬ。",
              "citation": {
                "source": "星",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の貫きて真直に通う路あり、車もようよう通い得るほどなれば左右の梢は梢と交わり、夏は木の葉をもるる日影鮮やかに落ちて人の肩にゆらぎ、冬は落ち葉深く積みて風吹く終夜物のささやく音す。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の半ばに時雨しめやかに降り来たりて間もなく過ぎ去りし後は左右の林の静けさをひとしおに覚え、かれが踏みゆく落ち葉の音のみことごとしく鳴れり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の者が野菜洗うためにとてこの流れの幅をことさらに広く掘り、小さき入り江をなせる、いつもかれが好みて訪い来るところにいで落ち葉を敷きつ、茅、野ばら、小笹の類入り乱れし藪叢を背にしてうずくまり、前には流れの音もなく走るをながめたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "風起こりて木の葉あらあらしく鳴りつ、梢より落つる滴りの落ち葉をうつ音雨のごとし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雑木林の出っ鼻の落ち葉の上に風呂敷をしいてすわり込んで向かいの丘を写し始めた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち葉を掃かないのさへ我儘らしいから、腕を組んでだまつて視た。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるほどに車体は一上一下と動揺して、あるいは頓挫し、あるいは傾斜し、ただこれ風の落ち葉を捲き、早瀬の浮き木を弄ぶに異ならず。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも常会をひらくまえに、境内をみんなで掃除することになっているのだが、きょうは僕はひとつみんなの気のつかないところをしてやろうと、御堂の裏へまわって、藪と御堂の間のしめった落ち葉をはいた。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々人が来るらしく、落ち葉を踏み固めたところが連続していること。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾く年の落ち葉木の実といっしょに鵯の鳴き声も軒ばに降らせた。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、ひどく冷たい北風が吹き荒んで、公孫樹の落ち葉や欅の落ち葉が、雀の群れかなんぞのように、高く高く吹き上げられていた。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉松林が尽きると、路はもはや落ち葉に埋められて地肌を見せなかった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車はぼこぼこと落ち葉の上を駛った。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馭者が馬を追うごとに、馬車はぎしぎしと鳴り軋めきながら、落ち葉の波の上を、沈んでは転がり浮かんでは転がって行った。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一面の落ち葉で、どこが路なのか判然とはわからないのだった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車は、午後の陽に輝きながら散る紅や黄の落ち葉をあびながら、ごとごとと樹の間を縫って行った。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おちば」は、やや長じた子供らに、社会の現実生活を感じさせ得るであろう。",
              "citation": {
                "source": "子供のために書く母たち",
                "author": "――「村の月夜」にふれつつ――",
                "note": "青空文庫"
              }
            }
          ]
        }
