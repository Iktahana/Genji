          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを割引きして聞くべきだとジュル・ラフォルグは思つてゐたのだが、世間が漸く彼を認め出した時に当つて恐るべき一撃をコルビエールに加へたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その忘失こそ忘失者自身には認め難いのであつて、恐るべき近代病の根本性質はそれである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれはやはり実に恐るべき現象でなければならない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、つひに、中國がその自らの獨立國としての存立を危くしてゐるのは、決して中國人たちの肉體の病氣の故ではなくして、あきらかに精神の病ひのせゐである、すなはち、理想喪失といふ怠惰にして倨傲の恐るべき精神の疾病の瀰漫に據るのであるといふ明確の結論を得るに到ります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの権威を無批判的に過信する弊害は甚だ恐るべきものでなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐るべきは権威でなくて無批判な群衆の雷同心理でなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に恐るべきことである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女の凱旋門、恐るべきことがある。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐るべき何者もなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝される事がらがかりに「悪い事」や「無理な事」や「危険な事」であったとしたら、その場合には結果はたいして恐るべきものではあるまいと思う。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果の善悪にかかわらず実に恐るべきことだと思われるのであった。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日偶然上野の精養軒の待合室で初めてＪＯＡＫの放送を聞いたが、その拡声器の発する音は実に恐るべき辟易すべきものであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津が強盗、殺人、強姦などをやってきた、そして多くの人々から、恐るべき蝎として、嫌われ、おっかながられている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの同じ心理が恐るべき惨害をかもす直接原因となりうるのは劇場や百貨店などの火事の場合である。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャーナリズムが恐るべき性能を充分に発揮するのはこの点であろうと思われる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてだれしもそれを承知していながら知らず知らずこのジャーナリズムの魔術にかかってしまうのは実に恐るべきことと言わなければならない。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから考えても悲哀ということ自身は決していとわしい恐るべきことではなくてかえって多くの人間の自然に本能的に欲求するものであることが推測される。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は恐るべき猛獣である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私には、かの落第生の恐るべき言葉を全く否定し去る事も出来なかった。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもししいて何か感じた事を述べよとならば、それは消化器の弱い自分にとって今夜の食卓に出されたパンが恐るべきかたいパンであったという事であると言って席についた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐るべきかたいパン」、この言葉が今この追憶を書いている私の耳の底にありあり響いて聞こえる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じように平生地震というものの災害を調べているものの目から見ると、この恐るべき強敵に対する国防のあまりに手薄すぎるのが心配にならないわけには行かない。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "包囲攻撃じゃ、恐るべきだね。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を閉じたが、しばらくして、「恐るべきです、恐るべきだ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷々然として落着き澄まして、咳さえ高うはせず、そのニコチンの害を説いて、一吸の巻莨から生ずる多量の沈澱物をもって混濁した、恐るべき液体をアセチリンの蒼光に翳して、屹と試験管を示す時のごときは、何某の教授が理化学の講座へ立揚ったごとく、風采四辺を払う。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、公衆は、ただ僅に硝子の管へ煙草を吹込んで、びくびくと遣ると水が濁るばかりだけれども、技師の態度と、その口上のぱきぱきとするのに、ニコチンの毒の恐るべきを知って、戦慄に及んで、五割引が盛に売れる。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立山の地獄谷はまた世に響いたもので、ここにその恐るべき山川大叫喚の声を聞くのは、さすがに一個婦人の身に何でもない事ではない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "取留めのない夢の想で、拓はこの時少年がお雪に向ってなす処は、一つ一つ皆思うことあって、したかのごとく感じられて、快活かくのごとき者が、恋には恐るべき神秘を守って、今までに秋毫も、さる気色のなかったほど、一層大いなる力あることを感じて、愕然とした。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に若し怪物といふ者があるならば、此軍艇こそ確に地球の表面に於て、最も恐るべき大怪物として、永く歐米諸國の海軍社會の記臆に留るであらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸はいま明らかに、このおそるべき錯誤を犯してゐるのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
