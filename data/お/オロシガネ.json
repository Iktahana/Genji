        "gloss": "grater (esp. the variety used in Japanese cooking to grate foods very finely)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
