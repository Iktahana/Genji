    "definitions": [
      {
        "index": 1,
        "gloss": "side of a mountain that gets a lot of sunshine (and is therefore suitable for farming)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
