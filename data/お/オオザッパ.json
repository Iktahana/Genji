        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それも安くて割のいいものを捜すとか、古いものを押っくり返し染め返したり、仕立て直したり、手数をかけるだけの細かい頭脳を働かすことはしないで、すべて大雑把にてきぱき捌いて行く方で、大抵は呉服屋まかせであったが、商売人の服装には注意を怠らなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "〇「慍は怒なり」『鄭玄註』というのは、大雑把な解釈で詳しいものでは無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『論語』は、大雑把に言えば、全て孔子の弟子が善言を記したものであり、詳しく言えば孔子の弟子の曽子の弟子である楽正子思の徒が記纂したもので、また孔子の弟子の有若の弟子等が記したところも有るので、単に子曰とあるのは孔子で無ければならない、そう考えられるのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雑把な愚策　支那語正科説に就て　▼パアマネント禁止説とか、中等学校で支那語を正科にするといふ説は、今の処風説に止まつてゐるが、この種の噂が民衆の間をとびまはつてゐる時、問題の本質的解明は依然として残されたまゝである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の問題の出し方を大雑把に云って了えば、科学の発達は科学自身に原因するか、それとも技術の方向にその原因が求められねばならぬか、というのであった。",
              "citation": {
                "source": "生産を目標とする科学",
                "author": "――再三「科学と技術」とについて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「山の手」を註して、　山手――原意是近山的地方、此処却専指東京本郷一帯高地、……云々と云ふのは少し大雑把である。",
              "citation": {
                "source": "日本小説の支那訳",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一谷君の碁は堅実、私の碁は大雑把で、棋風は異っていたが、勝負の数は互角だった。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の条件豊島与志雄　ごく大雑把にそして極めて素朴に、人間の生活の理想的な在り方を考えてみる。",
              "citation": {
                "source": "今日の条件",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済学者に言わすれば、これ需要供給の然らしむるところと、大雑把に一言で解決するであろうが、これを個人々々の場合に当て嵌めると、人の問題は死んだ物件の需要供給とは大いに異う。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私生活面の文化　一般的に極く広い意味に於る文化を考へる場合、即ち文化の時代性、文化の水準を、全体として考へる場合、僕は地域的に都会に文化が集中して、田舎には文化が浸潤してゐないといふ考へ方を、大雑把には信用しないのです。",
              "citation": {
                "source": "既往文化と新文化",
                "author": "――某氏との談話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　結局、われわれも茶寮を経営して行かねばならなかったので、利益を度外視して、ものをすることは絶対出来ませんでしたが、われわれがほかと少し違うところは、その経営法が大雑把で、大所高所から見た、すなわち、急がば廻れ式のソロバンをはじいていたことなんです。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先にもいったことであるが、おそらく各家は自己の指導力によって往古に見るがごとき名作を成し得られると大雑把に考えられたことと察せざるを得ないが、もし果たしてしかりとするならば、これを画の製作に考えを移して、各自の指導力が雲舟、牧谿でなくても三楽を生むか元信を生むか桃山芸術を生むかを反省されたい。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者が現在この意見につき思っているところによれば、これを確立するためには、社会に関する最も大雑把な観察に加えて、事実を平明に述べさえすればよいのであって、それ以上はほとんど必要はないようである。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "次兄の逸話　次兄は若いころから養家の仕送りを十分に受け、一生ほとんど難局にぶつかることもなかったわけで、ごく大雑把な、いわゆる昔の言葉にある国士の風格があった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく大雑把に言うと、パソコンにない漢字をＪＩＳ外字と呼ぶ。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三五・一二）五　三六年度思想界の展望　実際問題として、この年にどういう形の諸問題が思想界を賑かすか、又この年の思想界の一般的な傾向はどうだろうか、ということに就いては、極めて大雑把な輪郭しか描くことが出来ない。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一九年に至るまで、この大雑把な音訳をいかなるものでも他の知識と関連づけた者は一人もいなかった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "大雑把にいって、石は南緯二十二度三分十四秒東経百二十五度零分三十九秒の地点にあります。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし無論、道庵流に皮肉に見ることなどは知らないし、武芸者の大雑把な頭に、海老蔵の名前だけがしみ込んでいるものですから、その絵ビラを見て、「松本へ海老蔵が来たな、こいつは一番見ずばなるまい」という気になりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば世間の大雑把な記憶では、桜田門の十七浪士は、すべてもう死んでいるものとしてあるからだった。",
              "citation": {
                "source": "旗岡巡査",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大雑把にいって社会経済が武家から町人の手に移りつつあった現われであろうが、その反面、これら新興の富豪商人らが幕府政治の枠内で巨利を掴むために、大多数の庶民がひじょうな犠牲を払わされたことは云うまでもない。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、プルタルコスは両方を大雑把にくらべてはいないのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは実に大雑把であつた。",
              "citation": {
                "source": "吸血鬼",
                "author": "ジョン・ポリドリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "気軽なようで底が知れぬし、大雑把なようで、眸づかいは鋭くて細かい）　知り合うほど一面では、こういうふうに、警戒し合っているところもあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、議論百出なのだ、理論はそう大雑把なわけにゆかない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、「世界とは」とか「人生とは」とか、そんなおおざっぱなものの言い方は止した方がいいね。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民衆の文化水準というものも、現実には決しておおざっぱな一口ではいえないものである。",
              "citation": {
                "source": "全体主義への吟味",
                "author": "――今日の民衆、知識人への課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が、お孝さんは熱情家だ、と云った言葉は、おおざっぱではあるけれども、当っていると思った。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白書」は一方に外資導入について、それがさけがたいというおおざっぱな諦めを持たせ、中小工業の破産を止むを得ざる事態と認めさせ、公定価格つりあげの基盤としても役立てられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十八日の各紙に出ている逮捕理由はおおざっぱで独断的ですべての常識ある人には奇妙に思われるものだった。",
              "citation": {
                "source": "犯人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
