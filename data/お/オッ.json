          ],
          "literary": [
            {
              "text": "水禽の大鉄傘を過ぎて、おっとせいの水槽のまえを通り、小山のように巨大なひぐまの、檻のまえにさしかかったころ、佐竹は語りはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのうちに君、眼がさめて見ると、――」「おっとそれあ言うな」馬場は右手を鼻の先で力なく振って、太宰の言葉をさえぎった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は独り息子であるから、ずいぶん可愛がられて、十年ほど前にお母さんが死んで、それからは厳父は、何事も大隅君の気のままにさせていた様子で、謂わば、おっとりと育てられて来た人であって、大学時代にも、天鵞絨の襟の外套などを着て、その物腰も決して粗野ではなかったが、どうも、学生間の評判は悪かった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と山田君は久しぶりに私の寓居を訪れて、頗る緊張しておっしゃるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「縁談などの時には、たいてい自分の地位やら財産やらをほのめかしたがるものらしいが、小坂のお父さんは、そんな事は一言もおっしゃらなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこれが案外親切な巡査で戸籍簿のようなものを引っくり返して小首を傾けながら見ておったが後を見かえって内に昼ねしていた今一人のを呼び起した。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それははるかなはるかな太平洋の上におおっている積雲の堤であった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころ籾殻を箕であおっている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおったらみんなを連れて一日くらい遊びに行こう。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は、彼等は、「誰か痛快におっ初めたものだな！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして耳を兎のようにおっ立てた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "躯を直角に曲げて、耳をおっ立てて、彼は「グニャグニャしたロープ」を、闇の中に求めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お洒落でつつましやかで、おとなしくてお済しで、群っていても実は孤独で、おっとりしていてもなかなか怜悧で。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿をおっしゃい。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、せいぜい運動でもして、おっかさん位な体格になるんだね」　みち子はそれ以後何故とも知らず、しきりに柚木に憎みを持った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっかさんまた柚木さんが逃げ出してよ」　運動服を着た養女のみち子が、蔵の入口に立ってそう云った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっかさんが病気なんですから今晩でないと困るんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔七、〕北十字とプリオシン海岸「おっかさんは、ぼくをゆるして下さるだらうか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、（あゝ、さうだ、ぼくのおっかさんは、あの遠い一つのちりのやうに見える橙いろの三角標のあたりにゐらっしゃって、いまぼくのことを考へてゐるんだった。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはおっかさんが、ほんたうに幸になるなら、どんなことでもする。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、いったいどんなことが、おっかさんのいちばんの幸なんだらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみのおっかさんは、なんにもひどいことないぢゃないの。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、おっかさんは、ぼくをゆるして下さると思ふ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっと、も少し遠くから堀って。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぎといふものは、みんな天の川の砂が凝って、ぼおっとできるもんですからね、そして始終川へ帰りますからね、川原で待ってゐて、鷺がみんな、脚をかういふ風にして下りてくるとこを、そいつが地べたへつくかつかないうちに、ぴたっと押へちまふんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、おっかさんはどんなに永く待ってゐらっしゃったでせう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの大事なタダシはいまどんな歌をうたってゐるだらう、雪の降る朝にみんなと手をつないでぐるぐるにはとこのやぶをまはってあそんでゐるだらうかと考へたりほんたうに待って心配してゐらっしゃるんですから、早く行っておっかさんにお目にかゝりませうね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、天の川の岸にね、おっかさんお話なすったわ、………〔」〕「それから彗星がギーギーフーギーギーフーて云っ〔て〕来たねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だっておっ母さんも行ってらっしゃるしそれに神さまが仰っしゃるんだわ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱穀器は小屋やそこら中の雪、それからすきとおったつめたい空気をふるわせてまわりつづけました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
