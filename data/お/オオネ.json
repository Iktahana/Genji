        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――夕明下に投げいだされた、萎れ大根の陰惨さ、あれはまだしも結構だつた――今や黒い冬の夜をこめどしやぶりの雨が降つてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけなく頭の上が、二、三寸ほど、大根卸しでも注いだように、白くなっている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしないと、おしまひには米や大根を地下室の棚で作らなければならない事になるかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱や大根が到處に青々として、麥はまだ僅に芽を出した處がある位であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして日の暮れる迄働いておいて朝はもう二時頃から起きて大根の車の後押をして市場へ出るのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後四時にはもう三代吉の父親の辰五郎が白米、薩摩芋、大根、茄子、醤油、砂糖など車に積んで持って来たので少し安心する事が出来た。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は切なく叫ぶ、「この大根、嫁かずであれ、――今に」　といい、あとをも見ずに駈け去った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この大根、嫁かずであれ、――今に」そういうかと思うと、たちまち、男はまた、不器用にも俊敏に去った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はやはり「この大根、嫁かずであれ、――今に」といって駆去った男が、その翌日、何にも獣は持たずに水のほとりに来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根の花も莢になっている時分であった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬近い野は農家の軒のまわりにも、田の畦にも大根が一ぱい干されている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも仮りに私が机の上で例えば大根の栽培法に関する書物を五、六冊も読んで来客に講釈するか、あるいは神田へ行って労働問題に関する書物を十冊も買い込んで来て、それについて論文でも書くとすればどうだろう。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもしこれが当を得ているとしたら、結局私は大根裁培法を論じていいものだろうか悪いものだろうか。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいずれにしても私の大根裁培法が巣鴨の作兵衛氏に笑われる事だけは確かだろうと思った。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えたのが動機となって、ふと大根が作ってみたくなったので、花壇の鳳仙花を引っこぬいてしまってそのあとへ大根の種を蒔いてみた。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう本ばかり読むのはやめてしばらく大根でも作ってみようかと考えている。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六十八段、大根が兵士に化ける話は少し怪しいが、次の六十九段と合せて読んで見ると寓意を主として書いたものとも思われる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大掃除の午後の路地の交互点、こわれたおもちゃに葱大根の尻尾、空瓶空ボールの交響楽、マルクス、ムッソリニの赤ん坊の夢を買わないか。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「芸は大根でも　家柄のある奴は、親の威光で　ドンドン出世する　皆んな家柄のお蔭だ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩には夜なべに、大根を切ったり、屑芋をきざんだりする。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆりならずや幸助をいかにせしぞ、わが眠りし間に幸助いずれにか逃げ亡せたり、来たれ来たれ来たれともに捜せよ、見よ幸助は芥溜のなかより大根の切片掘りだすぞと大声あげて泣けば、後ろより我子よというは母なり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると第一通は英文で温泉へ宛てた四十人宿泊準備の依頼状で特に食事は白米の飯と大根の味噌汁と香の物だけを仕度してくれ但し価格は一日十円以内といふ　第二通は仲間へ出した活字の通知状であった。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔のへしゃげた苦力は、塵芥や、南京豆の殻や、西瓜の噛りかすを、ひもじげにかきさがしつゝ突ついていた、彼等は人蔘の尻尾でも萎れた菜っぱでも大根の切屑でも、食えそうなものは、なんでも拾い出してそれを喰った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――嬶や、親が、かつえるなんて、あいつら、生大根でも、人参の尻ッポでもかじっとりゃいいんじゃないか！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、大根ナマスのように、白楊の素地が軸刻機にきざまれて軸木の山が出来て行く、刻作業部を通りぬけて、用材置場から、薄暗い兵士のいない宿舎をちょっとのぞいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人が生大根の尻ッポをかじっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で渋りながら備中守の差出す腕を、片手で握添へて、大根おろしにズイと扱く。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷い挽割飯と、大根ッ葉の味噌汁と、塩辛く煮た車輪麩と、何だか正体の分らぬ山草の塩漬の香の物ときりで、膳こそは創だらけにせよ黒塗の宗和膳とかいう奴で、御客あしらいではあるが、箸は黄色な下等の漆ぬりの竹箸で、気持の悪いものであった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫野を見晴らす大根畠と墓原の間の小径の行止まりに、万延寺の本堂と背中合わせにして一軒の非人｜小舎がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくおおねえさんのとこへ行くんだよう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
