        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "後には森を背負ひ、門前の小川には小橋がかゝつて居る、何となしに閑寂な趣のある好い土地だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん俗悪な木版刷りではあったが、しかし現代の子供の絵本のあくどい色刷りなどに比較して考えるとむしろ一種稚拙にひなびた風趣のあるものであったようにも思われる。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろには森を背負い、門前の小川には小橋がかかっている、なんとなしに閑寂な趣のあるいい土地だと思う。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、さして心を傷めた趣のあるにもあらず、茅花々々｜土筆、摘草に草臥れて、日南に憩っているものと、大なる違はない。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんと類のない趣のある家じゃ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら彼等の思想は主観的で、他の学究のように純理的思弁をせず、意味が情趣のある気分によって語られているから、先ずこれ等の思想家は、定評のある如く詩人に属する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　なんといふ趣のある招待の言葉だらう。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧くは俳人の嵐雪が住み、歌人の加茂真淵が住みまして、真淵などは、その周囲の野趣のあるさまから家の号を懸居と称えたということを池上はいつか話していました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟というのは安宅先生のあの中性型の美人の顔を、横着に、そして神経質な苦渋をも加えた、いくらか奇怪な趣のある青年でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか Kambodscha の酋長がパリに滞在していた頃、それが連れて来ていた踊子を見て、繊く長い手足の、しなやかな運動に、人を迷わせるような、一種の趣のあるのを感じたことがある。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣をつけて見れば野趣のある花である。",
              "citation": {
                "source": "庭さきの森の春",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は下の下に属するものと品定めの人たちに言われるはずの所でも、そんな所から意外な趣のある女を見つけ出すことがあればうれしいに違いないと源氏は思うのである。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に流れた滝も情趣のある場所だった。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいそうにはしないで雅趣のある檜破子弁当が出て、勝ち方に出す賭物も多く持参したのである。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り鳥の一種で、姿の上品な趣のある鳥です）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが済むと次は同じく欄間で鉄線蓮唐草の図（鉄線蓮はよく人家にある蔓草で、これも紋様などにして旧くから使われているもので、大変趣のあるもの、葉は三葉で一葉を為し、春分旧根から芽を出し、夏になって一茎に一花を開く。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "皇居御造営の事、鏡縁、欄間を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の利いた凝った趣のあるビラ、昔風のなつかし味のある簡素な看板なぞは、活動や、缶詰や、最新流行洋式雑貨なぞのデコデコのポスターに蔽い隠されて行く。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の眼にある三朝川、白く黄ばんだ土手の上の趣のある道、兩岸に相對する温泉宿、これらの眺めはあの友達の來て見たころと同じやうであらうか。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "と私達は眼にあるものを指していふことも出來たけれど、あの友達の來て見たころはこれよりもつと野趣のある土地であつたらうか。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "兩國の村里が相接して、國と國との寢ものがたりする趣のあるといふところから、その名がある。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "木曾路名所圖會をあけて見ると、あの邊が東山道の街道筋に當るところで、左右に見える近江と美濃の山々がたけくらべする趣のあるところから、別にたけくらべの里の名も殘つてゐるといふ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸に見える村落、野趣のある釣橋、河原つづきの一帯の平地、遠い近い山々――それらの眺望は先生方を悦ばせた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の片隅から親愛な美しさが失われてゆく感じから我知らず郷土的な風趣のあるものだの、げてものの面白さだのを求めている人々の生活にしろ、つまりはそれらのものを外から運びこんで生活のあすこ、ここに置いているだけのことで、つきつめて云えば一種の消費が形を変えたものに過ぎない。",
              "citation": {
                "source": "生活のなかにある美について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都人の日常生活の細やかさ、手奇麗さなど、風景でも大ざっぱで野趣のある関東から来た人は、誰でも賞め、価値を認める。",
              "citation": {
                "source": "京都人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても古風で趣のある作品がこうして打ち捨てられ、そして、まもなくすべて消滅する運命である。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、古風で趣のある綺麗な通りや大きな寺院がある訳でもないし、また素晴らしい庭園がある訳でもない。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も田舎に住んだ年よりは東京に住んだ年の方が多くなつたので大分東京じみて来て田舎の事を忘れたが、なるほど考へて見ると田舎には何でも一家の内でやるから雅趣のあることが多い。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "西湖を船でゆくと、湖中に島があったり、島には文人好みの亭があったりして、いろいろと風景に趣のあるよいところであった。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか Kambodscha の酋長が巴里に滞在してゐた頃、それが連れて来てゐた踊子を見て、繊く長い手足の、しなやかな運動に、人を迷はせるやうな、一種の趣のあるのを感じたことがある。",
              "citation": {
                "source": "花子",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "月今宵は少くも灑脱の趣のある句である。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
