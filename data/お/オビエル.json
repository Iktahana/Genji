    "definitions": [
      {
        "index": 1,
        "gloss": "to become frightened",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "例へば、余り善良なものは却つて悪人であるかの如く怯えるものだといふシヱクスピヤの言事は高橋に当｜箝るだらう。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "向後どこへか呼ばれた時は、怯えるなよ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の白いのにさえ怯えるのであるから、雪の降った朝の臆病思うべしで、枇杷塚と言いたい、むこうの真白の木の丘に埋れて、声さえ立てないで可哀である。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とばかり怯えるように差出した三世相を、ものをも言わず引掴んで、追縋って跡に附くと、早や五六間｜前途へ離れた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おっと……番毎怯えるな、しっかりと掴ったり……」「あなた、邪慳にお引張りなさいますな。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは乞食の素性のことをまだ怯えているようですが、何を怯えることがありますか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしを見て却って怯えるように後じさりをしつゝ涙をぽろ／＼零した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの彼女が、こっそり自分の部屋へ入ろうとして、旦那に声をかけられると声をあげて怯えるだなんて。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンチョが牛の群にあんなに怯えるなんて。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と小さい時からただ人に叱られて育って来たので、人を見ると自分を叱るのではないかと怯える卑屈な癖が身についていて、この時も、譫言のように「すみません」を連発しながら寝返りを打って、また眼をつぶる。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼マルクス主義の残党の亡霊に怯える杉山平助氏は、自己の中の亡霊を追ひ出す暇もないほど、他の亡霊を追ひ廻すのに忙がしいが、その杉山氏の状態をみると、亡霊の社交界を駈けまはる男のやうで、一本をきに歯のぬけた口をもつた紳士のやうである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、極度に過敏になった夫人の神経は、些細な物音にも怯えるようになりました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、三人の愛児までが、その夜のできごとがあって以来、妙にものに怯える臆病な子供になりました。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は恐れる――強烈な淋しさが擬集して、私の心の中で一つの形を取ると、それがミサ子の羞かみ怯える姿になっているのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの怖ろしい風巻に怯える父祖伝来の血統が、村人一帯に流れてゐる故に、一名「吹雪病」と称ばれてゐるこの癲癇の一種に就いては村人は余り気にも掛けぬのであつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれは重に下町のことで、山の手の方には割合に病人も少のうございましたから、お屋敷勤めのわたくし共はその怖ろしい噂を聞きますだけで、そんなに怯えるほどのこともございませんでした。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは心配、なぞと云いますよりも、いっそ恐怖とでも申しましょうか……こう、ひどく困った風であちらの別館の方の船室の書斎へ籠りまして、暫く悶えてでもいたようでございましたが、恰度心配してこっそり様子を見に参りました私は、そこで主人の、物に怯えるような独言を聞いたのでございます」「どんなことです？",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の午後までだ、きっとここまでやって来る』と云う怯えるような深谷氏の独言を思い出し給え。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昨晩ラジオの演芸時間の始まる頃から、急に変られた深谷氏の妙な態度――しかも夫人は、深谷氏の怯えるような独言を聞かれました。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて東屋氏が、「最後に、私は、キャプテン深谷氏のあの奇妙な、怯えるような独言に就いて――」　と、この時である。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外は、どんなに不安に怯えるとも、博士を信頼して頑張ることになっていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗な東京を考えるだけで、ふだんの東京を知っているものは心は怯える。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近松は、この世の義理に苦しみ、社会の制裁に怯える男女の歎きと愛着とを、七五調の極めて情緒的な、感性的な文章で愬えて、当時のあらゆる人の心を魅した。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも題は忘れたけれども、電燈の下で赤ちゃんに添乳していて、急に、この頭の上の電球が破裂して、子供に怪我をさせはしないかと考え出して怯えることを書いた作品は好きで今でも覚えている作である。",
              "citation": {
                "source": "昔の思い出",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――時には、夢で、ノボオシビルクスに引き戻されて怯える夜もあつたが、夢が覚めると、白いパンに向ふ時の厭な気持ちになるのは、心に重たいしこりがあるせゐであらうか。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒い世相で、貧窮に怯えるのも厭だと云ふ心理も、ないではなからう。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生餌を食うその貪慾さも、自分自身の映像に怯える神経衰弱さに比ぶれば、自然そのものの神性に近い。",
              "citation": {
                "source": "守宮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、わたしの心はふと何かに怯えるのです。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を怯える、石田、増田に！",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞたびたびおびえるやうにうしろに手をあげながら足の痛さによろめきながら一生けん命歩いてゐるのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
