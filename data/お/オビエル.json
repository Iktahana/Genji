[
  {
    "uuid": "8708a1eb-4358-5eda-a259-0b6e727266d1",
    "entry": "怯える",
    "reading": {
      "primary": "おびえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
