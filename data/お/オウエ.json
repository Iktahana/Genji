          ],
          "literary": [
            {
              "text": "けれどもお寺の中のいちばん高いところには、最高の御仏である仏陀が聖なる絹の黄衣を身にまとって立っていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家には妖怪があって、しばしば人を殺すと伝えられていたが、彼は平気で眠っていると、夜の四更（午前一時―三時）とおぼしき頃に、黄衣の人が現われて外から呼んだ。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄衣婦人　唐の柳宗元先生が永州の司馬に左遷される途中、荊門を通過して駅舎に宿ると、その夜の夢に黄衣の一婦人があらわれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜の夢に、かの黄衣の婦人が又もや先生の前にあらわれたが、彼女には首がなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳瀬俊雄……『有段者』『黄衣婦人像』などをみると、一応腹の出来た人といふ感じがする。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "その像象首一牙で、四手に瓢と餅と斧と数珠をもち、大腹黄衣で鼠にのる（ジャクソンの『グジャラット民俗記』一九一四年ボンベイ板、七一頁）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は身のたけ一丈もあるらしく、黄衣をきて白い帯を垂れていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに従者四人、みな黄衣を着て東の方から来たが、ここの門前に立って尹氏の子供を呼び出し、暫く休息させてくれと言った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうごったがえしのなかを、黄衣のラマ僧が悍馬を乗りこなしながらこれ見よがしに疾駆している。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの患者の量よりも少ない私の尿は、大瓶の底のほうに黄衣のすそを見るように乏しいものであったと書けば、なかなかに尿にも美観はあるが、実際は子供のおしっこくらいしかなかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒衣の下には黒羊の皮衣、白服の下には白鹿の皮衣、黄衣の下には狐の皮衣を用いられる。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "完翻訳について　R. W. Chambers の The King in Yellow（『黄衣の王』）から The Street of Four Winds です。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "『黄衣の王』は以下の十編からなります。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうえ」と應ずる聲が水を渉つて強く然かも近く聞えた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は　てんのう　一休さんの　うまれたのは　おうえい元ねん、いまから　ざっと　五｜百六十｜年ばかり　まえの　ことです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "城代家老といえば、藩でも殿さまのつぎにくらいするおかたで、このかたが、たいそうさざんかをお好みになり、さざんかの名木という名木をあつめ、屋敷のまわりへおうえになったので、いまでも山茶花屋敷といえば、この近郷だれしらぬものもない、なりひびいたお屋敷だったのです。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "12　しょうねんたんていだんのおうえんにやって来たヘリコプターは、強い風をまき起しながら、原っぱのまん中へちゃくりくしました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村係長がきてんをきかせて、近くの消防署に、おうえんをもとめたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　もう海上自衛隊のおうえんをたのむしかありません。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき潜水カブトの中の電話で、ハヤブサ丸に「おうえんをたのむ。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
