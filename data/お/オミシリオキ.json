          ],
          "literary": [
            {
              "text": "「これが私の女でございます、どうかお見知りおきを願います」　老人はそれから老婆に御馳走の用意をさした。",
              "citation": {
                "source": "虎媛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後お見知りおきくだされい」「そのごあいさつではかえって痛み入りましてござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後お見知りおきを願っとくよ」　と名刺をだした。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見知りおきの程、ねがいあげます」「キサマ、なんの用できたか」「ハッ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかお見知りおきを……。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞお見知りおきを願います。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにとぞ、お見知りおきを」「鉄砲持ちには出来すぎた面だ。",
              "citation": {
                "source": "鈴木主水",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣保の仁義にも及ばなかったが、以後、よろしくお見知りおきねがいたい」　軽やかに受流して、悠然と上のほうへあがって行ってしまった。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一間一間に燭台を出しておけ」　と作左衛門に言いおき、書院にとってかえすと、又内に、「姫路にお下りになるのは、しばらく間のあることゆえ、憚りながら、家内をお見知りおきねがいたい。",
              "citation": {
                "source": "無惨やな",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「〔J'ai l'honneur de me vous repre'senter〕（どうかお見知りおきを願います）」と彼は言うのだった。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかお見知りおきください。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかよろしくお見知りおき願います」「お笛の亭主……」勘太夫はしずかに畳の上から莨入れを拾った、「たしかにお笛の亭主に相違ないか」玉の肌「亭主と申しましても、へっへ、こういう境涯の人間でございます、なにも人別帳に書くほどはっきりしたものではございません、いってみれば情人とでも申しましょう。",
              "citation": {
                "source": "明暗嫁問答",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはむすめ早苗でござる」と、左内がひきあわせた、「……ふつつか者だが、お見知りおき下さい」　平三郎は、はあと答えたが、そちらへは向かなかった。",
              "citation": {
                "source": "日本婦道記",
                "author": "小指",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうは、お子連れか」「お見知りおき下さいませ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見知りおき下さい。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「身が、又右衛門宗矩でござる、お見知りおき下さい」　武蔵もまた、「初めて御意を得ます。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同にその使用をすすめたのち、「拙者は大坂城に質としておる真田源次郎という若輩者、どうかお見知りおきを」　と、ていねいに名のった。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか今後とも、お見知りおきのほどを」　と、型どおりな、初対面の仁義をきって。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか以後はお見知りおきを」「えっ、では山東｜※城県の押司、宋公明さんだったんで。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢の代の良臣のご子孫、お見知りおき下さい」「やあ、汝が宋江か。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいや、某は京極殿の家中ではござらぬが、義によって試合申す、播州船坂山の住人｜鐘巻自斎と申す者、不鍛練なる富田流にてお相手致す、お見知りおき下されい」　と長髯の武士鐘巻自斎は、礼譲玄蕃の如き者の比でなかった。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見知りおきください」　彼から、改めて、こう挨拶すると、道三も気色を柔らげて、「わしが山城じゃ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見知りおきを願っておくがよい」「……はい。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信長です」　平伏して、お見知りおきください、と彼はいった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見知りおき下さい」「やはり明智殿であられたか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後はお見知りおきのほどを」　半兵衛は、膝を打って、「やあ、渡辺天蔵どのとは、あなただったか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山城というか」「お見知りおき下さいませ」「きょうは、大儀であった」「お盃、ありがとうぞんじまする」　直江山城は、盃を、秀吉の前に返して、もとの座へ、ひき退がった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ことは但馬守の老臣曾根権太夫というもの、何とぞ、お見知りおき下されますように」　と、玄堂と同様な言い訳を諄々とならべ立てて、どうか、上屋敷の方へ移ってくれと申します。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかお見知りおき下さい」　と、最高な礼儀をとって、慇懃にいった。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
