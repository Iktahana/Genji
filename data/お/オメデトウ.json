[
  {
    "uuid": "8a1cfe8c-0810-5948-8dd4-3ed1030b87d7",
    "entry": "御目出度う",
    "reading": {
      "primary": "おめでとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "congratulations!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「御目出度う御座る」　という足軽の言葉をあとに、検使に礼を述べる。",
              "citation": {
                "source": "相馬の仇討",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦さん、御目出度うさん。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御目出度う御座います。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は逢う人毎に「御目出度う」と言ったまま、火のある小屋の方へ行った。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御年貢ですか、御目出度う」と言って入って来たのは水車小屋の亭主だ。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "人みな同じ、五段おとされたこと忘れ果て、三段の進級、おめでとう、おめでとうと言い交して、だらしない。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭の当日は朝からよく晴れていて私が顔を洗いに井戸端へ出たら、佐吉さんの妹さんは頭の手拭いを取って、おめでとうございます、と私に挨拶いたしました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、おめでとう、と私も不自然でなくお祝いの言葉を返す事が出来ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、今日はおめでとう。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてこれらは、私たちの兄弟でありましたから、もう私たちは国と階級、職業とその名とをとわず、ただ一つの大きなビジテリアンの同朋として、「お早う、」と挨拶し「おめでとう、」と答えたのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳氏は私の行ったのを見ると本当に嬉しかったと見えて、いきなり手を出して、「おめでとう。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　火箸に手を載せ、艶麗に打微笑み、「おめでとう。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と手をつき、「おめでとう存じまする。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめでとう存じまする、皆、太夫様の御人徳。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明けましてまずはおめでとうございます、とおよろこびを申しあげる。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はおめでとう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめでとう御座います。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、おめでとう。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、おめでとう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を坐らせて、それからお二人も私の前にきちんと坐って、そろってお辞儀をして、「今日は、おめでとうございます。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と申しました時に、ちらと夫は仮面の底から私を見て、さすがに驚いた様子でしたが、私はその肩を軽く撫でて、「クリスマスおめでとうって言うの？",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年おめでとうございます」と小さく書き加えてあることにしよう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年おめでとうございます。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめでとうございます。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那、おめでとうございます。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、その夜に限ってごく自然に私のほうから津田氏に、「津田さん、おめでとう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、おめでとう。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢様も近々御縁が極りますそうで、おめでとう存じます、えへへ、と燥いだ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめでとう存じます。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオニングの紳士が、ひどくいい機嫌ではいって来て、「やあ、諸君、おめでとう！",
              "citation": {
                "source": "一燈",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
