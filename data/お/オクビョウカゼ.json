    "definitions": [
      {
        "index": 1,
        "gloss": "loss of nerve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
