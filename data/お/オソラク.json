        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ほがらかとは、恐らくは、悲しい時には悲しいだけ悲しんでられることでせう？",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、人が、思はず云ひ過ぎをしてしまふやうに、自殺も、思はずしてしまふやうなものに相違ない。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣一枚の胸をハダケて、恐らく我々が来るまで、彼は頭をカカへてゐたに違ひなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分類が終るや能事足れりとなす所に、現代インテリの過ちがあり、恐らくこの過ちが彼を不幸にした大きい理由であつたと云へよう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、芸術家は、昔日よりも、一層の孤独を必要とするであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "認められること余まりに遅かつたためには、もつと作品の実質に関係ある、謂はば有機的理由ありとする人々があるであらうが、恐らくそれは間違つてゐる。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなき浪の蕩揺に、汝はなが魂打眺む……「なーるほど…」と思ふのは、恐らくボオドレエルが私自身より意識的であることに気が付くからである。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、恐らくそれは当つてもゐよう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、信義に乏しい現今は、芸術家達が、恐らく甚だしい孤独に逐ひ込められてゐる筈である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに芸術にとつてそれから恐らく人間性にとつても不幸な世の中なのであらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――恐らくそれはさうであらう。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが短歌より出て来たものだとしても、既に短歌と訣別して、新しい領土に立つてゐることも恐らく間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく現に生存してゐる歌人諸氏が、最後的のものであらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は、一物と他物との合体の瞬間に於ける妙といふことを、非常に大切にしたのであるが、そして恐らく此の事こそ俳句の最高眼目たるものでもあらうが、その眼目が射当てられるためには、蓋し情理的であるよりもおのづと感覚的である方が適切であるに相違ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくそれは彼女の不幸に充ちた生活のことを云つてゐるものであらう。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくＢとしたことが、眼前に起つたことは何にもあれ批判するのがその生来なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく後者だと私は思ふ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、アツサリ取消しはなかつたことと、私は思ふのであります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉が如何に現実にとつてまどろつこしいものであるかは、諸君も先刻御承知であらうし、恐らく諸君が考へてゐられる以上にそれは事実だ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の心の奥底を動かすものは、却て人が毎日いやといふ程見てゐるもの、恐らくは人々称んで退屈となす所のものの中にあるのだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくに私自身の背後にもまた、その同じ二つの投影を見たことであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、彼はその生涯を通じて、叙情詩以外の何物をも書かないであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚まもなく若い稚気のぬけなかった夫人は、恐らく恐怖にふるえながらも、人生の最も楽しく忘れ得ない夢を経験したのだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし最近の如く、彼が詩に深い接觸をもち、詩的の實精神に憧憬し、殆んどそれによつて文藝觀の本質に突き入らんとするが如きは、恐らくかつて見なかつた所だらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、これが叙事芸術の抒情芸術に先立つて発達した所以である。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといふも恐らく通俗小説の方がより豊富な伝統を持つてゐたといふか、それとも通俗小説の方が小説よりも一層に容易に伝統から得をすることが出来たといふかそのどつちかであると思ふ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく「ああいふもの」と、貴方にも私にも互ひによく分つてゐるから「ああいふもの」なのですが「ああいふもの」だといふ以外に、此の場合他の如何なる言葉も帽子の属性なり用途なりの指示に止るほかはないでせう。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一、比喩的に云へば、太初には「消費」と「供給」は同時的存在だつたが、人類は恐らく「食はねばならぬ」とか「身を防がねばならぬ」といふ消極方面のことに先づ走つたので「消費」の方は取り残された。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その設定を何と名付けようと勝手だが、恐らくそれこそ人類が「神」と呼んで来たものの起原に相違あるまい。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、先に云ふ「血迷つた粗朴さ」が、今後うまい具合に立ち直つてゆくとすれば、恐らく詩に対する関心を増すことともなるのであらうと思はれるのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
