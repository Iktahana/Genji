        "examples": {
          "standard": [
            {
              "text": "優しい言葉をかけてくれた。",
              "source": "幻辞"
            },
            {
              "text": "優しい人間関係を築く。",
              "source": "幻辞"
            },
            {
              "text": "優しい表情で見つめる。",
              "source": "幻辞"
            },
            {
              "text": "優しい音楽を聞く。",
              "source": "幻辞"
            },
            {
              "text": "優しい接し方を心がける。",
              "source": "幻辞"
            },
            {
              "text": "優しい思いやりの心。",
              "source": "幻辞"
            },
            {
              "text": "優しい雰囲気の中で過ごす。",
              "source": "幻辞"
            },
            {
              "text": "優しい先生に感謝する。",
              "source": "幻辞"
            },
            {
              "text": "優しい親に育てられた。",
              "source": "幻辞"
            },
            {
              "text": "優しい笑顔が素敵だ。",
              "source": "幻辞"
            },
            {
              "text": "優しい手で支えてくれる。",
              "source": "幻辞"
            },
            {
              "text": "優しい言葉で励ます。",
              "source": "幻辞"
            },
            {
              "text": "優しい扱いをしてくれた。",
              "source": "幻辞"
            },
            {
              "text": "優しい心を持つことが大切。",
              "source": "幻辞"
            },
            {
              "text": "優しい風が吹く。",
              "source": "幻辞"
            },
            {
              "text": "優しい色合いの景色。",
              "source": "幻辞"
            },
            {
              "text": "優しい性格の人が好きだ。",
              "source": "幻辞"
            },
            {
              "text": "優しい対応に感謝する。",
              "source": "幻辞"
            },
            {
