[
  {
    "uuid": "8efab7b5-c4c4-5b4a-a65c-baa09b438ecd",
    "entry": "恩命",
    "reading": {
      "primary": "おんめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
