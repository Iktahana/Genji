        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今病人に指さされし時、件の男は蒼くなりて恐しげに戦慄きたり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも怪我は免れぬところと、老いたるは震い慄き、若きは凝瞳になりて、ただ一秒ののちを危ぶめり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "呆るるよりむしろ慄きたるなり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた絶えず、悩ましの角光り電車すぎゆく河岸なみの白き壁あはあはと瓦斯も点れど、うち向ふ暗き葉柳震慄きつ、さは震慄きつ、後よりはた泣くは青白き屋の幽霊。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる神秘、落ちついた真青な輝き……暗い深夜の秘密に密醸された新鮮な酸素の噎びが雨後の点滴と相連れて、冷たい霊性の火花も今真青に慄き出した。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊佐、君の事ぢやないか、何を※然してゐるのだ」　彼はほとほと慄きて、寧ろ蒲田が腕立の紳士にあるまじきを諌めんとも思へるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "王問うてその鐘に血を塗るため殺されに之くを知り、これを舎せ、われその罪なくして慄きながら死地に就くに忍びずと言う。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "俯して之に臨めば、心慄き、目眩す。",
              "citation": {
                "source": "金華山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりぼつちで、靜かに蠶室の桑の葉のあひだに坐つて、幽かな音をたてては食み盡くす蠶の眼のふちの無智な薄｜褐色の慄きを凝と眺めながら子供ごころにも寂しい人生の何ものかに觸れえたやうな氣がした。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かためらふ何かためらふ、内気なるわが繊弱なるたましひよ、幼児のごと慄きてな言ひそ、死をば避けましと。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、ただ、この迫つて来る力を前にして、恐れ、戦慄き、泣き、叫び、涙を流すだけなんだ。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ戦慄きて薪を投ぐる響をきけば、断頭台を人築く音なき音にも増りたり。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅仙女は恐れ慄き、江柄三十郎は石に打たれたように打ちひしがれました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            },
            {
              "text": "其言聞きて可憐なる老王そぞろ慄きつ、車馬の備を命ずれば、從者はとみに從へり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "神ポイボス・アポローン盾動かさず保つ間は、彼此二軍の羽ある武器互に壯士斃れしむ、されど眞ともにアカイアの軍勢睨め大音に、　320叫びて盾を揮ふとき、彼らの心胸中に恐れて震ひ慄きてその勇猛の意氣忘る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "額にびっしり汗をかき、ガクガクと震え慄きながら、私は気合で一歩を進めた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何か怖ろしい悪魔でも見うけたように慄きが背を走った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃の地震に、心の支柱をとり外し、気でも狂わせ給うたか」　と、惜しみもし、慄きもした。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば、嗚咽と変りそうな慄き声を、実平は強いて、励ましながら、言葉をつづけた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が佳境に入って来ると、ヘルンは恐ろしそうに顔色を変え、『その話、怖いです、怖いです』といっておののきふるえた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓えてや弱々しき声のしかも寒さにおののきつつ、「どうぞまっぴら御免なすって、向後きっと気を着けまする。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に物狂いの大晦日の露店の引き上げた跡の街路には、紙くずやら藁くずやら、あらゆるくずという限りのくず物がやけくそに一面に散らばって、それがおりからのからび切った木枯らしにほこり臭い渦を巻いては、ところどころの風陰に寄りかたまって、ふるえおののきあえいでいるのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おののき震うと同じ状なり。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手はおののきて筆の運びも自在ならず。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私がそいつを縊り殺したからさ」「あ、あ、あなたがザバタスなんですか※」当人はおののき※えて叫んだ。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間に対して、いつも恐怖に震いおののき、また、人間としての自分の言動に、みじんも自信を持てず、そうして自分ひとりの懊悩は胸の中の小箱に秘め、その憂鬱、ナアヴァスネスを、ひたかくしに隠して、ひたすら無邪気の楽天性を装い、自分はお道化たお変人として、次第に完成されて行きました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれから先き生きているなら、どんなにして生きていられるだろうかと想像して見ると、その生活状態の目の前に建設せられて来たのが、如何にもこれまでとは違った形をしているので、女房はそれを見ておののき恐れた。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが唯一のおののき　考えてみると、私たちはこうして文章が書けることだけでも、まだしも仕合せであった。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれの処女作の評判をはじめて聞く、このつきさされるようなおののき。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おののきつつ、前世の自分は、その木乃伊が前々世の己の身体であることを確認せねばならない。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
