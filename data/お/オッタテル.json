            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
