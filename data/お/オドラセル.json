      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to manipulate (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは、わずかに数本の箸と手ぬぐいとだけで作った屈伸自在な人形に杯の笠を着せたものの影法師を障子の平面に踊らせるだけのものであった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから矢張外道奴の所作と見えて、家々の道具に為込んである時計や置時計が魔法で踊らせるやうに踊り出した。",
              "citation": {
                "source": "十三時",
                "author": "THE DEVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "地蔵が踊るのじゃあねえ、踊らせるのですよ」「そうだろうな」「あの寺はね、林泉寺の向うを張って、縛られ地蔵を流行らせたが、長いことは続かねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "延光が歿しましたので、唯今の俊乗がそのあとを継いで役僧を勤め居ります」「縛られ地蔵もだんだんに流行らなくなったので、今度は地蔵を踊らせる事にしたのですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴熊というのは、いかさま博突などをする場合、その同類が床下に忍んで、細い針を畳越しに突きあげ、むしろの上に投げられた賽を自由に踊らせるのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の試みに成功したので、地蔵を踊らせるのは源右衛門の役になった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は何か歌いながら、その蛇を踊らせるのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕を挙げ、脚を蹴り、水を吹きして身を踊らせるのであつたが、たゞ見たところでは弱々しく邪魔にもなりさうもなく漂ふてゐる多くの水藻が、執拗に四肢にからまりついて、決して自由な運動が出来ないのである。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷い湿気を含んだ風が時々それを踊らせる。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫と黄色と白と土橋を胡蝶並びて渡りこしかな　たとへば日本舞踊で清姫のやうな美姫を三人並べて踊らせる舞台面があつたとする。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンドリンをひいてるコスマも、人形を踊らせるためにひいてるのではなく、人形からむりにひかせられてるようでした。",
              "citation": {
                "source": "活人形",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この度私が人形をひとりで踊らせる術を、神から授かりましたので、それを皆様にお目にかけます。",
              "citation": {
                "source": "人形使い",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は、伊豆辺の鹿島踊りと言ふのは、もつと間の長いものなのを、狂女に踊らせる為に、あゝ言ふ風に間をつめたのかも知れません。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影法師を踊らせることを、教えてやろうか」「え、おじさんはそんなことを知ってるの。",
              "citation": {
                "source": "影法師",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻を伸ばしといて踊らせるのはずるい」　見馴れない子供は、ただにこにこ笑っていましたが、みんなからずるいずるいとあまりいわれますと、それじゃも一度やり直そうといいました。",
              "citation": {
                "source": "天狗笑",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形を踊らせる箱をてらと称するが、内地のほこらと同じやうなもので、寺とは全く違うてゐる。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、前面の開いた箱を首にかけて、其中で、小さな人形を踊らせる。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中で、人形を踊らせるのだから、此には芸能以上の意味を以つて、考へられたものがあつた、と見なければならない。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちかごろのあなたは、まるであたしを踊らせることに夢中ぢやないの。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "このダンスホールは会員組織の形式を備えていたがフリの客をも吸収して勿論踊らせるのさ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊らせる方がよほど引き立つ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十五　赤罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "尺取り虫を踊らせる、奇態な女芸人がいるところから、人呼んで尺取り横町……その名物の本尊がなくなった。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその声に融け入って、その声とともに、歓びに心を踊らせるのである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その舞台の上に、存分に庶民を踊らせる捕物小説は、われらにとっては、まことに素晴らしいファンタジーである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説は楽し",
                "note": "青空文庫"
              }
            },
            {
              "text": "報道や批評は外でもない、ブルジョア社会道徳劇の善玉と悪玉とを踊らせる機会に過ぎなくなる＊。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊針を踊らせるためで、さざ波を立てて蚊針をほんとうの虫に見せようとするためである。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そして、僕の音楽を読んだあとに、小娘どもを踊らせるために、大音楽家の作品を去勢してくだらないものになすこと以外には、何も頼むような仕事はないというんですか。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ憂うるところは彼等を踊らせる舞台廻しがいないことだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が叩いている音楽に、無断で合せて犬を踊らせるのは、怪しからんじゃないか、と発田はなじっているのらしかった。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの事を書くのは、天恵多き我国のいずくに於てか、人種の異る外国人が、多少酒の影響を受け、而も相撲というような心を踊らせる演技を見たばかりの群衆の間を、何かしら侮蔑するような言葉なり、身振りなりを受けずに、通りぬけ得るやが、質問したいからである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
