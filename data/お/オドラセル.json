[
  {
    "uuid": "94f3c537-eaa4-5176-9b21-14be50a4fb4f",
    "entry": "踊らせる",
    "reading": {
      "primary": "おどらせる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
