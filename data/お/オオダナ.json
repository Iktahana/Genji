        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "宅へ帰ってどうすると云うあてもないので、銀座通りをぶらぶら歩き、大店のガラス窓の中を覗いてみたり雑誌屋の店先をあさってみたり、しばらくはほとんど何事も忘れていた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみよの兄という人が下町のある大店に勤めていて、その兄の方から月々の仕送りを受けているのだと母のおちかは吹聴していたが、その兄らしい人が曾て出入りをしたこともないので、近所ではそれを信用しなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗜も気風もこれであるから、院長の夫人よりも、大店向の御新姐らしい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場から連れて戻って、否応なしに、旦を説付けて、たちまち大店の手代分。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六が一人前の番頭になった時分、瘠我慢を張って大店の旦那衆の遊び仲間に入ったことがあった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの堅気な大店の旦那が一通りならない浮世の苦労をしたのち無事に隠居をして晩年の余技にいささか風流を弄んでいるという風格の人物以下には見えなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "癪、癪でして、ええ、そもそもＢＢ旅館なるものが、そりゃあ本斗一の大店でしょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大店のＢＢの肩ばかり持ちやがって、成っちゃいねえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ狭い場所に大きい建物が続いている上に、こんにちと違って江戸時代の吉原は、どんなに立派な大店でも屋根だけは板葺にする事になっていたんですから、火事の場合なぞはたまりません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが江戸でも屈指の大店を張っている大仏師東雲の店初めての金高でありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中、未亡人も没し、政吉氏も亡くなって、とても大店がやって行けなくなり、手元は不如意がちでついに店を人手に渡すことになりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "東雲師の家の跡のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "間口の広い大店にて、店さきの土間にも店の左右の地面にも、金物類が沢山に積んである。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年ほど前からあるのであるが、最近、素晴しく美しい女が、チョイチョイ店へ出るというので、にわかにワッと人気が立ち、白首、地まわり、ごろん棒、おつにひねったイカ物食い、そういうこれまでの馴染以外、相当立派な侍や、大店の若旦那というような者まで、昨今は出入りをするようになった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、或る人のいうには、「何某の大店の表看板を打ち毀して、芝の愛宕山へ持って行ってあったそうな。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "一度家に帰り父に誡められたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は町内の路地のなかに住んでいるお北という若い女で、以前は柳橋で芸奴を勤めていたのを、日本橋辺のある大店の番頭に引かされて、今ではここに小ぢんまりした妾宅を構えているのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "安のような職人とは違って、みんな大店の若旦那だから、さすがに自分が出て行くと云う者はねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は大店の若旦那株だから、嚇かせば金になると思って啖い付きました」「その相摺りは三八ですか」「三八は五十両でおとなしく黙っていたのですが、お葉の亭主の松五郎には銀六という子分がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら大店でも、その時代の三百両は大金で、部屋住みの息子の自由にはならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、それは大店だけのことだが、市内で、比較的廉価な遊びが出来るものだから、わざ／＼遠くまで出張に及んで高い金を払ふ必要がないといふ論者が可なりに多い。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が没趣味だとすると、私の身分ではもう売女に触れて研究する外はないが、これも大店は金が掛り過るから、小店で満足しなければならん。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の××宝石商は、東京でも屈指の大店で、時価八十万円の首飾りが、一夜盗賊のために盗み去られたのであります。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "午睡で皺になった着物にも頓着せず、素朴で、関わないその容子は大店の帳場に坐る人とは見えなかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供がよく遊びに来るので、近しくしていた向うのある大店の通い番頭の内儀さんも、その子供をつれてやって来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小いところから仕上げて大きくなって行った、大店の成功談などに刺戟されると、彼女はどうでも恁でもそれに取着かなくてはならないように心が焦だって来た。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "其一は貧家の妻が夫の恋を遂げしめむがために金を儲へ、終に夫を吉原｜大店のお職に逢はせたと云ふ物語である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "南側の高麗橋筋には三井、岩城桝屋等の大店がある。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の大店の旦那様の処へ行くと、大そう喜んで家の宝にするとて言い値で買い取ってくれたので、男は驚いて大金を持って帰って来た。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お城に近い日本橋｜両替町（現今の日本銀行附近）にかなりの大店であった、書籍と両替屋をかねて、町役人も勤めていた小熊という家もその数には洩れなかった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
