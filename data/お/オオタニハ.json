          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、この時に今日の東西本願寺――本願寺派本山のお西と、真宗大谷派本願寺のお東とが分岐した。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "大谷派の本願寺の三代前の法主大谷光瑩さんの落しだねだといふうはさが、古くからあつた。",
              "citation": {
                "source": "宗十郎を悼む",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "木津の唯泉寺（大谷派）の本堂が曲つて、棟の上で一尺五寸も傾いた。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙片と鉛筆を出して姓名を請うたら、斗満大谷派説教場創立係｜世並信常、と書いてくれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雑誌の中を見ると大谷派の能海寛氏がチベットの国境まで行かれたが、その関所の官吏のために追い返されたという記事が、日本のある新聞から翻訳されて載って居ります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
