        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのうちに、始めに出た極度の大声を出す人が壇上に立ってまた何事か述べはじめた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝶が、蝶が、蝶が来やがつた、」　三人の客の一人が大声を出すので童顔の男はふと顔をあげた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（下りの汽車が間もなく通過するのだ）庄平「やあ、また会いましたね」（と大声を出す）節子「京都でお会い出来るとは思いませんでしたわ、昨日奈良でお眼に掛ったばかしですもの」（とこれも少し大きな声で言う）汽笛の音。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大声を出すといふ場合には何でも彼でも思はずソレが出てしまふぢやないの！",
              "citation": {
                "source": "山を降る一隊",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお……」　彼はもう少しで大声を出すところだった。",
              "citation": {
                "source": "幸運の黒子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただ一言申し上げたいのですが、人に聞こえますほどの大声を出すこともどうかと思われますから、少しお開けくださいませんか。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕が君の細君に連れられて支倉の宅へ行った時には、何だか騒ぎがあったようだね」「――――」「細君が、お篠さんとか云ったね、大そう腹を立てゝいたじゃないか」「あいつはどうも無教育で、所構わず大声を出すので困るのです」　浅田はポツリ／＼答えた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に半三郎は何か大声を出すが早いか、三尺ばかり宙へ飛び上った。",
              "citation": {
                "source": "馬の脚",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は誠一を大村へやっているので、幼稚園へゆくカヤノとばあさんと三人暮らしだが、三人とも大声を出すことはない。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人さみしく、大声を出すこともなく暮らし慣れて、世の中はこのようなものとカヤノも幼な心に思いこんでいたらしい。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上で誰やら大声を出す。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞こえないまでも人を呼ぼうかと思ったが、大声を出すとバランスがくずれそうなので。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と思わず源右衛門が大声を出すと、女が手を振った。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "浮世芝居女看板",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと身体を振る、大声を出す、そうして勝手に読む、時には喧嘩を交える。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな大声を出すと、家の人がみんな吃驚するじゃないか。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやよ、私に触ってごらん、大声を出すわよ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "本館の大浴場へ、清も共に入る、ガラの悪い客が大声を出すので出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでスプーンが運ばれ、もうデザートかとあはてゝ、「僕は、もっと食ふぜ」と大声を出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "力ずくで入るなら、大声を出すぞ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "大声を出すとか、召使いを呼びたくなかったので、だまってそのまま引き下がるしかありませんでした」「旦那が返事を拒否したと言うことですか」「そういうことです、フィル。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "気鬱のときは、大声を出すが妙薬である。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の府県の千度詣りにもこれはよくあることで、あるいはエイエイと力のこもった大声を出すので、これをエイエイ祝詞という土地もある。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
