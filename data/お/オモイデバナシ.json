        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もちろんこれは自分等の年輩のものの自分勝手な見方ではあろうが、こうした見方もあるいは現代の俳人に多少の参考にはなるかもしれないと思ったので思い出話のついでに拙ない世迷言を並べてみた次第である。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつでもまるで海老をうでたように眼の中まで真赤になっていた」という母の思い出話をよく聞かされた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出せば私が三つのとき、というような書きだしから、だらだらと思い出話を書き綴っていって、二歳一歳、しまいにはおのれの誕生のときの思い出を叙述し、それからおもむろに筆を擱いたら、それでよいのである。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もまた、そのような手管はいやでなく、この赤児の思い出話にひとつ巧みな手管を用いようと企てたのである。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを赤児の思い出話のあとさきに附け加えて、そうして姿勢の完璧と、情念の模範と、二つながら兼ね具えた物語を創作するつもりでいた。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに、学校を出て、後でその頃の学友と思い出話をしてごらん。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あなたもわが東北文化のために大いに自由｜闊達に、当時の思い出話を語って下さい。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実朝の近習が、実朝の死と共に出家して山奥に隠れ住んでいるのを訪ねて行って、いろいろと実朝に就いての思い出話を聞くという趣向だ。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこんな思い出話を以て、私の家の宗派の親鸞の教えにこじつけ、そうしてまた後の、れいのデモクラシイにこじつけようとしたら、それはまるで何某先生の「余は如何にして何々主義者になりしか」と同様の白々しいものになってしまうであろう。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが深田氏の、太宰についてのたった一つの残念な思い出話になるのだ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その思い出話といったようなものが、一千一夜式に書けないものだろうか……。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしかたなしに監督に向きなおって、その父に当たる人の在世当時の思い出話などをして一人｜興がった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辰の思い出話は一生いいますぜ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は私にあまり手を触れないようにと注意しながらも、あたりの衣類を指して、思い出話をするのでした。",
              "citation": {
                "source": "虫干し",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それについての思い出話を新聞紙上にも書いたが、それからそれへと繰り出して考えると、まだ云い残したことが随分ある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文芸倶楽部の誌上に思い出話を書くにつけて、今更のように月日の早いのに驚かされます。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『文芸倶楽部』の誌上に思い出話を書くにつけて、今更のように月日の早いのに驚かされます。",
              "citation": {
                "source": "半七捕物帳の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋で、彼女のさまざまの思い出話を聞いたり、文学の話をしていると五時ごろにお寺の太鼓が鳴り出して、夜が白々と明けて来るので、びっくりして寝床へ入ることもあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い時の楽しい思い出話に倦まない葉子にとって、そこがどんなにか懐かしい場所であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "東郷元帥というひとが、日本の資本主義の発展のために、欠くべからざるものであった過去の戦争において、巨大な功績をのこした人であり、人格的に卓越した将であったことは、近頃種々の刊行物にあらわれている日露戦争の思い出話のうちにも十分に窺える。",
              "citation": {
                "source": "花のたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらを書こうとすると、事件や感じがあまり自分だけのことであったり、罪ない思い出話以上のものになるおそれがある。",
              "citation": {
                "source": "入学試験前後",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の事情では、そのような思い出話を、ゆっくりきくにふさわしいような機会もなく、過ぎていたのであった。",
              "citation": {
                "source": "『地上に待つもの』に寄せて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　前科者同士がよく出獄当時の思い出話をしながら、こう言っては笑う。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇が若い皇太子としてフランスに行っていたころの平民的な思い出話。",
              "citation": {
                "source": "ジャーナリズムの航路",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の一年ばかり前、或る海岸で珍しく父は幼年時代の思い出話を私にしてくれた。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや祖母の昔話の中では正確な年代も消えて、僅にのこった色濃いところどころが、思い出話のよすがとなっているにすぎなかったのである。",
              "citation": {
                "source": "明治のランプ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か耳新しい一つ話か思い出話が出るかと思って、心臓に氷嚢をあてながらも寝ないで柱にもたれ、明け方までいろいろな人に混っていたのであったが、誰もそんな話を切り出すひとは誰もなかった。",
              "citation": {
                "source": "母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚第一日目から父は祖父と客間で食事をし、母は姑その他と茶の間で食事をし、時にはあんまり二人で話が出来ない日が続くので、手紙を書いて紙つぶてにして話し合ったという思い出話さえ聞いています。",
              "citation": {
                "source": "わが母をおもう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父のそうした思い出話を多少のくすぐったさを以て聞いたものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ子は母の老いたことを沁々感じ、さっき彼女自身、祖母について云った口うらから、母が飽きず思い出話をするのが、水のように淋しかった。",
              "citation": {
                "source": "白い蚊帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
