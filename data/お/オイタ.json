        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同人中の谷丹三が牧野さんを知つてゐたので、その夜来て貰ふやう頼んでおいたのであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについて自分は、旧著『詩の原理』に詳しい解説を述べておいた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "募集した絵をゆっくり一枚一枚点検しながら、不折や虚子や碧梧桐を相手に色々批評したり、また同時に自分の描いておいた絵を見せたりして閑談に耽るのがあの頃の子規の一つの楽しみであったろうということも想像される。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一部が英訳されているのをおもしろそうだと思って買って来たまま、しばらく手を触れないで打っちゃっておいた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "草原の草を縛り合わせて通りかかった人を躓かせたり、田圃道に小さな陥穽を作って人を蹈込ませたり、夏の闇の夜に路上の牛糞の上に蛍を載せておいたり、道端に芋の葉をかぶせた燈火を置いて臆病者を怖がらせたりと云ったような芸術にも長じていた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んでくるあの飛行機には、昨日私が昆虫の涙を塗つておいた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕪翁のわが詠み捨てた句は、一つとして辞世ならざるはなしの徹底芸術精神は、学んで到り得るにあらねども、一｜順礼の最後の足跡までに、印をつけておいた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは訂正しないでそのままにしておいた。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして縁側の軒端に吊しておいた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鍋を火山の火にかけて一晩おいた後に一番鶏が鳴いたら蓋をとってみようと思っている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めに入れておいただけの物が煮爛れ煮固まっているに過ぎないだろうとしか思われない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋が滿員の場合には入口に「滿員」の札でも出しておいたら便利であらう。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日汽車の窓から見ておいた浦和附近の森と丘との間を歩いて見ようと思つたのである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある地方では同様な碑を、山腹道路の傍で通行人の最もよく眼につく処に建てておいたが、その後新道が別に出来たために記念碑のある旧道は淋れてしまっているそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だってあのおいたさんを遊ばせながらだもの。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、傍で砂いじりしている子はおいたさんと呼ばれるほどの一くせありげないたずらっ子の男児だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのえだにおいたの。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が来たときしばらく待たせておいたのもその手配をするためだったのか。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹がれいですよ」と訂正したかったのを村上に遠慮してよしておいたのである。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがそこは芝居であるからこのミルクホールの店先を肝心の夕刊嬢が丁度そのときまるで打合せておいたように通りかかる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先日バラの苗やカンナの球根を注文するために目録を調べたときに所在をたしかめておいた某農園がここだと分かった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海洋に関する物理的事項の重なるものについては近頃出版した拙著『海の物理学』にその梗概を述べておいた。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一｜匁の分銅を一分間吊した後と、一時間あるいは一昼夜吊しておいた後とは幾分の差がある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう物の運動に関係した問題に触れ初めると同時に、今までそっとしておいた力学の急所がそろそろ痛みを感ずるようになって来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りになるべき新しい利器を求めている彼の手に触れたのは、前世紀の中頃に数学者リーマンが、そのような応用とは何の関係もなしに純粋な数学上の理論的の仕事として残しておいた遺物であった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の音韻と題しておきましたが、現今の言語研究の上に「音韻」と「音声」とを区別して使うことがございますけれども、先ずこのお話では、格別そういう厳密な区別を設けないで、ただ音韻と言っておいたので、つまり言語の音のことでございます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは実は私が写しておいた本を土台にして出したのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし我々からみれば発音の区別に基づいたものであると考えられるのでありますが、それは後に述べることにして、まず仮名の使い分けとして考えておいただけでもよいと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『万葉集』は編纂した者は一人かも知れませんが、それの土台になったものは非常に沢山あって、色々の昔の歌集や歌を書いておいたものなどを集めて来たもので、決して或る人が始めて書きおろしたものではありませぬ。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだものを出かけにもあの位願つておいたのに。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
