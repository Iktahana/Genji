          ],
          "literary": [
            {
              "text": "しかしながら「いき」の意味を成すにはなお重要な徴表を欠いている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、きょう配給になったばかりのおミソをお重箱に山もりにして、私も置きどころが悪かったのでしょうけれど、わざわざそれに片足をつっ込まなくてもいいじゃありませんか。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ、お重ねなさいまし、すぐにまたまいります。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "法印さんの処から貰って帰ったお重詰めは、箸をつけないまま煎餅布団の枕元に置いてあった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお重ねて頂戴しよう。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海苔巻でも持つて行くと、不取敢それを一つ頬張つて、風呂敷と空のお重を私に返しながら、『お有難う御座んすてなツす。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそれながら、王には、ゆりの根のようにお重なりになったお歯がおありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどこの山はなお重霧の間に在りて、いつ往きつかんも、否、果たして往きつきぬとも、わが中心に満足を与えんも定かならず。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずちっとお重ねなされまし」と、彼女が銚子をとろうとすると、外記は笑いながら頭をふった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご不承か」　いうことばのはしばし、名は名のらなかったが、まさしく加賀家のお重役です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと買ってけえって、お重に詰めて、あしたの朝ははええんだからな、いつでも役にたつようにしたくしておきな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "お重も、かまぼこも、瓢も、ちゃんともう用意ができているんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は愛相よくそれを迎へて、屠蘇の道具やお重のものなどを運んで煮ものを取配けたりした。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "またも昔の話が出て、子息の縁組みその他のことで昔に増した濃い親戚関係を持つことにおなりになった二人は、睦まじく酒杯をお重ねになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々に濃くした鈍の幾枚かをお重ねになった下には黄味を含んだ淡色の単衣をお着になって、まだ尼姿になりきってはお見えにならず、美しい子供のような気がしてこれが最もよくお似合いになる姿であるとも艶に見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は次々に差し上げる盃を二つ三つお重ねになった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お師匠さんが、もういい加減に独り立ちしてみたらどうか、って仰言って下さいますが、なんせ、まだまだ心許なくて、こうやって玉子の殻をくっつけたまんまお傍にぬくもっている始末です」　銀三は奥へ気を兼ね、声を低めて、なお重ねた。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、こう独り言をいいながら、ふろしき包みをほどくと、大きなお重箱にいっぱい、おいしそうなお団子がつまっていました。",
              "citation": {
                "source": "和尚さんと小僧",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧はにこにこしながら、お団子をほおばって、もう一つ、もう一つと、食べるうちに、とうとうお重箱にいっぱいのお団子を、きれいに食べてしまいました。",
              "citation": {
                "source": "和尚さんと小僧",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうち、ふと何か思いついたとみえて、いきなりお重箱をかかえて、本堂へ駆け出して行きました。",
              "citation": {
                "source": "和尚さんと小僧",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お隣のおばあさんが、お重箱を持って来ました。",
              "citation": {
                "source": "和尚さんと小僧",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、和尚さんの褒め言葉の終らぬうちに、文吾の小ひさい掌は、お重ねをして、和尚さんの鼻ツ先きに出てゐた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "女「柳橋のお重でございますよ。",
              "citation": {
                "source": "明治の地獄",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩「なる程芸妓のお重さんだ、お前は虎列剌で死んだのだ、これはどうも……此方へ来てから虎列剌の方は薩張よいかね、併し並んで歩くのは厭だ、僕は地獄へ行くのは困るね、極楽へ行きたいが、何方へ行つたら宜からう。",
              "citation": {
                "source": "明治の地獄",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなた、いつぞや、お重役衆が、わしについて何か仰せられていた話を聴かせてくれたであろうがな――な、思い出したであろ？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、お坊さん、お酌、女のあたしが、一杯一杯のやりとりはきつすぎる――まあ、お重ねな」　すすめ上手に、いつか、法印、すっかり酔わされて、まるでうで蛸のようないろになってゆくばかりだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どうぞ、お重ねなすって」　云い云い女は片頬で笑い、上眼を使って流すように見た。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ひとまず旅籠へおちつくか、藩のお重役――お奉行様へなり、お縋りして事情を話し……」「さあそれは考えものだ」範之丞は首を振った。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かおじゅうひげにうずまったきたない男が、そっと、中をのぞいているのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、かおじゅうひげにうずまった、えたいの知れない男が、とほうもないことをやりはじめるのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
