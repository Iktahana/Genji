        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "父親は賭博するのが判っているから停めるのだと押さえつける。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼を押さえつけると、私の友人は合図の甲走った声を発すると、外の舗道の上には、靴音の急ぐのがきこえ、やがて正面の入口から、二人の制服巡査と、一人の私服の刑事巡査とが上って来た。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟詰めの禁欲論、味もセセラもない利害得失論で少年少女の不良性を押さえつける事が不可能な事を知った学校と社会とは、慌てて方針を立て直した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは犯人はその写真の男ではないのか」「むろん写真の男さ、けれどももう石川五郎とは名乗っていないのだ、だから僕はこの男が今どんな姿をして、どこにいるかを推定したのさ」　私はむらむらと湧きいずる好奇心を押さえつけることができませんでした。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と俊夫君は押さえつけるように言いました。",
              "citation": {
                "source": "自殺か他殺か",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私を押さえつける不愉快なものが一つあった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戦争をどうするか――だ」藤本が押さえつけるようにいった。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして押さえつけるような声で、「いいええ、ほんまのとこたまりゃしませんぞな。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽しい経験は長いあいだ覚えているが不愉快なものは押さえつけるのと同じように、成功した治癒は注意深く記録されるが失敗はすぐに忘れられる。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夕には、あるしめやかな永遠な喜びの下に人の悲しみを押さえつける清朗さがあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿気を充分にはらんだ強い真夏の陽ざしが、日常のぜんたいをくまなく押さえつけるように、あらゆるものの上に注いだ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒衣婦人は心中に湧き上がってくる大きな化物みたいなものを、押さえつけるのに一所懸命だった。",
              "citation": {
                "source": "黒蜥蜴",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃべってはいけない、しゃべってはいけないと押さえつければ押さえつけるほど、喉の奥から蓄音器のように、そのしゃべってはいけないことだけが、勝手に飛び出してくる。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが無意識な軽微の慢性的郷愁と混合して一種特別な眠けとなって額をおさえつけるのであった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、久助君を上からおさえつけるときの、相手のやせた腕が、ぶるぶるとふるえている。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとなしく、だだをこねずに、奥さんのお対手をなさいよ」　年増はおさえつけるようにして讓を寝台の縁へかけさした。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこらじゅうにある食物をできるだけ多く占有するように両の前足の指をできるだけ開いてしっかりおさえつける。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、「船長」と太い、低い、重々しい声がおさえつけるように、ストキの口から呼ばれた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ二十分も、おさえつけるような沈黙がつづいた。",
              "citation": {
                "source": "鉄の規律",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまず、窓のガラスは、外から大きな蒲団でかくし、その上に、長い板をもってきて、蒲団をおさえつけるようにして両端をとめた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき会長のおさえつけるような声が闇の中にした。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "車上でも、山木たちは、はあはあひいひいと笑いもがき、それをそうさせまいと思っておさえつけるマートンたちの努力はたいへんなものだった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は左手でパイ缶を持ち、右手には皿を持ち、その皿でパイ缶を上からおさえつけるようにしている。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は早いところ、話をつけようじゃないか」頭目四馬は、おさえつけるような太い声で戸倉老人にいった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪魔め」　老人は大あばれにあばれたいらしいが、手足のいましめは、ぎゅっとおさえつける。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子天井は、容赦なく僕の頭をおさえつける。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれかが、かれのからだをおさえつけるのをふりきって上半身を起した。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きてはよくない」　その怪物は、ポコちゃんのからだをおさえつける。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、かれのからだをおさえつける怪物の腕が実に三本もあることを、このときになって発見したからである。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりゆわえておけよ」　無言の太刀川を、五人ばかりでおさえつけると、両脚に、鉄でつくったゲートルのようなものをはかせ、その合わせ目に、ぴーんと錠をおろし、更に鉄のゲートルの穴に、二本の重い鉄の鎖を通した。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
