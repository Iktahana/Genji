        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "子供が浪打際で寄せたり退いたりしている浪に追いつ追われつしながら遊ぶように、自分は鏡のなかの伎楽の面を恐れながらもそれと遊びたい興味に駆られた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の映画でよくある場面は一群の人間と他の一群の人間とが草原や川原で追いつ追われつする光景をいろいろの角度からとったものである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど普仏戦争のように、黄色い太陽の下を思い出し思い出し、追いつ追われつ、往きつ戻りつ、毎日毎日、日もすがら繰り返して止まぬ。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹は純白で、一匹は黒斑で、どこから啣えて来たか知らず、一足の古草履を奪合って、追いつ追われつ、起きつ転びつ、さも面白そうに狂っている。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "素袍、狩衣、唐衣、綾と錦の影を交えて、風ある状に、裾袂、追いつ追われつ、ひらひらと立舞う風情に閨を繞った。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とき／″＼反則をしたと言っては争いを起し、追いつ追われつ無軌道に駈け廻ります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてパイプに火を点じ、後ろに寄りかかって紫煙の輪を眺めていると、互いに追いつ追われつ天井裏に這い上ってゆく。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いつ追われつ、草花を採ったり小石を拾って投げたり、蛇がいたと言っては三人がしがみ合ったりして、池の岸を廻ってゆく。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むらがる蝶は狂っているのか戦っているのか能く判らなかったが、ともかくも入りみだれて追いつ追われつ、あるいは高く、あるいは低く、もつれ合って飛んでいる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘いはその大木の二、三本を前にした小さい家の内そとを足場にして、追いつ追われつ挑み合っているらしく、小勢ながらも必死の敵をあしらいかねて、討っ手も少しく攻めあぐんでいるようにも見られた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "霙と日の光とが追いつ追われつして、やがて何所からともなく雪が降るようになった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　かくして、追いつ追われつしながら行くこと十町。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の文字のお話しの、惜しいところであと絶えて、　石神様のお話しは、わが身の上の事となり、　白髪小僧と青眼玉、それに妾と三人で、　追いつ追われつ行く末は、真暗闇の森の中。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装だけのコムソモーレツとコムソモールカとが、超現実的に追いつ追われつ、爪先踊りをやって、メデタシ、メデタシになって、最後の五ヵ年計画バレー化に到っては、問題の外だ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の晴天を嬉しがっているのか、孵った蠅の若者達がこの世万歳と遊んでいるのか、追いつ追われつ敏活に翔び廻っているうち、一匹の蠅がいきなり薬紙にぶつかった。",
              "citation": {
                "source": "蠅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "グルグル廻る太陽と、前後左右に吹きめぐる風と、戦争のように追いつ追われつする砂ほこりを見た。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……逢っては別れ、別れては逢い、いやお互いに執念深く、追いつ追われつしていることで！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は若い女だもの、美しい青年と腕を組んで並木路を歩いたり、美青年に荷物をもってもらったり自動車をよびに走ってもらったり、チヤホヤかしずかれて銀座など買物に歩いて、人波を追いつ追われつ、人波のあいまから目と目を見合せて笑いあう。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星人と人間との、追いつ追われつの合戦だった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事は互いに競争し、互いに追いつ追われつ、進み来たった道であった。",
              "citation": {
                "source": "野に山にかかる虹の橋",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いつ追われつする世界が現われてくるのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "修善寺橋の上から眺める白泡の流れの底に、七寸の大ものが追いつ追われつしていたのは既に五月の末であった。",
              "citation": {
                "source": "香魚の讃",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに顔をだすと、たちまち、先生と追いつ追われつの活躍となり、しかし結局先生を組み伏せるのは私の方であるし、当人の身にもツライことで、たのしいものではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "公方を殺してからのこの数年は、もっぱら味方の三好三党と仲間われの戦争に追いつ追われつ、おかげで奈良の大仏殿に放火して焼いたり、堺へ逃げて、あやまったり、さすがの老蝮も天下の政治をうッちゃらかして、逃げたり、だましたり、夜討をかけたり、つまらぬことに頭から湯気のたつほど忙しい。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お銀様と神尾とは、槎※たる梅の大木を七たび廻って、追いつ追われつしています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今までと違って、奇岩怪礁に当って水の怒るところとは打って変り、岸辺の砂浜に似たところや、板のような岩の上や、岩と岩との狭間に打ち寄する波のあまりが、追いつ追われつしているところを描いたものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　見れば月光が蒼白く明るい、眼の前の庭を二つの人影が、組みつほぐれつ、追いつ追われつしながら、梯子の裾の方へ走って来ていた。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして俺と鼓賊とが、あの晩湯島と池ノ端とで、追いつ追われつしたことを、この役者達は知っているのだろう？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いつ追われつ鼓賊と玻璃窓「九郎右衛門には逢わなければならない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃ今まで玻璃窓めと、追いつ追われつしていたのか！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
