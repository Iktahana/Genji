[
  {
    "uuid": "f2a4fb79-0e8e-5f62-8496-d6a30d59ddbd",
    "entry": "王土",
    "reading": {
      "primary": "おうど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
