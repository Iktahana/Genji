        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "然しその面白さたるや「感覚的」に終止するものであることは争はれない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが、一と先づ限界に達するから人は笑ふのだ。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが、その限界に達すること遅ければ遅いだけ、芸術家は豊富である。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが、一と先づ限界に達するので人は笑ふのだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが限界に達すること遅ければ遅いだけ芸術家は豊富である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑ふといふ謂はば面白さの名辞に当る現象が早ければ早いだけ人は生活人側に属する。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自然の面白さを拡張する一つの能力で、されば断じて興味以外のものを目的とすることが許されぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も名辞以前の「面白いから面白い」境のことは、その面白さを人は人為的に増減することは困難だから茲に宿命性が在ると云へる。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは名辞以前の世界、即ち「面白いから面白い境」でその面白さが明確であることと同時に存在する所のものである。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へば聴者は、それを旋律の美しさに於て聴かないで、歌詞の面白さに於て聴き、真の音楽的陶酔とはちがふところの、別の散文化の興味で聴くからである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨と晴れとの中にありて雲と共に東へ／＼と行くなれば、ふるかと思えば晴れ晴るゝかと思えばまた大粒の雨｜玻璃窓を斜に打つ変幻極まりなき面白さに思わず窓縁をたたいて妙と呼ぶ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し長すぎるなと思つても、結構、しまひまで附合ひさせる面白さがあつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニはもうすっかり機嫌が直って面白さうにわらって女の子に答へました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に家庭の事は、人々盛に談ずべしだ、面白い事も、悲しいことも、人に談ずれば面白いことは更に面白さを加え、悲しいことは依って悲しみを減ずる。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう押詰めて来て見ると、その面白いということ（味いが無くても面白いという面白さ）は正しき芸術的感能に訴えた面白さであるか否か、と云うことだけが疑問として残る訳である。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるレビューのうちで何遍繰返し繰返し観ても飽きない、観ればみる程に美しさ面白さの深まり行くものは、こうした自然界のレビューである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルメンの中の独唱でも、管弦楽の進行の波頭が指揮者のふりかざした両腕から落ちかかるように独奏者のクローズアップに推移して同時にその歌を呼出すといったような呼吸の面白さは、実地では却って容易に味わわれないものである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた酒への強い誘惑が、實にその冒險の面白さにも存するのだ。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フリイデリイケは何遍でも面白さうに耳を傾けてゐて、この次の十二度目には、この色の蒼いパリイの女が、どうしてそんな決心をしたかと云ふ、その小説の片端をなりとも聞き出したいと思ふのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その方のお名前、今はね……」それから、面白さうに、一つの名前を引用した。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、次から次へと加速度的に面白さや好奇的な感じが集積して、胸躍ると云つた工合に惹きつけられて行く。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『探偵と云ふ仕事はちよつと考へると、如何にも面白さうな仕事らしく見えます。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "單にフイクジヨン作りの手腕の巧さなどと云ふよりも、とに角あれ程の面白さを持つた相當の長さの作品を續々産み出すルブランはよつぽど好い頭の持主であるに違ひない。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、探偵小説の面白さは實際にあり得ない事があり得るらしさに近づいてゐればゐる程強められ深くなる。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、實際はそれこそ麻雀が人達を魅惑する面白さなので、誰しも少しそれに親しんでくるといつとなくその日その時の縁起まで擔ぐやうになるのも愉快である。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンパネルラだってあんな女の子とおもしろさうに談してゐるし僕はほんたうにつらいなあ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋しき父母兄弟に離れ、はるばると都に来て、燃ゆるがごとき功名の心にむちうち、学問する身にてありながら、私はまだ、ほんのこどもでしたから、こういういたずらも四郎と同じ心のおもしろさを持っていたのです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいと言えばおもしろいがそれは白日の夢のおもしろさで絵画としてのおもしろみであるかどうか私にはわからない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」姉は細い銀いろの指環をいぢりながらおもしろさうに向ふでそのはなしをきいてゐました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みそさざいどもは、とんだりはねたり、柳の木のなかで、じつにおもしろさうにやってゐます。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
