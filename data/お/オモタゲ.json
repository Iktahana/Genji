        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "赤い光までなんとなく重たげだつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は重たげに顏を擧げて、私達の姿に Pensive な瞳を投げた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉つきなら、仕打なら、人の息女とも思わぬを、これがまた気に懸けるような娘でないから、そのまま重たげに猟犬の頭を後に押遣り、顔を見て笑って、「何？",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父親が目を拭きながら繰り返し呼んだが、頷く力もなく、目蓋も重たげであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い花模様の重たげな着物を着て五六歩はしってはまたあるき五六歩はしってはまたあるきしていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りしきる牡丹雪は焔にいろどられ、いっそう重たげにもったいなげに見えた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は重たげに首をうごかして、「ん」と答へた。",
              "citation": {
                "source": "鍛冶屋の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさに嫁がんとする娘の、嬉しさと、恥らいと、心遣と、恐怖と、笑と、涙とは、そのまま膝に手を重ねて、つむりを重たげに、ただ肩を細く、さしうつむいた黒髪に包んで、顔も上げない。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗みゆく室内よ、暗みゆきつつ想の沈黙重たげに音なく沈み、そことなき月かげのほの淡くさし入るなべに、はじめまづ※オロンのひとすすりなき、鈍色長き衣みな瞳をつぶる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこぞや女声して重たげに雨戸繰る音。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ病める東南風のみぞ重たげに、また、たゆたげに、腐れたる翼の毒を羽ばたたく。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこぞや、女声して重たげに雨戸｜繰る音。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套から、やがて両手を、片手でその手首を、さもいたわりそうに取って、据えると、扇子持つ手の甲を熟と重たげに観て、俯向いて言った。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十の家々は、これまた悉く豪家の構へで、土蔵と厩小屋を持ち、何れの家の蔵にも千両箱の載積が重たげであつた。",
              "citation": {
                "source": "その村を憶ひて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "思案にあまり、思いに屈したというように、深くふかく考え沈みながら、踏む足も重たげにとぼとぼと取ってかえすと、ものをもいわずにすうとあの仕事場に上がって、かかえ持っていたなぞの青焼き人形を、静かにその前に置きすえながら、どっかと端座して黙々と腕こまねきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "根っからの侍共なら、あのように大小を重たげにさしてはいぬわ。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋とご幣かつぎは、昔から思案のほかと相場が決まっているじゃねえか」　ずばりというと、思案のほかのその恋ゆえに罪とが犯した比丘尼小町をあわれむもののように、重たげな足を運ばせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "――参ろうぞ」　忍びやかに、そうして重たげな足どりだった。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たった一本の煙草をさも重たげに指に挟むと、非常な努力を以て、それを吸はうとするのだった。",
              "citation": {
                "source": "真夏日の散歩",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり重たげな杖を切るのも鬱陶し過ぎたので、柳の技としやれたのは好かつたが、それも相当太目ではあつたのに、ついつい私の背骨の方が柳のやうにふらついて、とても頼りない息杖だつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "慣れぬ人達は彼等の言葉つきを耳にすると全く異様な感に打たれて唖然としたが、何ういふものか、恰度あの時分から特に様子が可怪しくなつて、いつも／＼の憤つとした態の重たげな物腰と太い心持で、眼を据ゑてゐる私に対当する為には、それが最も自然に違ひなかつた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は隻腕、壇にもたれ、明いたる手にて祝福し、黄金盤も重たげに、虚空に恩赦の印を切りて、音声こそは微なれ、闃たる堂上とほりよく、瞑目のうち述ぶるやう、　　　　　　「聖霊と。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は隻腕、壇にもたれ、明いたる手にて祝福し、黄金盤も重たげに、虚空に恩赦の印を切りて、音聲こそは微なれ、※たる堂上とほりよく、瞑目のうち述ぶるやう、　　　　「聖靈と。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　街にまはつて、出來あがつてゐる寫眞の燒つけなどをとつてから、もう一度家に引き返すと、彌生は靴下を脱いで、素足に重たげな庭下駄を穿いた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事が解れば何でもないんだが、その時は全く薄気味悪かつたぜ、僕は――」と正吉は、何か適当な形容詞を使はずには居られなくなつて、凝つと言葉を切つてから、静かに重たげに続けた。",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽が先に立つて、やがて満場は老若の差別もなく手拍子足拍子も物々しく、血煙も立つかと思はるゝばかりの世にも壮絶なる大合唱が、あはやさしもに重たげな草葺尾根も吹き飛ばさん勢ひで巻き起つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お鶴は頭おもたげに、首垂れながら合点々々。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓のそとにはたくましい孟宗竹が十四五本、二三、四五とほどよくあい離れて、こまかな葉のみっしりとかさなった枝を、澄んだ朝の空気のなかにおもたげに垂れている。",
              "citation": {
                "source": "日本婦道記",
                "author": "松の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、口おもたげに。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、会えなんだ」　と、正成は、これは正成のもちまえだが、口おもたげにぽつんと答えたのみだった。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
