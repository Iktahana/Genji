          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "或る日、おてんば娘の甜瓜が、かぼちやに毒舌を吐きました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵のヴァンスも溌剌としたフラッパー〔おてんば娘〕に好かれそうなタイプでもなければ、ホームズやルパン型のジャイアントでもない。",
              "citation": {
                "source": "ヂユパンの癖とヴァンスの癖",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたは、じぶんをおてんば娘だと思いませんか？",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おてんば娘は、とんでもないことをいいなさる。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしのおてんば娘がいなくなって、すこしさびしいが、そのかわり頼もしい心のやさしい娘があらわれた。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば、その村においても、おてんば娘の評ありという。",
              "citation": {
                "source": "甲州郡内妖怪事件取り調べ報告",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "おてんば娘は主人の気風に合わないのですわ」「奥さん、一寸黙ってごらんなさい」突然紋三が夫人を制した。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、一方はおとなしやかな無表情、一方は技巧たっぷりのおてんば娘なのと、それに髪の形だとか眼鏡や眉の相違があるので、一寸気がつかないだけです。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
