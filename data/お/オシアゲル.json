        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「パリの屋根の下」で二人の友がけんかをしようとするときに、こわれたレコードのガーガーと鳴り出すその非音楽的な不快な騒音が異常に象徴的な効果をもって場面のやまを頂上へと押し上げる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に二階へ押し上げると、柳吉は天井へ頭を打っつけた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝室の窓は大きめで、下から押し上げると開く種類だ。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "釘は少し力を入れて引つ張ると抜けたが、窓の戸を押し上げることは、どうしても出来なかつた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでサンは新しい技術の開発にも全力を上げ、生みだした技術を標準に押し上げるために努力する方針を取った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーン、ドドーン、バーン　と天龍の川を挟む両岸の絶壁に木魂して古畳を突き倒し、穴を明け、時には四五間も空へ押し上げるのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを又押し上げるか押し上げぬかは、日本の建築界の将来に於ける興味ある研究問題ではあるまいか。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌声だけはデビュー当時からなかなか見事だったと思いますが、それが果たして彼らをスーパーアイドルに押し上げる要素だったかどうか――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＰＣへの採用に関して一歩先駆けたマイクロソフトには、ＭＳ―ＤＯＳを一六ビット以降の標準に押し上げるチャンスがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西はＭＳ―ＤＯＳを日本でも一六ビットの標準ＯＳに押し上げるために、利用できる力はすべて利用したかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ページメーカーをはじめとするグラフィックスの強みを生かしたアプリケーションの登場によって、マッキントッシュの視覚的な操作環境にあらためて幅広いユーザーが注目しはじめるもう一方で、マイクロソフトはＷｉｎｄｏｗｓを標準に押し上げることに手こずり続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マイクロソフトとインテルは、コンピューターの歴史を一緒に切り開いてきたと思います」　かつて渡辺和也とビル・ゲイツとを引き合わせ、マイクロソフトを歴史の主役にもう一段押し上げるきっかけを作った西和彦は、本論をそう切り出した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜分なんか寝て居りますと、すき間から吹き込んだ風が天井にぶつかつて其の儘押し上げるものと見えまして、寝て居る身体が寝床ごといつしよにスーと上に浮きあがつて行くやうな気持がする事は度々のことであります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でも……初めて越して来た方は眠られないものだそうでございますよ」「そうかね僕はよく寝られた」　谷村さんはグッと押し上げる不快さを隠して、太つちよの下女がそろえてくれた靴に足をかけました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてジッと未亡人の寝顔を見返りながら、堪らない残忍な、愉快な気持ちに満たされつつ、心の底から押し上げるように笑い出した。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "突如、地平のはるか下から、白夜を押し上げるようにして、燦然たる金色の暈が現われたからである。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、栓がだんだんに持ち上がっていって、尾錠の梃子を下から押し上げる。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　錆ごえを、ふりしぼるのもあれば、金切ごえを振り上げる女もあり、すぐに、かつぎ上げるようにして、一行を、二階に押し上げる。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くかえろう」　夜店の商人が雨を押し上げる思いで怨めしそうに天を見上げながら、「もう二時間｜遅いと早いとで大きな違いだ」と、舌打ちするようにいってつぶやいているのを、私はしっとりとした好い気持ちに聞きなしながらお宮を連れて清月にもどって来た。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は自転車を押し上げる普通の速力で登ってきました。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "繃帯　　（かまはずに、どんどん押し上げる）眼鏡　　そ、そ、そんな馬鹿な……そこは痛いんだ、痛い、痛い、痛いつたら……。",
              "citation": {
                "source": "命を弄ぶ男ふたり（一幕）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一度崩したものを押し上げると、今度はちがった面に断層が出来て盛り上がるので、白線は地殻の褶曲に似たような形になるのであった。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは危険であるとパークス氏が忠告したときに、鉛のミルク・パンはどのような種類の容器よりもクリームをよく押し上げるとの返事があった。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一度崩したものを押し上げると、今度はちがった面に断層が出来て盛り上るので、白線は地殻の褶曲に似たような形になるのであった。",
              "citation": {
                "source": "寺田先生の追憶",
                "author": "――大学卒業前後の思い出――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　千浪は、二、三段下から、必死に懇願して、押し上げるような手つきをする。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせい様が、さきに鼻をかみ出して、じぶんの膝に押しつけているお高の顔を、両手にはさんで押し上げるようにした。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "手伝ひ共は押し上げる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "以心伝心といったような、まるで禅寺の公案の時間のような奇妙な対座をつづけたのち、真名古はフイと瞼を押し上げると、「ああ、ちょうど十分経ちました。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔見知りの雇人女中達の目礼するのに答えて、二階の寝室に通ると、私を寝台の上へ押し上げるようにした看護婦と花枝は、「お疲れでしょう、暫らくお休みなさいまし、あとでお目に掛り度い方がある相ですから」　妙に気に掛る言葉を残して階下へ降りてしまいました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間子は、１エネルギ量子を消費して、１電子を軌道１から軌道２へ押し上げるに要する時間の長さだ。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
