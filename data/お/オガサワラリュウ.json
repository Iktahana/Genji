    "definitions": [
      {
        "index": 1,
        "gloss": "Ogasawara-ryu (school of etiquette)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "小笠原流の礼法を標準としてロシアの百姓の動作を批評するようなものかもしれない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の父は小笠原流の弓術を学んで、かつて太郎射手を勤めたこともあるというほどの達人であるから、その子の石川も弓をよく引いた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐来とおぼしき金具造りの短檠にはあかあかとあかりがとぼされ、座にはきんらんのおしとねが二枚、蒔絵模様のけっこうやかなおタバコ盆には、馥郁として沈香入りの練り炭が小笠原流にほどよくいけられ、今は、ただもうそのお来客と城主伊豆守のご入来を待つばかりでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流にも今川流にも、こんな無作法な脱ぎ方はねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが恐ろしく小笠原流で――それで何をするのかと思うと、枕頭に蒔絵の煙草盆を置きに来たに過ぎなかった。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも勿論小笠原流であった。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして又しても村の娘が小笠原流で来たのではあるまいかと、不快に思わずにはいられなかった。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜は、村々の選ばれたるおとぎ女、急仕込の小笠原流の美人達は一人も来なかった。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのわたくしがをりし茶ざしきの西のをしこみ書物箱がありし、其中ニいかにもこげしかきがみかのひよふしかゝり候、小笠原流諸礼の書十本斗、ほんのあつさハ一分二分斗の本のあつさニて候。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年九月九日　坂本乙女、おやべあて",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで日本の使節もよいことを聞いた、小笠原流にもない礼法を学んだと喜び、いよいよ宮廷に達し拝謁するとき、使節は玉座の前でみな手を鼻に当てた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くするとお姫様が、蒔絵のお吸物膳にお吸物椀を載せ、すーツと小笠原流の目八｜分に持て出て来ました。",
              "citation": {
                "source": "士族の商法",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "心に油断がなくなり、油断のならない心をもち、ヤと叫べばマと応じる神速機敏、微塵も隙といふもののない緊張を常々身心に秘めてゐれば、動作は自ら静を生じ、静かなること林の如く、自然礼節を生じて茶道小笠原流などの奥妙にも達し、しかも全身電波の如く気魄波打つ鋭利の人材となるのである。",
              "citation": {
                "source": "総理大臣が貰つた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "物を運ぶとき、いつもかうです」「するとそれは小笠原流ですか」「いゝえ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃オサンドンの訓練、良妻賢母、小笠原流、窮屈の極点に痛めつけられているから単純な遊びでも御満悦で、戦争の真最中でも困らない。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は小笠原流といふ礼儀の中の武士の娘であり妻であつて、女でも人間でもないのである。",
              "citation": {
                "source": "欲望について",
                "author": "――プレヴォとラクロ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、皇居内ともなれば、万事小笠原流に、しとやかなものだと感心してゐたのである。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると記録係も立ち去り、塚田が便所から帰つてまもなく、オバサンが例の小笠原流、板敷の上をグルッと一周して、お茶を捧げてきた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流のオバサンが三時の茶菓を運んできた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流のオバサンが冷水でしぼつた手拭ひを持つてきた。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに救われたように、伝二郎は小笠原流の中腰でつつっと台所の敷居ぎわまで、歩み寄って行った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生なら、そらサヴェジ・チーが出たと冷やかすのだが、主人一人に対してすら痛み入っている上へ、妙齢の女性が学校で覚え立ての小笠原流で、乙に気取った手つきをして茶碗を突きつけたのだから、坊主は大に苦悶の体に見える。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな遠慮があるから、小笠原流で番茶なんか飮んで、恐しく突き詰めた顏をして居るんだな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらつしやいまし、私は其月堂の家内で――」　と、お屋敷勤めの昔を匂はせようと言ふ小笠原流の挨拶が始まつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は小堀和泉守樣御上屋敷に仕へて居ります、早瀬と申します、御見識り置きを――」　三つ指が縁無し疊の上を滑つて、小笠原流にピタリと極るのを、錢形平次さすがに持てあまし氣味でした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな遠慮があるから、小笠原流で番茶なんか飲んで、恐ろしく突き詰めた顔をしているんだな。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は小堀和泉守様御上屋敷に仕えております、早瀬と申します、御見識りおきを――」　三つ指が縁無し畳の上を滑って、小笠原流にピタリと極るのを、銭形平次さすがに持てあまし気味でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流に対抗して、五分も引けを取らぬ心持の準備だけは出来たのでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいまし、私は其月堂の家内で――」　と、お屋敷勤めの昔を匂わせようという小笠原流の挨拶が始まったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "小笠原流に物申すぢや、聞えはしないやな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつしの背後へ廻つた味噌摺用人奴、小笠原流で靜々とした起ち居振舞ひだから、うつかり油斷をして居ると、横合ひから、あつしの脾腹へどかんと來た。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美しき人質",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
