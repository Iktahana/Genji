[
  {
    "uuid": "d4e87b45-e89c-5ad0-888f-baee58c6c906",
    "entry": "治まる",
    "reading": {
      "primary": "おさまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
