[
  {
    "uuid": "61ddb610-c880-50ee-ba0d-f51affdeb16a",
    "entry": "烏滸がましい",
    "reading": {
      "primary": "おこがましい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
