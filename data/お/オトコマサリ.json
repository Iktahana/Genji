    "definitions": [
      {
        "index": 1,
        "gloss": "(of a woman) strong-minded",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
