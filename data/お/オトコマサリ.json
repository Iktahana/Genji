        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "男勝りの心に恥じて、強いてとも言い難く、さればとてこのままにては得三の手に死ぬばかりぞ、と抱き合いつつ泣きいたりしを、得三に認められぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が少女時代はあなたにかなりよく肖たなよやかな子であったのに、どうして男勝りと言われる意地強い女になったのでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何で御座います」「男勝りの機敏な貴方にも似合はん、さすがは女だ」「何で御座います？",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢明な彼女は男勝りのしっかりしたその腹の中へ、それをしまい込んで何人にも話さなかった。",
              "citation": {
                "source": "猫の踊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く眼色のような気象で、勝気で、鋭くて、能く何かに気の附く、口も八丁手も八丁という、一口に言えば男勝り……まあ、そういった質の人だったそうな、――私は子供の事で一向夢中だったが。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾家では子供も殖る、小商売には手を焼く、父親は遊蕩で宛にもなりませんし、何程男勝りでも母親の腕一つでは遣切れませんから、否でも応でも私は口を預けることになりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の男勝りの気性は、多分に私のうちにも移っていた。",
              "citation": {
                "source": "母への追慕",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もまた、世の荒浪と闘って独立してゆけたのは、母の男勝りの気性を身内に流れこましていたからなのであろう。",
              "citation": {
                "source": "母への追慕",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の頃は二十七、八で、男勝りを思わせるような顔は蒼醒めて、眼は訴えるように潤んでいた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、子爵家に男勝りの乳母がいましてな。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はもと逓信省の官吏を務めていたのですが、いまから十五年前に相当の財産を残して死去し、男勝りの未亡人は三人の子を育てて、他人に後ろ指一本指されないでいままで暮らしてきました。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はお光をも愛したが、勝気で男勝りな、強い綾子の、豊麗な少女と成長して行くのにある希望を見出していた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀の初めに、これも男勝りの女優として知られたブウルグワン嬢は、また同時に、同じ批評家から褒められたり貶されたりすることで有名であつた。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は三十郎はずっと前から――というより梶子の附け人として、梶子のもとへやって来て、梶子とはじめて逢った時から、梶子のずばぬけた美しさと、男勝りの気象とに、すっかり心を奪われて、燃えるように恋しているのであった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性へ　２岸田國士　昔から男勝りといふ言葉がある。",
              "citation": {
                "source": "女性へ　２",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今やわが日本の全女性は、一人のこらず男勝りになつてもらはねばならぬ。",
              "citation": {
                "source": "女性へ　２",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "男勝りといふ言葉は、主として精神的な意味に用ひられてゐるやうだが、容貌姿態に於ても、私たちは、日本の女性が、もつと、凜々しさを尊重し、手弱女などゝいふ呼び方をされることを厭ふやうになつてほしい。",
              "citation": {
                "source": "女性へ　２",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田　　男勝りといふ資格でね。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女ながらも、田宮流の小太刀を使っては、男勝りの手練の女丈夫、しかし獲物は懐剣であった、相手の脇差は受けられない、そこで飛び違い遣り違わせ、機を見て突きつ切りつして、「お兄イ様ア――ッ」と呼ばわり呼ばわり、主水の後を追おうとした。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気象の勝った男勝りのお粂が何ゆえにそのように弱々しそうに咽び泣きなどをはじめたのであろう？",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男勝りのクッキリした、横顔が朝日を浴びて、薔薇色にかがやいていた。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十　親しくなると共におしんは男勝りであるだけ色々と役に立つことが多くあつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃男勝りの母様この時きつぱりとしたお声にて。",
              "citation": {
                "source": "葛のうら葉",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分さん、娘はどうして死んだのでせう」　此處へ來る迄、少しも取亂した樣子のなかつた母親のお角も、娘の死骸を見るとさすがにたまり兼ねたものか、男勝りと言はれた誇りをかなぐり捨てて、冷たい娘の頬に、自分の頬を摺寄せてひた泣きに泣くのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "男勝りと言はれたお角も、二千兩を隱して町人道を立て通した佐太郎も、其頃になつてボツボツ集つて來た近所の人達や、遠い親類を相手に、新に湧き上がる悲しみに、泣いたり口説いたり、取止めのないことに紛れて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは男勝りといわれ、自分でもそう思っていたが、これが何で男勝りか、我ながら情ない気になっていたんだ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御槍奉行、矢走源兵衛の一人娘として育ち、男勝りで、才智容色とも京極家随一と云われる不由の、高く持して抂げぬ強い気性には実際ちょっと手の出せぬ処があるのだ。",
              "citation": {
                "source": "入婿十万両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三平は少し煙に巻かれて、柄にもなくおど／＼して居ましたが、だん／＼酔いが循って来ると、胆が落ち着き、「だが梅ちゃんのような男勝りの女は、私ゃ大好きサ。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら男勝りの寡婦だと言っても、到底女の手に合わぬ力わざが米作には多かった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "松子は本多平八郎忠勝のむすめで、内大臣家康の養女ぶんとして信之に嫁してきた、氏からいっても育ちからいっても、武将の妻として留守城をあずかる覚悟にいまさらおくれのある筈はない、ことにかの女はおとこまさりの生れつきで、小太刀、なぎなた、馬術などで鍛えた堅固な志操をもっていた。",
              "citation": {
                "source": "日本婦道記",
                "author": "忍緒",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
