        "形容詞-語幹"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "auto",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "先日のリュミエール会社のオートクローム板は三色の澱粉を混合して作ったものだが、今度のは種板の上に三色の細い線を並べたもので大体の理窟は前のと変りはない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士はオートバイで毎日やってきた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱漆で塗った地に黒漆でからすの絵を描いたその下に烏丸枇杷葉湯と書いた一対の細長い箱を振り分けに肩にかついで「ホンケー、カラスマル、ビワヨーオートー」と終わりの「ヨートー」を長く清らかに引いて、呼び歩いていたようにも思うし、また木陰などに荷をおろして往来の人に呼びかけていたようにも思う。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとオートでも振る舞えよ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ところがタスケの馬も馬でさあ、面白がってオペラのようにふしをつけて（なかなかやれないわたしのオート。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりふしをつけながら、（お呉れよ、お呉れよ、お前のオートわたしにお呉れよ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ハリケンハッチのオートバイ」「ハリケンハッチのオートバイ」　先ほどの女の子らしい声が峻の足の下で次つぎに高く響いた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その爆音を聞くと峻の家の近所にいる女の子は我勝ちに「ハリケンハッチのオートバイ」と叫ぶ。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オートバ」と言っている児もある。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近な些末な例をあげると、銀座の裏河岸のある町の片側に昔ふうの荷車が十台ほどもずらりと並べておいてある、その反対側にはオートバイがこれも五、六台ほど並んで置かれてあった。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一町ばかり先にある、今自分の乗つた自動車の通つて来た道を、オートバイが遠雷のやうに近づき、やがて消えていつた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれから何べんも遊びに行ったり相談のあるたびに友だちにきいたりして、それから三年の後には、とうとうファゼーロたちは立派な一つの産業組合をつくり、ハムと皮類と醋酸とオートミールはモリーオの市やセンダードの市はもちろん、広くどこへも出るようになりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなオートを食べていた。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……車の眞似だか、あの、オートバイだか、電車の眞似だか、ガツタン、ガツタン、がう……」　と、その七つに成る兒が、いたいけにまた話した。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に流言に憑いた鼠でも、オートバイなどで人もなげに駈し、溝の中で取つて倒し、組んで噛みふせる勇者が顯はれた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オムレツか、オートミルでも取ればいゝのに。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、オートミールとカツレツを食べるのは、だれだかも、みんな知ってますのよ。",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ロンシャンの大懸賞も、オートイユの障害物競馬も先週で打ちどめになった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天水桶のあったあたりには、木之助の嫌いな、オート三輪がとめてあった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートバイででん逃げ出えたそな。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートミルとフライエッグスと一、二杯の珈琲。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、遠足、日本酒、オートバイドライブ。",
              "citation": {
                "source": "回答",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんオートダイヤル、電話帳などの機能があって、自動受信、保存後の転送などが可能。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スバル社までこれを駆け足で持つて行かうか、何処かで貸オートバイを探さうか。",
              "citation": {
                "source": "僕の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕は自働電話に駆け込んで、つい此間買つたばかりのスタウト型インヂアン・オートバイを持つてゐるＲといふ先輩を呼び出した。",
              "citation": {
                "source": "途上日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お起きなさいよ、――オートミールが冷えてしまふ――」　フロラの烈しいノツクで彼は、漸く目を醒した。",
              "citation": {
                "source": "鸚鵡のゐる部屋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンネットの『フィオート民俗記』に、コンゴ河辺にの梵名種々ありて数種皆各名を別にするらしいが、予は詳しく知らぬ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "また仏領コンゴーの土人は、最初男色を小蛇が人を嚥むに比し、全然あり得べからぬ事と確信した（デンネットの『フィオート民俗篇』）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九八年、ロンドン板デンネットの『フィオート民俗記』に、一羽の雌鶏が日々食を拾いに川端に之く。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
