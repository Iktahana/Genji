          ],
          "literary": [
            {
              "text": "お楽しみ中を真に恐れ入ります。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは重々恐れ入りますと云つて一切の祕密を夫とをぢさんとの前で白状した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、恐れ入りますが、しばらくお控えくださいまし。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはお語誠に恐れ入ります。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや、そのご謙遜は恐れ入ります。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たびたびご迷惑で、まことに恐れ入りますが、いかゞなもんでございませう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たびたびご迷惑で、まことに恐れ入りますが、いかがなもんでございましょう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前味噌で恐れ入ります。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘヘ……旦那様……横道へ入って恐れ入りまするが、私は元来、金持が嫌いで御座いまして……」「フーム。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れ入りまするがあの娘の死骸は御覧になりましつろうなあ」「うむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは……お手ずから恐れ入りまする」　赤猪口兵衛は腰に挿した渋団扇を一枚取ってサラサラと筆を揮って差出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度試みて、とうとう指さきを臆させてしまった女中は「お嬢さま、まことに恐れ入りますが、とても私の手にはおえませんから、このまま蝙蝠を宅までお持ち願えませんか」　お涌は大人にこれほど叮嚀に頼まれる子供の侠気にそそられて承知した。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――不細工なもので恐れ入ります。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）蓮月　――まあ、こんなに沢山恐れ入ります。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎利弗　――恐れ入ります、一同無事で御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※曇弥　――恐れ入ります。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むぐらは土の中で冷汗をたらして頭をかきながら、　「さあまことに恐れ入りますが私は明るい所の仕事はいっこう無調法でございます」と言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご明察恐れ入ります。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」特務曹長「はあ実に恐れ入ります。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、小清潔とまゐりませんでも、せめて縞柄のわかりますのを、新年は一枚と存じます……恐れ入りますが、お帳面を。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ァまたてっきりそうだと思ったんですが…』『恐れ入ります。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それよりか、奥さまにもお楽にして頂いて、何かお話を承りとうございますわ」「恐れ入ります」　夫人はやっとソファの端に膝を下ろした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度試みて、たうとう指さきを臆させてしまつた女中は「お嬢さま、まことに恐れ入りますが、とても私の手にはおへませんから、このまま蝙蝠を宅までお持ち願へませんか」　お涌は大人にこれほど叮嚀に頼まれる子供の侠気にそゝられて承知した。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうも恐れ入ります。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女は後先を※しましたが、じりじりと寄って参り、「時につかぬ事をお伺い申しまして、恐れ入りますが、貴方は方々御旅行をなさいまして、可恐しい目にお逢い遊ばした事はございませんか。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は私からお願い申しまする筈でござりましたが、かようなものでも、主人と思召し、成りませぬ処をたっても御承知下さいますようでは、恐れ入りまするから、御断の遊ばし可いよう、わざと女共から御話を致させましたのでござりまするが、かように御心安く御承諾下さいましては、かえって失礼になりましてござりまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃ではあんたのおとうさまのご飯のお給仕でもなんでもしますのよ」「まあ、ほんとに恐れ入りますのね」　男同志で語りながら私たち女二人の話にも神経質に聴耳を立てゝいるらしい池上は、このときわたくしの方を向いて、ふと言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐れ入りますが教えて下さいませんか。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おそれいります。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お褒めにあずかって、おそれいります。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
