        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "新短歌が、短歌から出て来たものと考ふべきか、全然別個に発生したものと考ふべきかは甚だ疑問であるけれども、短歌にもはや発展の余地がないと思つた人々によつて工夫されたものであることは慥かである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論かういふことは、一々の短歌作品、一々の俳句作品に就いてそつくりそのまま当箝まることではないけれども、夫々の様式を規範的に観た場合そのやうに言ふことは先づ間違ひない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ラマルチーヌの、サント・ブーヴの、モンモランシイの、レカミエ夫人の、ミシュレの友情を招来したのだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ルモオル夫人の詩業は身を切るやうな感受性の叫びや呻吟である。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の此の家だつて、後で叔母の云ふ所によると、信者が家主であるさうで、その家主老夫婦が自分達の隠居のために建てたんださうで、値段に比べたら却々立派な家である。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちはイライラするけれど、彼方は親切に何やかと訊ねなさるから、牧代（姉娘）はどうしたか、生れた子供は丈夫かと訊ねなさつて……」とニコニコしながら呼吸をつきながら、仰向き勝なその顔の、アザヤかな色の唇がさういふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "下ろして「これはどうしますか」と訊くと、一応家主さんに届ける、家主さんは信者だから家主さんのではないが、家主さん隠居夫婦が此の家を出た後半年ばかりゐたといふ人達のものだから、家主さんからその人達に渡して貰らふ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、せめて木村夫婦の所を訪ねようといふ気もあるのだが、まだ訪ねない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍々あつて男――もう今では夫、入口より葉巻を銜へ、長きマントの儘、如何にも寒い中を歩いて帰つて来た風である。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　（クスグツタイ笑ひ）まあさう言はないで、俺の肩に手をかけて、――ポーランドの妻君は、自分の夫を膝にのせて、「コハーネ」つて言ふんだつて。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫よ　はやく夏草を刈りつくせ狼火をあげよ　烟を空にたなびかせよ空想の陣幕を野邊にはつてまぼろしの宴樂をほしいままにせよ。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼の夫人にとって――世の多くの若い女性と同じく――東京はあこがれの都であり、そこでの生活は一生最高の理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆あなたのためです』と、さすがにヘルンも夫人に愚痴をこぼしている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人もよくその良人の心を知り、『ヘルンの一生は、皆私や子供のために尽してくれた犠牲でした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "巌ト一雄、丈夫デ可愛ラシイ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はその追想記の中で、箪笥の抽出を開けるにさえも、そッと音を立てぬように気をつけたと書いている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク見タイモノデス』という焼津の手紙でも解るように、妻と同伴することなしには、どんな旅行も楽しくないほど、夫人を熱愛していたからだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ子供が出来ない頃、この新婚の若夫婦は、山陰道の辺鄙な島々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは本土との交通がほとんどなく、少数の貧しい漁夫たちが、所々の寂しい山蔭に住んでるような、暗く荒寥とした島嶼であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はその時のことを追想して、草双紙で読んだ昔物語を、そっくり現実に経験した様だったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚まもなく若い稚気のぬけなかった夫人は、恐らく恐怖にふるえながらも、人生の最も楽しく忘れ得ない夢を経験したのだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の見る物もなく風情もないので、夫人が怪しんで質問したところ、ヘルンは耳を指して、『お聴きなさい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "松江から東京に移るまで、ヘルン夫妻は、自分の家を持たなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし東京へ移ってから、子供が大ぜい生れたりして、家内が狭くなった上に、貯財も少し出来て来たので、夫人のすすめで売家を一軒買うことにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし何となく陰気に薄暗くじめじめして、妙に気味の悪い厭な感じがしたので、夫人が直覚的に反対したにもかかわらず、ヘルンは一見して大いに気に入り、『面白いの家』『面白いの家』と、子供のように嬉しがって、是非それを買おうと言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局それは、夫人の強硬な反対によって中止されたが、後でそれが有名な化物屋敷と解った時、夫人がほッと胸を撫でおろしたとは反対に、ヘルンは大変失望して、『ですからなぜ、あの家住みませんでしたか。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした夫婦の会話は女中や下僕にはもちろんのこと、子供たちにさえもよく解らなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘルン夫妻の奇妙な会話が、おそらくそういう種類のものであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水禽の大鉄傘を過ぎて、おっとせいの水槽のまえを通り、小山のように巨大なひぐまの、檻のまえにさしかかったころ、佐竹は語りはじめた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
