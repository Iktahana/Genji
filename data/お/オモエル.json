        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その力としてありそうに思える火の背梁だけは確に逞しくなっている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、魚にしたら、いきが悪くなったように思えるんだが、どうかね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ジャズの麻痺、映画の麻痺、それで大概の興味は平凡なものに思える。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れ来り、流れ去るのだが、その交替は人間の意識の眼には留まらない程すみやかでかすかな作業のようで、いつも若干の同じ魚が、其処に遊んでいるかとも思える。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "環虫類も何だか虫の中では醜い衰亡者のように思えるし、鰻だとて、やはり時代文化に取り残されたような魚ではないか。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて彼が心は人々の知らぬ間に亡び、人々は彼と朝日照り炊煙棚引き親子あり夫婦あり兄弟あり朋友あり涙ある世界に同居せりと思える間、彼はいつしか無人の島にその淋しき巣を移しここにその心を葬りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬にはどの夜もみな一つに思える。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお前は睡らないでひとりおきているように思える。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げると十六日十七日と思える月が真上を少し外れたところにかかっていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "××さんは」　それはこの港に船の男を相手に媚を売っている女らしく思える。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果物はかなり勾配の急な台の上に並べてあって、その台というのも古びた黒い漆塗りの板だったように思える。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　実際あんな単純な冷覚や触覚や嗅覚や視覚が、ずっと昔からこればかり探していたのだと言いたくなったほど私にしっくりしたなんて私は不思議に思える――それがあの頃のことなんだから。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんなような所にも思える。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はさこそあらめと思える見得にて、「どうだ、うらやましかったろう。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい二十世紀の文明国と名乗る国がらからすれば、内閣に一人や二人のしかるべき科学大臣がいてもよさそうであり、国防最高幹部にすぐれた科学者参謀の三四人がいても悪いことはなさそうに思えるのであるが、これも畢竟は世の中を知らぬ老学究の机上の空想に過ぎないのかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新進作家になってからは、一木一草、私にとって眼あたらしく思えるのだった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅館へ帰り、原稿用紙にむかって、いたずらがきして居れば、おのれの文字のひとつひとつが、額縁に収めるにふさわしく思えるのだった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただひたすらその決行を壮なりと思えるがごとし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどまた七日の後には再び来たりておもむろに告別せんと青年は嘆息つきて深く物を思えるさまなり、翁ははたと手を拍ち、しからばいよいよ遠く西に行きたもうこととなりしか。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもその笑っているのが僕のことを知っていて笑っているようにも思えるし、何か話をしているのが、「いまに見ろ、あの日本人が僕の絵具を取るにちがいないから。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といっているようにも思えるのです。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは海岸の砂の上にも水の中にも、朝から晩まで、沢山の人が集って来て、砂山からでも見ていると、あんなに大勢な人間が一たい何所から出て来たのだろうと不思議に思えるほどですが、九月にはいってから三日目になるその日には、見わたすかぎり砂浜の何所にも人っ子一人いませんでした。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くでは、日の黄を交えて草緑なのが、遠く見透すと、印度藍を濃く一刷毛横になすった様な海の色で、それ丈けを引き放したら、寒い感じを起すにちがいないのが、堪え切れぬ程暑く思える。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは痩我慢とも捨て鉢とも思えるものだった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが惰性と反撥で行動しているように思える自分について、もう少し考えたかった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌も皆三にむかっていると、あれほど気嵩で散漫だと思う自分がしっとり落付き、こまかく心が行届いて、無我と思えるほど自分には何にも無くなり、ひたすら皆三の身の囲りの面倒を見てやり度くなるのであった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあるとき皆三の母親から聞いた皆三の、当分独身といった言葉は、皆三の性格としては、もっともと思えるが「何という意気地なし」というような言葉で、皆三を思い切り罵倒してやり度い気持ちがお涌に湧然として来た。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　説き得て可しと思える状して、「叔母さんは、その婆を、妖物か何ぞのように大騒ぎを遣るけれど、気味の悪い、厭な感じ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく今日の切開術は、眼を開きてこれを見るものあらじとぞ思えるをや。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と弁舌流るるごとく、滔々として論じ来るに、へいげん等はこは案外とおもえる様にて、「それじゃ御持参の時計を拝見いたしましょう。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
