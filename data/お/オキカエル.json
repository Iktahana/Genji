[
  {
    "uuid": "0472361a-5dc2-586e-ad97-c3e0f7f4c7c2",
    "entry": "置き換える",
    "reading": {
      "primary": "おきかえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
