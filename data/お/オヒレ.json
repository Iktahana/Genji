        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しまひには、うはさに尾ひれがついて、あの人は、どんなことでもしつてゐるえらい賢者で、人の秘密でもすぐに見ぬいて言ひあてる、とてもふしぎな人だと、じぶんがためされたやうに言ひふらすものさへ出て来ました。",
              "citation": {
                "source": "ダマスカスの賢者",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく将軍家の耳にも、身の潔白は歪められて、ゆうべの一条もあることないこと様々に尾ひれをつけた上、さもこちらからお紋の方にゆるしがたき不義の恋しかけたごとく言上されているに違いないのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみも、こういう話に尾ひれがついて、あちこちでうわさされるのは、きっと不愉快だろう」「はい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても尾ひれのひらいた、頭でっかちの金魚です。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行のみなりをしていそいそと、まるで尾ひれを振ってあるく金魚かなどのようにしなしなと品をつくッて歩るいている。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごっちゃに押しこめられた桶から、急に、鉢の清水へ放されて、金魚はうれしげに、尾ひれを伸ばして泳いでいる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふうに、いろいろ尾ひれがついて、そのほうが大きくなってしまったが、もとを正せば、まっすぐな線が見えたというだけのことである。",
              "citation": {
                "source": "犬がなくとガラスがこわれるか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、かれは、いつか見たときとくらべるとからだ中が瘠せてしまって、それに鱗のつやがほとんどなくなり、どこか、よろよろと尾ひれのちからも自由にならないようなところが見えました。",
              "citation": {
                "source": "寂しき魚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "よその内で、ちっとでもうまい事してるの見ると、たちまち眼を光らして、尾ひれをつけて云いふらすだ。",
              "citation": {
                "source": "鈴が通る",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつ、ねじこんできた」　やがてそれは、また尾ひれがついて村中に伝わってゆくにちがいない。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに女学校女学校と、まっさきになってさわいでいたマスノが、結局は高等科へ残ったというのに、その姿が見えないことについて、小ツルは例によって尾ひれをつけていった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人には、その尾ひれが水から出ているのが見えた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらに尾ひれをつけようとすると、いかにさまざまな想像が我々の心の底にむらがり起ることか。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "テールに近づいたところでいったん細くすぼまってから、魚の尾ひれのように広がっている。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧には長い尾ひれが二本ついていて、それぞれが風になびいていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の尾ひれが砂の上で風に舞っていた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を細く切って作った尾ひれだった。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年と邦子とのあいだで、凧の尾ひれが盛んに風に舞った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧を顔の位置にかかげ、尾ひれをうしろへなびかせ、彼は邦子に近づいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの肩の高さのあたりを、二本の尾ひれがうしろへなびいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "凧を表にむけ、下の端を持ち、尾ひれがどこにもからまず風に流れるよう、邦子は自分の腕の位置を変えた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の尾ひれが彼女の後方へなびいた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾ひれのはためく音を、邦子は空の高いところに聞いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞を細く切って尾ひれを二本作り、凧についていた短い尾ひれに貼りつけた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二八　口の大きく、尾ひれの大きい鱸。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなんかも、着想は実にバカバカしいのだが、人間が椅子に化けられたら面白かろうという一点の着想から、だんだん考えを進め、尾ひれをつけて「人間椅子」という小説ができた。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの怪談が創作され、それが尾ひれをつけてひろがって行った。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎盛綱は、鎌倉に対して近ごろ不満をいだいているらしいと沙汰する者があったり、それに尾ひれを付け加えて、彼こそは油断のならぬ男で、今のうちに処置をせねば乱をなす者であろうと流言する者がある。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人事すべて、眼前を観ただけでは、何が幸不幸とも申されぬで」　――武蔵は、平伏のまま、「……はっ」　と、なおひれ伏していた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "せつな、一しお頭が下がって、町と道のつづく限りつづいている土下坐の人影は、靡くがごとく、なおひれ伏した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
