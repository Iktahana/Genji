    "definitions": [
      {
        "index": 1,
        "gloss": "chief",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "みんなが何を話したか別段記憶しないが、ともあれみんな文学青年が先輩を詣でた式のことで、主人は間もなく退屈した。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、自分が自分の主人たり得てはゐない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りれば好い連中が、不景気のために一層意志的となり、それが世間一般の主調である場合、常識はまた一層のさばるのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "主調色は青であり、あけぼのの空色であり、彼自身の讃ふべき語を以てすれば、「鋼青」である。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が高森を知つたのは七八年前のことであるが、彼はその前から詩を書いて、日夏耿之介主宰の游牧記等に発表してゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なぞまだ何処にも発表しない頃のことだし、何れ高森の方が早く所謂詩壇に出るのであらうと思つてゐたが、游牧記の後では、石川道雄主宰の半仙戯、其の後は友野代三主宰の童説といつたあまり世間の表てに顔を出したがつてゐない雑誌に発表するだけで、一向に其の他に発表はしたがらないのであつた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには非常に寡作のせゐもあるのだが、『そつとしておいてくれ』といふ気持の強い男だといふことがその主な理由だと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはつちを掘り、つちをもりて、日毎におんみの家畜を建設す、いま初夏きたり、主のみ足は金屬のごとく、薫風のいただきにありて輝やき、われの家畜は新緑の蔭に眠りて、ふしぎなる白日の夢を畫けり、ああしばし、ねがはくはこの湖しろきほとりに、わがにくしんをしてみだらなる遊戲をなさしめよ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま初夏きたる、野に山に、榮光榮光、榮光いんよくの主とその僕にあれ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が巡業を主としてゐたので、従つて彼女の生活は放浪的なものであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が把持したのは、必竟『聖なる抒情主義』ともいふべきものであつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "統一への途上に於て小主観的作品の物されることが多ければこそ、問題は錯雑を極め、作品よりも批評の方に真実の見られ易いが如き事態ともなつてゐるのではあるまいか。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し自分自身の言語或ひは心象でパンセされて出来た主義なら、その主義は彼自身なのだから、その主義を守るも守らないもないものだ！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し黄金万能主義的傾向に属することなのだらうが、Ｂの方では、Ａより貧しい条件の下に働いてゐるのに、Ａの方では、いつ知らず「俺の方が元金がかゝつてゐるのに……」といふ不平を抱いてゐるのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さうした事態を脱がれようとするものの如く、後から後から新しい主義主張が簇出しつつあることも事実である。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してそれらの新しい主義主張は、何か新しく云ひたいことが鬱勃とした所から発生してゐるといふよりも、事態の貧窮を救済しようとて案出されるもののやうである。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、私は思ふに、それら新主義新主張は何の実質的な意義もないであらう。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば小松清氏によつて、行動主義文学といふのが提唱される。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるを現今様々なる新主義新主張の提唱者等は、生産の形式で芸術を展開しようといふ、徒な欲求を持する者ではあるまいか。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は、新聞記事を読んでの私の記臆でありまして、詳しいことは何も存じませんが、又私はこれから、此の記事に出て来る実際人物のことを云はうとは思つてゐませんが、この記事を種に、私が想像出来るだけのことを記して、以て我邦感傷主義を一寸論じてみたいのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省の、その衝に当つた役人は、事務よりも先づ主観を述べられた。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてこそ、かの成巧者達が、大抵頸の硬い中庸主義者であり、殆んど理論なくカンでばかり体験し、苦労を咬み殺した人達であることが分ります。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "散文も少々あるやうだが、詩集アムール・ジョーヌは彼の主著である。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が今年になつて「新生」を受取るやうになつてから、漸く出たなとおもつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎたる彈くひと萩原朔太郎ぎたる彈く、ぎたる彈く、ひとりしおもへば、たそがれは音なくあゆみ、石造の都會、またその上を走る汽車、電車のたぐひ、それら音なくして過ぎゆくごとし、わが愛のごときも永遠の歩行をやめず、ゆくもかへるも、やさしくなみだにうるみ、ひとびとの瞳は街路にとぢらる。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ尾ばな藤ばかますでに色あせ、手にも料紙はおもたくさげられ、夏はやおとろへ、山頂は風に光る。",
              "citation": {
                "source": "山頂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔卑屈の友らをいきどほろしく〕宮沢賢治卑屈の友らをいきどほろしく粘土地二片をはしりてよぎり崖にて青草黄金なるを知りのぼりてかれ草黄なるをふめば白雪きららに落ち来るものか一列赤赤ならべるひのきふたゝび卑屈の友らをおもひたかぶるおもひは雲にもまじへかの粘土地なるかの官庁に灰鋳鉄のいかりを投げよ",
              "citation": {
                "source": "〔卑屈の友らをいきどほろしく〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔まひるつとめにまぎらひて〕宮沢賢治まひるつとめにまぎらひてきみがおもかげ来ぬひまはこころやすらひはたらきしそのことなにかねたましき新月きみがおももちをつきの梢にかゝぐれば凍れる泥をうちふみてさびしく恋ふるこゝろかな",
              "citation": {
                "source": "〔まひるつとめにまぎらひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔たゞかたくなのみをわぶる〕宮沢賢治　　……たゞかたくなのみをわぶる　　　　なにをかひとにうらむべき……ましろきそらにはゞたきてましろきそらにたゆたひて百舌はいこひをおもふらし",
              "citation": {
                "source": "〔たゞかたくなのみをわぶる〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
