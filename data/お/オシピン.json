        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのコルク・ボードをびっしりと何重にも埋めつくして、紙によるありとあらゆるものが、押しピンで止めてあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐわきの壁に、アランのポスターが押しピンでとめてあった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その壁に、冬彦が厳選した夏子の写真を、出来るだけ多く、しかしバランス良く、押しピンで留めた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日払いです」「応募します」「ほんとなら採用するわ」「ほんとです」　壁に向き直った彼女は、押しピンで四隅をとめたその貼り紙を、壁からはずした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのアパートメントへ持って帰り、部屋の壁のコルク・ボードに押しピンでとめておくといい、と彼は思った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙あるいはそれに類するもののすべてを、彼は押しピンでそのボードに留めておくことにしていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "引出しにしまったり書類箱、あるいはファイルに入れたりする代わりに、彼はここに押しピンで留めていた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間の壁の大きなコルク・ボートに、優子の母親の写真を、彼は押しピンで留めた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじく押しピンで留めてある数多くのものを、彼は見渡した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一定の間隔でホノルルから届く節子の手紙や絵葉書、そして同封されて来る写真も、押しピンで留めてあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「作りすぎかなあ」　大きく引き伸ばしたその写真を部屋の壁に押しピンで留めて、冬彦は何度も思案した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアには、ぼくの名刺が押しピンでとめてある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その柱の、立ちあがったぼくの目の高さのところに、写真が二枚、押しピンでとめてある。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱に押しピンでとめてある」「毎日、見てるの？",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　柱に押しピンでとめた二枚の写真を、ぼくは見た。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱に押しピンでとめてある二枚の写真に、小川は顎をしゃくった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
