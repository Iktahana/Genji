    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tea (esp. green or barley)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "行つて見るとまだ叔母は朝御飯が漸くすんだばかりで、ゆるゆるとお茶を飲みながら近所の人とトラックの話をしてゐるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶に早く起きたせゐもあつてか、その朝を思ひ出すたび、叔母のお茶碗から立つてゐた湯気が白々と見えてくるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は部屋から飛び出してお茶を取りに階下へ降りた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶道具と鉄瓶とを持って部屋へかえって来たら、もうすでに馬場と太宰が争っていたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の間わたしや此の子がお茶を飲んで寝た朝起すのに一骨折だつたから。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生と若先生と二人で患家を引受けていたが、老先生の方はでっぷりした上品な白髪のお茶人で、父の茶の湯の友達であった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの家から、絃歌の声が水面を渡って、宇治川のお茶屋にでも、遊んでいるような気がする。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一人でお茶を沸かして彼等にすすめました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "園さまはどうなされた今日はまだ顏が見えぬと問はれてまさかに、今までこれ／＼で次の間に泣いて居られますとも言ひがたければ、少々御不加※で、然しもう宜しう御座りませうほどに、まあお茶を一つなどヽ民は其塲をつくろひぬ。",
              "citation": {
                "source": "經つくゑ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして熱海ホテルでお茶を飲んで七時にはもう宅へ帰って夕食を食っていた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根ホテルでは勘定をもって来てくれと四、五度も頼んで待ち草臥れた頃にやっと持って来たのであったが、熱海ホテルの方ではまだお茶を飲んでいる最中に甲斐甲斐しい女給仕が横書きの勘定書をもって来て、「サービス三十銭頂戴します」と云った。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後のお茶は実験室内の教授室で催され、夫人と姉のシジウィック夫人もしばしば列席した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室で一、二時間仕事をしてからお茶になる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶の後、ことに冬季はよく子供達と遊んだ。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十七日と二十八日とは好天気であったので、戸外の美しい日光の下でお茶に呼ばれるために、二階からやっと下りて来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その部屋でお茶でも飲んで待って居てくれ」　七五郎、　「へッ、待たせて戴きます」　と石松と二人、次の部屋へ退る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでお茶でも呑んで待っていて呉れ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい新太、お客人にお茶出しな」　「へえ」　「さてと……吉兵衛、儂の番だったな」　「へえ」　次郎長、児分に、　「茶は要らねえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お静、次郎長にお茶を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは、初めは少し窮屈な客と思っていただけだったが、だんだんこの客の謎めいた眼の遣り処を見慣れると、お茶を運んで行ったときから鮨を喰い終るまで、よそばかり眺めていて、一度もその眼を自分の方に振向けないときは、物足りなく思うようになった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、いつ越すかわからないよ」　湊は珍らしく表で逢ったからともよにお茶でも御馳走しようといって町筋をすこし物色したが、この辺には思わしい店もなかった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶屋のボンボリの仄白い光の中から、芝居小屋にかかげられた幟の列を俯瞰する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お茶を一杯のんでから、おしかは清三に訊ねた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同教授にはかつてその本国で会ったことがあるばかりでなく、その実験室で北光に関する有名な真空放電の実験を見せてもらったり、その上に私邸に呼ばれてお茶のごちそうになったりしたことがあったので、すぐに昔の顔を再認することができたが、教授のほうではどうもあまりはっきりした記憶はないらしかった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者もそこで一風呂あびて室に帰ってつめたいお茶をこくりとのみそれから椽側へ出てあまり栄えもせぬおがせが滝を拝見に出ると、これはまた、さっきの大天狗殿がやはり椅子にすはってシガーをくゆらして滝を見てござったのである。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお茶を飲んでしばらく休んで、お茶代を一朱置いて行きました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その女の方がお蝶の名を訊いたり、年をきいたりして、やっぱり一朱のお茶代を置いて行きました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "製氷公司の社員からビールや、菓子や、お茶を御馳走されて、牛のよだれのような長話をつゞけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　お茶の水から本郷へ出るまでの間に人が三人まで雪で辷った。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽くおちゃらけてもいるし、最後のところなど、今にも私家版のエキスパンドブックを量産しそうな勢いです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
