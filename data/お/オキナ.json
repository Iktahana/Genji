        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同じく海の出て来るボオドレエルの詩だつて、「信天翁」だと、広々として一物も見えぬ、秋も終りの海が見えて来る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて筑摩書房から「千代女」が、高梨書店から「信天翁」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信天翁」には、主として随筆を収録しました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹屋の姐さんは吃驚した半身を店から出せば、筆屋の老翁は二三歩往來へ進み出て、共に引き行く人浪の趾を見送る事、少時焉たり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時われは裏道を西向いてヨボヨボと行く一人の老翁を認めた。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びヨボヨボと歩き出すと、ひとしきりの風が驀地に道の砂を捲いて老翁を包んだ時｜余は深き深き空想を呼起こした。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてこの哀れなる垂死の人の生涯を夢みた時、あたかもこの人の今の境遇が余の未来を現わしていて、余自身がこの翁の前身であるような感じがした。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも老翁の過去の歓喜の声が、ここに一時反響しているかのごとく。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「信天翁」には、主として隨筆を收録しました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "未だ四十歳にもならぬのだが、しかし、よほど前から自分の事を翁と署名し、また自分の家の者にも「お爺さん」と呼べと命令してゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りて七合目に至る、霜髪の翁、剛力の肩をも借らず、杖つきて下山するに追ひつく、郷貫を質せば関西の人なりといふ、年歯を問へば、即ち対へて曰く、当年八十四歳になります！",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉翁に、一夜の宿をまいらせたくもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕪翁のわが詠み捨てた句は、一つとして辞世ならざるはなしの徹底芸術精神は、学んで到り得るにあらねども、一｜順礼の最後の足跡までに、印をつけておいた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人は禿頭の工合から頬髯まで高橋是清翁によく似てゐる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人は禿頭の工合から頬髯まで高橋｜是清翁によく似ている。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに山を愛し、山に冥通するがゆえに、山の祖神と呼ばるる翁があった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は手を翳して眺める。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は須臾にして精神のみか肉体までも盛り上る土堆と関聯した生理的感覚を覚える。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は、時には、手を長くさし出して地平の線に指尖を擬する。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は地平のかなたの端から、擬した指尖を徐ろに目途の正面へと撫で移して行く。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに距離の間隔はあれども無きが如く、翁の擬して撫で来る指の腹に地平の林は皮膚のうぶ毛のように触れられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の翁がそう感ずると等しく、自然自体も感ずるのであろうか、翁の指尖が目途の正面を越して反対側へ撫で移るまもないところから地平は隆起し、麓から中腹にさしかかり、ついに聳え立つ峯巒となる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠方から翁の指尖はこつに嵌ったその飛躍の線に沿うて撫で移って行くと音楽のような楽しいリズムを指の腹に感ずる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の端で翁は、つれづれであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は腕を動かして自分の肉体の凸所を撫でまわす。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩尖、膝頭、臀部、あたま――翁の眼中、一々、その凸所の形に似通う山の姿が触覚より視覚へ通じ影像となって浮んで来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山処のひと本すゝぎ朝雨の狭霧に将起ぞ　翁は身体を撫でながら愛に絶えないような声調で、微吟した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山又山の峯の重なりを望むときの翁は、何となく焦慮を感じた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔いざ渡せかし　おいぼれめ〕宮沢賢治「いざ渡せかし　おいぼれめいつもこゝにて日を暮らす」すぱとたばこを吸ひやめて何を云ふともこの飯の煮たたぬうちに　立つべしや芋の子頭白髪しておきなは榾を加へたり",
              "citation": {
                "source": "〔いざ渡せかし　おいぼれめ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のおどおどしてまごついてる樣子をみると、彼は直ちに態度をかへ、急に平易なざつくばらんな調子になつて、心おきなく書生流儀で話しかけた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
