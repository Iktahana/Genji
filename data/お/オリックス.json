      {
        "index": 1,
        "gloss": "oryx (esp. the gemsbok, Oryx gazella)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
