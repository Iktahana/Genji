[
  {
    "uuid": "4d133491-b00e-5270-bcef-7116b4ef9322",
    "entry": "恩顧",
    "reading": {
      "primary": "おんこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
