        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "其の次の室も、他は推して知るべしで、珍什奇器殆ど人界のものにあらず、一同呆然として、口を利くものある事なし。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の下へ忍ばした勢だから、氣焔と、殺風景推して知るべしだ。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと芸術家ってのは厚顔無恥の気障ったらしいもので、漱石がいいとしをして口髭をひねりながら、我輩は猫である、名前はまだ無い、なんて真顔で書いているのだから、他は推して知るべしだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の性質の美、推して知るべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の種の慾は推して知るべしであると。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬に騎りて上れるを見ても、赤城山の嶮ならざることは、推して知るべし。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛り場の柳原にしてこれだったら、他は推して知るべしなのだ。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "以て推して知るべしである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも何がしのパリパリでさえこうだから、他は推して知るべしだと思った。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人格と徳義を最も大切にするお医者様の、しかも何々博士と銘打った人までがこうした最新式の営業振りを見せる程、震災後の東京の商売は発達しているのだから、他は推して知るべしである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでも妻君の顏色の曇つた日は、この一校の長たる人の生徒を遇する極めて酷だ、などいふ噂もある位、推して知るべしである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでも妻君の顔色が曇つた日は、この一校の長たる人の生徒を遇する極めて酷だ、などいふ噂もある位、推して知るべしである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか原節子が見舞いに寄つたとき、玄関に出て「どなたですか」ときいたくらいだから、その映画遠いこと推して知るべしである。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見旧知の如し、逢うて直ぐヨタのいひあひこが出来るのだから、他は推して知るべしである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他は推して知るべし。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに都下繁昌につれて、追々食店多くなりし中に、明和のころ深川洲崎の料理茶屋は、升屋祝阿彌といふ京都風に傚ひたるべし、此者夫婦の機を見る才あり、しかも事好、廣座敷、二の間、三の間、小座敷、小亭、又は數奇屋｜鞠場まであり、中庭推して知るべし。",
              "citation": {
                "source": "花火と大川端",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの位儲かるかは、この一事を以て推して知るべしだよ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々たる海牛丸、二千五百｜噸の機関長が、コンナ部屋に跼まっているんだから推して知るべしだろう。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＯＳを打ってみても聯合艦隊が相手にしてくれない……というのだから、その騒動たるや推して知るべしだろう。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "デその途中私は独り首肯き、この下駄と傘が又役に立つ、駕籠に乗たって何も後に残るものはない、こんな処が慎むべきことだと思たことがあります、マアその位に注意して居たから、外は推して知るべし、一切無駄な金を使たことがない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "右御殿女中の一例を見ても大抵、世の中の有様は推して知るべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他推して知るべしである。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまり磐梯山の爆発も、クレマンソオへ出した辞職届も、女たらしの大学生も、皆その白味のような物から出て来るんだ、我々の思想や感情だって――まあ、他は推して知るべしだね。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は推して知るべしといふのが、芝居道の娘である。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "執心のほど推して知るべしである。",
              "citation": {
                "source": "女優と劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の碁敵だから、推して知るべし。",
              "citation": {
                "source": "囲碁修業",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺三寸、三十八貫、江戸の大関でもあの野郎の鉄砲一発くわせたら危ねえもんだわと若い者をほめたがらない古老が言うほどであるから、推して知るべし。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の公子がその若さであるとすると、弟の公子の年ごろは推して知るべしである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "集解の釋に云ふ、「夷とは東夷なり、東夷を擧げて示す、餘は推して知るべし。",
              "citation": {
                "source": "蝦夷とコロボツクルとの異同を論ず之に潜みて",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の酉のにぎはひは此近年おぼえぬ景氣といへり、熊手、かねもち、大がしらをはじめ延喜物うる家の大方うれ切れにならざるもなく、十二時過る頃には出店さへ少なく成ぬとぞ、廓内のにぎはひおしてしるべし。",
              "citation": {
                "source": "「樋口一葉全集第二卷」後記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
