        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この種の人は正式の教育を受けない独創的気分の勝った人に往々見受ける事で甚だ惜しむべき事である。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに現代の日本ではただ天恵の享楽にのみ夢中になって天災の回避のほうを全然忘れているように見えるのはまことに惜しむべきことと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは惜しむべきことである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗下の諸将との間が、うまく行かなかった事は彼の為に惜しむべきであった。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは惜しむべきことであるかもしれないが、あるいはやみがたい自然の現象であるかもしれない。",
              "citation": {
                "source": "科学者と芸術家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しむべきのはなはだしきなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ惜しむべきは、和歌山城近くに松生院とて建築が国宝になっておる木造の寺がある。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜福の工夫と分福の工夫とを共に能くするは、その人すでに福人たりと云うべきであるが、世の実際を観ると能く福を惜しむ人は多くは福を分かたないで、能く福を分かつ人は多くは能く福を惜しまない傾向があるのは、嘆き惜しむべきである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に福は惜しむべきであってまた福は分かつべきである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に原稿紙の上でまで吃りになれとは誰が求めることができようか、せめて文章を書く唯一の自由を彼に学ぶべきであらう部分的には『純情』を売り、全体的には文字を売つて生活してゐる彼を見遁すべきだ、俗にいふ、好漢惜しむべきはあまりに好漢である。",
              "citation": {
                "source": "小熊秀雄全集-12",
                "author": "詩集（11）文壇諷刺詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しむべきことである。",
              "citation": {
                "source": "大阪で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸以来の名物たる錦絵がほろびたと云うのは惜しむべきことに相違ないが、わたしは歳晩の巷を行くたびに特にその感を深うするもので、いかに連合大売出しが旗や提灯で飾り立てても、楽隊や蓄音器で囃し立てても、わたしをして一種寂寥の感を覚えしめるのは、東京市中にかの絵草紙屋の店を見いだし得ないためであるらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "喃、瀧口殿、最早や世に浮ぶ瀬もなき此身、今更｜惜しむべき譽もなければ、誰れに恥づべき名もあらず、重景が一｜期の懺悔聞き給へ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今となっては、それは惜しむべき返らぬ日である。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のいのちの中の一番のエレメントを引き出す空気が欠けていたことは惜しむべきことであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水難救済会はその会の目的が日常的のものであつて今日の赤十字社の如く戦時にのみ働くといふやうなものとは性質を異にしてをるにかかはらずかへつて微々として振はんのは県官の誘導も赤十字社の如くあまねく及ばないのであるか、あるいは勲章めきた徽章のないためであるか、何にしても惜しむべき事であると思ふ。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "後失行があつて終をよくしなかつたのも惜しむべきである。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "無政府主義と、それといっしょに芽ざした社会主義との排斥をするために、個人主義という漠然たる名をつけて、芸術に迫害を加えるのは、国家のために惜しむべきことである。",
              "citation": {
                "source": "文芸の主義",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、惜しむべき年齢ではないのですが、旅の途中で病みました母に、正念に念仏もさせて終わらせたいと仏のお助けを乞うておりましてその人のほうはくわしく見ませんでした。",
              "citation": {
                "source": "源氏物語",
                "author": "夢の浮橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ自動車のドライヴは愉快だがあらゆる人情と風景と地球が縮まってしまうことは惜しむべきことだと思う。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表現の率直なるは善良なる趣味性を害ふの感あるも、誰も泡鳴の天賦を疑ふものあるを聞かず、彼が文学的円熟期に入らずして死せるは、最も惜しむべきものとす。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に舞ひたるすげ笠の何かは道に落ちざらんわが名はいかで惜しむべき惜しむは君が名のみとよ。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってこんなものを私のところにお送りになったのかしらといぶかりながら、ふと最後の一節、――「いかで惜しむべきほどのわが身かは。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ惜しむべきはその解脱は同時に解脱する筈の主體の壞滅を意味することである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古代エジプト王朝時代の遺物がメムフィスの地に殆んど全く見られなくなってるのは返す返すも惜しむべきである。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会性と処世との配慮はやや後れてくるべきものであり、それが青春の夢を食い尽くすことは惜しむべきである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故に青年時代に高く、美しい書物を読まずに逸することは恐るべく、惜しむべきことである。",
              "citation": {
                "source": "学生と読書",
                "author": "――いかに書を読むべきか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそして自分がいとおしむべきものであるということを知るのである。",
              "citation": {
                "source": "映画と季感",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然にふれることで、自分のほんとうのあるべき、守るべき姿にぶっつかり、ほんとうの自由な自分、いとおしむべき、健康な、大切にすべき自分に気がつくことは、大変なことである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
