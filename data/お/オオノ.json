        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "膳に向かえば大野味噌汁。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その點では、天下の大野暮乃木將軍も亦、ものの見事に通人の資格あらむ乎。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも大野原の上を、自由に飛翔しようとする大鳥が羽翼を収めて、暫く休息している姿勢を、富士は取っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六番目は誰です」　「追分け三五郎」　「七番は」　「尾張の大野の鶴吉」　「八番は」　「尾張の桶屋の吉五郎」　「九番は」　「三保の松五郎」　「十番は」　「問屋場の大熊」　「十一番は」　「よせやい、爺っつあん。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "覚えてろ」Ｓ＝亀崎の宿の旅籠「大野屋」（夜）　土間が居酒屋になって居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し右手の臥牛山の中腹から、やや急な傾斜を作つて、入り亂れた家家が流れるやうに大野の平地の方へ擴がつてゐる地形の面白さが私の眼を惹いた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、稲垣、大野、川本、坂田、みなそれぞれ二三分間おくれて、別の扉を叩くのであった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひかりうづまく黒の雲、　　ほそぼそめぐる風のみち、苔蒸す塔のかなたにて、　　大野青々みぞれしぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南はも大野のはてに、　　　　　ひとひらの吹雪わたりつ、日は白くみなそこに燃え、　　　うららかに氷はすべる。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしはそれが密林だったので何事も少かったのですが、十余年｜前に悉く伐採したため禿げた大野になってしまって、一夕立しても相当に渓川が怒るのでして、既に当寺の仏殿は最初の洪水の時、流下して来た巨材の衝突によって一角が壊れたため遂に破壊してしまったのです。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にも取らないで、口のなかに低声におよみなすったのが、市内衛生会委員、教育談話会幹事、生命保険会社社員、一六会会長、美術奨励会理事、大野喜太郎。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　越前國大野郡の山家の村の事である。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大野の話も頷かれて、そのはたらきも察しらるゝ。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀の大野、根生の濱を歩行いた時は、川口の洲の至る所、蘆一むらさへあれば、行々子の聲が渦を立てた、蜷の居る渚に寄れば、さら／＼と袖ずれの、あしのもとに、幾十羽ともない、くわらくわいち、くわらくわいち、ちよツ、ちよツで。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺は佐々木盛綱と大野九郎兵衛との墓を所有しているので名高い。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私に取っては大野九郎兵衛の墓の方が注意を惹いた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『仮名手本忠臣蔵』の作者｜竹田出雲に斧九太夫という名を与えられて以来、殆ど人非人のモデルであるように洽く世間に伝えられている大野九郎兵衛という一個の元禄武士は、ここを永久の住家と定めているのである。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その縁故に因って大野は浅野家滅亡の後ここに来て身を落付けたらしい。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、大野ともいわず、九郎兵衛とも名乗らず、単に遊謙と称する一個の僧となって、小さい草堂を作って朝夕に経を読み、傍らには村の子供たちを集めて読み書きを指南していた。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "復讐の同盟に加わることを避けて、先君の追福と陰徳とに余生を送った大野九郎兵衛は、不忠なる元禄武士の一人として浄瑠璃の作者にまで筆誅されてしまった。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度行ってみると、佐々木の墓も大野の墓も旧のままで、大野の墓の花筒には白い躑躅が生けてあった。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くさきは大野屋という店で、ここも今日は煤掃きである。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おせきも安心したが、折角ここまで来た以上、すぐに帰ってしまうわけにもいかないので、病人の枕もとで看病の手伝いなどをしているうちに、師走のみじかい日はいつしか暮れてしまって、大野屋の店の煤掃きも片付いた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、大野屋の伯母は言った。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせきが影を踏まれたのは、やはりここの家から帰る途中の出来事で、かれがそれを気に病んでいるらしいことは、母のお由から伯母にも話したので、大野屋一家の者もみな知っているのであった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それが大野屋の人々にもきこえて、伯母夫婦も心配した。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「世間の人達は妾のことを、鬼火の姥と申しております」「おおおのれが鬼火の姥か！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "様式は同一でありながらなおおのおのの時代の日本人自身の心の律動を表現しているということは、右のごとき第一次的と第二次的との二つの層において見いだされ得ると思う。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに富める青年が自己の無力を悲しんだまま、なおおのれを投げ出しえずして去ったのは、まことに惜しみても余りあることです。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
