        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "厳かな入学宣誓式が行われて、自分も大勢の新入生の中にまき込まれて大講堂へ這入ったが、様子が分らないのでまごまごしていると、中に一人物馴れた日本人が居ていろいろ注意してくれて助かった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはしづかで、きらびやかで、なみなみと湛へ、　　去りゆく女が最後にくれる笑ひのやうに、　　厳かで、ゆたかで、それでゐて佗しく　　異様で、温かで、きらめいて胸に残る……　　　　　　あゝ、胸に残る……風が立ち、浪が騒ぎ、　　無限のまへに腕を振る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "清らかな斎の衣は、鶴の羽づくろいしながら泉を渡るに似て爽かにも厳かである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "麓の春の豪華を、末濃の裳にして福慈岳は厳かに、また莞爾として聳立っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱などを巻いた布が黒白のだんだらになっているところを見ると何かしら厳かな儀式でもあるように思われる。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝、お日様がカツカツカツと厳かにお身体をゆすぶって、東から昇っておいでになった時、チュンセ童子は銀笛を下に置いてポウセ童子に申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日様がもうサッサッサッと三遍｜厳かにゆらいで西の山にお沈みになりました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は以前とは反対に溪間を冷たく沈ませてゆく夕方を――わずかの時間しか地上に駐まらない黄昏の厳かな掟を――待つようになった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……巌の層は一｜枚づゝ、厳かなる、神将の鎧であつた、謹んで思ふに、色気ある女人にして、悪く絹手巾でも捻らうものなら、たゞ飜々と木の葉に化して飛ぶであらう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というはっきりした厳かな声がしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戦闘艦隊が三十二隻、次々に出発し、その次に大監督の大艦長が厳かに舞いあがりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳かにそのあやしい円い熔けたようなからだをゆすり間もなく正しく空に昇った天の世界の太陽でした。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鉛筆を直ぐこの人にお返しなさい」と厳かに命つけた。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と厳かに膝を進めました。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実は人知れず天が下にて行なわれし厳かなる事実なり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより後なお真の友義というものわれらが中に絶えずば交わりは勉めずとも深かるべし、ただわが言うべきを言わしめたまえ、貴嬢のなすべきことは弁解を力むることにはあらで、諸手を胸に加え厳かに省みたもうことなり、静かにおのが心を吟味したもう事なり、今われ実にかの人を愛するや否やと。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろし二字、厳かなる二字、人を生かし人を殺す二字。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父さんはそれを見て、よけい声を高めて笑いましたが、やがてまた、きっと、トシオの方を向いて、今度は厳かに、「トシオ、まったくだよ。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その時まで、じっとこのありさまを、傍で見て居らしった神様が、「青いと思う小鳥は青い方へ、赤いという小鳥は赤い方へ、黒いと考える小鳥は黒い方へ、白いと囀る小鳥は白い方へ、めいめい飛んで行ったがよいわ」　と、厳かに、お命じになりました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は厳かなその形を一度くずして、へへへんと笑った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふはつきりした厳かな声がしました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戦闘艦隊が三十二隻、次々に出発し、その次に大監督の大艦長が厳かに舞ひあがりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦ちょっとお押え申せ」　いと厳かなる命のもとに五名の看護婦はバラバラと夫人を囲みて、その手と足とを押えんとせり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真屋は倉持が結婚してからは、好運が急角度で自分の方に嚮きかえり、時節が到来したように思われ、大島の対の不断着のままの銀子を料亭の庭の松の蔭に立たせて、おもむろにシャッタアを切るのだったが、二階へあがって来ると、呑めもせぬ酒を注ぎ、厳かな表情で三々九度の型で、呑み干したり干させたりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真屋は倉持が結婚してからは、好運が急角度で自分の方に嚮きかえり、時節が到来したように思われ、大島の対の不断着のままの銀子を料亭の庭の松の蔭に立たせて、おもむろにシャッタアタア」］を切るのだったが、二階へあがって来ると、呑めもせぬ酒を注ぎ、厳かな表情で三々九度の型で、呑み干したり干させたりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから小さな咳を一つすると繊細い……けれども厳かな口調で云った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酢の一に対して、油は三の割合」　厳かな宣告のようにこういい放ち、匙で三杯、オレフ油を蔬菜の上に撒き注ぐときには、教師は再び横柄で、無雑作で、冷淡な態度を採上げていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久次郎もそれを信用して、なにぶんお頼み申すと云うと、行者はお豊を神壇の前に坐らせて、一種のおごそかな祈祷を行なってくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "改めておふくろ殿にお掛け合いをいたすために、こんにち罷り越した次第であると、式部は形を正しゅうしておごそかに云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なになんでもないですよ、大丈夫ですよ」と学生がさも請け合ったように言ったのに対して、駅員は急におごそかな表情をして、静かに首を左右にふりながら「いや、そうでないです、そうでないです。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
