        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「to meet (someone of higher status)」である。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「to meet (someone of higher status)」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「to meet (someone of higher status)」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "to meet (someone of higher status)」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし昼間お目にかかるのは初めてでございますからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今夜はごたごたして居るから明日お目にかかる積りでいましたの。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこれまで彼女に会いたいなど夢にも思わなくなりましたが、貴女には会いたいと思っていましたから……」「それではお目にかかる事が出来る縁を待ちましょうね。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目にかかるのじゃなかったんです。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはね、この森をはいって行ってアルキル中佐どのにお目にかかる。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "確に、……何ですか、一つまくってお目にかかるとしますかね。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今初めてお目にかかる景色でもないが、とにかくに筆を執るに当って、その実地を一度見たいというような考えで、わざわざここまで足を運んだのである。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわいいぼっちゃまには、食事のあとで、お目にかかることになりました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前のお正月に、本当に久し振りにお目にかかる事が出来て、うれしゅうございました。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言う口の下から、もう此の逢い度い心は、……ええ、も、いっそ、今日は、お上人さまにお目にかかるのはやめてしもうて、源兵衛さんに逢う一筋に骨を折ってみましょう。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さまのところへ、挨拶に行くのが何となくおっくうで、不快で、しばらくの間ぼんやりしていると、さっきの女中が来て、「奥さまが、お部屋でお目にかかるといっていらっしゃいます。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、もしきょうの夕方、あの男がもう一度様子を見にいって、やっぱりまだ空家のままだったら、お目にかかるよ。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後お目にかかるのをお待ち致しております。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たびたびお目にかかるね」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで来年またふたたびどこかでお目にかかるときまでには少くとも幾何の遺物を貯えておきたい。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時放送は、さらに続いて、「きょうの夕食後に、それぞれお化粧を洗い落し、おそくとも今晩七時半の摩擦の時には、アメリカの人たちにへんな誤解をされない程度の簡素なよそおいで、塾生諸君にお目にかかるそうでございます。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう私は死んでもよいと見られる人間なんでございますが、少しこの世に未練を持っておりましたのはこうしてあなた様にお目にかかるということがあの世ではできませんからでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宮にお目にかかると、ずっとお身大きくなっておいでになって、珍しい源氏の出仕をお喜びになるのを、限りもなくおかわいそうに源氏は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもお目にかかるたびにあなたのきれいなのに驚いてばかりいましたよ。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれほど恨んだかしれない方にお目にかかることになりました」　おとどはこう言って幕の所へ来た。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方にね、近ごろお目にかかることができましたからね。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まででも時々いらしったんだけれどもついにお目にかかるおりがなかったわね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「始めてお目にかかるが、愛子さんおいくつ」　倉地はなお愛子を見やりながらこう尋ねた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はあなたにお目にかかる気にはなりません。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかの晩、あなたとお目にかかるお約束をして、十時の時計が鳴るのが待ち遠しく、やっと人目を忍び、胸をおどらせ、足は宙をふんで、四阿へ参りますと、あなたは思いがけなく京子さまと話していらっしゃいました。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度、あなたにお目にかかるときは、夫と妻としてお目にかかるつもりです。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の方におめにかかるのは非常に愉快です」　日本からいろんな外国へ駐在武官が派遣されている。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "塾がちがつたものですから、これと云つて、まとまつたお話もうかがつた事もありませんでしたし、ゆつくりおめにかかると云ふやうな機会もありませんでしたが、そのころ、お若い内から春挙さんは、すつくりした、いかにも書生肌の、大変話ずきの人でした。",
              "citation": {
                "source": "旧い記憶を辿つて",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "塾がちがったものですから、これと言って、まとまったお話もうかがった事もありませんでしたし、ゆっくりおめにかかるというような機会もありませんでしたが、その頃、お若い内から春挙さんは、すっくりした、いかにも書生肌の大変話ずきの人でした。",
              "citation": {
                "source": "古い記憶を辿って",
                "author": "山元春挙追悼",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから着物を着換えて、汪精衛閣下におめにかかることになっていた。",
              "citation": {
                "source": "余齢初旅",
                "author": "――中支遊記――",
                "note": "青空文庫"
              }
            }
          ]
        }
