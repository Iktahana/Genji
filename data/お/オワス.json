[
  {
    "uuid": "97bc3b9c-e84b-5c3e-95c0-a0c77ea3d364",
    "entry": "御座す",
    "reading": {
      "primary": "おわす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
