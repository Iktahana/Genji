    "definitions": [
      {
        "index": 1,
        "gloss": "field of flowers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お花畑の名が、富士にあるのも珍らしい。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お花畑の名が、富士にあるのも珍らしい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "高峰の花のあるところに、お花畑の名はつき物だが、御庭はあまり聞かない名だ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "デパートアルプスには、階段を登るごとに美しい物と人との「お花畑」がある。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花畑は呼んでゐる、遊びにおいでと呼んでゐる。",
              "citation": {
                "source": "雀の歌",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまやの角をすぎて、お花畑から、麦畑へあがる草の土手の上で、虫をふせました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "芍薬か、牡丹か、菊か、猿が折って蓑にさす、お花畑のそれでなし不思議な花よ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまやの角をすぎて、お花畑から、麦畑へあがる、草の土堤の上で、虫をふせました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、深山のお花畑、初雪の富士の霊峰。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊笹の柔かそうな微風の深い斜面の裾にはまた、紅の華魁草に似た花が見渡すかぎりのお花畑を作っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その山腹のお花畑の美しさは、その紅は黄は紫は、全く何に譬えよう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは窪地のようになって遠くの見はらしはなかったが、お花畑のように美しい場所であった。",
              "citation": {
                "source": "山寺の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ちょっと往ったところで樹木の枝葉がなくなって、お花畑のような赤白紫黄、色とりどりの葉を持ち花をつけた草庭になって、その前に枌葺の庵室のような建物があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芍薬か、牡丹か、菊か、猿が折つて蓑にさす、お花畑のそれでなし不思議な花よ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラバンのバン一万三千尺、富士の山せまい日本が、一眼に見える、お花畑で、カルモチン。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し下り、凌雲岳を右にして行くに、お花畑連続す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花畑の連続にて、傾斜も緩也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花畑が咲いていました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにおられるじゃアありませんか、その綺麗なお花畑の中に、妾の大好きなお方がね！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でもどうでしょう、そのお花畑がやっぱり町なのでございますの。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒマラヤ山のお花畑に青い花が月光を吸っていた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒマラヤ山のお花畑に青い花が月光を吸つてゐた。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで百花撩乱のお花畑のような、ペンキ塗りの玩具箱をひっくり返したような、青春の夢のように美しくも目を奪うものであった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白峯三山とここで別れて淋しいが下らねばならぬ、白峯御池らしく見えた残雪へ向ってお花畑を一気に下ってみると、これは池ではない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "這ひ松や、白い花を萬朶と咲かせたいそつゝじのお花畑へ出た。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此お花畑は硫黄山麓十五六萬アールに亙つてゐる。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャフェのテラスには、だんだら縞の海岸傘が一時にパツと開いて、パリは、高山のお花畑になつてしまつた。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの清水平あたりのお花畑の美しさは、恐らく日本第一と、今でも其の印象の焼きついた想い出を、さも楽しそうに話すことの出来る幸福を顧みねばならない。",
              "citation": {
                "source": "登山は冒険なり",
                "author": "河東碧梧桐",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお矢岳の山脚と相接するところに、宝原の高原があるが、この高原がまた見渡す限りのつつじ原で、すぐ目の下にこのお花畑を見下す五月の高岩山が、如何に美しいであろうかは、容易に想像されよう。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
