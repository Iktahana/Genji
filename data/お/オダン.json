        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それからなお段々と長ずるに従って進むかというと、先ず概してそれより以上は進まない。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　おお段六公ではねえか！",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっつり右門のだんなと聞いちゃ、おらがひいきのおだんなさまだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "精出して音いろを覚えろ、にせの小判とほんものとでは音が違うからと、おだんなさまがおっしゃったんで、音いろを聞き分けているんですよ」「うそおっしゃい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上のおだんなのところから、お葉さんがお使いにみえましてね――」「葉というは女中か！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "変なことに出会ったというのはそれっきりか」「いえ、もう一つあとで気がついたことなんですが、どう考えてもふにおちないことがあるんですがね」「なんじゃ」「お葉さんがお使いに来たとき、井上のおだんなは夜勤に出かけてるすだとたしかにおっしゃったのに――」「いたというのか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう鼓は、なんというんだか、謡の鼓でもなし、三河万歳の鼓でもなし、どうもさる回しのたたくやつじゃないかと思うんですが、それをまたどうしたことなんだか、井上のおだんながひどくお堪能でね、今までもときおりちょくちょくと夜ふけになんぞおたたきになったんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八丁堀のおだんながたでござりまするか」　早くも右門主従をそれと知ったらしく腰を低めましたので、名人もまたおごそかにきき尋ねました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、生島屋のおおだんなに八郎兵衛っていうおにいさんがもうひとりごぜえましてね、そのかたが兄でありながら、あんまりおかわいそうなご沈落をしていなさるので、見るに見かねて、あっしがちっとばかり侠気を出したんでごぜえますよ」「なるほど、さようか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、でたらめの朝鮮語ではありますが、ともかくも、日本語でないことばでいろごとをしようというのですから、かりにも江戸一円の警察権を預かっている八丁堀のおだんながたがくふうした趣向にしては、まことに変わった思いつきというべきでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなきっぷのいいおだんなを、なんだってまた江戸の女の子がいつまでもひとりでおくんだろうな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉のいなかよりたんまりとやまぶき色をご用意のおだんな衆が三人ほど参り候まま、万障お繰り合わせご入来くだされたく、みなみな首長くしてお待ちいたしおり候。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の金竜山にしてもあんと、きなこと、ごまのついた餅、芝の太々餅もおなじくであり、大橋ぎわのおだんご、谷中｜芋坂のおだんご、そのほか数えたらいくらでもあるが――　中洲は納涼にもってこいだから、川開きの時分の賑いは別段だった。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し昔から東京人が物見遊山やおまゐりに出かければ、帰りにはきつと何処かに寄つておそばかうなぎを食べ、なるべくけんやくしても、くづ餅やおだんご位はたべたのだから、デパートの食堂に入ることも昔のおまゐりと少しはつながりがあつたのかもしれない。",
              "citation": {
                "source": "買食ひ",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつもの茶店のうちの一軒でお茶を飲みおだんごを食べる、婆やさんがおてうもくと呼んでゐる大きい銅貨を二つ三つ出してお菓子をいくつも買ひ、十銭位のお茶代を置いた。",
              "citation": {
                "source": "豚肉　桃　りんご",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おおおおだんだん近寄って来る！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "都合で須山のおだんなや芹沢の金五郎と逢つて見べえ。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはとしよりのお献立に、春らしく蕗だの花菜（油菜の花の蕾のついたの）、うど、コリフラワーなどにとりの肉のたたいたのをおだんごにしたのをなべにします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおだんだん近づいてきたので、デンは後ずさりした。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
