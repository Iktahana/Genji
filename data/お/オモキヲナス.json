[
  {
    "uuid": "096e9186-83a6-5d34-8309-89c4872c39f4",
    "entry": "重きをなす",
    "reading": {
      "primary": "おもきをなす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
