        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奈々子もあとから、「わたえもおんも、わたえもおんも」　と同じく父に取りつくのであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつものごとくに、おんぼという姉とおんもという妹とをいっしょに背負うて、しばらく彼らを笑わせた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんもといい、あっこといい、おっちゃんといったその悲しい声は永遠に父の耳を離れてしまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっちゃんにあっこ、おっちゃんにおんも、おっちゃんがえい、お児ちゃんのかんこ、お児ちゃんのかんこがえいと声がするかと思うほどに耳にある彼の子の言葉を、口にいいさえすればすぐ涙は流れる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと二歳に成る嬰兒だが、だゞを捏ねて言ふ事を肯かないと、それ地震が來るぞと親たちが怯すと、「おんもへ、ねんね、いやよう。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子もあとから、『わたえもおんも、わたえもおんも。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつもの如くに、おんぼといふ姉とおんもといふ妹とを一所に背負うて、暫く彼等を笑はせた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんもと云ひ、あつこと云ひ、おつちやんと云つた其悲しい聲は永遠に父の耳を離れて終つた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつちやんにあつこ、おつちやんにおんも、おつちやんがえい、お兒ちやんのかんこ、お兒ちやんのかんこがえいと聲がするかと思ふほどに耳にある彼兒の詞を、口に云ひさへすれば直ぐ涙は流れる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恒藤権右衛門家内より、近藤右門様おんもとへ――」「こめんどうくせえこといってくるじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳子先生　おんもとへ　恋の力は遂に二人を深い惑溺の淵に沈めたのである。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんもてなしはわたくしどもの役目、何事も不行届きで申し訳がござりませぬ。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士｜額で、細い眉、おんもりとした高い鼻、ちょっと酷薄ではあるまいか？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※雁がとどけし玉章は、小萩の袂かるやかに、返辞しおんも朝顔の、おくれさきなるうらみわび……　安房守は立っていた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "艮が受けた山陰の海村には、稍おんもりと陰りがさして来た。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばあちゃん、おんも……よう。",
              "citation": {
                "source": "鳥鳴く朝のちい子ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばあちゃん、おんもよう。",
              "citation": {
                "source": "鳥鳴く朝のちい子ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、さ、おんもへいきましょう。",
              "citation": {
                "source": "鳥鳴く朝のちい子ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉服太物商磯五よりおんもとさまへの貸方二百五十両のとりたてを任せられ候については、右貸金はすでに三年越しにて、最初内金五両お下げ渡しありたる後は、月延べ月延べにて何らの御挨拶なく打ちすぎ参り候段、磯五とてもいたく迷惑いたしおり候ことお察し願い上げそろ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの御親愛なるシルヴァニー様については、おんもとに御滞在もしばしのことと存じますので、私へおたよりのひまもございますまい。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "――重ねて申上げそろ、大願の二字はけんもつの眼にこそ触れめとて彫りつけ候ものにござそろ、うえさまおん眼を汚し奉り候儀は、おそらくはみよの一心を神明の加護せさせたもうところと存じそろ、べつに使者を以て言上つかまつるべく候も、おんもとよりも御前よしなに御披露のほどたのみいりそろ。",
              "citation": {
                "source": "日本婦道記",
                "author": "箭竹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失礼でござるが、おんもとには、九条家から善信御房へ嫁がれた玉日姫でおわすか」「はい……」やはりそうだった、というように法師二人はまた、顔を見あわせてなにか笑っていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみると、おんもとがここにおられた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は日ならずして、時の花の都、開封東京にたどり着き、さっそく大相国寺の智清大禅師をその山門に訪うて、「拙僧は智深と申す五台山の一弟子ですが、当山の禅師がおんもとにて修行を積めいと、師よりお添状をいただいてまいった者。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
