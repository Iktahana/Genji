          ],
          "literary": [
            {
              "text": "お兄ちゃんはただにしとく」　ハアハア息を弾ませながら、娘は言った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなで家に帰ったら、ボブお兄ちゃんにこれをあげるんだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボブお兄ちゃんやあたしが大好きなんだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から、妹の礼子が、「お兄ちゃん泣いてるよ」　と、走って男の手へつかまった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居をまたぐと、そこの土間で飯ごとしていた六つの妙子がポツンと、「お兄ちゃんが来たヨ」と云った。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お兄ちゃん、まだお月きまが出ているよ。",
              "citation": {
                "source": "昼のお月さま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、不意に、「チョビ安お兄ちゃんは、どこへ行ったかわからないのねえ」　と、こどもながらも何かしら、しんみりした口調で申しました。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄ちゃんが可愛がっているから仕合わせです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎がいい子でお兄ちゃんになれそうならいまに赤こちゃんをくれるという話です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後から国男、アボチン改称お兄ちゃん同伴、初対面に出かけます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを見たお兄ちゃんは、『Ｕ子はいつも心がけが悪く意地わるなのを狐も知っているから狐もおとなしく抱かれないのだ』　といいました。",
              "citation": {
                "source": "愉快な教室",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「壮ちゃんはお兄ちゃんだもん、いい子よね」「…………」「いい子だから、ごほうびに、いいもの、あーげる。",
              "citation": {
                "source": "日めくり",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらん、おにいちゃんも、ここにいるよ。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
