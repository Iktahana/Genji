        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「大家さんが交番へ行ってくださったら、俺の管轄内に事故のあったことがないって。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか職業がなければ、このごろの大家さんたちは貸してくれないということを聞きましたので、ま、あんな出鱈目をやったのです。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの大家さんは、わかくて善良らしいとか、そんな失礼なことを言いまして、あの、むりにあんなおかしげな切手を作らせましたのでございますの。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家さんは火鉢と茶道具とを運んで来て、にこにこ笑いながら、「何かいるものがありましたなら遠慮なくおっしゃい」と言って、禿頭に頬冠をして尻をまくった父親の姿を立って見ていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいるところを大家さんはよく知っていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゆきの話ではその錺屋が大家さんなのだそうだった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おゆきがそこの人にものをいうときの声の調子で大家さんというのは普通の隣家とちがう何かであることはわかったが、カザリヤという商売との関係がわからなかった。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この木村屋の大家さんは三丁目の丸八だとか。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらためて、親愛なる電子大家さんに、深く感謝いたします。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご感想、ご指摘を、大家さん提供の左記のアドレスでお待ちしています。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家さんの女中さんらしいのがかれすすきの唄をうたって横の道を通っている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家さんは宮武骸骨さんと云う人なのだそうだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「洽子さん柿の実はもう食べられるでしよ」「あら、あの柿ねえ、愉しみにしてゐたら、大家さんでみんな持つて行つちやつたのよ。",
              "citation": {
                "source": "柿の実",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昼間は、暖けえが、夜は矢張り、寒いね、大家さん」「うん」　大家は、長屋の入口まで出ると、其処に立っている侍に「召連れましてござります」　と、お辞儀をした。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大家さん、大変だ、こりゃ」「何う調べたか、ちゃんと、お調べがついているんだから、隠せねえや」　大家は、気の毒そうに云った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕吏が「何うも居るのが判っているに、素直に云わぬと――」「為にならねえことぐらいは、子供の時分から、心得ているが、そうは行かねえや――大家さん、えらい騒ぎが起りますぜ」「手向いでもしなさるかのう――困った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく僕の大家さんなんだから……」　私は、丁度そこへ来合せた井河氏に、敗残兵とやらがこの辺にまだゐはせぬかを訊ねた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家さんの長男の亮嗣君（二年生）と二女のしょう子ちゃんも入ってくるので、皆は一層元気よくわあわあさわぐ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大家さんは何処か聞いてみませう。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、大家さんに話してみませうよ。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語に出てくる長屋の連中と大家さんと御隠居の組合が思ひ出される。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人の大家さんであるＡ家の令嬢に恋を感じて日本むすめの彼女を讃美する詩を書いたといふ評判だつたが、どんな詩であるか私たち子供はむろん知らなかつた。",
              "citation": {
                "source": "豚肉　桃　りんご",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼骨　　まあ、ぼつぼつやつてをるんですが、どうも、生憎お隣が大家さんでしてな。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年一軒づつ借家を売つて、それで新橋柳橋と飲み歩いた大家さんは、さう幾人もありませんからね。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんなさつぱりした方はない、大家さんにや珍しいよつて、さう申してるんですよ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ大家さんも、たまにはゐて下さらないと、困る人は困りますわ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　大家さんの足袋屋の主人の陳述は次の如うだ。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "発案者たる大家さんはひとりで気分を出して悦に入るが、長屋の衆はアルコール分がないから滅入るばかりだ。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、おおやさん。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおやさん、私はほんとに発明家ですよ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
