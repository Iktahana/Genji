        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "男役のほうはどうもみんな芝居臭さが過ぎて「俳諧」をこわしているような気がする。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、手紙を持って登場する役の人形は、一座の中でいちばんの色男役のつもりで、もったいぶっていました。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "男役として母親の弟が沼田の実家から住み移った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをひきずるように着て、固い姿勢で歩いて行く豹一の後姿というものは、まるで宝塚少女歌劇の男役としか見えず、どう見ても一人前の新聞記者とは受けとれなかったのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浅川町の空地にも小屋掛けの芝居があって、これは男役者の一座である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の手紙の中に「悲痛な決意」などという言葉があったけれども、悲痛なんてのは今の僕には、何だか安芝居の色男役者の表情みたいに思われる。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、村川はこの色男役のスターよりも、もっと背が高く堂々としていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、悪漢を追いかける色男役ですな。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "等しくレビューの男役をする女優、例えば水ノ江タキ子その他に若い女学生が夢中になって、その真似をして髪を切るとか、何か贈り物をしたいために、三十円で私を買って下さいという手紙を或る会社の重役に送ったとかいうことについて、非難の言葉を表現しておられるのである。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンテージ・ショウの娘たちは、レビューへ女が男になって出るなどというのは日本だけだと笑っているとその時も書いてあったが、私は、レビューの男役に若い娘の人気が集るとともに、日本の現代生活の矛盾とデカダンスとがあると思っている。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターキーは、もっと明るくて健康であり、若い娘の扮する男役の効果については、彼女自身が自覚するより先にぬけ目ない興行者が知っていたのであったろう。",
              "citation": {
                "source": "昨今の話題を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と女が組で踊るところを、男役を買ってでている女が、これはまたなんと威勢のいいことだ！",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新富町の露路裏に、男役者と、やもめ二人が同居していたが、そんな時、彼はすっかり世話女房だった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞妓は、和尚と称する舞踊以外には、居芸を演じて居る女役者と、脇役者とも見える男役者なる立役と、其に対するもどき役なる猿若とを単位として居た様である。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小忌衣についた「ぴんとこ」と言ふのと、関係があらう――の凜とした色男役で、和事であつて、つゝころばしでなく、辛抱立役であり乍ら、果断な男になつてゐる。",
              "citation": {
                "source": "正直正太夫に期待す",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "見合ひから帰つてきての言ひぐさが、あんな美男子は始めて見た、少女歌劇の男役よりも綺麗だと思つたなんて、他人のお聟さんでも見物してきた話のやうに笑ひながら言つたさうだ。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ァに玉川の水だ、朝早くさえ汲めば汚ない事があるものかと、男役に彼は水汲む役を引受けた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それによると、ヘプバーンは少女歌劇の男役の人気だというのである。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそういった風貌が宝塚の男役のように女性から慕われた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が男役をやる、ということも、男の子が女役をやる以上に変なところはないでしょう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、男が女役をやり、女が男役をやる、ということは、それも一ツの本筋ではないでしょうか。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その制約は男役が男になりきることをも制約し、つまり完ったき男女関係は封ぜられておるから、男役は妙な中性に止まらざるを得ぬような不自然なところがあったようだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころの宝塚の男役の妙に歯の浮くようなセリフというものは、私はラジオできき雑誌でせりふを読んだだけだが、相当に無神経な私すらもゾッとせしめる妖怪的なオモムキがありましたね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に、それが当然のことではあるが、予想以上に男役がよろしいね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、男役の主役陣が登場しての口上も、水際だっていた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男役について云えば、春日野や神代の現す男性には気品がある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、南悠子の演技がやや性格を表現しているといっても、結局あとで一番つよく残るのは男役だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の私にとっても、男役が結局印象にのこった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして舞台で男役であった人は特別にしっかりしていて、理性的でもあるようである。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
