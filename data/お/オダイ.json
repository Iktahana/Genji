[
  {
    "uuid": "f96badbf-2ea8-5246-ba30-866c8730a487",
    "entry": "お代",
    "reading": {
      "primary": "おだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "charge (for admission, a meal, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "癌のやっかいなことは外科手術で切り取ってもすぐお代わりが芽を出す。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党大臣や大学教授や官展無審査員ならば、ところてんのようにお代わりはいつでもできる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてお代金を頂戴いたしましたからには、惜しゅうは御座いますが、お譲り致します。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に奥様にでもお代を頂戴に行こうかと思っておりますところへ、今日ヒョックリ先生がお見えになる……トタンに今の夕立で御座いましょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いもかけませぬお代を頂戴致しまして恐れ入りました。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は滅多に御座敷はありませんし、あの……」　とお千世は言淀んだが、「鑑札のお代だって余計なものだのに、電話なんか無駄だからって、それで、譲ってしまったんでしょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あい、お代は置いたよ。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "温泉に浴して汗を流し、鯉汁のお代りをして飯八椀を平らぐ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "漬物は五、六杯お代りをすれば、もう一家中にあるだけ尽く平げてしまったので、今度は生の胡瓜に塩をつけて丸噛り。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さてこんな工合で、あまがえるはお代りお代りで、沢山お酒を呑みましたが、呑めば呑むほどもっと呑みたくなります。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……然らざれば、かけ一杯で、蕎麥湯をだぶ／＼とお代りをするのださうであつた。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　あの、お代、何の？",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　そうまでお気が済みませんなら、少々お代を頂きましょうか。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　でも、あの、お代とさえ申しますもの、お宝には限りません。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "百合　はい、お代のかわりに頂きます。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴客には限りませず、薬売の衆、行者、巡礼、この村里の人たちにも、お間に合うものがござんして、そのお代をと云う方には、誰方にも、お談話を一条ずつ伺います。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "取られて取られて、とうとう、のう、御主人へ持って行く、一樽のお代を無にしました。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "えくぼウイスキイのお代りじや！",
              "citation": {
                "source": "風船美人",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子は空になった壜を覗き、「お代り取って来るわ、お呑みなさいよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "くすりのお代に切らせてもらうよ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "めのさんのお魚は、現金にも月末にも、ついぞ、お代をお取り遊ばしたことはございません。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その野宿で倒れた時さ――当にして行った仙台の人が、青森へ住替えたというので、取りつく島からまた流れて、なけなしの汽車のお代。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）といったら、（どうぞ早や、お持ちなされまして……お代はおついでの時、）……はどうだい。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は味が落ちていないのを喜びながら、この暑さにフーフーうだるのを物ともせず三杯もお代りした。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『先様はこれでお代り。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ蒲焼のお代りを運んで来ましたが、わたしはもう箸をつける元気がない。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お代りの蒲焼は二人ともにちっとも箸をつけなかったので、残して行くのも勿体ないといって、その二人前を折詰にして貰うことにしました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをしましたら、福島のお代官所で縛られます。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おだいじにお暮らしなさい。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（額に接吻する）とも子　おだいじに浮気屋さん。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
