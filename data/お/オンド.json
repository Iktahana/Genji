[
  {
    "uuid": "75cc998f-6b49-5f8d-b9bf-1707add66297",
    "entry": "温度",
    "reading": {
      "primary": "おんど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
