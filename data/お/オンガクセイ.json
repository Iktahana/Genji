        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ときに意味より、リズムや音楽性を優先した部分もあります。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿江子が、例えばストコフスキーという人の指揮ぶりの非本質性を本能的に見ぬいたり、ストラビンスキーという、日本の現代作家80パーセントがその亜流であるような在フランス作曲家の非音楽性を見ぬいたりするところは、健康な資質で貴重だが、その健全の可能が、どのように伸びるか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもって自分の音楽性が自認できると思っていたからである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "白鳳の祈念に宿る音楽性はここにもうかがわるるであろう。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人が思うままに作って自然に音楽性の豊かな詩、作曲者が註文や義理でなく自分から進んで作りたくなるような詩が多ければ多いほど良い歌曲の生れる機会は増すだろう。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            },
            {
              "text": "気高い音楽性と言ってもいい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
