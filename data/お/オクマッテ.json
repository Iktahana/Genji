        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鏡の位置が奥まって横向きになっていたため、鏡の前へ立たないと自分の顔は見えなかった。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大通りをずっと奥まってから右に入った空地であった。",
              "citation": {
                "source": "牡丹",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "住いは奥まっていて、広場が傘の干場でした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど動物園の裏門前の邸で、奥まっていましたから、裏二階から不忍池は見えませんでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し奥まって一軒の茶屋、武蔵野と云って一流だ、前庭が広く木立が茂り、石燈籠などが置いてある。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前を廻って左手へ行き少し奥まって見える板塀。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵画的な方の帯は皿形に削られた面から浅いレリーフとして浮かび上がっており、背景部分は壁本来の面から約五センチメートル奥まっていた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の室は狭く小ぎれいで奥まっていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "正面のは入口が路次に面していて、（見物には）明りとりの小さな窓のあるはめ板が見えるだけで、下手のよりもやや奥まっている。",
              "citation": {
                "source": "或る別れ",
                "author": "北尾亀男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
