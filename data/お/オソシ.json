        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "紀州とても人の子なり、源叔父の帰り遅しと門に待つようなりなば涙流すものは源叔父のみかは」夫なる老人の取繕いげにいうも真意なきにあらず。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼光｜炯々たるも物を言ふこと少しく遅し、ゲンゾスキー財産家、物を言ふこと少しく遅けれども眼光炯々たり。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くこの部屋から身をぬけ出したいと云ふ一念で、彼は戸のあくのを遅しと閾外へ飛び出した。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　呼ぶ時遅し五六人、今の二人の魂消りしに何事ならんと駈附けつ、真先なるは時次郎、「照子様、どうなさいました、幽霊が出ましたかね。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と揉潰されたような掠れた咳して、何かに目を転じて、心を移そうとしたが、風呂敷包の、御経を取出す間も遅し。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫像が動いたのやら、女が来たのやら、問ば拙く語らば遅し。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱坊主夕づく遅し晴衣着て戻れる子等はいまだ外にあり氷沢行別所の裏山づたひに半里余をのぼれば氷沢にいたる。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "家を出でゝ程久しきに、母も弟も還ること遅し、鴉は杜に急げども、帰らぬ人の影は破れし簷の夕陽の照光にうつらず。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実上口先でどんなにうまい事を云っても、実意のある無しは鼻の表現に依ってチャンと相手に感じているので、只相手の神経の鋭敏さ、又は気持ちの静かさに依って、その感じ方に早し遅しがあるだけの違いであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "奮然として退いた昌景は、同志の面々が集まって居る席に来て「説法既に無用、皆討死討死」と云い棄てて、縁側から馬に打乗り、甲の緒をしめるを遅しと戦場に馳せ向ったと云う。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり崑崙山脈までの距離の遠し近しによって、出発の早し遅しが決まるのだそうですが、その行列というのが又スバラシイ観物だそうです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍子抜して返れる貫一は、心私にその臆測の鑿なりしを※ぢざるにもあらざれど、又これが為に、直ちに彼の濡衣を剥去るまでに釈然たる能はずして、好し、この上はその待人の如何なる者なるかを見て、疑は決すべしと、やがてその消息を齎し来るべき彼の帰来の程を、陰ながら最更に遅しと待てり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　父も瑠璃子も、心の中に戦いの準備を整えて、荘田勝平の来るのを遅しと待っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、岡山口から天王寺口にかけて、十五万に余る惣軍は、旗差物を初夏の風に翻し、兜の前立物を日に輝かし、隊伍を整え陣を堅めて、攻撃の令の下るのを今や遅しと待っていた。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして内ぶところに隠し持ったナイフをキラリと抜くや、それを逆手に持ってアネットの心臓の上をめがけてただひと突きとばかり腕をふるったが、このとき遅しかのとき早し、顔色をかえたバラが身を挺してアサリ女史の腕にシッカと飛びついて、わずかにことなきを得た。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "危ないと車掌が絶叫したのも遅し早し、上りの電車が運悪く地を撼かしてやってきたので、たちまちその黒い大きい一塊物は、あなやという間に、三、四間ずるずると引き摺られて、紅い血が一線長くレールを染めた。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "摘み上げた手紙を、取る手遅しと開いてみれば、こは如何に、そこには唯、水兵が煙草を吸っているような漫画が書き散らしてあるばかりだった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "営門をくぐるのも遅しとばかり、中尉はサイド・カーから下りた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロホンの前で、中内アナウンサーは、命令遅しと待つほどもなく、香取司令官は手をあげた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は勇躍して机に噛りつき、取る手も遅しとその青い本を開いて読みだした。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　父も瑠璃子も、心の中に戦ひの準備を整へて、荘田勝平の来るのを遅しと待つてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体庭樹といふものの多くが、人間の好みに適応するやうに囚へられ、撓められ、造り替へられてゐるのに比べて、雑木はその持味の素朴さ、粗々しさ、とげとげしさの感じが失はれてゐないだけに、それにとり囲まれてゐると、どうかすると人をして山林の中に棲遅してゐるやうな幻想を抱かしめるものだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は風帆船が早かった時代もありしかど、蒸気船を知りて居る眼より見れば風帆船は遅しと申すが至当の理に有之、貫之は貫之時代の歌の上手とするも前後の歌よみを比較して貫之より上手の者ほかに沢山有之と思わば、貫之を下手と評することまた至当に候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五十七回　後は真の暗闇　戸を閉じる音を聞きて余はハット驚いた、若しや医学士に一ぱい陥められたのではなかろうか、斯う思って狭い廊下を、戸口の所へ馳せ附けたが、残念、残念、事既に遅しである。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき遅し、例の会合のある室の大きな硝子窓が、バシーン、ガラガラというすさまじい音響をたてて壊れ始めた。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして直ぐさま身を飜えすようにして門前につづく広い空地の片隅に佇んで細田氏の姿の現われるのを今や遅しと待っていました。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はとる手も遅しとその名刺をつまみあげた。",
              "citation": {
                "source": "空中墳墓",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は風帆船が早かつた時代もありしかど、蒸気船を知りてをる眼より見れば、風帆船は遅しと申すが至当の理に有之、貫之は貫之時代の歌の上手とするも、前後の歌よみを比較して貫之より上手の者外に沢山有之と思はば、貫之を下手と評することまた至当に候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、突然Ｉが袂の中のハンケチを取り出す間もおそしと眼がしらに持つて行つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉君は、きりっとした声をはりあげて、朗々と読み、未知のわかい先生に、じぶんが秀才であることをみとめてもらうつもりで、番のめぐってくるのを、いまやおそしと待っていた。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
