        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ところが著いてみると、恐ろしい当て外れだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気味わるく物凄い顔をした、雲助のような男たちに脅やかされたり、黒塚の一軒家のような家に泊って、白髪の恐ろしい老婆に睨まれたりした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはずつと後々までも、彼の自殺の直前までも、遂によく解くことのできなかつた、或る恐ろしい意味をもつた「神祕の謎」であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、そのひとは世にも恐ろしい或るひとつの小説をこっそり企てる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　ソクラテスからジイド迄、いやもつと前からジイド迄かも知れぬ、僅々七十年間に、一とわたり読破した我が日本の力といふものは、世にも恐ろしい力である。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は夜で、夢の中に老婆殺しの恐ろしい幻影を見た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年時代になってからも、色々恐ろしい幻覚に悩まされた。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やもりと荒物屋には何の縁もないが、何物かを呪うようなこの阪のやもりを行き通りに見、打ち続く荒物屋の不幸を見聞きするにつけて、恐ろしい空想が悪夢のように心を襲う。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠っているような植物の細胞の内部に、ひそかにしかし確実に進行している春の準備を考えるとなんだか恐ろしいような気もする。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなんだか恐ろしいものを見たような気がした。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時に氷が増してよく冷えると見えて、少し心が落付いたが、次第に昇る熱のために、纏まった意識の力は弱くなり、それにつれて恐ろしい熱病の幻像はもう眼の前に押寄せて来る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来一つであるべきものが無理に二つに引きわけられ、それが一緒になろう／＼と悶え苦しむようでもあり、また別れよう／＼とするのを恐ろしい力で一つにしよう／＼と責め付けられるようでもある。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしい闇、恐ろしい命と身を悶えた拍子に、氷袋がすべって眼がさめた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにまた、この龜のこれまでの浦島に對する態度から判斷しても、決してかのエデンの園の蛇の如く、佞奸邪智にして、恐ろしい破滅の誘惑を囁くやうな性質のものでは無いやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてさらに恐ろしい事は、その自分の嘘にご自身お氣附きになつてゐない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはや、貧しきわが夢のほかに興ぜず※　　　　我が生は恐ろしい嵐のやうであつた、　　　　其処此処に時々陽の光も落ちたとはいへ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸の力は恐ろしいものだと思う。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸は心騷がしく、山の中は物恐ろしい。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見たときこれならこの建物は大丈夫だということが直感されたので恐ろしいという感じはすぐになくなってしまった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気の導体ですっかり包んだ中へは外からの電気作用が及ばぬというのは定則で、ある学者はこれを証するために自身で金網の中へはいり外から恐ろしい強い電気の火花をポンポン飛ばしたが中に居た先生には何の事もなかったという事である。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲はもうまっくろく、東の方だけ山やけの火が赤くうつって、恐ろしいようです。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも富沢が何かしっかりしたさういふことの研究でもしてゐてじぶんの考へに引き込むためにさう云ってゐるのか全く本音で云ってゐるのか、或は早くもあの恐ろしい海外の思想に染みてゐたのかどれかもわからなかった。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そのときはもう、そらがいっぱいの黒い雲で、楊も変に白っぽくなり、蝉ががあがあ鳴いていて、そこらは何とも云われない、恐ろしい景色にかわっていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして熊の出ない東京には熊より恐ろしいギャングが現われて銀行を襲ったという記事で新聞が賑わった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも恐ろしいことである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感じはちょうどおめでたい新聞小説と恐ろしい罪悪を主題とした傑作とを読み比べる時のそれとよく似たものである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは修学期の最後における恐ろしい比武競技のように、遥かの手前までもその暗影を投げる。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしいことには、男は、いよいよ丈夫になり、みじんも愛くるしさがなくなった。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはほんとうに、おそろしい小説だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、芸の上の進歩とか、大飛躍とかいうものは、ほとんど製作者自身には考えられぬくらいのおそろしいもので、それこそ天意を待つより他に仕方のないものだ。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
