    "definitions": [
      {
        "index": 1,
        "gloss": "number of syllabic sounds in a language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
