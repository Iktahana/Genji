        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お洒落でつつましやかで、おとなしくてお済しで、群っていても実は孤独で、おっとりしていてもなかなか怜悧で。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は美女なりに、醜女は醜女なりに、いかにも女性の心の弱さ、お洒落さ、見栄坊であることを象徴して好い。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は高等学校一年生の時に、早くもお洒落の無常を察して、以後は、やぶれかぶれで、あり合せのものを選択せずに身にまとい、普通の服装のつもりで歩いていたのであるが、何かと友人たちの批評の対象になり、それ故、臆して次第にまた、ひそかに服装にこだわるように、なってしまったようである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あはは……」　男ははじめて笑って、「――洒落もお洒落もあんまり好きやないが、洒落でも言ってんと、日が暮れん。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装もお洒落ではなかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『君は、屹度お洒落の若い衆のように身綺麗にし過ぎていたので、青い帽子迄が、女を誑すための嗜みのように思われたのですね。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小都会から更に十里はなれた或る城下まちの高等学校にはいってからは、少年のお洒落も、のびのびと発展いたしました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お洒落ではあっても、心は弱い少年だったのです。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下まちの、古い静かな割烹店へ、二度、三度、ごはんを食べに行っているうちに、少年のお洒落の本能はまたもむっくり頭をもたげ、こんどは、それこそ大変なことになりました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お洒落の暗黒時代が、それから永いことつづきました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お洒落の暗黒時代というよりは、心の暗黒時代が、十年後のいまに至るまで、つづいています。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年まずしい恋人が、できて、時々逢いに行くのに、ふっと昔のお洒落の本能が、よみがえり、けれども今となっては、あの、やさしい嫂にたのむことも、できなくなっているし、思うようにお金使って服装ととのえるなぞ、とても不可能なことなのでした。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、お洒落な子だったのですし、洗いざらしの浴衣に、千切れた兵古帯ぐるぐる巻きにして恋人に逢うくらいだったら、死んだほうがいいと思いました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに落ちぶれても、ロマンスの世界にはいると、彼のお洒落の本能が、むっくり頭を持ち上げて、彼の痩せひからびた胸をワクワクさせる様であります。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年、彼が借衣までして恋人に逢いに行ったという、そのときの彼の自嘲の川柳を二つ三つ左記して、この恐るべきお洒落童子の、ほんのあらましの短い紹介文を結ぶことに致しましょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどくお洒落な人だったらしい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も無いから仕方なくこんないやらしい派手な着物なんかを行李の底から引っぱり出して着ているのだけど、田舎の人たちの眼から見ると、あたしたちがおそろしくぜいたくなお洒落の衣裳道楽をしているみたいに見えているんじゃないかしら。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あたしはこんな不器量な子だから、お洒落をすると笑われるかと思って、わざと男の子みたいな事ばかり言っていたのよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にちょっとお洒落なのもいて、制帽のいただきが尖らないように辮髪を後頭部の方に平たく巻いて油でぴったり押えつけるという新工夫を案出して、その御苦心は察するにあまりあったが、帽子を脱ぐと、男だか女だかわからない奇怪な感じで、うしろ姿などいやになまめかしくて、思わずぞっとする体のものであった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下まちの、古い静かな割烹店へ、二度、三度、ごはんを食べに行つてゐるうちに、少年のお洒落の本能はまたもむつくり頭をもたげ、こんどは、それこそ大変なことになりました。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お洒落しゃれても惚れ手がないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――楓はお洒落で、幹を裸で天日に曝しとくのを嫌う。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のお洒落に男の駄洒落の過ぎたのは感心せぬて。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ、お前か」　お洒落の京吉は、いつもその娘に靴を磨かせていたのだが、この半月ほどはその場所に姿を見せなかったので、ふしぎに思っていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いそっぷの話に出て來るお洒落鴉。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャルの島民は、殊に其の女は、非常にお洒落である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャルの島民は、殊にその女は、非常にお洒落である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の愛人の美沢は、早く父を亡くして母親育ちであるだけに、お洒落な細かい動作が、身体にしみついていて、いかにも美青年らしく見えたが、この青年はいかにも健康な、スポーツででも鍛えたらしい若人という感じがした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貴女、随分お洒落になっちまったのね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟妹とちがって風采もよくてハイカラでまたそれだけにおしゃれでもあった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
