    "definitions": [
      {
        "index": 1,
        "gloss": "main street (esp. in a capital)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "爛熟し、頽廢し、さうしてさびた揚句の果が、こんな閑寂にたどりついたので、私は、かへつて、このせまい裏路に、都大路を感ずるのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天は愈よ明るい、氷の海は一層の白を加うると共に、一分の硬味を減じて来た雪になったのである、玉屑累々ともいうべき空に懸れる雪の大路を無形の手で、橇を縦横に掻き廻しはじめたと見え、捏ね返した痕跡が割れ目を生じたころは、雪は一方に堆く盛り上られ、一方では掬われたようにげっそりと凹む。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大路ゆく辻占うりのこゑ、汽車の笛の遠くひゞきたるも、何とはなしに魂あくがるゝ心地す。",
              "citation": {
                "source": "月の夜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大路の霜に月｜氷りて、踏む足いかに冷たからん。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一とせ下谷のほとりに仮初の家居して、商人といふ名も恥かしき、唯いさゝかの物とり並べて朝夕のたつきとせし頃、軒端の庇あれたれども、月さすたよりとなるにはあらで、向ひの家の二階のはづれを僅かにもれ出る影したはしく、大路に立て心ぼそく打あふぐに、秋風たかく吹きて空にはいさゝかの雲もなし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つ口など囃して小さき子の大路を走れるは、さも淋しき物のをかしう聞ゆるやと浦山しくなん。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして二人とも美しい顔をゆがめてチューインガムをニチャニチャ噛みながら白昼の都大路を闊歩しているのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、太平の世の中でもまれには都大路に白昼追いはぎが出たり、少し貸してくれなどという相手も出現するから、そういう時にはこれがたちまちにして原始民時代の武器として甦生するという可能性も備えているのである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂もおりたり、のぼりたり、大路と覚しき町にも出でたり、暗き径も辿りたり、野もよこぎりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現代のジャーナリズムは、まだまだ恐ろしいいろいろの怪物を毎朝毎夕製造しては都大路から津々浦々に横行させているのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空を藍色に見せ、夕日を黄金色に沈ませ、都大路の色硝子に曇って、文明の悲哀を匂わせる。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこんな晩に大路を歩くことが好きで。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "九百九十九の電燈の、大路小路に残ったのが、星を散らして玉を飾って、その横笛を鏤むる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日の出づる邊、我故國では今頃は定めて、都大路の繁華なる處より、深山の奧の杣の伏屋に到るまで、家々戸々に日の丸の國旗を飜して、御國の榮を祝つて居る事であらう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月　月のはじめに秋立てば、あさ朝顏の露はあれど、濡るゝともなき薄煙、軒を繞るも旱の影、炎の山黒く聳えて、頓て暑さに崩るゝにも、熱砂漲つて大路を走る。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯此時、大路を時に響いたのは、肅然たる騎馬のひづめの音である。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符を買つて、改札口を出て、精々、着た切の裾へ泥撥を上げないやうに、濡れた石壇を上ると、一面雨の中に、不知火の浮いて漾ふ都大路の電燈を見ながら、横繁吹に吹きつけられて、待合所の硝子戸へ入るまで、其の割に急がないで差支ぬ。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　明眸の左右に樹立が分れて、一条の大道、炎天の下に展けつつ、日盛の町の大路が望まれて、煉瓦造の避雷針、古い白壁、寺の塔など睫を擽る中に、行交う人は点々と蝙蝠のごとく、電車は光りながら山椒魚の這うのに似ている。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白く染め抜いたる、目、口、鼻など、大路小路の地の上に影を宿して、青き灯のなかにたとへば蝶の舞ふ如く蝋燭のまたたくにつれて、ふはふはとその幻の浮いてあるき候ひし。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能の出入り先で今大路という堂上方の家に綾姫という小鼓に堪能な美人がいた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に綾姫の里方の今大路家はあまり仕合せがよくなかった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私こそ……今大路の……綾姫の血すじを……受けましたもので御座います」「アッ」　と私は思わず声を立てて妻木君をかえり見た。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申すもお恥かしい事ばかりで御座いますが、今大路家は御維新後零落致しまして一粒種の私は大阪へある賤しい稼業に売られようと致しましたのを、こちらの主人に救われましたので御座います。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今大路家や音丸家のあとも一々尋ねて見たがみんな無駄骨折りにおわった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句がもし「月天心都大路を通りけり」だつたら、月が非常に小さな物になり、句の印象から消滅してしまふ。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが近代では、都会も田舎もおしなべて電光化し、事実上の都大路になつてゐるのだから、彼等の詩人に月が閑却されるのは当然である。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで武士は大路に面した家に宿をとつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど今日のやうな、秋の陽ざしの静かな日で、武士の見下してゐる都大路には、往き来の人の間に、黄色い蝶々が舞つてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年のやうに二階のてすりに凭れて、秋の陽の一ぱいさしてゐる大路を見おろしてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に我々の親・おおじの通って来た路が是であり、今でも一部の同胞が天然に阻まれて、なお脱却しかねている境涯も是だからである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
