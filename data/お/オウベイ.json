        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "当時の日本は、文明開化の欧米心酔時代であったので、至るところ、彼はそうした不機嫌の目に逢わされた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が西洋臭くなり日本の文化や風俗やが、日々にますます欧米化して来ることは、ヘルンにとって忍びがたい悲哀であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が盆踊を禁ずるのも、国民が欧米人の真似をするのも、固有の日本文化が亡びるのも、すべて皆基督教の宣教師が宣伝するためであり、一切の悪は耶蘇教の罪に帰せられた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし日本の人に、キリストの精神を教えてくれたのは、欧米の人たちであるが、今では、別段彼等から教えてもらう必要も無い。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや日本に居住することなく、日本の文学を全く読まず、日本に就いて知る所の殆んどない一般の欧米人が、宮森氏の訳を通じて、芭蕉等の俳句が解り得る道理はない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに限らず、富士の室は風俗史的に見て、欧米諸国の山小舎に、ちょっと類例のないものがある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でも外来語の整理が全国民の関心事となるのは欧米との戦争というような犠牲を払った後でなければ期しがたいのであろうか。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋語としての日本語の統体が欧米語によって煩わされること今日のごとく甚しい場合に、我々の日用語が大部分外来語だといって無関心をきめ込むのは識見においていささか欠けるところがありはしないだろうか。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を欧米の侵入に対して防禦することを私は現代の日本人の課題の一つと考えたい。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米語に対する社会一般の軽薄な好奇心を統制して大和言葉ないしは東洋語の尊重を自覚させるにはどうしたらいいか。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米における昨今のアインシュタインの盛名は非常なもので、彼の名や「相対原理」という言葉などが色々な第二次的な意味の流行語になっているらしい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言葉の中には欧米学界の優越に対する正当なる認識と尊敬を含むと同時に、我国における独創的の研究の鼓吹、小成に安んぜんとする恐れのある少壮学者への警告を含んでいたのである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾組かの拳銃隊が街の要所々々を発砲し、欧米人によって築かれた南京路のペーブメントは要撃された。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれらの新日本映画が逆にちょうど江戸時代の浮世絵のごとく、欧米に輸出される。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の大学へ、欧米から留学生が押しかけて来るようになったら、日本の製造工場へピッツバーグやスケネクタディあたりから、見習職工が集まって来るようになったら、そうしたら、一切のこういう問題はなくなるだろう。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして欧米には無い特別のモンスーンの影響を受けている。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノルウェーの理学者が北光の研究で世界に覇をとなえており、近ごろの日本の地震学者の研究はようやく欧米学界の注意を引きつつある。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後故郷を離れて熊本に住み、東京に移り、また二年半も欧米の地を遍歴したときでも、この中学時代の海水浴の折に感じたような郷愁を感じたことはなかったようである。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一般平均から見ても、また個別的に見ても、学芸にかけての日本人の頭が少しでも欧米文化国民のそれに劣らないものだと信じて疑わないものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たくさんの邦産映画の中には相当なものもあるかもしれないが、自分の見た範囲では遺憾ながらどうひいき目に見ても欧米の著名な映画に比肩しうるようなものはきわめてまれなようである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣もとうとう根気負けがして、注意深くその人のいうことを傾聴するようになったが、その結果としてその人は欧米への視察旅行を命ぜられ、帰朝すると、すぐいわゆる要路の位置についたというのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米では慈悲や救済は、殆んど宗教の専門のようになっています。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米列国を実利主義一点張の如くに思惟せし時代は既に過去つたり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米列国は日本を侮蔑し、二等国或は三等国と呼ぶも猶ほ其言に甘んぜざるを得ざりき。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米国民は夫れを知るや知らずや、中にも露国は傲慢無礼、日本を蔑視し、東洋に暴威を揮はんとせしより、日本国民の血は沸けり、骨は鳴れり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵力に於ても、富力に於ても、智力に於ても、当時の欧米人士中、誰か日本の大勝を予期せしものあらんや、若し有りとせば、之れ達観の士なり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して欧米列強は、今や堅実なる実利主義を右に握り、更に剛壮なる英雄主義を左に握らんとしつゝあり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十二月十二日、市川左団次、演劇研究のために欧米旅行の途にのぼる。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸事を改良して、欧米の劇場にならいたる興行法が、一般観客の反感を買い、さんざんの不評に終れり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
