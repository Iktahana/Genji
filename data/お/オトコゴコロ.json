        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "妾はそうした男心がなさけなくなりました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　若木三寸で螻蟻に害う　世の中に病ちょう者なかりせば男心のやさしかるまじ。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵児帯のおチマ」と名乗る不良少女などにふと、男心めいたなつかしさを抱くとは、留置場にいれば人恋しくなるせいだろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　いかにも、あどけない少女らしく見えていて、男心を捕えるのに妙を得て、奔放自在、しかもどっかに才気の閃きを見せて艶冶である、こんな少女を、一体どこで見つけて来たのだろうと、前川は感嘆しながら、心の底まで楽しくなっていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　歌の贈答が絶たれようとしてしかも絶たれず、男心の切なる戀に弱い女心が次第にそれとなしに引寄せられて行くさまがそこに細かな美しい巴渦を卷いた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本當でござるか』『さやうか』『男心といふものはそのやうなものかのう？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれば、此一｜語を唱へしめ……女は心の移る筈、男心さへも堅固にあらず。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄弱な、利己的な、制限のある男心。",
              "citation": {
                "source": "針",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると浅果な男心は直ぐ我楽多のやうな、ぞんざいな扱ひ風を見せて、何うかすると神様の傑作に対して敬意を失するやうな事になる。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ棄てられても、困らないことにさえしておけば、欲に繋がる男心の弱味をいつでも掴んでいられそうに思えた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "よきにつけあしきにつけ主動的であり、積極的である男心に添うて、娘としては親のために、嫁いでは良人のために、老いては子のために自分の悲喜を殺し、あきらめてゆかねばならない女心の悶えというものを、近松は色彩濃やかなさまざまのシチュエーションの中に描き出している。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものわかりよいということ、男心を理解しているということ、そのことがその女へ男の興味を呼びむかえる。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "女形の身ごなしで表現され得た女らしさにもられた女ごころというものも、つまりは古い男心の伝統が描き出したものであったとさえ云えるでしょう。",
              "citation": {
                "source": "自然に学べ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作中の女を絵中の女としていとおしく思わせる男心の余波を、おのずからその作品を生んだ婦人作家の上にまでひきつけて来るわざを、全く度外において、婦人作家は、おのずから装われた女心のいとおしさにあるのであろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またこの男も私から逃げて行くのだろうか」男心と云うものは、随分と骨の折れるものだ。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男といふものは、みんな逃げる気なのだと、ゆき子はつくづくと物慾の深い男心にいやらしいものを感じてゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのにそれに気がつかずにのんきな男心はすましてゐる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "男心と秋の空、と云うが、それは、女の主観的詠歎ではないか？",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "男心と云うものはそうしたものでございますからね。",
              "citation": {
                "source": "最終の午後",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "Maupassant が 〔notre coe&ur〕 と申した、その男心でございますね。",
              "citation": {
                "source": "最終の午後",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論お蓮は何度となく、変り易い世間の男心に、一切の原因を見出そうとした。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして Dirne のような女を見ると、私はずるい男心を呼び起こされます。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "真面目な女でも、あたくしは、時として自分の抵抗力を疑ふ真面目な女ですわ……」　作家ルナアルの「女性」は、彼の「言葉」の如く陰翳に富み、男心の隅々までを知り尽してゐる。",
              "citation": {
                "source": "愛妻家の一例",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い換えれば、私の男心をそそのかすのである。",
              "citation": {
                "source": "孤独者の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄江が男嫌いだということは、私は前から聞いていたし、胸の奥の男心に、ほのかな温かみを呼び起されていた。",
              "citation": {
                "source": "孤独者の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋は必ず破れる、女心男心は秋の空、必ず仇心が湧き起り、去年の恋は今年は色がさめるものだと分つてゐても、だから恋をするなとは言へないものだ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠洋航海より帰り来て、浪子のやせしを見たる武男が、粗豪なる男心にも留守の心づかいをくみて、いよいよいたわるをば、いささか苦々しく姑の思える様子は、怜悧き浪子の目をのがれず。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋は必ず破れる、女心男心は秋の空、必ず仇心が湧き起り、去年の恋は今年は色がさめるものだと分っていても、だから恋をするなとは言えないものだ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "変りやすいは男心に秋の空、それにお上の御政事とばかり極ったものではない。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
