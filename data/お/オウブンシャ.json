        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「筆者の履歴書にはこれまで、旺文社から出した『パソコン創世記』が処女作であると書いてきた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八五年二月に書き下ろし文庫で出した途端、旺文社文庫その物が出版取りやめとなって、哀れな末路をたどった本だ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺文社文庫の廃刊によって、「若いパソコン・ユーザーたちがこの労作を読む機会を失うことを非常に残念に思う」と書いてくれたその人は、続編をまとめることを条件に旧版を再刊しようと申し出てくれたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "後押ししてくれたのは、旺文社の椛田敏彦さんだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時デジタルの墓場と呼ばれていた豆単の旺文社には、給料のあらかたをコンピューターとアルコールに注ぎ込んでしまうという突然変異体が一匹棲息していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつの口車に乗せられて、オレは「パソコン創世記」という本を書き、旺文社文庫から出してもらった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとその直後に、旺文社文庫その物が消えてしまったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレが世間様に向けて投げ掛けたメッセージは、一般書からの撤退という旺文社の方針変更によって、あわれデスクトップのゴミ箱直行となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "粛正委員会は第一次に粛正されるべき出版社として講談社、第一公論社、主婦之友社、旺文社、家の光協会、日本社、山海堂の七社を指名し、社内民主化への条件を示し謹慎の条項が示された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次に他の十二社が審議されていた時に講談社、主婦之友社、旺文社、博文館が中心になって日本自由出版協会を組織した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八四（昭和五十九）年の秋に取材し、暮れから新年にかけて書いた原稿は、一九八五年二月に『パソコン創世記』として旺文社文庫から出た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺文社文庫版の主要な登場人物である日本電気の渡辺和也さん率いるチームは、物語の終わったあと、激しい変化の波に見舞われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺文社文庫版の第一部「一九七五　人ひとりのコンピューターの創造」に加え、「一九八〇　激動の一〇年をかけて何を目指すのか」として収録した第二部は、このＴＢＳブリタニカ版によっている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の中では、何かが起こり始めていた」（『Two Steves & Apple』旺文社）　パーソナルコンピューターとは何の関係もないと思われるのであろう、山岸会について長々と書きました。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に一番目の読者として容赦のない叱責と励ましを与えてくれた富田晶子さん、叱責と励ましに加えてアルコールを浴びせてくれた旺文社の椛田敏彦さん、この二人の協力を得てようやくここまでたどり着くことができました。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校三年生の二学期に行われた旺文社の模擬試験では全国で六位、東大合格率が七五パーセント以上と出た。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "旺文社の椛田敏彦さんにチャンスをもらい、その話と日本電気の開発物語りを絡めて初代の『パソコン創世記』を書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
