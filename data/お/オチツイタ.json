  {
    "uuid": "202f0a07-0f08-506d-b37c-ca74118fb89b",
    "entry": "落ち着いた",
    "reading": {
      "primary": "おちついた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
