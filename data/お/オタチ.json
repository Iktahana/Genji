        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「departure」である。",
              "source": "幻辞"
            },
            {
              "text": "「departure」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "departure」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「departure」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「departure」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "departure」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「departure」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "departure」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「departure」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "departure」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「departure」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "departure」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「departure」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "departure」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「departure」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "departure」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「departure」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "departure」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「departure」という要素は不可欠だ。",
