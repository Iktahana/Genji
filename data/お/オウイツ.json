        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "月給日といへば女優部屋などは、普段とは和気の可なり横溢してゐるものだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の細つそりした女優は、自分よりも新参者の出来たことを、その和気の横溢した中でモヤモヤと感じた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生君元氣横溢、しきりに僕に挑戰すれども、僕避けて爭はない。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治年間、殊に、日清戦争から、日露戦争前後にかけての期間は、最も軍国主義的精神が、国内に横溢した時期だった。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが軍事的傾向の横溢した日清戦争から日露戦争に到る間の当時の風潮に投合したのである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん短歌の中には無季題のものも決して少なくはないのであるが、一首一首として見ないで、一人の作者の制作全体を通じて一つの連作として見るときには、やはり日本人特有の季題感が至るところに横溢していることが認められるであろうと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "武松は忽ち元気を横溢さした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この光りに横溢した空間はまやかしだ。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど一面に朱と黄の色彩が横溢して見るもまぶしいくらいなので、一見しただけではすぐにこれが自分の昔なじみの庭だということがのみ込めなかった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……台所で働く女中の身体のこなしまでも、しかもそれが練達洗練された三昧に入っている所作である限り……その心境がその仕事に対して純一無雑である限り……そこに能楽の型と同じ真実味の横溢した「人間美」が後光を放っているではないか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが実さんの能を見ると、六平太先生や粟谷、後藤の諸先生はもとより、他流の諸先生の何人とも全然違ったスゴ味が全体に横溢している。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜間金太郎氏の演出なぞは素人眼にはスゴミが横溢しているようであるが、よく見ているとそのスゴ味は金春一流の意識的な気合い（アテ気と言っては過ぎる）から生まれたものであることが次第次第にわかって来る。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし茶目気分｜横溢していてむつかしい学科はなんでもきらいだという悪太郎どもにとっては、先生の勤勉と、正確というよりも先生の教える学問のむつかしさが少なからず煙たくもあったらしい。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしきり（よし原すゞめ、行々子）は、麥の蒼空の雲雀より、野趣横溢して親しみがある。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（舅の友人に前田黙鳳といふ先生があつて、その古朴正厳な覇気横溢の書体にも私は深く感銘を得たことを憶えてゐる。",
              "citation": {
                "source": "私の書に就ての追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる困難をも欣んで迎える強靱な精神力の横溢。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻息が荒い」というのは、決して凹まないという猛烈な意気組が鼻の先に横溢して、意志や感情の風雨雷電をはためかしているのを鼻息になぞらえたものでありましょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち実力主義が最も露骨に発揮された、活気横溢せる時代である。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この半島出兵は、結局失敗に終つたが、当時の日本は、民族的にも国家的にも、このくらゐエネルギーが横溢してゐて、倭寇以来の大陸進出の風潮が、国家的に発現したのだ。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "画きなぐつたやうな作品が多いが、このなぐり画きに生命感が横溢してゐるから妙である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "貿易順調ニシテ外國ヨリ貨幣ノ流入横溢シ爲ニ物價騰貴ニ至ル恐アル時、銀行省ハ其ノ金塊ヲ貯藏シテ國家非常ノ用ニ備フルト共ニ、物價ヲ合理的ニ調整スルヲ得ベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅に数筆を塗抹した泥画の寸紙の中にも芸衛的詩趣が横溢している。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊井公侯の欧化策は文明の皮殻の模倣であったが、人心を新たにし元気を横溢せしめて新らしい文明のエポックを作った。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生間に於ける鳥打帽の大流行は、カフェー、活動、その他に横溢している享楽気分にふさわしい気分のあらわれである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は古い江戸ッ子がバラック趣味を軽蔑し、オツな喰い物、意気な音締め、粋な風俗の絶滅を悲しんで、イヤになって引っ込んでいる間に、ドンドン彼等の趣味を東京市中に横溢させている。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロ文化の末路　しかしこうした江戸草創時代の元気横溢した平民の気象――逃げ水を追つつまきつつ家を建てた時代の芳烈な彼等の意気組は、太平が続くに連れて、次第に頽廃的傾向即ちブル気分を帯びて来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実ばかりでなく、大きい葉にも、黄いろい花にも野趣｜横溢、静かにそれを眺めていると、まったく都会の塵の浮世を忘れるの感がある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨船ゼムリヤ号発狂事件――という名称からして既に怪奇味が横溢し只ならぬ事態が窺われる次第であるが、それが後になって更に一層発狂的命名をもって「地球発狂事件」と唱えられるに至ったのである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、新しい思潮が横溢して来たその時では、その作の基調がロマンチックでセンチメンタルにかたよりすぎている。",
              "citation": {
                "source": "『田舎教師』について",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびに「おういつ」と、家人をよび、物情騷然の景を呈するが、めつたに下手人のあらはれたためしはない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
