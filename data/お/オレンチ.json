        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――俺んちまで一しよに來るんだぜ……そしたら、お前の嘘をばらしてやるから、さう思へ。",
              "citation": {
                "source": "羽ばたき",
                "author": "Ein Marchen",
                "note": "青空文庫"
              }
            },
            {
              "text": "留吉　……元はどうか知らねえが、俺んちが分散する時あ、あんたあ知らん顔で見てゐなすつたよ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに俺んちが憎ければ、なんで、へえ、おおつぴらに俺とこさやつて来て、この頭あ、ゲンノウでもつて叩き割らねえ？",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金五郎に種え分けてもらつたり、中にや金え握らされたり、それでなくてもあやつは須山の旦那あ笠に着て顔が良いから、それにオベツカする、みーんな俺んちのことアダをしやがら！",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田植えの加勢も、申し合せて、俺んちだけは一人も出てくれねえ。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うう、だのに、俺のこと、俺んちのこと、村中でお前、どこさ行つても、喜十さ、お茶がへえつたから、一杯のんで行けと声をかけてくれる家あ、たつた一軒も無えだあ。",
              "citation": {
                "source": "ぼたもち",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村　いや、悪いというんじゃねえけどさ――明　そいじゃ、俺んちじゃ、どうして食って行きゃいいんだよ？",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからね、古道具屋のほうでは、てっきりおれんちのやつを盗んだんだろうとこういって、質屋に因縁をつける――こいつあ寸分違わねえとするなら、古道具屋の因縁づけるのがあたりめえと思いますが、しかるに質屋のほうでは、あくまでもその金の大黒さまを日本橋だかどこかで買ったものだというんでね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "一緒におれんちへ行こうや！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれんちへ行こうよ！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はははは、おれんちに、物があるのは、金が欲しゅうないからじゃ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれんちの方は、魚が新鮮で安い。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれんちはおもしろいぞ！",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
