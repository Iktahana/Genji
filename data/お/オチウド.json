[
  {
    "uuid": "7a5f8e63-1cff-548e-8b84-9b2f010d152b",
    "entry": "落人",
    "reading": {
      "primary": "おちうど",
      "alternatives": [
        "おちゅうど"
      ],
      "is_heteronym": false
    },
    "grammar": {
