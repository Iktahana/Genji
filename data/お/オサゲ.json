    "definitions": [
      {
        "index": 1,
        "gloss": "wearing one's hair in braids",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お下げという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお下げの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お下げを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお下げという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お下げの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お下げは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お下げの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お下げと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お下げは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お下げはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お下げの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お下げの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お下げが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お下げを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お下げのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お下げに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お下げの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お下げの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お下げは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お下げの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お下げ髪もあれば束髪もある。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまめまめしい心よしの友だちがあたたかい南国へ羽をのして行くすがたのなごりも王子は見る事もおできなさらず、おいたわしいお首をお下げなすったままうすら寒い風の中にひとり立っておいででした。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、髪も兵古帯にふさわしくお下げにして、前髪を垂らしているせいか、ふと下町娘のようであり、またエキゾチックなやるせなさもある。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄のうしろに肩揚をしてお下げに髪を結つた私は、かくれるやうに座りました。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者の頼み様がよろしからずとは、何をもって左様申されるか」　と、満右衛門が詰め寄ると、「――貴方は、御主人の大切な用を頼むのに、手をお下げにならん。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲働が來て、奧さんの方を一寸見ると、奧さんが「今は食べないからお下げ」と云ふので、膳を下げてしまふ。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず第一に長女の髪をゆう、何がよかろうという事、髪はできぬという、祖母に相談する、何とかいう事に極って出来あがった、それから次なはお下げにゆう、仲なは何、末なは何にて各注文がある、これもまた一騒ぎである、予は奥に新聞を視ている、仲なと末なが、かわるがわる、ひききりなしにやってくる。",
              "citation": {
                "source": "浅草詣",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学校の制服を着た二人の少年と、髪をお下げにして、帯をおはさみにしめた少女とが、田川と夫人との間にからまってちょうど告別をしているところだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お下げをやめさせて、束髪にさせた項とたぼの所には、そのころ米国での流行そのままに、蝶結びの大きな黒いリボンがとめられていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、よくよく考えまするに、名器とは言い条、これまで数多の人の手にかかりたるやも知れざる品、むかし宋の徽宗皇帝は秘蔵の名硯を米元章に御貸与えになり、一度臣下の手に触れたものは、また用い難いとあって、そのまま元章にお下げになりましたとやら。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、宮内省からは、矮鶏の代価として百円をお下げになった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "叡覧後の矮鶏のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては宮内省より百円お下げになったから、此金を君へ持参した。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "叡覧後の矮鶏のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと口にいったら、芝のあの三縁山へお成りになって、そこに祭られてある台徳院殿さまの御霊屋に、ぺこりとひとつ将軍家がおつむりをお下げになるだけのことですが、下げる頭が少しばかり値段の高い八百万石のおつむりですから、事が穏やかでないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "お下げ渡しくださりませ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなる四人の公盗共が掠めし珠数屋の財宝財物を御糺問の上、すみやかにお下げ渡し然るべし。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "申すもかしこいことにござるが、上さまご秘蔵あそばす蓮華鬼女のご能面保管方をてまえにお申しつけくださって、保管料という名目のもとに、年金三百両あてお下げ渡しくださるならわしでござったのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままでお下げください。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ美穂子は赤いメリンスの帯をしめて、髪をお下げに結って、門の前で近所の友だちと遊んだ。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お下げに結った女生徒と鼻を垂らした男生徒とがぞろぞろと下駄箱のほうに先を争って出て行った、いずれの教室にも同じような言葉がくり返される。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔵米を惜しげもなくお下げになったのじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの少女達はジャケツにお下げぐらいの簡単な服装をして居りますから体のこなしが如何にも自由自在で、軽やかです。",
              "citation": {
                "source": "わたくしの大好きなアメリカの少女",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　わたしたち姉弟が、紺絣の筒袖に小倉の小さい袴をはいた男の児と、リボンをお下げの前髪に結んでメリンスの元禄袖の被布をきた少女で、誠之に通っていたころ、学校はどこもかしこも木造で、毎日数百の子供たちの麻裏草履でかけまわられる廊下も階段も、木目がけばだって埃っぽかった。",
              "citation": {
                "source": "藤棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵のひとは前髪をとってすこしふくらしたお下げにしていたが私はそれがどうしてもきらいであった。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪はお下げにして、色が抜けるように白かった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の女は明るい色のフランネルを着て、やはりお下げであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず風から見ると、頭髪をわけ、うしろでまるめるはよいが、白いゴムに光る碧石が入った大きなお下げどめをし、紺サージの洋服に水色毛糸帽同色リボンつきといういでたち。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのしみにしてその話、　中に一人赤いリボンの腕時計をし、お下げどめのしかたも東京風　「まあいやだ」などというのも東京風で色も白い、一寸リボンのついた靴をはき目立つ。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前額に二、三寸に梳れる程の髪を残してあとは丸坊主の子、辮髪風に色の布で飾ったお下げを左右に残すもの、或は片々だけに下げているもの。",
              "citation": {
                "source": "中支遊記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしては麦藁帽子……もっともおさげに結ってれば……だけど、そこまでは気が付かない。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪をおさげにして赤い細いリボンで結えていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
