        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「よかったら加世子さん、今夜ここにお泊まりになっては。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、弱りものの画師さんの、その深い馴染というのが、もし、何と……お艶様――手前どもへ一人でお泊まりになったその御婦人なんでございます。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間のことなのでございます、――柳橋の蓑吉姉さん……お艶様が……ここへお泊まりになりましたのは。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ドレッバーさんは三週間近くお泊まりでした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よいお泊まり所になればよろしいが」　と言って、紀伊守は召使を家へ走らせた。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思いがけぬ所で、お泊まり合わせになりました。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにお客様がお泊まりにならなかったらどんなに私たちは心細かったでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "）高田　今夜もお泊まりだそうですね。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「折角お泊まり下すっても、おかまい申すことも出来ません。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりのお客人が客室にお泊まりになりました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから十里ばかり先に呂という家がありまして、そこは閑静で綺麗な上に、賊をふせぐ用心も出来ていますから、そこへ行ってお泊まりなさるがよろしゅうございます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではおれをあの楼に泊めてくれ」「お泊まりになりますか」「なんの怖いことがあるものか。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用がなければごゆっくりお泊まりください。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜になってお泊まりがあるかも知れませんが、唯今のところではこのお座敷と十一番だけでございますから。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞどうぞ当分の間、むさくるしくはございますが、妾の家にお泊まりくだされ、杉窪の里の人たちの、味方となってはくださいますまいか」　その声には熱があり、訴えるようなところがあった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は人の出入りの物音の多さに妨げられて、絃を揺すったり、おさえて変わる音の繊細な味を研究おさせになるのに不便なために、夜になってから静かに教うべきであるとお言いになって、女王の了解をお求めになって院はずっと宮の御殿のほうへお泊まりきりになり、朝夕のお稽古の世話をあそばされた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝後夜の勤めにこちらへ参った時に、あちらの西の妻戸からりっぱな若い方が出ておいでになったのを、霧が深くて私にはよく顔が見えませんじゃったが、弟子どもは左大将が帰って行かれるのじゃ、昨夜も車をお返しになってお泊まりになったのを見たと口々に言っておりました。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く時もここへお泊まりになったのです」　と答えたのを聞いて、薫はそれであった、話に聞いた人であったと思い出して、従者たちは見えない所へ隠すようにして入れ、「早くお車を入れなさい。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "初瀬や奈良へおいでになる方はいつもそこへお泊まりになります」　と翁は言った。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ええとそれからもう一つ、ひょっとかすると当屋敷に、ちょっと変わった事件が起こり、お驚かせするかも知れませぬが、決して決してご介意なく、安心してお泊まりくださるよう」　三蔵琢磨というこの家の主人、こんな具合に話すのであった。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お泊まりなさいまし」「柏屋でございます」「へいへいこれはお早いお着きで」――などと云っていた出女の声も、封ぜられたようになくなって、萩村の駅は寂静となった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お泊まりなすったのでございますよ」「変ですねえ。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「由蔵という博労がおろう、当家に宿を借りたであろう」「へい、さようで、お泊まりでござんす」「ちょっとその男を呼んでくれ」「かしこまりました、ちょっとお待ちを」　男衆が奥へ素っ飛んで行ったが、すぐに三十一、二にもなろうか、博労らしい男を引っ張って来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼　せめて四、五日なりとお泊まりあそばして。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞　いや、今夜は私の寺にお泊まりください。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "法然様がある時｜室の宿にお泊まりあそばしたとき、一人の遊女が道をたずねて来たことがある。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも今夜はお泊まり遊ばすンでございましょう？",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お泊まりなすっておいでなさい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとまりでいらつしやいませうか。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "命はそれから尾張へおはいりになって、そこの国造の娘の美夜受媛のおうちにおとまりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
