        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "質素なる黒の上着に麦藁帽子の拵にて、遠慮らしく徐に入り来る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（徐に）信仰のあるような顔ですわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一方の画架の処に膝を突き、掃除をしつつ徐に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家が握手せんとして手を差伸ぶるを見て、徐に右だけの手袋を脱ぎ、指輪を嵌めたる、細長き、優しき手を出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（徐に部屋の内を見廻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家｜徐に手を放す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "令嬢は徐に画家の傍より離れ去る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（徐に戸の口に歩み寄り、徐に戸を開き、退場。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐にためらいつつ部屋の内に進み、始終物を怖るる如く四辺を見廻す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて画家の、己れの方に背中を向けて、先の姿勢を取りおるを見付け、驚き、徐に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は徐に煖炉に歩み寄り、その上なる素焼の瓶を取りて絵具入の箪笥の上に据え、それに翁草の花を挿す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家は徐に娘の髪を撫づ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（画家｜徐に娘の前に跪き、娘を見上ぐ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見た義母は徐に袖から取出して『どうかお使ひ下さいまし。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物は実は長い間にきわめて緩徐に造り上げらるるのであるが、その薄ぎたない見すぼらしい目隠しがある日に突然取り去られるからである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち、両翼を開張し、虔しく頸を垂れて、座を離れ、低く飛揚して、疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願ふらく、疾翔大力、疾翔大力、たゞ我等が為に、これを説きたまへ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願ふらく、疾翔大力、疾翔大力、たゞ我等が為にこれを説き給へ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷｜則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して願ふらく疾翔大力、疾翔大力、たゞ我等が為にこれを説き給へ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち、両翼を開張し、虔しく頸を垂れて、座を離れ、低く飛揚して、疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願うらく、疾翔大力、疾翔大力、ただ我｜等が為に、これを説きたまえ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願うらく、疾翔大力、疾翔大力、ただ我｜等が為にこれを説き給え。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷｜則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して願うらく疾翔大力、疾翔大力、ただ我｜等が為にこれを説き給え。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし全体のテンポは私にはむしろ緩徐に感ぜられ、アダジオのような気持ちがする。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影と分れたが、フト気になるので、そこで窄めて、逆上るばかりの日射を除けつつ、袖屏風するごとく、怪いと見た羽目の方へ、袱紗づつみを頬にかざして、徐に通る褄はずれ、末濃に藤の咲くかと見えつつ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畫師、徐に打微笑み、「否、不束ではございますが、我が手で拵へましたもの、貴下のお許しがありませんでも、開閉は自由でございます。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」バナナン大将（徐に眼を開く。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃やがて徐に段を下りて、清水に米を磨ぐお百合の背後に行く。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　時を見、程を計って、紫玉は始め、実は法壇に立って、数万の群集を足許に低き波のごとく見下しつつ、昨日通った坂にさえ蟻の伝うに似て押覆す人数を望みつつ、徐に雪の頤に結んだ紫の纓を解いて、結目を胸に、烏帽子を背に掛けた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と言ひ、それから、おもむろに腰の瓢のお酒を飮む。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく經つて、とんと輕く足踏みして、おもむろに呻き出すは、「是は阿波の鳴門に一夏を送る僧にて候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高く炎がゆらめき、人聲が顫へ、こんぐらかつた歌が玻璃と燭光から生じ、拍子がおもむろに熟して、――遂に、舞踏が涌き上つた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
