        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お縄ですか」「どうも素直に行きそうもねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手とお縄をあずかっている商売でも、年をとると後生気が出る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "神妙にお縄をうけいッ」　きくや、退屈男の蒼白秀爽な面に、ほんのり微笑が浮いたかと見えましたが、一緒にピリピリと腹の底に迄も響くかのごとくに言い放たれたものは、小気味よげなあの威嚇の白です。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間ひとりにお縄をかけるというのは重いことだ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やくざ者ではございますが、まだお縄を戴くには、間があるようでございます。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい私どもの稼業がら、海道筋へでも出ますれば、ゆすりかたりの一度や二度、やらねえこともございませんが、それとてあなたこれまでに、両とねだったことはなし、お縄だけはお目こぼしを。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあまあどうぞお縄だけは……」「何を！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の番の藤助はわたくしも識って居りますが、あなた方のお縄にかかりながら又それを抜けて逃げるとは、見掛けによらない大胆者でござるな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして世間へは駈け落ちと見せかけて、我が家の近所にうろ付いているなぞは、潔白な人間のおこないでは無いように思われますので、ともかくも取り押さえようと致しますと、案外に手向いを致しますので、よんどころなくお縄をかけたのでございます」「ごもっともで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも長年の間、いろいろの捕物をしましたがね、猿公にお縄をかけたのは飛んだお笑いぐさですよ」「その猿はどうしました」と、わたしは好奇心にそそられて又訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで三甚は思いも寄らない手柄をしたのですが、自身番へひかれて行った時に、金蔵はたいそう口惜しがって、どうでおれは遠島船を腰に着けている人間だから、遅かれ早かれ御用の声を聞くのは覚悟の上だが、いざお縄にかかるという時には、江戸で一、二といういい顔の御用聞きの手に渡る筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河町の半七、多勢に押さえ付けられて、とうとうお縄を頂戴した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違えば間違うもので、金蔵が藤吉となり、藤吉が半七となって、わたくしが先ず第一にお縄頂戴……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無益の殺生は致さん、思うこと申したる上は尋常にお縄を頂戴致そう」　良輔は、こういって、脇差を鞘へ納めて、荷の上へ置いた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の岡ッ引き、目明し、待っていた――で、お礼を頂戴するどころか、お縄を頂戴してしまいますよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やい、神妙にお縄をいただけ！",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遁がれぬところだ勾坂甚内、神妙にお縄を頂戴しろ！",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物一同、山の崩れる如くわッ／＼という人声、文治は取急ぎ血刀を拭い、お町に支度を改めさせて与力に向い、　文「いずれお役人様が御出役になりましょうが、市中を騒がし御法を犯せし我ら夫婦、お縄を頂戴いたします」　と大小を投出しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇屋へ招かれた大工の伊三郎だの、鳶の万蔵だのという者の口から聞くと、このたびのお縄張りは、滝の川附近へ、公儀で火薬の製造所をお建てになる御目論見から出たものだということがわかってきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥山の姐さんが朝腹お客を引込もうとした処を隠密に見付りお縄を頂戴いたしたので御座ります。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "お縄を戴きやしょう！",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那、お縄を戴きやしょう！",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神妙にお縄を頂戴いたせッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ、なんじも剣の妙手ならば、すみやかに機をさとり、その遁れられぬを観じて神妙にお縄をちょうだいしたらどうだッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからいろは屋文次はめったにお縄をしごかなかった。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、あの、私のほうはあとで存分にお縄をちょうだい致しますから、ちょっと、私のいうことをお聞き下すって――ああ、こういうまも、もどかしい――親分様の上に大変が迫っております」　水をやって落ちつかせたうえ、女のいう所を聞いてみて、さすがの文次もぎょっとした。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お六、逃れぬところだ、観念してお縄を頂けッ」「何をッ、銀流しのお六｜姐さんは、安岡っ引の手におえるような代物じゃねえ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "呪いの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高木銀次郎こと、幻の民五郎とはその方に相違ない、訴人があって確かだ、神妙にお縄を頂戴せい」「何、幻の民五郎」　あまりの事に高木銀次郎、一歩退きましたが、運悪く流しのぬめりに足を取られて、ハッと滑るところへ、待ち構えた小桶が四つ五つ、三方から狙い打に飛びました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幻の民五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなのようないい男のお手にかかるならせめても女｜冥利でござんすから、さ、ご随意におなわをかけなさいましな」　だから、じゃ、といって、すぐにも伝六へなわさばきを命じでもするだろうと思われたのに、意外なことに、むっつり右門はさらに莞爾とうち笑むと、涼しげにいったものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "じたばたせずと、おなわうけい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
