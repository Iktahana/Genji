    },
    "definitions": [
      {
        "index": 1,
        "gloss": "just as (each) one likes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "鼠色の印象（暴風雨前の富士山及び白峰山脈）　汽車の中は、蒸されるように混んだ、肘と肘と触れ、背と背と合された人々が、駅ごとに二、三人ずつ減る、はてはバラバラになって、最後の停車場から、大きな、粗い圏を地平線に描いて散った、そうして思い思いの方向へと往った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は思い思いの麓の野に土を掘り穿ち水を湛えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は子供の見方をするように人々はまた思い思いの見方をしているであろう。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "争議が解決した後も、いっその事思い切って従業員の制服を全廃して思い思いの背広服ないし和服着流しにする事を電気局に建言したらどうかと思ってみたのであった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物は思い思いに散って行った。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫をかかえた三人は思い思いの方角へ行って、なるべく寂しい場所を選んで捨てて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者が思い思いに退散するうちに、半七はわざと後れて座を起った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "六班がみんな思い思いの計画で別々のコースをとって調査にかかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国賊逆徒、売国奴、殺せ、撲れと、衆口一斉｜熱罵恫喝を極めたる、思い思いの叫声は、雑音意味も無き響となりて、騒然としてかまびすしく、あわや身の上ぞと見る眼｜危き、ただ単身なる看護員は、冷々然として椅子に恁りつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして魚ばかりではない、柳の葉も食切ると痛むのだ、）と思い思い、又この偉大なる樟の殆ど神聖に感じらるるばかりな巨材を仰ぐ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅びた主家の家臣らが思い思いに離散して行く感傷的な終末に「荒城の月」の伴奏を入れたのは大衆向きで結構であるが、城郭や帆船のカットバックが少しくど過ぎてかえって効果をそぐ恐れがありはしないか。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上り下りの電車がホームに到着するごとに、たくさんの人が電車の戸口から吐き出され、どやどや改札口にやって来て、一様に怒っているような顔をして、パスを出したり、切符を手渡したり、それから、そそくさと脇目も振らず歩いて、私の坐っているベンチの前を通り駅前の広場に出て、そうして思い思いの方向に散って行く。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思い思い私は充分の準備と警戒をしてコッソリとアパートを出た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに遠くへ歩いたおぼえはないが……と不思議に思い思いモトの階段を降りて、反対側の階段を昇ると、又も素晴らしく巨大な、知らない時計店の前に出た。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにかく今一度モトの処へ帰らなければと思い思い、タッタ今見て来た店の順序をタヨリに最初に降りた階段を上ってみるとヤットわかった。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は煮えくりかえる程腹がたって、どうしてくれようかと思い思いその時計屋に行ったら、見知り越しの番頭が出て来て、「いらっしゃいまし。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもせんの三人は、いくらかよかったと見えて、思い思いに飲っていた。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫んで思い思いに席を取った。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "評議の事定まりけん、童らは思い思いに波打ぎわを駈けめぐりはじめぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に出ずるものあり、煙草に火を点ずるものあり、また二人三人は思い思いに椅子を集め太き声にて物語り笑い興ぜり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその一二を受けながら、シナの水兵は今時分定めて旅順や威海衛で大へこみにへこんでいるだろう、一つ彼奴らの万歳を祝してやろうではないかと言うとそれはおもしろいと、チャン万歳チャンチャン万歳など思い思いに叫ぶ、その意気は彼らの眼中すでに旅順口威海衛なしである。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、もう一つのおみやげには思い思いのカメラの目にアルプスの魂を圧縮して持ち帰ろうとするであろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもはなはだふに落ちない不都合な話だと思ったのであったが、しかし翻ってこれを善意に解釈してみると、やはり役人たちがめいめい思い思いの赤誠の自我を無理押しし合ったのでは役所という有機的な機関が円滑に運転しないから困るという意味であるらしい。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "送りに来た書生さんたちはと見ると、まるでのんきな風で高笑いなどをしながら遠くから冗談口を取りかわしたりして、思い思いに散らばっていってしまった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い思いに気の合ったのが、帰際の世間話、景気の沙汰が主なるもので、「相変らず不可ますまい、そう云っちゃ失礼ですが。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ思い思いに祝ッてやったと思いたまえ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されども渠等は未だ風も荒まず、波も暴れざる当座に慰められて、坐臥行住思い思いに、雲を観るもあり、水を眺むるもあり、遐を望むもありて、その心には各々無限の憂を懐きつつ、※息して面をぞ見合せたる。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――村の人も婦を連れて、引立てて――村人ら、かつためらい、かつ、そそり立ち、あるいは捜し、手近きを掻取って、鍬、鋤の類、熊手、古箒など思い思いに得ものを携う。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い思い、町々八方へ散ばってるのが、日暮になれば総曲輪から一筋道を、順繰に帰って来るので、それから一時騒がしい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった時に、学校で何だか知らないけれど、私がものをいっても、快く返事をおしでなかったり、拗ねたような、けんどんなような、おもしろくない言をおかけであるのを、いつでも情ないと思い思いしていたのを考え出して、少し鬱いで来て俯向いた。",
              "citation": {
                "source": "化鳥",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
