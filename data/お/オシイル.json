        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そいつは押し入ると、獲物を求める、夜鷹のように、屋内を、隅から隅へ突きあたり、ひっくりかえした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは家へ押し入るとすぐ、夜更けにもかかわらず、わっと集まってきた群集を入れないために扉をふたたび閉じた。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人連の内の三人は、其処に停車している電車に、無理に押し入るようにして乗った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　しかし、すぐに押し入るような右門ではない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、すぐにも詮議に押し入るだろうと思われたのに、つねに周到綿密、目の光らせどころにそつがないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっても、門はぴしりと締まって、水門から消えた舟もはいったきり、その水門もまたぴたりと締まって、へいをのり越えるよりほかに、中へ押し入る道はないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダッともろ手体当てに、雨戸を難なく押し破りながら、先頭に主水之介、つづいて京弥、あとから神官正守の順でいきなり広縁に躍り上がるや、ずいと先ず退屈男が静かに部屋の中へ押し入ると、悠揚莞爾としながら、さらに静かに浴びせかけました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼まれてばかり斬って歩いて、馬鹿々々しい、と押し入る前にふいっと思ったのが、手元の狂ったもとさ。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "警固の者をまんまとやりすごしておいて、そのあとからすぐに裏をかいて押し入るなんてところは、なかなかあっぱれ者だよ」「なるほどね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちを騒がしておいて、そのすきに隣へ押し入る大胆な手口だけだって、相手の一筋なわじゃねえしろものってことがわかりそうなものじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひらりと上がって不意にそのへやへ押し入ると、静かに浴びせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "声もかけずに、無断で人の庭先までも押し入るとは、ふらちなやつと思いましたが、同役同僚とはいうものの、とにもかくにも先輩でしたから、何ご用かと名人みずから立ち上がって縁側まで出迎えると、こやつ、よくよく生まれながらのかたき役でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人連の内の三人は、其処に停車してゐる電車に、無理に押し入るやうにして乗つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、どうでしょう、あの男は、まるで＊２リナルドー・リナルジンみたいに頭の天辺から足の爪先まで物々しく身固めをして押し入るなり、『さあ、死んだ農奴をすっかり俺に売れ』って言うんですとさ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一人、町女房らしいものが、歩いておりましただけ――その女性が、つい今し方、風のように、追い抜いて駆け去ったものがあると申しましたれば、大方、そやつが――」「土部屋敷と知って押し入る奴、大胆不敵だのう――が、事が未然に防げたのは、太夫のお骨折りだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいるプールと僕とがこれから書斎へ押し入るつもりだ。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "押し入る代りにバラバラと、後へ退いたじゃアございませんか。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この機を失すれば、彼女は自分の部屋にはいってしまい、真夜中なので、きっとＫはそこへ押し入ることもできないだろう。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに近頃では強盗が押し入るんでも、ゲンカンから、堂々とアイサツをして来るそうですわ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもそんなことをして押し入る必要はございません。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも紳士の家にこんな風に不作法に押し入るのですか」「用件を説明しましょう。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに備えて、レッジポイントへさっと行って、さっと戻れば良い」「押し入るのですか」「いや、それはない。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋に押し入ると、床置きランプが見え、緑色の傘をかぶせてある。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶もそこそこに男爵とアーノットが押し入ると、すぐ扉をぴしゃっと閉め、鍵を掛けた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
