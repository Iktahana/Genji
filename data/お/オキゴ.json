          ],
          "literary": [
            {
              "text": "決して置碁を打たない。",
              "citation": {
                "source": "市井閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "置碁の定石の御手本通りのやりかたで、地どり専門、横槍を通すやうな打方はまつたくやらぬ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "置碁の定石の御手本通りのやりかたで、地どり専門、横槍を通すような打方はまったくやらぬ。",
              "citation": {
                "source": "教祖の文学",
                "author": "――小林秀雄論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはさておきご相談……」　と、京伝は落語でも語るようにペラペラ軽快に喋舌って来たのを、ひょいとここで横へ逸らせ、「どうでげすな滝沢さん、私の家へ来なすっては。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、半丁おきごとに点されている電燈でありました。",
              "citation": {
                "source": "老工夫と電燈",
                "author": "――大人の童話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして　ものおきごやに　かけこんで　じょうろのなかに　とびこみました。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピーターは　ぜったい　ものおきごやの　どこかに　いる。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものおきごやに　もどろうとすると　いきなり　すぐそばから　くわの　おとが　きこえてきました。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            }
          ]
        }
