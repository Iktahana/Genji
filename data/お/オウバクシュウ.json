        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いずれも黄檗宗の名僧｜独湛の嗣法の弟子で、性格も世離れしているところから互いは親友でありました。",
              "citation": {
                "source": "茶屋知らず物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "崇福寺は、黄檗宗の由緒ある寺だが、荒廃し、入口の処、白い築地の崩れた間を通って行くようになっている。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり黄檗宗で、明の帰化人、陳冲の子頴川藤左衛門が尽力して盛大ならしめた寺だ。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今籠町の黄檗宗崇福寺へ行って、唐門前の石欄から始めて夕暮の市を俯瞰した時、その心理的効果がはっきり感じられて面白かった。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、南京寺の一つ、黄檗宗に属す。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "興教大師御誕生地御誕生院、また黄檗宗支所並明寺などがあつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄檗宗のお寺ですから、下にずっと瓦を敷き詰めて、三方腰掛になっているのは支那風なのでしょう。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつぞや芝白金の瑞聖寺という名高い黄檗宗の禅寺を見に行った時その門前の閑地に一人の男が頻と元結の車を繰っていた。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "また自分はそんな冒険な事をやらないでも黄檗宗の一寺の住職になって居りさえすればごく安楽に過せる位置までに進んで居ります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
