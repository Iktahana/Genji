        "examples": {
          "standard": [
            {
              "text": "お袋について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お袋がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お袋というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお袋の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお袋が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お袋を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お袋の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お袋はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお袋があります。",
              "source": "幻辞"
            },
            {
              "text": "お袋は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お袋について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお袋の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お袋の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお袋が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お袋についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお袋は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお袋について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お袋という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお袋の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お袋を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "気立ての優しいよい娘であったが、可哀相にお袋が邪慳で、せっかく夫婦仲のよかった養子を離縁した。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親父は戦争で死ぬ、お袋はこれを嘆いたがもとでの病死、一人の兄がはずれものという訣で、とうとうあの始末。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝茶店内部　夜更けて――　表戸を開けて七五郎のお袋のお勘婆さんが顔を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、又、「アルファベット数えてしまえば、親爺や、お袋がいるところへ帰って行けるんかな。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひたといい出すお袋の事」と上がれば「よもすがら尼の持病を押えける」と下がるのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅さんのお袋とおぬいさんとは、妹を連れてきたおたけさんと一かたまりになって、混雑を避けるように待合室の外壁に身をよせて立っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やはそれをしおに諦めて、おぬいさんにやさしくかばわれながら三隅さんのお袋の所にいっしょになって、相対よりも少し自分を卑下したお辞儀をした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅さんのお袋はさすがに同情するらしく神妙にうなずいていたが、おぬいさんもだいぶ怪しかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三隅さんのお袋とおぬいさんとが親切に介抱してくれるので、婆やは倒れもせずに改札口を出たが、きゅうに張りつめていた気がゆるんで涙がこみあげてきそうになった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「星野さんがお帰りてから何んとかお便りがありましたか」　と大通り近くに来てからお袋が婆やに尋ねた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へえ天国に入れてもらいます……ばか……おやじが博奕打の酒喰らいで、お袋の腹の中が梅毒腐れで……俺の眼を見てくれ……沢庵と味噌汁だけで育ち上った人間……が僣越ならけだものでもいい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お袋に土産なんぞ持って来やあがる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おんつぁんはバケツに水を汲んで来て、お袋のやうに俺の足を洗つてくれた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに牛太郎と一緒におやぢのとこさ行つたらお袋が危篤で俺らこと捜しぬいてるところだつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三日目にお袋が死んぢやつたさ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺のお袋はいゝお袋だつたなあ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから俺はこんなに馬鹿になつたども、俺はお袋だけは好きだつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お袋の口をあけてコップの水をうつと流しこんでやつたら、ごゝゝと三度むせた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ……お袋の骨だあ」　と勃凸は珍らしくもないものでも見せるやうにつまらなさうな顔をして紙包みを私達の眼の前にさし出した。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほれ、お袋のよ」　私達は顔を見合はせた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく当分自前で稼ぐことにして路次に一軒を借り、お袋や妹に手伝ってもらって、披露目をした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまぼくの愛しているお袋は男に脅迫されて箱根に駈落しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お袋は新子と名を改めて復帰致しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実兄は、ぼくを中学の寄宿舎に置くと、一家を連れて上京、自分は××組合の書記長になり、学校にストライキを起しくびになり、お袋達が鎌倉に逃げかえった後も、豚箱から、インテリに活動しました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれ、お袋なんかねえよ」　と、京吉もロビイを横切って、「――おれのいる家の女のことだよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿な子ほど可愛いものだと言うけれど、ほんとうにまたあのお袋が可愛がっておるのでござります」お貞は僕にさも憎々しそうに言った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙を出しに行った跡へ、吉弥はお袋をつれて僕の室へあがっていた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "癇のためにそう引きつるのだとは、跡でお袋みずからの説明であった。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "精養軒は美味いのであり、おふくろのオムレツは不美味いのである？",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何処の国にもおふくろのオムレツみたいに、それがゲエテ、ダンテとばかり輝かしくはないまでも、納得の行く詩人といふものはゐるものである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
