        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女が、Ｔ「つい其処の道場の先生で相良伝右衛門とか仰しゃる御方」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎が、Ｔ「心配致すな　亭主　此の御方は誰あろう」　と武蔵を指さして、Ｔ「新免二刀流の開祖　宮本武蔵先生」　と言って、Ｔ「拙者は先生の高弟で　同じく新免二刀流の　達人」　と威張って、Ｔ「勇名天下に響き渡った　早水団九郎」　亭主も感心した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方こそは、この世の中で唯一人の、均衡と力とに充ちながら、御自身の作品とぴつたり調和してゐると自稱し得られる、御方でありませう。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚がＴ「此処には居なくとも御仏の御力を借りて拙僧が」Ｔ「必ッとその御方を貴女の眼の前へ御連れします」　おふみ、　「馬鹿々々しい」Ｔ「お生憎さま、妾の想ってる御方ァね、和尚さん」Ｔ「仏さまが鯱立ちして力んだって、こんなケチなお寺へは来っこないの」　と云い捨てて、廊下へ出ようとする。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「お類さんがッ」　「来ている筈だ」　「そんな御方は来て居りません」　「いま見たんだ」Ｔ「早く帰らぬと御主人様が心配なさる」　とお内儀を押しのけて入る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "非人同然の私が、お目付様のような大層な御身分の御方にお眼にかかる事が出来れば、それだけでも肩身が広うなりまする。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼うだ御方と、今一人の富豪と筆者と、三人歴行して自動車を降り、二月末の曇雲の下を藁葺のお寺じみた門に進むと、益田翁は黒い背広に宗匠頭巾庭穿靴でニコニコと出迎えた。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頭の頼うだ御方の背広に耄碌頭巾と調子を合わせたものであろう。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼うだ御方はしきりに質問しては感心して御座るが、その説明を聞いても格別わからないのだから少々情ないような気にもなった。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から聞いてみたら、愛想にも一片抓まないと主人と頼うだ御方に恥を掻かせる意味になるものだという。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤアヤア、それなる御方に物申す。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うしてくれようと思案の果てに、御方便なもんで、思い出したのが今云った諺だ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　一寸手懸　泰助は目をしばたたき、「薄命な御方だ、御心配なさるな。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとに深切な御方っちゃアありません。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御方の失せさせたまいし上は、最早この世に望みは無し、と下枝は落胆気落ちして、「もう聞とうない、言とうない。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明国の御方にも似合わない、名誉ということを御存じがありませんか。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前様方が人中で面を曝して、こんな会をしなさるのは、ああ、あの夫人は情深い感心な御方だと人に謂われたいからであろう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……篤志の御方は、一寸お日記を御覽を願ふ。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣ヶ峰千蛇ヶ池の、あの御方様とても同じ事、ここへお運びとなりますと、白山谷は湖になりますゆえ、そのために彼方からも御越の儀は叶いませぬ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい、はい、いえ、御坊様の前で申しましては、お追従のようでござりますが、仏様は御方便、難有いことでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女が神にせよ、また人間にしました処で、嘉吉づれが口を利かれます御方ではござりませぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、この秋谷で、邸と申しますれば――そりゃ土蔵、白壁造、瓦屋根は、御方一軒ではござりませぬが、太閤様は秀吉公、黄門様は水戸様でのう、邸は鶴谷に帰したもの。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の風をなつかしみ、またかしこくも、御朝廷の尊い御方々に対し奉つては、ひたすら、嬰児の如くしんからお慕ひなさつて居られたらしく、お傍の人たちを実にしばしば京へのぼらせ、その人たちが帰つて来てからの土産話を待ちこがれていらつしやる御有様は、お傍の私たちまでひとしく待ち遠がつたほどでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二日、甲辰、和田左衛門尉義盛、上総の国司に挙任せらる可きの由、内々之を望み申す、将軍家、尼御台所の御方に申合せらるるの処、故将軍の御時、侍の受領に於ては、停止す可きの由、其沙汰訖んぬ、仍つて此の如き類、聴されざる例を始めらるるの条、女性の口入に足らざるの旨、御返事有るの間、左右する能はずと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは、故右大将家の頃から、京都とはあまり接近せぬ御方針で、故右大将さまさへ、たつた二度御上洛なさつたきりで、――」「しかし、思ひ立つたら宋へでも渡らうとする将軍家です。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七　如是報我は飛来ぬ他化自在天宮に　オヽお辰かと抱き付かれたる御方、見れば髯うるわしく面清く衣裳立派なる人。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の人もまた、マリヤ様、エス様が、たいへんありがたいおかたであるという事は、教会の雰囲気に依って知らされ、小さい時からお祈りをする習慣だけは得ていながらも、かならずしも聖書にあらわれたキリストの悲願を知ってはいないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに黄ばんだしみのあるのも鼠のいたずらじゃないかしらんなど独語を云いながら我も手伝うておおかた三宝の清めも済む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空よく晴れて朝風やゝ肌寒く露の小萩のみだれを吹いて葉鶏頭の色鮮やかに穂先おおかた黄ばみたる田面を見渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ向うの腰掛には会社員らしい中年の夫婦が十歳くらいの可愛い男の子を連れておおかた団子坂へでも行くのだろう。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
