        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「crude」である。",
              "source": "幻辞"
            },
            {
              "text": "「crude」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "crude」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「crude」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「crude」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "crude」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「crude」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "crude」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「crude」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "crude」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「crude」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "crude」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「crude」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "crude」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「crude」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "crude」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「crude」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "crude」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「crude」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "crude」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "や、おぞいな千太、われ、えてものを見て逃げたな。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「久し振りでこういうところは珍らしいものだから」　葛岡はおぞい調子でこう言訳します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
