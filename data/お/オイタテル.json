        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自分が追い立てるようにして越前屋へ出してやった亭主の藤吉が、どうして再び江戸川の方角へ迷って行って、そこに身を沈めるようになったのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ナァニ、こんな物が重いものか」と、追い立てるようにして出発したが、その遅いこと牛の歩行も宜しくである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝のお化粧もやめてしまったが、その代りに夕方になると急にソワソワし出して、お湯に行ったり、おめかしをしたりして、まだ明るいうちに夕飯を仕舞うと、女中とチエ子を追い立てるようにして寝かした。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母は、取って置きの財資を貢ぎ出して、追い立てるようにわたくしの一家を海外に送ることにした。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、美和子を追い立てるように、階下へやると、前川氏への手紙を書き始めた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し喘息やみらしい案内者が No time, Sir ! と追い立てるので、フォーラムの柱の列も陳列館の中も落ち着いて見る暇はなかった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵の戸前をみんな明けて見せろ」　当兵衛はおどおどしながら何か弁解しようとするのを、半七は追い立てるようにして、奥の土蔵前へ案内させた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は追い立てるように二人を蚊帳の中へ送り込んで、間の襖を閉め切った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、采女もそばから追い立てるように口を添えた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの女の正体がこれであるのは誰にも想像されることであるから、大勢は騒ぎ立てて捕えようとしたが、短い武器では高い梁の上までとどかないので、さらに弓矢や長い矛を持ち出して追い立てると、怪鳥は青い燐のような眼をひからせ、大きい翅をはたはたと鳴らして飛びめぐった末に、門を破って逃げ去った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "法会は中途で急に終わって、参列の諸人が一度に退散するために、先払いの雑色どもが門前の群集を追い立てるのであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」夢中になって追い立てる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とかくに落ち着き顔をしている火の番の藤助を追い立てるように指図して、長三郎は近所の医者を迎えにやった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえその夜、甲谷がお杉を追い立てるようなことをしたとはいえ、それならそれで、お杉も売女にならずともすますことは出来たのではないか。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、そこの家に飼ってある犬がおそろしい声で追い立てるように鳴きました。",
              "citation": {
                "source": "幸福",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスの婦人たちは、この戦争によって流した無限の涙と、引き裂かれ失われたすべての愛のなきがらの中から、再び人民を戦争に追い立てるような権力のとりのぞかれた世界を創ろうと決心して、自分たちの党、共産党を選んだのでした。",
              "citation": {
                "source": "幸福のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸気がつかない間に、何処へかいなくなってでもいはしまいかという烈しい意味のない懼れが、ルイザを焼くような思いで腰掛から追い立てるのであった。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は、もう動かないつもりで、――大家が追い立てる迄は居る決心で――落付き場処を青山の中で見出そうと云うのである。",
              "citation": {
                "source": "又、家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、追い立てるのになぜ連れて来たのか？",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と追い立てるようにいわれたと思うと、ふと目を覚ましました。",
              "citation": {
                "source": "一本のわら",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と久慈は千鶴子を部屋から追い立てるように云って、彼女の後からドアへ鍵を降ろした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平は、稼がにゃならん、お前らも儲けてもらわにゃ、と二人の若い息子を励まし追い立てるようにして、装ふりかまわぬ暮しである。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の仕事の結終を急いでつけようとするのでもあろうか無数に並んでいる工場からは、鉄槌の音や機重器の音や汽缶の音がさも忙しく追い立てるように聞えて来る。",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北京の秋は、夏を追い立てるように急にやって来て、そして晴朗な日が続きます。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此は早晩儂を此巣から追い立てる退去令の先触ではあるまいか。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と追い立てるが一向に動かない。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "乱視の奈翁　――アルル牛角力の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "田んぼのあぜをまわって、ホーイホーイと雀を追い立てる仕事しかできない者であったとしても、雀追いを一生の間まじめに勤めて村のために働いたら、神の目から見て、人生成績に満点がつけられる。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
