        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――あら今お隣の窓から、若い男の人が此方みて嗤つてたわ、あたしたちの話を聞きやしなかつたかしら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上から男の人が手を差し出してくれたのでそれにつかまりました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尤も私達の所では、男の人が娘に取入らうとする時には、先づ最初に贈物をするのが普通だね、くるみか香料入りのパンか何か買つて来るのが。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は作楽井というこの男の人なつかしそうな眼元を見ると、反対するのが悪いような気がしたので「私は構いませんわ」と言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな打ち明け話があってから、芹川さんと私との間は、以前ほど、しっくり行かなくなって、女の子って変なものですね、誰か間に男の人がひとりはいると、それまでどんなに親しくつき合っていたっても、颯っと態度が鹿爪らしくなって、まるで、よそよそしくなってしまうものです。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、橋本のおばさんが、上からいきなりその男の人に声をかけた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目前へ路がついたように、座敷をよぎる留南奇の薫、ほの床しく身に染むと、彼方も思う男の人香に寄る蝶、処を違えず二枚の襖を、左の外、立花が立った前に近づき、「立花さん。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景ななどと、男の人の使うような言葉をもちいたが、全くその写真を見たときの私の気持はそれより外に現わせない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれまで男の人に好かれた経験はなかった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　弓子は踊りながら、「あの男の人、誰だかご存知ですか」「知らん！",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけず男の人からの手紙であった。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『綺麗な男の人はみんなお父さんに似ているかも知れないね。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の人魚というものは、未だその出現のことを聞かない。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の人って、死ぬる際まで、こんなにもったい振って意義だの何だのにこだわり、見栄を張って嘘をついていなければならないのかしら。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると街道の松の木のかげにゐた男の人が、かういつて鳥右ヱ門をよびとめました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そのほうの事では、男の人を、あまり信用して居りませんし、また、滅茶に疑っても居りません。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らない男の人の肩車に乘つて私はそれを眺めた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの社が傍にあつて、その男の人が私にそこのさまざまな繪馬を見せたが私は段々とさびしくなつて、がちや、がちや、と泣いた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除が終わって、いよいよ第二十｜回常会を開こうとしていると、きこりのような男の人が、顔の長い、耳の大きい爺さんを乳母車にのせて、尼寺の境内にはいって来た。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が椿のところへもどって来ると、そこに自転車をとめて、一人の男の人が立っていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言われると、そんな気もして来るけど、それじゃ、男の人は、どうなの？",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこの男の人品骨柄は、いやしくない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上から男の人が手を差し出してくれたので、それにつかまりました。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の人にはとてもわからぬ苦しみなのでしょうか。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、どんな男の人でも、尊敬している。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さちよは調子に乗って、「女ひとりの仕合せのために、男の人を利用するなんて、もったいないわ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところに、女のひとが、どさんと重いからだを寄りかからせたら、どんな男の人だって、当惑するわ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
