        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一点の人情をつけて恋々西国より東国へ娘の生い立ちにを見に下った螺の如き腹にえび蔓のような背をした老翁は、たとえ自然には冥通ある超人には違いないが、なお純粋の神とはいわれなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを何十万年何百万年の生い立ちの話をするなんて、あんまり親をばかにし過ぎるぞ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は彼等の生い立ちが何よりも待たれた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲んだくれの父の子に麒麟児が生い立ち、人格者のむすこにのらくらができあがるのも、あるいはこのへんの消息を物語るのかもしれない。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は久振りで、自分の嫌な過去の生い立ちを点検してみた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まこと、まごころ、こういうものは彼が生れや、生い立ちによる拗ねた心からその呼名さえ耳にすることに反感を持って来た。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ものの走りが純粋｜無垢でありながら、何か※ぎ取られた将来の生い立ちを不可解の中に蔵している一つの権威、それにも似た感じがあった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はダンディには朋輩を持たず、たれ一人としてその生い立ちを知っている者もない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "広く一国民の生い立ちを明らめんには、必ず民俗学の講究を要す。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧家にこそ生い立ちたれ、母上の慈悲にて、聊かながらかかる業をも習い覚えしなりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の生い立ちは非常に不幸であった。",
              "citation": {
                "source": "私の父と母",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶が、異常に興奮して、自分の生い立ちや、母の死や父の死や、兄の事などが、頭の中に次ぎ次ぎに思い浮んで来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がドンナ生い立ちの、どんな思想を持った女だったか、校長先生は御存じでしたか知ら……。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どうして三人が一しょになって仕事をする様になったか、また、三人がどういう生い立ちの者であるかというようなことは、この物語とは関係のないことですから、申し上げません。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共肇の話す生い立ちは「うそ」にしろ「出たらめ」にしろ気持の悪い作り事ではなかった。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この著者が『文芸』二月号に書いている「私の批評家的生い立ち」と合わせて、私は永年の友達であるこの著者の人柄や心持ちなどの真髄を、あらためて印象のうちに纏められたような心持がした。",
              "citation": {
                "source": "作家に語りかける言葉",
                "author": "――『現代文学論』にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧ろ、「私の批評家的生い立ち」の前半に語られているように、「評論を書いていると、論理の容赦なき発展が、逆に私自身に何か哀愁をさえ感じさせる」という感じやすさがつよく現れている。",
              "citation": {
                "source": "作家に語りかける言葉",
                "author": "――『現代文学論』にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川龍之介という作家は、都会人的な複雑な自身の環境から、その生い立ちとともに与えられた資質や一種の美的姿勢や敏感さから、それらのテーマが主観のうちに重大であり、客観的に注目をひくものであればあるだけ、いきなりの表現で描き出すことは避けてゆくたちの作家であったと思う。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船出は、地理上の旅行であるばかりでなく、フランス中産階級の生活の中でも特別な生い立ちをもったジイドにとっては全く幼年時代からの訣別であった。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は馬籠の旧本陣で、そこの大規模な家の構え、召使いなどの有様は、「生い立ちの記」の中にこまかく描かれている。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生い立ちの記」をよんで見ると、国を出る迄末息子としての藤村が、お牧という専属の下女にかしずかれ、情愛の深い太助爺を遊び対手とし、いかにも旧本陣の格にふさわしい育ち方をしている姿がまざまざと浮んで来る。",
              "citation": {
                "source": "藤村の文学にうつる自然",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一方では、作者は、作中の主要な人物の一人である与作の村の若衆としてはごく特殊な生い立ちや経歴から来る村民との日常交渉について忽卒に過ぎているのは作品の効果を薄める結果となっている。",
              "citation": {
                "source": "作家への課題",
                "author": "――「囚われた大地」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、私はそういう生い立ちでありませんから……なまじっか、柄にないことに手を出して見た処で、自分も困るし、他も迷惑と思います。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたも私も生い立ちは同じようなものじゃありませんか」　竹内さんはこういっておられる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "学校へ奉職した前後のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私の生い立ちと「青と白」の少年の生い立ちとも比較して考えてみました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が愛情の生い立ちから言っても、これから将来のことを考えても、彼の心は抑えに抑えたものであらねば成らなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマンティックな傾向に立って文学的歩み出しをしていた藤森成吉、秋田雨雀、小川未明等の若い作家たちは、新たに起ったこの文学的潮流に身を投じ、従来の作家の生い立ちとは全くちがった生活の閲歴を持った前田河広一郎、中西伊之助、宮地嘉六等の作家たちと共に平林初之輔その他が新興文学の理論家として活動しはじめた。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此の歓喜を永く記憶するために、この短かい一篇を記すと同時に、親切な、筆を以て、細かに、「生い立ちの記」を年毎に月毎に日毎に書き記して置きたい心がまえである。",
              "citation": {
                "source": "暁光",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は天主閣の建っていた所が平地になって、いつしか姫小松まばらにおいたち、夏草すきまなく茂り、見るからに昔をしのばす哀れなさまとなっています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの天狗の落とし子のような彼のおいたちがすでに仙人らしい飄逸味に富んでいるが、茶に沸かす川の水の清さを桶の中から味わい分けた物語のごとき、いやしくも文芸の道に一片の了解をいだく者の、会心の笑みを漏らさずには読み得ぬ一節ではあるまいか。",
              "citation": {
                "source": "茶の本",
                "author": "はしがき",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
