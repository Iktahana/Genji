        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは昔の旗本が住んでた屋敷で、大きな武家風の門があり、庭には蓮池などがあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の玄関へつくと、車夫がとても威勢の好い大きな声で、『オ帰リイ』と叫ぶ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人にとってのヘルンは、最も信頼する良人であったと共に、一面ではまた『大きな駄々ッ子坊や』でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時夫人が、江の島に遊んだ土産として、大きな法螺貝を買って帰った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大きな声を挙げて泣いた。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお手紙の文面が、やさしく正直なのも大きな悦びでありましたが、それよりも何よりも、私にはあのお手紙の長さが有難かったのです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると其処に自転車屋があつて大きな犬が飼つてあつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」つてな大きなことを言つてゐる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は急に大きな安心を得たやうに胸が踊つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに表現の構成を分析すれば、「柚の花」が静かな侘しい感覚を表象し、「母屋」が大きな旧家――別棟や土蔵の付いてる――を聯想させ、「乾隅」が暗く幽邃な位置を表象し、そして「ゆかしき」という言葉が、詩の全体にかけて流動するところの、情緒の流れとなってるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪かなしいつ大仏の瓦葺　夢のように唐突であり、巨象のように大きな大仏殿。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち例へば「古池」といふ言葉は、日本人の連想からは直ちに古い寺院の池や、庭園などにある閑雅で苔むした小さな溜水の池をイメーヂするが、温気のない西洋にはそんな古池が無いのであるから、西洋人のこの語から連想するイメーヂは、アルプスやスヰスの山中などにある、青明に澄んだ大きな湖水であるだろう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、これが僕を人嫌いにし、非社交的の人間にしたことの、一つの最も大きな原因だった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時三つ斗りなる兒の、小く太りたるが、大きなる大人の下駄を引きずりて、縁先近く參りたる、覺束なき足もとなり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立止って気をつけて見ると、頭に突き出た大きな眼は、怪しいまなざしに何物かを呪うているかと思われた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中景の右の方は樫か何かの森で、灰色をした逞しい大きな幹はスクスクと立ち並んで次第に暗い奥の方へつづく。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に一本大きな赤椿があって、鵯の渡る頃は、落ち散る花を笹の枝に貫いて戦遊びの陣屋を飾った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処で買ったかと聞いたら、町の新店にこんな絵や、もっと大きな美しいのが沢山に来ている、ナポレオンの戦争の絵があって、それも欲しかったと云う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番大きな下の壇へは色々な供物の三宝が並べられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから朝市の大きな西瓜、こいつはごろごろして台へ載りにくかったのをようやくのせると、神様へ尻を向けているのは不都合じゃと云い出してまた据え直す。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時はいかにも苦しそうな溜息ばかりして何遍となく便所へはいって大きな欠伸をする癖がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて禿頭の大坊主で、いつも大きな葉巻を銜えて呑気そうに反りかえって黙っていたのはプリングスハイムであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合わせた農夫農婦などは銘々の大きな荷物に腰かけているからいいが、手ぶらの教授方以下いずれも立ったままでゆられながら、しきりに大気の物理を論じ合っていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレフンケン・システムの大きな蛇のようなスパークがキュンキュンと音を立ててひらめいては消えるのを見た。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に生温かい、晴れるかと思うと大きな低い積雲が海の上から飛んで来てばらばらと潮っぽい驟雨を降らせる天候であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして毛糸で編んだ恐ろしく大きな長い羽織の紐をつけていたと想像される。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは地球から見た時に太陽が天球のどこに来ているかという事を意味するだけの事であるから、太陽系に何か大きな質量の変化が起こるか、重力の方則が変わらない限り、予定のとおり進行してゆくはずである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
