    },
    "definitions": [
      {
        "index": 1,
        "gloss": "room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お部屋について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お部屋がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お部屋というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお部屋の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお部屋が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お部屋を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お部屋の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お部屋はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお部屋があります。",
              "source": "幻辞"
            },
            {
              "text": "お部屋は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お部屋について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお部屋の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お部屋の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお部屋が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お部屋についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお部屋は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお部屋について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お部屋という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお部屋の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お部屋を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門だけではなく、乙姫のお部屋にも、屋根や壁はあります。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのかたは、これからご自分のお部屋に歸るのでせう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、乙姫はご自分の家へやつて來た珍客を階段まで出迎へて、さうして安心して、あとはあなたのお氣の向くままに勝手に幾日でもここで遊んでいらつしやるやうにと、素知らぬ振りしてああしてご自分のお部屋に引上げて行くといふわけのものぢやないんですかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さつきから、お前はお部屋お部屋と言つてゐるが、そのお部屋はいつたい、どこにあるの？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は、乙姫のお部屋にも、はひつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お部屋を綺麗に致しましたの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）本当にわたくしは、このお部屋を拝見いたすのを、昨晩から楽に致して参りましたのでございますよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう仰ゃれば、わたくしがこのお部屋へ参りまして、心付いた事がございますから、御遠慮なくそれを申して見ましょうか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んだかこのお部屋の空気の中に、そういう幸福の影が漂っているようでございますね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――アダは貴方のお部屋に寝床をとりに行くのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十三年六月十三日富栄追伸　お部屋に重要なもの、置いてございます。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "――日当は好んですけれど、六｜畳のね、水晶のやうなお部屋に、羽二重の小掻巻を掛けて、消えさうにお寝つてゝ、お色なんぞ、雪とも、玉とも、そりや透通るやうですよ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お師匠をお部屋へお呼びなされて富本のお稽古をお始めになられたのも、よほど昔からのことでございましたでしょう。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父様も母様も婆様のほんとうの御子ではございませぬから、婆様はあまり母様のほうへお遊びに参りませず四六時中、離座敷のお部屋にばかりいらっしゃいますので、私も婆様のお傍にくっついて三日も四日も母様のお顔を見ないことは珍らしゅうございませんでした。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い長い廊下の片隅に、白くしょんぼり蹲くまって、かなり遠くから見たのでございますから、ふいるむのように小さく、けれども確かに、確かに、姉様と今晩の御婿様とがお寝になって居られるお部屋を覗いているのでございます。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の十時頃、私が母と二人でお部屋にいて、一緒に父のセルを縫って居りましたら、女中がそっと障子をあけ、私を手招ぎ致します。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄さんはそう言って屈託なく笑って帰りましたけれど、私は勝手口に立ったままぼんやり見送り、それからお部屋へ引返して、母の物問いたげな顔にも気づかぬふりして、静かに坐り、縫いかけの袖を二針三針すすめました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途々、身なりを整えてお家へ戻り、静かにお部屋の障子をあけたら、母は、何かあったのかい？",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お部屋へあがったらどう？",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだそれだ……」「あ……それなら向うの突当りの梯子段をお上りになると、直ぐ左側のお部屋で御座います。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "柔和に構えて、チンとすましていられると、その剣のある眼つきが却って威を示し、何処の高貴のお部屋様かと受取られるところもある。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎの時間には教場に出ないでもよろしいから、私のこのお部屋に入らっしゃい。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が、貴女様このお部屋へ、その立花様というのがお入り遊ばしたのを見て、取って返しましたで、折返して、お支度の程を伺わせに唯今差出しました処、何か、さような者は一向お見えがないと、こうおっしゃいます。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さん、私ゃ芸者のかざかみにも置かれない……意気な人には御守殿だ、……奥さんだ、お部屋だって言われます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、ひとつこの若い神を困らせてやろうとお思いになって、その晩、大国主神を、へびの室といって、大へび小へびがいっぱいたかっているきみの悪いおへやへお寝かせになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大神は、その晩はむかでとはちのいっぱいはいっているおへやへお寝かせになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、おぐしがたる木じゅうへ縛りつけてあったのですから、大力のある大神がふいにお立ちになるといっしょに、そのおへやはいきなりめりめりと倒れつぶれてしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは三輪の社の大物主神が、勢夜陀多良媛という女の方のおそばへ、朱塗りの矢に化けておいでになり、媛がその矢を持っておへやにおはいりになりますと、矢はたちまちもとのりっぱな男の神さまになって、媛のお婿さまにおなりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "媛のおとうさまとおかあさまとは、どうかして、そのお婿さんを、どこの何びとか突きとめたいと思いまして、ある日、媛に向かって、「今夜は、おへやへ赤土をまいておおき、それからあさ糸のまりを針にとおして用意しておいて、お婿さんが出て来たら、そっと着物のすそにその針をさしておおき」と言いました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
