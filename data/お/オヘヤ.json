[
  {
    "uuid": "c2375b0e-df0b-539e-bb8a-f69c1242c111",
    "entry": "お部屋",
    "reading": {
      "primary": "おへや",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
