        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あのお澄ましの奥さんが、どんな顔をするか、ああ愉快だ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "お澄まし顔の紳士たち、挨拶じょうずの奥様方、は、僕の眼の下で慌てたが、けっして逃しはしなかった。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五重塔のある側に綺麗なお汁粉屋があって、そこのお雑煮のお澄ましが品のいい味だというので、お母様は御贔屓でした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、ふと、お姫さまはおうたいなさる声を止め、お鳴らしなさる琴の手を控えて、ずっと遠くの方に、耳をお澄ましなされました。",
              "citation": {
                "source": "町のお姫さま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつになく、お澄ましでいらっしゃいますこと」「今日はご主客でしょうが、なにもそんなにまで、よそ行き顔をなさらないでも、およろしいでしょう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『何処へ行らっしったんです、お澄ましで』『実家まで』『お実家へ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「月ヶ瀬」へ彼女が現れるのは、大抵夫婦喧嘩をしたときに限るので、あんまり腹が立ちましたよって「月ヶ瀬」で栗ぜんざい一杯とおすましとおはぎ食べてこましたりましてんと、彼女はその安い豪遊をいい触らすのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼な申し分ではございますが、まったく張り合いがない、どッと来べきところをでも皆様がたはおすましになっておられます」「そりゃ生活がまるで違ってるから、ね」「そうでげしょう、な」彼はさすがに学問ある人の仲間は違うものだと考えられた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一番おすましはだあれだ――つて、それはお姉さんが出したのよ。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "半四郎師匠は、変化の拵えを、おすましになったままで、俯伏さっていられたのでございます。",
              "citation": {
                "source": "京鹿子娘道成寺",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、気どり屋のおすまし、大きらい。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけ、おすましして、しくじらないように気をつけるわ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　とっても　おすまししてなあい？",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のあつさ考え、なしでおすましになることはよくないと思って居りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は暫く鏡を見つめていたが、何を思ったか、クスクス笑い出して、「お前、もっとおすまししてね、あちらの、書生や小間使なんかのいる部屋をね、見廻って来てごらん。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おすましやのお洒落の泣き虫さん。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、あんた、もっとぐっとおすまししてね、あちらへいって、書生や女中に、なにかいってごらん。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "で――軒から軒の浅黄｜暖簾や、紅ン殻色の出格子のうちから、「そこへ行く、美い男さま」「おすましの編笠さん」「ちょっとお寄りなさいませ」「笠のうち、一目、見せて」　と、籠の鳥が、囀り抜く。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧く、刑をおすましなすって」　と、涙さえ浮かべていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、奥方やお子たちのお別れは、はやおすましあられたか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨年、君命として、それがしから達しておいた松寿丸を打ち首になすことは、もはや滞りなくおすましとは存ずるが、その後、確たるお答えのないため、信長公にもお不審をかけられておる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿にも、あまり参れぬ御酒をたんと戴いて、めでたさのあまり、酔を過しておらるるものとみゆる」「では、お夕餉など、先へおすましなされては」「いやいや、お戻りを見ぬうちは、食事も摂りとうない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにとぞ、ご服喪は今日一日だけのこととして、おすましを願いまする」　と、進言した。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おすましなされた。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            }
          ]
        }
