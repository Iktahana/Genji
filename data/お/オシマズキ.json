        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "社長に泣きつけば自分だけはまだ入れて呉れるかも知れないといふ位に考へてゐた彼女は、それにどう返事して好いか悪らずに、几帳面に坐つてさへゐれば好いことにしてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句｜几董の句集に洩れ、後に遺稿中から発見された。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉の大木の下に床几を積み上げたるに落葉やゝ積りて鳥の糞の白き下には小笹生い茂りて土すべりがちなるなど雑鬧の中に幽趣なるはこの公園の特徴なるべし。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几代りにまた腰をかけて、少し休む。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の登山者は、ここで一息いれる、水を飲む、床几にごろりと横になるのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店の床几で鼠色羽二重の襦袢の襟をした粗い久留米絣の美少年の姿が、ちらりと動く。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几がひっくりかえる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝茶店の外　夕やけ小やけ……　半五郎の帰った後、源兵衛一人、表に出て、しょんぼり床几に腰掛けている。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几に腰掛けた商人風の男二人話す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝表　侍が床几に憩み、掛けている。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の様子に一寸意外に思ったが、その儘二人の傍に来て三次の隣りの床几に腰を下ろす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几に腰を下ろして休んで居ると、其処へ一人の遊び人風の男がやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝元の茶店――　三次が床几に腰かけている前を何処かの子供がワーンワーンと泣き乍ら帰って行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝居酒屋（夜）　土間で三次が床几に腰掛けてチビリチビリやって居る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "進藤が話して居る背後の床几に大吉が腰下した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几の上に残って居た進藤の大刀を大吉が取り上げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が又床几に腰掛けて茶を飲まんとした時、急ぎ足に半次が現れた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごつ／＼した、几帳面な藤井先生までが、野球フワンとなっていた。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "律儀な、几帳面な男でもない。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木谷は、几帳面で、根気強い活溌な性質がとくをして、上等兵になっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几の隅に腰掛けておふみが考え込んで居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几の前には冷たそうな小流があったから手桶の水を汲もうとしてちょいと気がついた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "備中驚き嘆じ、無事に渉り果てた按摩を、床几に近う召寄せて、「あつぱれ、其の方、水にせかるゝ大巌を流に逆らひ押転ばす、凡そ如何ばかりの力があるな。",
              "citation": {
                "source": "怪力",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はそのあひだに、几帳面らしく眞野と飛騨へ、お世話になりました、と言つてお辭儀をして、それから小菅へ眞面目な顏で尋ねた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明窓浄几、筆硯紙墨、皆極精良、とでもいうような感じで、あまりに整頓されすぎていて、かえって小川君がこの部屋では何も勉強していないのではないかと思われたくらいであった。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『なるほど、将几ができたね。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と畳んで棒のごとくする樫の将几を開いて見せた。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いよいよ本式になったナ』と自分は将几と小山とを見比べて言った。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は画板を肩から腋へ掛け畳将几を片手に、薬壜へ水を入れてハンケチで包んだのを片手に。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
