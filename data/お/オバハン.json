    "definitions": [
      {
        "index": 1,
        "gloss": "aunt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おばはんについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、おばはんがありますね。",
              "source": "幻辞"
            },
            {
              "text": "おばはんというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはおばはんの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はおばはんが好きです。",
              "source": "幻辞"
            },
            {
              "text": "おばはんを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、おばはんの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "おばはんはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにおばはんがあります。",
              "source": "幻辞"
            },
            {
              "text": "おばはんは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日おばはんについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はおばはんの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "おばはんの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではおばはんが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "おばはんについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でおばはんは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でおばはんについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "おばはんという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとおばはんの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "おばはんを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――ところで、おばはん、けったいな事訊くけど、おまはん字イはどないだ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、お門ちがいや、うちの孫はまだ十やさかいな、おまはん仲人したかったら、散髪屋のおばはんとこイ行きなはれ」「聴こえるがな、聴こえたら、また朝日軒のおばはん頭痛を起しまっせ」　広島生れの玉堂は下手な大阪訛りで言って、ちょっと赧くなった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「おばはん、もう帰り。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他吉は出て行く時、「おばはん、君枝をたのんどきまっせ」　と、言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅宇しかえ屋のおばはんみたいな声だして……」「お前うちのことあてこすってたやろが……」「どない言うねん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お、お、おばはん、わかった」　二度と浮気遊びはしないと柳吉は誓ったが、蝶子の折檻は何の薬にもならなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言うたら、手っ取り早いとこ乳にありついたいうわけやが、運の悪いことは続くもんで、その百姓家のおばはん、ものの十日もたたんうちにチビスにかかりよった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そンでまア巧いこと乳にありついて、餓え死を免れたわけやが、そこのおばはんいうのが、こらまた随分りん気深い女子で、亭主が西瓜時分になると、大阪イ西瓜売りに行ったまンま何日も戻ってけえへんいうて、大騒動や。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばはんとうとう出て行きよったが、出て行きしな、風呂敷包持って行ったンはええけど、里子の俺は置いてきぼりや。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ところで、おばはん、けったいな事訊きまっけど、おまはん字ィはどないだ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳吉は二十歳の蝶子のことを「おばはん」と呼ぶようになった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばはん、何すんねん、無茶しな」しかし、抵抗する元気もないかのようだった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「く、く、く、るしい、苦しい、おばはん、何すんねん」と柳吉は足をばたばたさせた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ごろどこぞで散財していやはりまっしゃろ」となおも苛めにかかったが、近所の体裁もあったから、そのくらいにして、戸を開けるなり、「おばはん、せせ殺生やぜ」と顔をしかめて突っ立っている柳吉を引きずり込んだ。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がついた、すぐ来いの電話だと顔を紅潮させ、「もし、もし、私維康です」と言うと、柳吉の声で「ああ、お、お、お、おばはんか、親爺は今死んだぜ」「ああ、もし、もし」蝶子の声は癇高く震えた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのおっさんがオレにとっては掛け替えのないただ一人の父であり、あのおばはんが誰が代わることもできない母であることは、地球が丸いと教えられる以前から当然のことながら気づいていたのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすごすご（いえ大分ねばったのですが、ほつれた髪の毛のおばはんに、高飛車にことわられ）出て、次の郵便局へゆきました。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駅にも、はア今ごろは新聞がついちょろうから、おばはんも大抵よろこんででありましょうよ」　天真爛漫な叔母のよろこびに、ひろ子は笑顔で応えることも出来なかった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "實が入るとたんぽぽのおばはんのやうに、少しの風にも飛び出す。",
              "citation": {
                "source": "春",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
