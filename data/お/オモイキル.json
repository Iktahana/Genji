        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "本当ならば、幸子をお前に譲ってやるべきだろうけれど、僕には彼女を思い切ることは到底出来そうにもない。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お前、可い加減な事を言って、ちっとも思い切る様子はないではないか。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、思い切れ、思い切ると判然言え、これでも薬はまだ利かぬか。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "申すまでもありません、お雪はとても辛抱の出来る事ではないのですから、きっと思い切ると言う。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そうかと言って、先生の言う通りあんたを思い切るなぞということは、どんなに努めても出来ることではない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自分に、先生は、思い切ると言えと迫る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は遂に最後の慎しみを破って、こう自分に決断を命じた、「わたしと結婚するか、でなければ、蝶子を思い切るか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "訣れるとき、わたくしは葛岡に念の為め、「詫び手紙の中に、あんた、あたしを思い切ると書くの」　と訊きますと、葛岡は、「だれが、そんなことを。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし善昌も堕落坊主を思い切ることは出来ない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても、思い切る事が出来ないのですか？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、いよいよ思い切るのかと念を押すと、六三郎はわっと泣き出しました。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜衣の返歌は彼に対する最後の一｜偈で、しょせん自分の望みは遂げられないものと覚りながらも、彼の根強い執着心はまだこの恋を思い切ることが出来なかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう倭文子が、それをきいて京子に対する義理から、自分を思い切るというなら、自分も男らしく、倭文子の言葉を甘受しよう。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そう思いながらも、俺は貴女を思い切ることが出来ないのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は、思い切るほかはござらぬ」　玄白が、何気なくそういった時だった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "男が手数料を出したとすれば、高価い、まずいオイランを買って流連した気で思い切る事になる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は刃を以てする複讐を思い切る為めに、何度か、あの免職教員の親切な助言を煩わした。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はどんな人か知らないが、お中間なんぞと係り合ったところで行く末の見込みは無いと、女房からも私からもよくよく意見を致しましたら、当人も眼が醒めた様子で、その男のことは思い切ると申していました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "有王は、主の心に物怪が憑いたものとして、帰洛の勧めを思い切るよりほかはなかった。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "手につかない仕事を思い切るまでは苦しかったが、それも思い切ってしまって四五日の休養に出掛けると成ったら余程もう気が楽になった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉は、限りなき憎悪をいだきながらも、京子を思い切ることが出来なかった。",
              "citation": {
                "source": "鉄路",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を思い切るという位、理窟のわかる貴様が、どうしてこれがわからないんだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこに居るかわからぬ子供を思い切ると云うかと思うと、夫婦別れをするらしいのに夫の身の上を心配している。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その中に唯一つ、只今より申述ぶる最後のお頼みばかりは、如何にしても思い切る事が出来ません。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、これがいい、これで和歌子が自分よりも深井を選べば、もしくは選んでいるなら、自分は残念だが――」（思い切る）とまでは自分に明言できなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もし僕が二度この世に生まれて来るものなら、そして和歌子さんが同時に二度この世に生まれて来れるものなら、あるいは僕はこのままで思い切ることが出来るかも知れません。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺アいよいよ思い切るよ」「うん。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
