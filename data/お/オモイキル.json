    "definitions": [
      {
        "index": 1,
        "gloss": "to give up (all thoughts of)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
