        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "隣りに言葉｜訛り奇妙なる二人連れの饒舌もいびきの音に変って、向うのせなあが追分を歌い始むれば甲板に誰れの持て来たものか轡虫の鳴き出したるなど面白し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "須走は鎌倉街道ではあるが、山の坊という感じで、浅間山麓の沓掛や追分のような、街道筋の宿駅とは違ったところがある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "追分の通りの片側を田舎へ避難する人が引切りなしに通った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに追分辺でミルクの缶やせんべい、ビスケットなど買った。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六番目は誰です」　「追分け三五郎」　「七番は」　「尾張の大野の鶴吉」　「八番は」　「尾張の桶屋の吉五郎」　「九番は」　「三保の松五郎」　「十番は」　「問屋場の大熊」　「十一番は」　「よせやい、爺っつあん。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りの汽車が追分辺まで来ると急に濃霧が立籠めて来て、沓掛で汽車を下りるとふるえるほど寒かった。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから追分が何時でもあわれに感じらるる。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を浮かべて、ゆるやかに流るるこの沼川を、漕ぎ上る舟、知らずいずれの時か心地よき追分の節おもしろくこの舟より響きわたりて霜夜の前ぶれをか為しつる。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通のわれわれの音楽で使われる音程の数は有限な少数であるのに、実際これからあらゆる旋律、たとえば追分節も生まれればチゴイネルワイゼンも生まれる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔ひがまはり切ると、おんつぁんはいつものやうに凄惨な美声で松前追分を歌ひはじめた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから追分が何時でもあはれに感じらるゝ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下戸の種田君に追分と云ふおはこがあつた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "種田君は追分を唄つた。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "姿も見えないどこかのあまり遠くない所に追分節の長く引つぱつた声が聞えたが、中途でばつたり切れた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "左山中｜道、右桂谷道、と道程標の立った追分へ来ると、――その山中道の方から、脊のひょろひょろとした、頤の尖った、痩せこけた爺さんの、菅の一もんじ笠を真直に首に据えて、腰に風呂敷包をぐらつかせたのが、すあしに破脚絆、草鞋穿で、とぼとぼと竹の杖に曳かれて来たのがあった。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と追分で路が替って、木曾街道へ差掛る……左右戸毎の軒行燈。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し行くと追分の通だ。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は東京駒込追分の坂路に夕日を浴びて汝に水桃を捧げんとする。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も穿鑿をするのではないけれど、実は日数の少ないのに、汽車の遊びを貪った旅行で、行途は上野から高崎、妙義山を見つつ、横川、熊の平、浅間を眺め、軽井沢、追分をすぎ、篠の井線に乗り替えて、姨捨田毎を窓から覗いて、泊りはそこで松本が予定であった。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは地震のあった月の二十九日で、本郷追分から出火して、谷中まで焼き、一方は小石川の水戸邸から出火して、上野湯島天神、聖堂筋違橋、向柳原、浅草茅町、南は神田から伝馬町、小舟町掘留、小網町、それから本所へ飛火して、回向院の辺、深川。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥で帰ると、追分で一生の道が南北へ分れるのを、ほんとうに一呼吸という処で、不思議な縁で……どうも言う事が甘ったるいが、どうもどうも、腹の底まで汁粉に化けた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も小石川白山の上、追分のあたりより、一圓の高臺なれども、射る日の光薄ければ小雨のあとも路は乾かず。",
              "citation": {
                "source": "森の紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理屋萬金の前を左へ折れて眞直に、追分を右に見て、むかうへ千駄木に至る。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一場（山科街道追分近くの裏道。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉公前によう逢うたあの追分けの松の根方に佇んで待って見ても、それかと思うはまぼろしばかり。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五年前まえの八月のはじめ、信濃追分へ行ったことがあった。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて軽井沢につき、沓掛をすぎ、そして追分についた。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い駅に降り立つと、駅員が、「信濃追分！",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗って来た汽車をやり過して、線路をこえると、追分宿への一本道が通じていた。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほのめくは鳩の白羽か、敷石の闇にはひとり盲の子ひたと膝つけ、ほのかにも尺八吹ける、あはれ、その追分のふし。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
