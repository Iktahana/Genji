        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この林からさえ追い出しとけぁいいんだ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、達二が支度をして包みを背負っている間に、おっかさんは牛をうまやから追い出しました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "健二は、慌てゝ柵を外して、十頭ばかりを小屋の外へ追い出した。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はうなずきました、樋口が鸚鵡を持ちこんだ日から二日目か三日目です、今では上田も鷹見もばあさんと言っています、かの時分のおッ母さんが、鸚鵡のかごをあけて鳥を追い出したものです。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ、のら猫の連れていた子猫のうちの一匹がどうしたわけか家の中へはいり込んで来て、いくら追い出しても追い出してもまたはいって来て、人を恋しがって離れようとしない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三男は子供のときから手癖が悪いので、おまきの方から追い出してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速おまきを呼びつけて、長屋じゅうの者が迷惑するから、お前の家の飼い猫をみんな追い出してしまえと命令した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は早速追い出します」　しかし今まで可愛がって育てていたものを、自分が手ずから捨てにゆくには忍びないから、御迷惑でも御近所の人たちにお願い申して、どこかへ捨てて来て貰いたいと彼女は嘆いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿本が入れられたのは支那人を追い出した、支那人への施療病室だった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして他の瑠璃がそのホラへはいって行くと喧嘩をして追い出してしまうと云う。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の女房もひどい奴でしたが、二番目のは、なおたちが悪く、三番目のは、逃げるどころか、かえって私を追い出しました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは見込み違いをしていた」と言って、その僧を追い出し、住まわしていた庵室まで穢らわしいと言って焼き払いました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く追い出しておしまいなさい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）なにしろ気味が悪いから、早く追い出して頂戴よ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おまえは無暗に追い出したが、おれは何だか気の毒でならねえ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊めて遣ってもいいものを、怖い怖いと無理に追い出してしまって、あの人も今頃は山道で困っていなさるだろう。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ追い出して、新しいのに変えようと思っていたところだ」　そして急に起ち上ると、「――どうだ、皆んなホールへ行かんか。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――なぜ、鈴子を追い出して、その代りに泊ったりするんだろう」　君勇が芸者の意地から、小郷という所謂「上客」を、鈴子から奪った――と、一応考えられた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、追い出して、新しく若い細君を貰うには、さすがに永年つれそうて来た真紀子には未練があった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客様も何も皆追い出してしまえ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　祖母を追い出してから、末弟は、おもむろに所謂、自分の考えなるものを書き加えた。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に彼等は、それの透明を暈らすところの、すべての主観的なもの、情感的なものを追い出してしまう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペリカンを追い出した余は其姉妹に当るオノトを新らしく迎え入れて、それで万年筆に対して幾分か罪亡ぼしをした積なのである。",
              "citation": {
                "source": "余と万年筆",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あの若い看護婦が自分を怖えさせるため、京子の眠るあの部屋から斯んな処へ追い出したのではないかと突然の憤りと困惑に陥った。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、直ぐ追い出しちまうにはあんまり可愛ゆい娘でしたからな。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相談はそれからのことだ」　とにかく、ここにいてはまずいと、無理やり女を追い出した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の方では、おれを追い出してやったと、思っているらしいが、違う。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれはかねてお見覚えのある女鳥王のお持物でしたので皇后はにわかにお顔色をお変えになり、この女にばかりはかしわの葉をおくだしにならないで、そのまますぐにご宴席から追い出しておしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大あわてにあわてて、さっそくみんなを残らず追い出したうえ、意外なところでお見出し申した、意富祁、袁祁のお二人を左右のおひざにお抱え申しながら、お二人の今日までのご辛苦をお察し申しあげて、ほろほろと涙を流して泣きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはおまえを、この国からおいだしてしまったが、それでもおまえは、わたしのねどこから、いやなつみのまぼろしを、歌でけしてくれた。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
