        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どこかの家から、絃歌の声が水面を渡って、宇治川のお茶屋にでも、遊んでいるような気がする。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶屋のボンボリの仄白い光の中から、芝居小屋にかかげられた幟の列を俯瞰する。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々、お茶屋さんだの、待合さんへ、そう云っておいでって云うんでしょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくれた座敷は、若い妓の背後に控えて、動く処は前へ立って目立たないように取り廻す、というのであるから、お茶屋の蔵の前に目の光る古狸から、新道の塒を巣立ちの雛児まで、「ああ、いい姉さん。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、ええ、別に秘すではござりません、（これからお茶屋へ行って一口飲むから、待ってるからきっとおいで。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、何とか云うお茶屋であった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう断念めていた処、その後宴会があって、あるお茶屋へ行くと、その時、しばらく振で顔を見た。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが縁で、……時々、と云っても月に二三度、そのお茶屋で呼ぶとね、三度に二度は来てくれる。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年の間｜熟と目を塞いでいて、お茶屋の二階で目を開いて、ドキドキする胸を圧えるのがその仕儀なんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶屋も懸っておりまするで、素麺、白玉、心太など冷物もござりますが、一坂越えると、滝がござります。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、じゃああのお茶屋の姉さんかい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川に気のいいお茶屋があると云つては、いろいろの友達にも紹介した。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾にして置いて、それをお茶屋へ引つぱつてあるけるとでも思つてゐるんだらう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして毎晩のやうにお茶屋さんでせう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな間柄になつて居るとまでは見破ることの出来ないお茶屋の女中や朋輩芸者は「あやちやんは利口ものだ」と云つて感心すると同時に「松村の旦那はちつとも御存じないのかしら」と云ふ様な目付で、男の顔を気の毒さうに見て居ることなどもあつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども家業柄――家業は、土地の東の廓で――近頃は酒場か、カフェーの経営だと、話すのに幅が利くが、困った事にはお茶屋、いわゆるおん待合だから、ちと申憎い、が、仕方がない。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の灰やら、犬の骨やら、いずれ不気味なその部落を隔てた処に、幽にその松原が黒く乱れて梟が鳴いているお茶屋だった。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　お茶屋じゃない。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、お茶屋の息子で三高生というのが珍らしいというわけではなかった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば三好はお茶屋に公然とそれが出来る所謂旦那だったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好はそんな君勇を見て、「いやお茶屋へも通さんと、お前を連れて行くのは無理やいうことは判ってるが……」　と寂しそうに自嘲しながら、「――しかし、ごらんの通りすっかり落ちぶれてしもて、お茶屋へ行く金もない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼は「渇しても盗泉の水を飲まぬ」如く、もはや餓えてもお茶屋の飯をくうまいと思っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがにお茶屋の息子だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と低声でたしなめるように云った、（先刻のあんなもの）は――鮪の茶漬で――慶喜公の邸あとだという、可懐しいお茶屋から、わざと取寄せた午飯の馳走の中に、刺身は江戸には限るまい、と特別に夫人が膳につけたのを、やがてお茶漬で掻込んだのを見て、その時は太く嬉しがった。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶屋へ行って、呼ばなくっては逢えないのじゃありませんか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私、十八になれば、京都へいって、お茶屋につとめるの。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お母さまのお知り合いで大きいお茶屋を、しているおかたがあるんですって。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お茶屋というのは、どうも、料亭のようであった。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、――京都では、ゆいしょのあるご立派なお茶屋なんですって。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
