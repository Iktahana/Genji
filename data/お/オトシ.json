        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暫くゆくと自転車を坂の下に落として、自分一人は草を掴めば上れるが、自転車を置いとくわけにもいかずといふ災難者にあつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "商店の赤地に白く染め抜いた幟は影を落としてる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通に詩が整つてゐるといふことは、伝統に頼ることから得られるやうだが、高橋新吉は純粋な良心家で、伝統に頼る事は彼からは堕落としか思へない。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたのは当人ばかりではない、その時余の顔に全く血のけがなくなったのを見て、いっそう気を落としたとこれはあとで話した。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢を座敷のまん中で取り落として洪水を起こしたり、火燵のお下がりを入れて寝て蒲団から畳まで径一尺ほどの焼け穴をこしらえた事もあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんはそれをあんまり悲しんでおうぎ形の黄金の髪の毛をきのうまでにみんな落としてしまいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも心地よさそうに体をくつろげて、あぐらをかいて、火鉢を中にして煙草を吹かしている、六番の客は袍巻の袖から白い腕を臂まで出して巻煙草の灰を落としては、喫っている。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だってこの切断は全くわたしの見落としですもの。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の次第で徳さんの武もついに手をひいて半年余りもたつと、母はやっぱり気になると見えて、どうにかして石井さんを説き落としてくれろと頼む。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物忘れする子なりともいい、白痴なりともいい、不潔なりともいい、盗すともいう、口実はさまざまなれどこの童を乞食の境に落としつくし人情の世界のそとに葬りし結果はひとつなりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも椅子から出たものではなくて、猫が落としたものらしい。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのとき自分が危く涙を落としそうになったのを覚えていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ来ると私はいつも今が今まで私の心を占めていた煮え切らない考えを振るい落としてしまったように感じるのだ。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰を落としたストーヴのように、そんなとき彼女の顔には一時鮮かな血がのぼった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩もとうとう寝床を起きてしまいまして、幸い月夜でもあり、旅館を出て、錯落とした松樹の影を踏みながら砂浜へ出て行きました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくなにか非常に大切なものを落としたのだろう。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそのお婆さんがある日上がり框から座敷の長火鉢の方へあがって行きかけたまま脳溢血かなにかで死んでしまったというので非常にあっけない話であったが、吉田の母親はあのお婆さんに死なれてはあの娘も一遍に気を落としてしまっただろうとそのことばかりを心配した。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばガラス板を平坦な台の上に置いて上から鉄の球を落として放射線形の割れ目を生ずるという場合に、板の厚さや、球の重量や落下の高さを一定にしてみても、生ずる割れ目の線の数や長さは千差万別であってなかなか一定しない。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず病室の長い廊下のはるかに遠いかなたで時々カチャンと物を取り落としたような音がする、それから軽くパタ／＼／＼とたとえば草履で廊下を歩くような音も聞こえる。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日思い切って左の頬をうんと切り落としてから後はこの不思議な幽霊に脅かされる事は二度となくなった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふぐ、きす、かまきり、たつの落とし子などに似た人さえある。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　空中殺人法「神伝流游書」という水泳の伝書を読んでいたら、櫓業岩飛中返などに関する条項の中に「兼ねて飛びに自在を得る時は水ぎわまでの間にて充分敵を仕留めらるるものなり」とか、「船軍の節敵を組み落とし、水ぎわまでの間にて仕留めるという教えはよほど飛びに自在を得ざれば勝利を得る事あたわず。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしデパートの屋上から落とした一枚の鼻紙は決してこの方則には従わないのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の場面でおつたが取り落とした錦絵の相撲取りを見て急に昔の茂兵衛のアイデンティティーを思い出すところは、あれでちょうど大衆向きではあろうが、どうも少しわざとらしい、もう一つ突っ込んだ心理的な分析をしてほしい。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば家出して船乗りになった一人むすこからの最初の手紙が届いたときに、友だちの手前わざとふくれっ面をして見せたり、居間へ引っ込んでからあわててその手紙を読もうとしてめがねを落として割ったりする場面の彼一流の細かい芸は、臭みもあるかもしれないがやはりこの人らしい妙味はあるであろう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいに片付いているべき床の間が取り散らされていたり、玄関の障子が破けていたり、女中が台所で何か陶器を取り落としたような音を立てたり、平生なら別になんでもないことが、その元旦に限ってひどく気になり、不愉快になり、やがて腹立たしく思われて来るのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中などが代わると、どうかするとばかに大きいのや堅びねりのが交じったり、線香の先で火のついたのを引き落として背中をころがり落とさせたりして、そうしてこっちが驚いておこるとよけいにおもしろがってそうするのではないかという嫌疑さえ起こさせるのであった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほてった皮膚に冷たい筆の先が点々と一抹の涼味を落として行くような気がする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも蝶のある種類たとえば Amauris psyttalea の雄などはその尾部に備えた小さな袋から一種特別な細かい粉を振り落としながら雌の頭上を飛び回って、その粉の魅力によって雌の興奮を誘発するそうである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまたみんな申し合わせたように眉毛をきれいに剃り落としてそのあとに藍色の影がただよっていた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
