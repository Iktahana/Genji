        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あなたが怒りんぼうのくせに、じき優しくなるのも、そんな思考の曲折や、性格の変化があなたにあるからですな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「目マルの怒りんぼう。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、あんたの怒りんぼにも私負けてしまふわ。",
              "citation": {
                "source": "或る女",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯者諸君は僕が怒りんぼで、ヤッツケられると大憤慨、何を書くか知れないと考へてゐるやうだけれども、大間違ひです。",
              "citation": {
                "source": "花田清輝論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秋　（心配を押し包んで）あの子はとても怒りんぼだからね。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯者諸君は僕が怒りんぼで、ヤッツケられると大憤慨、何を書くか知れないと考えているようだけれども、大間違いです。",
              "citation": {
                "source": "花田清輝論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎は一層ビービー泣いて、あっこおばちゃんは怒りんぼだからいやだ、怒るからいやだ、とわめいている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそれながら申しあげますわたしはただ息をしている女百万円よりも五十銭しか知らない牛めしは十銭葱と犬の肉がはいってるのね小さくてだるまみたいでよく泣いているおこりんぼ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞうさんはわがまゝで、おこりんぼで、ねずみさんは、おくびやうで、こわがりやでした。",
              "citation": {
                "source": "ゾウ　ト　ネズミ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とし子さんは、おこりんぼでちょっとしたことでも、すぐにいぼをつってしまいます。",
              "citation": {
                "source": "春の日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
