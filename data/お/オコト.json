        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御事情は私が見貫いております。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無名の青年　――くわしくは今が始めてですが、そういうあなたの御事情は前から大分知って居ました――で、あなたは世の中は無常だから、愛までも信じられなくなったといわれるのですか？",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御台所さまの御事でも申し上げませう。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、己亥、晴、将軍家聊か御病悩、諸人奔走す、但し殊なる御事無し、是若し去夜御淵酔の余気か、爰に葉上僧正御加持に候するの処、此事を聞き、良薬と称して、本寺より茶一盞を召進ず、而して一巻の書を相副へ、之を献ぜしむ、茶徳を誉むる所の書なり、将軍家御感悦に及ぶと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に人界不定のならひ、是非も無き御事とは申せ、想ひ奉るもいとかしこし。",
              "citation": {
                "source": "二日物語",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはありませんが、私は、家も無い、何も無い、姐の家に世話になって、それで、日間は親類の舗へ出ているものですから」「他に御事情がなければ、他に御事情があればなんですが、そんなことなら私の方でどうにでもいたしますから」　そう云って白娘子は顔をあげて小婢を呼んだ。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間に並べ有之候御｜位牌三基は、某が奉公｜仕りし細川越中守｜忠興入道宗立三斎殿御事松向寺殿を始とし、同越中守｜忠利殿御事妙解院殿、同肥後守｜光尚殿御三方に候えば、御手数ながら粗略に不相成様、清浄なる火にて御焼滅下されたく、これまた頼入り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某は当時｜退隠相願い、隈本を引払い、当地へ罷越候えども、六丸殿の御事心に懸かり、せめては御｜元服遊ばされ候まで、よそながら御安泰を祈念致したく、不識不知あまたの幾月を相過し候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何かあなたは、御事情があるようだ、云ってください、御相談に乗りましょう）　女は泣くのみであった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にも深い御事情はわかりませんが、貴方の伯母様ですね。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は伯母様からお電話がかかりまして、銀座のセイロン紅茶店へ参りまして伯父様と伯母様とに、貴方の弟御さんからスッカリ御事情を承りましたが……」「エッ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は父上の御事、鬼三郎ぬしの御事、又は明日をも計り知られぬ身の行末の事など、跡かたもなく忘れ果てゝ此寺に留まり、和尚の心のまゝに身を任せつゝ、世にも不思議なる年月を送り侍りぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗全雀躍して是を迎えて奉仕したと云うが、詳しい御事蹟は記録にないが、大衆文学の主人公としては、面白い存在ではないか。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この聖徳太子の御精神と御事業を継承して、大化の改新を断行されたのが、中大兄皇子である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の著書「玉くしげ」に、　凡て天下の大名たちの、朝廷を深く畏れ、厚く崇敬し奉り玉ふべき筋は、公儀の御定めの通りを、守り玉ふ御事勿論也。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに朝廷は、今は天下の御政を、きこしめすことなく、おのづから世間に、遠くましますが故に、誰も心には、尊き御事は存じながらも、事にふれて、自然と敬畏の筋、等閑なる事も、無きにあらず。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑本朝の朝廷は、神代の初めより、殊なる御子細まします御事にて、異国の王の比類にあらず。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）されば一国一郡をも治め玉はん御方々は、殊更に此子細を御心にしめて、忘れ玉ふ間敷御事也。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何かあなたは、御事情があるやうだ、云つてください、御相談に乗りませう、）　女は泣くのみであつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはありませんが、私は、家もない、何もない、姐の家に世話になって、それで、日間は親類の鋪へ出ているものですから」「他に御事情がなければ、他に御事情があればなんですが、そんなことなら私の方でどうにでもいたしますから」　そう言って白娘子は顔をあげて婢を呼んだ。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジエンナロ進み近づきて、さては此｜家あるじこそは、土地に匹儔なき美人なりしなれ、疲れたる旅人二人に、一杯の飮を惠み給はんやと云へば、いと易き程の御事なり、戸外に持ち出でてまゐらせん、されど酒は只だ一種ならでは貯へ侍らずと笑ひつゝ答ふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜、身に誤りのなき事は後日に相知るゝ御事なり。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日に相知るゝ御事、又御枕のうち身の曇り去るとは處女膜が彼の御ン事に御寵愛の其夕べまで嚴存せしを指たのだ）。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "御事情はどんなであろうと、この形になっては仕方がありません。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……園さんに、おなごりのおことづけまで申しました。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おことばまことに畏くて、何とお答へいたしていゝか、とみに言葉も出でませぬ。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか先生からペンネン先生へお許しの出るようおことばをください。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、年少の読者にも読みやすいように、改行を多くしたことを一言おことわりしておく。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども見世物になることだけはおことわり致します。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北さんが、せっかく連れて来て下さるというのに、おことわりするのも悪いと思って、私や園子までお供して来て、それで北さんにご迷惑がかかったのでは、私だって困るわ。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
