        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "純潔な処女をこの一角の怪獣の棲家へ送り込むと、ウニコールがすっかり大人しくなって処女の胸に頭をすりつけて来る。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、こういう変異の各相の中に未来の好適種の可能性が存するとすれば、われわれはむしろこの際できる限りの型式のヴェリエーションを尽くして選良候補者のストックを豊富にして、それらを生存競争の闘技場に送り込むのも時宜に適するものではないか、ということである。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに西南の戦雲が、愈濃厚になって来たので、県当局でも万一を慮ったのであろう、頭山、奈良原を初め、健児社の一味を尽く兵営の中の営倉に送り込むべく獄舎から鎖に繋いで引出した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ仕事はあふれ返っているのだから、使う側はどんどん機械にカードの束を送り込む。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワークスを日本市場に送り込むにあたって、古川はかつて自分自身をパーソナルコンピューターへと引き寄せた夢を16ビット・マシンから奪い取り、返す刀でソフトウエア業界の側からはじめて家電に切り込もうとしているのではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コミュニケータにまとまった情報を送り込むとき、常識人はパーソナルコンピューターから入力して渡す。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにも知らない手伝いの連中は家主の酒屋にことわって、お俊の家財をどしどし積み出して、駒形の引っ越しさきへ送り込むと、ここにもお俊は来ていない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、幾たびか蘇易の門内へ野獣の肉を送り込む者があった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "路地のなかまで送り込むと、その門口には一人の女が人待ち顔にたたずんでいた。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全な所に送り込むまではいったんお引き受けした手まえ、気がすまないといい張った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の仕事は犯人を正義の法廷へ運ぶのであって、失恋の男女を結婚の聖壇へ送り込むのではない」「犯人をきめるのは論理的帰納法によらねばならぬ。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山で採った松茸が将軍の口へはいるというのですから、その騒ぎは大変、太田の金山から江戸まで一昼夜でかつぎ込むのが例になっていて、山からおろして来ると、すぐに人足の肩にかけて次の宿へ送り込む。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人がお角に頼まれて、島田の死骸を入れた早桶をかついで、押上辺の寺へ送り込むつもりで、日の暮れがたに出て行くと、あいにくに横網の河岸で多吉に出逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令先について居るたまが金むくであろうとも、二米のゴム管を十二指腸へ送り込む芸当は優美にして　快適な至芸ではない。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は、あの百姓馬子等は速かに變遷するこの地の季節をこの市街に送り込む神ではなかつたかと思ふ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "）渠、百姓馬子は　速かに　変遷する　季節をこの　静かな　蔭の多い、外国じみた　市街に　送り込む　神の　様だ。",
              "citation": {
                "source": "札幌の印象",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝統的な校技としてのサッカー、毎年二〇人前後は卒業生を東京大学に送り込む学力レベルの高さ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして既存の社会の中にいる会員はできるだけ多くの人を特講に送り込むように努め、ヤマギシズムによる個人の変革を連鎖反応的に起こしていくことで、実体的に組織、社会を変革してしまおうとする道である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙テープをテレタイプに読ませて翻訳プログラムを送り込むと、アルテアからの反応が返ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "可能性のある製品を自らの目で選び取って日本に送り込む仕事にも、大いに魅力があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つのスイッチを上下させてプログラムを入力し、数字を送り込むと、マシンはランプを点滅させて計算の結果を示し、コンピューターとして確かに動いて見せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、大石とそんな話をしている矢代の周囲では、塩野と速水とが、中国へ送り込む各国の武器会社の模様を語っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹の順子の友達たちでは、その家の玄関に送り込むまで全部佳一の責任であった。",
              "citation": {
                "source": "ヴァリエテ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、その１から４までのものと云うのは、最後に上った濛気をある一点に送り込む――詳しく云えば、それに一つの方向を決定するために必要だったのだよ」「なるほど、それが虹を発生させた濛気か」検事は爪を噛みながら頷いた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを死の門に送り込むには、十分すぎるほど十分な証拠を必要とする。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きているうちに、柩に這入る――物好きな市民と、新聞社の自動車の追跡を避けて、無事に警察へ送り込むための、ラッセル判事の大苦心なのだった。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太郎を家へ送り込むと、紫錦は舟を漕ぎ返した。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、それでは加賀屋の倅を、加賀屋の金蔵へ送り込むんで」「うん。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この緊張した室に、ふくよかな微笑みをおくりこむ、あゝ快き初夏なるかな。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーガス大佐は、その河々の水を引いて幅五百フイート、長さ七マイル、海面から八十五フイートある水路を作り、下の方へ三区劃の水門をこしらへて、船がその中へはいると、水をふやして、つぎのたかい水面へおくりこむといふ仕組みにして、たかい水路をもらく／＼と通過させることに成功しました。",
              "citation": {
                "source": "パナマ運河を開いた話",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
