    "definitions": [
      {
        "index": 1,
        "gloss": "large, bald-headed monster",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "古寺の大入道や一本足の傘の化物などは、たいてい酒飮みの豪傑のために無邪氣な舞ひをごらんに入れて以て豪傑の乙夜丑滿の無聊を慰めてくれるだけのものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰭一つ動かすときは、おそらく、水紋が一つ描かれ、水楊の葉が一枚散り、谷の中には大入道のような雲がぬうっと立ち昇って、私たちを包んで、白くしてしまうときであろう。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大入道の団栗目は、はじめ死んでおった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、揺れません地震でござりましたもの、いくらでも荷は出せますが、しかしその荷物を投り出していた方が、白い浴衣を着た、見上げるような大入道だったと、申して、例のどんよりした薄明じゃござりますし、ちょうどその時分、どこからともなく衣類や鞄などが降った最中、それを見たものが、魔ものじゃと申します。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大入道の眞向に寢て居た男は、たわいなく寢ながら、うゝと時々苦しさうに魘された。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ら顔の大入道の、首抜きの浴衣の尻を、七のずまで引めくったのが、苦り切ったる顔して、つかつかと、階を踏んで上った、金方か何ぞであろう、芝居もので。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路の長屋の赤い燈に、珍しく、大入道やら、五分刈やら、中にも小皿で禿なる影法師が動いて、ひそひそと声の漏れるのが、目を忍び、音を憚る出入りには、宗吉のために、むしろ僥倖だったのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十「おい、出て来ねえな、おお、大入道、出じゃねえか、遅いなあ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、件の三ツ目入道、どろどろどろと顕れけり　　　　　　　十三　樽を張子で、鼠色の大入道、金銀張分けの大の眼を、行燈｜見越に立はだかる、と縄からげの貧乏｜徳利をぬいと突出す。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「紅蓮、大紅蓮の地獄に来って、」と大入道は樽の首を揺据えた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪女となっての、三つ目入道、大入道の、酌なと伽なとしょうぞいの。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば大入道のような怪物が黒い衣服の裳を長く※いて、太い片腕を長く突き出したような形で、徐に北の空から歩んで来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "古寺の大入道や一本足の傘の化物などは、たいてい酒飲みの豪傑のために無邪気な舞ひをごらんに入れて以て豪傑の乙夜丑満の無聊を慰めてくれるだけのものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜打死はしたが、相国寺の戦に敵の総帥の山名宗全を脅かして、老体の大入道をして大汗をかいて悪戦させたのは安富喜四郎であった。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……描ける花和尚さながらの大入道、この人ばかりは太ッ腹の、あぶらぼてりで、宵からの大肌脱。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に一体の大入道、面も法衣も真黒なるが、もの陰より甍を渡り梢を伝うがごとくにして、舞台の片隅を伝い行き、花道なる切穴の口に踞まる。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人すっと座を立ち、正面、鼓の緒の欄干に立ち熟と視る時、図書、雪洞を翳して高く天守を見返す、トタンに大入道さし覗きざまに雪洞をふっと消す。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大入道、大手を拡げてその前途を遮る。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書扇子を抜持ち、大入道を払い、懐剣に身を躱し、薙刀と丁と合わす。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、どうした、どうした」と、云って声をかけると、僕はやっと我にかえったように起きあがって、「夢であったか、今大入道が飛び込んで来て、私奴の上にあがって、ぐいぐい押しつけますので、呼吸が出なくなりました」　と、云ってまだ恐ろしそうにきょろきょろしていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になって作平は源之丞の家へ往って、起きて出て来たばかしの源之丞の顔を見ると、「昨夜はありがとうございました、其の時拝借した提灯は、松原で大入道に逢いまして捨ててかえりましたから、これから往って探して来ます、どうか暫くお待ちを願います」と云った。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻も大きければ、口も大きい、額の黒子も大入道、眉をもじゃもじゃと動かして聞返す。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『少いものを唆かして要らぬ骨を折らせるな、娑婆ツ気な老爺めが、』と二人の背後にぬいと立つた……　苔かと見ゆる薄毛の天窓に、笠も被らず、大木の朽ちたのが月夜に影の射すやうな、ぼけやた色の黒染扮装で、顔の蒼い大入道！",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸が化けたり、狐が化けたり、大入道が出ましたなんて、いうような、その事でございます。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜海岸で投網を打っていると大入道が腰の籃を覗きに来た。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対側の入口に近い処に、全身を繃帯で真白に包んだ、スバラシク巨大な大入道が、腰をかけていた。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマートな長身の若紳士が、真白い大入道に抱き付かれて、半狂乱に暴れている光景……それを通じてわかる白入道の超人的な怪力と、血も涙もない冷静な怒り……見ている連中は石のように固くなってしまった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間を押し分けた制服の巡査が、肩を怒らして這入って来たが、白い大入道に抱きすくめられて血を吐いている人間の姿を見ると、「アッ」　と云って棒立ちになった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて本堂の正面の格子扉を音荒らかに開きたる者を見れば、年の頃五十には過ぎしと思はるゝ六尺豊かの大入道の、真黒き関羽鬚を長々と垂れたるが、太く幅広き一文字眉の下に炯々たる眼光を輝やかして吾を見上げ見下す体なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
