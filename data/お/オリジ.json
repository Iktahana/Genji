        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山猫大明神さまのおぼしめしどおりじゃ。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも鳥に生れてただやすやすと生きるというても、まことはただの一日とても、ただごとではないのぞよ、こちらが一日生きるには、雀やつぐみや、たにしやみみずが、十や二十も殺されねばならぬ、ただ今のご文にあらしゃるとおりじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、それこそ、筋書どおりじゃないか。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうとも、其のとおりじゃ」松蔵を見て、「松蔵、判るか」　松蔵にもおぼろげながら其の意は判った。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大弐の夫人は、私の言ったとおりじゃないか。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのほうどもも聞いてのとおりじゃが、権右衛門どのの右乳下に卍のいれずみのあったことを、だれぞ存じおるか」　すると、待ってましたというように、魚勘の若い者が、威勢よくいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとも不面目しだいな仕儀でござるが、老骨一期の願い――このとおりじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとおりじゃ」　いうと、老武家は真実面目なさそうに、ところどころ痛々しげな霜の読まれるこうべを深々とうなだれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽吉夫婦は、そちのにらんだとおりじゃぞ」「えッ、じゃ、やっぱりご亭主が嫁さんで、お嫁さんがご亭主だったんですかい」「そのとおりじゃ」「いくら欲の皮がつっ張っていたからのことにしたって、あきれたものだね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、右門はすましたもので、にやにや笑いながらあとへついていくと、べつに鋭い観察を下すようなそぶりも見せずに、敬四郎のうしろからちょいと顔を出して、お検視がすまないためまだそこにひっころがしたままの二つの仏を、ほんのいっぺんどおりじろりと検分いたしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "にらんできたとおりじゃったな」「え？",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いちいちみな聞いてのとおり、わしに述べたのもそのとおりじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "応急の処置もまた、小娘に似合わずあっぱれであったのでな、わしもことのほかかわいく思い、采女に言いつけ、このとおりじゅうぶんに見張りをさせて、密々そちのところへ急使を立てたのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そのとおりじゃ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は近し、血によごれた匕首はむくろのそばに捨ててござるし、品はまさしくお駒の品でござるゆえ、下手人をこの女と疑うに無理はござらぬが、しかしながら肝心の傷がご覧のとおりじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かくのとおりじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "儂の想像していたとおりじゃった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病なような白い眼が、おりおりじろりと父親の方へ注がれた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なるほど、お初の申すとおりじゃ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "折合（をりあひ）土佐幡多　　　折木（をりき）磐城楢葉　　　折茂（をりも）陸奥上北　　　折浜（をりのはま）陸前牡鹿此ほかにも、織笠（をりかさ）陸中東閉伊　　　織島里（おりじまがり）肥前小城　　　織豊（おりとよ）尾張愛知などあるが、織笠の折笠と同じ語らしいものゝ外は、其意をたどる事も出来ぬ。",
              "citation": {
                "source": "折口といふ名字",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋でもそのとおりじゃ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤んぼがいなくたって、このとおりじゃないか……」「そんな言いわけは聞かないよ、赤んべえだ。",
              "citation": {
                "source": "死児を産む",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの創案した防腐剤の偉力は、このとおりじゃ。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君のいうとおりじゃ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、あなたのいうとおりじゃ、わしはあの子をかあいがっているが、がまんのならぬほどわしをじらすようなこともする。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "新五兵衛は娘のおとくが孝助に恋患いしているので、飯島まで孝助を貰いにやってきたのであるが、この新五兵衛のいかにもそそっかしい好々爺ぶりも春のやの賞讃しているとおりじつによく描かれている。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六｜畳の行燈の下に、机の上から投げ出されたのであろう、腰の付根から下だけを、幾つともなく描いた紙片が、十｜枚近くもちらばったのを、時おりじろりじろりとにらみながら、薬罐の湯気を、鼻の穴が開きッ放しになる程吸い込んでいた春重は、ふと、行燈の芯をかき立てて、薄気味悪くニヤリと笑った。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうじゃ、山伏、そのとおりじゃ、これこそ錦の御旗なのじゃ。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おおいかさまお言葉どおりじゃ」　と、宮家の御首級を胸に抱き、両手に捧げていた理智光院も云った。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
