[
  {
    "uuid": "82a5043a-267d-5f2c-93f1-03b5c15575ad",
    "entry": "お喋り",
    "reading": {
      "primary": "おしゃべり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chattering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お喋りという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお喋りの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お喋りを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお喋りという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お喋りの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お喋りは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お喋りの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お喋りと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お喋りは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お喋りはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お喋りの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お喋りの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お喋りが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お喋りを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お喋りのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お喋りに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お喋りの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お喋りの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お喋りは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お喋りの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なんだい、無慾だの何だのと悟り顏なんかしてゐても、相手が若い女だと、すぐもうわくわくして、聲まで變つて、ぺちやくちやとお喋りをはじめるのだからいやになります。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのテーブルにもアペリチーフの杯を前にした男女が仲間とお喋りするか、煙草の煙を輪に吹きながら往来を眺めたりしている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喬はその醜い女とこの女とを思い比べながら、耳は女のお喋りに任せていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はそのお婆さんからはいつも少し人の好過ぎるやや腹立たしい印象をうけていたのであるが、それはそのお婆さんがまたしても変な笑い顔をしながら近所のおかみさんたちとお喋りをしに出て行っては、弄りものにされている――そんな場面をたびたび見たからだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その皿の數ほどの頁、そしてリフアインされたお喋り。",
              "citation": {
                "source": "『亞』の回想",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お喋りね」「…………」　鶴雄は半泣きの顔をした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゃないんですか」　信吉はお喋りではなかったが「権威」というものに挑戦する時は、思わず知らず調子づくのだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな無駄なお喋りを、信吉がペラペラと続けていたのは、実は薄井を本来の俗物の地位まで、自分と共にひきずり下したいという天邪鬼からであった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだい、無慾だの何だのと悟り顔なんかしてゐても、相手が若い女だと、すぐもうわくわくして、声まで変つて、ぺちやくちやとお喋りをはじめるのだからいやになります。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、あの骨董屋の但馬さんが、父の会社へ画を売りに来て、れいのお喋りを、さんざんした揚句の果に、この画の作者は、いまにきっと、ものになります。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝お帰りの事も、ございましたが、私は別に何とも思っていないのに、あなたは、それは精しく前夜の事を私に語って下さって、何先生は、どうだとか、あれは愚物だとか、無口なあなたらしくもなく、ずいぶんつまらぬお喋りをはじめます。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、ほんとに、お喋りになりました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせあの弟はお喋りだから」　わたくしは逃れようもなく、「えゝ」と素直に答えました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分この話もお喋りの弟からあなた方は聞いたでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あら、何というお喋りの弟なのでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分勝手なお喋りもしました。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は実は大変な鬱血漢でしたよ」「割合いに刺戟的な方だと思うわ」「ばあやのお喋りがはいらないんで、今日はあなたがよくお話しになる、僕の本望だな。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自慢にはならぬが、話が上手で、というよりお喋りで、自分でもいや気がさすくらいだが、浅墓な女にはそれがちょっと魅力だったらしい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それもお喋りな生れつきの身から出た錆、私としては早く天王寺西門の出会いにまで漕ぎつけて話を終ってしまいたいのですが、子供のころの話から始めた以上乗りかかった船で、おもしろくもない話を当分続けねばなりますまい。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　顔を赤らめた圭子の、お喋りはしていても、どこか初心なところのある容子に、準之助は好意を感じて、ニコニコ笑っていると、圭子はまた喋り出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」準之助が、大人しく聴いているのをよいことにして、どこまで続くか分らないお喋りであった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、お姉さま、お喋りだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体この星の人は……」年を聞いて丙午だと知ると、八卦見はもう立板に水を流すお喋りで、何もかも悪い運勢だった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうのとりは長い赤い脚で歩きまわりながら、母親から教わった妙な言葉でお喋りをしていました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の家鴨達は、こんな、足の滑りそうな土堤を上って、牛蒡の葉の下に坐って、この親家鴨とお喋りするより、川で泳ぎ廻る方がよっぽど面白いのです。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなお喋りをしていますと、突然空中でポンポンと音がして、二｜羽の雁は傷ついて水草の間に落ちて死に、あたりの水は血で赤く染りました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄様、ずゐぶんお喋りをしてお笑ひにならないで下さいまし。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお喋り男は大きな声で叫んだ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお喋り男は雇はれるとき、主人との約束で、自分のことはしやべつてはいけない事、果樹園の主人が伝へてよいと許したこと以外にはしやべれない事になつてゐた、彼は自分のことは唖のやうに黙つてゐなければならなかつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水が引いてから主人はお喋り男の尻を撫でてやつて『いや御苦労々々』といつて褒美の金一封を渡した上、新聞に勇士らしくかきたてさせたのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
