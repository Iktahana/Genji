        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けふは、故郷の姉上から、お餅をこつそり送つていただきました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と四郎が笑って、「紺三郎さん、僕らは丁度いまね、お餅をたべて来たんだからおなかが減らないんだよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たち行くんならお餅を持って行っておやりよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　四郎とかん子はそこで小さな雪沓をはいてお餅をかついで外に出ました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお餅をみなさんであがって下さい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紺三郎はお餅を持って向うへ行きました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「堅雪かんこ、凍み雪しんこ、硬いお餅はかったらこ、白いお餅はべったらこ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　幕の横に、「寄贈、お餅沢山、人の四郎氏、人のかん子氏」と大きな札が出ました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉と杉作が、土曜の午後に、学校から帰ってくると、そのお餅を、町の克巳の家にくばっていくことになりました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもうきのう、お餅をつくっているときから、ふたりがおかあさんにたのんで、かたく約束しておいたことです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんが、お餅のはいった重箱を、風呂敷につつんでいるとき、松吉は、「ねえ、おっかさん、電車に乗ってっても、ええかん。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小平さんは、ともかく、お餅をいただいておこうといって、おくへはいっていき、カタンコトンと音をさせていましたが、やがて、からの重箱を、また風呂敷につつんで出てきました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――なま焼けのお餅を食べさせる娘がどうして純なの、あなた」　――まあ聞け、僕はそのとき結婚して居た友人の細君を知って居たんだがね、料理はうまいし家事万端非のうちどころも無いほど切って廻す。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もうお餅なんか焼かないで頂戴。",
              "citation": {
                "source": "餅",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　紺三郎はお餅を持って向ふへ行きました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お餅につけてたべる」　と三吉が答えました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もそれを啜りましたが、お湯のにおいがして、そうして、お餅をたべたら、それはお餅でなく、自分にはわからないものでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "松吉と杉作が、土曜の午後に、学校から帰つて来ると、そのお餅を、町の克巳の家に配つて行くことになりました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはもう昨日、お餅をつくつてゐるときから、二人がお母さんにたのんで固く約束しておいたことです。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんが、お餅のはいつた重箱を風呂敷につゝんでゐるとき、松吉は、「ねえ、おつかさん、電車にのつてつてもええかん？",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小平さんは、ともかく、お餅をいたゞいておかうといつて、奥へはいつていき、カタンコトンと音をさせてゐましたが、やがて、空の重箱をまた風呂敷に包んで出て来ました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こんどは此のおもちやの此処ンところをかう改良して来い！",
              "citation": {
                "source": "玩具の賦",
                "author": "昇平に",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎唇の手術のために入院している幼児の枕元の薬瓶台の上で、おもちゃのピエローがブリキの太鼓を叩いている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の庭には天狗がおもちゃにするというまさかり、かま、太刀などが、散乱している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍る深夜の白い息吐きが――そしてたちまちはげしい自棄の嘆きが荒く飛んで聴衆はほとんど腸を露出するまでに彼女の唄の句切りに切りさいなまれると、其処に抉出される人々の心のうずきはうら寂びた巴里の裏街の割栗石の上へ引き廻され、恥かしめられ、おもちゃにされる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猫のオルガン」が何のことだか分からないが多分おもちゃのことらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　大掃除の午後の路地の交互点、こわれたおもちゃに葱大根の尻尾、空瓶空ボールの交響楽、マルクス、ムッソリニの赤ん坊の夢を買わないか。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時少年の心に、この人生をおもちやにしようとしてゐる、色の蒼い弱々しい小娘に対する恐怖が、圧迫するやうに生じて来た。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生をおもちゃにする気は毛頭ありません。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際自分らの子供の時分に自由党のけんかの頻繁であったころは鍬の柄をかつぎ回ったりまたいわゆる仕込み杖という物騒なステッキを持ち歩くことが流行して、ついには子供用のおもちゃの仕込み杖さえできていたくらいである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
