    },
    "definitions": [
      {
        "index": 1,
        "gloss": "foolish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――私と北原白秋氏とは彼の最初の知己であつた――あまつさへ、私自身しばしば彼の表現を模倣しようとして、愚かな失敗を繰返したことさへある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私の方では、何といふ卑劣な愚かしさだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かにも自分は、その時彼の悲哀について、眞の事情を知ることができなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かさを愛したことがなかったか。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間行事のカタログをひろげ、あれかこれかと迷ふ程愚かな姿もないものである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、賣藥の效能書を、實に信用する愚かな性質を持つて居ります。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな愚かな藝無しどもが、もろもろの藝術の神であるとは、どうしても私には考へられないのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはただ、太宰といふ作家がその愚かな經驗と貧弱な空想を以て創造した極めて凡庸の人物たちばかりである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行ひは愚かで、その考へは分ち難い。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても屋上にこんな燃草をわざわざ載せたのは愚かな設計であった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かな愚かな表情を、院長さんとその園芸家とどっちが頭がうごくだらうといった風の――えい糞考へても胸が悪くなる。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かなことでしょうがこの場合お前さんに民子の話を聞いて貰うのが何よりの慰藉に思われますから、年がいもないこと申す様だが、どうぞ聞いて下さい」　お祖母さんがまた話を続ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この愚かな身の程をわきまえぬ一篇の偶感録もこのくらいにして差控えるべきであろう。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある解釈に従えば、私の偶然に関係した店の主人の仕打ちうや、それに対する私のした事や考えた事なんかは、すべてがただ小さな愚かな、時代おくれの「虚栄心」の変種かもしれない。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚かにも私は、また例の知覚の疾病「三半規管の喪失」にかかったのである。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画に下手な天然色を出そうとする試みなども愚かなことのように思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわれわれ愚かな人間にはそれらの運動が何を意味するか、何を目的としているか全くわからない。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気紛れに箸の先で毛虫をとったりしている自分の愚かさに気が付いた。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわれわれがわずかばかりな文明に自負し、万象を征服したような心持になって、天然ばかりか同胞とその魂の上にも自分勝手な箸を持って行くような事をあえてする、それが一段高いところで見ている神様の目にはずいぶん愚かな事に見えはしまいか。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事柄の落着を出来るだけ速やかにするにはその方がいいと思ってした事ではあるが、後で考えてみると、これは愚かなそして卑怯な事に相違なかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあのお方の愚かなしもべでございます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果として自然に他人のする事が愚かに見え従って自分がだれよりも賢いというような錯覚に陥りやすい。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の頭の力の限界を自覚して大自然の前に愚かな赤裸の自分を投げ出し、そうしてただ大自然の直接の教えにのみ傾聴する覚悟があって、初めて科学者にはなれるのである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙のどこの果てからとも知れず、肉眼にも顕微鏡にも見えない微粒子のようなものが飛んで来て、それが地球上のあらゆるものを射撃し貫通しているのに、われわれ愚かなる人間は近ごろまでそういうものの存在を夢にも知らないでいたのである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかく、こんなはげ山の頂にうさぎが何を求めて歩いているのか、また蜘蛛や甲虫や蝶などといかなる「社会」を作っているのか愚かな人間には想像がつかないのである。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼い主でさえ、噛みつかれぬとは保証できがたい猛獣を、（飼い主だから、絶対に喰いつかれぬということは愚かな気のいい迷信にすぎない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "所詮は、私が愚かなせいでございましょう。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木さんも、目もと涼しく、肌が白くやわらかで、愚かしいところの無いかなりの美人ではあったが、キヌ子と並べると、まるで銀の靴と兵隊靴くらいの差があるように思われた。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてお互い相抱き、慰さめ、励まし、祈り、悲しみ合うことは愚か、同じ処に寝る事さえも出来ない気もちになってしまったのでした。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はもちろん自動車はおろか乗合馬車もなく、また沿岸汽船の交通もなかった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
