[
  {
    "uuid": "3ea7e445-8041-54c9-a283-1766fb4e8755",
    "entry": "愚か",
    "reading": {
      "primary": "おろか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
