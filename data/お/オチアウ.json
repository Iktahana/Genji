[
  {
    "uuid": "da2132e6-79f4-500c-8966-5b3110697588",
    "entry": "落ち合う",
    "reading": {
      "primary": "おちあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
