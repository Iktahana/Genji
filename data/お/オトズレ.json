        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」なぞ云はれゝば、無論直ちに黙りもするが、かといつてそんなこと云つたつて僕に暗い時間が訪れるといふ事実をどうしやうもないんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま教ったばかりのフランスの叙情詩とは打って変ったかかる無学な文句に、勝手なふしをつけて繰りかえし繰りかえし口ずさみながら、れいの甘酒屋を訪れたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と山田君は久しぶりに私の寓居を訪れて、頗る緊張しておっしゃるのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいま友人、大隅忠太郎君から、結納ならびに華燭の典の次第に就き電報を以て至急の依頼を受けましたが、ただちに貴門を訪れ御相談申上げたく、ついては御都合よろしき日時、ならびに貴門に至る道筋の略図などをお示し下さらば幸甚に存じます、と私も異様に緊張して書き送ってやったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、眼光鋭く、気品の高い老紳士が私の陋屋を訪れた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ牛込の瀬川さんを訪れて、私の愚痴を聞いてもらおうかと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和七年の夏金沢を訪れた時、その松が見たかつたが、今は見知らぬ人が借りてゐる家の庭に這入つてゆくわけにも行かなかつたが、家は前面から見た限り、昔のまゝであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はそして、細つそりした女優の下宿を、屡々訪れた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮夜ひそかに、お旦那は、酒飮み爺さんの草屋を訪れ、さうしてあの、月下の不思議な宴の話を明かしてもらつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は、東京府下の三鷹町の、ずゐぶんわかりにくい謂はば絶域に在るので、わざわざ此の家にまで訪れて來るのは、よほどの苦勞であらうと思はれる。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし息子は、父親の神の遥々の訪れをそれと知るや、直ちに翁を家の中へ導き入れ、紹介せたその妻もろとも下へも置かない歓待に取りかかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃彼はソルスベリー卿の実験室を訪れて磁気に関する実験を見せられたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも、その向いの家の表に訪れる浪人がある、後姿（大吉らしい）。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪れて来た日下部典六が、雪枝に何か話して居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は、あなたが再び妾の許を訪れる日を信じていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼女は夫の寝室を訪れた英国の女らしくドアを閉めながら、では、お寝みなさい。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が更けると、米良は陳子文とイサックを伴って電車路からクインス・スタチウの花園の附近にあるマダム・レムブルクの夜の家を訪れる。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテル・マンションには、青銅色の秋が訪れていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の傲がんなこころがすこしの反省もなく、イズモ町の彼女経営の流行品店を素通りして、築地河畔のコルビジェ風のアパートメントの一室を訪れた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になって再びチタ子は私のアパートを訪れてきて、当分、私から離れたくないと言ったのです。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、漸く彼女の生活には貧困が訪れてきた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『若しやお前が‥‥‥』と、さう疑ひ返した時、また私の眼にはあの貞雄君の、呉に去つてから久しく私達の家を訪れない貞雄君の顏が、私がお前のいとこ達の中で一番好きだつた、あの快活な、懷しい微笑を口元から絶やさない貞雄君の、あのあの淺黒い顏が浮んで來たのだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私の部屋を訪れた人は御存じの事だらうがとにかくそれはいつも實にきちんと整頓してゐる。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に映るすべては、秋の訪れ速かな北國の寂しい朝の姿であつた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、興行の折の桟敷、又は従兄弟の住居で、顔も合はせれば、ものを言ひ交はす、時々と言ふほどでもないが、ともに田端の家を訪れた事もあつて、人目に着くよりは親しかつた……　親しかつたうへに、お嬢さん……後の香川夫人は、園のつくる歌の愛人であつた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "弔礼のために、香川家を訪れたものが、うけつけの机も、四つばかり、応接に山をなす中から、其処へ通された親類縁者、それ／″＼、又他方面の客は、大方別室であらう。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日汗水たらして働いた後にのみ浴後の涼味の真諦が味わわれ、義理人情で苦しんだ人にのみ自由の涼風が訪れるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途に金杉の絵師｜某をおとずれて蓮の絵を見る。",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食前の数分間には子供部屋をおとずれている彼を見かけた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
