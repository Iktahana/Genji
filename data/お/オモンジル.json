        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自らを重んじる道では無い。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼儀を重んじると云えども先生の道は常にこれ仁（思いやり）。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで礼と云い楽と云って礼楽を重んじるのであり、仁と云い義と云って仁義を称えるのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽明学は「所得の真」であることを尚ぶ、それなので禅家の印可証明のように承伝を重んじる。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "――体面を重んじるＨ町と小樽の教育会が動き出した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い伝統を重んじること、こればかりが能ではない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学運動について多少とも冷静に客観的事実を重んじる人は、それが従来の民主的プロレタリア文学の読者層をより広く開拓したことは率直にみとめています。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「台湾の伯父さんにお前のことを頼んで置いた――これから先の方針の話でも出た時にだね、お前の意志だけは重んじるようにッて、俺の方でよく頼んで置いた――無論それはお前の自由に任せるッて、返事をしてくれた――」「え――台湾の伯父さんがそう言って下さいましたか――」と節子の声で。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれは政治というものを軽蔑して文化を重んじるという、反政治的ないし非政治的傾向をもっていた、それは文化主義的な考え方のものであった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその教養思想が擡頭してきた時代に高等学校を経過したのであるが、それは非政治的で現実の問題に対して関心をもたなかっただけ、それだけ多く古典というものを重んじるという長所をもっていた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼女等の体躯が強壮であると云う事は、其裡に単に運動を重んじるとか、衣服が活動に便利であるとか申すより以上に深い根原を持つ事を知らなければならないと存じます。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのことに形式を重んじる癖があって、少しでもその点の不足したことは我慢のならぬように思う内大臣の性格であるから、思いやりもなしに婿として麗々しく扱われるようなことになっては今さら醜態で、気恥ずかしいことであると、その懸念がいささか源氏を躊躇させていた。",
              "citation": {
                "source": "源氏物語",
                "author": "行幸",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に身の毛もよだつ物語であるが、これによって、信頼を受けた侍の忠節はもちろんのこと、わが国人がいかに傑作品を重んじるかということが説明される。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は社会の秩序を何より重んじるから、自然に個人を無にしなければならぬ。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分がこのように棲息している種族の知性を論理の国際性より重んじるところは、自分が種族の国際性を愛するからだ」と。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしパリに科学を重んじる精神がなかったら、これほどパリは立派になっていなかったし、これほど自由の観念も発達していなかったよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面静に見えながら気象の強い母は、家系のことでは負け目を感じるのが不快らしく、何より武士道を重んじる心の姿勢は、年とともに母の中から強く感じ、そのために矢代は、父と母との間に立って苦しんだ日も、母の実家へ来る度びに思い起す記憶である。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅でも心の無を重んじるが剣も心を虚くする事を大切としている。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士の重んじる所は、勝敗ではない。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚本を重んじると同様に、大切にせねばならぬ要素が、まだ／＼外にもあるのです。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "来歴を重んじる芸道者流において、三味の組唄に、まづ琉球組――組唄の義――を据ゑたのは、琉球唄の調子に則つたものゝ義で、早く這入つた琉球唄の行はれなくなつて、其替へ唄が行はれ、其が固定したものを元唄ときめたのである。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平明派であり、日常語感を重んじる作家としての子規である。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "政道の軌範としての史書の意味を、重んじる儒学の態度の、輸入せられたのは古い事である。",
              "citation": {
                "source": "日本書と日本紀と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから仏教には昔から合い難き師に合うとか、享け難き人身を享けてとか、百千万劫難遭遇の法を聴くとかいってこのかりそめならぬ縁の契機を重んじるのである。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、彼等のうちで持てるものゝ面子を重んじる工夫が必要なのである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌允　そんなに習慣を重んじるお前でもないじゃないか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは信義を第一に重んじるよう教育されてきたのです」　と、博士はきっぱりこたえた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理よりも、情勢を重んじる」――なんだ、これや……。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "対等の立場で語るといふのはどういふことかといふと、つまりこれは対話の精神を重んじるといふことですな。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
