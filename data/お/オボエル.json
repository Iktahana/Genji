    "definitions": [
      {
        "index": 1,
        "gloss": "to memorize",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すべて技の進歩といふものは、見やう見真似で覚えることから発するのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり思念だけでは足りない、思念と物質とが一緒になつて働いてゐるところとか、その結果を見覚えるとかすることが勘甚なのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あーあ、よく覚えるんですよ。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、神秘を感じて魂の愉悦を覚えるといふことが、私の直観だけのことだとしたら、問題は、何等緊要の事ではなくなるに相違ない。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校で習うことは、誰でも習いさえすれば覚えることであり、一とわたりは言葉で云い現わすことの出来るような理窟の筋道の通ったことばかりであったが、亀さんの鳥や魚の世界に関する知識は全く直観的なものであって、とうてい教わることの出来ない種類のものであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は須臾にして精神のみか肉体までも盛り上る土堆と関聯した生理的感覚を覚える。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつも講演のあとで覚える、もっと話し続けたいような、また一役済ましてほっとしたような――緊張の脱け切らぬ気持で人々に混って行った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根附の中風薬の金看板なぞ見える小さな町だが、今までの寒山枯木に対して、血の通う人間に逢う歓びは覚える。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は文字通りに「味を覚える」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "与えられた知識を覚えるだけではその効は極めて少ない。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十種の実験を皮相的申訳的にやってしまうよりも、少数の実験でも出来るだけ徹底的に練習し、出来るだけあらゆる可能な困難に当ってみて、必成の途を明らかにするように勉める方が遥かに永久的の効果があり、本当の科学的の研究方法を覚える助けになるかと思う。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものを云う事を覚えるのが普通より遅く、そのために両親が心配したくらいで、大きくなってもやはり口重であった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が八度の近視眼鏡を二つ掛ける吾輩は、とう／＼其顔を能く見覚える事も出来なくて終つた。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの珍しい言葉を覚えるために何遍も口の中で、シッタシズム、シッタシズムと繰り返した。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字の方はその意味を覚えるまでの練習を要する代りに、一度覚え込んでしまえばその意味の内容はある程度までははっきり規定されてしまう。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るく鮮やかであった白馬会時代を回想してみると、近年の洋画界の一面に妙に陰惨などす黒いしかもその中に一種の美しさをもったものの影が拡がって来るのを覚えるのは私ばかりではあるまい。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "読んでそういう感じを覚える作家や、本は滅多にないものだ。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉は、そのしてはならぬことを、かげにかくれて反対にやってみせる、それに快よさを覚えるようなたちの男だ。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこれをひいていると、歌の文句は何も知らないのにかかわらず、いつも名状の出来ないような敬虔と哀愁の心持が胸に充ちるのを覚える。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………休むひまに、道具の名前一つでも覚えるようにせい！",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそれに見入っている彼自身がいかに情熱を覚え性欲を覚えるか。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩が現われ、頸が顕われ、微かな眩暈のごときものを覚えると共に、「気配」のなかからついに頭が見えはじめ、そしてある瞬間が過ぎて、Ｋ君の魂は月光の流れに逆らいながら、徐々に月の方へ登ってゆきます。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで二三か月も勉強すればだれでもラッセルとかマルクスとかいう人の名前ぐらいは覚える事ができるのだろう。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の子供を小学校へ入れてやると、いつのまにか文字を覚える算術を覚える、六年ぐらいはまたたくまにたって、子供はいつのまにかひとかど小さい学者になっている、実にありがたいものだと思わないではいられない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾天に散布された星の位置を覚えるのに、星の間を適当に直線で連ねていろいろの星座をこしらえる。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろもうアイスクリームの冷たくないのに屈辱の余味を帯びた憤懣を感じ、タオルの偶然な差別待遇にさえ世に捨てられでもしたような悲しみと憤りを覚えることの可能な年齢に近づきつつあるのかもしれない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きたいほどの自己嫌悪を覚えるのであるが、これを行わないと、たちまち噛みつかれるような気がして、私は、あらゆる犬にあわれな挨拶を試みる。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帰朝以来、甲府に二回遊んだが、これらの人々の郷土愛の熱心さには、いつも若返る力を身内におぼえる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "クねずみはいちばんはじめの一に一をたして二をおぼえるのに半年かかったのです。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うたう歌は、いつも同じなのですが、まだだれも、その歌をすっかりおぼえることができませんでした。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
