    "definitions": [
      {
        "index": 1,
        "gloss": "innocent (esp. of a girl)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だから英仏語ともに未通女の後見として、群聚や公会に趣く老婦をシャパロンと呼ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "操などと、たわいもない、七十になって、未通女だと申したなら、よく守って来たと称められるより、小野の小町だと、嗤われよう。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、人形のよそおいをした、初心の未通女の女が出る。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとこ・をとめなども、壮夫・未通女・処女など古くから当てるが、村の神人たるべき資格ある成年戒を受けた頃の者を言うたのが初めであらう。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとめ・をとこをとめ・をとこには、万葉では未通女・壮夫など言ふ字を宛てるのが、まづ普通の様だが、「通」は男に通婚せぬ義か、精通期に達せぬ事を示すのか、判断し難いと思ふ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯をとこは、性の解放を祭りの当夜から許されるが、をとめは、神の外には逢ふ事が出来ぬ為、をとめと言へば、夫を持たぬ女、処女・未通女と考へられる様になつたのだ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は確に、私の思って居たより清い――未通女的な――ところがある。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌理の細かい真白い顔に薄く化粧をして、頸窪のところのまるで見えるように頭髪を掻きあげて廂を大きく取った未通女い束髪に結ったのがあどけなさそうなお宮の顔によく映っている。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "……処女の、未通女の、お手本じゃ！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゼットは鋸楽師の左の腕に縋っておぼこらしく振舞うのであった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら真底からおぼこな二人は、その吉野紙を破るほどの押がないのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、おぼこい二十歳の青年のように、少女の魅力に悩まされ切っているところがあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は何処までも理髪師らしくない、おぼこな態度で客あしらひをした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは何も知らず、銑太郎なお欺くべしじゃが、あの、お松というのが、また悪く下情に通じておって、ごうなや川蝦で、鰺やおぼこの釣れないことは心得ておるから。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尽王香以、清兵衛を立つるときは、微塵数のパルヴニュウは皆守銭奴となって懺悔し、おいらん王を立つるときは、貞婦烈女も賢妻良母も皆わけしらずのおぼことなって首を俛るるであろう。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならと云って、小切れで肘衝でも縫って上げたら、岡田さんにはおぼこ娘の恋のようで可笑しいと思われよう。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実に興味深い研究対象だ、あのおぼこ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしたとえ古くさくとも、僕にとって新しいことが細かくひとつふたつはあるものなのだが、しかしあのおぼこ当人からは得るところがある。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おぼこならば釣れよう。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおぼこさ……葉子は闇の中で目をかがやかしてほほえんだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にもこんなおぼこな思いが潜んでいたかと思うと、抱いてなでさすってやりたいほど自分がかわゆくもあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあなたが同じ年ごろで、――たいへん美しいというためばかりじゃないと（その時古藤はおぼこらしく顔を赤らめていた）思っています。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『狼』のやうな暗い男女の争闘の代りに、初心な、おぼこな恋の事件のゑがかれてあるのを見た。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだおぼこじゃ、おぼこじゃと思うて、気を許していたうちに、いつのまにか、親の目をかすめまして、それも言いかわした相手がうちの手代の弥吉じゃ、とこのようなことを申しましたのでな、腹が立つやら、情けないやらで、むやみとがみがみしかりつけたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どんなにやかましい注意をうけても、今度が初めての店出しというおぼこ娘のお染には、どうしていいかちっとも見当がつかなかった。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女あふるるばかりの愛嬌のある顔に、しかもおぼこな処があつて、かかる料理屋などにすれからしたとも見えぬほどのおとなしさが甚だ人をゆかしがらせて、余は古洲にもいはず独り胸を躍らして居つた。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "達磨返し、しゃこ結び、世帯おぼこ、三ツ葉蝶、新蝶大形鹿子、新蝶流形、新蝶平形、じれった結び、三ツ髷、束ね鴨脚、櫛巻、鹿子、娘島田、町方丸髷、賠蝶流形、賠蝶丸形、竹の節。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じれった結び」とか、「世帯おぼこ」などというのは如何にも気のせかせかした、また世帯というものに重きを置いている都会生活者のつけそうな名前で、髷の形を知らぬものでも名前をきいただけで、その形が目に浮かんで来るようである。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "野桜と桜桃の樹のおぼこらしい叢林は、その根をおづおづと冷たい泉のなかへ伸ばしてゐるが、時々葉ずれの音を立ててざわめくのは、夜風といふ浮気ものがちよいちよい忍び寄つては接吻するのに、腹を立ててゐるのでもあらうか。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "村民は誰れ彼れなしに村長の姿を見ると遠くから帽子をとるし、ほんのおぼこの娘つ子でも、こんにちはと挨拶をする。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
