        "examples": {
          "standard": [
            {
              "text": "お臍について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お臍がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お臍というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお臍の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお臍が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お臍を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お臍の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お臍はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお臍があります。",
              "source": "幻辞"
            },
            {
              "text": "お臍は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お臍について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお臍の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お臍の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお臍が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お臍についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお臍は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお臍について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お臍という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお臍の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お臍を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それから赤い湯もじをお臍の上までマクリ上げると、大きな真白いお尻を振り立てて、妙テケレンな踊りをおどり出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、蜆の肉は、お臍みたいで醜悪だ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お蝶さま、はい、鯔のお臍」　わたくしは名前が面白いので、くゝと含み笑いしながら、喰べます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こどものとき小学校へ送り迎えをして呉れたり、わたくしの好きな鯔のお臍を焼いて呉れたり、母がわたくしを乞食の裔と罵るのを庇って呉れたり、想い出せば親切だったと思うことも沢山あります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小舟がゆらげばお臍がゆらぐ、お臍がゆらげば小舟がゆらぐ、いつまでもいつまでも恐ろしく、いつまでもただ一人。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田によると「成るべく女のお臍から下の方へ入れると安全だ」った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "素ツ裸になつてお臍の穴から睾丸まで見せ合ふやうにならなくつては。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、太郎のお臍の上にも母がちよんと、とまるよ」　太郎はわかるふうだつた。",
              "citation": {
                "source": "檀一雄「リツ子・その死」",
                "author": "――創芸社刊――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴方その身態は何ですね、襦袢の綻びからお臍が覗いてるぢやありませんか。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその子どもはしじゅう炉にばかりあたって、腹をあぶりながら、あまり臍ばかりをいじくっているので爺は火箸でちょいとお臍を突いてみると、そこからぶつりと金の小粒がこぼれ落ちた。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いとも強いとも、どんなにおれは強いんだと老婆はますます両足を踏ん張ると、腹もお臍もみな表わして人間がみたらそれこそおかしい態となりました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「それでもお臍が大きいやろ。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "う――んと気張ると、お前の胃みたいにごぼごぼお臍が鳴るのや。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんちゃら可笑しくって、お臍でお茶を沸かしましたがね。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、家の参右衛門のなまけ癖が、廂からの日ざしを受けたお臍のあたりにへこんで見えて、垢を擦る。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お臍までとゞくやうなカレツヂ・ネクタイをして、角帽なんぞ被つた姿で、村の娘を釣るといふのですから、大したものです。",
              "citation": {
                "source": "谷間からの手紙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤な唇を女のようにニッコリさせつつ、無言のまま、ウドン粉臭いパンの固まりを私のお臍の上に乗っけた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その新しいパンの固まりを、お臍の上に乗っけたまま、ソーッとあおのけに引っくり返った。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴を穿きかけたまま妾の処へ駈け寄って来て、妾のお臍の上から辷り落ちそうになっているパンの固まりをシッカリと両手で押え付けた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは英語の navel、お臍って字から訛ってきたのよ。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、ここんとこが、お臍のようでしょう。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女史は横目で妾のお臍のあたりを睨みながら、あたり憚らず驚きの声を放った。",
              "citation": {
                "source": "三人の双生児",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくお臍も水中にかくれた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は、「あのお婆さんは、今夜きっとその財布をお臍にあてて寝るんだろうよ。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時から女中はあの人の事を「お臍のお札」と云う名にして居た。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お臍の下と顎の下で大地がゆら／＼ゆれてグアッといふ風の音にひつくりかへされるやうな気がした、砂をかぶつたのはそれからだ。",
              "citation": {
                "source": "続戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これをお臍の上にすえるんだよ。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お臍の上に味噌をのっけては。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だって、お臍の上に味噌じゃあ……。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのおなかの真ん中より少し下に梅の花の様なおへそが附いている。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
