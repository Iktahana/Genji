    "definitions": [
      {
        "index": 1,
        "gloss": "opening (a new store, golf course, runway, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
