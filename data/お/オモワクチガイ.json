          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一本気で、ぷんぷん怒っている師匠も我を折って、「日本人と毛唐人との思惑違いというのなら話は分る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "店初まっての大作をしたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれが全く思惑違いとなったので、いつものさっぱりした気性にも似ず、ひどくそれを苦になすって、こちらでは忘れた頃になっても、まだ済まなかった、済まなかったとおっしゃる、と母が笑っておりました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは服部先生の思惑違いであって、余はやはり碧梧桐君などと共に二高――仙台――に行く事に極った。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、平次の目算にも、とんだ思惑違いがありました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "殺され半蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼姿で石井依右衛門を夢中にさしたという女の、ザンバラ髪もまた一つの魅力で、この女から美しさを奪うために、伸びかけた髪の毛を切ったとしたら、曲者は大変な思惑違いしたことになるでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは双方の思惑違い、勘違いでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は思惑違いをした。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
