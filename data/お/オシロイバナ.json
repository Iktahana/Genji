          ],
          "literary": [
            {
              "text": "おしろい花のさくほとり、しんねこの幽かなる音を泣くべけれ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の彼岸前後になると、懐妊した女の乳のように、おしろい花の実が黒く色づき初める。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉は並木と二人で墓場へゆき、ジャノメ草やおしろい花をとってきて八津をまつった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
