[
  {
    "uuid": "229bffa0-8927-5e59-bce6-4f3816c47ec6",
    "entry": "及び難い",
    "reading": {
      "primary": "およびがたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
