        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」清子「間もなく、発令があると思うんだけど……初枝さんのお見合い、明日でしょう？",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お寿「今日は日曜だし、お見合いだし一日おうちですよ」庄平「なんだ」六二　庄造の書斎。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてお見合いするんじゃあるまいし。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "度々のお見合いで御迷惑ならどうぞお帰りになって頂戴。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふみ　精三とお見合いにいらっしたわけじゃないんですからねえ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると私もお兄さんもお見合いなんてものしなかっただけに不便ね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふみ　太鼓判だかどうだかしらないけど、お見合いに来て介添人と将棋を始めるなんて随分｜呑気な人もあるものね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼とは、夏すぎに妙なお見合いをしたんです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は、白状いたしますが、あれはお見合いのつもりだったのでございます」「見合い？",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとしたらお見合いなのかもしれないとかんがえたら、びっくりしていっぺんに眼がさめた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……私たち、もう一度お見合いをさせられたら、結婚するかしら」　と、女はいった。",
              "citation": {
                "source": "一人ぼっちのプレゼント",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美樹ちゃんは、今日は休みなのよ」「それは残念です」「お見合いですって」「ほんとですか」　中原の言葉に思わず勢いが宿った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見合いの席は上野の精養軒ですって。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩といっしょにレストランで夕食して、そのとき初めてお目にかかって、お見合いですよね。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだったか夏子さんの友人に頼まれた、お見合い用の写真みたいに」「それ以外には、撮れないのか」「夏子さんを撮るようにしか、いまの僕には撮れない」「だったら、夏子さんに集中したほうがいいね」「ほかの人を撮る余裕はない」「夏子さんのヌードは？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに五件、上司からお見合いの話がありました。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐田啓二とお見合いして結婚するお嬢さんの役」「私が？",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋している女があるんだ」「……」　三年位前からのおつきあいで、ファン・レターから、お見合いが始まり、この間手紙がきて、結婚を強いられている由。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
