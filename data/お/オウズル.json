        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これに応ずる乗客の数々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋な自由研究と政府の要求に応ずるような功利的研究との融和｜塩梅も最も痛切な困難であったらしい。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生に応ずるには幾千の調子が入るか知れないのでございます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧歳時記を繰ってみてもわかるように季節に応ずる食用の野菜魚貝の年週期的循環がそれだけでも日本人の日常生活を多彩にしている。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、小田急線の往復切符は一種特別な比較的｜稀有な刺激としてそれに応ずる特別の動作を誘発するに過ぎないかもしれない。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを逐次修正して言語学者の要求に応ずるように近づけて行くことは必ずしも困難ではないが、ここではしばらくこれ以上に立ち入らない事にする。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような悪罵を父から受けても、どのような哀訴を母から受けても、私はただ不可解な微笑でもって応ずるだけなのである。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "精妙ないいものの中から、そのいいところを取り出すにはやはりそれに応ずるだけの精微の仕掛けが必要であると思った。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この必要に応ずる最も手近なものは、週刊、旬刊ないしは月刊の刊行物である。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この環境の変化に応ずる風俗人情の差異の多様性もまたおそらく世界に類を見ないであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校教場の生徒の列もいくらかこれに応ずるエピソードである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた一面においては常設館の常顧客であるところの大衆の期待に応ずるような手ごろの材料をかなりに盛りだくさんにあんばいすることに骨を折ったようである。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "季題の設定はこの必要に応ずるものである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは連歌時代からすでに発句がそれ自身に完結し閉鎖した形式を備えるべきものと考えられた結果起こった要求に応ずるための規定である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその瞳の働きに応ずるように、「まあ」というかすかな驚きの声が唇の後ろで時々破裂した。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の鰭や尾の附根の美味いのは、そこの筋肉が激しく使われながら、一向浪や潮に蝕まれず、常にこれに応ずる筋肉の組織を増備して行って、いつも生々活溌の気を貯えているので、その質中に自ずと美味になるものが含まれるのでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事情に応ずるとは、事情にちょうど振向いた処置捌きが必要だということです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこれに応ずる知識も無限でなければなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "応身とは、人間に相応して生れ、人々を教化せられる仏陀ということでありまして、人間に相応ずる以上、人間の肉体を持ち、人間の喜怒哀楽を備え、お腹も減り、病気もされる仏陀であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孝が一声応ずるとともに、崩れた褄は小間を落ちた、片膝立てた段｜鹿の子の、浅黄、紅、露わなのは、取乱したより、蓮葉とより、薬玉の総切れ切れに、美しい玉の緒の縺れた可哀を白々地。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なお応ずる者のあらざりければ、渠は困じ果てたる面色にてしばらく黙せしが、やがて臆したる声音にて、「はい、もし、誠に申兼ねましたが、小用場はどこでございましょうかなあ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどもなお応ずる者はあらざりしなり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "といえども一人として応ずる者無し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　響の応ずるがごとく、四五人口々に饒舌った。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　更に応ずるものがなかったのである。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、かけ離れてはいるが、呼べば、どの妓も三味線に応ずると言う。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　左右を顧って又｜呶鳴ったが、直には声に応ずる者もなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはあるいは彼はぼくがそれに応ずるかどうかに依ってぼくの彼女への関心の如何を探ろうとして、ぼくを試しているのではないかと思ったので、自分は病人であるから迷惑をかけては、と断った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、あなたの将来の方針、それに就いてあなたのほうから私に、まじめに相談を持ちかけて来たなら、私もその相談には応ずるつもりでいます。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、それに応ずる私の言葉も、最も自然の流露の感じのものであった。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
