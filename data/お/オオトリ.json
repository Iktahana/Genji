        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一歩境内に踏みいると、乱雑なる町家から仕切られて、吉野山の杉林を見るような、幽邃なる杉並木が、富士の女神にさす背光を、支持する大柱であるかの如く、大鳥居まで直線の路をはさんで、森厳に行列している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓦屋根の覆いを冠った朱塗の大鳥居には、良恕法親王の筆と知られた、名高い「三国第一山」の額が架かってある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山者の眼中には、金剛不壊の山の本体の前に、永久性の大鳥居がただ一つあるばかりだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも大野原の上を、自由に飛翔しようとする大鳥が羽翼を収めて、暫く休息している姿勢を、富士は取っている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鳥居の柱は立っているが上の横桁が外れかかり、しかも落ちないで危うく止まっているのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ路傍の草いきれが恐しい、大鳥の卵見たようなものなんぞ足許にごろごろしている茂り塩梅。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……軒も門も傾いて、破廂を漏る月影に掛棄てた、杉の葉が、現に梟の巣のやうに、がさ／＼と釣下つて、其の古びた状は、大津繪の奴が置忘れた大鳥毛のやうにも見える。",
              "citation": {
                "source": "月夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、御前様のお留守、奥様が欄干越に、その景色をお視めなさいまして、――ああ、綺麗な、この白い雲と、蒼空の中に漲った大鳥を御覧――お傍に居りました私にそうおっしゃいまして――この鳥は、頭は私の簪に、尾を私の帯になるために来たんだよ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛は大社の大鳥居のまえの居酒屋で酒を呑みながら、外の雨脚と小走りに走って通る様様の女の姿を眺めていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく左＝籐製の大鳥籠に鳥の代りに三彩の南洋花が囀つてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い空の中へ浮上ったように広々と潮が張っているその上に、風のつき抜ける日蔭のある一葉の舟が、天から落ちた大鳥の一枚の羽のようにふわりとしているのですから。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い空の中へ浮上ったように広※と潮が張っているその上に、風のつき抜ける日蔭のある一葉の舟が、天から落ちた大鳥の一枚の羽のようにふわりとしているのですから。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦に應じて、一箭忽ち五羽の大鳥が鮮やかに碧空を切つて落ちて來た。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦に応じて、一箭たちまち五｜羽の大鳥が鮮やかに碧空を切って落ちて来た。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ路傍の草いきれが可恐しい、大鳥の卵見たやうなものなんぞ足許にごろ／″＼して居る茂り塩梅。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかすがに、大寂静の空高く濃霧をわけて東より霊智の光しらしらと見え、かつ、消えぬ、大鳥の強きはばたき。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鳥居の前で下りると、清楚な白い石畳の道を、また石の段を真っ直に、私たちは登って行った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おれは大鳥の尾白を撃つという意味が、言葉の裏に含まれているらしく思われるので、又次郎はいよいよ暗い心持になった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの高い空の上を翔りながら、あれほどの大きさに見えるからは、よほどの大鳥でなければならない。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに明るいといっても、月のひかりだけでは果たして尾白であるかどうかは判らなかったが、それが稀有の大鳥であることは疑いもなかった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の日は、御前様のお留守、奥様が欄干越に、其の景色をお視めなさいまして、――あゝ、綺麗な、此の白い雲と、蒼空の中に漲つた大鳥を御覧――お傍に居りました私に然うおつしやいまして――此の鳥は、頭は私の簪に、尾を私の帯に成るために来たんだよ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金翅鳥は竜を常食とする大鳥で、これまた卵胎湿化の四生あり、迦楼羅鳥王とて、観音の伴衆中に、烏天狗様に画かれた者だ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鳥大王に申さく、日来附き奉りたりつる梵士后を盗み奉りて逃れ侍りつるを、大王還りたもうまでと思いて防ぎ侍りつれども、梵士竜王の姿を現じてこの羽を蹴折りたりといいてついに死門に入りぬ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "水※に大鳥居立てり。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "津ノ宮より鹿島へゆく水路は、大鳥居の筋向ひより十六島を横切り、加藤洲の十二橋の下を過ぎ、北利根に出で、潮來の市街にそうて園邊川に入り、この川を下りて北浦の末の浪逆浦に合せる處を横斷して大舟津に至る。",
              "citation": {
                "source": "鹿島詣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、あの向うに……松林の薄黒う見ゆるは……文字ヶ関から大里の浜、あれをうしろにして味方の兵船はおよそ五百艘、さながら大鳥がつばさをひろげたように、左右に開いて陣取っていたのじゃ。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（豪州を去って十日を経たがまだ山も見えず、身はおおとりの飛ぶ空と鯤という大魚がおよぐ海の間にある。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おおとりの飛ぶ天や鯤がおよぐという海の果てのあたりを見極めようとして、雲をすみかとし、露をこうむってやどりながら生涯を送ろうとする。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ただ一人で幾山河をふみわたり、九万里をゆくおおとりの道程をつつがなく行く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
