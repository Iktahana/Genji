    "definitions": [
      {
        "index": 1,
        "gloss": "seeing off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "寺の住持になって世を隠遁し、読経と墓掃除に余生を送りたいといった彼の言葉は、決して一時の戯れではなく、彼の心の無限の悲哀を告白した言葉であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりかまえて、一日一日を、せめて悔いなく送りたまえ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日、毎日、歌をつくってお送りします。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいぶかしく思いながらその後姿をそれとなく見送り縁台に腰をおろすと、馬場はにやにやうす笑いして言いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "登竜門というものは、ひとを市場へ一直線に送りこむ外面如菩薩の地獄の門だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の間の光を肩にうけて、女だけが、私を見送りに出てゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Je me suis dit : Laisse,Et qu'on ne te voie.qu'on ne te voie !!!　　　　　――――――――――　以後出来る限り、僕は詩論の断片をお送りします。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所に杯盤の音、戸口に見送りの人声、はや出立たんと吸物の前にすわれば床の間の三宝に枳殻飾りし親の情先ず有難く、この枳殻誤って足にかけたれば取りかえてよと云う人の情もうれし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄下の溜池に海蟹の鋏動かす様がおかしくて見ておれば人を呼ぶ汽笛の声に何となく心｜急き立ちて端艇出させ、道中はことさら気を付けてと父上一句、さらば御無事でと子供等の声々、後に聞いて梯子駆け上れば艫に水白く泡立ってあたりの景色廻り舞台のようにくる／＼と廻ってハンケチ帽子をふる見送りの人々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は大学の講師をして月給三十五円とおやじからの仕送りで家庭をもっていたのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　夏の盛りに虫送りという行事が行なわれる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして田舎で不用になっている虫送りの鐘太鼓を借り集めて来てだれでもにそれをたたかせる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船にのるのだか見送りだか二十前後の蝶々髷が大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はＴ君に貧しい慰問袋を送りました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫は、龍宮の階段まで見送りに出て、默つて小さい貝殼を差し出す。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私や、どうも、お迎へはいいけれど、このお見送りつてやつは苦手だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、このお見送りつてやつは、氣のはずまねえものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はリボンを空に送り、私は嘗て陥落した海のことを　その浪のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "円筒の外線には小さいアーク灯があって強い一条の光線を送り、写真の膜を通じて筒中のセレニウムを照らす。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして尖った針の先をこの円筒に触れしめ、この針より金属板を通じて電流を送りこの電流を目的地に送る。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもう一つの方法はブラウン氏の発明で、これは三本の垂直なアンテナから同時に波を送り、三つの波を互いに干渉させ、その結果ある方向に最も強い波の起るようにしたものである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち発信器の方では不断に規則正しい波を送りそのアンテナに電話の送話器を接続し、受信器には前述のエレクトロリチック・デテクターを用うればよいのである。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして宛てられた時間が切れてオスマン通りへ送り出されると其処で始めてわれに返った。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岡本かの子　　　春の雷が鳴つてから俄に暖気を増し、さくら一盛り迎へ送りして、今や風光る清明の季に入らうとしてゐる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――岡本かの子　春の雷が鳴つてから俄に暖気を増し、さくら一盛り迎へ送りして、今や風光る清明の季に入らうとしてゐる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゼットが始めて彼に捉えられてサン・ラザールの館――即ち牢屋へ送り込まれるときには生鳥の鶉のように大事にされた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "健気なむす子よと言い送り度い。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どもらばかりボートの中へはなしてやってお母さんが狂気のやうにキスを送りお父さんがかなしいのをじっとこらえてまっすぐに立ってゐるなどとてももう腸もちぎれるやうでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さう云ひながら博士は〔〕また川下の銀河のいっぱいにうつった方へじっと眼を送りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
