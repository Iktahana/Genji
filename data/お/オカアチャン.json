          "literary": [
            {
              "text": "着物を着かえてお母ちゃんを待っとろと言うたりしてなあ」「お祖母さんがぼけはったのはあれからでしたな」姉は声を少しひそませて意味の籠った眼を兄に向けた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お母ちゃん、花ってどんなもの。",
              "citation": {
                "source": "里の春、山の春",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母ちゃんになったのだよ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく洞穴へ帰って来た子狐は、「お母ちゃん、お手々が冷たい、お手々がちんちんする」と言って、濡れて牡丹色になった両手を母さん狐の前にさしだしました。",
              "citation": {
                "source": "手袋を買いに",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いんかいな」「わてのお父ちゃんやお母ちゃんどこに居たはんねん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六やそこらで髭生やすのは東西屋だけや」「あ、お父ちゃん、お父ちゃん」　君枝はおどりあがっていたが、急に、「――お母ちゃん居たはれへんわ」　しょげた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これや、これや、なあ、〆さん」「そや、そや」　君枝はじっとみつめていたが、「ああ、居たはる、居たはる、お母ちゃん髪結うたはる。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんもお母ちゃんも居たはる」　そして、きんきんした声で、「――わて、もう親なし子やあれへんなア。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田屋の前へ捨てればねえさんのことゆえ拾ってくれるだろうと思ってそうしたのだが、やっぱり育ててくれて、礼を言いますと頭を下げると、椙は、さアお母ちゃんといっしょに行きまひょ。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほな、ミネちゃんのお母ちゃんは……？",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたはん、どないおしやすか」「お母ちゃん、あて、かなわんのどっせ。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わてのお父ちゃんやお母ちゃん何処に居たはるねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母ちゃん居たはれへんわ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんもお母ちゃんもいる。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早今夜も、母親は恵子を膝の上に乗せて、白い頭を振り振り、身体を揺す振りながら、「お母ちゃん、帰るかと、見て来よかあ？",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "門に出て、お母ちゃん、見ていよかあ？",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、ここまで来ると、いつもの癖で、母親が「お母ちゃん帰るかと、見て来よかあ？",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十「ああ、天窓が重い、胸が痛い、体中がふらふらする、もう寝ようや、」　蝶吉は枕を竝べて、着たまま横になって裾を伸ばして、爪先を包んだが、玉のような腕を人形の掻巻の上へ投げ掛けて、ぴったり寄って頬を差寄せ、「坊や、ちょいと、どうしたの、お母ちゃんは可けなくッてよ、すっかりお花を引いて負けて来たわ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のお父ちゃんに叱られてから、お花なんざ引くまいと思って、水も沸したんでなくッちゃ飲まないでいたけれども、お母ちゃんはお暇が出たんですもの、体を大事にしたって詰らなくなってよ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母ちゃんがね、仁丹おくれって。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "会いに行ったことなんかないのかネ」「それはねエ、お母ちゃんが一緒に会いにゆこうといってあたいを引張ってゆくことはあるんだけれど、いつも途中までいって停めにしちゃうのよ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして帰りにお母ちゃんはいつもあの唄を歌うのよ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くうちへ伴れて行かないと、お母ちゃんに言いつけるといって、泣くんです――」　告白者の口は、捻ったように歪み、手は無意識に、しきりに血だらけの頸を撫でさすって、指が、痙攣的に開閉している。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は往診の自動車が来て、「サ、坊や、お母ちゃんの往診」御亭主が若い妻の手から赤ん坊を抱きとると、大丸髷の院長さんは、一人の看護婦に鞄を持たせて悠然と車に乗り込む。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そーら、お母ちゃん、牛乳おくれ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母ちゃんは、去年そこで死んじまったんだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オジチャン、もう日本へ来たのかい」「まだまだ、坊やがそう、百もおネンネしてからだね」「じゃ、オジチャンとオネエチャンがお父ちゃんとお母ちゃんになって……、坊やは、唯今って日本へいくんだね」　そんなことが、ますます二人を近附けてゆくのだ。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母ちゃんに、いいつけてこようッと」　二郎は、ぱたぱたと縁側をはしっていった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほらね、お母ちゃん。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのお母ちゃんがいったよ。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
