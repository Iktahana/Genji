    "definitions": [
      {
        "index": 1,
        "gloss": "one's student (esp. a former one)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
