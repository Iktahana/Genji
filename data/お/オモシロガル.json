    "definitions": [
      {
        "index": 1,
        "gloss": "to amuse oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昔の地図と今の電車線路入りの地図と較べているうちに色々のことを発見して独りで面白がることも出来た。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「赤飯を貰ッたと思ってひどく面白がるぜ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が赤飯のために面白がるなら、君なんぞは難有がッていいのだ。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その笑いには野暮な学者に向って縁の遠い女の話をすることの奇抜さを面白がる響があった。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとよさん、これ見たえま、おとよさんてば、このきれいな花見たえま」　お千代は花さえ見れば、そこに立ち留って面白がる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖面白がることは非常に面白がった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白がると同時に、金井君は妙な事を考えた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬的な人は人の苦痛を面白がるようになる。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家は只読者が面白がるといふ部分だけに喰ひ下り読者を釣つてきただけである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬に牛肉、猫にまたゝび、狐に油揚、青年に戀、俗人に錢、氣を負ふものに功名、釣られて面白がるが、浮世にや。",
              "citation": {
                "source": "風船玉",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、都を離れて、何處へゆけば子供は面白がるかと、いろ／＼考へしが、江の島は、山もあり、海もあり、貝細工あり、鮑取りもあれば、子供をつれての旅は、これに越したる處はあらざるべしとて、江の島へと思ひ定めて、新橋より汽車に乘る。",
              "citation": {
                "source": "親馬鹿の旅",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣くにつけ、笑うにつけ、面白がるにつけ淋しがるにつけ、お前たちを見守る父の心は痛ましく傷つく。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれを友達に見せて自慢することも、一緒に面白がることも出来ないのが、非常に残念だった。",
              "citation": {
                "source": "私の父",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には積極的に社会や警察をカラカッテ面白がるのさえある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と百合子は雪洞を高く差しあげて、これ位の大きな声を挙げても平気だといふことを披露するために、反響を面白がる子供のやうに――「こんばんわ！",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間にあったことの細かしい点は、僕の記憶から消えうせていますし、またよしんば覚えているにしたところで、そんなことを、誰が面白がるでしょう？",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の者だから松茸狩りなぞ面白がるだらうと思つて、本人もさう云ふもんだから、しかしわしらはとんと根太は知らんし、折角遠くから來たものを失望させてはと思つたので、松茸狩りでは玄人と云はれてゐる親爺に一緒に連れてつてくれと頼んだんだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の見た大学戸坂潤　私小説というものがあって、その評判は好悪相半ばしているようだが、それは私という自分であるものにしか判らない小説、自分だけが面白がるための小説、を意味する心算ではないらしい。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩なら一晩とおしての放送を全く強制のない条件で聴かしてどれを面白がるか、一つの話のどの部分で興味が示されたかという調査は、すでに実行されていることなのだろうか。",
              "citation": {
                "source": "ラジオ時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義が眞直ぐに進んで行く間に、いつも神秘なるものが感じられるのであつて、これは何も不可解を一時面白がるのではない、自然と本能との奧には、とこしなへに知力の及ばない神秘性が潜んで居るのである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形を勝手に踊らせていて、エゴイストらしい自己が物蔭に隠れて、見物の面白がるのを冷笑しているように思われる。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも石川貞白さんなどのやうに、子供の面白がるやうな事を仰やらなかつたので、後にはわたくしは餘り其席へ出ませんでした。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "古往今来小説などを面白がる人は沢山ゐない。",
              "citation": {
                "source": "亦一説？",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな山｜蟻が逃出すのを面白がる。",
              "citation": {
                "source": "チンコッきり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は５＋５を羽左衛門がやると100となったり、延若がやると55となったり、天勝がやると消え失せたりするような事を大に面白がる性分なのである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、見物の方では、子供だと、始から手を拍って、面白がるが、大人は、容易に感心したような顔を見せない。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し亂暴なのには閉口する事も多かつたが、萬事てきぱきと切つて廻し、御世辭や御座なりが無く、傍若無人な醉體も、三田の面白がるところだつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とおつぎは三田の給仕をしながら、おみつを女主人公とする事件の複雜になるのを面白がる樣子だつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見ておもしろがる人々はただ妙技に感心するだけではなくて、やはり影絵のもつ特殊の魅惑に心酔するのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の芸術写真に興味のない人でも映画はおもしろがるのである。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
