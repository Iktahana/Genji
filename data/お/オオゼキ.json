        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それで昔の電気学者が種々の物体を陽陰の順に列挙した時に猫の皮を陽の方の首位｜大関の位置に上げた。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、屈辱の大関くらいのところだ。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ものも、こう、新旧相競うと、至って対照が妙で、どうやら辻番附の東西の大関とでも言いそうに見える。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れじゃとても青年角力の大関を投げ飛ばすことは難かしい」　註に曰く、大村とは天狗倶楽郎の大関、工学士大村｜市造（横田注・一蔵）君で、未醒子、番付は天狗倶楽部の三段目なり。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方には黒獅子という強い大関がいるそうです。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ物語は一大関節にさしかゝつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "博奕は近郷での大関株、土地よりも隣村に乾分が多かつたさうな。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の主人の権八はもと三の井と云う力士で、一度は紀州家の抱えとなっていた大関角力であったが、其の比は故郷へ隠退して附近の壮佼に角力の手ほどきをしてやっていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、彼の馬十と呼べる下男は此処より十里ばかり東の方、豊前小倉城下の百姓にて、宮｜角力の大関を取り、無双の暴れ者なりし由。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の日、下野黒羽城主大関高増に手紙をやり、「今日箱根峠に打ち登り候。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小錦という大関だか横綱だかの白※の肉体の立派で美しかったことと、朝潮という力士の赤ら顔が妙に気になったことなどが夢のように思い出されるだけである。",
              "citation": {
                "source": "相撲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大関とも云うべき「四谷怪談」とても、昔は知らず、今日の観客はむしろ伊右衛門や直助権兵衛の方に多分の興味を感じて、肝腎のお岩さまの方は二の次にされている傾きがある。",
              "citation": {
                "source": "怪談劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は既刊のよく売れた小説を基礎にしての立論であるが、その他に、出版の時機が小説の売れると売れないとに大関係がある。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "包装或はその道の言葉でいへばジヤケツもまた小説のポピユラリチイに大関係をもつてゐる。",
              "citation": {
                "source": "商品としての近代小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "大関は当家の伜源七どん、関脇は本石町油屋藤右衛門どのの伜又助どん。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "張り出し大関が遠藤主計頭様というわけでござります」「ようしッ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "又も大盃を呷り付けて、素敵に酔払っているらしく、吉角力の大関を取ったという双肌を脱いで、素晴らしい筋肉美を露出している。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の音が大関で参りました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――さう云へば、もう其処は先程の酒場ではなくつて「大関」のナダヤであつたのだ。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく毎夕四合壜を一本宛晩酌にとるといふ先の宰相は、この家の「大関」酒を愛好さるゝのであらう――だがたしかに宰相の額であつたか何うかはウロ覚えであるが、私は時々お光さんのゐた酒場へ行くには未だ時間が早いと思はれる明るいうちなどに、杉の葉の目印の格子をあけて此処の土間の飲み場に現はれることがあつた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の衛生論から云うと余り感心しないものであろうが、かの冷奴なるものは夏の食い物の大関である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者の甚だ淡泊なるに対して、後者は甚だ濃厚なるものであるが、いずれも夏向きの食い物の両大関である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地蔵さまがこの話に大関係をもっているのだから、よく記憶していてもらいたい。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏工は古来より阿弥陀如来の立像と、地蔵菩薩の立像をむつかしい物の東西の大関に例えてある。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政の大コロリ、文久の大麻疹、この二つが江戸末期における流行病の両大関で、実に江戸じゅうの人間をおびえさせました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蟹のお角",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
