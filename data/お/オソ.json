        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "我邦でも昔から壁土や土器をかじる子供があるが、他人種でもやはり胃病やヒステリーあるいは悪阻のために土を食いたがる者が往々あるそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　トシエは、家へ来た翌日から悪阻で苦るしんだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私通した小娘の青い悪阻の秘密と恐怖とにふりそそぐ雨。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリスは二、三日前の夜、舞台にて卒倒しつとて、人に扶けられて帰り来しが、それより心地あしとて休み、もの食うごとに吐くを、悪阻というものならんと始めて心づきしは母なりき。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪阻の軽かったかれは、ほとんど臨月の姙婦とは見えないほどにすこやかであった。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しお腹がふっくりとなって悪阻の悩みに顔の少しお痩せになった宮のお美しさは、前よりも増したのではないかと見えた。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はふと定子を懐妊していた時のはげしい悪阻の苦痛を思い出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「妊娠した女の悪阻と考えます」「いかにも立派な推定だ。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者は妊娠三ヶ月だというから悪阻に悩んで然るべきだ。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "妊娠が進むにつれて悪阻を起して来ました。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリスは二三日前の夜、舞台にて卒倒しつとて、人に扶けられて帰り来しが、それより心地あしとて休み、もの食ふごとに吐くを、悪阻といふものならんと始めて心づきしは母なりき。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮が可憐な姿で悪阻に悩んでおいでになるのが院のお目に浮かんで、心苦しく哀れにお思われになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪阻に悩んでいる新女御の姿もまた美しい。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは前のときとちがって悪阻もすこしもないらしいしよく働いているし、いいだろう。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪阻のような気がします。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月見る物を見ないというのも、母の病気や死亡の感動のせいかも知れないし、悪阻だってないんだし……と俺は思ったが、悪阻がないことだってある、と彼女は云っていた。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康な彼女は悪阻に悩むようなことはまず無いと言ってよかったのであるが、それにしてもさすがに自分で自分の肉体が持てあまされた。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は悪阻も殊の他に強い。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言えば、この悪阻とは何だろう。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "病症が悪阻だから大丈夫という安心もあるらしく見えたが、容体が険悪になって後も、彼は依然としてその態度を改める様子がなかったので、人はそれを気に入らない妻に対する仕打とも解釈した。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は悪阻で死んだ健三の兄の細君の事を思い出した。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子は悪阻のあとの衰弱がひどかったので、暫時箱根の別荘に静養していたその留守の間に、花は暇をとって帰ってしまった、どういう理由で帰ったのか、別に詮議立てもしなかったので、それについては何も知らなかった。",
              "citation": {
                "source": "美人鷹匠",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしげはおしづの下を身籠ったが、悪阻の時期に悪性の感冒にかかって、それがもとで死んだ。",
              "citation": {
                "source": "日日の麺麭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは悪阻がいちばんつよい時期らしいから、劬ってあげるようにとも云った。",
              "citation": {
                "source": "醜聞",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………「三四箇月」と云うのであるから、事実があったのはこの六月頃、あの大病から起ち直った後のことであろうが、そうだとすれば悪阻を隠していた時期もあっただろうに、そんなことをも見過していたのはあたし等の迂濶と云うべきであろうか。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくヘルンはその時初めて心の隅に、幸福という物の侘しい実体を見たのであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが日本人の抒情的な言葉で、あきらめと呼ばれるものであることさえ、おそらくヘルンは知ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "化物屋敷の一件以来、おそらくは『面白いの家』という言葉などが、一種の反語として家族中に流行し、すべての不潔の家、陰気な家などを指す代名詞になったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の仲の好い成人が、子供の片言のようなことをしゃべり合って、何時間もの長い間、笑ったり戯れたりしている風景こそ、おそらく真にフェアリイランド的であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
