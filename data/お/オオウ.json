    "definitions": [
      {
        "index": 1,
        "gloss": "to cover",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "瞳の上を覆う角膜はいつも涙をためたように光っている。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は泣く泣く砂礫を拾って、裸骨へ根気よく肉と皮を覆うた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸に覆うてある単物のある点がいくらか動いておって、それが呼吸のために動くように思われてならぬ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘、突然激しく感動したる様子にて両手にて顔を覆う。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はリキュール酒のようなあまさで、夜の街を覆うと、絢爛な渦巻きがとおく去って、女の靴の踵が男の弛緩した神経をこつこつとたたいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫を且つ覆うて、薄の穗も靡きつゝ、旅店の午は靜に、蝉も鳴かない。",
              "citation": {
                "source": "十和田の夏霧",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗吾郎は、笠で自分の顔を覆うて、渡し舟に乗る。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが積極的誤解となると、手を尽すか探すかすれば、正解に達し得られるものをいい加減にして置くか、感情に左右されて軽忽に実情を覆う誤解であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝に葉のある季節には、青い簾のようにその枝が、土蔵の前を覆うていた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脅えて阿難を見て居た娘は、その時急いで駈け寄り阿難の口に袂を覆う。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菩提樹、椰子、棕櫚、雑草など、これを大方｜覆う。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その式場を覆う灰色の帆布は、黒い樅の枝で縦横に区切られ、所々には黄や橙の石楠花の花をはさんでありました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて二階屋が建続き、町幅が糸のよう、月の光を廂で覆うて、両側の暗い軒に、掛行燈が疎に白く、枯柳に星が乱れて、壁の蒼いのが処々。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで自然ぼくの心は自分自身の言った言葉にごまかされてしまい、轡川の言葉を信ずる方向に傾いて来て、明日子を覆うていたベエールが次第にとれ始め、明日子は単に男を求める浮気女に過ぎないのではないかと思われて来た。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の最中のこととて彼は裸でいるので、その見苦しさは覆うところなく人目を寒気立した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はモデレートな夏の洋装をしているのだが、それは皮膚を覆う一重のものであって、中身はこの回教の寺院の中に置けば、この雰囲気に相応わしく、ヒンズー教の精力的な寺院の空気にも相応わしかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お酌しましょうよ」　わたくしはこの間に、ほんの四つ五つの型だけで全身を覆うほどの大矢羽根が紅紫の鹿の子模様で埋り、余地の卵黄色も赤白の鹿の子模様で埋まっているのを見て、この雛妓の所作のどこやら場末臭いもののあるのに比して、案外着物には抱え主は念を入れているなと見詰めていた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝に葉のある季節には、青い簾のやうにその枝が、土蔵の前を覆うてゐた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は、もう、（突然、花火をやめて、袖で顔を覆う）何もかも、だめなのだわ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この緑の風呂敷を、電燈を覆うのに使用したわけは、けれども、その不潔の風呂敷の黴菌を、電球の熱でもって消毒しよう、そうして消毒してから、ながくわが家のものとして使用しようなどの下心からではない。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、この世くらくして、君に約するに、世界を覆う厳粛華麗の百年祭の固き自明の贈物のその他を以てする能わざることを、数十万の若き世代の花うばわれたる男女と共に、深く恥じいる。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、また二十丁ばかりも往くと三次殿の塚と云う五輪の塔があって、其の背後には俗に天狗杉と云う七尋か八尋位もある大杉が、塚を覆うように枝葉を張っていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの中之島と彼岸の渚とはたいして水を距てゝいず、三がい松の影は島を覆うていますので、わたくしは寮の縁側から見て、初めしばらくは、これが島なのを知らず、池はたぶん、地中の桟道によって区劃られ、大小二つの水溜りになっているのだろうと思っていたくらいでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅の灌木の群は丘の円味を一面に鳶色に覆うているその上へ蕾の花と嫩芽との萌しが色のうす葛をかけたように見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に対して若さを覆うために、われならなくに、ふと思い付いた唖の所作が、わたくし自身のためにも勿怪の幸となって、わたくしは深くも自分を唖とも物狂いとも思い込むのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の腰を覆うて枯蘆もぼうぼうと生えている。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから言葉をたゞ意味さへ通じればいゝ位に粗雑に取り扱つてゐる作品に接すると、たちまち耳を覆うて走つて了ふ。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は一面の灰色の雲、針の目程の隙もなく閉して、黒鐵の棺の蓋の如く、重く曠野を覆うてゐる。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して黒い雲が空を覆うて暗くなった。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冠の「イソ」というのは俚言集覧には「額より頭上をおおう所を言う」とあるが、シンハリース語の isa は頭である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
