        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「簡単なオプティミズムへの途を教えてやろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功のモラルはオプティミズムに支へられてゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが人生に對する意義は主としてこのオプティミズムの意義である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "オプティミズムの根柢には合理主義或ひは主知主義がなければならぬ。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにオプティミズムがこの方向に洗煉された場合、なほ何等か成功主義といふものが殘り得るであらうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的な冒險心と、合理主義と、オプティミズムと、進歩の觀念との混合から生れた最高のものは企業家的精神である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは歴史は時とともに進歩すると見る歴史観とは相反する方向をとるものであり、前者が単純なオプティミズムであるのに対して後者は単純なペシミズムであると考えられるであろう。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功のモラルはオプティミズムに支えられている。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが人生に対する意義は主としてこのオプティミズムの意義である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "オプティミズムの根柢には合理主義或いは主知主義がなければならぬ。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにオプティミズムがこの方向に洗煉された場合、なお何等か成功主義というものが残り得るであろうか。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的な冒険心と、合理主義と、オプティミズムと、進歩の観念との混合から生れた最高のものは企業家的精神である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点において快楽説は、抽象的なオプティミズム（楽天説）に立っている。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその根柢には予定調和の形而上学のオプティミズムが横たわっている。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等によれば実は寧ろ実際問題と原理問題との区別はないので、原理問題さえ片づけばそれで以て実際問題に対する処方も亦出て来るというオプティミズムが根本をなしているのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "進歩の観念自身がいつもそうしたオプティミズムを要請しているのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別な哲学史上の材料に依らなくても、例えばペシミズムとオプティミズムとの対立などは相当根本的なものと認められている。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこういうオプティミズムをこの不安時代に見出す権利があると思っている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当のオプティミズムが身につくためには、大した勉強や砕身がいるのですもの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
