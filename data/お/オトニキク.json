        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "音に聞く大正池の眺めは思の外に殺風景に思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く大正池の眺めは思いのほかに殺風景に思われた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　其の、いま、鎭守の宮から――道を横ぎる、早や巖に水のせかるゝ、……音に聞く溪河の分を思はせる、流の上の小橋を渡ると、次第に兩側に家が續く。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の海なる海鳴の鐘に似て凍る時、音に聞く……安宅の関は、この辺から海上三里、弁慶がどうしたと？",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞くシャン・ゼリゼーの通りが余りに広漠として何処に風流街の趣きがあるのか歯痒ゆく思えた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠の前には、一座滑かな盤石の、其の色、濃き緑に碧を交へて、恰も千尋の淵の底に沈んだ平かな巌を、太陽の色も白いまで、霞の満ちた、一塵の濁りもない蒼空に、合せ鏡して見るやうな……大さは然れば、畳三畳ばかりと見ゆる、……音に聞く、飛騨国吉城郡神宝の山奥にありと言ふ、双六谷の名に負へる双六巌は是ならむ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く太田の呑竜さまへお詣りしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「音に聞く松が浦島今日ぞ見るうべ心ある海人は住みけり」という古歌を口ずさんでいる源氏の様子が美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜光命、裸男の肩を叩いて曰く、『櫻の新名所へと云ひつるに、これは音に聞く市川の桃林に非ずや。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、これが音に聞く中坂思案外史だとはマダその時は知らなかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "○夜もすがら、しぐるる空を、玉水の、絶えぬ軒端の音に聞くかな。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるほどに悪魔はこの問答の間さへ、妖霊星の流れる如く、ひた走りに宙を走つたれば、「あんちおきや」の都の燈火も、今ははるかな闇の底に沈みはてて、やがて足もとに浮んで参つたは、音に聞く「えじつと」の沙漠でおぢやらう。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは音に聞く鹿島灘――今、目に見て白雲の心が躍りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、音に聞く胆吹颪は怖ろしい、全く、弁信さんという人は進んでいるのだか、退いているのだかわからない、ああ、危ない、あの崖、あそこへ顛落した以上はもう助からない！",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……」　飛騨を知らない半蔵が音に聞く嶮岨な加子母峠の雪を想像し、美濃と飛騨との国境の方にある深い山間の寂寞を想像して、冬期には行く人もないかと思ったほど途中の激寒を恐れたことは、平兵衛の上京でやや薄らぎもした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、あれが音に聞く木賊山と地主山か。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが音に聞く柳生源三郎か、あのものすごい腕前！",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く司馬道場の娘御に接近する機会をつくり、あとはこの拙者の男っぷりと、剣のうで前とであわよくば入り婿に……たいへんなうぬぼれだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く都の島原を、名にゆかしき朱雀野のほとりに訪ねてみても、大抵の人は茫然自失する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宿を騒がしても気の毒じゃ、どうだ諸君、これより程遠からぬところに鍵屋の辻というのがある、鍵屋の辻へ行こう、音に聞く荒木又右衛門が武勇を現わしたところじゃ、そこで一番、火の出る斬合いをやって、伊賀越えの供養をしてみたいなあ」　かの印籠鞘の武士は衆を顧みて腕をまくり立てる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "三輪の神杉の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "田山白雲は、そんなことは頓着なしに、ただ単純に、その根塊を珍しがって、「ははあ、これが音に聞くジャガタラいもですか？",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く、勿来の関の古関の址。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く島津の家の門番は、この途方もないいたずら者を、どう処分するかと見れば、案外にも易々と表門を素通りさせて、彼等をこの屋敷の中に吸い込んでしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、音に聞くベートーヴェンの『第五シンフォニー』、シューベルトの『未完成シンフォニー』などが、曲りなりながら、レコードを通して聴かれるようになって来た。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、あんたが音に聞く明智先生ですかい。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、幸子と雪子とが同音に聞くと、「それが可笑しいねんわ」と云って、妙子は笑いながら話すのであった。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く明智小五郎の手にかかっては、何と弁解して見た所で無駄だと悟った。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞くハンプトン・コートの扇形迷路、ヴェルサイユ宮殿の方形迷路、なども、遠くこれには及ばず、強いて比類を求めるならば、歴史家の雄大なる幻想として残っている、古代エジプトの大ラビリンスであろうか。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……これが、音に聞く二龍山だナ」と、さらに麓へ迫り、その夕べ、どこか一夜の寝場所はないかと、吹き渡る松風の中を、あちこち歩き廻っていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に聞く蜈蚣峰の晩秋もうしろに越えて、道は青州二龍山の方へと、一日一日、近づく冬の歩みとともに、二十日余りを重ねていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
