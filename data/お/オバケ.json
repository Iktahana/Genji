          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昔西洋の雑誌小説で蛾のお化けの出るのを読んだことがあるが、この眼玉の光には実際多少の妖怪味と云ったようなものを帯びている。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　地獄変相図の世界国ノアの洪水、ソファの下から這出した蜘蛛蟹のお化け。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また私の郷里では昔天長節の日に市の公園で「お化け」と称する仮装行列が行われた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠が死んだんです」　お化け師匠――こういう奇怪な綽名を取った本人は、水木｜歌女寿と呼ばれる踊りの師匠であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠の綽名はそれから産み出されたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠のおそろしい名が町内にひろまって、弟子たちもだんだんに寄り付かなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお化け師匠が今死んだのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お化け師匠は蛇に巻き殺されたんで……」「蛇に巻き殺された」と半七も驚かされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠が蛇に巻き殺された――どう考えてもそれは戦慄すべき出来事であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこれからおめえの家へ寄ろうかと思っていたんだ」「なんです、なにか御用ですか」「お前まだ知らねえのか、お化け師匠の死んだのを……」「知りません」と、松吉はびっくりしたような顔をしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう少し身にしみて御用を勤めねえじゃいけねえぜ」　半七からお化け師匠の死を聞かされて、松吉は眼を丸くしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠とうとう憑殺されたんですよ」「まあ、どうでもいいから俺の云うことをきいてくれ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れると、源次がこっそりたずねて来て、お化け師匠の検視はけさ済んだが、人が殺したか蛇が殺したかは確かに決まらないらしかったと話した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てめえは御成道の横町のお化け師匠の情夫か、亭主か。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠と札付きになっているのに付け込んで、師匠をそっと絞め殺して、その蛇を死骸の頸へまき付けて置いて、娘の執念だとか祟りだとか、飛んだ林屋正蔵の怪談で巧く世間を誤魔化そうとしたんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは文といふ女のお化けです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前もおとなしくしないと、庭のお池からかういふ怖いお化けが出ますよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を伏せている子守娘が今度こちらを向くときにはお化けのような顔になっているのじゃないかなど思うときがあった。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは女のお化けです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔はあたり前ですが、後頭部に――その部分がお化けなのです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年だれか八頭の大蛇とヒドラのお化けとを比較した人があった。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような化け物の一例として私は前に「提馬風」のお化けの正体を論じた事がある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うにこの役者は「木魂」のお化けをかなりに深く研究したに相違ないのである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばけは、日本の古典文学の粋である。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "媛神　（廻廊に立つ）――私の傍においでだと、一つ目のおばけに成ります、可恐い、可恐い、……それに第一、こんな事、二度とはいけません。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『まつくらでござんすなおばけが出さう』ボーイは少し屈んであの若い船乗りののぞいてゐる窓からちよつと外を見ながら云ひました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出た」とおばけらしく話したい。",
              "citation": {
                "source": "くさびら",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何う言ふものか、此のごろ私のおともだちは、おばけと言ふと眉を顰める。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばけでもあるまい。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じや、おばけ見たやうね。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
