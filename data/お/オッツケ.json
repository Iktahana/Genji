[
  {
    "uuid": "28ab1591-7f9e-5612-9e2d-b7ededf9654f",
    "entry": "追っ付け",
    "reading": {
      "primary": "おっつけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
