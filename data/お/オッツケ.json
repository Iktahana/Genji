    },
    "definitions": [
      {
        "index": 1,
        "gloss": "by and by",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "詩人としては第一流、とても僕など追っ付けそうもない」　互いに推重をしあったのであった。",
              "citation": {
                "source": "岷山の隠士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒が切れて、お燗番の勝造が眼を白黒させているではないか――三吉はまだ戻らぬか」「もう、追っ付け戻りましょう」　用人の村川菊内は少し苦々しいのを我慢して、精一杯｜合槌を打っております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "下っ引が二人飛んで行ったから、追っ付けしょっ引いて来るはずさ」　大根畠の金太はこの上もなく得意でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縁結び",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で、後で、悔んでも追っ付けめえぜ、引いたっ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――誰かあなた方が来て下されば話が分ると思ったもんですから」「へえ、成る程、………だけどとにかく手前共へは参りませんのよ、そう云うことなら追っ付け来るかも知れませんけれど」「だけどもお前、昨夜ッからなら分りゃしねえぜ」と、そうこうするうちに兄貴も出て来て云うのでした。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近にあったアルコールの数滴を机の上に垂らしてその上に玉虫の口をおっつけると、虫は活溌にその嘴を動かしてアルコールを飲み込んだ。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっつけ先生は二階からおりていらっしゃる時分だよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミゼラブル」の中でファンティーヌが往来で乱暴な男に肩へ雪の塊をおっつけられるところもあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルクナー主演の「女の心」（原名アリアーネ）の一場面で食卓の上にすみれの花を満載した容器が置いてある、それをアリアーネが鼻をおっつけて香をかいだりいじり回したりするのであるが、はじめは自分にはそれがなんだかよくわからなくて、葡萄でも盛ったくだもの鉢かと思っていた。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばド・ヴァレーズ伯爵がけしからぬ犯行の現場から下着のままで街頭に飛び出し、おりから通りかかったマラソン競走の中に紛れ込み、店先の値段札を胸におっつけて選手の番号に擬するような、卑猥であくどい茶番はヤンキー王国の顧客にはぜひとも必要なものであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうおっつけ九頭竜らがやってくる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっつけお前が誰かと恋に落ちた時に、はじめて解ることだわ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論誰にも知らせないで、おっつけ土くれになってしまう僕の体と一緒に亡びてしまう秘密だ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぶれのお客をおっつけやがって。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "オロチョンギリヤーク土人の独木舟の競漕がおっつけ花火が揚ると初まる手筈であった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝生の上に置いてもとの古巣の空きがらを頭の所におっつけてやっても、もはやそれを忘れてしまったのか、はい込むだけの力がないのか、もうそれきりからだを動かさないでじっとしていた。",
              "citation": {
                "source": "簔虫と蜘蛛",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（詩入）「国を去って京に登る愛国の士、心を痛ましむ国会開設の期」雲や霞もほどなく消えて、民権自由に、春の時節がおっつけ来るわいな。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自業自得を、人の責任におっつけるのは、図々しすぎるぜ」船長は、こいつ一つ脂をすっかりしぼりぬいてやろうと考えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうおっつけお帰りになることでございましょう。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんなはそのるす中に、あの、なんとかいいましたね、そうそう、お弓さんか、まだけさは姿を見せませんが、おっつけご入来になりましょうからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに、その香箱とやらも取り返してしんぜようが、いま仙次の野郎は在宅でござるか」「今は不在でござりまするが、暮れ六つまえには帰ると申しましたので、おっつけもうそのころでござります」「さようか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "足の裏の冷や冷やする心持は、なまゆるい湯婆へ冷たい足の裏をおっつけて寒がっていた時とは大違いだ。",
              "citation": {
                "source": "初夢",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "露出しの男の膝を抓ったり、莨の火をおっつけたりなどした。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっつけ仕事を間に合すことのできないその器用な遅い仕事振を、お島は時々傍から見ていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の方の男は、眠っているうちに段々そうなったという風で、窮屈そうにやはりインバネスの大きい肩をねじって窓枠に顔をおっつけて睡ているのである。",
              "citation": {
                "source": "東京へ近づく一時間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い男二人は立ってしまったが、日本女のすぐ前へ腰をかけた女はそのままベンチのよりかかりに背中をおっつけて動かず、扉の方へ盛に手招きしている。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計屋が使うような片目の覗き眼鏡にぴったり顔をおっつけ、右手でその眼鏡の下のものをいじっているところだが、ヴォルフはカメラをその顔や手の、下の方から向けた。",
              "citation": {
                "source": "ヴォルフの世界",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は先ほど家を出て林の方へ参りましたが、おっつけ帰ってまいりましょう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい何の目的があって、どこへおっつけるために、死んだ農奴など買いこむのだろう？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも品川署との所管争いでおっつけっこをしていた結果ですよ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
