                "source": "ヴォルフの世界",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は先ほど家を出て林の方へ参りましたが、おっつけ帰ってまいりましょう。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい何の目的があって、どこへおっつけるために、死んだ農奴など買いこむのだろう？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも品川署との所管争いでおっつけっこをしていた結果ですよ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女は、技師の肩に鏝をかけた自分の頭をおっつけそうに喉を反らせ、やがてこごみ、大笑いした。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はその上へジャケツを着こみながら、窓んところへ額をおっつけて戸外を見た。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
