    "uuid": "c815fb06-9a40-5485-84ff-912c2ab28ca2",
    "entry": "オーバーラップ",
    "reading": {
      "primary": "オーバーラップ",
      "alternatives": [
        "オーバラップ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
