        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "叔父は親友のような存在だ。",
              "source": "幻辞"
            },
            {
              "text": "叔父が家を訪問してくれた。",
              "source": "幻辞"
            },
            {
              "text": "叔父の話は面白い。",
              "source": "幻辞"
            },
            {
              "text": "叔父が就職のアドバイスをくれた。",
              "source": "幻辞"
            },
            {
              "text": "叔父の得意分野について学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "叔父との時間を大切にしたい。",
              "source": "幻辞"
            },
            {
              "text": "叔父は私の人生の先輩だ。",
              "source": "幻辞"
            },
            {
              "text": "叔父が困った時に助けてくれた。",
              "source": "幻辞"
            },
            {
              "text": "叔父の子供は私のいとこだ。",
              "source": "幻辞"
            },
            {
              "text": "叔父からのプレゼントを受け取る。",
              "source": "幻辞"
            },
            {
              "text": "叔父のおかげで成功した。",
              "source": "幻辞"
            },
            {
              "text": "叔父が経営する会社で働く。",
              "source": "幻辞"
            },
            {
              "text": "叔父の経験を聞きたい。",
              "source": "幻辞"
            },
            {
              "text": "叔父が定年退職した。",
              "source": "幻辞"
            },
            {
              "text": "叔父との関係が深まった。",
              "source": "幻辞"
            },
            {
              "text": "叔父の知恵を借りる。",
              "source": "幻辞"
            },
            {
              "text": "叔父が孫の成長を喜ぶ。",
              "source": "幻辞"
            },
            {
              "text": "叔父のような存在になりたい。",
              "source": "幻辞"
            },
            {
              "text": "叔父が健康で長生きする。",
              "source": "幻辞"
            },
            {
              "text": "叔父は親戚の中の頼れる人だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "）　婦人はそなたを振向いて、（おじ様どうでござんした。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（おじ様、今日はお前、珍しいお客がお二方ござんした、こういう時はあとからまた見えようも知れません、次郎さんばかりでは来た者が弱んなさろう、私が帰るまでそこに休んでいておくれでないか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その刹那に「おじ様、お相手」と叫んで、前髪の七之丞が電光のごとくに飛んで出て、又七郎の太股をついた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時分はお前達と雪の中で、ずいぶん苦労したからなあ」「おじ様が毎日｜鮭を捕えて来て、あたし達に喰べさして下さいましたわね」「アハハハ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじ様」「お松、ちょっと耳を貸してくれ」　七兵衛の来るのは、いつもあわただしいものであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おじ様、どうなすッたの」　奈都子は、電話口を離れて椅子へ戻った彼の顔いろに、彼以上の動悸をうけ取って訊ねた。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじ様、千歳の女将さんよ」「そうか、大隈の御前様はまだおいでるらしいのか」「え。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角、横浜へ来た大官を、利用せずに帰しちゃつまらんからの」「どうしておじ様は、官員様ばかりそう崇拝なさるの」「崇拝はせんよ、勲章を佩げた鴨をつかまえんじゃ、大きな実業家にはなれやせん。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰れッ……」「――おじ様ッ、おじ様。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、おじ様も、いつお討死か知れぬと聞き、お別れに参りました」　ここは、半兵衛｜兄妹の生地、菩提山の城からも程近い。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの遣戸をスウと開けて、「おじ様、お名残り惜しゅうございます。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさま、奥様、お開けになって、野川さんと御相談下さいまして、暫くのあいだおあずかり下さいまし。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはわたしの話の大半を聴いたとき、急にわたしの肩を抱え、涙をさん／″＼と流して「何という可哀相なおじさまなの」と言った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あーあ、おじさまってば／＼」美しく乱れたおまえの額の下に在ってわたしは腕組をし、薄く眼を瞑っていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は弟さまの大長谷皇子のために、仁徳天皇の皇子で、ちょうど大おじさまにおあたりになる大日下王とおっしゃる方のお妹さまの、若日下王という方を、お嫁にもらおうとお思いになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな意味でも、この場合の「おじさま。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……額の下へ、もそもそ不手際に、件の紅白水引を、端づくろいに、ぴんと反らして差置いて、すぐに座を開くと、「まあ、おじさま。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさまはご親切ね、私の掌の傷をあんなに心配したりして」　坂上とよ子が元気がなくなってからは、私も妙にさびしかった。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たべたい物などは、うちのおじさまにも云えば買ってきてくれますし」　こう急いで宥めると、とよ子は思いのほかきれいに涙を収めてくれた。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だろうと思っていたら、静子がおとなりの吉田さんのおじさまなのよ、とおしえてくれました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しいか」「ありがとう御座います」「おじさま。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の準備が出来たら女中を迎えに遣るから……」「おじさま……さようなら……」「先生……さようなら……」「ああ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "知栄　でも、叔父さまはとにかく中国へお行きになったんですもの、おじさまだけは初志を貫徹なすったわけでしょう。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "知栄　おじさまは、御自分のことは、ちっともお話しにならないで、うちのことばかりおききになるのね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "（戻ってきて坐る）知栄　今、おじさまを連れて行った人達は、何ですの。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "知栄　お母さま、おじさまは一体何をなすったからあの人達に連れてゆかれたのですか。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "けい　おじさまが何をなすったか、これから何をしようとしてらしたか、私は知りません。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "知栄　お母さまは、おじさまの為に何かして上げることは出来なかったのですか。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじさま、お早ようございます」「やあ、ムサシ君か」　甥の蜂葉十六、十六だから〔十六｜六指というゲームがあるから〕ムサシだとて帆村は彼をムサシという。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさまは今のお客さんから当然聞き出さなくてはならない重大な項を、ぼろぼろ訊き落としています。",
              "citation": {
                "source": "断層顔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
