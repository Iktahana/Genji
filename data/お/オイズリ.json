    "definitions": [
      {
        "index": 1,
        "gloss": "thin, sleeveless overgarment worn by pilgrims",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "薄い髪の、かじかんだお盥結びで、襟へ手拭を巻いて居る、……汚い笈摺ばかりを背にして、白木綿の脚絆、褄端折して、草鞋穿なのが、ずつと身を退いて、トあとびしやりをした駅員のあとへ、しよんぼりと立つて、饂飩へ顔を突込むだ。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アイ、笈摺もな、兩親のある子やゆゑ兩方は茜染……」の一段になつて、予も始めて、はつと幻想の世界に落ち込んだやうな心持がした。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄概念的に味はつて居た十郎兵衞住家の悲劇も、兩親があるから笈摺の兩縁が茜染だといふ特殊の事實の描寫が、阿片のやうに瞬間的に予の自覺を濁らしたと見える。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「からげも解かず、笈摺も掛けたなり」と云ふ處で、また小さいシヨツクを感じた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に荒縄の太いので、笈摺めかいて、灯した角行燈を荷ったのは天狗である。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その反対の角隅には、道者の笈摺を枕元に据えて、人一人が布団を冠って臥ておりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の隅に眠ていた行者風の男はむく／＼と起き出し、粥の小鍋を炉の端に提げて来まして、白湯をさし、「ちょっと火にかけさしてお貰い申すだ」と、自在鈎へ釣り下げて元の隅へ戻ると、今度は笈摺に向って何やら頻りに呪文のようなことを誦しながら珠数をじゃら／＼揉み鳴らしています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春なれば街の少女が華やぎに、君も交りて美しう、恋の祈誓の初旅や笈摺すがた鈴ふりて、大野のみなみ、菜の花の黄金海透く筑紫みち列もあえかのいろどりに御詠歌流し麗うらと練りも続く日、軟かぜに絵日傘あぐる若菜摘、法師、馬上の騎士たちも照りつ乱れつ菅笠に蝶も縺るる暖かさ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳亭筆記上「順禮がるた考證」の條に、「京順禮といふは、衣裳にだてを作り、笈摺を絡ひ、胸札をかけ、實の順禮の如く出立ち、洛陽の觀音の靈場を打廻りし也」とあれば、拙文に棟札とせしは間違ひで胸札が正しい。",
              "citation": {
                "source": "女順禮",
                "author": "並にサンヤレの事",
                "note": "青空文庫"
              }
            },
            {
              "text": "笈摺菅笠と言えば、極った巡礼の扮装で、絵本のも、芝居で見るのも、実際と同じ姿でございます。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "笈摺岩、右に天を衝く。",
              "citation": {
                "source": "上州沼田より日光へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木綿に朱印をベタベタと捺した巡礼の笈摺を素肌に引っかけて、腰から下に色々ボロ布片を継合わせた垢黒い、大きな風呂敷｜様のものを腰巻のように捲付けている恰好を見ると、どうやら若い女らしい。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「コレコレ……退かんか……」「コラッ……コン外道……」　と二人が声を揃えて怒鳴り付けるうちに一作が、女の襟首へ手をかけると、古びた笈摺の背縫と脇縫が、同時にビリビリと引離れかかった。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "笈摺も古ぼけて、旅窶れのした風で、白の脚絆も埃に塗れて狐色になっている。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "博文館から發行される「葉書文學」といふ雜誌に、岡田八千代夫人の談話筆記だつたと記憶するが、その愛讀書について述べてある中に、泉先生の作品殊に「笈摺草紙」が激稱してあつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見て自分は初めて先生に「笈摺草紙」といふ作品のある事を知り、今日迄のやうな不秩序な古本探しでは、まだまだ見落しが澤山あるに違ひ無いと思つた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田の夜店を漁りに行つて、有斐閣の前あたりだつたと覺えてゐるが、蓙の上に積重ねてある雜誌の間に、手垢で汚れた「笈摺草紙」の出て居る「文藝倶樂部」を見出した。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども自分が久しく探し求めて居た「笈摺草紙」に對してはちつとも高いとも思はなかつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「笈摺草紙」の十二錢は自分の主觀的價格からみればおい夫と支拂つて差支へないけれども、客觀的價格からみれば成程人を馬鹿にした者に違ひない。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更それを買ふ事は出來なくなつてしまつたが、此の一册を手に入れなければ永久に「笈摺草紙」は手に入らないやうに思はれた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "癪に障つて堪らないので、往來の石つころを蹴飛ばした勢ひで、一町ばかり次の町筋の角迄來たが、右に行かうか左に行かうかと考へた時、どうしてももう一度後に引返して恥を忍んでも「笈摺草紙」を買はなければならないと思ふ心持が強く起つた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "古本屋のおやぢは依然として身動きもしないで煙草をふかして居たが、たつた五分か十分とはたたない間に「笈摺草紙」はもう賣れてしまつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴がそれ程に「笈摺草紙」に焦れてゐるとは想像出來ないから。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は其後泉先生及び永井荷風先生の作品の出てゐる古雜誌は一切云ひ値で買ふ事にしたが、他日、「笈摺草紙」を手に入れてから十年以上もたつてゐる今日に到つて、未だ彼の神田の夜店の古本屋のおやぢの姿を、憎惡の念を抱かずに思ひ出す事は出來ないのである。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時或席で右の「笈摺草紙」を買ひそこなつた話をした。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "「笈摺草紙」を手に入れそこなつた自分の失敗談を冒頭にふつて、梶原君が「日本橋」を手に入れた一事を購書美談として世の人に傳へようと思ふ。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "笈摺を背負った六部であった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡礼というのは、まだ三十歳ばかりの女で、菅笠、手甲、脚絆、笈摺、みなさっぱりしたみなりでしたが、胸に赤ん坊をだいていました。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内二十両はぴったりと腹帯肌襦袢に縫付けて人に知れぬように致し、着慣れませぬ新らしい笈摺を引掛け、雪卸しの菅の笠には同行二人と書き、白の脚半に甲掛草鞋という姿で、慣れた大工町を出立致しまする。",
              "citation": {
                "source": "敵討札所の霊験",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "登路は池の平、赤倉、燕等の各温泉を出発点とするに従って異なるが、孰れも心岳から前山に連る尾根上の小平地天狗平に於て相会し、それより心岳の登りとなり、笈摺、貝摺などいう峻坂を鉄鎖に依りて攀じ上り山頂に至るのである。",
              "citation": {
                "source": "那須、尾瀬、赤城、志賀高原",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
