        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "牧羊者の祖先が山地の住民であったためか、それとも羊を追い回しおおかみでも追い払うために使われたものか、ともかくもいわゆるステッキとはだいぶちがったものである。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると、家主にも不憫が出て、たってこの親子を追い払うわけにも行かなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眠けを追い払うためには実際この一杯のコーヒーが自分にはむしろはなはだ必要であったのである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は追い払うように左手を振った。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前等を追い払う心は無くなった……それをまた何故にお前等はそのように肩をせばめて逃げて行くのだ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、この母子が折々に里へ出て物を乞う時、快く之に与うれば可矣、若し情なく拒んで追い払うと、彼等は黙って笑って温順く立去るが、其家は其夜必ず山を手先に遣うとも伝えられた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は、持って居たフォークの先で、何か執拗なものを追い払うような手つきをした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、ふと、隣室の母を見ると、母は口を力無くあけて肩で二つ三つ荒い息をして、そうして、痩せた片手を蠅でも追い払うように、ひょいと空に泳がせた。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくすれば此敵安く追い払う事が出来るぞ」と下知して戦ったが、ついに手負｜数多で討死した。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はホズマ・エインジェルとして現れ、自分を愛させることで他の恋人候補を追い払う。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草綱目』に越地深山に治鳥あり、大きさ鳩のごとく青色で樹を穿って寄生の枝もて追い払うた、爾後虎はプレ神の敵となり※寄生を滅ぼさんとすると蛇これに加勢した。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて張る気は他の悪気を追い払うものであるから、一気大いに張る時は種々の悪気は掃蕩されて、自然と精神状態及び身体状態を一新する。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばらしく自尊心は強くても、現在の国の長官の一族以外にはだれにも尊敬を払わない地方人の心理を知らない入道は、娘への求婚者を皆門外に追い払う態度を取り続けていたが、源氏が須磨に隠栖をしていることを聞いて妻に言った。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁村の住民たちが貴人の居所を気にかけて、集まって来て訳のわからぬ言葉でしゃべり合っているのも礼儀のないことであるが、それを追い払う者すらない。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいわく、アゼンスに八十まで生きた騾あり、かつて堂を建つる時この老騾を免役したが、自ら進んでその工事を助けたから城民大いに悦び、議定してどの家の穀を食うとも追い払う事なからしめたと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夷人の利器によって夷人を追い払うのだ」　寅二郎は、熱海の湯の宿で作ってくれた大きい握り飯をほおばりながら叫んだ。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一の小学校の同級生は、ほとんどが商人の子どもで、彼らの姉さんというのは、弟たちのすがたを見ると、あっちへいけ、と追い払うことになっていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは私の病気を恐れている彼の女の心をためすためにも、彼の女を大急ぎで追い払うためにも、是非必要だったのです。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣をぬいて追い払うと、猴はしりごみして立ち去った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつは高飛車に出て、一遍で夫人を追い払うのがいいと思った。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬どもはみな追い払うた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけて今夜の怖ろしさ、わたしは生きている心地もなかった」「関白殿のお屋形には犬を飼うておられぬか」「わたしは犬が大嫌いじゃで、殿に願うて一匹も残さず追い払うてしもうた」「犬もおとなしければ可愛いものじゃが、群がって来て人を噛もうとする、そのような野良犬は憎いものじゃよ」と、千枝太郎も言った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前から祈祷を頼みつけていて、物怪を追い払うのに得意な律師が叡山の寺にこもっていて、京へは当分出ない誓いを御仏にしたというのを招くのに都合がよかったからである。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それもすぐ彼は追い払うことが出来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この皆の国から蠅を追い払う努力だけでも、人人のこれからの役目は大変な力が要ると矢代は思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国人はぜんぶおいはらうにかぎるよ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
