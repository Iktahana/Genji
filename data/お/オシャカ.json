        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "死んでこの竜は天上にうまれ、後には世界でいちばんえらい人、お釈迦様になってみんなに一番のしあわせを与えました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときの虫もみなさきに竜の考えたように後にお釈迦さまから教を受けてまことの道に入りました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにしてお釈迦さまがまことのために身をすてた場所はいまは世界中のあらゆるところをみたしました。",
              "citation": {
                "source": "手紙　一",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神将のＢ　――して見ると阿難の美しさは感情を攪きまわす器械でお釈迦さまの美しさは感情の水｜漉し器械だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釈迦様より間違いのない事を云うわ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠藤さんが扉を覗いて、袖で拝んで、「お釈迦様と、お閻魔さんとは、どういう関係があるんでしょう。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫も殺さぬ大慈大悲のお釈迦さまだって、そのお若い頃、耶輸陀羅姫という美しいお姫さまをお妃に迎えたいばかりに、恋敵の五百人の若者たちと武技をきそい、誰も引く事の出来ない剛弓で、七本の多羅樹と鉄の猪を射貫き、めでたく耶輸陀羅姫をお妃にお迎えなさったとかいう事も聞いている。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庭にいっぱい人がいて、おれの笛くらいの大きさのお釈迦さまに、あま茶の湯をかけておりました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚く、黒人式にむくれ返った唇の周囲をチョビ髭が囲んでいて、おまけに、染めた頭髪は（禿は何処にもないのだが）所によってその生え方に濃淡があり、一株ずつ他処から移植したような工合であって、またそれが短いくせに、お釈迦様のそれのようにひどくねじれ縮れているのだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は交通が不便でありましたために、お釈迦様やイエス様は、その当時の文化の先進国たる埃及へ洋行された事はなかったものと見えます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の姿像のうちには、胸ややあらわに、あかんぼのお釈迦様を抱かるるのがあるから、――憚りつつも謹んで説おう。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釈迦様より間違ひのない事を云ふわ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "基督敵同前の説が仏教にもありとはお釈迦様でも気が付くまい。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "――花御堂の灌仏会、お釈迦さまも裸になって、善男善女が浮かれだして、赤い信女がこっそり寺の庫裡へ消えて、数珠と杯を両手の生き仏から怪しい引導を渡されるのもこの月にしばしば聞くうわさの一つです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっそり裏手から船をつけて、尾のあるきつねが日参りするたア、これこそほんとうにお釈迦さまでもご存じあるめえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――考えてみりゃ、きょうはお釈迦さまのお生まれなさった日のはずだったが、それだのにあんな罪劫の深いやつらがいるところを見ると、まだご功徳がお足りなさらねえのかな」",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用駕籠なぞに納まって、なんにするかと思ってましたが、出入り禁止の見張りのがれに使うたあ、お釈迦様でも気がつきますめえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "お番所勤めをしている者がばくちをやるといっちゃ聞こえがわるいが、そこはそれ、お釈迦さまのおっしゃるうそも方便というやつさアね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番に飛び出したのは真っ黒々の唐金のお釈迦様でした。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は欲ばりの大人に拝まれるよりも、こんなに親切な子供達に可愛がられる方がよっぽどうれしゅう御座います」　皆はパチパチと手をたたいて、お釈迦様の演説に感心をしました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私もお釈迦様と同じように誕生日には子供たちに可愛がられます。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お釈迦様とイエス様のお話が済むと、七福神が揃って飛び出して「七福踊り」というのを踊りました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――監督は、これではもう今までのように「お釈迦様」のようにしていたって駄目だ、と思った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お釈迦様はそうおっしゃッていなさる。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように暗号には、鍵の数字というやつが大切なのですが――いや、お釈迦さまに説法のようで恐縮ですが――これがまた厄介なことに、一ヶ月ごとにひょいひょいと変る。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "タゴオルが若しか涅槃の国へでも往つたら、早速訪ねて往つて、お釈迦様か阿弥陀様かに紹介状を認めて貰ひ度いといふのは、かういふ日本人に一番多からう。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば地球では今は、お釈迦様の時代です。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしお釈迦様は未来永劫この世界を支配するのではありません。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お釈迦様の年代は、いろいろ異論もあるそうでございますが、多く信ぜられているのは正法千年、像法千年、末法万年、合計一万二千年であります（五三頁の表参照）。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏滅後（お釈迦様が亡くなってから後）の最初の五百年が解脱の時代で、仏様の教えを守ると神通力が得られて、霊界の事柄がよくわかるようになる時代であります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
