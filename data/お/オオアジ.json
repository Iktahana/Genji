        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "であるから氏郷の佐沼の後詰は辺土の小戦のようであるが、他の多くの有りふれた戦には優った遣りにくい戦で、そして味わって見ると中々｜濃やかな味のある戦であり、鎗、刀、血みどろ、大童という大味な戦では無いのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝上時代にも人物画を描かなかつたといふことではなく描いてもゐるし、その画中の人物たちは大味ではないが、それぞれ何かしら特長的な味を出したものを発表してゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "味は一體に大味ですが、色や形には誠に見ごとなのゝ多いのが特色です。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "大味のようならこっちも大味、小味に出ればこっちも小味、むっつり右門にゃいくらでも隠し札があるぜ」「恐れ入ってござります……」「恐れ入っただけじゃわかりませんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次へと搬ばれてくる大味な料理をどんどん片づけながら、帆村は壁に貼ってある時間表へしきりに目をやっていた。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し大味でなければならない。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも大きな者は大味で、小さな者は小味だ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊池の小説は大味であっても、小説としてちゃんと出来上っている。",
              "citation": {
                "source": "合理的、同時に多量の人間味",
                "author": "――相互印象・菊池氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の雪は、大味だよ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "童顔で、いまの日本人には誰にもないような、茫乎とした大味なところがある。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに妙な田舎田舎したすしやに行き、大味氏□に行き、錦輝館に行ったら夜の六時からでだめ。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りに父さまが四かどでまって居て下さったので、そのまま大味氏へ行き、竹葉で食事をして三越へ行く。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の秀れた技巧を包蔵している大味である。",
              "citation": {
                "source": "九代目団十郎の首",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、荒波に身を粉と砕いている上に、外洋には餌となるべき蝦や烏賊が少いためであろうが、居付の鯛に比べて肉の組織に細かいところがなく、舌触りが粗荒で、味が大味である。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以上に大きく育ったものは、第一香気が失われ、大味で不味い。",
              "citation": {
                "source": "鮎ははらわた",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひらめの洗いづくりもやられないことはないが、東京のひらめは大味で、且つ平凡だ。",
              "citation": {
                "source": "洗いづくりの世界",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "孟宗の終るころ、はちく・やだけ・まだけが出て、孟宗の大味にひきかえ、乙な小味を楽しませてくれる。",
              "citation": {
                "source": "筍の美味さは第一席",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　巷間ありふれた中国料理を是認してみたり、トンカツという大味なものを食って、なんのいぶかりもなく暮している今の日本人。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから上は大味で、美味いもの食いには駄目だ。",
              "citation": {
                "source": "料理の秘訣",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところ、堂々としていても、本節は大味で、値も亀節の方が安く手に入る。",
              "citation": {
                "source": "だしの取り方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいについて申しましても、四、五百｜匁のところがちょうど美味本位に当たるので、一貫目から一貫目以上になると、非常に味が大味になります。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのはなんに用いても、大味で駄目なものだ。",
              "citation": {
                "source": "鱧・穴子・鰻の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚はタコマで折々海へ釣りに行ったり、また大西洋岸のものも口にした事がありますが皆｜大味で、日本近海の肴のような美味いものはありません。",
              "citation": {
                "source": "亜米利加の思出",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼奴騒々しい石塊だ哩」とアフリカを踏破したスタンレーのような、大味な冒険心の持ち合わせはないが、騒々しい石塊の眼の前で、その雑音を封する可く、喉仏の見える迄口を開け、笑殺一番するくらいの、小味な冒険心なら持っている。",
              "citation": {
                "source": "小酒井不木氏スケッチ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、平次も今度は大味噌をつけたよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「舞台のまんまの、舞台もふだんもちッとも違わない、気のいゝ、ごく大味な……」　すぐ、また、田代のそばからそういいかけるのを「黙ってろよ、うるさい。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家中の者十六人、それに町内の者が二十人ばかり、女が多くなるように集めたのは、与作の大味噌でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "多計代の着物や帯のこのみも大味で、縞でも多計代は大名縞を、娘の伸子の方がこまかい吹きよせの縞をきるという風なちがいがあった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
