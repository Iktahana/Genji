    "definitions": [
      {
        "index": 1,
        "gloss": "visit (to a shrine, grave, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
