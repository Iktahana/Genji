        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「勝ちさびに天照大御神の営田の畔離ち溝埋め、また大嘗きこしめす殿に屎まり散らしき」というのも噴火による降砂降灰の災害を暗示するようにも見られる。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天照らす大御神、皇祖、皇祖かくぞ、　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だから、どうしても天照大御神を中心に、お祭りするのがほんとうでないかと思う。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "心も空に　　　　ダンテ・アリギエリ心も空に奪はれて物のあはれをしる人よ、今わが述ぶる言の葉の君の傍に近づかば心に思ひ給ふこと応へ給ひね、洩れなくと、綾に畏こき大御神「愛」の御名もて告げまつる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテ・アリギエリ心も空に心も空に奪はれて物のあはれをしる人よ、今わが述ぶる言の葉の君の傍に近づかば心に思ひ給ふこと應へ給ひね、洩れなくと、綾に畏こき大御神「愛」の御名もて告げまつる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに神代紀に載つて居る傳説では、最初から天照大御神と素戔烏尊とが兄弟であり、又天菩比命も天照大神の子であるといふ風に神話が形作られてある。",
              "citation": {
                "source": "女眞種族の同源傳説",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "一天｜万乗の大君の、御座の側らにこの后がおわしましてこそ、日の本は天照大御神の末で、東海貴姫国とよばれ、八面｜玲瓏の玉芙蓉峰を持ち、桜咲く旭日の煌く国とよぶにふさわしく、『竹取物語』などの生れるのもことわりと思うのであった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は十一、二歳から歴史と文学書とが好きで、家の人に隠して読み耽ったが、天照大御神の如き処女天皇の清らかな気高い御一生が羨しかった。",
              "citation": {
                "source": "私の貞操観",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰はく皇祖天照大御神が女性の御身を以て、高天ヶ原に君臨せさせ給ふ事是なり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神典を通讀するに男尊女卑の精神は全篇に※滿するにも拘らず、大御神が女神を以て天上の君主と仰がれ給ふは、一見甚しき矛盾なり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於てか大御神は男神にして女神にましまさずとまで思惟する者あるに至る。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て神話傳説は國民の理想を述べたるものにて、當時の社會の精神風俗等は、悉く其の中に包含せらるるものなるが故に、皇祖發祥の地たる九州に於いて、上古卑彌呼をはじめとし女子を以て君長たりしもの其數を知らずとせば、大御神が女神として、天上に照臨し給ふも、亦何の怪むべきことかこれあらんや。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "神典の中天安河の條はよく大御神の御資格を表はすと共に、また當時の社會の状態を示すを以て、左にその一段を引用せん。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "云々　此文を以て之を觀れば、大御神は高天ヶ原に於いて至高の神にましませど、敬神の念深くして祭祀を重じ、御自らまた天神を祀らせ給へり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して大御神が天神に奉侍せしさまは、宛も後世倭姫命が大御神に奉侍せしと毫も異なかりしなり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『倭姫命世紀』は後世の作に係れど、その神衣祭の由來を記せる一段は、上古の制度を傳へたるものにて、大御神が天神に奉侍せしさまも、又卑彌呼などが神祇を祀りしさまも、之によりて其一斑を窺ひ得べければ、左の一節を拔載せん。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩は此等の記録に徴して、大御神が敬神の念甚深にして祖宗に孝順なるの故を以て、天上に君臨し萬神を統御し給へるを知ると共に、卑彌呼が九州に於いて一國の尊崇を受けしも、全く同一の理由に因るものなるを信ず。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し卑彌呼は下界の小君長に過ぎざりしかども、大御神は天上まします至高至尊の神にして、日輪を玉體となし、長へに下土に照臨し給へり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩は大御神の風姿を拜み奉りて、功徳の盛なるを欽慕すると共に、また太陽崇拜の我國民の根本思想たりしを思はずんばあらず。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つら／＼神典の文を案ずるに、大御神は素戔嗚尊の荒らき振舞を怒りて、天岩戸に隱れさせ給へり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に於て八百萬神達は天安河原に神集ひに集ひて、大御神を岩戸より引出し奉り、次で素戔嗚尊を逐ひやらひしかば、天地再び照明となれり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそも天上皇帝とは、この天地を造らせ給うた、唯一不二の大御神じゃ。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大御神を知らねばこそ、方々はかくも信心の誠を尽して、阿弥陀如来なんぞと申す妖魔の類を事々しく、供養せらるるげに思われた。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同母兄弟をイロセということ、古事記に、「天照大御神之｜伊呂勢」、「其｜伊呂兄五瀬命」等の用例がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男神ジオニソスや女神ウェヌスの仲間で、霊魂の大御神がわしじゃ。",
              "citation": {
                "source": "痴人と死と",
                "author": "ホフマンスタアル　Hugo von Hofmannsthal",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は豊国神社の主神と交通があるところから見ると、神ながらの道に通じ、あるいは天照大御神のご託宣によって、市長になったのかも知れない、あまり乱暴なことを言うてはいけないと言うのであった。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達とて矢張り御神前に静座して、心に天照大御神様の御名を唱え、又八百万の神々にお願いして、できる丈きたない考えを払いのける事に精神を打ち込むのでございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の私どもの境涯からいえば、最高のところは矢張り昔から教えられて居るとおり、天照大御神様の知しめす高天原の神界――それが事実上の宇宙の神界なのでございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまてらすおおみかみの頃には、こんなに人もあまってはいなかったのだろう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまてらすおおみかみさまは裸で岩戸からのぞいておいでになる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
