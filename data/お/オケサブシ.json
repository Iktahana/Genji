    "definitions": [
      {
        "index": 1,
        "gloss": "style of Japanese folk song associated with Niigata Prefecture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おけさ節も出れば、いそ節、ほうかい節、しののめ節も出る。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さみしい夜が、お隣の蓄音器によつて賑つた、唐人お吉、琵琶歌、そして浪花節だ、やつぱりおけさ節が一等よかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "おけさ節に、インタアナショナル、北大校歌に、オリムピック応援歌、さては浪花節に近代詩といった取り交ぜで、興がわくままに大声はりあげ、しかも音痴はこの上なしというのですから、他人には見せも聞かせもしたくない、のんびりした阿呆らしい風景でした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはそこの「おけさ節」で、もっと広く知られているかも知れません。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想は愚か、小原ぶしやおけさ節や、娘まで都會に捧げてしまつてゐるのだ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へばおけさ節といひ、小原節といつた所で、今日のおけさ節は越後のものではない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
