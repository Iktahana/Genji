        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "馬もびっくりしましたぁね、（おいどいつだい、何の用だい。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうしたのか。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マリオは、こゝから三百里も北ですから、よほど涼しい訳ですが、やっぱり仲々蒸し暑いですからね、私は給仕に、「おいどうしたんだ。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授はあきらめて落着いて、「おいおいどうしてくれるんだ――給仕にも何にもまだ膳が来ないではないか。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともう一つ私が感心したのは、祇園や先斗等の柳の巷の芸者や妓たちが、客から、おいどうだ、何か買ってやろうかとか、芝居へ連れて行てやろうかとか、こんどまた来るよ、などと言われた時に使う「どうぞ……」という言葉の言い方である。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は笑いながら、「おいどうした」と聞く。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃあれっきりのお茶番と思ってましたが、じゃいくらかあいつにほしのにおいがするんですね」「においどころか、ばりばり障子をひっかいた音っていうのは、そのさるなんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "にらみ合っただけで一合も渡り合わずに、突然江戸錦がぷいと立ち上がって、にたり微笑を漏らすと、「おいどんが負けでごんす」　つぶやきながら、さっさとたまりへ引き揚げてしまったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおいどうしたんだい。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうした、どうした」　と、私は近づきながらたずねました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうした」　と云う声がして、また一人人影が浮き出した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうした、陶器師殿、痩我慢なら止めるがいい。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端に水を汲んでいる女衆や、畑から帰って来る男衆は、良平が喘ぎ喘ぎ走るのを見ては、「おいどうしたね？",
              "citation": {
                "source": "トロッコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端に水を汲んでゐる女衆や、畑から帰つて来る男衆は、良平が喘ぎ喘ぎ走るのを見ては、「おいどうしたね？",
              "citation": {
                "source": "トロツコ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうだ」　かれはへびを口からはきだしてからみんなにいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "……姐さんあんたから上げておくれよ」　で、わたしはホッといたしまして、胸をなでおろしましてございますが、不意にその時わたしの横手で、「おいどうだった？",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹田街道の立場茶屋で、「おいどうだった？",
              "citation": {
                "source": "犬神娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいどうする引くか厭か？",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺らのお株を奪っていやがる」「女を誘拐かし担いで行く、俺らの昔の商売だったっけなあ」「素人にやられてたまるものか」「それもよ、ご両人の眼の前で」「それも二本差しがやってるんだ」「おいどうする？",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうした」「大いに深刻な顔をしているじゃないか」　紙洗大尉は、二人の友人の問を、其儘聞き流して、ジッと立っていた。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が、何だ、例えば木谷さんと恋をして、世帯を持って、願いが叶ったとして、それから、暫くたって、昔馴染のお客さんなんかに出逢って、おいどうだい、なんて話しかけられたとしたら、嬉しいか嫌か……まあ嬉しい方が多いだろうよ、ねえそうだろう。",
              "citation": {
                "source": "阿亀",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈没「おいどうした。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうだい、此の頃は。",
              "citation": {
                "source": "生あらば",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうしたんだ。",
              "citation": {
                "source": "未来の天才",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ショペンハウエルやスペンサーに至ってはまるで小僧っ児扱いで、親爺然と肩でもぽんと叩いて、『おいどうだい、スペンサー』といった調子だ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいどうする、行くか厭か？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大名方のなさることは、おいどもにはわからん」吉之丞は呟き、考えてもわからないことは考えないほうがいいと、邪念を払うように強く頭を振った。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいどうした」　クロチルドは死んでいた。",
              "citation": {
                "source": "海難記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞなびいてやりてえものだが――おいどうしたえ、いやにすましているじゃあねえか」　女はちらと眼を動かした。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
