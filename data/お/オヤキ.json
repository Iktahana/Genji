      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "base unit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幼い娘が、何を理解することもまだできぬままでそちらへ行っておりますが、邪気のないものとしてお許しになってお世話をおやきください。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒鯛は、おかあさんがおやきになりました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで、ミツ子がどんなにまきの手をふさぎ、そのために「おやき」の商売も減って来たかということを、勇の筆跡で細々くどいてよこした。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川風が凍みるからと云って、焼き立ての「おやき」の熱いところを懐へ入れ、それを喰い喰い夜遊びから帰る若者が減るのは当然のことであった。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小銭がつかえる者は「おやき」をやめて、ワンタン屋の屋台に入った。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出したように祖父ちゃんに向って、「――おやきの鉄板どうしたかね？",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、祖母ちゃんに、「おやきの道具、あんげなものでも売らねばよかったナ」　そう云っている祖父ちゃんの声がきこえた。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにしても、本来、筋のよからぬ会社のことだからな」「まア、まア、おやき遊ばすな。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやきゃつは友吉ではないか」たしかに一人は友吉であった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に、お角さんの威勢に怖れて、明らかには笑ったり、そしったりしないけれども、この気色を見て取って、お角さん自身が、こいつは少し恥を掻いたかなと、なおやきもきする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
