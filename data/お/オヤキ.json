[
  {
    "uuid": "e8d7ab56-bf56-54c3-805d-a30204e20c72",
    "entry": "親機",
    "reading": {
      "primary": "おやき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
