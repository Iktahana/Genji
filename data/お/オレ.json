    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人によつて色々異ることと思ひますが、私は詩に就いては自分に分るやうにだけは考へますが、それを人に分らせようとするや大変骨が折れます。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道を折れて、少し下り坂になる道をスタコラと歩いてゆくと、街道でしてゐた豆腐屋の喇叭の音は急に聞えなくなり、道の傍の、森の葉擦の音に私は淋しくなるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴と譬喩と、どうちがうか、それにさえきょとんとしている人がたまにはあるのだから、言うのに、ほんとに骨が折れる。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でその柄が折れてゐたら、ポンプは汲めぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それはあんたには分るまいが、お父さんも骨の折れた人だつたし。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして手の指が一本折れてるのをみた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋がなけりやあ、指も折れないし、シャツもズボンも世の中になかつたらう……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "オラーフが「すさまじい音をして折れ落ちたのは何か」と聞くと、エーナールが「王様、あなたの手からノルウェーが」と答えた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川は、やがて、左に折れて、農鳥山支脈の峡間に入って、益す狭く、石が次第に多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い、逞ましい喬木でも、心が朽ちているから、うっかり捉ると枝が折れて、コイワカガミや、ミヤマカタバミの草の褥へ俯ったりする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "焚火の烟は、油紙の屋根の継ぎ目から洩れて、白い柱が立っては崩れ、風に折れて地を這いながら、谷中を転げてゆく。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体を白く塗つてゐないから、白鳥とは見えないが、又鰭を振る魚とも見えない、船の長さ七間半、幅四尺、深さ三尺ぐらゐで、両方の舷側には、小さな穴を明け、棕櫚繩で、長さ九尺ぐらゐもあらうかといふ樫製の櫂を、左右に二挺結びつけてある、櫂の折れ目に鉄環でツギをあてたのもある。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　私は一つの重い計画を、行李の代りに背負って、折れた歯のように疼く足で、桟橋へ引っ返した。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい急坂を上る機関車のような、重苦しい骨の折れる時間が経った。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この岸壁だけを見ていると、実際｜天柱は摧け地軸も折れたかという感じが出るが、ここから半町とは離れない在来の地盤に建てたと思われる家は少しも傾いてさえいないのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この横町の奥にちょっとした神社があって、石の鳥居が折れ倒れ、石燈籠も倒れている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場近くの神社で花崗石の石の鳥居が両方の柱とも見事に折れて、その折れ口が同じ傾斜角度を示して、同じ向きに折れていて、おまけに二つの折れ目の断面がほぼ同平面に近かった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の入口に立っている煉瓦と石を積んだ門柱四本のうち中央の二本の頭が折れて落ち砕けている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地方では明治二十九年の災害記念碑を建てたが、それが今では二つに折れて倒れたままになってころがっており、碑文などは全く読めないそうである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋の所見によると塩尻から辰野へ越える渓谷の両側のところどころに樹木が算を乱して倒れあるいは折れ摧けていた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時気のついたのは附近の大木の枯枝の大きなのが折れて墜ちている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震のために折れ落ちたのかそれとも今朝の暴風雨で折れたのか分らない。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点から云えば非常に得なランプであるが、ただこの針金が脆くて折れやすいのが欠点である。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物園の門をはいってまっすぐに広いたらたら坂を上って左に折れる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りは少し骨が折れましょう。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝで折れては何にもならん。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おれには、どう仕様もない。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの凄惨な一声で、この団欒が滅茶々々になるのだ、と思ったら喉まで出かかった「助けて！",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の道や葵かたむく五月雨　曇暗の雲にかくれて、太陽の光も見えない夏の昼に、向日葵はやはり日の道を追いながら、雨にしおれて傾いているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『イヨー、大哥』『えらいぞ』『音羽屋ア』『やつちえねえ、骨はおれが拾つてやる』彌次馬の騷ぐこと、夕立の如し。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
