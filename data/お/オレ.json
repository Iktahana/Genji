[
  {
    "uuid": "6e90dda2-ca04-5761-a287-15938732f92d",
    "entry": "俺",
    "reading": {
      "primary": "おれ",
      "alternatives": [
        "オレ",
        "おらあ",
        "おり"
      ],
      "is_heteronym": true
    },
    "grammar": {
