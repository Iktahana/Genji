  {
    "uuid": "23263398-2e83-5ed1-ba93-188b8b8f29fa",
    "entry": "折れ",
    "reading": {
      "primary": "おれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
