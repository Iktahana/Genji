    "definitions": [
      {
        "index": 1,
        "gloss": "notice or order handed down from above",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "距離をその八尺ずつというお達しでさ、御承知でもございましょうがね。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君が踊りに加ったため、夜二時までとの警察のお達しが明け方まで忘れられた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君が踊りに加わったため、夜二時までとの警察のお達しが明け方まで忘れられた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「しかし順調にそこへお達しになろうとするのにはお慎みにならなければならぬ故障が一つございます」　と言った。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「城外へ漏れてはならぬゆえ、そのことくれぐれも心して、たち騒がずに見張りせいとのお達しじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日まえにまず増上寺へ正式のお使者が立って、お参詣お成りのお達しがある。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の内閣だったか忘れたが、少なくも浜口内閣でなかったことはたしかで、十二時限り営業まかりならぬというようなお達しは、その頃は出ていなかったから、十二時頃でも喜んで私たちを迎えたのであった。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草を吸いたくて手がひとりでにポケットにゆくが、この病室では煙草を吸ってはいけないというきついお達しを急に思いだしては手を戻すのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田さん、學校には、畏くも文部大臣からのお達しで定められた教授細目といふのがありますぞ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新田さん、学校には、畏くも文部大臣からのお達しで定められた教授細目といふのがありますぞ。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その橋普請の材料にこの曲がりトチが伐り出されるようにと、時の役人からのお布令が村にお達しになりました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十日出帆というのに、潮の工合で、二十日は早朝に解纜するから、十九日一ばいに乗り込むようにというお達しである。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "客は�T・Ａ社の自動車に乗せられて十一時に市の空中館を出るんだが、その十五分まえ、すなわち十時四十五分には必ず出頭するようにと前日社から電話でお達しのあったのは、つまり出発まえにこれだけの手つづきを済ます余裕を見ておくためだった。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌々年の明治二十五年にも同じ題材、同じようなイキで「四季美人図」を描いて展覧会に出品したが、これは前の勧業博出品の「四季美人図」が評判になったためであろうか、農商務省からの名指しで、始めからシカゴ博の御用品になされる由お達しがあり、六十円の金子が下げられた。",
              "citation": {
                "source": "最初の出品画",
                "author": "――四季美人図――",
                "note": "青空文庫"
              }
            },
            {
              "text": "税務署からは税金のお達しも来ました。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎの汽車で宮様が御通過になる由にて、線路添いの貧民｜窟の窓々は夜まで開けてはならぬ、と云うお達しが来る。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申すまでもないが、今夜は切らん」「何故、切らん」「お達し通りに、評定所へ出て、お由羅派の徒輩に、一言云いたい」「無駄じゃ」「無駄ではない」　隆左衛門が、眼を険しくした時、本田が「今、川北に逢って参ったが、話の外の沙汰じゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御奉行所から、お達しのあるまで、係り合いの者は、一足も動いちゃならねえと、この長屋の者まで、出ないでいるのに――困るなあ、私だって、忙がしい用事を控えて、そのために、こうして、来ているんだよ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "太政官のお達しにその様なことが見えたかな、とんと存ぜんな、降伏人どもは除族されとる、従ってあそこには貫属があろうわけはないぞ、はッはッは――自体そなたはどこから見えられた？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……で、もうお達しがありましたので？",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こっちで随意に選ぶようにとばかに寛大なお達しだそうで」「へえ、さようでございますかな。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでご相談に上りましたが、今年もいよいよ歳暮に逼り新年の仕度を致さねばならず、ついては洵に申し兼ねますが、お上のお達しに逆らわない範囲で草双紙をお書き下さるまいか。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日お達しを受けたのじゃ、老中罷免のお達しをな」「…………」チラリと意次の顔を見たままで、貝十郎は眼を垂れた。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そのうち紀州藩から、帰還せよというお達しが来た。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、追って何とかお達しがあるまでは、君は僕を船長と思っていてくれ給え。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "この磯崎は、鹿島灘の一番北の端を占め、しかも町全体が、ズーッと海の真中へ突き出ているから、監視哨には持ってこいの土地ですよ」「場所は、どこなんですの」「三ヶ所、作れというお達しでナ、岬に一つ、磯崎神社の林の中に一つ、それから磯合寄りに一つ、と都合三ヶ所、作りましたよ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが青竜王の日頃のお達しであったから。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田　　ほう、それやまた厳しいお達しだな。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "各村の社寺等の古文書を差しだすようにというお達しによりまして、庄屋の会合がありました折に、オーカミイナリのことまで考えたものはなかったのですが、蛭川さんがそれを言いだされまして、この機会に天狗の系図を見てやろうじゃないか。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、お母さまはおたっしゃですか。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
