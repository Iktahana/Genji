            }
          ],
          "literary": [
            {
              "text": "奈々ちゃんお先においでよ奈々ちゃんと雪子が叫ぶ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一時間ばかり、さらに談じかつ飲み、中倉翁は一足お先に、「加と男」閣下はグウグウ卓にもたれて寝てしまったので、自分はホールを出た。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "救助隊を出さねばなるまいという者もあったが、ナァニあの先生が捕虜になる気遣いはないと、一同は一足お先に那河川に架けたる橋を渡り、河畔の景色佳き花月｜旅店に着いて待っていると、間もなく杉田先生得意満面、一行の荷物を腕車に満載してやって来た。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お先に失礼します」　伝票を掴んでいた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ものの二十間も行かぬうちに、案内すると見せかけた客引きは、押していた自転車に飛び乗って、「失礼しやして、お先にやらしていただきやんす。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、さ、まあ――』『何卒お先に。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、硯友社より、もっと前、上杉先生などよりなお先に、一輪、大きく咲いたという花形の曙女史と聞えたは、浅草の牛肉屋の娘で――御新客、鍋で御酒――帳場ばかりか、立込むと出番をする。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳳山の大友｜吉統は、平壌囲まると聞くや仰天して、行長より一足お先に京城へ逃げ込んだ。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お先に」　長髪の男へそう挨拶して、少女のあとに随いて廊下へ出た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先に……」　言われて、豹一が玄関にはいると、女中が頭を下げていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々ちやんお先にお出よ奈々ちやんと雪子が叫ぶ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "のち程参りますから、お先にどうぞ」　そこの廊下先でばったり出会うと、何がどう分ったものか、目と目で物を言わせながら、二人してしきりに分り合っていた様子でしたが、間もなく前後して吸われるように、姿を消していってしまったところは、庭の向うのこんもり木立ちが繁り合った植込みの中でした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先に……」　怪しむようにふり向いた同僚たちの目に送られながら、名人は不審に首をかしげて、迎えの駕籠にうちのりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お妙さまからお先に話してやってくださいましよ」「…………」「お迷いなさらなくともよろしゅうござりまするよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、お先に失礼」　何かののしろうとしてつっ立ち上がりながら、二足三足追っかけてまいりましたが、右門はもうそのとき白扇で涼風を招きながら、さっさとお牢屋敷の表門を往来へ踏み出しているときでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おきのどくだが、今度はお先に失礼するよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかた、そのあわて方じゃ貴公たちも足を見つけたらしいが、今度はおれがお先に失礼するよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先に帰って、ゆっくりとお休みなせいよ」　わかったものか、伝六がまめまめしくいっさいを取りしきりましたので、右門はひたすらに、次の朝を待ちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえなお先にもぽつりぽつりと同じようなのが置いてあるというんでね、さっそく捜しさがし行ってみるてえと、なるほどあるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、お先に飛びおりますぞ」　つづいてヒラリ上がった退屈男共々、難なく二人は塀をのりこえて、屋敷の庭先に侵入すると、臆せずに近よっていったのは、心地よげに百姓達のくくされるのを見眺めていた十郎次の前です。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、どうぞお先に、うしろから送り狼が五六匹狙うているようでござりますゆえ、ちょッと追ッ払ってから参ります」　何者か編笠の中の正体を見届けようとつけ狙って来た小者の方へ、ずいと静かにふり向くと、パチンと高く鍔鳴りをさせました。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おきのどくだが、今度はお先にご無礼したな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾臺もの俥が置かれた順序なりにそれに續かうとすると、『どうぞ御縁の近い方からお先に願ひます、御縁の近いお方は前の方にいらして下さい。",
              "citation": {
                "source": "響",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親　あのう、たいへん睡くて、脳髄がお豆腐のようになりそうだと、こう申しますので、お先に寝かしてやりました。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "小泉が、「天野氏、どうぞお先に。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『兎に角僕はお先に失敬します。",
              "citation": {
                "source": "漂泊",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっそり、おさきに這入ってきたのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「女は、おさきに、とうしろで挨拶をする。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、おさきに失礼します。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽観論やら悲観論やら、肩をそびやかして何やら演説して、ことさらに気勢を示している人たちを岸に残して、僕たちの新時代の船は、一足おさきにするすると進んで行く。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
