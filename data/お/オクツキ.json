        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "御母堂の奥津城を展じたあとで。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女の逃れられぬ運命、それを食い止められぬおのれの無力さを悟った若者は、おのれもこの老いた農夫とともに静かに安らかに奥津城に横たわりたいと願う。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこゝに坑を穿てば「よし」といひて、たゞひとり闇穴道におりたちて、物陰の座にうちかくる、ひたおもて、地下の戸を、はたと閉づれば、こはいかに、天眼なほも奥津城にカインを眺む。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊死者のみ、ひとり吾に聴く、奥津城処、わが栖家。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "古井の傍に名もない墓などあると、真間の手児奈の奥津城どころ　と彼女は口吟んだものだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔は忽ち熾なり、とみれば、また、かつがつうちしめて滅し去る、怪みて人に問へば、これ各わが家の悲しき精霊の今宵ふたたび冥々の途に就くを愴み、そが奥津城どころに到りて「おくり火」焚くなりと教へられし一夜をわれは牧島村長の小高き阜の上の家に宿りたりし。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「公の薨後三百年、ことし、京都阿弥陀峯なる奥津城どころを修め、追弔紀念の祭典をあげたり、いささか公が御霊を慰むるものあらむか。",
              "citation": {
                "source": "松浦あがた",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――われも見つ人にも告げん葛飾の、真間の手児奈の奥津城どころ――お前様にはこの和歌をご存知でしょうな」「はい」　とお蘭は直ぐに申しました。",
              "citation": {
                "source": "真間の手古奈",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○われも見つ人にも告げむ葛飾の真間の手児名が奥津城処　〔巻三・四二三〕　山部赤人　山部赤人が下総葛飾の真間娘子の墓を見て詠んだ長歌の反歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "饅頭のかたちに土を盛り上げた新しい塚、「青山半蔵之｜奥津城」とでもした平田門人らしい白木の墓標なぞが、もはやそこに集まるものの胸に浮かんだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "親しい我が子の奥津城に、流す涙ははてもない！",
              "citation": {
                "source": "ランボオ詩集≪学校時代の詩≫",
                "author": "VERS DE COLLEGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀音　　　　　――故渡久地政佐君を悼みて奥津城の闇をもりたる、その底に君ねむる時、あやなくも時雨るゝまなこ、悲哀はたえず雫きぬ、年若かき愁ひをおびし、臨終のほそき泣き声――身動も得ならぬ思ひ、君ならで誰か知るべき。",
              "citation": {
                "source": "小曲二十篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなだるる眼ひらきて黄昏の空を仰げば奥津城の岩のほとりの、小山なす屍の上に、胸もどき声をきゝしる。",
              "citation": {
                "source": "哀詩数篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、或は無実の汚名をきせられて地下に眠って居る道子の為にも、奥津城に花の絶えぬように心がけて居ります。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "4415冷やかなる奥津城に、小さき妹我骨を埋めつ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "得ることのさはにあるべき望の糸を、断ち切りて奥津城の底深く墜しつ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人が安眠の地と考えている奥津城から究極の食屍鬼どもによってかすめ取られ、彼らの知識を吸い取ろうとする狂人連中の思うがままに扱われる。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼が自腹を切って、気の毒な『憑かれた女』の奥津城の上に建てたものである。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それから五年、今日ゆくりなくも見たあの墓は、才色一代を掩ったその日野涼子の奥津城であり、あの侘しい少年はこの薄命な音楽家の忘れ形見であると知っては、私も世の儚さに言い知れず打たれずにはいられなかったのであった。",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大木の下に小さな自然石の立ち並んだ様は如何にも没落した人達の奥津城らしく、何とはなしに哀れを誘う。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ山の中に葬つた、母のおくつきは彼處に近い。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、折角、私がおさがりを頂いたんですからね、あの塚から、」　その古塚は、あわれ、雪に埋れた名工と、鼓の緒の幻の陽炎に消えた美女のおくつきである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝やける手おくつきの砂よりけちえんの手くびは光るかがやく白きらうまちずむの屍蝋の手指くされどもらうらんと光り哀しむ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよ　おくつきに銀のてぶくろかがやき指はひらかれ石英の腐りたるわれが烈しき感傷にけちえんの、らうまちずむの手は光る。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がなく初恋人のおくつきに詣づるごとし。",
              "citation": {
                "source": "悲しき玩具",
                "author": "―一握の砂以後―",
                "note": "青空文庫"
              }
            },
            {
              "text": "真偽を道具屋にたしかめるために、祖母がついて、大橋を渡る半ばで、母のおくつきのある山の峰を、孫のために拝んだ、小児も小さな両手を合せた。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ山の中に葬った、母のおくつきは彼処に近い。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の歌に曰く、萩寺の萩おもしろし露の身の　　おくつき處こゝと定めむ　去つて、龜戸天神に詣づ。",
              "citation": {
                "source": "吾嬬の森",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "草青み目黒は政岡小むらさき　　　芝居の女のおくつき所　寺を語れば、行人坂の大円寺をも語らなければならない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
