          ],
          "literary": [
            {
              "text": "「お父ちゃん、春ってどんなもの。",
              "citation": {
                "source": "里の春、山の春",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉ちゃん、お父ちゃんが、お父ちゃんが、目が見えなくなるから、……ちょっと姉ちゃんを見てえってなあ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "シゲ子は、その頃になって自分の事を、何もこだわらずに「お父ちゃん」と呼んでいました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シゲちゃんには何でも下さるだろうけれども、お父ちゃんには、駄目かも知れない」　自分は神にさえ、おびえていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シゲ子はね、シゲ子の本当のお父ちゃんがほしいの」　ぎょっとして、くらくら目まいしました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お父ちゃんはね、お酒を好きで飲んでいるのでは、ないんですよ。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうでもないけど、……」「お父ちゃんは、きっと、びっくりするわね」「おきらいかも知れない。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、坊やとお父ちゃんは逃げてしまうのだよ」　文六ちゃんはびっくりしてお母さんの顔をまじまじと見ました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いんかいな」「わてのお父ちゃんやお母ちゃんどこに居たはんねん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父ちゃん、いたはる、しやけど、髭生やしたはれへんな」「当り前や。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十六やそこらで髭生やすのは東西屋だけや」「あ、お父ちゃん、お父ちゃん」　君枝はおどりあがっていたが、急に、「――お母ちゃん居たはれへんわ」　しょげた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんもお母ちゃんも居たはる」　そして、きんきんした声で、「――わて、もう親なし子やあれへんなア。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、誰も親なし子や言うて虐めたら、あけへんし」　その日から、君枝はだんだん明るい子になり、間もなく行われた運動会の尋二徒歩競争では、眼をむき、顎をあげて、ぱっと駈けだし、わてのお父ちゃんはマラソンの選手やった、曲り角の弾みでみるみる抜いて一着になった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんも今｜堅儀で、お光ちゃんの夢ばっかし見てはるえ。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっちゃん、ミネちゃんのお父ちゃんやな。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「わてのお父ちゃんやお母ちゃん何処に居たはるねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんもお母ちゃんもいる。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その日から、君枝はだんだん明るい子になり、間もなく行われた運動会の尋二女子の徒歩競争では、眼をむき、顎をあげて、ぱっと駈けだし、わてのお父ちゃんはマラソンの選手やった、曲り角の弾みでみるみる抜いて、一着になった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のお父ちゃんに叱られてから、お花なんざ引くまいと思って、水も沸したんでなくッちゃ飲まないでいたけれども、お母ちゃんはお暇が出たんですもの、体を大事にしたって詰らなくなってよ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しも分らないでした事だから、堪忍することはするッて、お父ちゃんもそうお言いだから、坊や、お前も酷いことをされて、鬼とも蛇とも思ってようけれど、堪忍して、母ちゃんと言って頂戴な。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、坊や、お父ちゃんが帰ってくるんだよ。",
              "citation": {
                "source": "父帰る",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父ちゃんが※」　お君は背中の子供をゆすり上げ上げ、炎天の下を走った。",
              "citation": {
                "source": "父帰る",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ねえ、絹坊一体お前の、お父ちゃんは無いのかい」「お父ちゃんは一人いるんだってよ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあたいはお父ちゃんの名前は知らないの。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって母アちゃんが教えて呉れないんだもの」「お前はそのお父ちゃんという人を見たことがあるのかい」「一度ちょっとだけ見たことがあるわ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「小母さんは帯をすると、頭が痛くなるからねえ」「フン、――僕のお父ちゃんも頭が痛いの」　私は、青と黄で捻ったしで紐で前を合わせていた。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに、坊やはどこの子だね」「お父ちゃんは、日本人でジョリジョリ屋だい」「ジョリジョリ※　ああ理髪屋さんだね。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、「おとうちゃん」と呼びかけては、何かしら片言で話している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁ぎわや太い柱の陰に桶や馬穴が汚物をいっぱい溜め、そこらに糞便をながし、骨を刺す異臭のなか「助けて　おとうちゃん　たすけて「みず　水だわ！",
              "citation": {
                "source": "原爆詩集",
                "author": "峠三吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん」「おとうちゃん」「おとと」「ちゃん」「ちゃっちゃ」――この呼び声！",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
