  {
    "uuid": "b151ae73-27de-5f87-bbe7-e3dd0f5184f9",
    "entry": "扇",
    "reading": {
      "primary": "おうぎ",
      "alternatives": [
        "おおぎ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
