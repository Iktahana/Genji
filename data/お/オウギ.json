      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "folding fan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "此処は銀座の裏通りのカフェー、卓子の上で扇風器は、哀しげな唸りをつづけてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――実は今日三田村さんからお話を聞きまして、とも角それでは御相談に上らうと存じまして……」云ひながら彼は扇子をパチリパチリさせてゐた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、玄関の式台には紋服を着た小坂吉之助氏が、扇子を膝に立てて厳然と正座していた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は扇風機を掛けて置いて煙草を吹かし始めた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんと、も一人の奥さんの親族の奥さんとは、扇を使ひながら、「扇風器もないのか……」つて顔をしてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は芭蕉の俳句中でひらひらと上る扇や雲の峯　を第一等の名作として推賞してゐたが、上例の如き自作の句を観照すると、芥川氏の芭蕉観がどのやうなものであつたかが、およそ想像がつくであらう。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "床し小扇　　　　　　誰がすさみぞや　これ優しぐさ『秋の恨み』と。",
              "citation": {
                "source": "絶句四章",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は店で団扇をつかいながら楽しげにこの様を見ている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "涼しい風が吹いて来て榊のゆうがサラサラと鳴り、檜扇がまた散った。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑い盛りだと下帯一つの丸裸で晩酌の膳の前にあぐらをかいて、渋団扇で蚊を追いながら実にうまそうに杯をなめては子供等を相手にして色々の話をするのが楽しみであったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と會釋し、鐵扇はらりと開き、屹つと月を見上げて、大樹の如く凝然と動かず。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "團扇が無數にひらひら動いてゐます。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東方を顧れば、箱根足柄にかぶさる雲から、雨脚のような光線が流れて、大裾野は扇の地紙のように、森や小阜の折目を正しくして、黄色に展開している。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "団扇のような胴船が、浚渫船の横っ腹へ、眠りこけていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ署の高等係中村は、もう、蚊帳の外に腰を下して、扇子をバタバタ初めていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一日俺もグッスリ眠りてえや」　彼等は足駄を履いて、木片に腰を下して、水の流れる手拭を頭に載せて、その上に帽子を被って、そして、団扇太鼓と同じ調子をとりながら、第三金時丸の厚い、腐った、面の皮を引ん剥いた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい袴を出し、新らしい足袋と白扇を進めて、それが威容の料とはならず、罪問ふ敵への礼儀とあらば、何たる切ないことであらう。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこは古い沖積扇です。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内一の財産家といふに、家内は祖母と此子二人、萬の鍵に下腹冷えて留守は見渡しの總長屋、流石に錠前くだくもあらざりき、正太は先へあがりて風入りのよき塲處を見たてゝ、此處へ來ぬかと團扇の氣あつかひ、十三の子供にはませ過ぎてをかし。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば轆轤に集中する傘の骨、要に向って走る扇の骨、中心を有する蜘蛛の巣、光を四方へ射出する旭日などから暗示を得た縞模様は「いき」の表現とはならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇紋は畳扇として直線のみで成立している間は「いき」をもち得ないことはないが、開扇として弧を描くと同時に「いき」は薫をさえも留めない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんはそれをあんまり悲しんでおうぎ形の黄金の髪の毛をきのうまでにみんな落としてしまいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くるみはみどりのきんいろ、な、　風にふかれて　　すいすいすい、　くるみはみどりの天狗のおうぎ、　風にふかれて　　ばらんばらんばらん、　くるみはみどりのきんいろ、な、　風にふかれて　　さんさんさん。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "射干は「ひおうぎ」「からすおうぎ」などいえる花草にして、ここは「照射して」の誤なるべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　雪之丞の官女が、花道の七三にかかって、檜おうぎをかざしたとき、東桟敷の紫幔幕の下に、そッとつつましく坐った、高島田の美女のひとみに、ありありと、讃嘆のかがやきが漲った。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇の巣でもあるが、春は香の好いツボスミレ、金蘭銀蘭、エゴ、ヨツドヽメ、夏は白百合、撫子花、日おうぎ、秋は萩、女郎花、地楡、竜胆などが取々に咲く。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうぎ形の槻板に、大きく屋号を書いた招牌が、さがっていた。",
              "citation": {
                "source": "元禄十三年",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "めいっぱい　めかしこんでて、　かたてには　しろの　かわてぶくろ　ひとくみ、　もう　かたてには　ちいさな　おうぎ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "てぶくろと　おうぎを　とりおとして、　ぜんそくりょくで　にげてった。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
