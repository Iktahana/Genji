              }
            },
            {
              "text": "アリスが　おうぎを　とりあげて　じぶんで　あおぎだしたんだ。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウサギが　てぶくろと　おうぎを　おとしたときのこと。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから　てぶくろも　おうぎも　ないままじゃあ　そりゃあ　ごぜんさまのところへも　おうかがいできない。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "いますぐ　うちに　いって、　てぶくろと　おうぎを　とってくるでおじゃる！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り口はきれいなおうぎ形になっていて、いろいろかざりがついています。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしの　もとで　五ねんあまり　こっくべんれいして、ぶっきょうの　おうぎに　たっしたと　いう　しるしです。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも　一休さんと　したしく　して　いる、みえいどうという　おうぎやの　ろうじんふうふが、ある日　とつぜん　一休さんを　たずねてきて、「一休さん、ながく　おつきあい　いただきましたが、このたび　わけあって　みせを　やめ、くにに　かえる　ことになりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その　ひろうに、今日　一にちだけ　おうぎを　かって　くださった　かたに、むりょうで　きごうします。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おうぎを　かえば、一休さんが　ただで　じを　かいてくださると　いうので、大へんな　ひょうばんに　なりました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おらもう飽きただよ、もうこんねえにしててもしようねえ、……すっかり飽きただから、おらこれでお暇にするだから、げっぷう、……檀家の衆によ、そいってもれえてえだ、みなさん、ええへへへん、だんだおうぎゃあ、……わかっただかね。",
              "citation": {
                "source": "百足ちがい",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
