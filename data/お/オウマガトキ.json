    "uuid": "d10b59c7-fbd7-5da8-8c1e-0df4d4b5a3de",
    "entry": "逢魔が時",
    "reading": {
      "primary": "おうまがとき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
