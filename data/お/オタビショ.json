        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「そうして、その相手の二人侍は、何者だか判らねえのか」「ひとりは本所の御旅所の近所に屋敷を持っている平井善九郎というお旗本ですが、連れの一人は判りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかみの少女見むとて街をゆく我ならなくに淋しきものを　　　　　　　　　○　祇園會の神興が御旅所に置かれてゐる間は、路へ向いた御旅所の軒にぎつしりと、高張提灯が掛けられる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして神輿が御旅所にある一週間は、參詣人が引きもきらない、この一週間に無言詣でをしたものは、どんな願の筋でも叶へられるといふことで、家を出るから往復の道すがらどんなことがあらうとも物を言はないで、お詣りするよき人もある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "御蔭森御旅所にて、音楽神供を観するもの有。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日には大神事として、八基の神輿が暗闇の中を御旅所に渡御とある。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "七基は二の鳥居前より甲州街道の大路を西に渡り、一基は随身門の前より左に別れ、本町宿の方から共に番場宿の角札辻の御旅所にと向うのであった。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣田村には前記の通り廣田八幡があり、廣田村字｜中條には同社の御旅所と向ひ合つて蛭子社がある。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも私の一番失望したのは、御旅所の芝舞台が臨時祭記にはちやんとした舞台としてあつたらしいことである。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時祭記の御旅所の舞台の図では、板の舞台でなければならないと思ふが、芝の様にも見える。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は八月十一日に御旅所を造り、九月に棟上を行つてゐるが、寺社雑事記時代は、原則としては、十一月廿七日だと思ふが、それさへ動揺がある。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十日（昔は大祓の日）には、堺の宿院の御旅所へ住吉の神輿の渡御がある。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其をり、神輿が堺の町に這入ると、本道の紀州海道は行かないで、わざ／＼海岸を迂回して、御旅所に達する。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄兵衛は、せっかちに問いかけて、「どうだった、身許がわかったか」　ひょろ松は、汗を拭きながら、「いえ、それが妙なんで、下ッ引を総出にして江戸中の尼寺はもちろん、御旅所弁天や表櫓の比丘尼宿を洩れなく調べましたが、家出した者も駈落ちした者もおりません。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、翌日より大工頭、下奉行等｜社家一同の先達にて、御本社、拝殿、玉垣を始め、仮殿、御旅所にいたるまで残らず見分。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "御旅所といって神さまが一週間ばかり他所に出張しておられる。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、通旗籠町に、御旅所を設けて、武州比企郡の修験者の玄沢坊というのが居りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "袈裟、兜巾姿に、一本歯の足駄をはき、釈杖を突き鳴らし、法螺の貝を吹きながら、町々を勧進して歩き、御旅所では信者を集めて祈祷などをして居りましたが、思いの外の信心を集めて、その頃神田日本橋一円の人気者になって居りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の大きな神社には、一まはり廻つて又もとの社殿へ戻つて来られる例も有るが、普通には御旅所又は御仮屋と云つて、そこに御出を迎へて一日又は一夜、御止め申して祭をする、臨時の祭場が出来るのである。",
              "citation": {
                "source": "祭のさまざま",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御旅所の所在は定まつてゐた。",
              "citation": {
                "source": "祭のさまざま",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "神屋御旅所等の社地以外の場所に、神幸を仰ぐものは別に名がある。",
              "citation": {
                "source": "祭禮名彙と其分類",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "くにたまの欅の並木たけびたち国つ神がみ武者押しすらし　五月五日の祭には夜八つの神輿が古式の行列をととのへ社殿の内外、氏子一同悉く消灯した暗黒のうちを御旅所へ渡御する。",
              "citation": {
                "source": "府中のけやき",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
