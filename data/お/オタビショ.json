    "definitions": [
      {
        "index": 1,
        "gloss": "place where the sacred palanquin is lodged during a festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
