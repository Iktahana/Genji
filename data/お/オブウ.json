      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to carry (a child) on one's back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "烏の行水みたいに早いおぶうである。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "味噌汁のことをおみおつけ、風呂のことをおぶう、香のもののことをおしんこ。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に小便臭いので暑くなって來るとおぶうのがいやでいやで仕方がありませんでした。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の啼き声を演ったあとで「ちょいとニャーニャーにおぶうを呑ませまして」いと軽く高座の湯呑みを取り上げて自らの咽喉をうるおす呼吸が愉しかった。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきぬ　（包をうけとり）少し行ったらあたしがおぶうよ。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おぶうって」私はしりごみをした、「それはだめだよ、おれは重いもの、だめだよ」　長は痩せていて十三貫ぐらいしかないようだし、私は春から少し痩せたものの、まだ十六貫くらいはあると思う。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そう……」月江はホホ笑みながら、次郎の肩へやわらかい手を廻して、「おまえ、私をおぶうときまりがわるいの」「だって、お嬢様は、女だもの」「でも、主従だから、人が見てもおかしくはないはずだろう」「だって女だもの。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to take on (a job, responsibility, etc.)",
