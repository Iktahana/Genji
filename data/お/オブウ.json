  {
    "uuid": "289d190a-674d-5d00-ae8a-466d09d8cf31",
    "entry": "負ぶう",
    "reading": {
      "primary": "おぶう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
