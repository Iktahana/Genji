        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "義雄は喧嘩のあとで意志が通じたと云ふいい氣持ちを味はひながら、電車を芝公園の御成門で下りると、向ふから海軍水路部の前を、弟の馨がいそ／＼とやつて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして御成門の電車停留所の方から傾斜をのぼつて來る男があると、どの男を見ても、先づ義雄の客ではないかと思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田から御成門までの切符代が無かつたのか、惜しまれたのかして、曾ては、その間を歩いて、夜中の一時半頃に我善坊へ歸つて來たこともある女だが、一緒になつてからは、こんなに遲くまで留守にしたことはない――と、かう思ひながら、渠は額を枕の切れに當てて、油あせを拭きつけた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇田川町で電車を下り、御成門の方へ一直線に急ぎ、またの電車線を横切つて、自分がきのふまで陣取つてゐたところに行つて見た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも渠はこの坂を向うへ越える氣になれないで、再び御成門の方へ引ツ返した。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "脇差を一本、提灯を一つ――芝中門前町を出て、増上寺の塀の闇の中を、御成門の方へ、歩いて行った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "御成門から、植村出羽の邸に沿って曲り、土橋へ出ないで、新し橋の方へ進んだ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "御成門まで来ると、一隊の練兵が粛々と練って来る。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の境栽の月桂樹の根元に、ルルがそとへ散歩にいくときの御成門がある。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝園橋で一度、御成門で一度、田村町で一度、日比谷の角で一度。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島町の角を、御成門の方へ、今の赤十字本社のある増上寺の學寮の前まで來ると、後ろからヒタヒタと跟けて來るらしい足音が聞えます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女を洗ひ出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島町の角を、御成門の方へ、今の赤十字本社のある増上寺の学寮の前まで来ると、後ろからヒタヒタと跟けて来るらしい足音が聞えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、竜之助様」　御成門外で人の足音、増上寺の鐘。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一「あの声は――」　今の絶叫を聞咎めたのは、御成門外で駕籠を捨てた宇津木兵馬の一行です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴鹿山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "来るときには御成門から入ったので、いちどまぢかに眺めたのである。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "御成門を出ると馬場があり、そのさきは武家屋敷がつづいている。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
