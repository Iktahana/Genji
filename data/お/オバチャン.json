        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お雪は眼の覚めた銀造を抱き擁えて、「へえ、伯母ちゃん、銀ちゃんを見て下さい」「オオ、温順だそうな。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母ちゃんがくるだろうから。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "待合室で待っていると、おばちゃんと声掛けられ、見ると、銭湯屋の娘たち五人が、いずれも子供を連れて写真をうつしに来ているのだった。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯屋の姉娘が、おばちゃんちょっとも痩せてはれしまへんなというと、おたかは、へえ、郊外で空気がよろしおまっさかい、おかげで肥えとオりまんねんと答え、そうして、これ見たっとくなはれと、赤ん坊を差しだした。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ訊いて、どないするちゅうネや」　さからっていると、もう炬燵のなかに、はいっていた君枝が、むっくり起き上って、「三味線もったはるおばちゃんやったら、乗らはった、乗らはった」　と、言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此間のおばちゃん、うちへ来やはるのん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、おばちゃん」　君枝は飴でおぼえていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君ちゃん、起きたんか」　婆さんはいつの間にか君枝の名を知っていて、「――いま、おばちゃん、御飯たいたげるさかいな、待っててや」「おばちゃん、今日からうちへ来やはるの？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばちゃん泣いたはった」「なんぜや」「芝居がかわいそうや言うて、泣いたはった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そない言うたかテ……」「おばちゃんが黙ってエ言うたんやろ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃん、どこイ行くねん」　と、君枝が随いて行こうとするのを、他吉はいつにない怖い声で、「阿呆！",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばちゃん今なんぞ言うたやろ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "羅宇しかえ屋の婆さんがくやみに来て、他吉の胸の上で御詠歌の鈴を鳴らし、「他あやん、良えとこイ行きなはれや」　と、言うと、君枝は寝床の裾につけていた顔をあげて、「おばちゃんお祖父ちゃんは、言わんでも、もうちゃんと良えとこイ行ったはる。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃん、京ちゃんどこへ行ったのか知らん……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃん、お酒のんだの……？",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばちゃんはもうあかん！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばちゃんは汚れちゃった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、言うと、君枝は寝床の裾につけていた顔をあげて、「おばちゃん、お祖父ちゃんは、もうちゃんと良えとこイ行ったはる。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記者は眼つきが悪いからと思ったほどでなく、陽気に子供じみて、蝶子を呼ぶにもマダムでなくて「おばちゃん」蝶子の機嫌はすこぶる良かった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おばちゃんに、接吻をして頂戴よ。",
              "citation": {
                "source": "接吻を盗む女の話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃんの足｜綺麗ね。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃんの家そんなでもない！",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おばちゃんは出て行った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おばちゃんどこへ行ったの？",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寅坊、このおばちゃんを覚えているかい。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前を可愛がったおばちゃんだよ」　羊羹の片を持たされた子供は、直にお島に懐いた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばちゃんに負けないでもっともっと大きい声で泣け、遠慮なんかしないで、汽笛の様な大きな声で泣くんだよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
