        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "娘の神は父の老翁に、こういう慮りから、宿は村里の誰かの家へ取ってあげますから、祭の今夜一夜だけは自分の家をば遠慮して欲しいと頼んだのであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠き慮りなき時は、近き憂ありとは、能くも云うたものじゃと我から自分を嘲ったのである。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり焦慮ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "某々四五人のものは、既に一身の運命の窮極を悟り、且つは共同の被告に累の及ばんことを慮りて、なるべく詞短に問に対する答をなした丈であつたが、之等は千万言を費しても動かすことの出来ない犯罪事実を自認して居たからである。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し春暖に至れば景隆の来り戦わんことを慮りて、燕王の請えるなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "手段は既に十分にととのい、敵将を追落し敵城を乗取ること、嚢の物を探るが如くになり居れど、ただ兵粮其他の支えの足らぬため、勝っても勝を保ち難く、奪っても復奪わるべきを慮り、それ故に老巧の方々、事を挙ぐるに挙げかね、現に貴殿も日夜此段に苦んで居らるるではござらぬか。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はいよいよ更けて、風寒きに、怪者の再来を慮りて、諸君は一夜を待明かさむ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは物語の昔日の過に及ばんことを慮りしに、この御館を遠ざかりたりしことをだに言ひ出づる人なく、老公は優しさ舊に倍して我を※待し給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "南宋の淳煕三年金国へ往った大使の紀行『北轅録』にも〈趙州に至る、道光武廟を経て二石人あり、首路に横たわる、俗に伝う、光武河を渡らんと欲し、二人餉を致す、その蹤を洩さんと慮りすなわちこれを除く、またいう、二人に遇いて道を問うに答えず、怒ってこれを斬る、すでにして皆石なり〉とある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌人が自分で深く慮り、すべて婦人の弟子に対する節は、いつもその紅、白粉、簪、細い手、雪なす頸、帯、八口を溢れる紅、褄、帯揚の工合などに、うっかりとも目の留まらぬよう、仰向いて眼を塞ぐのが、因習の久しき、終に性質となったのである。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "齢人生の六分に達し、今にして過ぎ来し方を顧みれば、行いし事として罪悪ならぬはなく、謀慮りし事として誤謬ならぬはなきぞかし。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別を訣げなば妨げ多からむを慮り、ただわずかに一書を友人に遺せるのみ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お峯は直道が言に稜あらんことを慮りて、さり気無く自ら代りて答へつ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はただに棄てざる恋を棄てにし悔に泣くのみならで、寄辺あらぬ貫一が身の安否を慮りて措く能はざりしなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国の大王、太子、大臣等に婚を求めたが、相師の予言を慮り、彼ら一向承引せず、ただ彼女を門窓｜戸※より窺う者のみ多くなり、何とも防ぎようがないので、長者早く娘を嫁せんとすれど求むる者なし。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと等しく鬼門の祟りなど凡衆にとって有無ともに確証を認めぬながら、君子は有るを慮り無しを慮らず、用心に越した事なしてふ了簡がほとんど天性となり居るところへ以て、蘇張の弁でその妄を説いたって容易に利く事でなかろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が上つ方においては例の有るを慮り無しを慮らざる用心から、依然旧慣に循わるるのであろう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に慮り左に慮りてろくろくに夢さへ結ばず。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "予、往を顧み來を慮り、半夜惘然として吾れ我れを喪ふ。",
              "citation": {
                "source": "人生終に奈何",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾輩はかねてこの危険を慮り、Ｔ市の鍵の模造品を用意して身辺に保管して置いたのだ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "６　氷山が近いので万一を慮り、機関を停めて静止していたキャリフォルニアン号の船橋である。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ロ）本年八月十日小洪水なりしも海老瀬村有志は谷中村堤防字移堤の危険を慮り自ら人夫を出して之を防がんとし同所に至るや、栃木県庁よりの間牒数名、堤上ニ在りて海老瀬村の人夫に対し「此小洪水に水防に来るハ痴愚なり」と放言し大に嘲罵を加へたり。",
              "citation": {
                "source": "非常歎願書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く理の實より小ならむことを慮りてなり、理想世界の現實世界より狹からむことを思議してなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは大理想の何物なるかを證すべからざるを慮りてなり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に聞けば、近年蘭法の医流大に開け来にける折、此侯までも信用し給ひなば、天下一般に蘭家にもなりなん勢なれば、さては又其弊害あらむことを深く遠く慮り給ひて、蘭家の長処は心得給ひにけれ共、余はよしあしにはよらず、天下のために蘭家の薬は服し難しとのたまひけるとなん。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は少なくとも自然の経済を重んじて、注意深い慮りをもってその犠牲者を選び、死後はその遺骸に敬意を表する。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い慮りとして、ベシイはこの良人の処置を悦んだが、案外それは近い慮りだったのだ。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる出來事を防がんため、小生は絶對的に必要なる場合を慮り、結末の場を變更したるものをランゲ氏まで送附いたし候。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいてか警察部長は万一をおもんぱかり、彼に向かってせつに集会を中止せんことを求めたけれども、元来彼ロイド・ジョージは、自ら反みて縮からずんば褐寛博といえども吾惴ざらんや、自ら反みて縮くんば千万人といえども吾｜往かんという流儀の豪傑なれば、なんじょうかかる事にひるむべき。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずこに露命は果てるとも測りがたいおもんぱかりから、この寺に残し置くべき辞世までも和尚は用意してある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
