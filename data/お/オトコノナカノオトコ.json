        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やくざは男の中の男じゃねえか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか、それでこそそのほうも男の中の男｜伊達じゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "天帝の愛子、運命の寵臣、人の中の人、男の中の男と世の人の尊重の的、健羨の府となる昔｜所謂お役人様、今の所謂官員さま、後の世になれば社会の公僕とか何とか名告るべき方々も出た。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に対して荒々しく君臨する男は、いつの時代も男の中の男とはいえませんでした。",
              "citation": {
                "source": "自然に学べ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさしくイブン・サウドこそは男の中の男である。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴんからきりまで男の中の男ですよ」　この清岡さんの言葉が胸を刺した。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、僕は精神の旅において「男の中の男」として振舞いたかったのだ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神の世界に住む「男の中の男」は、けっして八百長勝負はしない。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡魂この地にとゞまり、前歯に恨みの三十万円を書きしるして、夜ごとに骨壺をゴソゴソ騒がせるという吾吉は、男の中の男勇士かも知れない。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の中の男つてやつさ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に男の中の男を称えて裸百貫という諺があるが、金峰山も何処へ放り出しても百貫の貫禄を具えた山の中の山である。",
              "citation": {
                "source": "秩父の奥山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮名草紙で園部左衛門となっている大炊介は、男の中の男とでもいうような誠実な魂をもった大丈夫で、薄雪姫なる行子のほうは、自分の生きる道を愛の方則から学びとるほか、なにひとつ知らぬような純情無垢の女性である。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の中の男がうち込んで愛し得る男であり、ワレンシュタインがケプラーの例のない真情の表現に対し、心をひらき、自分は旧教の皇帝を擁立しながらプロテスタントのケプラーに指をささせなかった所以も肯けます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのところが我ながら妙な工合だと見えて、バルザックは、そこのすぽぬけのところを神秘主義でふたして居ります、人間の昇らんとする欲望、より高からんとする意欲、それはさすがにあれも男の中の男にはちがいないから、直感したのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴヤはヴェラスケスが描いたフィリップ四世のデカダンスの後をうけて全く崩壊したスペインに、愛着と憤怒とをもって作品をのこした画家で、あの時代として男の中の男というような男ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ鯉はほかの魚と違って、俎の上へ載せられても、三十六｜鱗ビクともせぬという、人間で言えば男の中の男、それが苦しがって器量いっぱいもがき苦しむのですから、そりゃ見ていても凄くなります」　棚を走る鼠としては温和しいと思うと、外ではこの時分から、時雨が古寺の屋根を濡らしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "東海道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、男の中の男ね」「コーラ、どういうこと」「あなたのやることよ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人の武大ときては、背も五尺たらずのちんちくりんでおまけに猪首で薄野呂で、清河県でも一番の醜男と笑われていたのに、武松の身長け隆々たる筋骨は、男の中の男にも見える。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
