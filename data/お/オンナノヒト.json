        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは恰度、音楽に鈍感な女の人が、オーケストラを聴いてゐて、フリュートなぞが単独に吹奏される部分でだけ、音そのものの物理的な快味にだけ感じ入るのに似てゐて、私は明治以降の殆んど全ての文学者が、外国文学の作品を読む時も、そんなやうなものであつたと云つても、強ち過言とは思はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな奇麗な手のお手紙を貰つた女の人が、此の世の中に幾人あるのか知ら？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとしばらくたってから、年老った女の人が、どこか工合が悪いやうにそろそろと出て来て何か用かと口の中で云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりわけ女の人の声には、どこか皮膚の表面を撫でるような、甘美でうっとりとした魅力があった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供を背負ッて帯を除して、兵隊の横を小走りに行く女の人を見る。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の人気が沸騰するにしたがって、ために暑気は加わるばかしだ。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その女の人相というのはちっとも判らなかったかえ」　その女が白地の手拭をかぶって、白地の浴衣を着ていたのは、お伊勢もたしかに認めたが、そのほかのことは夜目遠目でやはりはっきりとは判らなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふから女の人と子供がやって来る。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（この家はあのおじいさんと今の女の人と二人切りなようだな。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女の人は孫娘らしい。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとしばらくたってから、年｜老った女の人が、どこか工合が悪いようにそろそろと出て来て何か用かと口の中で云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の人が時々家へも来ることがあったが、その人は着物の着つぶしたのや端ぎれを持って帰るのだ。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその女の人はなによりも色濃い島の雰囲気を持って来た。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ――という女の人の私室である。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女の人は平常可愛い猫を飼っていて、私が行くと、抱いていた胸から、いつもそいつを放して寄来すのであるが、いつも私はそれに辟易するのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分行き倒れか転んで気絶をしたかした若い女の人を二人の巡査が左右から腕を抱えて連れてゆく。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩の時間を残しながら席に帰った私は、すいた会場のなかに残っている女の人の顔などをぼんやり見たりしながら、心がやっと少しずつ寛解して来たのを覚えていた。",
              "citation": {
                "source": "器楽的幻覚",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女の人が二人、洗濯物を大盥で濯いでいた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盥の方の女の人が待つふりをすると、釣瓶の方の女の人は水をあけた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへも緑は影を映して、美しく洗われた花崗岩の畳石の上を、また女の人の素足の上を水は豊かに流れる。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の人の造作をとやかく思うのは男らしくないことだと思いました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗っている女の人もただ往来からの一｜瞥で直ちに美しい人達のように思えました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗っている女の人もただ往来からの一瞥で直ちに美しい人達のように思えました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しまた可笑しかったのは、其巾着をさげて机の前に坐って手習をして居ると、女の人達が起ったり坐ったりする時に、動もすると知らずに踏みつける、すると毛がもじゃもじゃとするのでキャッといって驚く。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それにしても、女の人のあの無慈悲は、いったいどこから出て来るのでございましょう。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女の人は、きっと綺麗な夢を見ているのに違いない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
