        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "人に使われつけている身が主筋に対して、何ぞの愛嬌に、身うちのことを手柄のように暴露して、諂い阿る例は世間によくあり勝ちです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風流な家に住んで現代を誹謗して鹿を馬だと言おうとする人間に阿る者がある」　とお言いになって、報復の手の伸びて来ることを迷惑に思う人たちは警戒して、もう消息を近来しなくなった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "このいたいけな姿を憐れむのを自己に阿るものとのみ云い退けられるものであろうか。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして尚も母に逆に阿る為に、見るからに苦々し気な表情をして一座を眺め回した。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」などと私は、はつきり阿る心を承知しながら遠回しに祖母の歓心を買はずには居られなかつた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとに阿ることは間違つたことを言ふよりも遙かに惡い。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘吐くことでさへもが阿ることよりも道徳的にまさつてゐる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "僞善が阿るためにとる姿もまた無限である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少とも權力を有する地位にある者に最も必要な徳は、阿る者と純眞な人間とをひとめで識別する力である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが抽斎の心胸を開発して、劇の趣味を解するに至らしめた人々に敬意を表して、これを学者、医者、画家の次に数えるのは、好む所に阿るのではない。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、相変らず揉み手をしながら、阿るような鈍い柔らか味のある調子で云った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとに阿ることは間違ったことを言うよりも遥かに悪い。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘吐くことでさえもが阿ることよりも道徳的にまさっている。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽善が阿るためにとる姿もまた無限である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "多少とも権力を有する地位にある者に最も必要な徳は、阿る者と純真な人間とをひとめで識別する力である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、単純に来客に阿るからの言ひ表しでなく、神と考へられたものが人になり替つて来た為に、神に言ふまれびとを、人の上にも移して称へたのが、更に古く、敬意の表現に傾いたのは、其が尚一層変化した時代の事であつた。",
              "citation": {
                "source": "まれびとの歴史",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大日本史』の大業を成就して、大義名分を明らかにし、学問を曲げてまで世に阿るものもある徳川時代にあってとにもかくにも歴史の精神を樹立したのは水戸であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一月、「不同調」という雑誌に私は作品を発表したが、その流行に阿るような作品で、醜を曝したからである。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の亘は父がそんな事を思ひ悩んで居るとは知らず、親に阿る小供の技巧の、おづ／＼するやうな甘へた口調で、猶も問を進めて行つた。",
              "citation": {
                "source": "虎",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの屋上庭園は下まで六十尺もある、こんな時は高い建築も悪くないな」「それに、郊外の有難さで、お邸の外の家へは五六丁もあるから、余程大きい声を出しても聞えませんね」　黒津は男爵に阿るように、窓から夕暮の景色を眺め乍ら、こう言います。",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に求道心が燃えて居れば、自他に阿る心を焼きつくして、素朴な心にかえることが出来る。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように王に阿ることができる画題を美術家が見逃す筈はなかったがこの光景の絵が少ないことはこの習慣が英仏の２王家に限られていたからであろう。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり秀郷は尊大に構え、貞盛はそれに阿るのほかはない。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "万乗の大君をして、さまで幕府の鼻息に阿るような策をおすすめ申さいでも、毎日の公卿集議には、もそッとほかによいお智恵も」「…………」　後醍醐は、お耳をすました。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お世辞の失敗を取りかえそうとして、山名先生のモオツアルト礼讃の或る小論文を思い出し、おそるおそるひとりごとみたいに呟いて先生におもねる。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老耄儒者めが、家に引込んで、溝端へ、桐の苗でも植ゑ、孫娘の嫁入道具の算段なりとして居れば済むものを――いや、何時の世にも当代におもねるものは、当代の学者だな。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この相手に、おもねる為に彼はさう云つたのであるが、云つて見ればこれも偽りではないやうに思へた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の好みにおもねるではないが、東洋と西洋との文化をほんたうによく噛み碎いた彼の著作こそは、明治年代がわたしたちに遺して呉れた最もいゝ遺産の一つと言つていゝ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の利潤追求におもねるばかりであった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は与へすぎる、私は受けすぎる、与へて情におもねるなかれ、受けて恩になれるなかれ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
