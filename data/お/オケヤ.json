        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "縁があつても、まづ、風と桶屋くらゐの關係ぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは空風が吹いて桶屋が喜ぶというのと類似の詭弁に過ぎない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が吹いて桶屋が喜ぶという一場の戯談もあながち無意義な事ではない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六番目は誰です」　「追分け三五郎」　「七番は」　「尾張の大野の鶴吉」　「八番は」　「尾張の桶屋の吉五郎」　「九番は」　「三保の松五郎」　「十番は」　「問屋場の大熊」　「十一番は」　「よせやい、爺っつあん。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんこれは大風が吹いて桶屋が喜ぶというのと同じ論法ではあるが、そうかと言ってそういうことが全然ないということの証明もまたはなはだ困難であることだけは確かである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶屋の小僧の平太郎が蝙蝠の一ぴきを竿でうち落して、両翅を抓み拡げ、友達のなかで得意顔をしている。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思えば、桶屋の息子の、竹を削って大桝形に組みながら、せっせと小僧に手伝わして、しきりに紙を貼っているのがある。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶屋の凧は、もう唸って先へ飛んだろう。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "疣々打った鉄棒をさし荷いに、桶屋も籠屋も手伝ったろう。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何としても、これは画工さんのせいではない――桶屋、鋳掛屋でもしたろうか？",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏壇屋の隣に桶屋があつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶屋の隣に標札屋があつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁があつても、まづ、風と桶屋くらゐの関係ぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長女は北津軽のこの町の桶屋に嫁いでいる。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桶屋の小僧の平太郎が蝙蝠の一ぴきを竿でうち落して、両翅を抓み拡げ、友達のなかで得意顔をしてゐる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本町、在府町、土手町、住吉町、桶屋町、銅屋町、茶畑町、代官町、萱町、百石町、上鞘師町、下鞘師町、鉄砲町、若党町、小人町、鷹匠町、五十石町、紺屋町、などといふのが弘前市の街の名である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　こつちへ來る前にＨＹと君の居る桶屋さんの家を訪ねたが生憎お留守で殘念であつた。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この秋の取ッつきに、雷雨おびただしかりし中に、ピシャン、と物凄く響いたのを、昼寝の目を柔かに孫を視て、「軒近に桶屋が来ているかの、竹の箍が弾いたようじゃ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "節分の日、もうその歳ではいくらか気がさす桃割れに結って、源聖寺坂の上を、初枝が近所の桶屋の職人の新太郎というのと、肩を並べて歩いている姿を、他吉は見つけた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな不仕鱈な女をひとり放って置いて、比律賓へ行ってしまえば、どうなっていたことかと、他吉はひやっとしたが、間もなく行われた町内のマラソン競争で桶屋の新太郎は一等をとった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "マラソン競争のあった翌日、他吉はれいの上着のポケットに、季節はずれの扇子を入れて、桶屋の主人を訪れ、「早速やが……」　と、新太郎を初枝の婿にする話を交渉した。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、わいには異存はないけど、新太郎の奴がどない言いよりまっしゃろか」　桶屋の主人が言うと、「どないも、こないも、あんた、おまはんやわいの知らん間にあいつらもうちゃんと好いた同志になっとりまんねんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、新太郎は玉造で桶屋を開業したが見込んだ通り、働き者で、夫婦仲のよいのは勿論である。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度、立ち直って、桶屋をはじめる気もないらしく、また、職を探しに歩こうともしなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「玉造で桶屋してましたけど、失敗してマニラへ行って、死にました」　君枝はしみじみした口調だったが、顔はそんなに執拗い御寮人へ怒っていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの鯉を生捕ったのは新堀河岸の材木屋の奉公人、佐吉、茂平、与次郎の三人と近所の左官屋七蔵、桶屋の徳助で、文字友から貰った一朱の銀で酒を買い、さかなを買って、景気よく飲んでしまった。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから同じく長崎中の桶屋を、裏長屋の隅々まで尋ねて、福昌号の註文で新しい味噌桶を作った家を探し出し、そこで百斤入の蓋附桶を十個作った事が判明すると、千六はホッと一息して喜んだ。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "千六は、その小判を新しい唐米の袋に詰込んで、手車に引かせ、帰りに桶屋から十個の桶を受取り、序に山口屋から味噌を四百斤と、材木置場から鋸屑を五俵ほど買込んで、同じ手車に積ませて、その日の暮れ方に舟着場へ持って来た。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、十年経ち、大正七年の春、娘の初枝はもう二十一歳、町内のマラソン競争で優勝した桶屋の職人を見込んで婿にしたが、玉造で桶屋を開業させたところ、隣家から火が出て、開業早々丸焼けになった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "山はわし気に入ったども、雲が黒すぎるでねえか」「さし出口はおけやい」　そして君たち二人は顔を見合って溶けるように笑みかわす。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
