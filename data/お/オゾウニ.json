[
  {
    "uuid": "da1056b5-fb91-52e4-a74a-84780d251d75",
    "entry": "お雑煮",
    "reading": {
      "primary": "おぞうに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
