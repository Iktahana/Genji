[
  {
    "uuid": "03ed8387-f237-568c-8bc8-4cdf29b0efca",
    "entry": "お下がり",
    "reading": {
      "primary": "おさがり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hand-me-down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お下がりという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお下がりの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お下がりを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお下がりという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お下がりの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お下がりは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お下がりの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お下がりと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お下がりは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お下がりはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お下がりの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お下がりの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お下がりが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お下がりを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お下がりのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お下がりに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お下がりの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お下がりの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お下がりは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お下がりの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "手水鉢を座敷のまん中で取り落として洪水を起こしたり、火燵のお下がりを入れて寝て蒲団から畳まで径一尺ほどの焼け穴をこしらえた事もあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だけど、お師匠さまがときおりないしょで召し上がりますゆえ、そのお下がりをいただくのでござります」　と、――はしなくもいったその一語を聞くやほとんど同時でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の部屋にいようとも、あたしの耳は発音をきくだろう、耳で覚えたものを寝てからブックに照し合わせても解る筈だとは――とは、とはと、思いもするが、あたしは読ませないようにという意味が、御奉公の眼目におかれているので、お下がりの新聞さえ読ませられないのだ。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "お幼年にもかかわらず驚き入ったるお手のうち、いざこれよりは拙者お相手、お下がりあるな下がってはならぬ」　大小を置くと鉄扇を握り、場の真ん中へ突っ立った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一間ほどお下がりくださいまし。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だがお前さん後へお下がり！",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お下がりお下がり、二、三尺お下がり」いいいい嘉門は自分でも、ソロリと背後へまた下がった。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は若様が今度の試験にせめて五、六番上がってくださらないとご奉公のかいがありません」「それはごもっともです」「僕はもう覚悟をしています」「しかし早まってはなりませんぞ」「若様が一番でもお下がりになるようなら、僕はもうお暇をいただいて家へ帰ります」　と正三君は兄さんと相談してきたのだった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいじなことがあります」「なんだい」「今度の試験で若様が一番でもお下がりになるようなら、僕はお殿様にも奥様にも申しわけがありませんから家へ帰ります。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなた、折角、私がおさがりを頂いたんですからね、あの塚から、」　その古塚は、あわれ、雪に埋れた名工と、鼓の緒の幻の陽炎に消えた美女のおくつきである。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その下着は、故郷のお婆さんのおさがりだった。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホレーショー、おさがりなさい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホレーショーは、もう、おさがり。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホレーショー、あなたは、やはり、おさがり下さい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポローニヤス、もう、おさがりなさい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――そこへ、貴方のお姿が、すっと雲からおさがりなすったように……」「何、私なら落ちたんでしょう。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇子はとうから評判にも聞いていた、このきれいな人を、天皇のお許しでお妃におもらいになったお嬉しさを、同じく歌にお歌いになって、大喜びで御前をおさがりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんびりと寝た、仏前からおさがりをいたゞいて。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人夫婦が毎日米を取り分けて置くのを、奉公人は神様に供へるのだらうと云つてゐるが、それにしてもおさがりが少しも無いと云ふのである。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、読者が既に御承知のこと、つまりペトゥルーシカが旦那のおさがりの、少々ゆるすぎる羊羹色のフロックコートを著ており、こういう階級の人間には得てありがちな、おそろしく大きな鼻と唇を持っているということに、ほんの少しばかり附け足せばよいからである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、ぢや控訴なさらないともう直き既決におさがりになるんですね』『えゝ、まだ一週間ばかり間はあるさうですけれど――』『ぢやあなたもう一遍弁護士の方だの他の方からすゝめて御覧になつちや何う？",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "その浪路が、大奥にいればこそ、その手一すじをたよりに、城内に深刻な発展を試みようと努力しているのではないか――その手つきを失ったら――「まさか、ずっとお城をおさがりになるわけではあるまいな！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お料理の折ヅメは、お客さん方は持って帰るし、ウチの方々、旦那と末のお嬢さん夫婦はいつもキレイに食っちまうし、お酒のみで物をあんまり召上らぬ若旦那は惚れた女の子のところへ折ヅメを持ってッてやるから、おさがりはないねえ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこれは母のおさがりですのよ。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、これは母のおさがりですのよ。",
              "citation": {
                "source": "野萩",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれは僕の見当違いでＫ氏が言うのには、第一着る物もおさがり物で大偉張りで間に合うし、靴も破けたら下駄でも大偉張りだし、お互に、季節はずれの衣食住が目立たなくなって楽になったではないか。",
              "citation": {
                "source": "楽になったという話",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさがりの細かい格子のハンティングをかぶって、ゴム長をはき、シャツの腕をまくり上げた手に大きいなめし革の艶出し雑巾をにぎっている。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はおさがりがたいそうおそいようですね」「はあ」と広一郎は云った、「帰りに村田で夕餉の馳走になりました」「村田さまってどの村田さまですか」「三郎助です」　と広一郎は云った。",
              "citation": {
                "source": "女は同じ物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着る物は順送りのおさがりで、満足な品は一つもないから、みっともないのは当然である。",
              "citation": {
                "source": "七日七夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日まで折々お上が鷹狩りをあそばしました時は、雁の吸物のおさがりがございます」「うん、余の申付けだ」「かたじけのう頂戴を仕りますが、吸物椀の中にあるのはいつも牛蒡と定っております。",
              "citation": {
                "source": "備前名弓伝",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
