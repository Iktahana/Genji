        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ところが又そのうちに、収穫が一通り済んで、村中がお祭り気分になると、後家さんの家がいつまでも閉め込んだ切り、煙一つ立てない事にみんな気が付き初めた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや、開けた山裾、家があちこち、みんな日の丸の旗を掲げた、つい前もお祭り気分の運送屋、毛糸がありますと、貼り紙した店の横の雨戸袋。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "摂政宮殿下の行啓を仰いで、ついその翌晩、お祭り気分の濃厚な、黄や碧や赤やの色々の装飾の中で、実に鮮かに一斉に電灯が点いた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾分お祭り気分的に上ずった、プロレタリア文壇の一部に対する青野季吉の忠告は、勝本氏らによりて簡単に葬り去られたが、この問題も来年度にはきっと再燃するだろう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクニツクと｜同じ意味なんだけれど、もう少しお祭り気分が濃厚の、あたし達の町の行事なのよ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　阿父の一団が手に手に美しい歌妓を携へて附近の温泉場を会議場としながら株式の設立をいそぎ、祝盃に祝盃を重ねて素晴しい大夢に恍惚としてゐた有様は、さながら海賊の度胸にも似た豪胆さと奔放無碍なるお祭り気分であつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物席は色めき出し、お祭り気分が漲り初めると、舞台の方も自由になりだした。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしなべて、どの顔にもこの顔にも、お祭り気分が漂つてゐた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "解ったのか解らないのか、ともかくとてもおめでたい事という概念と、はちきれるほど一ぱいなお祭り気分で、ノーノー、ヒヤヒヤ、拍手｜喝采、何もかもメチャクチャに景気よく、弁士を胴上げにして家まで送って持って来た。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "スポーツそのものが、変に深刻で、血眼で、勝つても負けてもすぐに涙なんか流すのだから、折角のお祭り気分を台なしにしてしまふ。",
              "citation": {
                "source": "文学オリンピツク",
                "author": "――主催国としてどうするか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者がこれを読まれるにあたって、わたしが切におすすめしたいのは、学者のようないかめしい態度は取り去り、心からお祭り気分になって、馬鹿げたことも大目に見て、ただ面白いことだけを望んでいただきたいということである。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその人たちが、この町に集まることによって、町じゅうがお祭り気分になったのです。",
              "citation": {
                "source": "公園の花と毒蛾",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽気で派手でお祭り気分で、ワーッといったような雰囲気であった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "てくてく歩く人、驢馬に乗る人、あるいは二輪馬車、四輪馬車を走らす人、いずれも、お祭り気分で浮かれながらぞろぞろ行くのでした。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど八月十五夜で、川開きから三度目の大花火が、両国橋を中心に引っ切りなしに打揚げられ、月見の気分には騒々しいが、その代りお祭り気分は、申分なく満点でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなお祭り気分ではない、うけた無念は深刻なものだ。",
              "citation": {
                "source": "八寒道中",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとから十五六人の人たちが、この場面の幕がどんなふうにおろされるかという好奇心のため、多少はお祭り気分のように浮き浮きと、勝手なことを高ごえに話しあいながらついてゆき、やがて堀のほうへと曲って、見えなくなった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、たのしいお祭り気分になっていて、鳴いたり、さけんだり、大さわぎをしながら飛んでいきました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島大社のお祭り、橘・堀井夫妻・平野と揃ってお参り、昔のお祭り気分、満喫。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "泊の山上一帯は、これを迎えるに、どよめき立って、歓呼をあげ、さらに当夜、また、翌日へかけての、慰労の宴など、お祭り気分に染まったのもまたいうまでもない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは雨乞いの岳登りに、百炬火、千束柴を持って出たのと同じものにちがいないのだが、今では美観が主になって、何のわけもわからずに、ただ祭りの景気だの、お祭り気分だのという人ばかり多い。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
