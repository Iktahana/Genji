[
  {
    "uuid": "18996bd9-4fe8-5109-b07c-773ebb79b85c",
    "entry": "お捻り",
    "reading": {
      "primary": "おひねり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
