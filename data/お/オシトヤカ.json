        "examples": {
          "standard": [
            {
              "text": "お淑やかという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお淑やかの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお淑やかという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お淑やかは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お淑やかの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お淑やかは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お淑やかはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お淑やかの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お淑やかが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お淑やかのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お淑やかに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お淑やかの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お淑やかは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お淑やかの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "でも、おやゆび姫はバラの花びらのようにおしとやかでやさしく、この世の中でいちばん愛らしい人間なのです。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおよしあそばせ、ちょっと見ては、左様なおしとやかなお方でございますけれども、その悪党は底が知れぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さああなたの許婚とやらはどのようにお美しく、おしとやかで、どのようにお利口かは存じませぬが、そのようなこととて妾にとりましては怖くも恐ろしくもございません。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも　そだちのいい　おしとやかな　子犬よね。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かっきり４時１５分、　たいそう　おしとやかに　とんとんと　たたかれる　ドアの音。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　おしとやか。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんぞりかえる　１のひめ　こっちを　にらんで　さしず　「おはじめなさい」おしとやかにも　２のひめの　おのぞみは　「すっからかんな　おはなしが　あるといいな！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてあのおしとやかなふうをした歌い雌犬はドルス夫人です。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれを、あたしみたいに、正直にうわべに出しているか、おしとやか振って、うまく包んでいるかの違いしかありやしないものよ」「そんなことないよ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おしとやかでした。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
