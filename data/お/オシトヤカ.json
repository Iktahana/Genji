          ],
          "literary": [
            {
              "text": "でも、おやゆび姫はバラの花びらのようにおしとやかでやさしく、この世の中でいちばん愛らしい人間なのです。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおよしあそばせ、ちょっと見ては、左様なおしとやかなお方でございますけれども、その悪党は底が知れぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さああなたの許婚とやらはどのようにお美しく、おしとやかで、どのようにお利口かは存じませぬが、そのようなこととて妾にとりましては怖くも恐ろしくもございません。",
              "citation": {
                "source": "娘煙術師",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも　そだちのいい　おしとやかな　子犬よね。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かっきり４時１５分、　たいそう　おしとやかに　とんとんと　たたかれる　ドアの音。",
              "citation": {
                "source": "パイとやきがたのはなし",
                "author": "THE TALE OF THE PIE AND THE PATTY-PAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリス　おしとやか。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふんぞりかえる　１のひめ　こっちを　にらんで　さしず　「おはじめなさい」おしとやかにも　２のひめの　おのぞみは　「すっからかんな　おはなしが　あるといいな！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてあのおしとやかなふうをした歌い雌犬はドルス夫人です。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれを、あたしみたいに、正直にうわべに出しているか、おしとやか振って、うまく包んでいるかの違いしかありやしないものよ」「そんなことないよ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おしとやかでした。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
