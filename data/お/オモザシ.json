        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なぜなら、そのすぐあと私の方へ向き直ると、その面差しは心から心配しているように見えたからだ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面差しが平生よりも青くやせこけていたのには、私としても衝撃だった。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "目も眉もぱらっとして、覗き鼻の鼻梁が、附け根から少し不自然に高くなっているのも、そう気になるほどではなく、ややもすると惑星のように輝く目に何か不安定な感じを与えもして、奈良で産まれたせいでもあるか、のんびりした面差しであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の面差しが私によく肖ているというのよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、それはそれなりに、面差しに年代の影が差してゐるだけだつた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、今日でもまだ其の少年の其那に高くはない、然し立派に明瞭な声や熱心な面差しを思い出す事が出来ます。",
              "citation": {
                "source": "私の見た米国の少年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々及び我々の背後に永劫の未来に瞑る幾多数うべくもあらぬ人の群は、皆大いなるものの面をみにくき仮面もて被い、其を本来の面差しと思いあやまって見ると云う痛ましい事実を抱いて居る。",
              "citation": {
                "source": "大いなるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二三日は何の変りもなくって退屈に立って行ったが、五日目に七度二分に熱った時には、皆がもう生き返った様な面差しになって、「もう大丈夫ですよ、ええ。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞奴はその妹分の優しい、初々しい大丸髷の若いお嫁さんの役で、可憐な、本当に素の貞奴の、廿代を思わせる面差しをしていた。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人席には千鶴子を初め、田辺侯爵夫人、藤尾みち子など四五人の見える中に混って、真紀子は千鶴子とさきから話していたが、ときどき久慈の方へ視線を向ける面差しには、悪びれた風もなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師村の何んでもない、白髪をたばねた、わごわごした腰の、拭き掃除ばかしして来た老婆だのに、――あちらを歩き、こちらを歩きしながら、幼児の思い出を辿る風な面差しで、棟を見上げ見降ろし、倦怠を感じる様子もない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイゴンに行く篠井春子は、五人のなかでも一番美人で、一寸｜李香蘭に似た面差しがあつたので、幸田ゆき子なぞの存在は、誰にも注意されなかつたのだ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかその面差しが私の死んだお祖母さんに似てでもゐるのか知らん。",
              "citation": {
                "source": "エトランジェ",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "色の白いほつそりとした若い文士の其の頃の面差しは、従姉妹達の胸にくつきりと刻み込まれてあつた。",
              "citation": {
                "source": "若芽",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を預けた儘打ち任せた寛やかな面差しで居るのを見て※子は何となし驚ろかされた様な気持になった。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば面差しが残っています。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりやれと自分のお盃を差してくれたあの日の師匠の思いやりある面差しなんか、薬にしたくももう見られなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりよく栄養もとれなかったと見えて、面差しはたいへんやつれていたけれど、そのかわり、眼の中には、堅忍とでもいったような、ゆるぎのない光がやどっていた。",
              "citation": {
                "source": "キャラコさん",
                "author": "新しき出発",
                "note": "青空文庫"
              }
            },
            {
              "text": "『母』の、あの面差しだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "新しき出発",
                "note": "青空文庫"
              }
            },
            {
              "text": "大炊介の見た行子は、稚気離れのしない、咲きたての花のような面差しをした愛々しい女性で、生まれてからまだただの一度もこの世の不幸に逢ったことがなく、この世で思いのままにならぬものはないという、驕るかにも見える寛濶な表情をしていた。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前と菊治が子供の時から一緒に育つたせゐが、赤の他人のくせに、不思議に面差しが似て居る、――俺はそれに騙されて、幾日も／＼無駄にした上、三人も五人も餘計｜殺生をさして了つた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女を洗ひ出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前と菊治が子供の時から一緒に育ったせいか、赤の他人のくせに、不思議に面差しが似ている。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも埒が明かないと見て、近頃は毒矢を飛ばしたり、娘お小夜の美色を餌に、毒湯をすすめて一挙に怨みを報じようとしましたが、奉行の朝倉石見守が老中に進言して、将軍家光に面差しの似た与力笹野新三郎を替玉に使い、見事にその裏を掻いて取って押えたのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金色の処女",
                "note": "青空文庫"
              }
            },
            {
              "text": "色褪せた写真の聡明そうな額と大きな目が、大人になった彼女の面差しと重なる。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若い頃は、奥に仕えておりました」　というこの人は、山村座事件の絵島でもなく、先代萩の政岡でもなく、むしろ、安政大獄の老女姉小路を思わせる端麗で物静かな面差しをしていた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一、二か、三ぐらい、さっきの娘の姉なのでしょう、妹とよく似た面差しはしていますが、これは妹と違って細面の、艶やかな瞳……愛らしい口許……隆い鼻……やっぱりふさふさとした金髪を、耳の後方へ撫で付けて、丈も妹よりは、心持ち高いように思われます。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき父がどんなふうに許諾を与え、しかも後顧の憂なく自分を志すところへと踏み出させてくれたことか――それを思って、正造はあたかも父の面前に手をついているような敬虔な面差しで膝を揺った。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "決意を新にするもののような深刻な陰影が、その面差しを蔽うた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の者も、顔だけは知っていても名を知らぬ者が多かったが、いずれも必死に、正造に取りすがる面差しだった。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "子は父のおもざし、なにか求めて、　安らけき笑ひや。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
