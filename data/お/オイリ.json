    "definitions": [
      {
        "index": 1,
        "gloss": "oiri (small, spherical, colorful rice candies from Kagawa Prefecture, used as a topping on dessert)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あすこのおくらには、金や銀やダイヤモンドや、ルービーや、珊瑚や真珠が一ぱいはいつてをりますから、おいりになるだけお取り下さいまし。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お坊さん、茶もおいりようなら、茶も沸いております」　お作は黍の餅をさしだしながら云った。",
              "citation": {
                "source": "妖怪記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豚肉でも、腸詰でも、蕎麦粉でも、それとも、布地にしろ、稷にしろ、そのほかどんな物でも、おいりやうの節には……それあもう大概どなたの処でもよくあり勝のことなんで……さういふ折には、決して物吝みはいたしません。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、すぐ湯へおいり」　正一が湯上りの若々しい胸の上に素っぽこ袷をいいかげんに着て、片足で黒メリンスの兵児帯を蹴りながら腰へからみつけつつ中の間へ出て来た時、後へのこって車を掃除し、車庫の戸じまりまでひとりで終った弟の直二が入って来た。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきゃくさんは　まいにち　おおいりで、　キャラメルが　とくに　たくさん　うれていきます。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいり用のものをちつともおつしやつてくださらないから……」「毛布はいらないよ。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "メフィストフェレスおいり用の物は拵えますとも、それより多分に拵えます。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "棄てると言いましても、神様は我々の小さな家や田畑がおいりになるのではない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいりようだったら、そう言いましょうか、何時もは中に這入っていらっしゃるんだけれど、今日はどうしたんでしょう、お這入りにならないわ、……」「あら、ちょっと俟ってておじさま、きょう会場にいらっしった方だわ、違いないわ、横顔がおばさまそっくりだもの。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんの側としても、やはり、その段々がおいりになったのですけれども。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、シーツおいりになるのでしょう？",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
