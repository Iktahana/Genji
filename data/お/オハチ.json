    "definitions": [
      {
        "index": 1,
        "gloss": "container for boiled rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
