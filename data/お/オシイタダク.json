    "definitions": [
      {
        "index": 1,
        "gloss": "to accept an object and hold it reverently over one's head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
