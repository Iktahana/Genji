    "definitions": [
      {
        "index": 1,
        "gloss": "you (plural)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「受け取れ、これはお前たちのものだ。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちにおれは之を遺産とし、永遠の領地として贈つてやる。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の口から言ふべき事では無いが、お前たちの宿命と私の宿命には、たいへんな階級の差がある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お前たちには、それがよつぽど口惜しいらしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかのと言つて、私の宿命をお前たちの宿命にまで引下げようとしてゐるが、しかし、天の配劑、人事の及ばざるところさ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちこそ、人の深切を素直に受け取る法を知らぬ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちには、ひとの惡いところばかり眼について、自分自身のおそろしさにまるで氣がついてゐないのだからな。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人、一緒になつたので、「お前たちはお父さんの先きにお歩き」　さう云つて、私たちは県道を歩き始めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労してゐるんだからね、お前たちも贅沢を云つてはいけないよ」　と、ふだんから云つてあるのだ。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、誰だ、お前たちはどこから入って来た。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちね、今日はここへ非常なえらいお方が入らっしゃるんだから此処に居てはいけないよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、お前たちの籠の蕈をみんなよこせ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、お前たちもう行ってくれ、この袋はやるよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに、蔭ながらお前たち夫婦の身の上を守るとも云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前たちもお午飯かえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちが大馬鹿さ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると二番目の兄さんの二郎が「お前たちは狐のとこへ遊びに行くのかい。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たち行くんならお餅を持って行っておやりよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちはそれで足やからだをやぶる。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうお前たちは思ってゐる、けれどもこの地面はまるっきり平らなのだ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな小さな形の本にあらゆる本のみな入ってゐるやうな本もある、お前たちはよく読むがいゝ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちが笛なんか吹かなくたって星はみんなくるくるまわるさ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちはそれじゃ今やっとここへ来たんだろう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちの仲間もあちこちに、ずいぶんあるし又私も、まあよく知っているのだが、でそう云っちゃ可笑しいが、まあ私の処ぐらい、待遇のよい処はない。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちは、和子を利用して、てんでの虚栄心や功名心を満足させようとしているのです。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちは、和子を、食いものにしようとしているのだ。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に、此の親しい美しい日本の土を、けだものみたいに無神経なアメリカの兵隊どもが、のそのそ歩き廻るなど、考えただけでも、たまらない、此の神聖な土を、一歩でも踏んだら、お前たちの足が腐るでしょう。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちには、その資格が無いのです。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大きな声で言って、「お前たちには、信仰が無いから、こんな夜道にも難儀するのだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちは、のんきさうだが、しかし、めんだうな事件だよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
