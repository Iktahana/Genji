        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大雪田の石の峰を超えて、三角点の下に来た、木曾山脈を西に控えて、その間の高原を、天竜川が白く流れ、仙丈岳は渓谷を隔てて、その頂上の、噴火口と擬いそうな欠けたところが、大屋根の破風のように聳えて、霧を吐く窓になっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁盤の目ほどに窓の多いデパートメント、タンクを伏せたように重っ苦しい大屋根、長方形の箱を、手品師の手際で累積したようなアメリカ式鉄筋コンクリートの高層築造物は、垂直の圧力を通行人の頭上に加えて虚空の「通せん坊」をしあっている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "身にしむやうな媚めかしい聲に大屋根の方へと啼いて行く。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りですから、主人が引返さうとした時です……藥賣の坊主は、柄のない提灯を高々と擧げて、椎の樹の梢越しに、大屋根でも見るらしく、仰向いて、（先づは送つたぞ……）　と聲を掛けると、何處かで、（御苦勞。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あ、又降るよ……」　凄まじい霰の音、八方から亂打つや、大屋根の石もから／＼と轉げさうで、雲の渦く影が入つて、洋燈の笠が暗く成つた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菊の咲く頃、大屋根へ出て、棟瓦をひらりと跨いで、高く、高く、雲の白きが、微に動いて、瑠璃色に澄渡つた空を仰ぐ時は、あの、夕立の夜を思出す……そして、美しく清らかな母の懷にある幼兒の身にあこがれた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　猪が飛出したやうに又驚いて、彼は廣い辻に一人立つて、店々の電燈の數より多い、大屋根の石の蒼白い數を見た。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……昨夜、戸外を舞靜めた、それらしい、銀杏の折れ枝が、大屋根を越したが、一坪ばかりの庭に、瑠璃淡く咲いて、もう小さくなつた朝顏の色に縋るやうに、たわゝに掛つた葉の中に、一粒、銀杏の實のついたのを見つけたのである。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これへ乘つて、廂へかゝつて、大屋根へお上んなさい。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處で薄汚れた襪に成つて、肩から廂へ、大屋根へ這上つて、二百十日と云ふ形で、やつとこな、と帽子を掴むと、下の奴は甜瓜かじりに靴を掴んで、一目散。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は大屋根の廂ぐらゐで、下は、然れば丁ど露地裏の共同水道の處に、よその女房さんが踞んで洗濯をして居たが、立つと其の頭ぐらゐ、と思ふ處を、スツ／＼と浮いて通る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、厚さは雜と塀の上から二階家の大屋根の空と見て、幅の廣さは何のくらゐまで漲つて居るか、殆ど見當が附かない、と言ふうちにも、幾干ともなく、急ぎもせず、後れもせず、遮るものを避けながら、一つ一つがおなじやうに、二三寸づゝ、縱横に間をおいて、悠然として流れて通る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線の音もしたけれど、吹さらわれて大屋根へ猫の姿でけし飛ぶようさ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と饂飩屋は坂塀はずれに、空屋の大屋根から空を仰いで、茫然する。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車にゆられながら隣村の森を拔けると、幾里四方もの青田の海が展開して、その青田の果てるあたりに私のうちの赤い大屋根が聳えてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はるか前方に、私の生家の赤い大屋根が見えて来た。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先へ斜に飛んで、其の大屋根の高い棟なる避雷針の尖端に、ぱつと留つて、ちら／＼と青く輝きます。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "話声がふわふわと浮いて、大屋根から出た蝙蝠のように目前に幾つもちらつくと、柳も見えて、樹立も見えて、濃く淡く墨になり行く。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、怪し火は、何と、ツツツと尾を曳きつつ、先へ斜に飛んで、その大屋根の高い棟なる避雷針の尖端に、ぱっと留って、ちらちらと青く輝きます。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "現場をつかまへた刑事のいふところでは、この犯人は猫のやうに、すら／＼と屋根裏までかけ上り、にげるのにも、大屋根の真上を、平地のやうに、かけとぶといふ、したゝかもので、この手ぎはでは、むろん前科もあるにちがひないのですが、何しろ耳も聞えず、口もきかないのですから、署でも手こずりました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あ、また降るよ……」　凄まじい霰の音、八方から乱打つや、大屋根の石もからからと転げそうで、雲の渦く影が入って、洋燈の笠が暗くなった。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菊の咲く頃、大屋根へ出て、棟瓦をひらりと跨いで、高く、高く、雲の白きが、微に動いて、瑠璃色に澄渡った空を仰ぐ時は、あの、夕立の夜を思出す……そして、美しく清らかな母の懐にある幼児の身にあこがれた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一廓は、柳にかくれ、松が枝に隔てられ、大屋根の陰になり、建連る二階家に遮られて、男坂の上からも見えず、矢場が取払われて後、鉄欄干から瞰下しても、直ぐ目の下であるのに、一棟の屋根も見えない、天神下のかくれ里。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ遥に空を衝いて、雲のその夜は真黒な中に、暗緑色の燈の陰惨たる光を放って、大屋根に一眼一角の鬼の突立ったようなのは、二上屋の常燈である。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい往来に出て、初めてほっとしながら見かえると、津の国屋の大屋根に大きな鴉が一匹じっとして止まっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも甲州屋へ行ってみよう」「ああ、すぐに来てください」　お粂は兄をうながして表へ出ると、暑いと云っても旧暦の七月の宵はおいおいに更けて、夜の露らしいものが大屋根の笹竹にしっとりと降りているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ路を塞がれては不便だと気がついて、次郎左衛門は敵の廻らないうちに、自分から先きに窓を破って大屋根の上に逃げて出た。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蒼ざめた顔が大屋根の上に立っている次郎左衛門の眼にはいった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "本伝寺の大屋根へ足場なしに上るんやもの、こなな低い屋根やこしはお茶の子や。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜吐水の水はやっと大屋根に届く位、それも直接｜消火の用を足すというよりは、屋根に登って働いている仕事師の身体を濡らすに用いた位のもの……ゲンバという桶を棒で担い、後から炊き出しの這入ったれんじゃくをつけて駆け出した（これは弁当箱で消防夫の食糧が這入っている）。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その頃の消防夫のことなど",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
