[
  {
    "uuid": "788c5353-63f7-5fcf-bf58-b93ecc4bbd94",
    "entry": "怯え",
    "reading": {
      "primary": "おびえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
