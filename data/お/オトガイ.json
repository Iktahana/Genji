[
  {
    "uuid": "b80f9e1d-58be-5d8d-a6c1-25582e9bf189",
    "entry": "頤",
    "reading": {
      "primary": "おとがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
