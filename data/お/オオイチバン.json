        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この折詰を積んだ形が大一番の棺桶などは、どんなものです。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷包を左手に載せて、左の方へ附いたのは、大一番の円髷だけれども、花簪の下になって、脊が低い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "体重百四十｜斤に近い、六尺豊かの図体で、大一番の菜葉服の襟首や、袖口や、ズボンの裾から赤黒い、逞ましい筋肉が隆々とハミ出しているところは、如何にも単純な飾り気のない性格に見える。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がそれは、大一番の丸髷に赤い鹿の子のてがらをかけた、たわやかな美人なのである。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの直径二｜呎何｜吋、全長二百何十｜呎という、大一番の鋼鉄の円棒だ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大一番の丸髷に結って肉襦袢姿、それが三百ポンドもある大重錘をさしあげる、大和撫子ならぬ大和｜鬼蓮だ。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "アコ長のほうは、ごぞんじの通り、大一番、長面の馬が長成の冬瓜をくわえたような、眼の下一尺二寸もあろうという不思議な面相。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙の入つて居る大一番の野暮な紙入の中に、質札が二枚と、一昨日兩國の獸肉屋で掻拂つた妻揚枝が五六本、それから寛永通寶が五六枚入つてゐる筈だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お銀お玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にある大一番の紙入には、穴のあいたのが少々入つてゐるだけだつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "八五郎の戀人",
                "note": "青空文庫"
              }
            },
            {
              "text": "押入の下の段に入れてあつた大一番の葛籠は蓋をしたまゝ、上から拔刀がズブリと突つ立つて、葛籠から漏れた血が、押入の床板を赤黒く染めて居るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱れん坊",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋場の文七は、どこから持出したか、自分の船に大一番の早桶を積み、諸人を嫌がらせ乍ら、川筋を上へ下へとたつた一人で漕ぎ廻つてをりましたが、それもどうしたのか、七日ばかり前からふツつりと姿を見せなくなつたといふのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大一番の早桶を買つて來て入れたのは大した智慧だらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大櫓時計や置時計は別だが」「ところがお前が見落したところがあるのだよ、これだ」　平次はヅカヅカと大一番の櫓時計の前に進むと、自鳴鐘といふ名の由來する、ピラミツド型の櫓の上に伏せた恰好になつた、かなり大きい鐘の中に手を入れたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "御時計師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは何んだ」　その空つぽの六疊、主人の源左衞門が、有難さうな道話を説いたところに、人を馬鹿にしたやうに轉がつて居るのは、有太郎が平次に見せた眼潰球と同じものが一つと、外に大一番の島田の附け髷、――お歌はこれを頭の上に載つけて、鼬小僧から娘に、娘から鼬小僧と早變りして居たのでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鼬小僧の正体",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢屋のやうな恐ろしく嚴重な格子戸に、大一番の海老錠をおろして、薄暗い六疊ほどの部屋の中には、何やら黒いものが蠢めきます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青錢と鍵",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐紙を開けると、格子になつた開き扉は、大一番の海老錠をブラ下げて、地獄の門のやうに嚴重に閉つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青錢と鍵",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷牢へ行つて見ると、彌太郎は眼を泣き脹らして、着物の裾に血が附いて居る、――背後の方だから、本人も氣が付かなかつたらしい」「――」「彌太郎が座敷牢から拔け出して藤六を殺したとすれば、あの大一番の海老錠をどうして外したか、それがわからなかつた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青錢と鍵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その惣吉の側には、大一番の青砥が据ゑてありました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "贋金",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大一番の島田」「大一番の島田は變だな」「兎も角、なよ／＼としなだれ掛かるから、少し氣味が惡くなつて、――おい人違ひだよ、――と突つ放して、此處へ飛込みましたがね、一と晩に若い女三人に獅噛みつかれたのは、あつしも生れて始めてですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "苫三七の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程さういへば、座敷牢の格子には、大一番の海老錠がおろされてあり、朝比奈三郎がやつてきても、これは破れさうもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女御用聞き",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸の帶に結んで、大一番の海老錠の鍵はありますが、それは見たところ何んの異状もなく、主人が四六時中それを肌身離さなかつたとすれば、下手人はこの鍵で土藏を開けて入つたのでないことは明らかです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女御用聞き",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅の厚板で組んだ、恐ろしく巖乘なもので、大一番の海老錠を卸してありますが、覗いて見るとよく底が見えて、穴のあいた小錢が五六枚あるだけ、何の變哲もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八五郎さん、ちよいと」　お靜が聲を掛けると、いきなり大一番の咳をして、「お品さんいらつしやい」　ヌツと長んがい顏を出すのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蜘蛛の巣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八五郎さん、ちょいと」　お静が声を掛けると、いきなり大一番の咳をして、「お品さんいらっしゃい」　ヌッと長い顔を出すのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "蜘蛛の巣",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンクリートで築き上げた厳重な室の中には、一人の美人が、大一番の金庫に縛り付けられて、怨みの目尻を割いて屹と闇を見据えて居ります。",
              "citation": {
                "source": "青い眼鏡",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口はたつた一つ、廊下の行き止りに樫の一枚板の塗喰の大戸で鎖した上、大一番の海老錠がおろされ、地獄の門のやうな嚴重な造りです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鍵の穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大一番の海老錠をおろして、鍵は私の腰に下げ、夜も晝も側を離さないやうにして置きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鍵の穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋場の文七は、どこから持出したか、自分の船に大一番の早桶を積み、諸人を嫌がらせながら、川筋を上へ下へとたった一人で漕ぎ廻っておりましたが、それもどうしたのか、七日ばかり前からふっつりと姿を見せなくなったというのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大一番の早桶を買って来て入れたのは大した智恵だろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二階の娘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
