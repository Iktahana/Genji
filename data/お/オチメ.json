        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "落ち目になった夫人は年がいもなくしどろもどろになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ち目になったら最後、人間は浮き上がるがめんどうになる。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――神代直人も、もう落ち目だ。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつの頃からかじりじりと目に見えないほどに落ち目になって来、今ではもう起き上れる見とおしもつかないのだ。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の落ち目になった社会的信用で、この上私を持って行こうったって、それは無理だわ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "この五時になると、景気のいいものも落ち目のやつも一せいに手を停めて、各自持ち札の総計をとらなければならない。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体同情をされると云ふのは人がきつと落ち目になつたときの事で勝ち目になつたときに厚意をよせることを同情するとは云ひません。",
              "citation": {
                "source": "妾の会つた男の人人",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は落ち目になると僻み根性を起し易い。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃しきりに髪が落ち目のふちに小皺が見え自分ながら急に衰へを感じ出したが、さてどうにもならないといふ時、自分に言つて聞かせる言ひ訳だらうと思ふがどうであらうか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "リングでの負傷が祟って落ち目が続き、帰国の旅費もないとやら。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのむものの弱味と云おうか、落ち目と云おうか――とにかく妙な心持がしていやであった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "義観が「心配すな、牧は落ち目で、小太郎は上り目じゃ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂「堀川の段」のお俊のくどき「人の落ち目を見すてるをさとの恥辱とするはいな」の句を引いて、遊女すら尚かくの如し。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「落ち目になったと申しましても、まだ権勢の田沼意次、それに公職を空しゅうして、このようなところへ潜行する――あり得べきことでござりましょうか？",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は気持が落ち目になるとダメなものだ。",
              "citation": {
                "source": "俗物性と作家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとにこんな風では代々落ち目になるばかりだ」　この村には特別の習慣があって、子供が出来ると秤に掛け、斤目によって名前を附ける。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ本当に正真正銘の事実だから彼女は、「代々落ち目になるばかりだ」と固く言い張るのである。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の秤に掛ければ、せいぜい九斤か八斤くらいのものです」「代々落ち目になるばかりだ」九斤老太は同じ事を繰返した。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「代々落ち目になるばかりだ」九斤老太はまた同じことを言った。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「代々落ち目になるばかりだ」九斤老太は不平の真ッ最中であったから、この機に乗じて趙七爺に向い「今の長毛（革命党）は人の辮子を剪るので、坊さんだか、道士だか、見分けのつかぬ頭になった。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "九斤老太は泣き倒れている六斤の手を取って引越し「代々落ち目になるばかりだ」といいつづけて一緒に歩き出した。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "代々落ち目になるばかりだ。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「代々落ち目になるばかりだ。",
              "citation": {
                "source": "風波",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "この庭は彼の家がまだこれほど落ち目にならぬ時、夏になると彼の祖母と共に毎晩ここへ出て涼んだ。",
              "citation": {
                "source": "白光",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海の大火の折に母からもらっていた山林を売って高利貸しをはじめ、その当時はかなりの好調であったらしいが、今では成績不振らしくビッコひきひき駈けずり廻っているだけで落ち目になると焦りがでて借り手にしてやられるようなことになりがちでいけなくなる一方であるらしい。",
              "citation": {
                "source": "能面の秘密",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "清洲の本家が信秀から離れるに至ったのは落ち目の信秀がいずれ美濃の道三に退治されてしまうと見たからであろう。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽く一ひねりに五千の尾張兵をひねり殺して信秀の落ち目の元をつくったのは道三だ。",
              "citation": {
                "source": "梟雄",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お内儀も、そんな、めそめそしてないで、せっかくのいい髪をもったいない、ちゃんと綺麗に結って、おちめを人に見せないところが女房の働き。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なるほど、百合の蕊なら洗ってもおちめえ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕えていた中宮が権門の関係におされて、まことにおちめになり、藤原氏の女御が高くおさまっている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
