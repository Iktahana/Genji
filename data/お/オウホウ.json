[
  {
    "uuid": "44b8215a-4bae-556f-a0a7-7505541be42f",
    "entry": "往訪",
    "reading": {
      "primary": "おうほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going to visit (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "修善寺時代以後の夏目さんは余り往訪外出はされなかったようである。",
              "citation": {
                "source": "温情の裕かな夏目さん",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "二葉亭もまた蘇峰が高調した平民主義に共鳴し、臂を把って共に語る友と思込んで、辞を低うし礼を尽して蘇峰を往訪した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "汀居往訪、全不在だつた、句集を置いて戻つた。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方早々散歩しながら汀居往訪、柿の会例会である、会者七人、これはといふ句は出なかつた、真摯なのがうれしい、席上雑話をして月村さんから、画家乃至画工のうらおもてを聞かされたが、本物でない芸術家はあさましいあさましい。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "上一万へ、どんぐり老一洵居往訪、俳談しばらく、夕飯まで御馳走になつた、そうめんの御馳走はうれしかつた、おかげで私の盆が盆気分になりました。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "無水君往訪、不在、干うどんを借りる、和蕾居往訪、小遣を借りる。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "女史は往訪の新聞記者に向ってこう語っている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室の青年に話していると、高橋さん来訪、同道して藤岡さん往訪。",
              "citation": {
                "source": "四国遍路日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明兄を往訪して、明日の山口行を取消さうと思つてるところへ来訪、残念だけれど、こんなに声が嗄れてゐてはとても行乞は出来ないから。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明居を往訪する、病気見舞でもあるし、お詑びでもある（私のワヤの余沫が同君へまで飛んだのである）、対坐してゐるのも気の毒だから、水を腹いつぱいよばれて戻つた（こゝの井戸はもう水が涸れて濁つて、とても生水は飲めない）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件に関してわたくしの往訪した人、書を寄せて教を乞うた人は頗る多い。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒は江戸に於て春水と会見する機会を得なかつたので、此日に始て往訪したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒が往訪した時の春水の身分は、百五十石の側詰であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で蘭軒は文化三年に春水を広島の邸宅に往訪し、最後に四年に春風を長崎の客舎に引見したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は再三往訪した時のつれか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞亭は「居無幾、先生帰伊州、予亦雲遊四方、数歳而帰郷、（中略）遂往訪則云、先生以本月朔病歿、今已六日、実文化七年三月也、夫知己相待之殷、以十三年※離之久、期一見於二百里外、豈意其人既亡、臨之後事、即俾予此行、纔在数日前、尚及其目未瞑也」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今茲庚午三月子譲往訪先生。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし榛軒は絶て往訪せずにしまつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞻淇の日記を閲するに、柏軒は五月二十八日、森枳園は閏五月二日に往訪した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」是日棠軒の往訪した七家の中に関藤がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは平八郎さんが來た時、これに告ぐるに往訪に意あることを以てした。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に歸つてから、手近い書に就いて谷中の寺を出して往訪したが、増田氏の墓は無かつた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に就き正木博士は同教授室に於て、往訪の記者に対しかく語った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "予等は其の華工の寄宿舎を見せて貰ふのが往訪の目的であつた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "予等は今日その一つを往訪した。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブノワはコッペの縁戚で且つ今日の往訪は予ねて先生に打合せ済みだつた。",
              "citation": {
                "source": "フランソア・コッペ訪問記",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神病理学者として令名あるフォウブス・ウィンスロウ博士は、往訪の新聞記者ガイ・ロウガン氏に語って、この殺人者は、個々のエロティックな発作的狂乱の場合以外、平常はごく普通の、穏厚な一市民であろうとの意見を述べている。",
              "citation": {
                "source": "女肉を料理する男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "『夏目君が……館に来てゐる、先輩に対する礼としてでも往訪するんだが同伴しないか』と私を誘うて下すつたのは同じく英文科の先輩（目下二高の教頭）玉虫一郎一さんでした、同郷の秀才で後同じく英文科に学んだが惜いかな中途で斃れた秀才渡辺芳治君も亦同伴されたと記憶します。",
              "citation": {
                "source": "漱石さんのロンドンにおけるエピソード",
                "author": "夏目夫人にまゐらす",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうようなわけで、たずねて来てくれる客も絶えがちになり、こちらからはもとより往訪も出来ない。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
