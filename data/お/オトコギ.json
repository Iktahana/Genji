        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "クソ真面目な色男気取りの議論が国をほろぼしたんです。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その生涯の馬鹿正直さ加減を、おかしな男気を、ヒロイズムを、自分を捨てゝ人の注文に嵌るその偶像性を、その見栄坊を、嘲りながら泣いた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜のとばりがせめてもに、この醜さを隠しましょうと、色男気取った氏神詣りも、悪口祭の明月に、覗かれ照らされその挙句、星の数ほどあるアバタの穴を、さらけ出してしまったこの恥かしさ、穴あらばはいりもしたが、まさかアバタ穴にもはいれまい。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間、男気無しのまま、人跡絶えたモノスゴイ山奥に、原始生活をして来た気の強い女……ことにタッタ一人でアラユル飢寒と戦いながら、四人もの子供を育てて来た母性が、如何に慓悍狂暴な性格に変化するものかという事実は、普通人のチョッと想像の及ばないところでしょう。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、素敵なものだと、のほうずな大声で、何か立派なのとそこいらの艶麗さに押魂消ながら、男気のない座敷だから、私だって遠慮をしました。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗にいふ越後は八百八後家、お辻が許も女ぐらし、又｜海手の二階屋も男気なし、棗の樹のある内も、男が出入をするばかりで、年増は蚊帳が好だといふ、紙谷町一町の間に、四軒、いづれも夫なしで、就中今転んだのは、勝手の知れない怪しげな婦人の薬屋であつた。",
              "citation": {
                "source": "処方秘箋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高利貸が又た飛んだ赤樫満枝で……しかも男気のある一風かはつた女で、Ｔ子の江戸ツ児風の気象にすつかり惚れこんで、素敵な座蒲団を作つてくれたり、終ひには借金を棒引きにしてくれたりしたといふ事もあつたな。",
              "citation": {
                "source": "女流作家",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの女の無邪気にハキハキとして居て男気が有り、わり合に考も有って男の手管にまかれるような事は一度もない、　と云う事をきいてまだ言葉も交わさない内、まだかおも見ない内から少なからず動かされ、或る特別なような好奇心に動かされて居た。",
              "citation": {
                "source": "砂丘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、妙なわけになって居るが段々その力つよさと男気の有るのが消え始めた。",
              "citation": {
                "source": "砂丘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪屋には女の姉妹の外に、年老の母親が居るばかりで、男気がなかつたといふこと、それに二人とも旦那持の身であつたといふことが、伯父をして殊更馴れ親しみ易からしめたやうであつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのオヤジはここへ来るたんびにキット、この窓の真下の勝手口の処で立ち止まって汗を拭くんだから……そうして色男気取りでシャッポをチャンと冠り直して、ネクタイをチョット触ってから勝手口の扉を押すのが紋切型になっているんだから、その前に落せば一ペンにフッ飛んでしまうかも知れないわね。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親のない身の上ながら、親が残して行った金があるので、女中と婆やとを二人ほど使い、男気のない女世帯を、このようなひっそりした町の露路で、しばらく前から張り出したが、その男気のないということが、何より寂しいと云うのであった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男気のすくない南国のキリシタン島へ一夜兵隊の一行が上陸し、街を通り、天主堂でもてなしを受け、さうして翌日帰つていつた。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男気のすくない南国のキリシタン島へ一夜兵隊の一行が上陸し、街を通り、天主堂でもてなしを受け、そうして翌日帰っていった。",
              "citation": {
                "source": "悲願に就て",
                "author": "――「文芸」の作品批評に関聯して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "孀暮しをしつけた人達は、田舎の旅舎へ来ても、淋しい男気のない様子に見えた。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」「あちらへお廻り遊ばしました」　男気のない奥庭に、次第に数を増した女中達は、お蓮の姿を見失っては一｜大事と思ったのであろう。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族のほかに男気なんてない筈の奥にひッこんでいらッしゃるお嬢さまがネ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとては野暮な沙汰、男気なしの女暮しで、三日に挙げず、料理の御用、正宗の明瓶を屑屋があてに来るといへば、いはずと知れた商売柄、知れぬは弗箱の在所ばかり。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "土方「……とんだ男気のある仁も有るもんだ、アハハハ。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家には嬢様と子供衆の外には男気と言っては俺がたった一人ぎり。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下を向いてそれを聞いている仙太郎……）※誓いしことも有明の、月の桂の男気は、定めかねたる秋の空だまされたさの真実に、見下ろされたる櫓下」お蔦　（三味線と唄をフッツリ止める）……天下を俺一人で背負っているといった顔だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさんに似たおなかさんに良く思われてえばっかりに、自分の身を忘れて飛び出した、それもこれも心からの男気なんかじゃありゃしねえ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳之助　いえ、いくら卑下しても、政さんは男気で、わたし達を助けてくれたんです。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "男気が無いと見定めたからの事でしょうが、優形で、無類の美男と言われた千代之助は、何処へ行っても無礼な仕打で通って来たのでした。",
              "citation": {
                "source": "百唇の譜",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "※誓いしことも有明の、月の桂の男気は、定めかねたる秋の空、だまされたさの真実に、見下ろされたる櫓下」お蔦　（三味線と唄をプッツリ止める）……天下を俺一人で背負っていると言った顔だ、ふん、あたしぁキツイきらいさ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所柄が長局であるということと、それと、ここでは誰も知った者のあろうはずはないが、昨今、この城下へ姿を現わした、あのイケしゃあしゃあとした、いや味たっぷりの、色男気取りの、向う見ずで、意気地なしの、がんりきの百というやくざ者の姿を思い浮べてみると、いい気持はしない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "根が、このがんりきというやくざ野郎は、こういう色男気取りに出来ている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
