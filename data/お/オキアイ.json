        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "八年前に謝源がこの沖合で難破した蘭人の二人を家来の救ふて来たのを、世話してやつたことがあつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡褐色の沖合に人間の死体を燃したような煙を吐いて、陳独秀の乗った汽艇が影を没した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗礁に乗りあげた駆逐艦の残骸は、山へあがって見ると干潮時の遠い沖合に姿を現わしていることがあった。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その日の黄昏時、おなじ島の南にあたる尾野間という村の沖に、たくさんの帆をつけた船が、小舟を一隻引きながら、東さしてはしって行くのを、村の人たちが発見し、海岸へ集って罵りさわいだが、漸く沖合いのうすぐらくなるにつれ、帆影は闇の中へ消えた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老船頭が櫓柄につかまって沖合の一点を白眼みつつ、悠々と大浪を乗り切る、その押す手引く手や腰構えの姿態美は、ソックリそのまま名人の仕カタ開キであるまいか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　舟は暫時く大船小船六七｜艘の間を縫ふて進んで居たが間もなく廣々とした沖合に出た。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　舟はしばらく大船小船六七｜艘の間を縫うて進んでいたが、まもなく広々とした沖合に出た。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から一天俄に掻曇りて、※と吹下す風は海原を揉立つれば、船は一支も支えず矢を射るばかりに突進して、無二無三に沖合へ流されたり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霎時にして海上を見渡せば、日は已に没し、海波暗くして怒濤砂を捲き、遥か沖合には漁火二、三。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の一件をやることにした」　年の暮に、彼のところへ、長崎県五島沖合にある沈没汽船売り込みがあった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "村中を駈けずって仲間を呼び出してまわったが、その仲間の四五人が、冷酒の勢いに乗じて別荘に押しかけた時分には、若旦那夫婦と女中二人を乗せたモーターボートが、大凪の沖合はるかに、音も聞こえない処に辷っていたのであった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ日はしづみゆきかなしく沖合にさまよふ不吉の鴎はなにを歌ふぞ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならびてすすむ水のうへみなみをむき沖合にあるもいつさいに祈るがごとく浪をきる。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六艘の船が沖合へ出た。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "波は神威崎の沖合あたりもいと静かなりき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小豆島沖合の霧で船足が遅れて、別府湾にはいったのはもう夜だった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の夜、国境安別の海岸と別れた私たちの高麗丸は、元来た南へ南へと下航して、黎明に野田の沖合五、六丁の処にその機関の運転を停めた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、今、同じ方向に今夜の泊りの本斗を目ざして、自分たちの高麗丸が、やや少し斜め先きに、船体を真横に見せて、さほど遠からぬ沖合を駛っている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "高麗丸はこの沖合ではいかにも壮麗に、またいかにも文明の高貴な象徴であるかのごとく眺められた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはその西側に直面して、今は僅かに五、六町の沖合まで近々と寄せて機関の運転を止めた高麗丸の船上にあるのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船はつい二三年｜前、オポルトウの北方数｜哩のポルトガルの沖合いで沈んでしまった。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二　いま一度、私は瀬戸内海の島に渡つて行つたことがある、備前の宇野港から數里の沖合に在る直島といふのへ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "程なく右手に突き出た岬のはなの沖合に何やら大きな旗をたてた一艘の發動機船の姿が見えた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の漁場は、わたくし共の行く所よりずつと南に寄つた沖合なのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しわたくし共の行く岩の間で取れる魚は、種類が沖合より余程多くて、魚の数もやはり多いのでございます。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて平野橋、一本二本蘆の中に交ったのが次第に洲崎のこの辺土手は一面の薄原、穂の中から二十日近くの月を遠く沖合の空に眺めて、潮が高いから、人家の座敷下の手すりとすれずれの処をゆらりと漕いだ、河岸についてるのは川蒸汽で縦に七｜艘ばかり。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
