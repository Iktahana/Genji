        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おまけにオイル・ショックで、四国あたりにぶら下がっている日本の金玉が縮み上がった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがオイルショックで社会が縮こまった中、新手の電子部品にはさっぱり販路が開けなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイルショック後のヒステリーの中で、まるで軍隊のように組織的締め上げが進んでいったこの国に悪態を付きながら、オレは正直なにをしたらよいのか分からなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためには、グズグズしてると不純な分子藤原のごとき、小倉、波田のごときが乗り込んで来ると、いけないというので、気脈相通ずる火夫長とナンブトー（ナンバーツーオイルマン）とを誘惑して、伝馬を占領してしまった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイルマンは機関室からのぞいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は鎖国思想の反キリスト教論者であつたが、そんな晩にはアメリカの息子が贈つて寄越したオイル・ラムプのシヤンデリアを燭して、最も簡単な意見を交換した。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は鎖國思想の反キリスト教論者であつたが、そんな晩にはアメリカの息子が贈つて寄越したオイル・ラムプのシヤンデリアを燭して、最も簡單な意見を交換した。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉の大和煮、コンビーフ、ウィンナソーセージ、オイルサーディン、シャケの水煮、桃やミカンやパイナプルといった果物類、オレンジジュース、コカコーラ、そういった缶詰がほとんどだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に鎖を引くと消えるアメリカ製のきらびやかなオイル・シヤンデリアが、ワアツ――といふ観客の熱狂と共に幻のやうに消えて、技手役の照吉が写し出す日章旗のへんぽんたる光景が華麗な色彩を浮べた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃のクリスマスにジャッキイが、美しいきりこ硝子の飾りのついたオイル・シャンデリアを贈つたものだ。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより少し前に短篇によって登場した小山いと子は、この頃「熱風」や「オイル・シェール」というような作品を生むようになっていた。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油液化を扱った「オイル・シェール」（小山いと子）、ソヴェトのレオニード・レオーノフの「スクタレフスキー教授」などは、科学者の学問的情熱と社会の歴史的環境を扱っていましたが、素人眼にも科学者は成功的でありませんでした。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "題材的には数年前になかった変化があって、例えば大石千代子氏のブラジル移民を描いた小説、小山いと子氏の「オイル・シェール」のような題材のもの、川上喜久子氏の朝鮮を背景とした作品など出ている。",
              "citation": {
                "source": "拡がる視野",
                "author": "――今日の婦人作家――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな理由からも、小山いと子という作家は段々「熱風」や「オイル・シェール」を書くように変化して行ったのであろうか。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、よりひろい空間と、よりひろい社会の場面に自分をふれさせ其を描きたい欲望が、彼女を「熱風」や「オイル・シェール」に向わせた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熱風」にしろ「オイル・シェール」にしろ、婦人作家としては珍しく、見知らぬ外国を背景として、そこでの日本技師のダム工事にからむ事件や人造石油製造工業技術の発展に絡む人事などが扱われている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう社会的な理由に対する作者自身の無自覚に加えて文学の世界の人々は「熱風」や「オイル・シェール」の文学的失敗の結果についてだけやかましく云って、只の一言もその作の貧困をもたらしている日本の社会文化生活の貧困条件について、いきどおらない。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば小山いと子の「オイル・シェール」に対して「女は女のことを書いた方がいゝ」という評言が男の作家にとっても共通であった筈の、もっと重要であった文学上の諸問題をひとくるめに片づけてしまったように。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦二人だけで始めた会社はこれまで、オフィスコンピューターの販売とメインテナンス、加えてマシンの納入先からの開発依頼をこなし、第二次オイルショック後の苦しい時期をどうにかこうにか乗り切ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テエブルにかけたオイル・クロオスは白地に細い青の線を荒い格子に引いたものだつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "テエブルにかけたオイル・クロオスは白地に細い青の線を荒い格子に引いたものだった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに次ぐものはオイルランプなり、これまた一行人をして、手に提燈を携ふの煩とわかれしむ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポートサイドでは、有名な鱈のお料理を御馳走になりましたがそのうまかったこと、鱈をトマトとオリーブオイルで煮たものですが、今でもそのおいしかったのが忘られません。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤヨイ号は、仏領インドシナ某地点で、多量のガソリンやオイルを積みこんでから、ふわりと空へまいあがったのであった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワイシャツの着替えを持って来なかったことも、ライター・オイルの小瓶を一つ持ってることも、知っているのだ。",
              "citation": {
                "source": "憑きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯖の切身をちょっとごまかして、下等なピーナツオイルで揚げたものだ。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも王子さまはあたまをはたらかせて、まえもって、かいだんをぜんぶオイルでべとべとにしておきました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い雲形の模様が薄く泛びでてゐて、このごろ流行のオイルシルクで作つたレーンコートに彷彿としてゐる。",
              "citation": {
                "source": "河童酒宴",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ガロン入の丸缶の内身を、ドラム缶入のディーゼル・オイルとまぜ、別のドラム缶と、交互に入れかえること二十回、長い竹の棒でよくかきまぜた上、二十四時間放置したのを霧ふきで、ふきかけるのである。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイルクロースを張った食卓の一番端に、皿を持って行って坐ると、丁度食事を終って立上ったＧが、実にさりげなく、塩と胡椒の小瓶を右手の甲で押して食卓の上をすべらし、僕の前に置いて出て行った。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            }
          ]
        }
