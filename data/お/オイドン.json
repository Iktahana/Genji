          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "にらみ合っただけで一合も渡り合わずに、突然江戸錦がぷいと立ち上がって、にたり微笑を漏らすと、「おいどんが負けでごんす」　つぶやきながら、さっさとたまりへ引き揚げてしまったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいどんもちっと胸糞が悪るうになって来ましたけん」　馬場先門をさけて日比谷から数寄屋橋。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "両国の大鯨",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいどんと違うて先が見ゆうかあ豪いですよ」　と実業家風のが言うと、「……論より証拠使用人が大将の為めに労を吝みません。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大隈はん、もう何も言わぬ、おいどんには理窟も何もなか、――何事もよかごと頼む、今度だけは一つ、おいどんを助けてもらいたい」。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大隈はん、恩に着ますぞ、おいどんは薩摩武士じゃ、おはんを見殺しにはせん」。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはははは、今夜あ、貴公たちが、おいどんに、奢ってもよか！",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいどんと呼ばわるどじょう髭もあるし、吾輩がと肱を張る五ツ紋もある。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
