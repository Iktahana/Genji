    "definitions": [
      {
        "index": 1,
        "gloss": "emotional attachment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こういう時代物の映画で俳優たちのいちばんスチューピッドに見えるのは、彼らが何かひとかどの分別ありげな思い入れをする瞬間である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主従は互に見交わす眼と眼に思い入れ宜しくあって、ム、ハハ、ハハ、ハハハと芝居ならば政宗方の計画の無功に帰したを笑うところであった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "（暫時深き思い入れ。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女決心した思い入れあって――ええ、よろしゅうございます。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（女思い入れあって）仕方がございません。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書店で本を買うときは、ほとんどが思い入れを原動力として仕事を続けている書き手に対して、ちゃんと挨拶したような気分でいられます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集にまつわるさまざまな作業の中で、もっぱら手間のかかるめんどうな仕事を下請けでこなすプロダクションには、思い入れを育てる余地はなかなかありませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書く側には、書き手としての抜き差しならない思い入れがあるでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画に対する強い思い入れを土台として生まれたボイジャーの仕事には、最初からはっきりとした主張が込められていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしかし、この考えは自分に取っては決して良い考えでは無くて、どんなに達観して悟ったような事を思ったからといって、それなら明日から世間の外の人となれるかと云うと、そうはなれないというのなら、やはり正直に筋書に従って、同じ感慨、同じ希望、同じ思い入れをした方が良いのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなどは更にわけの若衆の思い入れにはあらず、情を懸けし甲斐こそあれ」とは、西洋で石田を耕すに比べられ、『四季物語』に「妹脊の道は云々、この一つのほかの色はただ盛りも久しからず、契りの深かるべくもあらぬ事なるを、いい知らずもすける愛なき云々、幼き心つからは何かは思わん。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホントに頼りにならないひとね……」　浅井夫人は、ちょっと周囲に目をやり、すぐにあきらめ、では改めて、という思い入れで、身じまいを正し、慶一に笑みをむけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "安心するように、高志にいってくれ」　ノブのまわる音がして、慶一は手で義晴を追いはらい、外の空気を吸っていた、という思い入れで、ゆっくりと寮長をふりかえった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは、坐った位置から、うしろ手にもった教鞭をリズミカルに動かしながら、生徒を見まわるといった思い入れの、関口先生の表情をあおったパーン。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と仁王立になった信玄と、ちょんびり、出立の用意を命じて思い入れした信玄とが短くつながって幕になってしまったのである。",
              "citation": {
                "source": "印象",
                "author": "――九月の帝国劇場――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、「小豚派作家論」と題してきり出された勇ましいその評論も、すえは何となししんみりして、最後のくだり一転は筆者がひとしおいとしく思っている心境小説の作家尾崎一雄を、ひいきしている故にたしなめるという前おきできめつける、歌舞伎ごのみの思い入れにおわった。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角速い車を駆って定刻にうまく滑りこみながらも、花道で飛んだ思い入れ沢山の芝居を演じたため、ハッと気がついて出勤簿の前に駈けつけたときには、ほんの今すこし前、庶務の給仕が集めて持っていったところだと聞かされた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "リアリスティックであるようだが（場面の登場人物、その動作、言葉、たとえば土地名物の餅のたべかたまでこまごまと書いてあるが）読者はそれがすべて藤村流の気分・心持で圧えられ、思い入れを伴って描かれ、人物自体、動作自体が地の文の上に浮動して活躍していないことを感じる。",
              "citation": {
                "source": "「夜明け前」についての私信",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その現実に対する角度は、芭蕉のように身を捨てて天地の間に感覚を研ぎすました芸術家の生涯にある鋭い直角的なものではなく、謂わば芭蕉を味うその境地を自ら味うとでも云うべき、二重性、並行性があり、それは、藤村の文章の独特な持ち味である一種の思い入れを結果しているのである。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章における思い入れと芭蕉の云ったしほり余韻との本質的相異については云うまでもないことである。",
              "citation": {
                "source": "鴎外・漱石・藤村など",
                "author": "――「父上様」をめぐって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国はこれでいいのかと焦れる気持ちばかりが強かった中で、一九六〇年代に出合った歌と一九七〇年代に生まれたパーソナルコンピューターには、素直に思い入れることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターには何の思い入れもなく、パワーブックをまな板代わりに使うような同居人は、記述が技術的な説明やスペックの紹介に及ぶとプリントアウトを数枚まとめて放り投げ、物語の本線のみを追った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械工学になにか思い入れがあったわけではなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "スグ向うに並んだ松板の間からチラリと見えた赤い物に気が付いたからであった、担いでいた杉皮の束を、鋸屑の山盛りの上に置くと、ハテナという思い入れ宜しくあって抜足さし足も半分、芝居がかりに壁のように並んだ松板の蔭に近寄った。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　窓によりかかった阿濃は、鼻の穴を大きくして、思い入れ凌霄花のにおいを吸いながら、なつかしい次郎の事を、そうして、早く日の目を見ようとして、動いている胎児の事を、それからそれへと、とめどなく思いつづけた。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という思い入れだ。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて、それはふしぎだ」　怪塔王はあらあらしい息づかいをして、無念のおもいいれです。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
