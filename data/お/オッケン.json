          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この點に關して、世俗の臆見ほど誤謬の甚だしいものはない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不安は事物に対する吾々の臆見がもたらすのであつて、事物それ自体に不安の伴ふ暇はない。",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不安は事物に対するわれらの臆見がもたらすものであって、本来の事物に不安の伴うものではない。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "初から神は人なりというような臆見成心を有っていて、それによって神代の物語を改作したり、その物語と遺跡や遺物との間に曖昧な妥協的結合を試みたりするのは、決して科学的の研究ということは出来ぬ。",
              "citation": {
                "source": "神代史の研究法",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、人間はみな、つねに発生と死滅との中間にいて、自己に関してただぼんやりした影のような写像と、不確実でたよりない臆見とを、与えているだけだからである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
