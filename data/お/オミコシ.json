          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この言葉の定義は「mikoshi」である。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」という意味で使われることが多い。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という概念は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "その出来事は「mikoshi」の良い例だ。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」という価値観が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という考え方は昔から存在する。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」というのは難しい概念だ。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」を理解することは重要である。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」という側面から見ると異なる。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という表現は適切だ。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」の意味で使用される。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という判断は妥当だ。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」という概念を日本語で表す。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という視点は有効である。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」の例は多く見られる。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という定義で理解している。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」という意味が込められている。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」という考え方に共感する。",
              "source": "幻辞"
            },
            {
              "text": "「mikoshi」という要素は不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "mikoshi」というテーマで議論した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "沈み切っていた、職人頭の富さんが、運八に推遣られて坐に返ると、一同も、お神輿の警護が解けたように、飲みがまえで、ずらりとお並びさ、貴方。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてお神輿を上げようと思つたが、コニヤツクに湯ざましを割つたコツプの、飲み干さずにあるのが目に着いた。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事と知ったら来るのじゃあなかったと、おかみさんも後悔していましたが、今さら帰るにも帰られず、まあ小さくなって辛抱して居りますと、やがて四ツ（午後十時）過ぎでもございましょうか、唯今お神輿のお通りでございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗いなかでお神輿の金物がからりからりと鳴る音と、それを担いで行く白丁の足音がしとしとと聞こえるばかり。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神輿は上の町のお旅所へ送られて、暗闇のなかで配膳の式があるのだそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お神輿は未だ／＼お練が大変で御座んすよ。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "末法に入ると、叡山の坊さんは、ねじり鉢巻で山を降りて来て三井寺を焼打ちにし、遂には山王様のお神輿をかついで都に乱入するまでになりました。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "女一　（髪を束ね直しながら）さ、お神輿を上げようかね、朝っぱらから据わり込んでいても、いい話もなさそうだし――。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはいづれも田舎じみた男女が大勢佇んでをり、その中を小さいお神輿が一台ワツシヨワツシヨとかつがれて行つた。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「お神輿の渡るを見るや爪立ちて。",
              "citation": {
                "source": "夢",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりお神輿を揉むように、揉みに揉んで宮川の河原へ、一同が押し出した時分になって、あたり近所がようやく騒ぎ出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お祭のお神輿様か知ら、御祭礼があったようにもないが、おかしいねえ」　お雪ちゃんは、寝巻のまま立って、雨戸へ手をかけて無雑作に引きあけてみた途端に、「あっ」と言って、眼も口も打たれて、開くことのできなくなったのは、濛々として外から捲き込んだ烟でした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は大甕のとなりの腰掛けにお神輿を据えて、やり始める。",
              "citation": {
                "source": "天才",
                "author": "ТАЛАНТ",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままで押しだせッ」　ワッショイ、ワッショイ……まるでお神輿をかつぐような騒ぎ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ、お神輿をあげるとしようか。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろく侍どもをしりめにかけて、押し入って来た蒲生泰軒は、この日からこのとんがり長屋にお神輿をすえることになった。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらに肩を押し合い、揉み合い、めいめい先へ出ようと邪魔しあって、お神輿をかつぐようにギツシリ廊下に詰まって、ワッショイワッショイ！",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、いくらお祭日でもまさかあたしが古鎧櫃のお神輿になって車で出て来ようとは思うまいから今度こそはまんまとまいてやったというものさ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神輿栄太ってましてね。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神輿栄太ということは差配の伊勢源と近所の店子たちの証言によって判然したのであった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田明神は祇園三社、その牛頭天王祭のお神輿が、今日は南伝馬町の旅所から還御になろうという日の朝まだき、秋元但馬守の下屋敷で徹宵酒肴の馳走に預かった合点長屋の釘抜藤吉は、乾児の勘弁勘次を供につれて本多肥後殿の武者塀に沿い、これから八丁堀まではほんの一股ぎと今しも箱崎橋の袂へさしかかったところ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "三つの足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "大沼博士はもちろん植物学界の重鎮であるが、旅行の好きなことでは、よく若いものから笑はれるくらゐで、誰が何処から呼ばうと、旅費さへ心配のないやうにしてあれば、きつとお神輿をあげるのである。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お邸が坂の上の小高い処にあるものですから、まるでお神輿様を見下していらっしゃるような形だったので、気の立っている若い者が怒ってしまい、そのうちに誰だか奥様は寝間着じゃないかなどというものも出てまいり、神様を高い処から寝間着で見下すとは怪しからん。",
              "citation": {
                "source": "機密の魅惑",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と安子夫人は漸くお神輿を上げて台所へ御出馬になった。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか感激のあまり泣きだしそうにさえなったくらいだが、それと同時に、もうそろそろお神輿をあげるころあいだと感じた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」九　幽靈　パーヴェル・パーヴロヴィチはさも居心地よげにお神輿を据えていた。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなりお神輿をあげて、醫者を迎えにペテルブルグへ飛んで行って、幾人かの名醫をすぐって連れて來て、立會診斷をやってもらうのであった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だがあなたは、すっかりお神輿を据えちまったもんですねえ」と、痛みのためろくろく聲も出せずに、ヴェリチャーニノフは注意した、「私は横になりますよ……あなたは御隨意に。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小商人はこれでもう二日もこの停車場にお神輿を据えて、いろんな取卷き連にわいわい擔ぎ上げられながら、酒は浴びる錢はばらまくといった調子で、いまだに先へ行く列車に乘りこめずにいるのであった。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達もいつまでも油を売ってはいられないから、それを機会にお神輿を上げた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
