        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "風は峡間にどこからともなく漲って来て、樹々の葉は、婆娑婆娑と衣摺れのような音を立てる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り秋風が立ち始めて黍の葉がかさかさ音を立てるころになると世の中が急に頼もしく明るくなる。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかとの裏の三角形の鉄片がまず門内の敷石と摩擦してゴリゴリまたゲリゲリとすさまじい音を立てる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで取っ手を回すと同じリズムでキュル／＼／＼と一種特別な轢音を立てるのであった。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌のさきを奥歯にやって、それをかみながら一種の音を立てる癖があった事を思い出す。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちどまってみると、ぼくのからだはぶるぶるふるえて、ひざ小僧と下あごとががちがち音を立てるかと思うほどだった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の間頑固にかじり附いて枝を離れず、吹雪にもざわ／＼と淋しい音を立てる赤褐色なその廣葉も、小さな嫩芽の追ひ立てを喰つては一たまりもないのだ。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい足はよろめいて、二三度可愛ゆい下駄の音を立てるだろう。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは雑朶の細枝のふたまたになって居る岐れめに何かの虫が附けた玉子から、至極｜巧に、中味の虫の子が脱け出したあとの、可愛い笛の様な音を立てる小さな穴の一つあいた、かやの紅さし指のあたま位いな、貝のように硬い滑かな、灰色に白い斑の付いた殻であった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "躓きて縁の上に音を立てる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "残らず、薄樺色の笠を逆に、白い軸を立てて、真中ごろのが、じいじい音を立てると、……青い錆が茸の声のように浮いて動く。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もの凄まじい爆音を立てると、さすがに驚いたように草が騒いだ。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴虫が音を立てると、露が溢れますような、佳い声で、そして物凄う、（ここはどこの細道じゃ、　　　　　　　細道じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしの風にも音を立てる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪は、窓を掠めて、サラ／＼、サラ／＼と微な音を立てる……辛うじて心で聞取れるやうな寂な響であツた。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮も胴もかなり新らしいもののように見えて実は百年ばかり前に出来たものらしいが、これをしかけて打ってみると、ほかの鼓の、あのポンポンという明るい音とはまるで違った、陰気な、余韻のない……ポ……ポ……ポ……という音を立てる。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "高の知れた鼓一梃が人の一生を葬るような音を立てるなんて怪しからぬ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢にかけた湯鑵の湯水が、やうやく暖まつて来て、微々の音を立てるやうになつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渦と渦と抱き合ってぴちょんぴちょんと音を立てる。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大儀ぢや』と正しく如意輪が仰せあつた……『はツ、』と云ふと一個、丁ど石高道の石※へ其の一本竹を踏掛けた真中のが、カタリと脚に音を立てると、乗上つたやうに、ひよい、と背が高く成つて、直に、ひよこりと又同じ丈に歩行き出す。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五寸程芽の出掛かつた椰子の實の落ちてゐるのを蹴飛ばすと、水の中にころげ入つてボチヤンと音を立てる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五寸ほど芽の出掛かった椰子の実の落ちているのを蹴飛ばすと、水の中にころげ入ってボチャンと音を立てる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "音を立てるような視線だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "音を立てるちふのは、その人の将棋がまだ本物になつてん証拠だす。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、彼は駒の音を立てるやうなことは決してしない。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつかしい経済学上の理論などはわからないが、あの五十銭銀貨一枚を財布からつまみ出して切符売り場の大理石の板の上へパチリと音を立てるとすぐに切符が眼前に出現するところに一種のさわやかさがある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしや獅子や虎でも同じような音を立てるものだったら、この音はいっそう不思議なものでありそうである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて、いせいのいい音を立てることでしょう。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
