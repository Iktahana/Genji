  {
    "uuid": "a22ddb94-9694-57b7-a804-4ce2d4ddc0dd",
    "entry": "己",
    "reading": {
      "primary": "おの",
      "alternatives": [
        "おぬ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
