      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "蹌踉めくままに静もりを保ち、聊か儀文めいた心地をもつてわれはわが怠惰を諫める、寒月の下をゆきながら、陽気で坦々として、しかも己を売らないことをと、わが魂の願ふことであつた！",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "横光氏が此の詩集の序に「惑乱を防ぐ克己」を以て此の詩人の特質としてをられることには意義がある。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊岡久利の詩が、記憶を可なり無雑作に書き付けてゐる場合にも、猶一貫した流れを見せる所以のものは、彼のその克己が、彼の遠近法を乱すことがないからである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ気持になるには、己を空うせねばならない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自己以外のものと争ふことは修辞を作り、自己と争ふことは詩を作る」（三六・一〇・五）",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋持続の、人に於ける心理的状態は、強ひて言へば、未来を思ふとしては神を、現在を思ふとしては自己を、過去を思ふとしては運命を信じてゐるのだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しパンセは起るものとして自己を益し、パンセしようとしてすれば良く行つて歴史家の知にしかならないものだ。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり文学芸術といふ観念が自己の胸底に十分に確立しなければならぬ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織袴を忘れずに、帽子はなるべくアミダに冠らないやうにして、六ヶ敷い顔をして、理想を前例に照して持つてゐれば、近所知己の評判は良いのでありませう。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして兎に角にも自己流の珍らしい建築を完成した。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私と北原白秋氏とは彼の最初の知己であつた――あまつさへ、私自身しばしば彼の表現を模倣しようとして、愚かな失敗を繰返したことさへある。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し私共二人が、互にその思想や主張の上で自己を押し立てようとするならば、私共はとくに血を流すやうな争論を繰返して居なければならなかつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の意志や感情やを、真によく対手に呑み込んでもらうためには、対手が自分の親友｜知己であり、自分の心持ちや性格やを、充分によく知っているものでない限り百万言を費して無駄になる場合が多い。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は、かつて伊香保で知己になつた谷崎潤一郎氏に對しても、やや同樣の邪推なしに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己嫌悪で一ぱいだ。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己弁解でない文章を読みたい。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンチテエゼの成立が、その成立の見透しが、甚だややこしく、あいまいになって来て、自己のかねて隠し持ったる唯物論的弁証法の切れ味も、なんだか心細くなり、狼狽して右往左往している一群の知識人のためにも、この全体主義哲学は、その世界観、その認識論を、ためらわず活溌に展開させなければなるまい。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己嫌悪、含羞、閉口しているのであろう。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "博識の人が、おのれの知識を機会ある毎に、のこりなく開陳するというのは、極めて自然の事で、少しも怪しむに及ばぬ筈であるが、世の中は、おかしなもので、自己の知っている事の十分の一以上を発表すると、その発表者を物知りぶるといって非難する。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、私は自己統一ある奴であつたのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――このことは今になつてやうやく分るのだが、そのために私は甞ての日の自己統一の平和を、失つたのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つにはだいたい私がそれまでに殆んど読書らしい読書をしてゐず、術語だの伝統だのまた慣用形象などに就いて知る所殆んど皆無であつたのでその口惜しさに遇つて自己を失つたのでもあつたゞらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく私は自己を失つた！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も私は自己を失つたとはその時分つてはゐなかつたのである！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――然るに、自己をなくしてゐた、即ち私は唖だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煮え返る釜の中にあつて、私は過ぎし日の「自己統一」を追惜するのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見ることを見ること」が不可能な限り、自己の叫びの当の対象を、これと指示することは出来ない。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　扨、対抗的でなくなるためには人は先づ克己を持てばよい。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われらひとしく丘に立ち〕宮沢賢治われらひとしく丘に立ち青ぐろくしてぶちうてるあやしきもののひろがりを東はてなくのぞみけりそは巨いなる塩の水海とはおのもさとれども伝へてきゝしそのものとあまりにたがふこゝちしてたゞうつゝなるうすれ日にそのわだつみの潮騒のうろこの国の波がしらきほひ寄するをのぞみゐたりき",
              "citation": {
                "source": "〔われらひとしく丘に立ち〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
