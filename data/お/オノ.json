[
  {
    "uuid": "9e7e2f87-17fd-5ce0-ab7c-3c9b4d681b64",
    "entry": "斧",
    "reading": {
      "primary": "おの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
