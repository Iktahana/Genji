[
  {
    "uuid": "c8e6d021-b277-5d22-a9d8-42cd035dc8ec",
    "entry": "遅れる",
    "reading": {
      "primary": "おくれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
