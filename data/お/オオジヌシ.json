        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "富豪であり、大地主であり、県政界の大立物である本田氏の、頭蓋骨にひびが入ったと云う、大きな事実に対して、証拠は夢であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別な家柄でもなく一介の土木技手上りに過ぎない貧乏な作家と、大地主で大金持で伯爵の名門に生れた作家と、その呟きには何か胸を打つものさへあるが、とにかくドストイェフスキイは時には境遇的にも自分の原稿を讀み返す暇さへ持てなかつた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "満洲ハタダ大資本家大地主ヲ太ラセルダケダ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社務所には、既に、近頃このあたりの大地主になれらましたる代議士閣下をはじめ、お歴々衆、村民一同の事をお憂慮なされて、雨乞の模様を御見物にお揃いでござりますてな。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "村でも一番の大地主で、この辺でも指折の富豪です。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また川向うの斎藤だって、いまこそあんな大地主で威張りかえっているけれども、三代前には、川に流れている柴を拾い、それを削って串を作り、川からとった雑魚をその串にさして焼いて、一文とか二文とかで売ってもうけたものなんだ。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に凡俗の、ただの田舎の大地主というだけのものであった。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、大地主の子である。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は大地主の子である。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚前智子は二三度武蔵野の大地主であった三木雄の父の遺した田舎の邸宅へ三木雄を訪れ、其処に後見やら家政婦やらを兼ねていた中老の叔母からもよくもてなされ、その叔母さんの淡泊な性質はむしろ好んで来たのであるが、三木雄の教養に対する叔母さんの無頓着さには呆れて聊か腹立たしくさえ感じた。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時初め君主政の行はれた Attike（Athen）は貴族政に一變してゐて、實權は大地主の手にあつた。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は、会議及び其の実権者、ツラファレ（大地主）達が王を操っていたのに、今は、アピアの街に住む極く少数の白人が之に代ったのである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちの左手にある森の上には、もう大地主であるトレヴォの家の高い煙突と旗竿とが見えていた。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の大地主で、数多の借家を持ち、それで、住宅の向前に酒や醤油の店を持っている広栄の家は、鮫洲の大尽として通っていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無償ヲ以テ徴集スル所以ハ、現時大資本家大地主等ノ富ハ其實社會共同ノ進歩ト共同ノ生産ニヨル富が惡制度ノ爲メ彼等少數者ニ停滯シ蓄積セラレタル者ニ係ハルヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本現時ノ大地主ハ其經濟的諸侯タル形ニ於テ中世貴族ノ土地ヲ所有セルニ似タルモ、所有權ノ本質ニ於テ全ク近代的ノ者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會主義的議論ノ多クガ大地主ノ土地兼併ヲ移シテ國家其者ヲ一大地主トナシ以テ國民ハ國家所有ノ土地ヲ借耕スル平等ノ小作人タルベシト云フハ原理トシテハ非難ナシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ガ大地主ノ土地ヲ徴集スルコトハ最高ノ所有者タル國家ノ權利ニシテ國有ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地主ト投機商人トノ有スル大資本ガ米穀ノ買占メ賣惜ミヲ自由ナラシメテ現時ノ米價騰貴ヲ現出シツツアルヲ見ヨ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "將來ノ帝國領土中、先住國民ノ大富豪大地主アリテ多大ノ土地ヲ獨占シ又ハ生産業ヲ專有スル時是ヲ是認スル如キアラバ、日本國家ハ只彼等ノ不義ナル財産ノ保護ヲ負擔セシメラレ、日本國民ハ只其ノ小作人タリ勞働者タルニ過ギザル可シ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英國ハ全世界ニ跨ル大富豪ニシテ露國ハ地球北半ノ大地主ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヒユース」ガ勞働者出身ナリトモ、「レニン」ガ社會主義者ノ尊敬スベキ同志ナリトモ、國際的對立ヨリ見テ彼等ガ〔大地主〕タルコトハ、昔時魚賣タリシ大倉喜八、貧書生タリシ加藤高明ガ無産階級ヨリ見テ富豪タルト同シ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も狡猾な都会人に欺かれて早くから地所を手放して了ったのもあるが、中には拱手して忽ち意外なる市街地の大地主となったものもある。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にいる、爵位のある大地主も、時々北海道へやってきて、小作人や村の人達を「家来」に仕立てて、熊狩りをやった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "村長を看板にし、関係大地主が役員になって、「土功組合」を組織し、北海道庁から「補助金」や「低利資金」の融通を受ける。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地主は只のような金で、その金の割合の何十倍もの造田が出来た。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地主の存在がジリジリと圧迫していた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――龍徳寺の前には、岸野や吉岡などの大地主や、※、吉本などの寄附金の「芳名録」の札がズラリと立っている。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
