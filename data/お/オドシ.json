[
  {
    "uuid": "f936998f-8b90-510d-a5d2-1b8d19256556",
    "entry": "脅し",
    "reading": {
      "primary": "おどし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "threat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして一人｜留守番のときの用心に、いつものように入口に鍵をかけ、電燈を消して、蚊帳の中に這入り、万一｜忍び込むものがあるときの脅しに使う薄荷入りの水ピストルを枕元へ置いた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "璧を齎ちて河を渡りける時、河の神の、璧を得まくおもふより波を起し、蛟をして舟を夾ましめ其を脅し求むるに遇ひしが、吾は義を以て求むべし、威を以て劫すべからずとて、左に璧を操り右に剣を操り、蛟を撃ちて皆殺しにしけるとぞ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "死の脅しがすぐ彼には感ぜられた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか脅し気味でもあつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼からかけての心の顫は漸く薄らいだが恐怖は却つてはつきりした知覚を以て彼を脅した。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に至るまで持続せられて行く生に対する脅しを恐れたのである。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり刺青のマニアっていう奴ね」「…………」「いやがるのを無理に、脅したり、すかしたり、甘言を弄したりして、家へ連れこんでは、麻薬をかがせて、刺青をしてしまうのよ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その態度は物の味の試しを勧めるというより芝居でしれ者が脅しに突出す白刃に似ていた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢の中の虐待者に対する恐怖感迄が甦って来て彼を脅した。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はもう帰るよ」　とナフキン紙をテーブルに投げつけてわたくしを脅しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はだいぶ安心したものか、もうこの頃ではわたくしを芸妓にするの妾に出すのなぞという見え透いた脅しは言わなくなったと池上は苦笑していました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ綺麗よ」と言って娘たちを脅した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは決して脅しでも気取りでもない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆるらかに幾尺の水晶の念珠を引くときは、ムルデの河もしばし流をとどむべく、忽ち迫りて刀槍斉く鳴るときは、むかし行旅を脅ししこの城の遠祖も百年の夢を破られやせむ。",
              "citation": {
                "source": "文づかひ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今孔氏の宅に入り、伯姫・渾良夫と共に当主｜孔※を脅して己を衛侯に戴かしめた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の改選を要求する島民の声が政府を脅していたことは事実だが、マターファ自身は一度も、まだ、そんな要求をしたことはない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の午前中、ロトゥアヌウからの砲声が我々を脅した。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太子は私を脅して、自分の義母を殺させようとした。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮女装して孔氏の邸に潜入、姉の伯姫や渾良夫と共に、孔家の当主衛の上卿たる・甥の孔※（伯姫からいえば息子）を脅し、之を一味に入れてクウ・デ・タアを断行した。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮女裝して孔氏の邸に潛入、姉の伯姫や揮良夫と共に、孔家の當主衞の上卿たる・甥の孔※（伯姫からいへば息子）を脅し、之を一味に入れてクウ・デ・タアを斷行した。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し将軍義政が東軍に在って、西軍諸将の守護職を剥奪して脅したからである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろ／＼考へた末、芹澤が真先に立つて、八名の浪士がわざ／＼大坂まで行き、鴻池を脅して二百両借りて戻つた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党が説得から脅しへ進んだことがわかり、私はシカゴの悪党どものやり方を知っているだけに、すぐにでも言葉を実行に移すことがわかりました。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで俺は調子に乗って、あいつを脅し始めたんです。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すると脅しの張本人は誰だろう？",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつらはその妻とやらに手紙を送り、そっちへ行ってばらすぞ、と脅した。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察へ訴え出なかったところを見ると、ベドウズは脅しを本気と誤解したのかもしれない。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでばらすぞと脅し、ふたりを転がして金をせしめようとしました。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンディシェリの場合には、脅してから殺すまでが七週、ダンディの場合がわずか三・四日、この示すところは何か？",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のおどおどしてまごついてる樣子をみると、彼は直ちに態度をかへ、急に平易なざつくばらんな調子になつて、心おきなく書生流儀で話しかけた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
