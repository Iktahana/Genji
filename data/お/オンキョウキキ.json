          "standard": [],
          "literary": [
            {
              "text": "一九六九（昭和四十四）年五月、富士通の音響機器部次長だった友納春樹が設立した通信機器メーカー、サイバネット工業は、歴史の波に翻弄されてジェットコースターに乗ったような急成長と急激な衰退とを短期間で経験していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "百貨店を歩いてあらためて見なおしてみると、家電製品や音響機器など、日常的に使われる道具はいずれもプラスチックのケースに収まっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を上りほとんど暗闇に近い薄明りの中を様々な音響機器に体をぶつけないよう注意しながら自分の場所へすみやかに進んで行く。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
