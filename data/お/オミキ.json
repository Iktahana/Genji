    "definitions": [
      {
        "index": 1,
        "gloss": "sacred wine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さあ、このお神酒をあげてお詫びをなせえ。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の力だけを信じている農村の病患者を救うには、竹駒稲荷大明神の御供物、お神酒と言って医薬を施すより他には途がないものと思ったからで御座います。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汝は、も一つお神酒とお洗米を持って来てくれないか、お倉の方へな」「よろしゅうございます、すぐ持ってまいります」「それじゃ、俺は前へ往ってるから」「それじゃすぐ持ってまいります」　定七はすぐ腰をあげて出て往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を飲まうと云ふと屹度始めは断る、さうして見るからに苦い顔をしてゐる、その癖少しお神酒が回つて来ると独りではしやぎ出すんだ。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」純七郎はお神酒をチビチビ飲みながらビラを見上げて云つた。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃあ、わたしも早くお参りをして、お神酒とお供え物をあげて来ましょう」　女房は帯をしめ直して、表へ出る支度に取りかかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お神酒を出すんだけはわたしは反對や。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆さんはそのお仕着のお神酒がまはると、好い機嫌になつて唄など口吟みながら、笑つたり泣いたりして嬉しがるのであつたが、何うかすると姑風を吹かしなどして、妻の気色を悪くするのであつた。",
              "citation": {
                "source": "余震の一夜",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はイクラかお神酒がまわっていたせいかも知れないがね。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、少しお神酒がまわると、すぐに手拭をかぶって、口で笛と太鼓の調子を一つにとりながら、腰を据えて、肩を揺って、塩吹面舞と言うのをやりたがる。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸銭御無用、千客万来の芝居、お神楽、其れが出来なければ詮方無しのお神酒祭。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の朔で、八幡様に神官が来て、お神酒が上る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お石の間で散々にお神酒をいただいて行った形跡もあります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一杯飲んでも、えいじゃないか、えいじゃないか」　神前のお神酒をかかえ出して、自らも飲み、人にもすすめながら踊りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかにおしいただいて神棚へ上げるやら、お神酒を供えるやらの騒ぎとなりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お民、このお神酒は家じゅうでいただこうぜ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、条山神社のお神酒でもいただいて、今夜はよく眠ることだ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "村では鎮守に、お神酒があがった。",
              "citation": {
                "source": "戦争雑記",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年秋）　　　モリヨリヨン　モリヨリヨンは、狂馬楽が先代文楽と、それぞれの前名千枝伝枝のお神酒徳利でつるんで歩いていた頃に創作した落語家一流の即興舞踊とつたえられる。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れて行った人夫は携帯のお神酒とお供とを神前に捧げて礼拝した後、賽銭は下げて懐に入れてしまった。",
              "citation": {
                "source": "三国山と苗場山",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神の町に行き着いたよろこびのあまり、無邪心小児のごとき泰軒が、お神酒をすごして大道に不穏な気焔をあげている時、山田奉行手付の小者が通りかかって引き立てようとすると、ちょうど前の脇本陣茶碗屋の店頭から突っかけ下駄の若い娘が声をかけて出て来た。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな雌猫の化けたやうな脂ぎつた女なんかと見換へちや罰が當るよ」「お町、口が過ぎるぞ」「お神酒は過ぎてるが、口なんか過ぎるものか」　お町は一寸も引きさうにありません、――それどころか、長火鉢の向うへ、女だてらに大胡坐をかくと、お樂の手から猪口をむしり取ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな雌猫の化けたような脂ぎった女なんかと見換えちゃ罰が当るよ」、「お町、口が過ぎるぞ」「お神酒は過ぎてるが、口なんか過ぎるものか」　お町はちょっとも引きそうにありません、――それどころか、長火鉢の向うへ、女だてらに大胡坐をかくと、お楽の手から猪口をむしり取ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神酒は些かでも、氣の合つた親分子分は自分達の話に醉つて、いつかは陶然とした氣持になつてゐたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様だってお神酒をあがるんだからな」「そうかい、それじゃ済まねえが、一杯やらしてもらうとしよう」　小林文吾は米友の好意を得て、また徳利を引き出しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "でこでこの頭が二つ恭しく段のうへに据ゑられ、巻奉書のそぎ竹のやうなのがつくんと立つた大きなお神酒徳利が供へられる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷馬車の御者は樹木を欲しがり、医師は病気を欲しがり、祭司はお神酒を欲しがる。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "「羨ましいね、御両人は」「若旦那同志のお神酒徳利だ。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "優良若旦那の好一対、お神酒徳利として認められたのは夙にこの頃からだった。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下のスペースには、大きな太鼓がはめこまれたようにつんであり、お神酒をそばに、地元のだんなたちが何人も乗っている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
