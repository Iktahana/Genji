        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこに此の世の喜びの話や悲しみの話は、彼のためには大きすぎる声で語られ、彼の瞳はうるみ、語り手は去つてゆく。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別、先生の口唇が、鼻腔が可笑しいといふのぢやない、起立して、先生の後から歌ふ生徒等が可笑しいといふのでもない、それどころか、俺は大体、此の世に笑ふべきものがあらうとは思つちやゐなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に邪魔になる程に、大声で笑つたわけでもなかつたし、それにしてもだ、先生がカン／＼になつてたことは事実だし、先生自身何をそんなに怒るのか知つてゐぬらしいことも事実だし、俺としたつて意地やふざけで笑つたわけではなかつたのだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人となつた今日でさへ、さうした悲運はやみはせぬ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変元気で粗忽が自慢でもある、甚だ罪のない男がその夜の進行係をやつてゐて、一人で大声で喋舌つてゐたが、大部分の者は聴いてもゐなかつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "進行係は依然大声を出してゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞きながら、大きいガツテンガツテンを、アクセントをつけてやつてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分類が終るや能事足れりとなす所に、現代インテリの過ちがあり、恐らくこの過ちが彼を不幸にした大きい理由であつたと云へよう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて暫く案じた揚句、大抵はお断りすることとなるのでありますが、今もよつぽどお断りしようかと思つた所でありました。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人によつて色々異ることと思ひますが、私は詩に就いては自分に分るやうにだけは考へますが、それを人に分らせようとするや大変骨が折れます。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も骨を折つた結果は、大抵の場合自分は気拙くなり、相手には殆んど役に立たないやうな次第です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又近頃は詩の定型無定型といふことが盛んに論じられてゐますが、私は定型にしろ無定型にしろ、面白ければいいといふ程の呑気なことしか考へてをりませんが、なんだか此の問題は具体的のやうでゐて、その実途方もなく遠大か何かのやうに受取れます。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や、どんな観念が大切だなぞとは猶更云つてゐるのではない。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはこれら彼の作品が、大正十三年頃、つまり「春と修羅」が出た頃に認められなかつたといふことは、むしろ不思議である。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年、「宮沢が死んだ」と聞いた時には、大変気の毒に思ひました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ「明治・大正詩人論」といふ書が近々出るわけですから、その中で宮沢賢治のことは、詳しく論じたいと思つてゐます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "感想中原中也　地方の詩のグループも多いことだが、どういふものか、ずつと以前から大連と神戸にだけ面白いものが見られるのだつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "感覚、つまり自然を何よりも大事に守つて居るからである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり彼は詩人として第一に大事な点に於ては決してころがりつこないのだ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学を出て一年ばかり郷里の日向で何をするともなく暮してゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大正四年元旦――",
              "citation": {
                "source": "竹",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて各人各様の特質にも拘らず、可なり大同小異の観があることは脱れられない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて芸術上の新様式の発生期に当つてその新様式を是非することは、予想外の困難を伴ふことだし、大概の場合正鵠を射当てることはない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり大人の芸術とはなることは出来ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ是等三様式は極めて短い詩形であるから、語自体の力が、語を駆使する作者の力よりも存外に大きいものであることは明瞭であらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬚がそよそよと伸びるのが肉眼でも判るほどだから、と真顔で教えたら、だまってしゃがんで僕の顎を皿のようなおおきい眼でじっと見つめるじゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおきいふぐりをぶらさげて、さあ、この一物をどうして呉れる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
