        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "春風駘蕩たるところが無いんで、僕なんか、いつでも南国の芸術家には押され気味だ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼にする物象が絶えず跳ね動いているような活気に矢代は人からも押され気味になり、受け答えにも窮する遅鈍なものが、いつの間にか自分になっているのを感じた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らを五月の山の精としも思ふ卯つ木は思はせておけ　毒うつぎともいはれる卯つ木が紅白とりどりに初夏の山に咲き誇る勢ひは大したもので、藤にしろ躑躅にしろ蹴押され気味である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがの帆村も、その大力に抗しかねて、押され気味となった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご自分に罪はないとお信じになれれば、それでよろしいんぢやございません」と、彼女は、さつきまで、どことなく重みもあり、鋭さもあるその言葉つきと風貌とに押され気味であつたのに、いつか、それにかゝわりなく、かへつて年下のものに対するやうな馴れ馴れしさで物を言つてゐることが自分にもわかりました。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間に出てからは他に押され気味で、いつとはなしに引込み思案に陥ることが慣いとなった。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんパンもあんの部分だけは食わない、ビスケットなどは噛んでやればよろこんで食べる、この二ツのうち、三毛の雌の方が丈夫でトラの方が少し痺弱いようだ、組打をしてもトラの方が押され気味で、いつもねわざに受けて居る。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "気押され気味に伝二郎は咽喉が詰ってしまったのである。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年たちはいづれもこの黒岩の登場には押され気味であつたが、小峯喬はこの時、「なあ、万さん、今夜は幾島さんになんか御馳走しようと思ふとつたんだが、生憎、かしはをつぶす暇もなかつたで、おらの家の味噌汁で我慢して貰はんならん。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾島は素子の場所馴れた様子に押され気味で、たゞ黙つて運ばれる料理を次ぎ次ぎに平げた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物技量ともに井上とは少し段違いらしく、井上は押され気味である。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は激流に押され気味に、なお二十メートルばかり進みました。",
              "citation": {
                "source": "水中の宮殿",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら繁昌して、旦那さんすこし押され気味だって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで押され気味の父が東京の有力者と共同で村にモスリンの会社を起した。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相応の成績　最初から押され気味の安達君は兎角自信がない。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――改進党もなかなか侮りがたいぞ、今のところ言論では筑前協会の方が押され気味だ、こっちも少し火の手を挙げんことには、だんだん切崩されるかも知れぬ」。",
              "citation": {
                "source": "風蕭々",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七人の方が却って押され気味である。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの男が配達している間、終始押され気味であった。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷の司馬道場では、このごろこそだんだん、あの源三郎一味におされぎみに、わが屋敷とはいいながら肩身がせまくなっているものの、それでも、椎たけ髱の侍女数十人を顎で使い、剛腹老獪な峰丹波をはじめ、多勢のあらくれた剣士を、びっしりおさえてきたお蓮様だったが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
