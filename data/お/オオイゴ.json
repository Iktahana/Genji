              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "後進の能力を認めこれに信頼することの出来ない大御所的大家ではなかったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝ちさびに天照大御神の営田の畔離ち溝埋め、また大嘗きこしめす殿に屎まり散らしき」というのも噴火による降砂降灰の災害を暗示するようにも見られる。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政の頃本所南割下水に住んで、祿高千｜石を領した大御番役、服部式部の邸へ、同じ本所林町家主惣兵衞店、傳平の請人で、中間に住込んだ、上州瓜井戸うまれの千助と云ふ、年二十二三の兄で、色の生白いのがあつた。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よこしぶき　さても、其の後、江戸で元二が身を置いた處は、本所南割下水に住んで祿千石を領した大御番役服部式部邸で、傳手を求めて同じ本所林町、家主惣兵衞店、傳平と云ふもの請人で齊く仲間に住込んで居たのであつた。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化に於いて、はたまた産業に於いて然り、かしこくも明治大帝の教育に関する大御心はまことに神速に奥州の津々浦々にまで浸透して、奥州人特有の聞きぐるしき鼻音の減退と標準語の進出とを促し、嘗ての原始的状態に沈淪した蒙昧な蛮族の居住地に教化の御光を与へ、而して、いまや見よ云々。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海凪ぎぬ、朝ぼらけ潮もかなひぬ、艫舳接ぎ、大御船、御船出今ぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "行でませや、おほらかに大御軍、まだ蒙し、遥けきは鴻荒に属へり。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大御稜威い照らすと御船出成りぬ、日の皇子や、御鉾とり、かく起ちましぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　御船謡男声（独唱竝に合唱）その一御船出ぞ、大御船出、御伴船挙りさもらへ、御伴びと挙り仰げや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大御船真梶繁ぬき、照りわたる御弓の弭、あな清明け、神にします、あな眩ゆ、皇子にします。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足一騰宮の大御饗、　誰が献る、はるか雲居に。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざのぼれ大御軍、　　いざ奮へ丈夫の伴。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二日下江の蓼津、その津に、雄たけびぞ今あがる、大御軍。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※かなりその肇国、　　窮みなし天つみ業、　　いざ仰げ大御言を、　　畏きや清の御鏡。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "海凪ぎぬ、朝ぼらけ潮もかなひぬ、艪舳接ぎ、大御船、御船出今ぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "行でませや、おほらかに大御軍、まだ蒙し、遙けきは鴻荒に屬へり。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四章　御船謠男聲（獨唱竝に合唱）その一御船出ぞ、大御船出、御伴船擧りさもらへ、御伴びと擧り仰げや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大御船眞棍繁ぬき、照りわたる御弓の弭、あな清明け、神にします、あな眩ゆ、皇子にします。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "足一騰宮の大御饗、誰が獻る、はるか雲居に。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "※かなりその肇國、　　窮みなし天つみ業、　　いざ仰げ大御言を、　　畏きや清の御鏡。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天照らす大御神、皇祖、皇祖かくぞ、　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）大きなり、彌榮や、天つ御業、げに崇し、はや和す大御軍。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ならず、日の御裔、久米大伴が後、神々の我が跫音、大御軍。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
