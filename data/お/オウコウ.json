[
  {
    "uuid": "7f34ca3e-bbd8-570c-a253-5c601ef36868",
    "entry": "往航",
    "reading": {
      "primary": "おうこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
