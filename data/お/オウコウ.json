    },
    "definitions": [
      {
        "index": 1,
        "gloss": "outward voyage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "父親は往航の船の中で既に連れて行った組下の連中と喧嘩をしてしまって、アメリカへ着くと、もう離れ／＼になった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も多くに見積っても、私たちの往航の最後の日に当る頃のことであった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "同船の英吉利人は、往航の場合と等しく復航にも亦私の心を暗くした。",
              "citation": {
                "source": "帰来",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往航でここへ寄ったとき、ヤング名誉領事から南極の地図と、シャクルトンの探検記（The Heart of Antarctic, vol. ※, London 1909のこと）を貰ったので、それを読んで、だいたいの方針をたてた」「食糧は」「米と罐詰、鯛味噌、昆布（トロロ昆布）……それから金平糖。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十五年二月十五日著者しるす第一、南球往航日記（ホンコン、カントン、マニラ紀行）一、南球視察の目的　近年もっぱらわが国の社会教育、地方教育、民間教育に従事せし以来、自ら思うに、戦勝国の国民として世界に活動するには、海外の事情に通ずるを要す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国に往航するときには一日の余日を生じ、日本へ帰航するときは一日の空白を生ずるなり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日前、ウイルソン号が往航で横浜へ入った。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし往航ならば先づ左舷の彼方にエトナが高く屹立してゐるのを見るべく、六七合目以上は無疵の圓錐形をしてゐるので富士を思ひ出すくらゐであるが、それ以下には二百以上の寄生火山が簇立してゐるので鋸齒状の輪廊が見られる。",
              "citation": {
                "source": "火山の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
