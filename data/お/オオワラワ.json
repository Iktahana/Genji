        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "片側の大名邸の高い土堤の上に茂り重なる萩青芒の上から、芭蕉の広葉が大わらわに道へ差し出て、街燈の下まで垂れ下がり、風の夜は大きな黒い影が道一杯にゆれる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま大わらわでお礼状を書いている始末だ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グレグソンとレストレードはこの死に大わらわだろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その選択に大わらわになっているうちに、先程からの気持がようやく、納まるところに片づくのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＸ号をのせて飛びだしたロケットを追って、大わらわの活動がはじまったのである。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐世保のステーションに着いたのは黄昏時で、なるほど、下車する人を見ると米軍の士官や水兵達が大きなトランクや袋なぞをかついで、赤帽達が大わらわである。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "城は大わらわで彼をむかえるにふさわしい歓迎の準備をしていた。",
              "citation": {
                "source": "幽霊花婿",
                "author": "ある旅人の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の秘密など、剖かぬこと剖かぬこと」「そうともそうとも」と合い槌を打ったのは、山口という武士で、「その日その日を食いつなぐだけでも大わらわの我ら、他人の秘密事など、どうでもよかよか。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も五年前の習練を思い出すべく、木片の端をちぎってささくれを作り、その先に結晶を吊して、その結晶の一端を硝子面に唾の小滴で垂直に凍りつかせようと大わらわであった。",
              "citation": {
                "source": "雪後記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして煤煙防止に大わらわである。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大わらわでどたばたやってきて、ぶつぶつ言いながらこっちへ来るんだ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は早朝出勤じゃなく、帰宅するのが遅すぎたと弁明に大わらわ。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の専門家たちはその犠牲者の上でメスや熱した鏝や鉗子を使うのに大わらわだった。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ支配人その他の連中はどこか別の所で仕事の説明や注文に大わらわになつていた。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはすっかり晴れて、うちでは満帆を張りひろげたように白い洗濯物を干し、畑ではくさりかけている麦の手入れと始末に大わらわです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿のわたのふとんを着せてあげようとおかみさんは大わらわよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、仏僧たちが病気平癒のために大わらわになってやった大般若経の転読も効果はなかった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドン・ザルバ総督はおもてなしに大わらわ、バラドスに対して、過失島に滞在している間、邸宅の部屋を使っていいと申し出た。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ってみると、団長夫人は団員の昼食準備に大わらわ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂っぽい大きな汚物が二、三個、一階席の淑女の白い肩にぽたぽた落ちたので、同伴者は拭き掃除に大わらわ。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇分も経たずして、各銀行当局は今しがた払い出した金貨の山を、再び収納する作業に大わらわ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむらい頭は山崎｜庄兵衛、「走り組みの陣立て――などは初めてだ」　と、大わらわに、隊伍のさしずを、どなってゆく。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおわらわの伯寧が縄付きの姿で王妃らの前に平伏し、自分らが不覚にして王妃らにかかる恥辱を見せたる罪を謝するところは、文字通り声涙｜倶に下るの悲壮な場面で、この場が最も好評を博していたのであるが、興行の中途で朝鮮公使館から外務省にむかって抗議を提出した。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今警報が発せられる模様であります……」　昨日から、中内アナウンサーは、おおわらわの奮闘だった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしばらくするとおおわらわになって引戻しに努力している正体が暴露したりする。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　よるが　あけるまでに　おわらせようと　おおわらわ。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
