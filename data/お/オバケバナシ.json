          "literary": [
            {
              "text": "お昼御飯のときは、お化け話が出る。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でもかれでも、このお化け話とやらには、興味が湧くらしい。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三伝が、死んで四日目に銀行へ現われたんだとさ」「そうか、ついでに何かと思ったら、お化け話か。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お伽話でもないし、お化け話でもないし、いささかばからしくも思えた。",
              "citation": {
                "source": "早春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくお化け話で聞いておどかされている三ツ目入道というのがある、絵草紙でも見たが、あれだ、この人はその三ツ目入道だ、これは人間ではない、怖ろしいお化けだと感じました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみも若いくせにおばけばなしにこるなんて、おかしいよ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
