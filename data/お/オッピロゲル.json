            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
