          ],
          "literary": [
            {
              "text": "京では須磨の使いのもたらした手紙によって思い乱れる人が多かった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも習慣的制裁を墨守して娘の恥を雪ぐためには、ともかくも公けに結婚させてしまわなければならないと思い乱れる父親にも同情があります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お供の人たちが次々に促しの声を立てるのを聞いておいでになって、京へはいって人目を引くように明るくならぬようにと、宮はおいでになろうとする際も御自身の意志でない通い路の途絶えによって、思い乱れることのないようにとかえすがえすもお言いになった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
