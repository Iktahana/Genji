          ],
          "literary": [
            {
              "text": "送り手の資格について六人の青年の間にしばらく冗談口が交わされた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りたての真白な雪の中に小さい棺と、それにふさはしい一群の送り手とが汚いしみを作つた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論脅迫状の送り手以外にだね」　藤枝がこう云つたが、ふと不安そうに、われわれ二人を見た。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十人ばかりの送り手もぞろぞろ歩いてゐる。",
              "citation": {
                "source": "うき草",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、七兵衛｜親爺だ」と船長も、白雲も、こちらで笠を振る七兵衛の方へ振向くと、船上の一同もそのようにして、それからあらためて陸上の送り手と、送らるる七兵衛とを見比べていると、彼方の人数の真中に囲まれたデップリした頭領らしい男が、最後に笠を取って打振りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも何か悲劇が起こって、電報の送り手が言質を恐れたかのようだ。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波の山われをおくりて、翠黛の眉濃かに插秧既に終りて日をふること旬日、朝風露をわたりて更に一段の緑を添ふ。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるさとに背子がおくりて。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治二十五年三月）早稻田文學の後沒理想　逍遙子おほいに後沒理想の論を説き、説き畢りて書をわれにおくりていはく。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜におくりて手も相ふれで別れけり　　　より江　霜の夜道を互に黙々と手さえふれあわで、送り送らるる男と女。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "※澗めぐり流るゝ水を　はる／″＼と　靡き　おくりてつゞく　竹かな※滑らかに露もつ苔路　風ありて、下陰ぐらき竹の奥かな※疎竹三禽図茂からぬ一もと竹の　細き枝に、乗りて親まつ　雀の児三（？",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガニュメデスはトロイア王トロスの子にして世にたぐひなき美男子なり、かつてその朋輩とイデ山上に狩す、ゼウス一羽の鷲をおくりてこれをさらはせ天にとゞめて神々に奉仕せしむ（神話）二五―二七【こゝに】イデ山に二八―三〇【火】火炎界。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            }
          ]
        }
