    "definitions": [
      {
        "index": 1,
        "gloss": "boiled greens in bonito-flavoured soy sauce (vegetable side dish)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
