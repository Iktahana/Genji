        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お浸しについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お浸しがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お浸しというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお浸しの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお浸しが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お浸しを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お浸しの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お浸しはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお浸しがあります。",
              "source": "幻辞"
            },
            {
              "text": "お浸しは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お浸しについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお浸しの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お浸しの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお浸しが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お浸しについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお浸しは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお浸しについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お浸しという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお浸しの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お浸しを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「御免なさい、本当に私何だか急に胸が一杯んなっちゃったのよ――こんなにして御飯がたべられるなんて――一人で暮すの全く厭よ、お浸しがたべたいと思って小松菜買うでしょう？",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "承った処では、居士だと、牡丹のおひたしで、鼠は朝顔のさしみですかな。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君招待、酒は亀齢、下物は茹葱と小鰕、ほうれん草のおひたし、鰯の甘漬。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ほうれん草のおひたしがうまい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の湯へ行く、帰りみちに酒店に寄つたら、下物として冬菜を一皿御馳走してくれた、ほうれん草に似てゐてうまい、宿ではオコギのおひたしがうまかつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなりから芹のおひたしを頂戴する、おいしかつた、早春の匂ひだ。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は俊和尚の典座だ、飯頭であり、燗頭であつた、ふらん草のおひたし、山蕗の甘煮、蕨の味噌汁、みんなおいしかつた、おいしく食べてぐつすり寝た。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日はまるで酔ひどれの下らなさ図々しさを見せるためにお訪ねたやうなものでしたね、寄せ書きした頃から何が何だか解らなくなりましたよ、でも梅若葉のあざやかさ、おひたしのおいしさは、はつきり覚えてゐるから不思議です。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿のおばさんが「あかざ」の葉をむしてゐる、あかざとはめづらしい、そのおひたし一皿いたゞきたい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴のついでに、市場でシユンギクとホウレンサウとを二把買つてきて、さつそく汁の実おひたしにして食べた、やつぱり菜食がよいと思ふ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は郵便が来ない、新菊のおひたしはおいしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "掃除をする、ほうれんさうのおひたしをこしらへてをく。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "出勤時の身じろぎも出来ない電車の中で人と人の肩の隙間を流れる窓外の新緑を見遣りながら、ウコギやウルシの若葉のおひたし、山蕗の胡麻よごしを思い描く。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田芹のおひたしに、大きな塗椀の中にはぷつぷつと泡立っているとろろ汁が入っていた。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より三日大坂ニ下り、四日に蒸気船ニ両人共ニのり込ミ、長崎ニ九日ニ来り十日ニ鹿児島ニ至り、此時京留居吉井幸助もどふ／＼ニて、船中ものがたりもありしより、又温泉ニともにあそバんとて、吉井がさそいにて又｜両りづれにて霧島山の方へ行道にて日当山の温泉ニ止マリ、又しおひたしと云温泉に行。",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十二月四日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "千穂子は油菜のおひたしと、汁を大椀に盛ってやりながら、さっき、水の中へはいっていた与平のこころもちを考えていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも殊別なものはなく、いつもの、ハンバーグステーキにマッシュドポテトウ、アニオン、おつゆ、おひたしでよろこんで居る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "若草山で摘んだ蕨や谷間で採った蕗やが、若い細君の手でおひたしやお汁の実にされて、食事を楽しませた。",
              "citation": {
                "source": "遊動円木",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "真珠貝の吸物、牡牛の舌の塩漬、羊肉のあぶり焼、茶の芽のおひたし、松茸の松葉焼……いや、もうよそう。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十一信〔欄外に〕面会二月四日（土曜）〔受信〕二月一日づけの手紙、第七信　○原さんのところへおひたしと鯛のさしみを届ける。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、ぬいた小松菜のおひたしをした、美味、色の美しさ。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑がりのお方さまはこの水瓜の湯槽におつむをおひたしになればよろしうございます。",
              "citation": {
                "source": "果物屋の広告文",
                "author": "仲村渠",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上いった以外でも日本料理の特徴的なもの、例えばおひたしでも、てんぷらでも、お煮しめでも皆醤油が必要である。",
              "citation": {
                "source": "風土と伝統",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、おひたしのほうは片づいた。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の相子は四時から五時の間に、夕食のさかな、おひたし物などを料理し毎日大森から通い、八時の外来客の帰る時刻にかえって行ったが、私はさかなも刺身にも手をつけないでぶどうとか梨とかメロンしか食えなかった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食の時、奥テル子のお膳の上を見て、そこに海苔で巻いたおひたしの緑、ゆで卵、焼ざかなのあぶりの照りを眺め、なかんずく若さぎの酢和えが眼をとらえた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉子焼、刺身、煮ざかな、おひたしに干物というふうに、近くの料理屋からの仕出しもならべて、相子は弁当箱を用意して向う側にある晩は寝台に早変りする深い腰かけに、奥テル子とならんで飯を食べていた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、殆ど生れてはじめて蒔いて、とって、ゆでたそのおひたしを、自分ひとりでたべることを千万遺憾といたしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぜんまい」の大きなようなもので多肉柔軟、田舎ではせいぜいおひたしだが、僕はホワイトソースであたたかいうちに食う。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャリシャリといえば花の咲く前の蕎麦の軸も、ちょっと赤味がかった美しさで、おひたしには持って来いである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
