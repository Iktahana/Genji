        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "随分迷惑でしたそうですが、然し止せということも出来ないので、御母様も堪えて黙って居らしったそうです。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯ういうように朝も晩もいろいろの事をさせられたのは、其頃下女も子守も居なかったのに、御父様は昼は家に居られないし、御母様は私の下に妹やら弟やらを抱えて居られたのでしたから是非もない事でした。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君は後に、御母様がそうしておいたのだ、と言ったが、知らず堂守の思違いであったろう。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父様や御母様の宜いやうにと云ふので、宮の方には異存は無いのだ、あれにもすつかり訳を説いて聞かしたところが、さう云ふ次第ならばと、漸く得心がいつたのだ」　断じて詐なるべしと思ひながらも、貫一の胸は跳りぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三）の二　昨日は見舞がてらに本宅の御母様参られ候。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの御母様のお母様は継母だったんですって、今でも辛かったってよく仰云るわ、だから私御同情するのよ」　こんなに云われると、只さえ淋しい、悲しい心持になっている政子さんは、堪らない心持になってしまいました。",
              "citation": {
                "source": "いとこ同志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしたら、何にも御存知ない御母様まで御泣きになりましたのね。",
              "citation": {
                "source": "秋",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月三十日（木曜）晴　御母様が銀座へいらっしゃった。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父様御母様浅草、午前中さらった丈で夜は英語なんかちっとも見とれなかった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のお便りで承りますれば、御母様は頭痛で御苦の由、どうぞ／＼御大切に遊して下さいませ。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御母様が思ふていらっしゃるやうな気弱ではありませんから、決して御心配なく御願ひ致します。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来得るならば私がとった此の花の香をたく山びんに入れて、御父様や御母様の御許へ送って上げたい心地がします。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年も御母様、梅をつけておいて下さいな。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父様も御母様も皆々様御自愛専一に祈り上げます。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "御父様も御母様も嘸相変らず御いそがしい事でせう。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十七日午後一時半さよなら　　御両親様　　　　　　御許に知里高吉宛大正十一年六月九日付（東京発信）親愛なる御父様御母様、ほんとうに久しぶりで手紙を書く事が出来て嬉しう御座います。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら　　　九日幸恵より　愛する　　御父上様　　御母上様　　　　　　御両所へ知里高吉・波子宛大正十一年七月四日付（東京発信）愛する御父様御母様、此の間はお手紙を誠にありがたうございました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "知里高吉・波子宛大正十一年七月十七日付（東京発信）愛する御父様と御母様、お手紙を誠にありがたく頂戴致しました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛する御父様　　愛する御母様　　　八月一日夜十一時十五分書終る知里高吉・波子宛大正十一年九月四日付（東京発信）先達は御手紙をありがたう存じました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の御母様には朝から晩まで使ひ立てられて、何につけ、かにつけ、お亀さんの子ぢやのに何んでそんなに出来が悪いのだとおこられてばつかり、ごぜんもろく／＼食はしてくれず、下女よりひどく使はれ、つらうて／＼堪らず、四十日程まへにお父様の所へ逃げて来たのです。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "また御母様によろしく」と云うのである。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "御母様をお持ちですか？",
              "citation": {
                "source": "アイヌ神謡集",
                "author": "知里幸惠編訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつつけ若旦那様の御卒業あそばしてお帰りなされむには、あなた様の、いやと仰せられても、御母様の捨置きたまふ事でなし。",
              "citation": {
                "source": "野路の菊",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "健さんお乳はもう沢山ですね、おたあさまはお話があるからおとなに待っていますのね、さあまたおねんねですよ」　云うことも態度もひどくそわそわして、少しも同じところに止まっていない。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれを待ってでもいたように、「おたあさま」と仙千代の呼びかける声がした。",
              "citation": {
                "source": "日本婦道記",
                "author": "忍緒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじいさまとは、どのおじいさまです」「おじいさまですよ、お髪の白い、お背の小さいおじいさまですよ、仙千代を抱きに来たと仰しゃったのに、おたあさまは……」　そう云いかけて、言葉が切れたと思うと、仙千代の眼はそのまま閉じ、すぐにやすらかな寝息をたてはじめた。",
              "citation": {
                "source": "日本婦道記",
                "author": "忍緒",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おたあさま、上田のおじいさまがおいでなさるのですか」「しずかになさい」　松子はうろたえて叱った。",
              "citation": {
                "source": "日本婦道記",
                "author": "忍緒",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
