[
  {
    "uuid": "94468e3f-4af4-5085-b84d-60d224ca08d4",
    "entry": "お陀仏",
    "reading": {
      "primary": "おだぶつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "今夜のうちにお陀仏よ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お末の奴、今朝あぶなく昇汞を飲む所さ……あれを飲んで居て見ろ、今頃はもうお陀仏様なんだ」　とさも可愛げにお末の顔をぢつと見てくれた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小水が詰まって、三日目にお陀仏になってしまったの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ、上見りや限りやなし、下見りや限りやなし、諦めさんせの、因果なもんだよ、泣いても焦れても、死ちたらお陀仏、やつこらさつさ、やつこらさ、長命や為まいぞ地獄の夕焼。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、仁三郎が完全に呼吸を引取ったアトの事で、御本尊の仁三郎のお陀仏自身にすら思い付かない……しかも仁三郎一流の専売特許式珍劇がオッ初まって、オール博多の人口に膾炙する事になったのだから痛快中の痛快事である。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者が三月と宣告したんだから、力んでも踏反り返っても三月経てばゴロゴロッと痰が咽喉へ引からんでのお陀仏様――とこう覚悟して置かにゃ虚偽だよ、」と片頬に笑を含みつつ力の抜けた空元気で、「そこは大悟徹底している。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――んだから、そう今にもお陀仏するような不景気な面してるなって云うんだ。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼も夜も寝てばかり、それでも食べることは一人前以上だ、驚くべき食慾であり、大きすぎる胃の腑である、もつとも私たちのやうなルンペン乃至ルンペン生活をやつてきた人間が、食慾を失ひ、そして食べるものを食べなくなれば、もうお陀仏である、彼等（私たちとはいひきれないから）は食べることが即ち生きることだから。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "トテモ明日の今頃には、お陀仏になっている人間とは思えないだろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、水面下でお陀仏になりかけていた芸者の髪の毛だったろうと思うんだが、今思い出しても妙な気持になる。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よせ、よせ、君のこしらえた巡洋艦なんか、僕の爆撃機にかかったら三分間でお陀仏だよ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとう自分でお陀仏になったか」「あんがい、かんたんな最期をとげたじゃないか」「大事なところを弾丸にうちぬかれたのだろう」　怪魔のからだは、ばらばらになっていた。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（これは、たいへん、うっかり眠ろうものなら、お陀仏になってしまうぞ！",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "那落の底へお陀仏だ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったらお陀仏であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなったらお陀仏だ」「それじゃあ妾は殺されるの？",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま俺はお陀仏かな……」　斯う云い乍ら、大きな建物へ、彼はドシリと衝突った。",
              "citation": {
                "source": "人間製造",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくがんばって、ここまで怪塔ロケットについて来た青江機も、いよいよお陀仏になるときが来たかのようでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉をあけりゃ、そこから水がどっと入ってきて、われわれはたちまちお陀仏だ」「じゃあ、助かりたくないのか」「扉をあけりゃ、とたんに、死んでしまいますよ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大将、あの小坊主は井戸へ落っこってお陀仏ですぜ、死んでしまいましたぜ」　福村が、言いくるめようとすると、主膳は承知しません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なアに、そのうちまた中風がぶり返して、今度こそはお陀仏と来べえから。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱりお陀仏だ。",
              "citation": {
                "source": "買出し",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やつぱりお陀仏だ。",
              "citation": {
                "source": "買出し",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さ、お陀仏だ」と、カテリーナ・リヴォーヴナはささやいて、どれ後始末をしようと身をもたげたその刹那、度かさなる犯罪を秘めて森閑としているその家の四壁が、耳を聾せんばかりの打撃を受けて、ぴりぴりと震動しだした。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "今になっても、柳生源三郎が現われないところをみると、あのとき、あの穴の底で三方子川の水にひたされて、お陀仏になったにきまっている――。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は森に飛びこんで野良猫になり、後で聞くところによると、ヤマネズミを捕えるためのワナにかかり、ついにお陀仏となってしまったそうである。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんど召集されたら硫黄島あたりで、お陀仏ですよ、まるで命を誰かに吊られているようなものだ。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなお陀仏だ、海の底で――あの連中のいばしょとしては、海の底がいちばんいいのじゃないかね。",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            },
            {
              "text": "フットボールが飛んできて、兵太郎君の頭にあたりでもすると、かれはふらふらとよろめいて、地べたの上にところきらわずばったりたおれ、あたりどころが悪くて、自分はおだぶつしてしまったのだというようすをして見せるのであった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえとロックが監視しろ」「女のほうは」「ありゃ、浪にさらわれていまごろはおだぶつさ、もし生きてりゃ、おれたちの秘密を知ってるから、殺してやる」　悪漢どもの足音は東のほうへ遠ざかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
