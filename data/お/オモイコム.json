    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be convinced (that)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある人はこれを社会経済状態の欠陥のせいだと信じ、またある人は唯物論的思想の流行による国民精神の廃頽のせいだと思い込む。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思い込むと、ぼくは急に顔が赤くなった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、美代子が死体を発見して、投げ出されているピストルを見て、黒いリボンでもあれば尚更のこと、葛飾に殺されたものと思い込む。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私が以前の数十篇の小説を相変らず支持しているからといって、私を甘いと思い込むのは、誤りである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に対して若さを覆うために、われならなくに、ふと思い付いた唖の所作が、わたくし自身のためにも勿怪の幸となって、わたくしは深くも自分を唖とも物狂いとも思い込むのでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お艶にはなお、これが伯母だとか義姉だとか異母妹だとか、他人を勝手に引張って来て勝手にそう思い込み、そう思い込むが最後、その通り肉身の気持になれる幾人かの女性がある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殻だらけのわたしが殻だらけの世の中で、これを得たということは、せめてこれからのわたしを幸福な男と思い込むのに唯一の手がゝりになるものだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしはこの唇二つによってあの刹那のときのおまえばかりとおまえを思い込むことが出来る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨が降り込むことをうっかり忘れていた間抜けさ加減を嗤われた――と思い込むほど、春隆も貴族の没落を感じている昨今妙にひがみ易くなっていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そののちに、彼の書残した史をつづける者は、知覚も意識もない一つの書写機械にすぎぬ、――自らそう思い込む以外に途はなかった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きながらえるためには、どうしても、完全に身を亡きものと思い込む必要があったのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことじゃいかん、あまりひとすじに思い込むのは愚だ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六条の貴女はあまりにものを思い込む性質だった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがそんなに思い込むほどの価値のあるものはないではないか」「それは別にないのですが、六位だと人が軽蔑をしますから、それはしばらくの間のことだとは知っていますが、御所へ行くのも気がそれで進まないのです。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が気を落ち付けて、米国に着いてからの生活を考えてみると、こうあってこそと思い込むような生活には、木村はのけ物になるか、邪魔者になるほかはないようにも思えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのものだ」　と貞世の寝息をうかがいながらしっかり思い込むような時もあったが、同時に倉地がどこかで生きているのを考えると、たちまち燕返しに死から生のほうへ、苦しい煩悩の生のほうへ激しく執着して行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもぼくくらい世の中に住み古した年配の人間なら、あの記事を見て、すぐ事実だと思い込む人ばかりもないから、やっぱり若い人ほど正直に迷惑とは感じない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯罪と同時刻に起った出来事は、何でも、その犯罪と因果関係をもっているように思い込む。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の人に何でもない事でも、ヘルンは深く思い込む人ですから、感じたのでございます。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが勿論思想をこういう傾向文学的なものと思い込むことは、第一の誤謬だったのだ。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "要は、その「偶像」を創造者であるかの如く思い込むことを戒めているのである。",
              "citation": {
                "source": "自分だけの世界",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術というものを何でも写実でなくてはいけないと思い込む人が多いが写実は美術の最も一般的な道ではあるが決して写実のみが美術ではない。",
              "citation": {
                "source": "想像と装飾の美",
                "author": "それを持つ特殊の個性によって生かさるべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ若いあなたがどうしてそんなことを深く思い込むのだろう。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "また或る人は自分が大の音楽通で、どんな深遠な妙所でも聴き分けることが出来ると思い込む。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一事をもって総ての推測を下すのではないが、憎くはないがこの女一人のためには、何もかも失ってもと思い込むほどの熱情は、なかったのであろう。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは社長の癖が我知らず出てしまって、何か事あるときは日本人を代表しなくちゃならん、と思い込むのが趣味なんだね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の知識階級のものにしても、自分を死んだ墓だと思い込む方法を西洋から教え込まれて来たものだから、人間のいない世界でだけ完全に立派なもの以外に信用しない癖を、だんだん植えつけられて来てるんですね。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて技術の奥にまで達した人は機に臨み変に応じてどんなことでもやるのだから、その一斑を見てすぐ今のフランスは早がきだと思い込むことはどうかと思う。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその結果は村一切の滋養は北野一家に吸収され、村全体は貧窮に苦しむようになり、しかもそれが感謝すべき自然な状態であるとさえ思い込むようになってしまった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
