[
  {
    "uuid": "2c1ba5ba-1f3d-5b3c-8990-577a196b6d94",
    "entry": "思い込む",
    "reading": {
      "primary": "おもいこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
