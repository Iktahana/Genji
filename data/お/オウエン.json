        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だが、青年団、消防組の応援による、県警察部の活動も、足跡ほどの証拠をも上げることが出来なかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "静岡の復旧工事の応援に出かけるらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士達は、始終過激派を追っかけ、家宅捜索をしたり、武器を押収したり、夜半に叩き起され、やにわに武装を整えて応援に出かけたりしなければならなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」老婆は、皺の口をほころばせて笑い、うしろから少女を応援するようにして言うのである。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発は八月十日、同行は差当り五人、蛮カラ画伯｜小杉未醒子、髯の早大応援将軍｜吉岡信敬子、日曜画報写真技師｜木川専介子、本紙記者｜井沢衣水子、それに病気揚句の吾輩である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺も上京して応援したいんだけれども知つての通りの境遇だから悪しからず思つてくれ。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山からも警官が大勢出張した、岐阜の警察からも昼夜兼行で応援に来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ヶ月の京都での生活中、彼は屡々応援団の者に撲られ、与太者と喧嘩し、そして数人の女を彼の表現に従えば「もの」にした。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援団の者になぐられたことが彼を勇気づけた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "新太郎ちやんが栄蔵に応援されながら、苦心に苦心を重ねて、こつそり貯めて来たお鳥目は、ぜにさしにいつぱいになつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「徒党」というものは、はたから見ると、所謂「友情」によってつながり、十｜把一からげ、と言っては悪いが、応援団の拍手のごとく、まことに小気味よく歩調だか口調だかそろっているようだが、じつは、最も憎悪しているものは、その同じ「徒党」の中に居る人間なのである。",
              "citation": {
                "source": "徒党について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私はこの手記に於いて、ひとりの農夫の姿を描き、かれの嫌悪すべき性格を世人に披露し、以て階級闘争に於ける所謂「反動勢力」に応援せんとする意図などは、全く無いのだという事を、ばからしいけど、念のために言い添えて置きたい。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "周さんひとたび怒らば、この一万の留学生は必ず周さんを応援して立ち上る。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の運動会の時の、応援などにも、これと同様の気持を味いました。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時も、父様は、東京の叔父さんだの、坂田（道学者）さんに応援して、火の出るように、敵と戦ったんだわ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも事件が起こったときには、村の青年団が駐在巡査の応援をすることになっていましたので、芝田さんは青年団の人びとにあつまってもらいました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまえ、青年団が芝田さんの応援をしたのは、西山のふもとのわら小屋に草焼きの火がうつったときのことで、事件はたいそうかんたんでした。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も応援に立つわ」　磯子は自分のまずい言い方を今後の態度で補うとでもいうように力んでみせた。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学して一月も経たぬうちに理由もなく応援団の者に撲られた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念祭の夜応援団の者に撲られたことを機縁として、五月二日、五月三日、五月四日と記念祭あけの三日間、同じ円山公園の桜の木の下で、次々と違った女生徒を接吻してやった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ違うのは、之を取巻いて囃し応援し批評する観衆の中に、ハモニカを持った二人の現代風な青年の交っていたことである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸根砦攻撃　　　松平元康　二千五百人鷲津砦攻撃　　　朝比奈｜泰能　二千人援軍　　　　　　三浦備後守　三千人清須方面前進　　葛山信貞　五千人本軍　　　　　　今川義元　五千人鳴海城守備　　　岡部三信　七八百人沓掛城守備　　　浅井政敏　千五百人　更に大高城の鵜殿長照をして丸根鷲津攻撃の応援をさせる。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "応援させる兵は無いが、自分がその戦線を代ろうかと乃木が云ったのに対して、吉松少佐は笑ってその必要の無いことを答えたが、間もなく吉松の率いる兵の突撃する声が聞えた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、ここを奪われるなら、二俣口の守線も打撃を受け、田原坂攻撃の策戦に、重大な影響を与えるので、応援の兵と共に、必死に戦った。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神速の行動に、もろくも一の柵を破られたので、明智十兵衛光秀、不破河内守等が馳せ来って応援したが、既にこの時は、二の柵まで押入られた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に長秀の応援でいい加減気を腐らして居た盛政の軍は、今また秀吉の追撃があるとなると、もう浮足立つ計りである。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "重昌之を見て、松倉重次に応援を命ずると、卑怯の重次は、勝てば功は忠茂に帰し、敗るれば罪我に帰すとして兵を出そうとしない。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "高山右近は、明智の中央軍斎藤内蔵介に向ったが、相手は明智方第一の剛将なので高山勢さんざんに打ちまかされ、やっと三七信孝、丹羽長秀の応援に依って漸く盛り返すことが出来た。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "12　しょうねんたんていだんのおうえんにやって来たヘリコプターは、強い風をまき起しながら、原っぱのまん中へちゃくりくしました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村係長がきてんをきかせて、近くの消防署に、おうえんをもとめたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
