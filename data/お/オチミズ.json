            }
          ],
          "literary": [
            {
              "text": "おなじ変若水信仰は、沖縄諸島にも伝承せられている。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中に「変若水」と言ふ万葉の用語に関した解釈を書いてゐた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "万葉に「月読の持たる変若水」と言ふ語がある。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此月読神は恐らく山城綴城郡の月神で、帰化漢人の祀つたものゝ事であらうと言ふ推定から、此変若水の思想は、其等帰化人の将来した信仰が拡つたものであらうと言ふ仮説を立てゝゐた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初春の聖水は、復活の威霊の寓りとして、変若水信仰の起因となつたものである。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "其水を又｜変若水と称する。",
              "citation": {
                "source": "貴種誕生と産湯の信仰と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴人誕生に壬生の汲んでとりあげる水は、即、常世の変若水であつたのだ。",
              "citation": {
                "source": "貴種誕生と産湯の信仰と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、常世の変若水は、禊ぎの水であり、産湯でもあり、同時に甦生の水にも役立つたのである。",
              "citation": {
                "source": "貴種誕生と産湯の信仰と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ変若水信仰は、沖縄諸島にも伝承せられてゐる。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見のためには、この書がたまさかに変若水の役目を果すことになったのである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
