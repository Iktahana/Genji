        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この割で進歩すれば海峡を横断するくらいは遠からず出来るだろうと思われる。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海路は相模国三浦半島から、今の東京湾頭を横断して房総半島の湊へ渡るのが船筋だった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷点に相当する等温線が大陸をほぼ東西に横断してその以北は雪、以南は雨が降っている、その雨と雪の境界に沿うて帯状をなした区域が凍雨や雨氷に見舞われている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『その次は今から五年ばかり以前、正月｜元旦を父母の膝下で祝ってすぐ九州旅行に出かけて、熊本から大分へと九州を横断した時のことであった。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、どうしたことかさ、今いうその檜じゃが、そこらに何もない路を横断って見果のつかぬ田圃の中空へ虹のように突出ている、見事な。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し唐突ではあるが地球上における蚯蚓の分布を調べた学者の研究の結果によると、ある種の蚯蚓は、東は日本から海を越えて大陸に、欧亜大陸を横断して西はスペインの果てまで広がり、さらに驚くべき事には大西洋を渡って北米合衆国の東部にまでも分布されているのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記事によると、アメリカでは太平洋上に浮き飛行場を設けて横断飛行の足がかりにする計画があるということである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり怒れず、そのまま炎天の都塵、三度も、四度も、めまいして、自動車にひかれたく思って、どんどん道路横断、三里のみちを歩きながら、思うことには、人間すべて善玉だ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四十九聯隊の練兵場を横断して、まっすぐに行くと、もっと早い。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれやれ、何か面白い事をやってくれようと、そこで企てたのが本州横断徒歩旅行！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤそんな事もあるまいが、横断旅行の首途にこの理由の分らぬ血汐は不吉千万、軍陣の血祭という事はあるが、これは余り有難くない、それにこの大風！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "横断旅行が海底旅行になっては大変じゃ」「ナアニ、危いもんか。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は茫漠たる那須野ヶ｜原を横断して西那須野｜停車場。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで吾輩は水戸からの三人武者と共に、横断隊に別れて帰京の途に着いた。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "横断隊は未醒子、髯将軍、衣水子、木川子、これから日本海沿岸まで山中の突貫旅行をやるのである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩の今回の旅行はこれで終ったが、横断隊は勇気｜勃々として突貫旅行を続けている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ仕組の同じ獅子の、唯一つには留まらで、主立つたる町々より一つづつ、すべて十五、六頭｜※り出だし候が、群集のなかを処々横断し、点綴して、白き地に牡丹の花、人を蔽ひて見え候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機に乗って太平洋を横断したり、或は文明を過去に逆行して、古風な駕籠に乗って旅行したりするのは詩的であるが、普通の汽車に乗って平凡な旅行をするのは散文的だ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の真中を横断する散歩道の両端には、殊にも巨大な桜が枝を張り、それに準じて中背の桜が何十本か整列している。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はこの夏の休暇にはサウザンプトン港から新造の米船に乗りニューヨークに上陸してはるばる北アメリカを横断する計劃が良人と約束してある。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樺太横断はどうする。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太横断　ひどい自動車である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが樺太横断を決行しようとする私たちの使用車だというのだから驚く。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "西海岸の真岡から、樺太庁の所在地たる豊原まで、二十余里の山野を、蝦夷松、椴松、白樺の原生林を技けて、怪獣のごとくまた疾風のごとく自動車で横断することは、少くともこの旅行中の一大壮挙にはちがいない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが朝になると、咄嗟に横断の議が極った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　話はそれから航海中の出来事や、横断のパンク自動車、逢坂の後家さんの安来節、これから廻ろうという敷香のオロチョンギリヤークの生活、海豹島の噂に移った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは一昨日真岡から豊原へ二十里の原生林の横断を果したが、六度もパンクして、とうとうこの追分口から滑走してはいってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "耿として白く、また黒く、燕尾服の、　両翼を張って、ひらりと、　画面を横断して、　消える。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は一｜月末、雪と氷に埋もれて、川さへ大方姿を隠した北海道を西から東に横断して、着て見ると、華氏零下二十―三十度といふ空気も凍たやうな朝が毎日続いた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は一月末、雪と氷に埋もれて、川さえおおかた姿を隠した北海道を西から東に横断して、着てみると、華氏零下二十―三十度という空気も凍たような朝が毎日続いた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
