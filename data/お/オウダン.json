    "definitions": [
      {
        "index": 1,
        "gloss": "crossing (a road, river, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
