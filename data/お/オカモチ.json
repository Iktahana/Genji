          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "自転車で岡持ちを運んで来る若者は遠路をぶつぶつ叱言いったが、小初の美貌と、父親が宛てがう心づけとで、この頃はころころになって、何か新らしく仕込んだ洒落の一つも披露しながら、片隅の焜炉で火を焙して、お椀の汁を適度に温め、すぐ箸が執れるよう膳を並べて帰って行く。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡持ちさげて、また、「エンヤラヤアノヤアヤ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さん、気の毒だが山科さんのところまでこの岡持ちを届けて来てくれないかい。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一軒のお茶受けにも、店の権助さんが、籠をもって来たり、大岡持ちをもってくるので、一釜位では一人の注文にも間にあわなかった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い毛糸の腹巻きをして上体を左右にふりながら岡持ちを片手に鮨屋の出前が狭い鋪道を縫って走って来た。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みがきこんだおかもちをさげたてぬぐい浴衣の男が、自転車に片足かけて坂をすべってゆく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、会社から帰って来ると、台所の隅に仕出し屋のおかもちや、洋食屋の容物などが置いてあるのを、私はしばしば見ることがありました。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
