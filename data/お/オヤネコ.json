    "definitions": [
      {
        "index": 1,
        "gloss": "parent cat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "親猫が子猫を優しく毛づくろいしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "路地裏で親猫が警戒しながらご飯を探していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子猫たちが親猫の後に続いてちょこちょこ歩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親猫は敵から子供を守るため、必死に威嚇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "おまきは若いときから猫が好きであったが、それが年をとるにつれていよいよ烈しくなって、この頃では親猫子猫あわせて十五六匹を飼っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "親猫が樹の根元へすわってこずえを見上げては鳴いている。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がそばへ行くと、親猫は人の顔を見ては訴えるように鳴く。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に親猫は一、二度途中まで登って行ったが、どうすることもできなくて、おめおめとまたおりて来るのであった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを抱き上げて連れて来ると、親猫はいそいそとあとからついて来る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親猫もクルークルーと恩愛にむせぶように咽喉を鳴らしながら、いつまでもいつまでも根気よく嘗め回し、嘗めころがすのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青く芽を吹いた芝生の上のつつじの影などに足を延ばして横になっている親猫に二匹の子猫がじゃれているのを見かける事もあったが、廊下を伝って近づく人の足音を聞くと親猫が急いで縁の下に駆け込む、すると子猫もほとんど同時に姿を隠してしまう。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へもらわれて来たころはまだほんとうの子猫であったが、わずかな月日の間にもう立派な親猫になってしまった。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　葉子はその時少し熱があって、面窶れがしていたが、子供のこととなると、仔猫を取られまいとする親猫のように、急いで下駄を突っかけて、母屋の方へ駈け出して行った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "此宿の裏長屋に、仔猫が四匹生れてゐる、みんな可愛い姿態を恵まれてゐる、毎日、此宿の孫息子にいぢめられてゐるが、親猫は心配さうに鳴いてゐるより外ない、その仔猫を夕方、舞妓が数人連れて貰ひに来た、悪口いつては気の毒だが、仔猫仔猫を貰ひに来た、ソモサン！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔猫の方はさすがに無頓着で、時々実の親と間違えてか、なつかしそうに寄ってゆくこともあるが、親猫はすぐに、睥みすえ唸り声を出し、場合には引掻いたりする。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今になって考えると、親猫の方が馴染まなかったのは、妊娠していたせいだったらしい。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親猫が白の仔猫を抱いて乳をのましている。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後の親猫の態度は、云わばヒステリー的愛撫そのものになってしまった。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔猫にはまたそれが面白いと見えて、なかなか親猫の云うことを聞かない。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親猫は益々ヒステリー的になる。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう親猫の態度から判断すると、生後二カ月半もたったその仔猫を、全く生れたばかりのもののように考えてるらしい。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお云えば、親猫には、子が死んだ後も母性愛が残っていて、その愛がこの仔猫を対象に選んだらしい。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "親猫の悲歎は見るも憐れだった。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に二匹の猫がいて、漆黒の親猫の方は、もう亀などを見向きもしないが、純白の仔猫の方は、しばしば亀の囲いの中にはいりこんで、珍らしそうに亀たちをからかっていたが、遂には互に馴れてきて、魚の生肉などを與える時には、同じ皿のものを仔猫と亀と仲よく食べてる始末である。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ親猫にはなりきっていないが、だいぶ大きくなっていた。",
              "citation": {
                "source": "絶縁体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫を飼った人はよく知っているであろうが、親猫が鼠を捕えると、必ずこれに傷をつけて全く逃げ去ることのできぬだけに弱らせておき、生きたるままで、これを子猫に与えて鼠を捕えかみ殺すことの練習をさせる。",
              "citation": {
                "source": "生物学より見たる教育",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い頃は至つてお転婆だつたのだし、親猫になつてからだつて、相当に喧嘩も強かつたし、活溌に暴れる方であつた。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い頃は至ってお転婆だったのだし、親猫になってからだって、相当に喧嘩も強かったし、活溌に暴れる方であった。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親猫も飼うつもりはなかったが、お産をしたばかりだのにすぐ追い出すのもかわいそうだと牛乳をやったり魚をやったりしているうちに、彼女が居すわってしまったのだった。",
              "citation": {
                "source": "猫料理",
                "author": "村松梢風",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上生まれては困るので土地の獣医さんに頼んで去勢をしてもらうと、運悪くその獣医さんは初めての手術とかで、親猫は腹をたち割られたままたちまち死んでしまった。",
              "citation": {
                "source": "猫料理",
                "author": "村松梢風",
                "note": "青空文庫"
              }
            },
            {
              "text": "母猫が生きている時分は、母猫が利口であったから、よく子猫たちを統御して、晩には必ず家へ帰るようにしていたが、親猫が死んでしまうと、とうてい放し飼いでは収拾ができなくなったので、家じゅう網戸にして、一歩も外へ出さないことにし、一番上の姉猫を除いて全員を上手な獣医さんの手で去勢してもらった。",
              "citation": {
                "source": "猫料理",
                "author": "村松梢風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この牝犬は或る種の犬がもつている医者気質をもつていて、親猫が仔猫を舐めてやるように、バックの傷を舐めてきれいにしてやつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は、頭にアイロンでものせておけば、大人にならないものならいいけど、つぼみは花になるし、子ねこはおやねこになるし、ああ、つまらない。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに　こねこが　４ひきも　うまれて、　おまけに　おやねこが　カナリアを　おそってしまって。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
