        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "陽極には大袋に亜鉛を入れたものを用い、陰極には銅板を用い、二・五ボルトの電圧で千アンペアの電流を通すと陰極の方へは純銅がだんだんに附着し、陽極には硫酸と酸素が出て来る。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は十銭最中を買うと、大袋に一ぱいあった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜風の神と思ひこらして大袋をかついだ鬼面の大男は、居酒屋の権太郎ではないか。",
              "citation": {
                "source": "馬上の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "買物いろ／＼、小鍋、削節、なでしこ（これはやうやくその大袋を八木デパートで見つけた）、そして古本。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の買物一金三十銭　　麦二升一金六銭　　　焼酎半杯一金三十弐銭　なでしこ大袋一金四銭　　　葱一束十二月一日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルスタムは、混雑した荷騾馬の群の横や、地面に積上げられた食糧の大袋の山をよけ、彼方の天幕に戻った。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "児童たちへのおみやげの菓子の大袋は、幾つかさきに届けられているので、白砂糖の腰高折と目録包みが校長の前へ出された。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝登校のときに松さんがもって来た大袋四ツが持出されて、うまい具合に分配されてゆくのだった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅は自分が菓子工場に働いていることをみんなに隠さないばかりか、ときどきハトロン紙の大袋に一杯パン菓子を抱えこんで来て、みんなに振舞った。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲「ハテ、愛嬌もありなか／＼大腹な仁です、布袋和尚に縁があるのは住居が悉皆寺です、殊に彼程に成るまでには、跣足で流れ川を渡る様な危い事も度々有ツたとさ、遊ぶ時には大袋を広げる事もあり、芸妓も極くお酌のから子供を多くお呼び被成るのがお好だとさ。",
              "citation": {
                "source": "七福神詣",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "米の大袋を背負い、両手に十羽の鶏をぶら下げて大道せましと歩いても、ヤァお相撲さんか、腹がへるだろう、とお巡りさんが全然可愛がってくれるのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時の如きは、日本橋からくさやの干物、鱈の切身というようなもの一包を買い込んで、大袋の中へ投げ込み、たしかに持参した筈のがない、東京へ置き忘れて来た筈はないのに幾ら探してもない。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一隅に羊毛の大袋があって、紡ぐばかりになっていたし、また別の隅には、機織り機械から下ろしたばかりの麻と毛とを交ぜたたくさんの織物や、玉蜀黍の穂が置いてあった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "金方が熊手の先で押して寄越した二万八千法の賭牌の小山を忙しく例の大袋へ投げ込んだ。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "南風吹かば　――モンテ・カルロの巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに綿屋で売ってくれる綿袋という大袋は、切ってそのまま雑巾につかうと、水ぎれもよく実に具合のよいものです。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "パン屋が５ブッシェル（１ブッシェル＝36.37リットル）、１袋（大袋）の小麦粉を出来るだけ混ぜ物処理をしないでパン（塊）にしようと意図したとする。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちのベッドの周りは壁一面に山羊のチーズ、乾燥させた薬草、食品の大袋などの冬を越すための品々が積み上げられていた。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　客は戸の外へ出て、直ぐに大袋を二つ持つて這入つて来て、革紐を解いて、食料を取り出した。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、情報によれば東洋服を入れた大袋がスラウ近くの線路上で見つかった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林君は、例の黒いきれの大袋を、肩にかついで、そのあとを追いました。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また一時間あまり、例の大袋をかついで、つかれた足をひきずりながら森の中を歩きました。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林君は、例の大袋を持ったまま、小屋の中にはいって、いろりのそばに腰をおろしました。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
