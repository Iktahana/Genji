        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれどももしヴェーッサンタラ大王のように大へんに徳のある人ならばそしてその人がひどく飢えているならば木の枝はやっぱりひとりでに垂れてくるにちがいない。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は闇の中に、ありありうかぶ豹の毛皮のだぶだぶの着物をつけ、一人は烏の王のように、まっ黒くなめらかによそおっていました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に嫉まれ、蔑まれて、心が魔王のように猛り立つときでも、あの小魚を口に含んで、前歯でぽきりぽきりと、頭から骨ごとに少しずつ噛み潰して行くと、恨みはそこへ移って、どこともなくやさしい涙が湧いて来ることも言った。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも普通の家ではないので、Ｆ市外の公園の入口に在る檜御殿と呼ばれた××教の教会堂が、先年の不敬事件に関する信者の大検挙以来、空屋同然になっていたのを自分の名前で買い取らせて、見事な住宅の形に手を入れさせたもので、そこに素敵な自動車や、大勢の女中を雇い込んで女王のように奉仕させた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い悲しみと、あきらめと、思いやりのこもった微笑を口元に浮べて、生れながらの女王のように落ちついている。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし男が葉子の目の前で弱味を見せた瞬間に、葉子は驕慢な女王のように、その捕虜から面をそむけて、その出来事を悪夢のように忌みきらった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はただ木村という邪魔な考えが、もやもやと胸の中に立ち迷うばかりで、その奥には事務長の打ち勝ちがたい暗い力が、魔王のように小動ぎもせずうずくまっているのみだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は女王のように誇りの必要もないという自らの鷹揚を見せてすわっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、現在の社会組織では人格がどんなに下劣でも、金さえあれば、帝王のように強いのです。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした華やかな群の中に、女王のように立ち働いている荘田夫人が、自分に――片隅に小さく控えている自分に、少しでも注意を向けて呉れるかと思うと、妻の手前を繕ろってまで、出席した自分が、何だか心細く馬鹿々々しくなって来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が日曜の午後を、華麗な客間で、多くの男性に囲まれて、女王のように振舞っているのを外に、美奈子は自分の離れの居間に、日本室の居間に、気に入りの女中を相手に、お琴や挿花のお復習に静かな半日を送るのが常だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝靄をまとわりつかせながら、森の女王のように東屋の入口に立った令子に、慶一の目は、いまはじめて見たかのように、くぎづけになってしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると、勇吉は、粗朶火を持たない左の手で、怒り猛る仁王のようにおしまにつかみかかりながら罵りかえした。",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の遊ぶ部屋の前には大きい半分埋まった石、その石をかくすように穂を出した薄、よく鉄砲虫退治に泥をこねたような薬をつけられていた沢山の楓、幾本もの椿、また山桜、青桐が王のように聳えている。",
              "citation": {
                "source": "雨と子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は小屋元なので、いつも一番いい席に赤い毛布が敷いてとってあり、豊子姉は妹たちに着飾らせて、それをつれて、自分が女王のようにまん中に坐っていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が生活にまけて貧乏臭く、ケチな量見になろうとする時、亡き姉は華やかに、女王のように笑いこぼれて私の前にあらわれる。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "きらびやかな見送人の大群と、泣き顔の火夫を後に、タイタニックは帝王のように堂々と桟橋を離れて行く。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "四たび目に尼提の曲った道にも如来は獅子王のように歩いている。",
              "citation": {
                "source": "尼提",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "白ずくめの洋装をした呉羽は中世紀の女王のようにツンとして……。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "木下司令官は、仁王のようにブリッジに立って、ジッと前の方をにらんでいる。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番船の舳には関矢一郎が、腰に銘刀｜関の孫六をぶちこみ、角笛を持って、仁王のように立っている。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やい、やい、やい、やい……」　モレロが仁王のように立ち上った。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物学者白井光太郎博士はトリカブト毒研究で死なれたそうだが、この光太郎はなかなか気をつけて、毒草にうっかりやられたり、何とかいうフランス王のように毒キノコなどに派手にはひっかからないつもりでいる。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、それをまず俺に話すがいい」　小浜兵曹長は仁王のように突立ち、敵方の大将株らしい白人をぐっとにらみつけました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "女王のように歩いていた。",
              "citation": {
                "source": "カスリイン・ニ・フウリハン（一幕）",
                "author": "CATHLEEN NI HOOLIHAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "やわらかい金色な髪をまん中で二つに分け、それが金の波を打つ二つの河になって両方の顳※に流れているところは、王冠をいただく女王のように見えました。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "クラリモンド",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは魔王のように、おのれの内部に地獄をもち、自分が同情されないのを感じながら、木々を根こぎにしようとし、やがて、まわりというまわりをめちゃくちゃに破壊してやろうと思った。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きなこうもりは、ちょうど女王のように、ほかのこうもりを率いているごとく、見えました。",
              "citation": {
                "source": "牛女",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっ外して、「浮藻殿オ――ッ」　追おうとする小次郎の行く手を遮り、仁王のように突っ立った右衛門、「そいつがいけねえ、その浮藻殿オ――ッが！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
