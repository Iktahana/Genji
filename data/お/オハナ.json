        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お花、梅吉、喜三郎ことし十五の小性とて娘お蝶がませぶりをさげすみしたる樣もなく家代代の重寶をそつと小縁に運ぶ哉。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花畑の名が、富士にあるのも珍らしい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "高峰の花のあるところに、お花畑の名はつき物だが、御庭はあまり聞かない名だ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "用をすました帰りにぶらぶら竹の台を歩きながら全く予期しなかったお花見をした。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あア、明日お出になる時、お花を少し持て来て下さいませんか、何んでも宜いの。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い女児二人は縁側へいろいろなお花を並べて花屋さんごっこをする事もある。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな勤倹な四民も年に一度のお花見には特定の「濫費デー」を設けた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことから、女の口はほぐれて、自分がまだ出て※々だのに、先月はお花を何千本売って、この廓で四番目なのだと言った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デパートアルプスには、階段を登るごとに美しい物と人との「お花畑」がある。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かお花を落したらうつつたお空がゆれました。",
              "citation": {
                "source": "井戸",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花畑は呼んでゐる、遊びにおいでと呼んでゐる。",
              "citation": {
                "source": "雀の歌",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまやの角をすぎて、お花畑から、麦畑へあがる草の土手の上で、虫をふせました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄貫一の子は三人あって、お花というが十五歳で、その次が前の源造、末が勇という七歳のかあいい児である。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花は叔父を慰め、源造は叔父さんと遊び、勇は叔父さんにあまえた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉はお花が土蔵の前の石段に腰掛けて唱う唱歌をききながら茶室の窓に倚りかかって居眠り、源造に誘われて釣りに出かけて居眠りながら釣り、勇の馬になッて、のそのそと座敷をはいまわり、馬の嘶き声を所望されて、牛の鳴くまねと間違えて勇に怒られ、家じゅうを笑わせた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる際にお花と源造に漢書の素読、数学英語の初歩などを授けたが源因となり、ともかく、遊んでばかりいてはかえってよくない、少年を集めて私塾のようなものでも開いたら、自分のためにも他人のためにもなるだろうとの説が人々の間に起こって、兄も無論賛成してこの事を豊吉に勧めてみた。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花は叔父のために『君が代』を唱うことに定まり、源造は叔父さんが先生になるというので学校に行ってもこの二、三｜日は鼻が高い。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも悲しんだものはお花と源造であった。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「四十物町のお花主というと、何、知事様のお邸だッけや。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜かろう、毎日の米の代といっても差支えない、大切なお花主を無くする上に、この間から相談のある、黒百合の話も徒為になりやしないかね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははは、まずまあ毎日汗みずくになって、お花は五厘なんていって歩かないでも暮しのつくこッた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芍薬か、牡丹か、菊か、猿が折って蓑にさす、お花畑のそれでなし不思議な花よ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、腰の矢立はここのも同じだが、紺の鯉口に、仲仕とかのするような広い前掛を捲いて、お花見｜手拭のように新しいのを頸に掛けた処なぞは、お国がら、まことに大どかなものだったよ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四辺を※す）ちょいとお花見をして行きましょうよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘のお花さんというのが評判の美人であった。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お花さんは十九年頃の虎列剌で死でしまって、お路久さんもつづいて死んだ。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その春から上野の中堂が大修繕の工事に取りかかりましたので、お花見差止めというわけでもありませんでしたが、大抵は遠慮して上野のお花見には出ませんでした。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下品な字しか書けません」　しかし、女は気にもとめず、「私、お花も好きですのん。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お習字もよろしいですけど、お花も気持が浄められてよろしいですわ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼく知ってらあ、ぼくおはなししやう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
