    "definitions": [
      {
        "index": 1,
        "gloss": "to think",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この沢山の自分の本は、一体どうして書けたと思うか。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術は、そんなに、人に強いるものではないと思う。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言ってやがると思う。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるようにも思うのであるが、私は、わざと、できぬ、という。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "意の在るところの一端は、諸兄にも通じたように思う。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくて、自分の哲学的思想体系を、ちゃんと腹に収めてからでなければ、どんな行動も起し得ない種類の人間も、たくさんあることと思う。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "未完成であると思う。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから文化人は、いそがしくなると思う。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いますぐいちどに、すべて問題を解決しようと思うな。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんな男女川の姿を眺め、ああ偉いやつだといつも思う。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いだろうと思う。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校のおつとめからお帰りになって、隣りのお部屋で、私たちの話を立聞きして、ふびんに思い、厳酷の父としては一世一代の狂言したのではなかろうか、と思うことも、ございますが、まさか、そんなこともないでしょうね。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにたくさんひとが居るのに、誰も僕を知っていない、僕に留意しない、そう思うと、――いや、そうさかんに合槌うたなくたってよい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い声で、「きょうは八十八夜」そうひとこと呟いたかと思うともう、てれくさくてかなわんとでもいうようにむっくり立ちあがって両肩をぶるっと大きくゆすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思わず口を滑らせたら、菊ちゃんは一瞬はっと表情をかえて妙にまじめな眼つきで私の顔を見つめたかと思うと、くるっと私に背をむけお盆で顔をかくすようにして店の奥へ駈けこんでいったものだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "インポテンスじゃないかと思うんだけれど。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに暑いのに、わざわざこんな田舎にまでおいで下さって、本当に恐縮に思うのですが、さて、私には何一つ話題が無い。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がうますぎると思う。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の事を思うな、とあの人も言って居られます。",
              "citation": {
                "source": "私信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎氏の父祖の遺徳の、おかげと思うより他は無い。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって自ら筆を取り、あえて大胆にこの書をあらわし、著者の見たる「新しき蕪村」を紹介しようと思うのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を思うて岡の辺に行きつ遊ぶ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があらゆる俳句を理解し得ず、俳句を本質的に毛嫌いしながら、一人例外として蕪村を好み、彼の俳句だけを愛読したという事実は、思うにおそらく、蕪村の情操における特異なものが、僕の趣味性や気質における特殊な情操と密に符合し、理解の感流するものがあったためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして単に、近代の抒情詩や美術しか知らない若い人たちでも、こうした蕪村の俳句だけは、思うに容易に理解することができるだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が俳句を毛嫌いし、芭蕉も一茶も全く理解することの出来なかった青年時代に、ひとり例外として蕪村を好み、島崎藤村氏らの新体詩と並立して、蕪村句集を愛読した実の理由は、思うに全くこの点に存している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村を誤った罪は、思うに彼の最初の発見者である子規、及びその門下生なる根岸派一派の俳人にある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言にして言えば、それは時間の遠い彼岸に実在している、彼の魂の故郷に対する「郷愁」であり、昔々しきりに思う、子守唄の哀切な思慕であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下その俳句について、個々の評釈を述べると共に、この事実を詳しく説いて見たいと思う。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句もやはり前のと同じく、実景の写生でなくして、心象のイメージに托した咏嘆詩であり、遅き日の積りて遠き昔を思う、蕪村郷愁曲の一つである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
