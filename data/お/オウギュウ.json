        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "廿日、戊子、天晴風静なり、将軍家新御所に移徙なり、御車京都より遅く到るの間、御輿を用ひらる、酉刻、前大膳大夫広元朝臣の第より、新御所に入御、大須賀太郎道信黄牛を牽く。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野雲に舞ひ、黄牛の草に眠るが如し。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――鈍き眼に頭もたげて黄牛よ、汝はなにおもふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山から薪を着けて来た一疋の黄牛が、その旋風に捲きあげられて大根畑の中に落とされた。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるところ、黄色の衣を着、黄牛に車を牽かせて乗り、従者ことごとく黄色な人が通り掛かり、小児を見るとすなわち穀賊何故ここに坐し居るかと問うた。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂くだりゆく牧がむれ、牛は練りあし、馬は※、時しもあれや、落日に嘯き吼ゆる黄牛よ。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここへ駈け込んで来た人は、身の長およそ七尺もあろうかと思われる赭ら顔の大男で、黄牛の皮鎧に真っ黒な鉄の兜をかぶって、手には大きい鉞を持っていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又革卦に於て初九に黄牛之革といひ、九五、上六に、大人虎變、君子豹變といふ辭のあるのは、明らかに皮革の革の義であるらしく見えるが、彖傳では天地革而四時成、湯武革命などゝいひ、象傳で治暦明時の義に解釋するのは、いづれも元來の意義でないやうに考へられる。",
              "citation": {
                "source": "易疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "）一人の牛商人が、一頭の黄牛をひいて、その畑の側を通りかかつた。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛商人は、笑ひながら、黄牛の額を、撫でた。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　牛商人は、とうとう、約束の期限の切れる晩に、又あの黄牛をひつぱつて、そつと、伊留満の住んでゐる家の側へ、忍んで行つた。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ひいて来た黄牛の綱を解いて、尻をつよく打ちながら、例の畑へ勢よく追ひこんでやつたのである。",
              "citation": {
                "source": "煙草と悪魔",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後からは、めずらしく、黄牛に曳かせた網代車が通った。",
              "citation": {
                "source": "運",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其間に褐色の屋根や白い壁を擡げて田舎家が散らばり、雨上りの濁つた沼の畔には白｜斑の黄牛が仔牛を伴れて草を食み、遠方の村村の上に聳えた古い寺院の繊細な尖塔が、白楊のひよろ長い、橡の円形な木立と一緒に次第に矮く地平の彼方へ沈んで行く。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼よりすれば、海内の命を掌握に断ぜる入道相国も、唯是剛情なる老黄牛に過ぎざる也。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄牛も水牛も空をつかってわたしを馬鹿にする。",
              "citation": {
                "source": "村芝居",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "畦をゆく斑の牛と黄牛は声も慵く、今は皆｜刑の場に皮｜剥がれ紅く伏しなむ、かく思ひ定めし如くとぼとぼと霧にまぎれぬ。",
              "citation": {
                "source": "坂",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠牛嘯き吼ゆる黄牛よ、目路にかゞなふ、屠殺場を知るやしらずや、あな哀れ、ものおぞましき足どりに、牧場の草を、いでたちぬ。",
              "citation": {
                "source": "ふるさと",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の黄牛に田器を負わせて田舎に将往かんとすとあって、田舎の二字をいつの頃よりかイナカと訓ませている。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "○菊元百貨店売品牛角製｜煙草セット（黄牛角製煙草筒をとり上げ）この筒だけなら見所がある。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○同所黄牛角製｜帯鉤　これなぞはいや味がなくていいね。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また茶店の朱貴は、大甕十箇の酒をあけ、三頭の黄牛をつぶし、ぞんぶんに大勢の腹を賑わした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄牛、羊、鶏、豚、あひる、およそ園菜家畜をあげて、調理の鍋、大釜にぶちこまれた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで逢いたさの余りに、諸方をあるいて黄牛を買い集め、九百九十九疋までは手に入ったが、残り一匹はどうしても見つからない。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして百足の草履とか千頭の黄牛とかの、余りにも奇抜な条件すらも、信州の千駄の厩肥に比較することによって、始めてその来由を明らかにすることが出来る。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
