        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして茲で何がなし附加へてみたいのは、孤独を恐れぬこと、といふことである。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂に拠れば、男女川はその身長に就いての質問を何よりも恐れるそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではもう、何も恐れる事は無い。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼のやうに一切を演繹することの出来る人は、ヒュマニティの実質を見失ひ易い恐れがある。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本気な従兄の怒りを恐れる気持をゴマカすやうに、Ｓ子は雪駄の音をペツタペツタさせて、オドケてみた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――）　　　　　　　※　さうしてよき心の人よ、あれら手際よい技能家や学者等を恐れたまふな。",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目を忍び、露見を恐れ、絶えずびくびくとして逃げ回っている犯罪者の心理は、早く既に、子供の時の僕が経験して居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れに恐れる事も諛う事も入らぬ、唯我独尊の生涯で愉快だろうと夢のような呑気な事を真面目に考えていた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人として王を恐れ且つ憎まぬ者はないやうになつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿波聖人とは恐れいる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの嚴肅なるお婆さんをも、また品行方正の聖人をも、なに恐れんやといふやうなかなりの勇者になつてゐるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほその上、鬼どもに對し、親和の情を抱いてゐるのであるから、何の恐れるところもなく、圓陣のまんなかに飛び込んで、お爺さんご自慢の阿波踊りを踊つて、むすめ島田で年寄りやかつらぢや赤い襷に迷ふも無理やない嫁も笠きて行かぬか來い來い　とかいふ阿波の俗謠をいい聲で歌ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えへへ、」と龜は不敵に笑ひ、「せつかく助けてやつたは恐れいる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして實地に臨んでみると、田舍者まる出しなんだから恐れいる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は糞眞面目な話を恐れます。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん今でも未開時代そのままの模範的な迷信が到るところに行われて、それが俗にいわゆる知識階級のある一部まで蔓延している事は事実であるが、それとは少し趣を異にした事柄で、科学的に験証され得る可能性を具えた命題までが、一からげにして掃き捨てられたという恐れはないものだろうか。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにこれに備うる事もせず、また強い地震の後には津浪の来る恐れがあるというくらいの見やすい道理もわきまえずに、うかうかしているというのはそもそも不用意千万なことである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人が代わる間には法令も時々は代わる恐れがある。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "津浪の恐れのあるのは三陸沿岸だけとは限らない、寛永安政の場合のように、太平洋沿岸の各地を襲うような大がかりなものが、いつかはまた繰返されるであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく続けている観測も上長官が交迭して運悪く沿革も何も考えぬような後任者が来ると、こんな事やっても何にもならんじゃないかの一言で中止になるという恐れがあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、こういう大切な観測事業をその日暮しその年暮しになりやすい恐れのある官僚政治の管下から完全に救出して、もう少し安定な国家の恒久的機関を施定することが刻下の急務ではないかと思われる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にこの灯の光は普通電灯のごとく一点から出るのではなく、広い面積から出るので、光が柔らかく眼を害する恐れがない。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから色の不完全な灯光を始終使っていると遂には一種の色盲になる恐れがあると心配している人もある。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもそうしたなら、自分の性格の腹の皮の方が裂けよう」　翁はいまにもそれを恐れるように大事そうに螺の如き自分の腹を撫でた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがこれをも外らしたら、結局恐れてゐることだ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしわたくしが外に出ることができ、おまへが恐れぬならばわたしはおまへを抱きまた撫したいのであるが、いまはそれができないので、わたしはわたしの小さな贈物をだけしよう。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソビエトの幼児が函館の町っ児の感化に染まることを恐れるのであろう。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入ったのはまるでしがみついたように小脇に抱いて誰かに掠奪されるのを恐れているようである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、気をつけないと、自働交換台の豆電燈の瞬きを手帳に記録するだけで満足するようなことになる恐れがないとは云われない。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは仲間に入れてもらえなかった人の怨恨によるともいわれ、またクロトンの市民等がピタゴラス一派の権勢があまり強すぎて暴君化することを恐れたためともいわれている。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
