        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お星様について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お星様がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お星様というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお星様の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお星様が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お星様を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お星様の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お星様はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお星様があります。",
              "source": "幻辞"
            },
            {
              "text": "お星様は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お星様について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお星様の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お星様の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお星様が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お星様についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお星様は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお星様について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お星様という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお星様の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お星様を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "見るともう狐の学校生徒が沢山集って栗の皮をぶっつけ合ったりすもうをとったり殊におかしいのは小さな小さな鼠位の狐の子が大きな子供の狐の肩車に乗ってお星様を取ろうとしているのです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの双子のお星様の役目でした。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双子のお星様たちは悦んでつめたい水晶のような流れを浴び、匂のいい青光りのうすものの衣を着け新らしい白光りの沓をはきました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　双子のお星様たちは笛を吹きはじめました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはチュンセ童子とポウセ童子という双子のお星様でめいめい水精でできた小さなお宮に住んでいます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがこの双子のお星様たちの役目でした。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この双子のお星様はどこ迄でも一緒に落ちようとしたのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るともう狐の学校生徒が沢山集って栗の皮をぶっつけ合ったりすまふをとったり殊にをかしいのは小さな小さな鼠位の狐の子が大きな子供の狐の肩車に乗ってお星様を取らうとしてゐるのです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんこから狐になって、はたいた方が愚に返って、とうとうね、蜜柑の種を勘定しながら、地体お星様は丁か半か、とあけ方の天井へ、一服吹かしております処へ、ひょッくり、その姉さんが来たんでね。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいなお星様」　呟いた時、ふと星が流れて、青い光がすっと斜に、あえかな尾を引いて、消えた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お加代はしみじみと、星の流れるあとへ遠い視線を送りながら、「……お星様が流れている間に願いごとを祈ると、かなうというけど……」　と、ひとり言のように呟いていると、ふと思いがけぬやるせなさに、胸がしめつけられた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜も日本も見えやしねえで、お星様が映りそうで、お太陽様は真蒼だ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、あんなにお星様が見えるやうになつたぢやありませんか。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの眼の光るのは星か、螢か、鵜の鳥か螢ならばお手にとろ、お星様なら拝みませう。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてちっとばかり聞かしておくれ、こんな風で済まないけれどもッて、銀貨のお代を頂きました時は、私は掌へ、お星様が降ったのかと思いました。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月様やお星様は、あのやうに静に輝いてゐらつしやるのに。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは何か彼の女は悲しい思ひに駆られて――たゞでさへ、故もなくたゞわけもなく、月見れば涙、花咲けば涙、お星様よ何故泣くの、すゝりなくヴヰオロンの音、あゝ悲しき星よ！",
              "citation": {
                "source": "美智子と日曜日の朝の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中の子供がみんな眠つた時お月様何してる、お星様何してる。",
              "citation": {
                "source": "コドモノスケッチ帖",
                "author": "動物園にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空のように青い、そう昔はね、この世界に菫が一つも無かったの」「それからお星様もねえ、母様」「ええ菫もお星様もこの世界になかったの。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが菫の一番はじまりなんだよ」「それからお星様は？",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "お星様はね、青い空の小さな穴ですよ。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々と澄んだ水が急に濁つたり、風もないのに浪が立つたり、空が曇つて星のない晩でも、湖の中にはお星様が映つて見えることなぞもありました。",
              "citation": {
                "source": "虹の橋",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いお星様、十字星……地中海の波が二つにわれ、そこを通って行く幾十万！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方お星様がチラチラまたたく頃になると何の家でも生のままの杉の葉をいぶしてその紫の煙で蚊を追いやるのです。",
              "citation": {
                "source": "蚊遣り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お星様が出ていますこと」女中の追従には答えないで、天野は冬子の方をじっと、大きな眼で見た。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれが僕らのお星様なのだよ。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど体がどんなに小さくても、あの広い広い青空も、そこを流れて行く白い雲も、それから毎晩砂金のように光る美しいお星様も、みんな見えます。",
              "citation": {
                "source": "すみれ",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お月様とお星様が近くにある晩には火事がある。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「籌さん、あのお星様はお月様に近いのね。",
              "citation": {
                "source": "私の生ひ立ち",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
