        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "北国をめぐる旅人が、小百合火の夜燃ゆる神通川を後に、二人輓きの人車に揺られつつ富山の町を出て、竹藪の多い村里に白粉臭い女のさまよう上大久保を過ぎると、下大久保、笹津の寂しい村々の柴｜焚く烟が車の上に流れて来る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "白粉臭い、汗くさい変な香がこもった中で、自分は信乃が浜路の幽霊と語るくだりを読んだ。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには白粉臭い女が一人又は二人ぐらい控えていて、二階にあがった客は新聞や雑誌をよみ将棋をさし、ラムネを飲み、菓子をくい、麦湯を飲んだりしていたのであるが、風紀取締りの上から面白くない実例が往々発見されるので、明治十八年頃から禁止された。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその日も暮れかかつた頃、京漢鉄道の客車の窓に白粉臭い母のことを考へてゐた。",
              "citation": {
                "source": "貝殼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女世帯で気味が悪いでしょうが、白粉臭いようなことはありません」　女のいうのをでっかい掌で払い退けるように、「それじゃ俺は帰えるぞ」　八五郎は背を見せました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日、白粉臭いのを首実検してつくづく厭になりましたよ、おしまいには嘔気いて来る」「とんだ役得だ、――ところで、さらわれた女に一人でも出っくわしたか」　平次は冗談を言いながら膝を進めます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "江戸阿呆宮",
                "note": "青空文庫"
              }
            },
            {
              "text": "商賣女の白粉臭いのに慊きると、素人娘に眼をつけて、今から七八年前から、江戸で名うての處女を漁り始めた」「――」「金で濟むのは百兩二百兩。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "浮世繪の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "見かけはありふれた田舎食堂のような店だったが、すすめられて座敷へあがると、白粉臭い女たちがあらわれて、なにも注文しないのに酒だのビールだのを持って来、おのおの景気よく飲んだり喰べたりした。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが勘定の段になると、白粉臭い彼女たちの飲み食いした物が、残らず池部さんのふところに噛みついたものであり、その取立てには些かの容赦もなかった、ということであった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東路君を訪ねあてる、旧友親友ほどうれしいものはない、カフヱーで昼飯代りにビールをあほつた、夜は夜でおしろいくさい酒をしたゝか頂戴した、積る話が話しても話しても話しきれない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人々の一人として法主がおしろいくさい匂いをさして、毎朝祇園の町から馬車でいかめしく帰って来たものです。",
              "citation": {
                "source": "私の作陶体験は先人をかく観る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ　おかあさん、マルが　おしろいくさいよ。",
              "citation": {
                "source": "マルは　しあわせ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱり　おしろいくさいよ。",
              "citation": {
                "source": "マルは　しあわせ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「マル、どうして　おまえは、おしろいくさいの？",
              "citation": {
                "source": "マルは　しあわせ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑後川すじから佐賀へんにかけちゃ、舟幽霊じゃとか、人のシリコ玉あ抜く川太郎じゃとか、おしろいくさいバケモンがウンと居るけんなあ。",
              "citation": {
                "source": "破れわらじ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
