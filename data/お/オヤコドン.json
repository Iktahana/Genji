    "definitions": [
      {
        "index": 1,
        "gloss": "oyakodon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のランチは、奮発して少し高級な親子丼を食べよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鶏肉がふっくらと卵でとじられた親子丼は、老若男女問わず人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "疲れた日には、出汁の効いた温かい親子丼が何よりもご馳走だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外の日本食レストランでも、親子丼は定番メニューとして愛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "うどん屋の二階に居れば、階下の商売が商売故、たまには親子丼、ならいゝが酒もとる。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "母と来たとき、食堂のようなところで親子丼をたべた。",
              "citation": {
                "source": "琴平",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃じみたカツフエの壁には「親子丼」だの「カツレツ」だのと云ふ紙札が何枚も貼つてあつた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃じみたカッフェの壁には「親子丼」だの「カツレツ」だのと云う紙札が何枚も貼ってあった。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうですねえ、お蕎麥か、親子丼ぐらゐのとこでしたら‥‥」「ぢやア、親子丼とうどんかけを一つづつ取つて下さいませんか」　女中が階下へおりてゆくと、ふじ子は暑いので帶をといた。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭をしぼつて部屋へかへつてゆくと、もう丼物が來てゐて、上の子の健吉は、親子丼の蓋をあけて母を待つてゐた。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと虱だらけになって来ると思って、ちゃんと着物を用意しているんだけれど……こないだ行って親子丼をたべさせて来た」　姙娠のためにやつれ、また風邪でやつれながら、窪川いね子は持ち前の落着きと微かなユーモアを失わず、おいしいお茶を入れてくれた。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからステーションの上で食事をすることになったところが、耳のきこえない本田の細君が、塩ッ辛いとうてい舌のちぢんで仕舞うような親子丼をとる。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のうちに喰べるものは喰べて置かないと、たとい若い婦人にしても、顔面のない屍体を見ると食慾がなくなるだろうと考えて、当直は夜食の親子丼の蓋をとった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当直は気がついて、喰べかけの親子丼に蓋をした。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりでうれしく、うちでこしらえた親子丼を幾杯もかえる。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝鮮時代の食い物で今でも覚えているのは、親子丼の味だね。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの司令部へ持って来る親子丼がうまい。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と女の手をつかまへ、昨日調べて置いたお好焼の二階へ上り、女中代りの小娘が盆に載せた茶を置いて行くのを呼び留め親子丼を誂へた後、茶ぶ台の傍に坐つてゐる女の身近に寄添ふが否や、「民子さん。",
              "citation": {
                "source": "男ごゝろ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫くして、女は肩から落ちさうになつた羽織の紐を結び直さうとした時、わざとらしく梯子段に足音をさせて、女中代りの小娘が親子丼を二ツ運んで来て、茶ぶ台の上に置き、「お茶只今。",
              "citation": {
                "source": "男ごゝろ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は新見も朝食もせずに、昼と晩とはうどんやで親子丼を食つて居るのであるが、あまり、内山が可哀相に思つたから、早速米と土鍋と七輪を買うて来て、一緒に飯を炊いて食ふことにした。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "生涯でいちばん美味いとおもつたものは、學生時代に小島政二郎氏におごツてもらつた親子丼だとよく云つてゐた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着いた時は日暮れ時で寒く、駅前のそば屋で食った親子丼が実にうまかった。",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "親子丼、テンプラそば、ぜんまいと、実にありふれた食物だが、飢えプラス何物かが最上のソースになったのである。",
              "citation": {
                "source": "飢えは最善のソースか",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒を一本ずつ取り、親子丼を食べた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ近処の英百合子の家へ、清川虹子と寄り、親子丼をとって貰って食べる、映画人の生活の一面、この家にあらはれてゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた葉の親子丼をかき込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終っても、外出の元気なし、ふた葉の親子丼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚又、親子丼一つ食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終り、外出して、空襲にぶつかってはと、ふた葉の親子丼をとりて食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるの部終って、渡辺が親子丼を食ってるんで、会田に「ミツバ抜きで」と命じたら、ミツバが入って来ちまった、会田が言ふのを忘れたと言ふ、腹が立ったがもう一つ改めて言はせる、今度は向ふが間違へてミツバを入れて来た、之は大辻が引受けて食った、「バカ！",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回の終り、ＰＣＬの大谷組が、「女性読本」の打合せに来る、親子丼食ひながらヅラを合せる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食する暇もない、昼は下高井戸のそばやで二十銭の親子丼。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "花井と田村の「夏の日」のセリフを直す、急しい／＼、夕食は親子丼一個。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
