        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同級生たちはもうみんな分別くさい顔の親父になって、町会議員やらお百姓さんやら校長先生やらになりすまし、どうやら一財産こしらえた者みたいに落ちつき払っている。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細君の言うには、田舎のお百姓さんが純朴だとか何とか、とんでもない話だ、お百姓さんほど恐ろしいものは無い。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金をずいぶん欲しがっているくせに、わざとぞんざいに扱ってみせて、こんなものは紙屑同然だとおっしゃる、罰が当りますよ、どんなお札にだって菊の御紋が付いているんですよ、でもまあ、そうしてお金だけで事をすましてくれるお百姓さんはまだいいほうで、たいていは、お金とそれから品物を望みます。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのお金や品物が残っていたら、なに、あとはその人の創意工夫で、なんとかやって行けるものだ、田舎のお百姓さんたちにたよらず、立派に自力で更生の道を切りひらいて行くべきだと思う。",
              "citation": {
                "source": "やんぬる哉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの朝早く、ひとりのお百姓さんが通りかかって、あわれなアヒルの子を見つけました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百姓さんは、すぐさま、そばへやってきて、木靴で氷をくだいて、家のおかみさんのところへ持って帰りました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百姓さんの子どもたちは、大よろこびで、アヒルの子とあそぼうとしました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの家のえんとつからも、貧乏なお百姓さんの家の、ちっぽけなえんとつからさえも、ちょうど、ドルイド教徒のさいだんからのぼる煙のように、かんしゃをこめた、ささげものの煙が、うす青く立ちのぼりました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は路傍の畑で働いてゐるお百姓さんに、スフの帽子をとつてお辞儀をして、「この路を、洋服を着た若いアネサマがとほりませんでしたか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお百姓さんの裏庭の方々に紹介するからね。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "山羊ならお百姓さんの畑だよ」「しかし僕はいま、その絵は山羊じゃないと言ったぜ」「うん、そんなら仔山羊だね、――まあ、ほとんど同じものさ」「ほとんどね。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人の穿き古した靴が破けかかって、別なのを新調しなければならないのを見てとった妻は、「これまでのあなたの靴はあまり大き過ぎて、まるでお百姓さんのように不恰好でしたわ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、お百姓さんって、何時でもこの水の中に入って働くのねえ！",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "良人の穿き古した靴が破けかかつて、別なのを新調しなければならないのを見てとつた妻は、「これまでのあなたの靴はあまり大き過ぎて、まるでお百姓さんのやうに不恰好でしたわ。",
              "citation": {
                "source": "茶話",
                "author": "昭和三（一九二八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦飯と松葉薬とが（消極的には酒を飲まずにゐたことが）胃の工合をほどよくしてくれた、こゝに改めてお百姓さんと源三郎君とに感謝を捧げる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百姓さん達はそれに絶対に服従していたのです。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山村のお百姓さんはほんたうによく働らいてゐる、もつたいないと思つた、すまないと思つた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はもう十分だが、この風では田植も出来ないと、お百姓さんは空を見上げて嘆息する。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡部一郎ひるまず　岡部一郎はなぜ、もぐらをとっているお百姓さんを見て、よろこんだのか。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、廃品回収車を、道ばたへおき放しにして、そのお百姓さんのところへ、のこのこと近づいた。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百姓さんは、一郎のすがたを見ると、手を左右にふっった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれッ、そばへいっちゃ、いけないのかなあ」　もぐらが、一郎にかみつくといけないと、お百姓さんは、しんぱいしているのであろうか。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことなら、何がこわくあるものかと、一郎は、かまわず、お百姓さんの方へ歩いていった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お百姓さんは、また手を左右にふった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "来ちゃいけないというわけじゃねえが、今日はなにもお払いものがないということさ」　お百姓さんは、岡部一郎が、廃品回収屋の腕章をつけているのを見て、てっきりお払いものはないかと、ききにきたのだと感ちがいしたのだ。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのもぐらのことですよ」　一郎は、お百姓さんの足許にころがっているもぐらを指した。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ、おしえてください」　それをきいて、お百姓さんは、おどろいて目をまるくした。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、土掘りの名人のもぐらのことを、ぜひ勉強して、出来れば、もぐら式の地下戦車をこしらえてみたいなあ」　一郎のいうことは、一郎にはわかっているが、お百姓さんには、ちんぷんかんぷんだった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このもぐらというけだものはこんなかわいい顔をしているが、悪いやつじゃ」　と、お百姓さんは、足で、もぐらの腹を、ぽんとけった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
