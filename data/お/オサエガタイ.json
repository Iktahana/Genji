        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "抑えがたい戦慄がだんだん体じゅうにひろがり、とうとう心臓の上にまったくわけのわからない恐怖の夢魔が坐った。",
              "citation": {
                "source": "アッシャー家の崩壊",
                "author": "THE FALL OF HOUSE OF USHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "お弓に対して、抑えがたい嫌悪を感じ始めていた市九郎は、お弓が一刻でも自分のそばにいなくなることを、むしろ欣んだ。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は師の信西入道をも驚かすほどの博学で、和歌に心を寄せる兄の忠通を常に文弱と罵っているほどに、抑えがたい覇気と野心とに充ち満ちている人物であった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学者は科学的であるかという悲しい疑問が心に湧くのを抑えがたいのである。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中のある旅館における雨の侘しい晩に、従兄への葉子の素振りの媚めかしさが、いきなり松川の嫉妬を抑えがたいものに煽りたてた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでもしこのアカデミシャンが、判だの鍵だの紹介状だの其他一切の権威の象徴を用いて、私を社会的にこの宝庫に近づけない結果を招くとなると、この羨しさは忽ち抑えがたい不平に転化せざるを得ない。",
              "citation": {
                "source": "学界の純粋支持者として",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの窓から其光景を遠く眺めやっている私の胸に、抑えがたい欣びがあるのであった。",
              "citation": {
                "source": "カメラの焦点",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでは、あらゆる社会階層の、あらゆる生活内容の、あらゆる矛盾をもった精神が、ただひとすじ、人民的生存の要求にせき上げられて、抑えがたい声をあげてゆくわけである。",
              "citation": {
                "source": "両輪",
                "author": "――創造と評論活動の問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代的な小説の成立という問題を、わかりやすく、しかし情熱をもって、わたしどもの生きているきょうのこころに引きつけて吟味しようとする意欲は、抑えがたい。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の本質は、人間性のうちにある抑えがたい展開と発見への欲求に立っている。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず彼の内部に存在したヨーロッパ風の自由主義に立つ教養と家風にしみている武士気質の躾との間の衝突、そういう精神の桎梏を何かの動機で一気にかなぐりすてて、生のままの人間一人の生きる爽やかさをもちたいという抑えがたい欲求があった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉の手と重吉の声とは、もしかしたら重吉が心づかないうちに、こうして生活はとりかえされた、という抑えがたい感銘を表現したのかもしれなかった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おそらく立会いが要ることだろうから、小使の一人を呼ぼうと思ったが、抑えがたい好奇心に駆られたため、扉をノックしたうえであけてみた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の一切をぶちまけたいという抑えがたい慾望が、この日のうちにさらに二度ばかり彼を襲った。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に病気だったこともあり、誰からともなく噂が耳にはいると、ようすをみにゆきたい、という抑えがたい衝動に駆られたものだ。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいま、おすえの大きな眼でみつめられたとたん、彼はなにもかも話してしまいたいという、抑えがたい衝動に駆られた。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにも抑えがたい衝動を感じさせるのに、そのあとではいつも、激しい屈辱と嫌悪におそわれる。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ったとき、抑えがたい怒りと悲しさがこみあげてき、われ知らず振向いて母に問いかけた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺は現在、これを書いていて、新たな怒りが俺の胸にこみあげてくるのを抑えがたい。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを支えているのが、抑えがたい強さの性欲であることを認めてしまうと、つらさはなぜか少しだけ緩和された。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "描きたいという抑えがたいあの衝動という、本来はかたちなどないものを、ひとまず自分にも出来ることとして、この絵に描きとめた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もが抑えがたい好奇心の目を彼に注いでいた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも助かったのですか」　そうだと言うと、総督は相変わらず憂鬱そうに歩いていたが、内心は抑えがたいほど興奮していた。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐怖のせいじゃなく、驚いた為であり、抑えがたい感情から出たものだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何かは知れず、油然といま、いま胸に抑えがたい感慨がわいた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こよいこの絶景に対して回顧の情、望呉の感、抑えがたいものがある。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長三郎は一種の恐怖を感ずると共に、又一方にはおさえがたい憤怒が胸をついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちすべてが無関心であり得ないからこそ、その関心の持ちよう、関心をもつ切ない心の女の日々の生活のありようについて、深く思いめぐらしたい心持がおさえがたいのである。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜も昼もと、おさえがたい成長をうながされつつ、――新制高校の若いひとびとの書いた原稿を一つ一つとよみながら、わたしは信頼とよろこびにみたされて、この事実を感じた。",
              "citation": {
                "source": "小さい婦人たちの発言について",
                "author": "――『わたしたちも歌える』まえがき――",
                "note": "青空文庫"
              }
            },
            {
              "text": "対象の含んでいる種々の複雑な価値についてよく考え理解した上で、そこに諷刺のおさえがたい横溢を表現してゆくという製作の態度よりは、寧ろ小熊秀雄の才分の面白さ、という周囲の評価の自覚において諷刺の対象への芸術家としての歴史的な責任という点は些かかるく扱われた。",
              "citation": {
                "source": "旭川から",
                "author": "――小熊秀雄氏の印象――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
