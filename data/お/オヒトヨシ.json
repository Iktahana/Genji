    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good-naturedness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お人好しについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お人好しがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お人好しというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお人好しの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお人好しが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お人好しを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お人好しの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お人好しはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお人好しがあります。",
              "source": "幻辞"
            },
            {
              "text": "お人好しは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お人好しについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお人好しの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お人好しの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお人好しが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お人好しについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお人好しは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお人好しについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お人好しという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお人好しの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お人好しを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "祖父が――父の養父――がお人好し過ぎて他人のために財産といふものを全部使ひ尽して、自分の住家といふものは古い家を買つて建てたやうな有様であつたことを能く父は祖父の生前言つてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、山には一目見ただけでも傲慢であったり、独りよがりのお人好しであったりしそうな性格に見立てられるものがある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美少年は不良を衒っているが根が都会っ子のお人好しだった。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の好印象は、殆んど底ぬけのお人好しと、農民的の素朴さと、北國的の憂鬱感と、大陸的のヌーボーとが、漠然たる色彩で神祕的に混同してゐる所にある。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた日本人は野心家であるが、それにもまして日本人がお人好しであること、恋を恋とも思わぬ日本人の高潔は畢竟それは日本人に不足した性教育のためである。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生からお人好しで、愚圖で、低能な彼は、もともとだらしのない男だつたが、今は全く正體を失つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また髭にうんと絞られるぜ‥‥」「可哀想になあ‥‥」　中根熊吉の「馬さん」は二｜年兵の二｜等卒で、中隊でもノロマとお人好しとで有名だつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやはや、そんなことと知っていたなら、僕は何もこんなお人好しの役目を仰せつかるのではなかった。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "といつて今にも出て行かうとしましたので流石にお人好しの仕立屋も此言葉を聞くと大層｜憤つてお神さんを打ちました。",
              "citation": {
                "source": "金剛石",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、あんまりやっつけ過ぎたために、相手は平々凡々のお人好しを通り越して、何もかも覚りつくした、諦め切った人間になってしまっている。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は単にお人好しの小説家で、真実を見ぬこうとする意地悪さもなく、科学的なる残忍さも持っていない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この普通常識から批判すれば痴呆のような甘いお人好しの観念が、時にかの女の知性以上に働いて、かの女を非常に謙遜にしたり、時には反対に人を寛大に感じさせ過ぎてかの女を油断に陥れる……　かの女が黙って考えているのを規矩男は気づかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、お人好しだったよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ阿諛迎合を事としても、杜周（最近この男は前任者｜王卿を陥れてまんまと御史大夫となりおおせた）のような奴は自らそれと知っているに違いないがこのお人好しの丞相ときた日には、その自覚さえない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穿ったような見方をするようでいて、実は大変に甘いお人好しである点なども、その一つであろう。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず和製では、野生的の勇気を表わす「獅子鼻」を筆頭に、意地の悪い感じを与える「鷲鼻」、お人好しと見られる「団子鼻」、無智を示す「蓮切鼻」、無能を示す「トンネル鼻」、慌て者を表白するという「二連銃」、むずかし屋を表明する「碇鼻」（「怒り鼻」？",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして引き続いてクレオパトラに愛せられたところを見ると、アントニーの鼻の表現は余程のお人好しか好色漢の色彩を帯びたものであったろうと想像されます。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の性格はお人好しもいいところだが、なかなか情と思いやりのある人物だ。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもお人好しのやつだったから、こうして友人の事件に首を突っ込むなど、あいつらしいな。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（それと云うのも、兄貴がお人好しだからだ）　兄貴がお人好しで蛇を拝んだり、白蟻の糞を拝んだりしているからだ。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来都市計画は、お人好しの立案者が予想しなかったあぶれ者の流入によって、足元をすくわれると相場は決まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらお人好しでも亭主がある以上、しん吉と思うように逢うことが出来ないので、これも駈け落ちの相談、ちょうど和泉屋の女房とおなじ行き方です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分お人好しの處がある。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "監房ホテルの中で係官の註文によつて、お人好しの彼は大真面目で再演するのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに無口で大力で正直で何ひとつも欠点がありませんでしたが、唯そのお人好しがあんまり過ぎるので困りました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけで日本の国際的地歩の向上である――とお人好しに喜んでもをれない。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな話で、バカだからなどと云はれると彼は、俺はお人好しだから俗事には疎いのさ、といふ風な途方もない虚栄心を誇つた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家の阿母さんや叔母さん達は純ちやんのことを随分心配してゐるのだからね、ほんとにこれから気を附けてね……」「此方の敗北に附け入つて、」照子がそのお人好しのところを露骨に示し出すと、彼は、自分の厭にひねくれた、さうして莫迦気て邪推深い愚かさを強く憎まずには居られなかつた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生たちは私を、はにかみの深い、おひとよしだと思っていたかも知れない。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は無類のおひとよしの癖に惡辣ぶりたがる性格を持つてゐて、そのひとりむすこである彼にさへ、わざと意地わるくかかつてゐた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
