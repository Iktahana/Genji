        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "５１＝二階の密室　「ではそろそろ」と一同御膳を横へ押しやると其処に穴がある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "51＝二階の密室　「ではそろそろ」と一同御膳を横へ押しやると其処に穴がある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "先に立って歩きたまえ」　巡査は腕を掴んで前へ押しやるようにした。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "几帳を隔てて花散里はすわっていたが、源氏がそれを手で押しやると、また花散里はそうするままになっていた。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は小さい土器に神酒徳利のしずくをそそいで、その口さきへ押しやると、蛇は蜜をなめるように旨そうになめ尽くした。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに屋敷へかえりつくや、うなじ迄も赤く染めている菊路の方へ、これも一面の紅葉を散らしている京弥をずいと押しやるようにすると、至って粋な言葉をぽつりとひとこと、愛撫のこもった揶揄と共に言いました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえのぶん」　高志がテーブルにおかれたホットドッグを、慶一のほうに押しやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ済みますからこちらへ寄っていて下さい」　宇利氏は早口にそう云って、手早く案内人を伝さんのほうへ押しやると、もう後の人の切符を忙しく受取りはじめた。",
              "citation": {
                "source": "三の字旅行会",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早う帰れ」　僧は千枝松の手を取って門の外へ押しやると、くろがねの大きい扉は音もなしに閉じてしまった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "懷疑といふのは動かし難いものを搖り動かし（eversio）、迫り來るものを押しやる（remotio）ことである。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "デカルトは我々のこのやうな自然的な考へ方を押しやるために夢の假説を用ゐてゐる。",
              "citation": {
                "source": "認識論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」義雄は、薄いかけ蒲團と敷き蒲團が延べてある上に、その不足を補ふインバネスや座蒲團を載せてある床を、そのまま圓めて障子の方に押しやる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな情報を頭脳に送り込み、結果的に人の認識の限界をはるか彼方に押しやるメディアとなるだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時ちゃんは、枕元の紅いシクラメンの鉢をそっと押しやると、簪も櫛も枕元へ抜いて、「さあ寝んねしましょう。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を押しやるようにして波が白くはじけている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　時ちゃんは、枕元の紅いシクラメンの鉢をそっと押しやると、簪も櫛も抜いて、「さあ寝んねおしよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を押しやるようにして波が白くはじける、五本の指に藻がもつれた糸のようにからまって、しおしおとしている。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊代は泣き声をあげていた時よりも一層悄気て、灰皿を九太の膝元へ押しやると、少女のようにうつむいてしまった。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう意味に於いて、文学の生産不足は、文学を「文学以前」に引戻すと共に、文学に対する需要を増加させ、文学の生産過剰は、文学を「文学以後」に押しやると共に、文学に対する需要を減少させる。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "てる子が無邪気に、「ああア私、何だか変な気分になっちゃった」　定規を図板のむこうへ押しやるようにしながら、胸を反らしてその辺を見まわした。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、署の方と仰言いますと――刑事さんで、まあ、このお暑いのに――」　一眼で前身の判る又七女房おろくが、楽屋模様の中形の前を繕いながら、老刑事助五郎へ煙草盆を斜めに押しやる。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房また権太の方へ押しやる。",
              "citation": {
                "source": "いがみの権太",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいってくると、私の向ったそばにいる若い男を押しやるように、割り込んだ。",
              "citation": {
                "source": "帰途",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、房枝の腕をとると、前へ押しやるようにして、そのところを通りぬけた。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）鐘さへ鳴れば　去なうとおしやる。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）千たび百たびおしやるとも、なるまじものをうつつなの其方や、われに主ある、思ひとまれよ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "して、これからはどうおしやる。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わらわの申すことを用いねば命はないぞ、その期に及んで後悔おしやるなと、言うかと思うと、その檜扇の蔭から怖ろしい……人か幽霊か鬼か獣か判らぬような、世に悽愴い変化のおもてが……。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（朱書、磨滅）月　日―――――――――認おわりて枕辺におしやる頃、門守る犬の声には夜ふかふおぼへ、鳥のこゑのこゝかしこにきこゆるは寅の針は卯をさすにちかゝらんか。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月十日　長崎奉行あて差出の草案",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に、先生がひどいことをするので、それがます／＼ガスパールを家の方へおしやるのでした。",
              "citation": {
                "source": "村の学校（実話）",
                "author": "アルフオンズ・ドーデー　Alphonse Daudet",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
