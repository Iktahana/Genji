          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そんな錯乱のさなかの一九九一年四月九日、コンパックとマイクロソフト、そしてＵＮＩＸで勝負をかけるサンタクルズオペレーションを始めとする二十一社が、新しい先進的プラットフォームと銘打った、ＡＣＥ（アドバンスト・コンピューティング・エンバイロメント）構想に取り組むと発表してオレの錯乱に拍車をかけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は、マイクロソフトのＯＳ／２バージョン３・０（これは後に例のマイクロソフトとＩＢＭの大喧嘩で、Ｗｉｎｄｏｗｓ　ＮＴと呼び変えられた）、そして第二はサンタクルズオペレーションのＵＮＩＸシステムＯｐｅｎ　Ｄｅｓｋｔｏｐ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳはマイクロソフトかサンタクルズオペレーションと、互いにしのぎを削るはずのライバルを襷掛けに組み合わせて、果たして一つのまとまった構想たりうるのかと最初から首を傾けさせる要素はあった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月になってコンパックが正式にＡＣＥからの脱退を表明すると、サンタクルズオペレーションも撤退だと言い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳはサンタクルズ・オペレーションのＵＮＩＸか、マイクロソフトのＯＳ／２　３・０。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでない限り、単なる研究手段は随時に各処に存在する断片的なオペレーションなのである。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
