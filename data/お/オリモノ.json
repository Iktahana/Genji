    "definitions": [
      {
        "index": 1,
        "gloss": "vaginal discharge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京の糞尿と共に、此辺はよく東京のあらゆる下り物を頂戴する。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町に売る繊細ないわゆる「下り物」とは比較にならない。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店という店｜他処から来た「下り物」ばかりで、土地の人は地のものを愛さない。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方ではそれを「下り物」と呼ぶ。",
              "citation": {
                "source": "地方の民藝",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、肩｜撫でたげて、「なんぞ下り物でもしたんかいな」いうと、黙って首振って、「あて、もう死ぬ、死ぬ、……助けてほしい」と、ほんまに消えてしまいそうな虫の息で、「姉ちゃあん、……」と一と声大きく呼びながら、両手で私の手頸にしがみ着きますねん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも最近はいわゆる「下り物」といって、中央から流れ込む商品に段々犯されて来ました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "儀一はあのとおりものにならない。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿部一族」では、そのようなロマンティックな要素も作品の一つの色彩とはしつつ、作者はぐっとリアリスティックに心理と経済の事情にまで広く多岐に踏みこんで、一人の君主の死が、武家社会に波及させた悲劇と生死の幾とおりもの姿を描き出している。",
              "citation": {
                "source": "鴎外・芥川・菊池の歴史小説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海道本線では有名で、幾とおりものプラットフォームには、殆どいつも長い客車、貨物列車のつながりが出入りしているのに、駅じゅうに赤帽がたった一人しかいない。",
              "citation": {
                "source": "この夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に知りつくされているとおり、自然主義は、所謂自然派の人々の間にもいくとおりもの見解をもって理解されていた。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイについていくとおりもの文章が集められているが、これは重複していない。",
              "citation": {
                "source": "あとがき（『作家と作品』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまは、まっ赤なおりものとアーミンの白い毛がわをまとって、あっさりながらもでんとしたイスにこしかけていた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、ぐったりといすに身をなげだして、もの思いにしずんでいたが、「そうだ、新聞を見れば、なにか手がかりがつかめるかもしれんぞ」　ぽつりとひとり言をもらし、いくとおりもの新聞をかきあつめ、机の上にひろげて、むさぼるように読みはじめた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからいづみ子にしろ並々ならぬ心持で、どこかそこを通っている好ちゃんの上を思いやるという次第でしょう、いくとおりもの家並や街筋やに遮られて、好ちゃんの歩いてゆくその道は見えないにしろ、いづみ子の胸に、あの爽やかで力にみち、よろこびにみちた姿が映らないというわけがありません。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、一とおりものになった理論ですよ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "出かけられる時もいつものとおりもの柔らかだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
