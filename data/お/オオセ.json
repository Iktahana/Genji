[
  {
    "uuid": "1e6262fe-ae74-54de-a3a0-c8e6396cb580",
    "entry": "仰せ",
    "reading": {
      "primary": "おおせ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "order (from one's superior)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "昔の大名それの君、すれちがいし船の早さに驚いてあれは何船と問い給えば御附きの人々かしこまりて、あれはちがい船なればかく早くこそと御答え申せば、さらばそのちがい船を造れと仰せられし勿体なさと父上の話に皆々またどっと笑う間に船は新田堤にかかる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋殿が例えば「狸」と仰せられると加八は一同の顔色を注意深く観察して誰が「狸」であるかを観破するために云わば読心術の練習のようなことをする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と苦笑しながら、「仰せに隨つて、お前の甲羅に腰かけてみるか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る口の惡るきお人これを聞きて、扨もひねくれし女かな、今もし學士が世にありて札幌にもゆかず以前の通り生やさしく出入りをなさば、虫づのはしるほど嫌やがる事うたがひなしと苦笑ひして仰せられしが『ある時はありのすさびに憎くかりき、無くてぞ人は戀しかりける』とにも角にも意地わるの世や意地惡るの世や。",
              "citation": {
                "source": "經つくゑ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此坂を下りてあしこへ行きて暫時やすまん、つかれては話しも厭やなればと仰せあるに、さらば歸りたまふか、厭々、今しばし遊ばんとて、苔なめらかなる小道を下らるゝに、おあぶなしと言へば、氣のどくなれど其肩をかし給へとてつと寄りて此處を下りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよ、今宵よりは一時づゝの仕事を延ばして、この子が為の収入を多くせんと仰せられしなりき。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕には職あり、身は健かなるに、いつまでかくてはあらぬ物を』と口癖に仰せらるゝは、何所やら我が心の顔に出でゝ、卑しむ色の見えけるにや。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「エーと仰せられましても、エーでごわせんだ。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左久馬供侍に、Ｔ「あの女、虫がついている喃」　その侍がハッ仰せの通り。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださえ忙しい県庁のお役人様はこの上に山火事の調査まで仰せつかっては困ると言われるかもしれないが、しかしこれも日本のためだと思って、もう少しめんどうを見てもらいたいと思うのである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは全く仰せの通りでございます。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と仰せられます」「まあさようせき込まずとユックリお話を聞きましょう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵元屋に限って御尽しになる義理張りは盗人に追銭も同様……」「何と仰せられまする。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――ほほほ、絵などと仰せられては痛み入ります。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――何と仰せられます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧一　――何と仰せられます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世尊は聖なる花嫁であれと仰せられました。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにても其の餘りの美しさに、ひととなりて後國を傾くる憂もやとて、當時國中に聞えたる、道人何某を召出して、近う、近う、爾よく此の可愛きものを想せよ、と仰せらる。",
              "citation": {
                "source": "妙齡",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と仰せあるばかり、少しも御聽許にはならないのです。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と有り難い仰せぢやあるまいかなう。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱落もあるめえが、何ぞ一品、別の肴を見繕ってよ、と仰せられる。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と仰せられ、「ああ、いい酒だぜ、忠兵衛のおふくろかい、古い所で……妙燗妙燗。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "へえ、今度はまた格別の御註文仰せつけられまして、難有い仕合せにござります。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）姥　（居直り）また……我儘を仰せられます。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――仰せつけられまする儀は？",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姥　ええええ仰せなればと云うて、いずれも必ずお動きあるな。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姥　これは何となされます……取棄てて大事ない鐘なら、お前様のお手は待たぬ……身内に仰せまでもない。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄衣　　もし父上が飽までも御不承知と仰せられたら……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎　　さなきだに世の中が面白からぬと仰せられてゐたところへ、恰も將軍の御上洛、その御出迎ひを強ひられる蒼蠅さに、いつそ武士を捨つるとのお詞でござりまする。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、そのうちに本家の老舗の日本人がこのアメリカ語に翻訳された「俳諧」の逆輸入をいかなる形式においてしおおせるであろうかを観望するのは、さらにより多く興味の深いことである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
