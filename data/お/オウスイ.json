        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "不純酸化コバルトを王水に浸し、その四倍の重量の水に薄めたものが、ときどき用いられる。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒蛇に咬まれた人、糸一条を七所結び頸に掛け、ジェット・シン、ジェット・シンと唱え続けながら、王宮に趨く途中、結び目を六つまで解く、宮に入って王の前で、七つ目の結びを解く、時に王水をその創に灌ぎ、また両手に懸け、一梵士来りて祈りくれると、平治して村へ還ると。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「王水〔塩酸と硝酸との混合物〕ですか？",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではあの竹内の土瓶の中は王水でしたか？",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俊夫さんは、どうして白金が土瓶の中の王水にとかしてあることを見つけたのですか？",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ商人たちは、こういう途轍もないマデラ酒がお気に召す地主連の味覚を百も承知で、遠慮会釈なくラムで味をつけたり、時にはロシア人の胃の腑なら、この位のことは大丈夫と見越して、＊６王水まで注ぎこんでおくからである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊６　王水　強硝酸と強塩酸との混合液で、通常の酸に溶解せぬ金、白金を溶解し得る強烈な作用を有する。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "金博士始末案件（一）王水険博士を擁立し、金博士を牽制するとともに、必要に応じて、金博士をおびき出すこと。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに王水険博士というのは、この程、ソヴェトから帰って来た近代に稀なる科学的天才といわれる大学者で、しかも彼は、昔金博士を教えたことがあり、つまり金博士の先生だから、大博士であろうというので、王水険博士の力を借りる計画を樹てたのである。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士が封を切って中を読んでみると、巻紙の上には情緒纏綿たる美辞が連なって居り、切に貴郎のお出でを待つと結んで、最後に大博士王水険｜上と初めて差出人の名が出て来た。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらなつかしや王水険大先生！",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが飜訳大監として威張っとるうちに、ぜひ来て下されや」　と、王水険博士は、大秘密を洩らして居られる。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "王水険大先生のお部屋はどこであるか。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今金博士が推参いたしましたぞ」　とうとう王水険大先生が朝寝坊の居間が、金博士｜自らの捜索によって発見せられた。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻になったら起してやろう」「はあ、恐れ入ります」　王水険先生は、自室を金博士に譲って、そこを出ていった。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金のやつ、ぐっすり寝こんでいる頃じゃ」　醤にうまくいいくるめられている王水険大先生は、最高の善事をするつもりで、醤を引具し、窓下に高梯子をかけ、それをよじ登って、窓からそっと金博士の様子を窺ったのである。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤と王水険大先生とは、さすがにタンクには手が出しかねて、すごすご退却のほかなかった。",
              "citation": {
                "source": "戦時旅行鞄",
                "author": "――金博士シリーズ・６――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお附け加えると、園長の金歯は、大胆にも私の見ている前でビーカー中の王水に溶かし下水道へ流しました。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "王水という強酸があることを、人々は知っているであろう。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの強酸に王水という貴い名前が附けられている。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　黄金を王水に溶かしたのは私ではない。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、飯を喰わしてくれんか」　食堂の衝立の蔭から、瞳の青い、体の大きい給仕がとびだしてきたが、博士を見ると、直立不動の姿勢をとって、「あ、王水険先生のお客さまでいらっしゃいましたね。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、老師のおかげです」　食卓に向い合って、金博士が、王水険老師を恭々しく拝しながらいった。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その奈落には、火薬炉が大きな口をあけて待っているのだ……」「能書はあとにして、金博士を骨にして見せて下され」「いざ、いざ、これを見よや」　王水険老師は、この寒中に汗だくだくとなって、廊下の床をおとすスィッチを引いた。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、王水の中での溶解性の発見によって、我々はその新しい性質を既存の諸性質に追加する。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
