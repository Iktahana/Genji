[
  {
    "uuid": "7c69ac07-de3f-5a0f-bf12-ab8438628862",
    "entry": "お尻",
    "reading": {
      "primary": "おしり",
      "alternatives": [
        "オシリ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "bottom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お尻という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお尻の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お尻を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお尻という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お尻の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お尻は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お尻の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お尻と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お尻は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お尻はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お尻の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お尻の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お尻が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お尻を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お尻のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お尻に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お尻の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お尻の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お尻は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お尻の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私のあの散歩の帰途、私にまつわりつくようにしてついてきて、その時は、見るかげもなく痩せこけて、毛も抜けていてお尻の部分は、ほとんど全部｜禿げていた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそは勘弁しないぞと、空気銃にバラ玉を込めて犬のお尻の処をジット狙いました。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅で縫い物をしていらっしたお母様はお父様の様子に気がついて、どうしたのかと思って窓の外を見ると、猫は金魚をねらい、犬は猫のすぐ後に近寄り、坊ちゃんは犬のお尻を狙って引き金を引こうとし、お父様は坊ちゃんの襟を捕まえようとしておられます。",
              "citation": {
                "source": "ドン",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「肩まで、肩まで」と手で押えられて、かやは婆やの丸いすべすべした膝の上へ、ひったりお尻を据えてしまった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、「真昼間、……お尻を振廻して歩行いたって、誰も買手は有りはしないや。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなお尻は鳶の突くが落だ、と云う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆がしらでも中軸でも一味についた連名の、昼鳶がお尻を突く、駿河台の水車、水からくりの姉さんが、ここにも一人と、飛込もうか。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうの、あの四角いような白い丘が、お尻の響でぶるぶると揺れるようなの。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、いまじゃ流行らないけれども割安の附木ほどの名刺を出すと、錺職の御老体、恐れ入って、ぴたりとおじぎをする時分には、ついて来た、羽織なしで袴だけの下役が、手拭を出して、そッと課長さんのお尻の下へ当がうといった寸法ですって。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校の生徒らしく、お尻に手拭いをぶら下げているのだが、それが妙に塩垂れて、たぶん一向に威勢のあがらぬ恰好だったろう。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもヒョロ子はとうとう我慢し切れなくなって、馬車屋のお爺さんの横に掛けてあった鞭を取ると、いきなり馬のお尻を力一パイ打ちました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶先生はそれから馬をもと来た道の方へ向けて、お尻をピシャリとたたきますと、馬は驚いてドンドン駈けてゆきました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから赤い湯もじをお臍の上までマクリ上げると、大きな真白いお尻を振り立てて、妙テケレンな踊りをおどり出した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お尻ののるところは黒い革で張つてあります。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまも松吉は、小平さんが、そんないたづらを、はじめるのではないか、とお尻のおちつかぬおもひでした。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の重箱は、ズボンのポケツトにつつこんだ松吉の右手にだらしなくぶらさがり、一足ごとにお尻にぶつかります。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "短いしつぽが、やせたお尻の上にぺろりと垂れてゐるのも可愛かつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分揺られて来たので、良寛さんは、お尻が痛くなつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、私のお尻をくすぐっているのは誰？",
              "citation": {
                "source": "失敗園",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっとこうした処は、お尻の方だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁様――処ででしゅ、この吸盤用意の水掻で、お尻を密と撫でようものと……」「ああ、約束は免れぬ。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭をたたいたり、お尻をつねったりしたのです。",
              "citation": {
                "source": "巨男の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しめた」笑ってると、いきなりぴしゃりとズボンのお尻を叩かれた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明の月に血を吐くほととぎすの悲歎を曾て見知らぬ私は寧ろキヤベツ畑の雨に啼く郭公を楽しいものに哀れみ、昔ながらの古い前栽の繁みに飛ぶ蛍よりも客待の人力車のかげに仄かに蒼白いお尻のパツチを光らす東京の蛍をこの上なく今の心に親しむ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつしか黄ばみかけた日の光のもとに、薄青いクローバ模様の壁にかけた玩具の木時計が可笑しさうにお尻の分銅を動かし乍ら今三時を点つ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間の光に薄黄色い火の線と白い陶器の笠とが充分にダラリと延ばした紐の下で、畳とすれすれにブランコのやうに部屋中揺れ廻つて居る、地震かしらと思ふ内に赤坊が裸で匍ひ出して来た、お内儀さんが大きなお尻だけ見せて、彼方向いて事もあらうに座敷の中でパツと紺｜蛇目傘を拡げる。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、お尻の方からちかちか光る小さなものを落して草をくれた雀と伴れ立って飛んで往った。",
              "citation": {
                "source": "雀の宮物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高座へ出ると、行きなりお尻をくるっとまくって据わるのですもの。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……グワ――アアッ……」　中野学士のお尻の処の布地が、又野の指の間で破れて、片足が足首の処まで火の海の中へ落ち込んだのであった。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説のお尻の穴から片手を突出してオイデオイデをしている変態心理。",
              "citation": {
                "source": "探偵小説の正体",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
