    "definitions": [
      {
        "index": 1,
        "gloss": "to overcome (opposition)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし所詮真の芸術が一つの業苦であるならば悩みのまゝに押し切るより外に術はない――』と神泉氏に向つて言つてのける。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだとすれば、つぎの彼女の言葉『悩みのまゝに押し切るより外に術はない』といふ言葉が意味を為すからである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挙に押し切るか、一挙に押しきられるか、そこへ来ている！",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "高をくくって軽く動かそうとされると、猛然癇を立てるけれども、所謂情理をつくして折入ってこちらの面目をも立てた形で懇談されると、そこを押し切る気が挫ける律気で常識的な市民の俤が髣髴としている。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "糞でも喰らえという気で、押し切るには押し切ったが、実のところ寿命が縮まる思いをしたね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを押し切るようにして、幹夫を枕頭に呼びました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しは親の思惑でも押し切るほどだったらいいんだけど。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "収　一々押し切るようだったら、一層困るんでしょう。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを押し切ることを、あなたの自尊心が許さないとすれば。",
              "citation": {
                "source": "みごとな女",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて自然にといふわけにいかなかつたことは、田丸も重々承知のうへであるが、これで押し切るより外はない。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、乗りかゝつた船だから、無理にも押し切ることにするが、若し私のそういう調子を発見したら、どうか読者諸君は、嗤わずにゆるしてほしい。",
              "citation": {
                "source": "いわゆる「反省」は我々を救うか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "山門寺門の天台側からこの抗議があって見ると、仮令法皇の思召でもそれを押し切る訳には行かなかった。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、どこまでも生家と青山の家との旧好を続けたいという継母おまんが強い意志も働き、それほどの先方の厚意を押し切るということは、半蔵としても容易でなかったからである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも、好んで、御両親の反対を押し切る必要はない。",
              "citation": {
                "source": "ここに弟あり",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、やはり本当のもの、即ち科学の力は俗論を押し切ることが出来たのであって、ついに一九三一年になって、初めてこの世紀の事業が着手されることにきまり、着手以後は僅か五年間にしてこの大事業が完成されたのである。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻す途中で少しためらったが、押し切るようにして最後まで廻した。",
              "citation": {
                "source": "記憶",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花田は、射撃の達人だったな」　うつむいた隊長の髪の薄い顱頂を見守りながら、彼はふっと涙が流れそうな衝動を感じたが、それを押し切るように首をあげ、彼は確かな声音で一語一語復唱した。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼胤の立場が困難なことをよく知っているかれは、無理に押し切ることが、弟をどんな苦痛に押しやるかわかるし、さりとて老臣たちの申し条を容れれば、今とりかわしたばかりの、水戸家臣との口約を裏切ることになる。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「惜しいことをしたものだ、こう決ったものを覆して鉱業停止にもってゆくことは、かえって一気に押し切るより難しい。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はそれまでは二人で押し切る相談もあったんだが、冗談にお婆さん呼わりをしてから、もういけない。",
              "citation": {
                "source": "妻の秘密筥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし然うなれば運命だ」「一気呵成に押し切る気はないか？",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
