        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "をばさんも、娘さんも、はじめのうちは、私の音無しさに、かへつて奇怪を感じた樣子で、あのお客さんは女みたいだ、と蔭口きいて、私は、それをちらと聞いて、ああ、あんまり音無しくしてもいけないのか、とくやしく思つた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんは、すると、落ちついて私の傍に坐つて、あたしも何かお話しようと思ふのですが、お客さんがあんまり默つてゐるので、つい、あたしも考へてしまつて、何も言へなくなります。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん茶店の人たちも、あのお客は、ただ口が重いだけで、別段に惡だくみのある者でないといふことが判つた樣子で、お客さんのお嫁さんになるひと仕合せですね、世話が燒けなくて、とをばさんに冗談言はれて、私は苦笑して、やつと打ち解けて來たころには、はや十一月、峠の寒氣、堪へがたくなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんも呆れたらしく、私の部屋を拭き掃除しながら、お客さん、馴れたら惡くなつたわね、としんから不機嫌さうに呟いた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さんの原稿の番號をそろへるのが、毎朝、ずゐぶんたのしみなのだから、たくさんすすんでゐると、うれしい。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は出際にお客さんがありはしたし……明日立つたら……」　母が「甘い」とよく彼が言ふので、また言はれはしまいかと思つて、遠慮深さうにさう言つた時、彼はさすがに「甘い」とはいはれなかつた、却つて自分の方が「甘い」だつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお客さんは、どこへいらつしやいました。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきのお客さんは、どうしました。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのお客さんは、どこにゐるのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だつて、挨拶を申さなければ、お客さんに失禮ですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが、あの若い女のお客さんを逃がしてしまつたのなら、身代りにこの雀の舌を拔きます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こなひだから、さう、こなひだ、ほら、あの、若い娘のお客さんが來た頃から、あなたはまるで違ふ人になつてしまひました。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を切つて高崎へでも賣りに出すのかと聞くと、唯々お客さんに自由に進呈するためだといふ。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は自分の年｜恰好から、自然上品向きのお客さんのお相手をすることが多くなったから。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛が店から、　「お客さんお前さん詳しい様だが、余り詳しくないね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『此温泉に來るお客さんの中じア旦那が一｜等だ。",
              "citation": {
                "source": "都の友へ、Ｂ生より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『六番さんのお浴湯がすんだら七番のお客さんをご案内申しな！",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも宮の下あたりで買ったものらしかったが、教授のなくなった日、室のボーイが自分にこの尾長鶏を指さしながら「このお客さんは、いつも、世の中にこのくらい悲惨なものはないと言っていましたよ」と意味ありげに繰り返して話していた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかあもせっ角拵えたのお客さんに食べていただかなぃと恥かきますから。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからワイナハトマンが袋をかついで出て来ておどけて笑わせて、それで式が済みお客さんはみんな別室へはいって、ここへ陳列した子供への贈物を一覧するわけでした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "降誕祭前一週間ほど、市役所前の広場に歳の市が立って、安物のおもちゃや駄菓子などの露店が並びましたが、いつ行って見ても不景気でお客さんはあまり無いようでした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客さんを連れて来たんだ。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「トシちゃん、下にお客さんが来ているらしいぜ。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんに言ったってね、私はあの二階のお客さんたちに殺されますって。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしその間、お客さんの部屋で待ってるわ。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はまっすぐに私のところへ来て、どうぞ外へ出て下さい、他のお客さんに迷惑です、と追放令を私に向って宣告したのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申しますのは、ひとりもお客さんがこないからであります。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、お客さん方、早くいらっしゃい。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しゃべる事の好きな人が、ごちそうを食っていい気持ちになった時分に立って何かしら警句でも吐いてお客さんたちをあっと言わせたりくすぐって笑わせたりするのはかなりな享楽であろうと想像する事ができる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムジークのお客さんには少しもったいなくもあるし、またわかりにくそうにも思われるくらいであった。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
