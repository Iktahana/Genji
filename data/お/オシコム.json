        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "電車の運轉手は、しきりにベルを踏み鳴らしながら、併しわり合にのんきさうな顏をしてバスに押し込む遊山客の群を眺めて居たのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かと云えばＳ先生のは一と口うまいものを食わせておいて、その外に色々の旨そうなものをちらと見せたきり引込めてしまう流儀であるが、教科書は一向うまくない汽車弁当のおかずの品々を無理やりに口の中へ押し込むような流儀だからである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には、この土塊の円筒の頂上へ握りこぶしをぐうっと押し込むと、筒の頭が開いて内にはがらんとした空洞ができ、そうしてそれが次第に内部へ広がると同時に、胴体の側面が静かにふくれ出してどうやら壺らしいものの形が展開されて行くのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服はびしょぬれになる、これは大変だと思う矢先に、グイグイと強く糸を引く、上げると尺にも近い山※の紫と紅の条のあるのが釣れるのでございます、暴れるやつをグイと握って籠に押し込む時は、水に住む魚までがこの雨に濡れて他の時よりも一倍鮮やかで新しいように思われました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんの五倍も十倍も押し込む、それでちゃんと肥るのです、面白い位｜肥るのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥打帽の庇を上げて、ロイド式の色眼鏡を取り外して、手に持ったカメラと一緒に上衣のポケットに押し込むと、草の中からソーッと頭を上げて空地の周囲を見まわした。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く深くと思って、力いっぱい押し込むと、横へすべってしまった。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここだけの話ですが、わしのささやかな所持金はあの箱のなかで、だからおかかりでしょう、見知らぬ人間が部屋に押し込むというのが、わしにとっていかなる意味なのか。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "お婆あさんには娘の死骸を煙突の中へ押し込む腕力もあるまいし、又お婆あさんの体の創を見ても、自分で付けられる創でないことは分かる。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "與吉はそれでも窪んだ目を蹙めて居る卯平がまだこそつぱくて指の先で下唇を口の中へ押し込むやうにしながら額越しに卯平を見た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると一人の水夫が後から牛の臀をぐつと持ち揚げて押し込む。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く／＼と思つて、力一ぱい押し込むと、横へすべつてしまつた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "深く深くと思つて、力一ぱい押し込むと、横へすべつてしまつた。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして越後獅子の懐に顔を押し込むようにして、うわっ、うわっ、と声を一つずつ区切って泣出した。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は手に持ったハンケチを口に押し込むようにくわえて、震える手で壁を細かくたたくようにしながら階子段を降りた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年が、嫌いだと云うものを、グン／＼咽喉に押し込むような、母の意地の悪い逆な態度が、恐ろしかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとき味方の者を大勢連れて或る家へ押し込むと、その家の娘が美婦であるので、賊徒は逼ってこれを汚そうとしたが、女がなかなか応じないので、かれらは女をうしろ手にくくりあげた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐ろへ押し込む者もある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……不用心の世間でございますから」「全く不用心の浮世だな、戸締まりを破って押し込む奴がある」「いえ、自然と開きましたので」「光殿、光殿」と老人はいった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おきん、息子たち三人を押し込むように、奥に入れる。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年が、嫌ひだと云ふものを、グングン咽喉に押し込むやうな、母の意地の悪い逆な態度が、恐ろしかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして箱の中に押し込むやうにして入れて、繩を上から網目のやうにかけた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、駒平がチユンと手洟をかみ、襟卷の端をふところへ押し込むやうにして云つた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は庸三を押し込むように乗せて、自分も乗ってドアをがちゃんと締めた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然らしく上官の傍を通る拍子に、そっとそのポケットへ紙幣を押し込む、憲兵ら一斉に咳払いをする。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ツ叉の熊手は犯人が被害者を慘殺するため又屍體を竈の中へ押し込むために使用されたものでまだ生々と血と毛髮のべつとり附着せる儘竈の中より發見され、四本目の叉には染革を吊す金具が引懸つてゐた。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "止むを得ず義雄はどこへでもかの女を押し込むつもりで、或客車の踏み段へ片足をあげると、かの女は立ちどまつたまま、「あたい、そんな窮窟なところ厭だ、わ」とすねて見せた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "」すると　物しりは　おちついて、「いや　こんな　帽子では　いかん、驢馬の　耳を　おしこむので　耳が　いたいのぢや。",
              "citation": {
                "source": "驢馬の　びつこ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "正坊がすかさず、手のひらの丸薬を口の中へおしこむと、クロはぞうさなく、ペロリとのみこみました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い土間に自轉車をおしこむと、人々は腰の手拭ひを取つてパツパツと裾をはたきながら、ゆがんだ階段をぎしぎしときしませてのぼつて行く。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
