        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "オスワルドはこはごは惜しげにその肉を見送つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小山は惜しげに云った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、死者が、しょっちゅうあこがれていた太陽の光が惜しげなく降り注いでいた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "退職技手こぞりてひとを貶しつゝ、　　　わかれうたげもすさまじき、おのれこよひは暴れんぞと、　　青き瓶袴も惜しげなく、籾緑金に生えそめし、　　　　　代にひたりて田螺ひろへり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少なくも歴史的に見た時に従来の物理的科学ではいわゆる常識なるものは、論理的系統の整合のためには、惜しげなくとは言われないまでも、少なくもやむを得ず犠牲として棄却されあるいは改造されて来た。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通例こういう場合には「事がらが再起的 reproducible でないから」という口実で、惜しげもなく放棄されて来たのである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭はむさ苦しく延び煤けているかと思うと、惜しげもなくクリクリに剃りこぼしたままを、日に当てても平気でいる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会などで本職の画家のかいた絵を見ると、美しい草木や景色や建築物やが惜しげもなく材料に使われている。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その上にその平面の中のある特別な長方形の部分だけを切り抜いて、残る全部の大千世界を惜しげもなくむざむざと捨ててしまうのである。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は白露と水光との饒舌を惜しげなく切り取って、そのかわりに姿の見えぬ時鳥の声を置き換えた。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく肥った猫が一匹人おじもせずにうずくまって草の間に惜しげもなく流れこぼれた牛の乳をなめていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　イワンは胸から、あんなに大切にして肌身につけていた銀の小箱の鍵をとって、惜しげもなく兄に渡してしまいました。",
              "citation": {
                "source": "イワンとイワンの兄",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "じょきり、じょきり、惜しげも無く切って、それから髪の毛を結び合せ、長い一本の綱を作りました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての博徒等は、その生涯を惜しげもなく、かかる冒險に賭けて悔いないところの、烈しい情熱を持つてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉はおつとりして、こだはらぬ性格だつたので、与へられた松毬をいちどにどつと惜しげも無く竈にくべたところが、その火で楽にごはんが出来、さうして、あとに燠が残つたので、その燠でおみおつけも出来た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、漸く眼を定めて見渡すと自分の立って居る足下には、燦爛と輝く金砂と銀砂が、鴨川石か何かのように惜しげもなく撒き散らされて居るのを見た。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しげもなく投げ入れたる薪は盛に燃えあがりて、烟は岫を出づる雲の如く、騰りて黒みたる仰塵に至り、更に又出口を求めて室内をさまよへり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに何の惜しげなくこれを滅尽するは、科学を重んずる外国に対して恥ずべきの至りなり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "染めぬいた紺の絣に友禅の帯などを惜しげもなくしめてきりっと締まった、あの姿で手のさえるような仕事ぶり、ほんとに見ていても気が晴々する。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそうこの前の稲刈りの時にもおれが鎌で手を切ったら、おとよさんは自分のかぶっていた手ぬぐいを惜しげもなく裂いて結わいてくれた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何の苦もなくいわば余分の収入として得たるものとはいえ、万という金を惜しげもなく散じて、僕らでいうと妻子と十日の間もあい離れているのはひじょうな苦痛である独居のさびしみを、何の苦もないありさまに振舞うている。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は決して貴方に殺される覚は無い」　満枝は口惜しげに頭を掉りて、「有ります！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "予四十分ばかり見ていたが、大分腹も日も北山に傾いて来たから、名残惜しげに立ち去った。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くすること數時、見返り／＼名殘惜しげに、ひとり溪山の中をもどりゆく。",
              "citation": {
                "source": "阿武隈川水源の仙境",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "栓を抜いた香水の瓶を、居睡っている紳士のほうへ、ワクワクふるえながら差出し、差出したかと思うと、素早く瓶の口を下へ向けて、紳士の洋服へ、惜しげもなくタラタラと中身を流しつくしてしまった。",
              "citation": {
                "source": "香水紳士",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き笑いと怒りと入れ交ったような口惜しげな父の眼も烈しく彼を見込んでいた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六蔵の姉はおしげと呼び、その時十七歳、私の見るところでは、これもまた白痴と言ってよいほど哀れな女でした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその後、だんだんおしげと六蔵の様子を見ると、いかにも気の毒でたまりません。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしげはともかく、六蔵のほうは子供だけに無邪気なところがありますから、私は一倍哀れに感じ、人の力でできることならば、どうにかして少しでもその知能の働きを増してやりたいと思うようになりました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、割床の方、……澤山おしげりなさい。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
