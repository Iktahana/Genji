        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お仕事という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお仕事の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お仕事を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお仕事という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お仕事の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お仕事は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お仕事の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お仕事と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お仕事は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お仕事はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お仕事の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お仕事の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お仕事が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お仕事を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お仕事のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お仕事に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お仕事の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お仕事の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お仕事は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お仕事の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "このごろは煙草も、日に七つづつ、お仕事は、ちつともすすまないし、ゆうべは、あたし二階へ樣子見に來たら、もうぐうぐう眠つてゐた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふは、お仕事なさいね。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　　此頃お仕事をなさいませんのね。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、ジョバンニ、お仕事がひどかったらう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さんやきくよねえさんはまだいろいろお仕事があるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋は大理石像の一群に囲まれて、ロダンさんは秘書のマハセル・チレル公爵夫人と、何かお仕事をしていらっしゃいましたが、その公爵夫人が部屋からお去りになるとロダンさんは壮年のような若々しさを以て、妾の小さい肉体を、あの頑健な腕で抱えて、喜悦をお伝えになったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台から跳ねあがる音がして、黒いスカートのもとから素足のままで、フランのワイシャツに汚れたネクタイを締めながらスマ子女史は英介氏の部屋にやってきて、ストーブのまえでうずくまりながら、――お仕事できたらしいわねえ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終そんな道具立てばかりなすたつて、お仕事の方はちつとも運ばないぢやないの」「そんな事はない。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ジョバンニ、お仕事がひどかったろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人も今朝は、七時ごろに起きて、朝ごはんも早くすませて、それから直ぐにお仕事。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月は、こまかいお仕事が、たくさんあるらしい。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ入って、お仕事最中の主人に、いま聞いて来たニュウスをみんなお伝えする。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お昼少しすぎた頃、主人は、どうやら一つお仕事をまとめたようで、その原稿をお持ちになって、そそくさと外出してしまった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、ジヨバンニ、お仕事がひどかつたらう。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとにこんなに永く滞在していて、あなたのお仕事はよいのですか」と私は良人に訊きました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）鉄斎　――今日は――お仕事ですか。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄斎　――お仕事に御念が入りますな。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧なさい、あなたがお仕事が上手になると、望もかなうし、そうやってお身体も輝くのに、何が待遠くって、道ならぬ心を出すんです。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんなお仕事でしょう。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仕事のほうは、もうはじめているのですか？",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとお仕事をはじめて下さい。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お仕事ができましたか？",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことでなしに、何かお仕事でもはじめていませんか？",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、立派なおしごとをあちらへ行ってなさるでしょう。",
              "citation": {
                "source": "マリヴロンと少女",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で、あたらしく何かおしごとをおはじめになるということでした。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う向きのベンチにはおかみさんのブランシユとおしごとに来る小母さんが掛けて居る。",
              "citation": {
                "source": "午後",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが　おなべも　お皿も　カーテンも　毎日　おなじおしごとを　してゐるのが、いやになつて、お台所から　にげだすことに　しました。",
              "citation": {
                "source": "お鍋とお皿とカーテン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや／＼先生はこれからまだおしごとがあるんですって。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなかにいるときから、本を読むのがすきでありましたので、こちらへきてからも毎月のお小づかいの中から雑誌を買って、おしごとのおわったあととか、ひまのときにはとり出して、読むのをたのしみにしていたのであります。",
              "citation": {
                "source": "朝の公園",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩になって、おしごとがおわりました。",
              "citation": {
                "source": "田舎のお母さん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
