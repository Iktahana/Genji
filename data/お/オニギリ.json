        "examples": {
          "standard": [
            {
              "text": "よく泥棒を追っ払った」「さあ御ほうびにお握りを上げるよ」　とお父さんとお母さんが交わる交わるお賞めになりました。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "よく泥棒を追っ払った」「さあ御ほうびにお握りを上げるよ」　とお父さんとお母さんが交わる交わるお賞めになりました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは赤漆塗りの鉢の上に笊を置いて、桶の中から半分｜潰れた葡萄の粒を、両手に掬って、お握りを作るやうな工合にしぼりはじめました。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姉さんを、警戒する前に、奥さまは、手近な前川さんの心臓を、しっかりお握りになっているといいんだわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『濟まないが、お握りを三つほど拵へて呉れないか、海苔に包んで……』　不思議さうにこちらを見上げた妻は、やがて笑ひながら、『何處にいらつしやるの。",
              "citation": {
                "source": "樹木とその葉",
                "author": "或る日の晝餐",
                "note": "青空文庫"
              }
            },
            {
              "text": "或はおにぎりで、上野の動物園にゆくとき、いつもその前のおひるはお握りだった。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お握りを持つて行きませうか？",
              "citation": {
                "source": "滑川畔にて",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにそうなら――でもわたしには、何となく、まるで夢を見つづけているような気ばかりされて――」　と、彼女が、一そう強く、手を引きしめると、雪之丞も、緊めかえして、「夢でもござりませぬ――まぼろしでもござりませぬ――わたくしの手を、こうしてつよくつよくお握りになっておいでではござりませぬか？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯円　永蓮様が、さっき本堂で永蓮様が（新しく涙をこぼす）私の手をお握りあそばして、ゆるしてくれとおっしゃいました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しっかりといいお握りをこしらえてもたせてやる。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "潔子は御飯をたいてお握りをつくつてくれたが、邦子は炊事を知らなかつた。",
              "citation": {
                "source": "エゴイズム小論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の糞みたいな臭いものをコチトラは使うことがねえや」　大きなお握りをほおばり、女中がつくってくれた土ビンのお茶をすすりつつ、巧みに本題へ運んでいった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔全体がシワだらけで、安物の赤いノリでつつんだお握りのようであった。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "木ノ葉天狗もお握りも先祖代々この山中の住人だそうだ。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホラ穴の美女　翌朝は考古学探険隊案内のため、お握りジイサンが早朝からきて、一同の朝の目ざめを待っていた。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクが行かない方がお父さんたちもロマンチックでよろしいでしょう」　またしても一夫に裏切られてしまったが、いざ出発の用意となると、お握りのジイサンの注意が厳重をきわめるのである。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "大自然だわねえ」「よく生きていたなア」「ナアニ、なんでもねえだよ」　お握りジイサンが横から云った。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お握りジイサンはなれているから鼻唄まじりで登って行くが、あとの二人は大変である。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お握りジイサンから一パイ水をもらって、ようやく人心地がついた。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "行っていいこと」「行ってらッしゃい」　梅玉堂を暗黒の廊下に置き残し、お握りジイサンと初音サンは懐中電燈をたよりに石の彼方の広間へと消えこんだ。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふッと運命ということを考えたわよ」　お握りジイサンは先に立って降りて行った。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が茫然としているところへ、お握りジイサンがお疲れ見舞いにやってきた。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ま、ゆっくり養生しなさい」　お握りジイサンが退去すると、初音サンがふきだした。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉いてるね、お父さん」「お前、下へ行って、木ノ葉天狗かお握りサンにきいておいで。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前、こんなもの、食うか」　多茂平は谷底の岩へ腰を下して、おもむろに包みをといて、子供の頭ほどあるお握りをとりだして、あたえた。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "菓子も果物も、自由に買えぬ時代であるから、子供の間食といえば、味噌をなすったお握りを、一日に二、三回は掬ぶ。",
              "citation": {
                "source": "食べもの",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、そのとき、先生は年子の手を堅くお握りなさいました。",
              "citation": {
                "source": "青い星の国へ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中がしこたまつくつてきたお握りを皆で食べ終ると、私はおばあさんを無理に寢かしつけ、寢不足の女中も女中部屋で休ませた。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お握りでもこさへといてやらうよ。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼めしには、お握りを二つくれただけであった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は彼女の前へお握りを入れた皿と一杯の水を置いて、「バカ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
