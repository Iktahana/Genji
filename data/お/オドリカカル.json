        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あっ、四方から挑みかかる、躍りかかる、　無慙――女獣は引っ裂かれたのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すういと薙いでおいて、逃げのびようとしていた今ひとりの十五郎へ躍りかかると、「面体みせい！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は躍りかかるようにして、抱きついて行った。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその幕切れのところで劇の女主人公に躍りかかると、大向うを初めとして諸見物の大喝采を得た」「人をばかにしているじゃアありませんか？",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よオし、こいつが……」　私はたちまち躍りかかると、親蠅の咽喉を締めつけた。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、どうしたのだ」　と、大隅はイザといえば彼に躍りかかるつもりで、声をかけた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と逆上して空気に躍りかかるのであつた。",
              "citation": {
                "source": "霓博士の廃頽",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "風をきって彼めがけて躍りかかる如く見えるから自転車のシルシ半纏が恐怖のたねで、そこで彼は自動車にのって目的地へ走る、運転手に睨まれ、もじもじ恥にふるえながら目的地のアルジに車代を払って貰う、人生至るところただもう卑屈ならざるを得ない。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "散々空をうたせると、さらばと大入道、両手をひろげて、「この野郎めが」　と躍りかかる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓番のヴァンサンは、やにわにその浅ましい男に躍りかかると、たちまち組み伏せてしまい、両手を縛りあげて、その男を交番へ引ッ立てて行った。",
              "citation": {
                "source": "墓",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は風車を敵とみ悪魔とみて躍りかかるが、そして命を落すけれども、彼は敵や悪魔に自分のイノチを発見しても、それを憎んではいなかったはずだ。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大喝、おなじく捕役のひとり、土を蹴って躍りかかると、刹那に腰をおとした左膳は、「こ、こいつもかッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小癪っとばかりに躍りかかる敵兵一人二人が血煙をあげ、その数五人を数えた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしが勘定書を変えたのを、貴公が払ったのじゃ」　世界はフランボーが猛虎の如く躍りかかるのを待っているように見えた。",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはもう一匹の恐竜に躍りかかる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "“ソレヲ考エルコトハ許サレマセン”　不意に一匹のミノタロウスがしびれを切らしてアリアドネ姫に躍りかかる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、のれんを割って、「おごめん」　胡蝶屋豆八が、ひょこんと、顔を出すと、ワアッと、芸者たちが、躍りかかるように、群がって行った。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　まるで躍りかかるように殺気立って叫んだが、二人の刑事が左右からその腕をかかえた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、任原もさる者、片足でよろめき止まって、奮然とふたたび躍りかかる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新米の卒の分際で」　喚いた一人が、槍もろとも、躍りかかると、張飛は、団扇のような大きな手で、その横顔をはりつけるや否や、槍を引ッたくって、よろめく尻をしたたかに打ちのめした。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度いってみい」「何を」　呂布は、躍りかかるや否や、一刀のもとに、丁原を斬り伏せ、その首を落した。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んで来はしたが、倉地に対してのようにすぐおどりかかる事は得しないで、口もきかずに、少し恥ずかしげにそこに立ちすくんだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ降参しないかっ」　と、おどりかかる憲兵隊に、さすがのスパイたちも、あれよあれよとさわいでいるうちに、しばりあげられてしまいました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一頭の頤を蹴返すと、一頭が肩先へおどりかかる。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ッチョに寝てブラブラしている剣が突然敵の頭上へおどりかかるのだ。",
              "citation": {
                "source": "安吾武者修業",
                "author": "馬庭念流訪問記",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは――吊された綱があまり早く切られたので地上において息をふきかえし、すっくと立ち上るや、やけになって絞首役人におどりかかる。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に、佐伯がこの部屋に足をふみ入れたとたん、ものもいわずその体におどりかかる自分、絶叫する彼の胸に咲く真紅の血の花の鮮やかさがうかんでくる。",
              "citation": {
                "source": "歪んだ窓",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆もまた、そのものすごい形相から察すれば、この猛犬におどりかかるかもわかりません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
