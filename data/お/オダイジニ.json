        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「宜いのよ、其処へ出ると未だ人通りが沢山あるから」とお富は笑って、「左様なら、源ちゃんお大事に、」と去きかける。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室の戸口に立って、お大事になさい、と一こと言って、あかるく笑って、そうして直ぐに別れよう。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お大事に、と私は心の底からのお辞儀をした。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウゾ奥様をお大事に……。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお俊と頭領がどたばた荷ごしらいをするようでしたが、間もなくお俊が私の傍に参りまして、『いろいろわけがあるのだから、悪く思っちゃアいけませんよ、さようなら、お大事に』　二人は出て行きました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では、お爺さん、お大事になさいまし。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後へ廻って、肩を抱いて、「お大事になさいよ、静にお寝みなさいまし、お孝さん、ちょいとお千世さんを借りますよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、お大事になされませ、今にまたあの犬を連れた可厭しいお客がござって迷惑なら、私家へ来て、屈んで居ッさい。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりさん、さよなら」　「僕も、ひばりさん、さよなら」　「じゃ、さよなら、お大事においでなさい」　奇麗なすきとおった風がやって参りました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひばりさん、さよなら」「僕も、ひばりさん、さよなら」「じゃ、さよなら、お大事においでなさい」　奇麗なすきとおった風がやって参りました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（立上る）姉　　どうぞお大事に。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞお体をお大事に。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お大事に」　それから、三日たって、私が仕事のことよりも、金銭のことで思い悩み、うちにじっとして居れなくて、竹のステッキ持って、海へ出ようと、玄関の戸をがらがらあけたら、外に三人、浴衣着た父と母と、赤い洋服着た女の子と、絵のように美しく並んで立っていた。",
              "citation": {
                "source": "黄金風景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は当番の看護婦が、交代に二人ずつ附添うので、ただ（御気分はいかがですか、お大事になさいまし、）と、だけだけれども、心優しき生来の、自から言外の情が籠るため、病者は少なからぬ慰安を感じて、結句院長の廻診より、道子の端麗な、この姿を、待ち兼ねる者が多い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではお大事に。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経をたかぶらせないでお身お大事に勉強してほしい。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おからだお大事にねがいます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして歸つて行く時は、恰度何かの合言葉ででもあるかのやうに色々の特有の聲を以て「お大事に」と云つて行く。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしあ、氷の塊にでもならなけりやいいがと心配でなんねえだ」「折角、お大事になせえよ。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、失敬する、大事になさいよ、」「はい、どうぞ、貴君こそお大事に、」　お幸ちやんの声は震へてゐた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでいよいよお別れいたします、どうかお大事に」　趙も胸がいっぱいになって言おうと思うことが口に出なかった。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんをお大事に……」　半七はそこを出て、更に近所で訊いてみると、むさし屋に出入りする金さんは金造といって、この品川の宿をごろ付き歩いて、女郎屋の妓夫などを相手に、小博奕などを打っている男であることが判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、そちらもお大事に。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と別な助手さんが、「どうぞお大事にね、ってことを何というの？",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぼお大事になさるつて、そんなに仕舞込んでお置きなさるものぢやございません。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、お大事に……。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじさんがお帰りになったらよろしくおっしゃってくださいまし、葉子はどんな人間になり下がるかもしれませんって……あなたどうぞおからだをお大事に。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さようなら」「お大事に」　はばかるように車の内外から声がかわされた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お大事にお過ごし遊ばしませ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おだいじにお暮らしなさい。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
