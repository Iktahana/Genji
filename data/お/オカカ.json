        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "保養をなすって、それから為事におかかりなさるが好いわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はお為事におかかりなさいますかと思いましたので。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この御祈祷におかかり下さる前に、わたくしの御奉納物を一度おあらためを願いたいと存じますが……」「なんと云わるる」と、式部は少し眉をよせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も言おう、この時言おう、口へ出そうと思っても、朝、目を覚せば俺より前に、台所でおかかを掻く音、夜寝る時は俺よりあとに、あかりの下で針仕事。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまいには利助さんは、もうこんな話はいやだというように、「おかか、めしのしたくしろよ。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのおかかえ作家、太宰治へ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にひどい恥をおかかせになった。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは香坂、忍熊の二皇子は、それをお聞きになりますと、案のとおり、ご自分たちがあとを取ろうとおかかりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがお兄上の大山守命は、天皇のおおせ残しにそむいて、若郎子を殺して自分で天下を取ろうとおかかりになり、ひそかに兵をお集めになりだしました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が伯父様と伯母様の計略におかかりになったのです」「計略に僕が……」「そうです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここだけの話ですが、わしのささやかな所持金はあの箱のなかで、だからおかかりでしょう、見知らぬ人間が部屋に押し込むというのが、わしにとっていかなる意味なのか。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうに、皇帝の御苑は、なにからなにまでじょうずにくふうがこらしてあって、それに、はてしなくひろいので、おかかえの庭作でも、いったいどこがさかいなのか、よくはわからないくらいでした。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、王さまはいって、ヨハンネスに手をおだしになるために、珠を小わきにおかかえになりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それとも、宮中おかかえのからすとして、台所のおあまりは、なんでもたべることができるし、そういうふうにして、いつまでもごてんにいたいとおもうかい。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしなおかかる者をして囚徒を取り締らしめんには、囚徒は常に軽蔑を以て取締りを迎え、表に謹慎を表して陰に舌を吐かんとす、これをしも、改化遷善を勧諭する良法となすべきやは。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おにらみになる父帝の目と視線をお合わせになったためでか、帝は眼病におかかりになって重くお煩いになることになった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての秘密を握っている依田重三郎は、ともかくも加賀百万石おかかえの弓道師範役なのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万石おかかえ、依田流の弓術があきれるよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、切り取り強盗のこやつと一味のやつらもそれ相当手ごわい連中ばかりでしょうから、そこのところを抜かりなくじょうずにひと知恵絞ってね、ひと網にお捕りのときもずんと腹をすえておかかりなせえましよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちの方々ッ」「………」「おかかりなされッ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はなおかかる問題について考えて見たことはないが、一例をいえば、俳句という如きものは、とても外国語には訳のできないものではないかと思う。",
              "citation": {
                "source": "国語の自在性",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯今も申した通りですから、あなた方は決して蝶々の一件におかかわり合いなさるな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "淫らな絵画は到る所に今もなおかかっている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおむずかり遊ばしましたが、六年前の二月ごろその時はやった痘という病気におかかりなされついにお失せなされました。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水芸なんかほんまに不思議じゃけえ」　そこへ伯母が出て来て、「おかかんと行ったの？",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかかんにね、今度のおさらいはお師匠さんが他行ゆえ延ばしますって」「はい。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかかせなさってと云うことなのである。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれにも知らせないことだからそのつもりにしておくのですよ」　と、お言いになって、院は外出の化粧におかかりになったが、ただ事とは思われなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮は旅なれぬお身体であったから疲労をお覚えになったし、この土地にしばらく休養していたいという思召しも十分にあって、横たわっておいでになったが、夕方になって楽器をお出させになり、音楽の遊びにおかかりになった。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
