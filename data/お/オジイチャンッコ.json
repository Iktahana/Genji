    "definitions": [
      {
        "index": 1,
        "gloss": "child who is very close to their grandfather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "おじいちゃんっ子という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はおじいちゃんっ子の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではおじいちゃんっ子という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、おじいちゃんっ子は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、おじいちゃんっ子の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、おじいちゃんっ子は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、おじいちゃんっ子はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、おじいちゃんっ子の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、おじいちゃんっ子が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、おじいちゃんっ子のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、おじいちゃんっ子に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、おじいちゃんっ子の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "おじいちゃんっ子は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、おじいちゃんっ子の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
