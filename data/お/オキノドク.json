        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「そりゃお気の毒なことでございました。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生真面目な顔をしたカリタが彼にむかって、「お気の毒に存じます。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「晩く来てお気の毒様ねエ」と少女は少しもじもじして居る。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんまりお気の毒さまで……」　お秀は眼に涙一杯含ませて首を垂れた。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お気の毒さま、これ丈け下さいな、」とお富は白銅｜一個を娘に渡すと、娘は麺包を古新聞に包んで戸の間から出した。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあお気の毒さまねエ、明朝のお目覚にやりましょう。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、もう少し深入りして訊きてえことがあるんだが、師匠はどうせここへはいるつもりなんだろうから、おれ達も附き合ってもう一度引っ返そうじゃあねえか」「でも、それじゃあんまりお気の毒ですから」「なに、構わねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの空襲で豊田さんも全焼し、それに土蔵まで焼け落ちたようで、お気の毒です。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑うのにも力が無く、むりに笑おうとなさるので、頬に苦しい固い皺が畳まれて、お気の毒というよりは、何だかいやしい感じさえ致しました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って暫くすると、早大の佐藤さんが、こんど卒業と同時に入営と決定したそうで、その挨拶においでになったが、生憎、主人がいないのでお気の毒だった。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、久し振りで今さんも、ステッキを振りながらおいで下さったが、主人が不在なので、じつにお気の毒に思った。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこへ、いろいろ注文が多くてうるさかったでしょう、お気の毒でしたなんて、間抜けたことを書いたもんだ。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると給仕はてかてかの髪を一寸撫でて、「はい、誠にお気の毒でございますが、当地方には、毒蛾がひどく発生して居りまして、夕刻からは窓をあけられませんのでございます。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒ですが一万年は持ちません。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「苦しいでせう、これはほんたうにお気の毒なことになりました。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、うむ、そのクォーツさんもお気の毒ですがクウシャウ中の瓦斯が病因です。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「苦しいでしょう、これはほんとうにお気の毒なことになりました。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うむ、うむ、そのクォーツさんもお気の毒ですがクウショウ中の瓦斯が病因です。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒でしたわね」「…………」　維倉青年はギリギリと歯を噛んで、眼の前の訪問着を見上げた。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大風呂敷が何を包んだものか、何処の穴から出て来たものかがわからぬうちは、お気の毒ながらお役目柄がお先まっくらじゃろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎度お気の毒だと思うんだけれど、ツイね私の方も請取る金が都合よく請取れなかったりするものだから、此方も困るだろうとは知りつつ、何処へも言って行く処がないし、ツイね」と言って莞爾。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気の毒でしたね、色々御心配をかけて。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は渡瀬さんが何んだかお気の毒だ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その失敗者が同じ失敗者のあなたをお迎えに来るなんて妙なわけですが、おかあさまがお気の毒なので、お頼みをそのまま引受けてお迎えに参りました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――お気の毒な事になりました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とんだお附き合いで、どうもおきのどく様でございます」　美人は軽く会釈するとともに、その手は帯の間に入りぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧早く遣ってくんな」　奴は途方に暮れて、曩より車の前後に出没したりしが、「どうもおきのどく様です」「おきのどく様は知れてらあ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、会社のほうでは穏便がいいというので、むろん片手落ちの裁判だけれど、私が因果を含められて、雇を解かれたのさ」　白糸は身に沁む夜風にわれとわが身を抱きて、「まあ、おきのどくだったねえ」　渠は慰むる語なきがごとき面色なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "馭者は冷笑いて、「なあに、高が馬方だ」「けれどもさ、まことにおきのどくなことをしたねえ、いわば私のためだもの」　美人は愁然として腕を拱きぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきのどくな老王さま。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
