        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲は東から西へと引いたように取れると一天は石灰洞のような大口を開けて、見る見るうちに次第にひろがり、碧い初冬の冴え返った空が、冷たい鯖色をした湖水のようになって、金光ちらりと黒砂に燃え落ちる、黒砂の一線、天に向って走るところ、頂上火口の赭禿げた土は、火を翳したように眩ゆくなる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "親仁は大口を開いて、（留守におらがこの亭主を盗むぞよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてさて迷惑な、こりゃ目の前で黄色蛇の旨煮か、腹籠の猿の蒸焼か、災難が軽うても、赤蛙の干物を大口にしゃぶるであろうと、そっと見ていると、片手に椀を持ちながら掴出したのは老沢庵。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白く酔い痴れた顔が大口を開いて笑っていた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と竹内は大口を開けて笑った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどかの君は大口開きて笑いたまい、宝丹飲むがさまでつらきかと宣いつつわれらを見てまた大口に笑いたもう。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "店も何も無いのが、額を仰向けにして、大口を開いて喋る……この学生風な五ツ紋は商人ではなかった。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真黒ケの大の男五、六人、四、五丈高き断崖の中腹に鶴嘴を持ってゲラゲラ大口開いて笑っている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "慓輕なる武村兵曹は大口開いてカラ／＼と笑ひ『ヤイ、ヤイ、畜類、其樣に吾等の肉が美味相に見えるのか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある先生はショボショボ降る雨でも飲んでくれようと考えたものか、空を仰いで大口開けて突立っているが、雨はなかなか旨く口中へ降り込んではくれぬ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と大口を開けて笑った。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳に受けて歩行かっしゃるで、機織場の姉やが許へ、夜さり、畦道を通う時の高声の唄のような、真似もならぬ大口利いて、果は増長この上なし、袖を引いて、手を廻して、背後から抱きつきおる。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯨を見ろ、しこ鰯だ、なぞと大口を利いて元気でしたが、やがて酒はお積りになる、夜が更けたんです。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああよく通ったね」「また壅ったときは、いつでも持ってお出でなさい」　大口｜開いて馭者は心快げに笑えり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "団十郎の大口屋暁雨、大好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここぞと思ふやうなところになると、和尚さんは、台を手でぱんぱんと叩き、二つの目をかにのやうにむき出して、台のすぐ下にゐる老人達を喰ひつかんばかりに大口でしやべりました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小径の途中の土の層から大溝の浸み水が洩れ出て、音もなく平に、プールの葭簾を撫で落し、金網を大口にぱくりと開けてしまっている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と酒井は笑みを含んだが、この際、天窓から塩で食うと、大口を開けられたように感じたそうで、襖の蔭で慄然と萎んで壁の暗さに消えて行く。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何だい、）と聞かれたので、法学士が大口開いて（掏摸だよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩を聳て、前脚をスクと立てて、耳が其の圓天井へ屆くかとして、嚇と大口を開けて、まがみは遠く黒板に呼吸を吐いた――　黒板は一面眞白な雪に變りました。",
              "citation": {
                "source": "雪靈續記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女童等、走り近く時、面を差寄せ、大口｜開く。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恍惚した小児の顔を見ると、過日の四季の花染の袷を、ひたりと目の前へ投げて寄越して、大口を開いて笑った。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高須隆哉が楽屋を訪れたときには、ちょうど一幕目がおわって、さちよは、楽屋で大勢のひとに取り巻かれて坐って、大口あいて笑っていた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "高須隆哉が楽屋を訪れたときには、ちやうど一幕目がをはつて、さちよは、楽屋で大勢のひとに取り巻かれて坐つて、大口あいて笑つてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとね、くいほじった柿の核を、ぴょいぴょいと桟敷中へ吐散らして、あはは、あはは、と面相の崩れるばかり、大口を開いて笑ったっけ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩を聳て、前脚をスクと立てて、耳がその円天井へ届くかとして、嚇と大口を開けて、まがみは遠く黒板に呼吸を吐いた――　黒板は一面｜真白な雪に変りました。",
              "citation": {
                "source": "雪霊続記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
