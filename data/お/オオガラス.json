      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "The Raven (narrative poem by Edgar Allan Poe)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども、天の大烏の星や蠍の星や兎の星ならもちろんすぐ行けます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あ、大烏の星だ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう空のすすきをざわざわと分けて大烏が向うから肩をふって、のっしのっしと大股にやって参りました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏は二人を見て立ちどまって丁寧にお辞儀しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら大烏は泉に頭をつき込みました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏は息もつかずに三分ばかり咽喉を鳴らして呑んでからやっと顔をあげて一寸眼をパチパチ云わせてそれからブルルッと頭をふって水を払いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏は見る見る顔色を変えて身体を烈しくふるわせました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで大烏が怒って云いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　チュンセ童子が「大烏さん。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏はもう怒ってぶるぶる顫えて今にも飛びかかりそうです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠍は大烏を尻眼にかけてもう泉のふち迄這って来て云いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間も、いかにも大烏を馬鹿にする様に、毒の鉤のついた尾をそちらにパタパタ動かすのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう大烏は、我慢し兼ねて羽をパッと開いて叫びました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大烏はかっとして思わず飛びあがって叫びました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏は飛びあがってそれを避け今度はくちばしを槍のようにしてまっすぐに蠍の頭をめがけて落ちて来ました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠍は頭に深い傷を受け、大烏は胸を毒の鉤でさされて、両方ともウンとうなったまま重なり合って気絶してしまいました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏には毒がはいったのだ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大烏をしっかり押えていて下さいませんか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ポウセ童子も沓をはいてしまっていそいで大烏のうしろにまわってしっかり押えました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュンセ童子が大烏の胸の傷口に口をあてました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると大烏がやっと気がついて、うすく目を開いて申しました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大烏はよろよろ立ちあがって蠍を見て又｜身体をふるわせて云いました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は大烏を急いで流れへ連れて行きました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大烏はすっかり悄気て翼を力なく垂れ、何遍もお辞儀をして「ありがとうございます。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大烏めは死にましたか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは、大烏賊の主だ。",
              "citation": {
                "source": "小田原の夏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "霰や雪をもよおす雲は空に低くかかり、大烏は羊歯の上に立って、「カオカオ。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、かなりの重傷で、とても助からぬと見て竹青は、一声悲しく高く鳴いて数百羽の仲間の烏を集め、羽ばたきの音も物凄く一斉に飛び立ってかの舟を襲い、羽で湖面を煽って大浪を起し忽ち舟を顛覆させて見事に報讐し、大烏群は全湖面を震撼させるほどの騒然たる凱歌を挙げた。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『エンサイクロペジア・ブリタンニカ』十一版二十四巻にかかる大海蛇譚の原因は海豚や海鳥や鮫や海狗や海藻が長く続いて順次起伏して浮き游ぐを見誤ったか、また大きな細長い魚や大烏賊を誤り観たか、過去世に盛えた大爬虫プレシオサウルスの残党が今も遠洋に潜み居るだろうと論じ居る。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念なことにはその烏は一本足ではなかったけれど、しかし立派な大烏で、少年の空想を充たせるには、充分の値打ちを持っていた。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
