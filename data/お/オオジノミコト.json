        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "既にして太祖崩じて太孫の位に即きたもうや、刑官に諭したまわく、大明律は皇祖の親しく定めさせたまえるところにして、朕に命じて細閲せしめたまえり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "朕が前に改定せるところは、皇祖｜已に命じて施行せしめたまえり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶を皇祖かく積みましき、正しきを年のむた養ひましぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "）天照らす大御神、皇祖、皇祖かくぞ、　（讚へまつれ、いざや。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇祖皇宗はこの徳に坐し、神ながら道に蒼古に、あやに畏き高千穗の聖火は今に燃え繼いで盡くるを知らぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌に曰く、　大陸軍の歌　　　１青雲の上に古く、仰げ皇祖、天皇の大陸軍、道あり、統べて一なり、建国の理想ここに、万世、堂々の歩武を進む、精鋭、我等、我等奮へり。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "神武天皇の御世には、その皇化は九州一円に及んで、皇祖の神勅のまに／＼大八洲を経営すべき自信と力とを獲得されたのであらう。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも如何に思わるるは、皇祖神武天皇を古く奉祀せる渡御前の社をも合祀し、その跡地なる名高き滝を神官の私宅に取り込み、藪中の筍を売り、その収入を私すと聞く。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわんや、山神も海神もいずれもわが皇祖の御一族たるにおいてをや。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "神祇は、皇祖皇宗およびその連枝また末裔、もしくは一国に功勲ありし人より下りて一地方一村落に由緒功労ありし人々なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的能力は白人種の最優秀者に優るとも劣らないのみならず、皇祖皇宗によって簡明に力強く宣明せられた建国の大理想は、民族不動の信仰として、われらの血に流れている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇祖皇宗のこの大予言は実にわれらが安心の根底である。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天津教は現に磯原に住する竹内氏が守るところの皇祖皇太神宮を中心として宣傳せられる思想の系統である。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その主張を聞けば、武内宿禰の子孫は後ち竹内と稱し連綿千九百年、皇祖皇太神宮を奉戴して以つて今日に及び、其間あらゆる困難と迫害とを經て、尚ほよく神代より傳はつた皇室關係の古文書及び古器物を守護保存してゐると云ふのである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理に關し、越中國皇祖皇太神宮の所在が問題とすべきであるが、之を決定するには意外の困難が豫想せられるので、暫く天津教の言分を立てる。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち人物の實在性に關しては多大の疑團が存ずるのであるが、其一人を證明するにも否定するにも、丁度皇祖皇太神宮所在地の場合と同じ樣な困難を感ずるのであるから、無駄な努力を止めて、次ぎの事項に移る。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "出來上つたものは棟梁皇祖皇太神宮の神代文字卷を形假名及び唐文字を以て寫す寶卷、皇祖皇太神宮大祕藏の卷、萬國の棟梁天皇寶の卷の三種で、之を今上天皇に上げ奉ると云ふのである。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰はく皇祖天照大御神が女性の御身を以て、高天ヶ原に君臨せさせ給ふ事是なり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡て神話傳説は國民の理想を述べたるものにて、當時の社會の精神風俗等は、悉く其の中に包含せらるるものなるが故に、皇祖發祥の地たる九州に於いて、上古卑彌呼をはじめとし女子を以て君長たりしもの其數を知らずとせば、大御神が女神として、天上に照臨し給ふも、亦何の怪むべきことかこれあらんや。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新嘗・大嘗を通じて、皇祖神との関係を主として説く従来の説は、どうも私の腑に落ちぬ。",
              "citation": {
                "source": "稲むらの蔭にて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇祖とか祖宗とか書いてあります神の中には、この高皇産霊神・神皇産霊神たちを申してゐる例も多いのです。",
              "citation": {
                "source": "神道の新しい方向",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "国栖・隼人の大嘗会に与り申すのも、遠皇祖の種族展覧の興を催させ奉る為ではなかつた。",
              "citation": {
                "source": "妣が国へ・常世へ",
                "author": "異郷意識の起伏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝした長い自分の家が、天子の為に忠勤を抽づるに到つた昔の歴史を述べた寿詞を唱へ、其文章通り、先祖のした通り自分も、皇祖のお受けになつたまゝを、今上に奉仕する事を誓ふのである。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして其続きに、そのかみ、皇祖の為に奏上した健康の祝辞を連ね唱へて、陛下の御身の中の生き御霊に聞かせるのであつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
