        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あなたは、それじゃ、」温泉芸者は、更に興を覚えぬ様子で、「Ｔさんのお坊ちゃんなの？",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような問題が出ても、フロオベエルはお坊ちゃんである、と書くつもりでいた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――フロオベエルはお坊ちゃんである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボオドレエルこそは、お坊ちゃん。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタお一人のお坊ちゃんが、牛乳ばっかりで育てておいでになったのが、四、五日前に急にお亡くなりになった。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には平常向い合って話していると、あの風采がソックリそのまま、実にタヨリない、涙ぐましい位のお坊ちゃんに見えて来る。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなお坊ちゃんをいじめるのは貴様可哀そうじゃねえか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃいまし、……唯今お坊ちゃんがお見えになりましたよ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにお坊ちゃんは、水菓子がお好きでいらっしゃいます事！",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあれは、失礼ですが、もっとおっとりしたお坊ちゃんのようでしたけれど。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう記憶も薄れている程なのですが、おひとりは、何でも、帝大の法科を出たばかりの、お坊ちゃんで外交官志望とやら聞きました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、あの人たちは僕を避けて、かげでこそこそ僕を批判し、こまったものさ、お坊ちゃんには、等と溜息をついて上品ぶっていやがるのだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、お坊ちゃんなのかも知れない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の登記所のお坊ちゃんなのである。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころのこと、戸籍調べの四十に近い、痩せて小柄のお巡りが玄関で、帳簿の私の名前と、それから無精髯のばし放題の私の顔とを、つくづく見比べ、おや、あなたは……のお坊ちゃんじゃございませんか？",
              "citation": {
                "source": "黄金風景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三歳といえば尋常中学へ入るか入らぬかの齢だが、沸り立っている世の中の児童だ、三太郎甚六等の御機嫌取りの少年雑誌や、アメリカの牛飼馬飼めらの下らない喧嘩の活動写真を看ながら、アメチョコを嘗めて育つお坊ちゃんとは訳が違う。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢さん、お坊ちゃんたち、一家揃って、いい心持になって、ふっくりと、蒲団に団欒を試みるのだから堪らない。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　もともと気の小さい、懐育ちのお坊ちゃんなんだから、遊蕩も駄々で可かったんだけれど、それだけにまた自棄になっちゃ乱暴さが堪らないんだもの。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見画伯のお坊ちゃんが、こんな工合いじゃ、いたましくて仕様が無い。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の言に依れば、風間は、お金持のお坊ちゃんで秀才で、人格の高潔な人だという。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちが、どんなにみじめな、くるしい生活をしているのか、このお坊ちゃんには、なんにもわかっていないのだ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれもかれも、みんな、お坊ちゃんよ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、あなたは都会の人で、そうして少し不良のお坊ちゃんの面影をどこかに持って居られました。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は、お坊ちゃん育ちだな。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなお坊ちゃんくずれは、……」「あの」　私は微笑んで口をはさんだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆一本握る事もせずに朝から晩まで葉子に膠着し、感傷的なくせに恐ろしくわがままで、今日今日の生活にさえ事欠きながら、万事を葉子の肩になげかけてそれが当然な事でもあるような鈍感なお坊ちゃんじみた生活のしかたが葉子の鋭い神経をいらいらさせ出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな馬鹿なお坊ちゃんなんかに。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中のことは、お坊ちゃんの理想｜通に行くものではありません。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば男女の学生、華族や富豪のお坊ちゃん嬢ちゃんなぞがあらわす不良性は、大部分この方に属すると見ていい。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあまりに世間見ずのわがままなおぼっちゃんの象であった。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
