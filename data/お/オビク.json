        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "此は岩戸神楽と同様、髯籠だけでは不安心だといふので、神を誘く為に柱を廻つて踊つて見せるので、諾冉二尊の天の御柱を廻られた話も、或は茲に意味があるのであらう。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然は友を誘くものであつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然は友を誘くものであった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三枝のお嬢さんお綾さんには母者人のおびくさんが附いて見えられる。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧来の思慕の情調を湛へた日本の文章・詞章の、国人の心をおびく美しさも、之にかゝつてゐることが多いと信じてゐる。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ己をおびくように、避けるように、狡猾に騙すように、女の群が空を踏んで踊っている。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "メフィストフェレスいらなくても、詩人が出て来て、あなたの栄華を後世に伝えて、馬鹿話で10190馬鹿の真似をさせるように、人をおびくでしょう。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、橋上の趙雲は、なおびくとも動かないので、徐晃も張※もいよいよ気味悪く思ったか、急にまた、途中から駒を返そうとした。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
