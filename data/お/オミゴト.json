        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「へい、いいえ、お顔は存じておりますほどでもござりませんが、その上被の召ものでござります、お見事な、」　こう云ったのは羆の筒袖。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女　お見事や、お見事やの。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸と一どんぶり、それでも我慢に平げて、「うれしい、お見事。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は、だまつて犬をひいて来て、主人の矢の先で、首から縄を放すのでしたが、主人の矢が、みごとに犬の急所をつらぬいても、ほかのしもべどものやうに、「お見事なうでまへでございます。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや将軍家も御年二十一、次第に、荘厳と申してよいほどの陰影の深い尊さがその御言動にあらはれるやうになつて居りまして、同じ月の二十八日にも、実にお見事なる御裁決をなさいました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧都　一段とお見事じゃ。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、叫んだ時には、もう出る幕は念仏しか残っていず、ぷりぷりと楓に当ったが、楓は耳にはいらず、いそいそと佐助の傍にかけ寄って、「お見事でござりました」　佐助は月を仰いでいた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お見事、僕も奴らを捕まえました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「見事だ、ワトソン、お見事！",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この熨斗、この水引、余りお見事に遊ばした。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気おのずから、脳天を圧して、いよいよ頭を下げ、「は、当｜御館におかせられましては、このお庭の紅葉を、諸人に拝見の儀お許しとな、かねがね承ったでありまするで、戸外から拝見いたしましてさえ余りのお見事。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……いやどうも、花瓶も見事でございますが、どっちが綺麗かと思うほど、扇もお見事でございましたがな。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太股をつかれた柄本又七郎が台所に伏していると、高見の手のものが見て、「手をお負いなされたな、お見事じゃ、早うお引きなされい」と言って、奥へ通り抜けた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、余りお見事ぢや御座いませんか」「見事でも可かんのかい」「いいえ、お見事は結構なのですけれど、余り又――頂戴……ああ恐入ります」「いや、考へて見ると、人間と云ふものは不思議な者だ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いちだんとお見事でござりまするな。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お見事でござります」　感に堪えたように目を涼しくしたのは菊路です。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ、ありゃたしかに金城寺の旦那さまの筈だが、――お見事だなあ」　寄り集っていた群集の中から、年老いた鳶の者らしい顔が出て来ると、感に堪えたように言った。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、奥様のお宅の蕎麦の出来栄は大層お見事でございますこと――こちらへ上ります道すがら拝見いたして参りましたよ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生のお払いのお見事な事は皆、不思議だ不思議だって大評判で御座いますよ」「ううむ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見事」と敵の声がした。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、俺には却って幸い、どれこの隙に腹を切ろう」　左の脇腹へブッツリと、伊賀之助刀を突き立てた時、「お見事！",
              "citation": {
                "source": "首頂戴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キュッと飲んで置こうとするところを、「お見事。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お見事」と又も女の声がし、すぐに続いて問いかけた。",
              "citation": {
                "source": "弓道中祖伝",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはお見事、これはお美しい」　と、民弥は思わず声をあげた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ははあ、お見事なものでございますな」　その絵図面は、駒井甚三郎が自ら引いた西洋型の船の絵図面であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて皇后様の御父君であらせられる久邇宮邦彦王殿下に、用人某が殿下の数々の御墨蹟中、とりわけ法隆寺に御下賜のものがお出来栄え、一段にお見事であらせられる旨言上すると、殿下は言下に、「書はその時々で色々である」と明白に仰せられた。",
              "citation": {
                "source": "魅力と親しみと美に優れた良寛の書",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は軽くうけて、「たいそうおみごとでございました」「いや、おみごとばかりじゃあない、おまえはあれを見てなんと思った」　女は老人の顔を見たり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたら堂脇が案外やさしい声で、「失礼ながらどちらでご勉強です、たいそうおみごとだが」と切り出した。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれがなんと申しましょうと、必ずともに敬之丞どのと添いとげさせてしんぜまするぞ」「いや、おみごと！",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝の御字は輝くばかりおみごとで、目もくらむかと思いなしも添って思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
