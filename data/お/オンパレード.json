          "literary": [
            {
              "text": "夜は中洲の川丈座へゆく、万歳オンパレードである、何といふバカらしさ、何といふホガらしさ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村歌右衛門の葬儀、わりに人が少くて淋しい、入口から棺前迄列もなく一人だ、恥かしい、両側は名優オンパレードらしいが、見ずに一直線。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四に据へたオンパレード物の寸劇に一つと、「西遊記」の三蔵と二つ役をとる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二日（火曜）　昨夜家へ帰ってみると、島村・穂積・川村・堀井・水町・松村・一木・林・多和・友田といふオンパレード。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしまひは、「僕の演芸会」と言って、歌オンパレード。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他「海の一日」といふ夏向きオンパレード物や子供物のプランを沢山出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "樋口を呼んで十一日の躍進東宝オンパレードの打合せ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "上山の作オンパレード物。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宝オンパレードの正月短篇のため大久保の扮装で一カット撮り、終ると三度目の彦根行き、車中宇野浩二の「一途の道」を読み出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は屋井が新派連を呼んだので喜多村御大以下来てる、島田正吾、ひょっくり現はれる、スターオンパレードだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに「百万弗大放送」といふパラマウントのオンパレード物を試写。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
