        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "クラシックはテンポが遅いどころか、「ああした深いことをもう云つてのけたのか」と、君が若しミュジックなるものの存在に耳を触れるに相応しければ当然感ずる次第なのであつたかも知れない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが、その限界に達すること遅ければ遅いだけ、芸術家は豊富である。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母の来るのはいやに遅いが、どうせ近所へのお暇乞ひがまた長いのであらう。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が結婚致しましたのは、松江に来てからのことで、二十四の秋でございますから、当時としてはずいぶん遅い結婚でございました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白さが限界に達すること遅ければ遅いだけ芸術家は豊富である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもすがら音なき雨や種俵うぐひすや家内｜揃ふて飯時分　春の日の遅い朝飯。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も春といつても、山の春は遅いから、伊香保で春といへば五月か六月であらう。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中で夜までも忙がしいので父の帰りは遅いことがしばしばあった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅いぞ、あしたイサドへ連れて行かんぞ。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の級数は収斂の仕方の遅いものである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚図々々して親爺が帰って来ると、又叱言の一つもきかなくちゃならねえからな」　「兄さん、此頃毎晩遅いのね」　「今夜も亦、遅くなるから戸じまりはしねえで置いてくれ」Ｓ＝茶店の表　石松、出て来て、　「あッ、帰って来た。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「石松の奴が今に帰るかと思って……」　「そうかい……妾もね、あんな親不孝な伜だけれど、今夜の様に何時までも帰りが遅いと、つい心配になってね」　「おばさん、まあお這入ンなさいよ」　「有難う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父っつあんは何故ッ、何故お貸元をッ」　「五月蝿えッ」　親子の睨み合い――　「石松、今夜はもう遅いから寝ろ」　「父っつあん、一と言云っとくが……お前が何んと云ったって、俺ァ清水のお貸元の身内になるんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝桟敷　五郎蔵親分「遅いな半次は？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎と武蔵が、おしまが遅いので戻って来た。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、しまったと思ったが遅い。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）はい、はい、もう大分遅いからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう遅いでせうか。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと平岡さんに頼まれて来た用があるのよ、此処でも話せますよ、もう遅いもの、上ると長座なるから。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみそっと小柄を隠して、Ｔ「遅いよ色男」　「えっ」　と驚く太郎左衛門。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「兎も角遅いなァ」　言って居る時女中が、Ｔ「只今江戸から飛脚が」　二人飛び起きた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど彼らは逃げ足が遅い。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げ足が遅いだけならまだしも、わずかな紙の重みの下で、あたかも梁に押えられたように、仰向けになったりして藻掻かなければならないのだった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と勇んで友人達に号令し、みな道端に寄って並び立ち、速力の遅いバスを待って居ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかりが消えてからぢゃ遅いや。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　箱根細工の店では大友が種々の談話の末、やっとお正の事に及んで「それじゃア此二月に嫁入したのだね、随分遅い方だね。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそいぞ」馬場は怒っているような口調で言った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、おそい朝ごはんを、気まずい思いで食べた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまさら、そんな事を言つたつて、もうおそいわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅愁は人生の旅にもおそいかかってくる。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
