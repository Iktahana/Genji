    "definitions": [
      {
        "index": 1,
        "gloss": "carrying (someone) on one's back (esp. a child)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「誰れが争議なんかおっぱじめやがったんかな。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから戦争をおっぱじめて、こんなみじめなことになってしまったんだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、おっぱいやろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、暑さと、それから心配のために、食べものが喉をとおらぬ思いで、頬の骨が目立って来て、赤ん坊にあげるおっぱいの出もほそくなり、夫も、食がちっともすすまぬ様子で、眼が落ちくぼんで、ぎらぎらおそろしく光って、或る時、ふふんとご自分をあざけり笑うような笑い方をして、「いっそ発狂しちゃったら、気が楽だ。",
              "citation": {
                "source": "おさん",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、一歳の次女におっぱいを含ませながら、そうして、お父さんと長女と長男のお給仕をするやら、子供たちのこぼしたものを拭くやら、拾うやら、鼻をかんでやるやら、八面六臂のすさまじい働きをして、「お父さんは、お鼻に一ばん汗をおかきになるようね。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか赤坊の時から、紫式部や、おっぱい御上り、清少納言や、おしっこをなさい、ワンワン来い来い、などと云われたので無かろうことは分っているが、仙人の女王、西王母の、姓は侯、名は婉泥滞水の挨拶を以て其場を済ませて置くというようなことも仕無かったろうから、次第次第に夫婦の間は険悪になっていったであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母様のおっぱいが飲みたくはないの」　女は小声で笑った。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はもうあの娘さんを、あの悪漢に渡すことが出来なくなってしまった」「えい、私は金輪際、渡すことが出来ませんでした」「そこで君たちの中には喧嘩がおっぱじまってしまった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「のの様、おっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……のの様、おっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、欲くないの、坊、のんだの、のの様のおっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お雛様のような、のの様のおっぱい。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角が、方角が違ったぞ、と慌てる処へ、おっぱいが飲みたい、とあびせたのがあります。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯛もしおっぱい海の水を出て、じかに空気に触れるので、よく風邪でも引いて充血したように、真っ赤な眼をしているのがよくある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、あのおっぱいは下を向いてるだろうけどな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後生ですから、そこから鋏をもってきて頂戴な、ね」こんどはだまっていましたが、いそいでそこにあった人形を抱きあげて、「あたし、いま、人形におっぱいあげていますの……」と言いました。",
              "citation": {
                "source": "人形物語",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "小娘の癖におっぱいがぶらぶらしてゐる。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅で苦々しげに「いつだって騒動おっぱじめる原因は女の子だ！",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃き火のまわりで、子供におっぱいをやっているひともあったりして、そのきっちりと手拭でくくられた頭の上に大きい水中眼鏡がのっている。",
              "citation": {
                "source": "漁村の婦人の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又おっぱじまったのかナ。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこへ、酔ったボルティーコフがよろけこんで騒動をおっぱじめたのであった。",
              "citation": {
                "source": "「インガ」",
                "author": "――ソヴェト文学に現れた婦人の生活――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時頃に一度お乳を遣った丈だったので、空おっぱいをあずけたまま、先ぐお乳を作りに配膳室へ出て行った。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅かな涙金でおっぱらわれ、散々になって去って行く仲間を見て見ぬ振りをしている有様だった。",
              "citation": {
                "source": "組合旗を折る",
                "author": "永崎貢",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はまことに涼やかで、私のおっぱいが一貫目もあるほど重い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は啓坊は私のところで泊るし、その前の晩は、神田の尺八を吹く人の家に世話になったりして、寛子姉さんとこだって、二晩もあずかってさ、夫婦喧嘩までおっぱじめたりしたのよ……そんな邪魔な子だったら孤児院にでもやったらいいでしょう！",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "討論がおっぱじまる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――えーふー、あにおっぱじめた……。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくりして眼をさますと、大きなねずみが何匹も何匹も顔をなめている、かれがおっぱらうと、一匹が鼻の頭をかじって逃げたんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汐汲み」を踊って、楽屋で乳母やのおっぱいを飲んだことを朧気に覚えています。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
