    "definitions": [
      {
        "index": 1,
        "gloss": "delivery (of a package, goods, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "番太郎に云い付けて早速お届けはして置きましたが、まだ御検視が下りないので、うっかり手を着けることもできません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのことは取りあえず自身番の方へもお届け申して置きましたが、けさも長五郎親分が見えましたから詳しく申し上げました」「そりゃあ案外な事になったね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまお届けしようと思ってゐましたが手があきませんでね。",
              "citation": {
                "source": "車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉が一つ割れておりましたので……お届けしようと存じておりましたところで……」　と言ううちに大きなマホガニーの箱をだした。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お届けをしようか、受取りにおいで下さるか、という両国辺の運送問屋から来たのでした。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手廻りのものや、何やかや、いずれ明日お届け申します。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "針一本と、白い木綿糸をたくさんに、黄、青、赤の糸を少しづつお届け下さい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "早々とお届け下さい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生御夫妻が可愛がって下さった頃の麗姫のかたみだと申し添えてお届けして欲しいと申して………」　遜は土間の隅に大きな包みを抱え、うずくまって居る従者を顧み幾重にもからめた包装を解かせた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一家はほとんど着のみ着のままで目白の方面へ避難したのであるが、なんでも九月なかばの雨の日に、ひとりの女がその避難先へたずねて来て、震災の当夜、お宅の門前にこんな物が落ちていましたからお届け申しますと言って、かの兜を置いて帰った。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度の奉公先は一時の腰掛けでございますから、いずれ本当におちつき次第、あらためてお届けにあがります。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから入院料の方は、自宅へ帰りましてから早速、お届けする事に致したいと思いますが……。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日にでも、東京の事務所の方へ電話をして、お宅の方へお届けしましょう。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、お姉さんが留守だったら、劇場の方へお届けするよう、云い添えました。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはどなたです」「わたし、慶よ、さっき、肩輿の中から釵を落したのよ、あなた、あれを拾ってくだすって」「拾ってあります、すぐ追っ駈けて往って、お渡ししようとしましたが、御門が締りましたから、朝お届けしようと思いまして、持っております」　興哥は卓の傍へ往って釵を取ろうとした。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうだ、桐島さんだ、何時も胴忘れをしましてね、で、絹漉は、ちりか何かになされるので」「どうですか、やっこに切ると云ってましたよ」「そうですか、やっこに、では、すぐお届けいたします」　女房が立って来て顔をだした。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕が貰って往っても好いのですよ、遅いし、雨も降ってますから」「なに、よろしゅうございます、すぐお届けいたします」　女房は余計な口さえ出さなければ、書生さんに持って往ってもらうのに、と、夫の贅言が小面憎かった。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「神月さんからお届けものだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　打微笑み、「相済まんがどうぞ宅の方へお届けを、といって平にあやまると、使の婦人が、私も主義は違っております。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さんに、その遊女が今夜中にお届け申す約束のものがあるが、寮にいらっしゃるお若さん、同一御主人だけれども、旦那とかには謂われぬこと、朋友にも知れてはならず、新造などにさとられては大変なので、昼から間を見て、と思っても、つい人目があって出られなかった。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合わせの薬を飲ませて介抱して、ともかくも奥へ連れ込みまして、表向きは死骸紛失ということにお届けを致させました」「お歌はそれからどうしました」「日が暮れてから気分も快くなったと申しますので、裏山づたいに帰してやりました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "「柳将軍から盧君に書面をお届け申す」　言うかと思うと、一幅の書がどこからとも知れずに軒下へ舞い落ちた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「警察へでもお届けいたしましょうか。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速お届け致すでござりましょう。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお持ちの象牙も今晩私が担いでお届け致しますから、その辺、どうか、悪しからず……」　こういう意味で私はキッパリと謝絶ました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "牙彫りを排し木彫りに固執したはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の二十一日にご注文うけまして、当月二日にお届けいたしました品でござります」「注文主はだれじゃ」「ちとご身分のあるおかたでござりまするが」「承知のうえでしらべに参ったのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この品もそちらへお届けいたしました」「よし、わかった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石川伝通院裏吉田｜法眼様のご後室へ、たしかに三蓋松の紋つきちりめんをひとそろいお届けいたしましたと、呉服後藤の店の者がいってるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど、今は親しくお目にもかかれぬ身、お礼のかわりにこの守り袋お届け候まま、わが身と思うて、たいせつにご所持なさるべく、はよう年季勤めあげて、ご立身なさるよう、陰ながら祈りあげ候。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえなに仔細を打ち割って見れば他愛もないこと、御武家様をお泊め申せばお届けやら手続きやら、何かとあとで面倒でござりますゆえ、それをうるさがってどこの宿でも体よくお断りしているだけのことでござりまするよ」「異な事を申すよ喃。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
