    "definitions": [
      {
        "index": 1,
        "gloss": "main street (as opposed to a side street)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "表通りのデパアトよりも、こんな裏まちに、甲府の文化を感ずるのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分だけ早くから寝てもなかなか寝付かれないので、もう帰るかもう帰るかと心待ちにしていると自然と表通りを去来する人力車の音が気になる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの店屋などでも荷物を纏めて立退用意をしている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は東北のＳという城下町の表通りから二側目の町並を歩いていた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの白痴を呼んで来るのは町の景気引立策にもいいですなあ」　北国寄りのＦ――町の表通りに、さまで大きくはないがしっかりした呉服店の老舗があった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者屋をしている表店と彼女の住っている裏の蔵附の座敷とは隔離してしまって、しもたや風の出入口を別に露地から表通りへつけるように造作したのも、その現われの一つであるし、遠縁の子供を貰って、養女にして女学校へ通わせたのもその現われの一つである。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの繁華から折れ曲って来たものには、別天地の感じを与える。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "眺めるのは開け放してある奥座敷を通して眼に入る裏の谷合の木がくれの沢地か、水を撒いてある表通りに、向うの塀から垂れ下がっている椎の葉の茂みかどちらかである。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊もそういう素振りをされて、却って明るく薄笑いするときもあるが、全然、ともよの姿の見えぬときは物寂しそうに、いつもより一そう、表通りや裏の谷合の景色を深々と眺める。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、ともよは、籠をもって、表通りの虫屋へ河鹿を買いに行った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは、表通りの目的の店近く来ると、その店から湊が硝子鉢を下げて出て行く姿を見た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときどこからともなく、ハイヤーの滑って来る轟がして、表通りで停まったらしい。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは表通りまで響くような声をあげて人を呼んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんが丁度来たから、もうそろそろ出かけるとしようか」　形ばかりに戸をひき立てて、内は留守だからと隣りの人にことわって、半七はかの男と共に露路を出ると、表通りはもう夜になっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りも夜更けになるとこの通りである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景にしても壊れかかった街だとか、その街にしてもよそよそしい表通りよりもどこか親しみのある、汚い洗濯物が干してあったりがらくたが転がしてあったりむさくるしい部屋が覗いていたりする裏通りが好きであった。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿芝居、大蛇、熊、盲目の墨塗――（この土俵は星の下に暗かったが）――西洋手品など一廓に、※草の花を咲かせた――表通りへ目に立って、蜘蛛男の見世物があった事を思出す。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は表通りへ出て、二階を仰ぎ、奥さん、おねえさん、奥さん、おねえさん、と小声で呼んでみましたが、もう眠ってしまったのかどうだか、二階はまっくらで、そうして何の反応もございません。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの白痴を呼んで来るのは町の景気引立策にもいいですなあ」　北国寄りのＦ――町の表通りに、さまで大きくはないが確っかりした呉服店の老舗があった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者屋をしている表店と彼女の住っている裏の蔵附の座敷とは隔離してしまって、しもたや風の出入口を別に露地から表通りへつけるように造作したのも、その現れの一つであるし、遠縁の子供を貰って、養女にして女学校へ通わせたのもその現れの一つである。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船は、櫂もなく艪もなしに、浜松の幹に繋いで、一棟、三階立は淡路屋と云う宏壮な大旅館、一軒は当国松坂の富豪、池川の別荘、清洒なる二階造、二見の浦の海に面した裏木戸の両の間、表通りへ抜路の浜口に、波打際に引上げてあった。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は此處に、と少年の導くまゝに、階子を上つて、其の手代は二階の一室、表通りの見晴と云ふのへ通る。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がさり……　裏町、表通り、火を警むる拍子木の音も、石を噛むやうに軋んで、寂然とした、臺所で、がさりと陰氣に響く。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其うしろ姿は正しく猫、加之も表通りの焼芋商に飼つてある雉子猫だ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ今、表通りでクーペを御自分で運転していらした紳士の方から、そう云いつかってまいりました。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は直に踵をかえして表通りに出ると、通りがかりのタクシイを呼び止めて、それで街のヨロピン酒場へ参りました。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "編上靴をシッカリと搦み付けて、勝手口から佩剣を釣り釣り出て来ると、国道とは正反対の裏山に通ずる小径伝いにサッサと行きかけたので、表通りで待っていた一知青年は、慌てて追っかけて来た。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りへ出てみたりまた横町へ折れ戻り、そして露路の中へ切れ込んだりした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの呉服屋と畳表問屋の間の狭い露路の溝板へ足を踏みかけると、幽かな音で溝板の上に弾ねているこまかいものの気配いがする。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、まがりかどまで来て、ヒョイと銀座のおもてどおりのほうを見ると、ずっと向こうのかどに、へんてこなものが、うごめいているではありませんか。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
