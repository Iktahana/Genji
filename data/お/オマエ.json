[
  {
    "uuid": "15d7cc32-6c72-531d-9544-339051127d91",
    "entry": "お前",
    "reading": {
      "primary": "おまえ",
      "alternatives": [
        "おまい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "you",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お前について知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お前がありますね。",
              "source": "幻辞"
            },
            {
              "text": "お前というのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお前の例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお前が好きです。",
              "source": "幻辞"
            },
            {
              "text": "お前を使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お前の話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お前はどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお前があります。",
              "source": "幻辞"
            },
            {
              "text": "お前は日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お前について考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお前の定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お前の使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお前が重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お前についてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお前は大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお前について相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お前という概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお前の説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お前を正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼がもしそのことを欺いたとして、当今人々は云ふのである、「それはお前だけのことだ、お前の註文があるだけのことだ」と。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのお前自身にしてみれば、その註文を抱いてこそ生きてゐるやうなものでもあるのだ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　長く出てゐりやあ、お前が手紙を書くに遥つくり出来るだらうと思つてね、とそれはまあ冗談だが………。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆妻のお前のお蔭で、お前の話を聞いて書いたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　織田君を殺したのは、お前じゃないか。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、」と二番目の姉さんを小声で呼んで、「お前のところに、モオニングがあったろう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前達の来る所ぢやないツ！",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその支那人を信用し切つた母の「お前よく言つて呉れたね、そんな時はこれからでも一寸わたしまで言つてお呉れよ」といふ声が聞えた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりやあお前が成績を悪くするからだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「またお前が急にそんなことを言ひ出す。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も少しは私のことを考へろ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が一人でやつて行けるものでもないし。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだお前こそ甘え奴だ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝もＭのおつ父さんに会つたがね、あれはお前が入学当時の成績のことを思つて、あなたのお子さんはよくお出来でつて挨拶をしたが私は冷汗が出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍはお前の成績の悪いことをおつ父さんに話さないのだらうか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前達は俺の弟だ俺の弟だ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お前のする仕事とお父さんとは関係ないぞ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の仕事はお父さんと関係ないぞ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は将軍のビオルン（熊）に「鋼鉄のかみつけないこの犬（フンド）はお前が仕止めてくれ」と言った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日南洋から手紙が來て「東京の家にはお前の唯一人の叔母たる小生の母と、小生の妹と家内と三人で侘しく留守をしてゐるから一度訪ねて行きなさい」とそれに書かれてありましたが、私はそれに返事して「僕にはとても行けない。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「受け取れ、これはお前たちのものだ。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちにおれは之を遺産とし、永遠の領地として贈つてやる。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は一體どこに居たのだ。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前がこの天上におれと一緒に居たいなら、時々やつて來い。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此所はお前の爲に空けて置く！",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは、こなひだの爺さんからあづかつてゐる大事の品だが、しかし、お前さんがそんなに欲しいならやつてもいい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは一體、何のつもりでお前はこの物語を書いたのだ、と短氣な讀者が、もし私に詰寄つて質問したなら、私はそれに對してかうでも答へて置くより他はなからう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と質問され、博士大いに閉口して、奥さま、生れたばかりの赤ん坊に、おまえは何を建設するのだい？",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも、「おまえがわるいんだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、この友人と酒を飲んで「おまえは馬鹿だよ」と言った事があるのを思い出して、恐縮した。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
