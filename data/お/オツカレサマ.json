  {
    "uuid": "725f5f79-2f75-5e21-a6ac-ef8dab1bd417",
    "entry": "お疲れ様",
    "reading": {
      "primary": "おつかれさま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thank you (for your hard work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "君の意見は大事だ。",
              "source": "幻辞"
            },
            {
              "text": "君はどう思うか？",
              "source": "幻辞"
            },
            {
              "text": "君のおかげで成功した。",
              "source": "幻辞"
            },
            {
              "text": "君と一緒にいると楽しい。",
              "source": "幻辞"
            },
            {
              "text": "君の頑張りに感動した。",
              "source": "幻辞"
            },
            {
              "text": "君にお願いがある。",
              "source": "幻辞"
            },
            {
              "text": "君の夢を応援したい。",
              "source": "幻辞"
            },
            {
              "text": "君は素敵だと思う。",
              "source": "幻辞"
            },
            {
              "text": "君に任せて大丈夫だ。",
              "source": "幻辞"
            },
            {
              "text": "君の才能はすごい。",
              "source": "幻辞"
            },
            {
              "text": "君といるのが幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "君のアイデアが役に立った。",
              "source": "幻辞"
            },
            {
              "text": "君を信頼している。",
              "source": "幻辞"
            },
            {
              "text": "君の笑顔が大好きだ。",
              "source": "幻辞"
            },
            {
              "text": "君との時間を大切にしたい。",
              "source": "幻辞"
            },
            {
              "text": "君のサポートに感謝する。",
              "source": "幻辞"
            },
            {
              "text": "君なら成功できる。",
              "source": "幻辞"
            },
            {
              "text": "君にもできるよ。",
              "source": "幻辞"
            },
            {
              "text": "君と一緒に頑張ろう。",
              "source": "幻辞"
            },
            {
              "text": "君の力を信じている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「ヘイ……どうもお疲れ様で……お流し致しましょう」　揉み手をしながら小奇麗な若衆が這入って来た。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お疲れ様で」　とか「先刻のお方様で」　とか、という御世辞を聞き流して、奥まった部屋へ入った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつかれさま、本当に。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
