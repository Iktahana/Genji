    "definitions": [
      {
        "index": 1,
        "gloss": "to be in one's debt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
