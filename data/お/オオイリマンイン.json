        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二昔前の書生劇でも大入り満員だというので、劇も映画も明治の壮士芝居である。",
              "citation": {
                "source": "芸道地に堕つ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、これに関係した古道具屋連が相集まり、これは公開して世間の人に、古今はじめての奇蹟を見せてやるべきであるという相談がまとまり、見世物小屋を開いて、茶釜の狸踊りをご覧に入れたところ、大評判となって大入り満員。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように美少女と動物を活用しても、大入り満員なのは劇場と動物園だけで、その他はどうしてもダメらしいや。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日わたくしどもで『裏返しのファウスト』を出しましたら、どのボックスもほとんどがらあきでしたが、それがもしわたしたちヴァーニチカと二人で何か俗悪なものを出したとしたら、さだめし小屋は大入り満員だったに相違ないんですわ。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……車室は大入り満員の盛況でね、眠ることなど思いも寄らん。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しいものが掛っていて、席桟敷は大入り満員なのだった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "影人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って喫茶店にはいるといった具合で、喫茶店は大入り満員となる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この興行は、大入り満員の売切れつづきで、すばらしい人気を博したのみならず、その人気に該当する実質を、見る人に与えたようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大入り満員は確実だ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い会員の学生は、安い会費で鱈腹呑めるし、古い連中は懐旧談がたのしめるので、毎回、大入り満員であった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も大入り満員、「東京読本」の当りである。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
