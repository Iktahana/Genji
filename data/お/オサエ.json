          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかもこの衝動は、避けがたく抑えることが出来ないのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白痴の主人公は、愛情の昂奮に駆られた時、不意に対手の頭を擲ろうとする衝動が起り、抑えることが出来ないで苦しむのである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は虫抑えの薬を取り出して呑ませてくれたがあの時の自分の心は今でも説明は出来ぬ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとその始末が付いたと思うと今度は手とも足とも胸とも云わず、綿のように柔らかい、しかも鉛のように重いもので、しっかり抑え付けられる。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊へ着いて見ると、戸は厳重に釘づけにされ、その上に材木を筋交えに抑えにして、鋼線で結びつけてあるが、寂ッそりとして、人の気はなく、案内者の咳払いが、沈んだ空気を乱しただけだ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の奴に、発破を抑えつける奴を寄越せとそう云ってくんな。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらにゃ、ダイナマイトを抑えつけるてな、芸当は打てねえんだからってな。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "発破と度胸競べなんざ、真っ平だよ」　こんな訳であって、――どんな訳があろうとも、発破を抑えつけるなんて訳に行くものではない――岩鼻火薬製造所製の桜印ダイナマイト、大ダイ六本も詰め込んだ発破は、素晴らしい威力を発揮した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯をたべて自分が近所へ遊びに出ようとすると、お松はあわてて後から付いてきて、下駄を出してくれ、足袋の紐を結び直してくれ、緩んだへこ帯を締直してくれ、そうして自分がめんどうがって出ようとするのを、猶抑えて居って鼻をかんでくれた。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼にもつ涙をお増に見られまいとして、体を脇へそらしている、民子があわれな姿を見ては僕も涙が抑え切れなかった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は民さん一寸御出でと無理に背戸へ引張って行って、二間梯子を二人で荷い出し、柿の木へ掛けたのを民子に抑えさせ、僕が登って柿を六個許りとる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして民さんは死んだんです」　僕が夢中になって問返すと、母は嗚咽び返って顔を抑えて居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親のいいつけで背かれないと思うても、道理で感情を抑えるは無理な処もありましょう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば有為の青年を金や権勢や義理合やでとって抑えて本人のあまり気のすすまぬ金持の養子にしたり、あるいはあまり適当でない地位に縛り付けたりする事があるとすれば、これはいくらかカラザン人の遣り口に共通なところがありはしまいか。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして激昂する心を抑えてピアノの前に坐り所定曲目モザルトの一曲を弾いているうちにいつか頭が変になって来て、急に嵐のような幻想曲を弾き出す、その狂熱的な弾奏者の顔のクローズアップに重映されて祖国の同志達の血潮に彩られた戦場の光景が夢幻のごとくスクリーンの面を往来する。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（驚を自ら抑えて、詞急に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両手の間に画家の頭を挟みて抑え、目と目を見合せ、一瞬間極めて真面目になりいて、さて詞ゆるく、極めて悲し気に。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は神経が昂ぶるのを抑えて、彼が持った小判型の象牙札を見詰めていたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に乗り上げた舟のように傾いた橇の底では兵士が、でこぼこのはげしい道に動揺するたび、傷を抑えて歯を喰いしばった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果は、帝国主義ブルジョアジーが、一日だけ余命を長く保って、労働者農民の頭を一日だけより長く抑えつけているということになるのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワへ行きたい希望を抑えることができなかった。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これさえ抑えとけば、香水をつけたり、絹の靴下をはいたりして、封建時代の気分を呼び戻そうとするような、反動分子に何も手にはいれゃしなかったのだ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が貧乏な百姓や、労働者の出身でありながら、詰襟の服を着とるというんで工人や百姓の反抗を抑えつけているんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　高取が幅のある声で訓練所を抑えつけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、軽蔑の眼を、小山とかわして冷笑している支配人に、むっとするものを抑えて、一言、ことわった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大隊長は、空へ鉄砲を向けた兵タイのことは忘れて、内心の幸福を抑えることが出来ずにこにこした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまるで獲物を捕った虎のように刳物台を抑え込んでしまっている。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はいよいよ母親を起こそうかどうしようかということで抑えていた癇癪を昂ぶらせはじめた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし母親を起こすことを考えると、こんな感情を抑えておそらく何度も呼ばなければならないだろうという気持だけでも吉田はまったく大儀な気になってしまうのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、どいてくれよと言って、前の人をどかせて牛を歩かせたんです――みんな見てました……」　姑の貌は強い感動を抑えていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
