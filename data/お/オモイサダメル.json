          ],
          "literary": [
            {
              "text": "それが出来ないことが判って見ると今度は積極的に慧鶴を未来の夫と思い定めることによって良心を宥めた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……貞阿はそう思い定めると、暫くじっと瞑目した。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まアいい、どうした八五郎」「それが変で、路地を出るとしばらく思案をしていましたが、思い定めると、竪大工町へ」「森右門という浪人者の家へ入ったろう」　と平次。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
