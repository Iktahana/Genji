[
  {
    "uuid": "4b925692-69a7-5669-ae5f-907a50fda2e7",
    "entry": "お強",
    "reading": {
      "primary": "おこわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "glutinous rice steamed with red beans or some other ingredient",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お強という言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお強の意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お強を正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお強という概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お強の用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お強は習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お強の意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お強と同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お強は複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お強はしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お強の語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お強の使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お強が特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お強を含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お強のニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お強に複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お強の使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お強の文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お強は、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お強の代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すなわちアーク灯の陰極になっている炭の棒を不断廻転させ、陽極には金属の棒を用い、これを水素または炭酸瓦斯で包んでなお強い磁力をアークの光部に作用させる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、Ｔ「今の物音は　拙者が　投げられました音」　と言われておしまが、うっとりと、　「まァＴ「お強う御座いますのね　先生は？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　反感をなお強めながら、彼は、小屋の床をドシンドシン踏みならした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と今度はなお強く言いましたので私も仕方がないから、のっそり内庭に入りました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "）その四（幻影が姿を消して仕舞ったあと、舞台面は現実感が一しお強められる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しき美人は満面に笑みを含みて、起伏常ならざる席に安んずるを、隣たる老人は感に堪えて、「おまえさんどうもお強い。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまほどのお強い、卓抜の手腕をお持ちの政治家は、欧洲にも数が少うございます。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御病身で、癇癖がお強く、御鞠の御名人で、しかも世に例のなかつたほどの美貌でいらつしやつたとか、そんな事くらゐを人から聞かされてゐる程度でございますが、いづれは非凡の御手腕もおありになつたお方に違ひございません。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうにお心ばえのうるはしい御台所さまでございましたから、あのお強い御気性の尼御台さまも、この御台所さまをお可愛がりなさる事ひとかたでなく、どこへおいでになるにもお連れになつて、お互ひ実の御親子以上にお打解けられ末しじゆう御睦じくして居られたやうでございました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）美女　（起直り、会釈す）……父へ、海の幸をお授け下さいました、津波のお強さ、船を覆して、ここへ、遠い海の中をお連れなすった、お力。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び聞かれよ、強いられよ、なお強いられよ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女がおっしゃいませんでも、私からお強請り申しましょう。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みなさん、お強いのね」　とおかみさんは、なぜだか、しんみりした口調で言った。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "克はぬまでも多少は累を免れんと、貫一は手を拱きつつ俯目になりて、力めて関らざらんやうに持成すを、満枝は擦寄りて、「これお一盞で後は決してお強ひ申しませんですから、これだけお受けなすつて下さいましな」　貫一は些の言も出さでその猪口を受けつ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩沙汰があまり続くうちには、いかにお強い殿様でも物のはずみで、どのような怪我あやまちもないとは限らぬ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "春を送る雨の音は井筒の柳の上にひとしお強くひびいた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車を下りて車に乗った時から、秋の感じはなお強くなった。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの方がお強いんですから、もう怺へてお上げなさいましな。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お願ひですから狼退治だけは止めて下さいな、――先生のお強いことはすつかり解つてゐるんですもの、この上そんな処へ出かけて若し怪我でもなさつたらと思ふと、待つてる間に妾は死んでしまひさうだわ。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寒いのに、お強いこってすね。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女は私のお送りした歌に對して『秋風は荒凉ふくとも葛の葉のうらみ顏には見えじとぞ思ふ』などとお強い事を仰有つておよこしになりましたけれど、私はそれをお信じしませんでしたよ、貴女の御心の底の底を知つて居りましたのですよ。",
              "citation": {
                "source": "誠心院の一夜",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――「若旦那は、お口は拙いけれどどこかお強いところがあるわね。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに閉口して将棋会なぞに顔を見せると、「まア、あなたはお強いんだから見てゐて頂きませう」　なんて敬遠され勝だつたよ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子が笑うと、彼は調子づいてなお強く自分の頭をぴしゃりぴしゃりと叩いていった。",
              "citation": {
                "source": "赤い着物",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも尚お強情を張ッて行かなければ、「貴君と御一所でなきゃア私も罷しましょう」とか何とか言て貰いたかッた……「シカシこりゃア嫉妬じゃアない……」　と不図何か憶出して我と我に分疏を言て見たが、まだ何処かくすぐられるようで……不安心で。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「随分お苦しさうですね、貴方のお腹は余りお強い方ではないんですね。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるをなお強いて「戯れに」と題せざるべからざるもの、その裏面には実に万斛の涕涙を湛うるを見るなり。",
              "citation": {
                "source": "曙覧の歌",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家は、その場合、どんな力で、我血の流れる負傷のあとを調べ、そのように人情以上の力がわが人情を破壊したいきさつを摂取し、その経験によってなお強く人生を愛しつつ社会の現実を描破し得るであろう。",
              "citation": {
                "source": "パァル・バックの作風その他",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのお帰りがあんまりお早いので、天皇は変だとおぼしめし、「いったいどんなふうにおこわしになったのです」とおたずねになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはわたしがおこわいの」　葉子はさりげなく岡の顔をのぞき込むようにしてこういった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
