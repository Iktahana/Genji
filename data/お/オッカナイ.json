        "examples": {
          "standard": [
            {
              "text": "私は毎日頑張っている。",
              "source": "幻辞"
            },
            {
              "text": "私の意見です。",
              "source": "幻辞"
            },
            {
              "text": "私がやります。",
              "source": "幻辞"
            },
            {
              "text": "私は同意しません。",
              "source": "幻辞"
            },
            {
              "text": "私の家族について。",
              "source": "幻辞"
            },
            {
              "text": "私の仕事は楽しい。",
              "source": "幻辞"
            },
            {
              "text": "私ができることは限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "私のせいではない。",
              "source": "幻辞"
            },
            {
              "text": "私が間違っていた。",
              "source": "幻辞"
            },
            {
              "text": "私は理解した。",
              "source": "幻辞"
            },
            {
              "text": "私の目標を達成したい。",
              "source": "幻辞"
            },
            {
              "text": "私の経験から言うと。",
              "source": "幻辞"
            },
            {
              "text": "私が保証する。",
              "source": "幻辞"
            },
            {
              "text": "私だったらこうする。",
              "source": "幻辞"
            },
            {
              "text": "私の夢は実現した。",
              "source": "幻辞"
            },
            {
              "text": "私は幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "私を信頼してください。",
              "source": "幻辞"
            },
            {
              "text": "私の時間は限られている。",
              "source": "幻辞"
            },
            {
              "text": "私たちの関係は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "私ができた理由は努力だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おっかないさかなもあったものさ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は驚きてソッとそのまま立離れながら、「オヤおっかない狂人だ。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の個性みたいなものを、本当は、こっそり愛しているのだけれども、愛して行きたいとは思うのだけど、それをはっきり自分のものとして体現するのは、おっかないのだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだね」「なんだもないものだ、お前さんは、おっかない骸骨と抱きあってるじゃないか」「骸骨、骸骨って、あれかね」「笑いごとじゃないよ、お前さん、おっかない骸骨と、何をしようというのだ、お前さんは、邪鬼に魅いられてるのだよ」　喬生も薄気味悪くなってきた。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだね」「なんだも無いものだ、お前さんは、おっかない骸骨と抱き合ってたじゃないか」「骸骨、骸骨って、あれかね」「笑いごとじゃないよ、お前さんは、おっかない骸骨と、何をしようと云うんだね、お前さんは、邪鬼に魅られてるのだ」　喬生もうす鬼魅悪くなって来た。",
              "citation": {
                "source": "牡丹燈籠　牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へい、ただいま」　慶一が『ラバー・ソウル』をのせ、回転を三三にセットし、スタート・ボタンを押しながら、「お母さん、それから、うすらデカイ、おっかない不良少年もいるのです」とつづけると、「もォー」と、全員が不満の声をあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにもう二十人近い男女のひとが来ていましたが、初めてこういうところへ来て私が珍しく感じたことは、来ている人の多くが元気な眼つきをして互に挨拶したり話しをしたりして、ちっとも普通に裁判所と云うおっかないところに来ているようでもなくのびのびしていることでした。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、始めのこわいものみたさのような心持はなくなり、逆に、なぜわたし達のような働く婦人まで共産党というとおっかないもののように思わされていたかという訳がまざまざわかったように思いました。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十二「真実におっかない人ですよ。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私おっかないから、もう外へも出ないでおこう。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気で半年休んでもおっかないことはない。",
              "citation": {
                "source": "「我らの誌上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって来て、釜、庖丁の類を私の前に並べ「マア、おっかないみたいなもんですよ。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田舎の男って、ほんとにおっかないったらないの、活動見に行って、かえりなんか三十人も男がついて来るんだもの、娘十人ばっかしに、三十人も男どもがおっかけて来て、畑ん中までおっかけたりして、ほーんに野蛮だからね、おっかないったら」　この話には誇張がある。",
              "citation": {
                "source": "想像力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんの声に深い感動がこもっていて、ミーチャは重い掌の下で嬉しいような、おっかないような気になった。",
              "citation": {
                "source": "楽しいソヴェトの子供",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まったくおっかないほど伸びたもんだなあ！",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "半分分っている奴ほどおっかない者はない。",
              "citation": {
                "source": "今世風の教育",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかないわ……」　ネクタイをひらひらさせた二人の西洋人が雁木に腰をかけて波の荒い景色にみいっていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みみずは龜さんがこわい眼をしたので、こいつはおっかないぞと、すぐまた石の下へもぐりこみました。",
              "citation": {
                "source": "龜さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかないわ……」　ネクタイをひらひらさせた二人の西洋人が、雁木に腰をかけて波の荒い風景にみいっていた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京新聞さ書かれたら伯母も成仏すっぺと云ったら、おっちゃんがおっかない顔してコケ！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏人に法律は、実際おっかないんだ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この頃の子供なんて、ほんとに……大人よりおっかない奴らさ」若いおとなしそうな近眼の男は、幾分迷惑そうに脱いで膝の間へ持ってるレインコートの紐をいじりながら、「……われわれのところじゃ、まだ大人がほんとに子供の育てかたを知らないんだよ、お婆さん。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっかない、勇ましい気がし、急に焚火のそとの暗がりが濃く深く空の星が遠く感じられた。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大勢の、大して愉快な希望もなさそうにして歩いている殆どみんなが月賦の洋服を着、女房子供をかかえて去年から賞与も半減かまるで無しかで日々同じように働かされているのだと思うと、ミサ子は心の底でおっかないように感じた。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だってェ……あんた、さっきからおっかない眼つきして、私の顔ばっかり見つめてるんだもの……」「そうだった？",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――坐ってたよ」　そして、おっかないことでも云うように乙女は一段と声をひそめた。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やいっ、肩を押しゃがって、何んだ」「お嬢さんのお供だ、おっかない顔をしなさんな」　庄吉の後方に、傘をすぼめて、顔を隠した深雪がついていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
