        "examples": {
          "standard": [
            {
              "text": "おころりよという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はおころりよの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "おころりよを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではおころりよという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "おころりよの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、おころりよは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、おころりよの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "おころりよと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、おころりよは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、おころりよはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "おころりよの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、おころりよの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、おころりよが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "おころりよを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、おころりよのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、おころりよに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "おころりよの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、おころりよの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "おころりよは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、おころりよの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "＝＝ねんねんよ、おころりよ、ねんねの守はどこへいた、山を越えて里へ行た、里の土産に何貰うた、でんでん太鼓に笙の笛＝＝白雪　（じっと聞いて、聞惚れて、火焔の袂たよたよとなる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころ、ころ、ころ、ころ、おころりよ。",
              "citation": {
                "source": "蝉の子守唄",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねんねんよう、おころりよ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし取り外しができるものならその「掌」をやわらかい真綿か何かへシッカリと包んで、寝ン寝ンよおころりよと子守唄歌いながら毎晩抱きしめて添い寝してやりたかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねんねんよう　おころりよ、唄をうたってあげましょう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねんねんよう、おころりよ」と、彼女はつぶやく、「お粥をこさえてあげましょう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねんねんよう、おころりよ、唄をうたってあげましょう……」と、ワーリカはつぶやくと、今度は自分が、暗い、むんむんする百姓小屋のなかにいるのが見える。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ねんねんよう、おころりよ。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねんねんよう、おころりよ」と、彼女はつぶやく、――「唄をうたってあげましょう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、ねんねよう、おころりよ、筑波のお山に火がついたあ、火がついた、烏が三匹焼け死んで、その子の烏がいうことに、いうことに……（しかし長く尾を引っぱったお咲の泣声は止もうとはせぬ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ　おころりよ　こどもたち。",
              "citation": {
                "source": "ねっこうまれのこびとたち",
                "author": "ETWAS VON DEN WURZELKINDERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、ねんねよう、おころりよ、筑波のお山に火が付いたあ、火が付いた、烏が三匹焼け死んで、その子の烏が言うことに、言うことに……（しかし長く尾を引っぱったお咲の泣き声は止もうとはせぬ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
