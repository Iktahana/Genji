          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "＝＝ねんねんよ、おころりよ、ねんねの守はどこへいた、山を越えて里へ行た、里の土産に何貰うた、でんでん太鼓に笙の笛＝＝白雪　（じっと聞いて、聞惚れて、火焔の袂たよたよとなる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ころ、ころ、ころ、ころ、おころりよ。",
              "citation": {
                "source": "蝉の子守唄",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねんねんよう、おころりよ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし取り外しができるものならその「掌」をやわらかい真綿か何かへシッカリと包んで、寝ン寝ンよおころりよと子守唄歌いながら毎晩抱きしめて添い寝してやりたかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ねんねんよう　おころりよ、唄をうたってあげましょう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねんねんよう、おころりよ」と、彼女はつぶやく、「お粥をこさえてあげましょう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねんねんよう、おころりよ、唄をうたってあげましょう……」と、ワーリカはつぶやくと、今度は自分が、暗い、むんむんする百姓小屋のなかにいるのが見える。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ねんねんよう、おころりよ。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねんねんよう、おころりよ」と、彼女はつぶやく、――「唄をうたってあげましょう。",
              "citation": {
                "source": "ねむい",
                "author": "СПАТЬ　ХОЧЕТСЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、ねんねよう、おころりよ、筑波のお山に火がついたあ、火がついた、烏が三匹焼け死んで、その子の烏がいうことに、いうことに……（しかし長く尾を引っぱったお咲の泣声は止もうとはせぬ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ　おころりよ　こどもたち。",
              "citation": {
                "source": "ねっこうまれのこびとたち",
                "author": "ETWAS VON DEN WURZELKINDERN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さ、ねんねよう、おころりよ、筑波のお山に火が付いたあ、火が付いた、烏が三匹焼け死んで、その子の烏が言うことに、言うことに……（しかし長く尾を引っぱったお咲の泣き声は止もうとはせぬ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
