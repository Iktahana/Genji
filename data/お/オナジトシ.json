        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして五六｜人の同じ年頃の小供がやはり身動きもしないで婆さん達の周圍を取り卷いて居るのである。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "源叔父の独子幸助海に溺れて失せし同じ年の秋、一人の女乞食｜日向の方より迷いきて佐伯の町に足をとどめぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、彼と同じ年恰好の者のうちでは、誰れにも負けず、物事をよく知っていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ年恰好の老婆、小さく痩せていて胸が鎧扉のようにでこぼこしている。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　同じ年の夏である。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何より嬉しくって今思いだしても堪りませんのは同じ年ごろの従兄弟と二人で遊ぶことでした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "珪次はそのとき私と同じ年の二十一で、みずみずした青年でした。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、抱主の家へは自分の了簡でも遠慮をするだけ、可愛い孫の顔は、長者星ほど宵から目先にちらつくので、同じ年齢の、同じ風俗の若い妓でも、同じ土地で見たさの余り、ふとこの夜に限って、西河岸の隅へ出たのであった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは王子と同じ年の大臣の子でした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちのせがれも丁度あなたと同じ年ころでした。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭湯の向いにミヤケ薬局があり、そこの主人は永助と同じ年で町会の幹事にあげられていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木造だけに部屋の感じもよく、今一人の同じ年頃の患者とベッドを並べているので、寂しそうにもなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九「裁かるるジャンヌ」を見て来た一夜、ちょうどそれが自分と同じ年頃の村の娘の、世の常ならぬ崇高な姿であるだけに、銀子は異常な衝動を感じ、感激に胸が一杯になっていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ年齢でも、ハムレットさまなどに較べると三倍も大人だ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」去年の夏にも、私はこの娘さんと同じ年恰好の上品な女中を兄の長女かと思い、平伏するほどていねいにお辞儀をしてちょっと具合いの悪い思いをした事があるので、こんどは用心してそう言ったのである。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも同じ年配の支那の青年たちが、奮起するどころか、相も変らず清国留学生会館でダンスの稽古にふけっているのを見るに及んで、自分もようやく決意した。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金木へも、たまに行つたが、金木のまちを歩きながら、もしやお前がその辺に遊んでゐないかと、お前と同じ年頃の男の子供をひとりひとり見て歩いたものだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と向かい合っている席には、四、五人、同じ年齢恰好のサラリイマンが、ぼんやり坐っている。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私と同じ年です。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人だってまだ若いのだし、それは無理もないと言えるかも知れぬけれど、そんなら私だって同じ年だ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの人と同じ年だ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ年に出た小宮豊隆君の「黄金虫」がやはりこの庭の写生画を其本の表紙に用ゐた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子まじりにわたくしと同じ年頃の少女が四五人いて、どこかこの近所の富裕な家の子たちと見え、少し遠慮が無さ過ぎるくらい活溌で人慣れています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "里子を預かるくらいゆえ、もとより水呑みの、牛一頭持てぬ細々した納屋暮しで、主人が畑へ出かけた留守中、お内儀さんが紙風船など貼りながら、私ともう一人やはり同じ年に生れた自分の子に乳をやっていたのだが、私が行ってから一年もたたぬうちに日露戦争がはじまって主人が出征し、畑へはお内儀さんが出た。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがたつた一人、お母さんの妖女だけは、いつまでたつても、お嫁に来たときとちつともかはらず、まるで息子の若ものと同じ年ぐらゐに見えました。",
              "citation": {
                "source": "湖水の鐘",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸持、鶴寿、花雪、交山は死して既に久しく、書家｜董斎の如きは、香以と同じ年の四月に死んでいる。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや小兵ではあるが、色のあさ黒い、引緊った顔の持主で、同じ年ごろの友達仲間にも元気のよい若者として知られていた。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼は素足になっていたが、そこには同じ年頃らしい女の子の古下駄が片足ころげていた。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に逍遙子はシエクスピイヤを評せし無名氏が用ゐし「レアル」の語を實と譯し、「アンレアル」の語を虚と譯して、其實を鴎外の所謂實におなじとし、其虚を鴎外の所謂想に適へりとしたり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕とおなじとしで、僕より小さいのですけれど、とても頭のいい子です。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
