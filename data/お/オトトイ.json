        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "このやうな夕暮が、私たちの上に襲ひかかるであらう、と云ふことは、昨日や一昨日から予感してゐた事ではなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の第二限ころなんか、なぜ燈台の灯を、規則以外に間〔一字分空白〕させるかって、あっちからもこっちからも、電話で故障が来ましたが、なあに、こっちがやるんぢゃなくて、渡り鳥どもが、まっ黒にかたまって、あかしの前を通るのですから仕方ありませんや。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたのかなあ、ぼくには一昨日大へん元気な便りがあったんだが。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日政夫さんが来るのは解りきって居るのに、姉さんがいろんなことを云って、一昨日お民さんを市川へ帰したんですよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "待つ人があるだっぺとか逢いたい人が待ちどおかっぺとか、当こすりを云ってお民さんを泣かせたりしてネ、お母さんにも何でもいろいろなこと言ったらしい、とうとう一昨日お昼前に帰してしまったのでさ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "政夫さんが一昨日きたら逢われたんですよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、昨日、一昨日、俺の心をひどく陰気にしたものもそれなのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、一昨日、俺を不安がらせた神秘から自由になつたのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに窓から見える病院の芝生の庭には一昨日のやうに、昨日のやうに、ぎらぎらした午後の太陽が照りつけ、處々に咲く松葉牡丹の花が陽炎の中に燃えるやうな紅を映してゐる、動く物一つない靜けさだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あるとも、一昨日なんか骨膜炎の手術を受けた老人がね、義太夫を唸り出す騷ぎだつたよ‥‥‥』と、水島は相變らず冷靜な顏附で云つた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、丁度、地下から突き出て来るように、一昨日よりは昨日、昨日よりは今日の方がより高くもれ上って来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎には、すべてが、つい一昨日の出来事のようにまざまざと躍っている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日から帰らないんであります。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、一昨日、武器を取り上げた高取や、那須や、岡本などが、一個の弱い生物でしかなかったように。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日そこへ行ってみた。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう昨日か、一昨日かに村の大部分が納めてしまったらしく、他に誰れも行っていなかった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の第二限ころなんか、なぜ燈台の灯を、規則以外に間〔一字分空白〕させるかって、あっちからもこっちからも、電話で故障が来ましたが、なあに、こっちがやるんじゃなくて、渡り鳥どもが、まっ黒にかたまって、あかしの前を通るのですから仕方ありませんや。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくには一昨日大へん元気な便りがあったんだが。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、一昨日、俺を不安がらせた神秘から自由になったのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度のは、一昨日の朝から懸った仕事で、ハヤその半を挽いた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日の夜を通した雨のなごりも、薄い皮一｜枚張つたやうに道が乾いた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ――」「降るのは構ひませんがね、その雷様は――」小笠原氏は、幌なしの車に、横ざまに背筋を捻ぢて、窓に腰を掛けたやうな形で飛び飛び、「昨日一昨日と三｜日続けて鳴つたですで、まんづ、今日は大丈夫でがせうかな。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは奥戸の池で釣ってたよ、昨日も一昨日も。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたのかなあ、ぼくには一昨日たいへん元気な便りがあったんだが。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てはゐましたが一昨日の晩の処にでなしに、おぢいさんのとまる処よりももっと高いところで小さな枝の二本行きちがひ、それからもっと小さな枝が四五本出て、一寸盃のやうな形になった処へ、どこから持って来たか藁屑や髪の毛などを敷いて臨時に巣がつくられてゐました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに昨日も一昨日も人の居ない処をせっせと歩いてゐたんだが。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたのかなあ、ぼくには一昨日大へん元氣な便りがあつたんだが。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てはいましたが一昨日の晩の処にでなしに、おじいさんのとまる処よりももっと高いところで小さな枝の二本行きちがい、それからもっと小さな枝が四五本出て、一寸盃のような形になった処へ、どこから持って来たか藁屑や髪の毛などを敷いて臨時に巣がつくられていました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに昨日も一昨日も人の居ない処をせっせと歩いていたんだが。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゆんべもおとといの晩も自分の家へ帰って来ませんとさ」　新日本音楽の先生の帰ったあと、稽古場にしている土蔵の中の畳敷の小ぢんまりした部屋になおひとり残って、復習直しをしていた老妓は、三味線をすぐ下に置くと、内心｜口惜しさが漲りかけるのを気にも見せず、けろりとした顔を養女に向けた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
