    "definitions": [
      {
        "index": 1,
        "gloss": "day before yesterday",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
