[
  {
    "uuid": "419555c1-f9c9-537b-ab83-ae98f7b2e795",
    "entry": "大きい",
    "reading": {
      "primary": "おおきい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
