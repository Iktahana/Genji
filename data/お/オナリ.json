[
  {
    "uuid": "7cdd42e3-5d84-5bee-8146-1e3116e11056",
    "entry": "お成り",
    "reading": {
      "primary": "おなり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
