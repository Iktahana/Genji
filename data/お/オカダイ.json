        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "先達てかねて紹介して置いた福岡大学の久保博士からの来書に、長塚君が診察を依頼に見えたとあるから、今頃は九州に居るだろう。",
              "citation": {
                "source": "『土』に就て",
                "author": "――長塚節著『土』序――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の犬どもの、耳には火を立て、牙には火を齒み、焔を吹き、黒煙を尾に倦いて、車とも言はず、人とも言はず、炎に搦んで、躍上り、飛蒐り、狂立つて地獄の形相を顯したであらう、と思はず身の毛を慄立てたのは、昨、十四年五月二十三日十一時十分、城崎豐岡大地震大火の號外を見ると同時であつた。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "現役の受験となった一九七四（昭和四十九）年、美大には軒並みふられたものの、静岡大学教育学部の美術専攻に受かりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "先達てかねて紹介して置いた福岡大學の久保博士からの來書に、長塚君が診察を依頼に見えたとあるから、今頃は九州に居るだらう。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後の直江の浦に来て、応化の橋の下に寝てゐると、そこへ山岡大夫と云ふ人買が来て、だまして舟に載せた。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて沖に漕ぎ出して、山岡大夫は母子主従を二人の船頭に分けて売つた。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "地の文はこれまで書き慣れた口語体、対話は現代の東京語で、只山岡大夫や山椒大夫の口吻に、少し古びを附けただけである。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは山岡大夫という船乗りじゃ。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸すなという掟のある宿を借りて、ひょっと宿主に難儀をかけようかと、それが気がかりでございますが、わたくしはともかくも、子供らに温いお粥でも食べさせて、屋根の下に休ませることが出来ましたら、そのご恩はのちの世までも忘れますまい」　山岡大夫はうなずいた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしども三人がお世話になるさえ心苦しゅうございますのに、こんなことを申すのはいかがと存じますが、実は今一人連れがございます」　山岡大夫は耳をそばだてた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら待って進ぜましょう」山岡大夫の落ち着いた、底の知れぬような顔に、なぜか喜びの影が見えた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭は山岡大夫で、客はゆうべ大夫の家に泊った主従四人の旅人である。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "応化橋の下で山岡大夫に出逢った母親と子供二人とは、女中｜姥竹が欠け損じた瓶子に湯をもらって帰るのを待ち受けて、大夫に連れられて宿を借りに往った。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山岡大夫は纜を解いた。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――――――　山岡大夫はしばらく岸に沿うて南へ、越中境の方角へ漕いで行く。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、主人にお預けなされた嚢は」と、姥竹が主の袖を引くとき、山岡大夫は空舟をつと押し出した。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご機嫌ようお越しなされ」　※の音が忙しく響いて、山岡大夫の舟は見る見る遠ざかって行く。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼はいろいろに事情を訴えて、一枚の古毛布を借りて来て、病める岡大人――岡本の一字を略して云う――に着せてくれる事になったのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代更紗で大尽遊び５・３（夕）　平岡熙氏といへば、例の運動好きの平岡寅之助氏の兄さんで、平岡大尽の名を取つた大通である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事では吾が福岡大学の名誉を不朽に伝える事は出来ないと思った。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その序に、お前達の戸籍の事も都合よく片付けて来たいと思うから、用事が出来たらコレコレ斯様斯様の処へ通信をするがいい……といったような事で話の辻褄を合わせて、渋々ながら納得をさせると、その翌々日の福岡大学最初の卒業式をスッポカシて上京してしまった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを私は、福岡大学病院の夕日さしこむ病床で、作品への失望と病苦の君とに、二重の淋しみをいたく味つたのである。",
              "citation": {
                "source": "不器男句集",
                "author": "芝不器男",
                "note": "青空文庫"
              }
            },
            {
              "text": "其には藤原北家長岡大臣（内麻呂）の子孫から採るといふ事になつてゐて、毎年さうしてゐたらしいことは、北山抄にあります。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度福岡大学へ行く途中とあつて立寄つた。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗手は有名な金岡大尉と三隈一等航空兵曹とでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "福岡大学病院の札のついた薬瓶を持つて居る様だから、多分、投げ出して居た、その繃帯した脚の手術を受けに行つて居たのであらう。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀河組の社というのは、鶴岡市の西南一里｜許の井ノ岡村の一小丘遠賀山の字伊波手井に在りて井ノ岡大権現と称し、祭神は豊岡比神の五神となっているから、寧ろ※神に縁のある社ともいう可く、遠賀はオガミの略されたものかも知れぬ。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく荒川と品川に住んでいる石郷岡大尉、荒川の援助者の一志茂敬の三人が出資者となる話が決まったのだ。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
