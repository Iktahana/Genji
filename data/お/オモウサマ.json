[
  {
    "uuid": "99a84d67-7465-581b-833f-13a917300460",
    "entry": "思う様",
    "reading": {
      "primary": "おもうさま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
