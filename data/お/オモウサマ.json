      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to one's heart's content",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "）と達二は、半分思う様に半分つぶやくようにしました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんはただただ御自分の悪い様にばかりとっているけれど、お母さんとて精神はただ民子のため政夫のためと一筋に思ってくれた事ですから、よしそれが思う様にならなかったとて、民子や私等が何とてお母さんを恨みましょう。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れにした処がまあカチヤには何よりべらべらしたものを着せて、頬っぺたの肉が好い色になるものでも食わせて、通りすがりの奴等が何処の御新造だろう位の事を云って振り向く様にしてくれりゃ、宿六はちっとやそっとへし曲って居ても構わ無えと思う様になるんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれむ様な小田の顔にはきかける様に女なんて自分の思う様になるよ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは権右衛門が身を以て贅沢するなと教えてくれたのであると思う様にしているのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と今度はその次の樽をあけて、みんなに思う様飲ませました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそう思う様に目的は達せられんので晩からかけて翌日の午後の三時頃迄は村中浜へ総出の儘風の中、雨の中を立ち尽して居た。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し多忙で思う様に之を利用する事が出来なかったのは残念｜至極である。",
              "citation": {
                "source": "入社の辞",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が愈大学へ這入って三年を過して居るうちに、段々其希望があやしくなって来て、卒業したときには、是でも学士かと思う様な馬鹿が出来上った。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貴婦人の底意なく頷いたのを見て、小さな靴を思う様｜上下に刎ねて、外国人の前へ行くと、小刀と林檎と一緒に放して差置くや否や、にょいと手を伸ばして、小児を抱えて、スポンと床から捩取ったように、目よりも高く差上げて、覚束ない口で、「万歳――」　ボオイが愛想に、ハタハタと手を叩いた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日、信綱は海上から鉄砲で城を撃たせたが、船が少ない上に城は高く思う様にならない。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親さえ、しまいには、ああこんな子なら生れない方がよっぽど幸だったと思う様になりました。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに可愛いじゃあないかねえ、」とものおもい、もの思う様子で謂いながら、つむりへ手を遣ると、さしていた銀脚の簪を抜いて取った。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから出たかと思う様に、一人の車屋がいつの間にか予の前にきている。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は君が来ることを杉野や渋川にも知らせたかったが、下女がいないからね」岡村は言い分けのように独で物を云いつつ、洋燈を床側に置いて、細君にやらせたらと思う様な事までやる。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの階級とあなた様たちの階級とは、遠く離れて別々のものなのです」　こう言って、強さで自分を征服しようとしている男を憎いと思う様子は、源氏を十分に反省さす力があった。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんがたよりにしている人はさきが短いよ」　と源氏がでたらめを言うと、小君はそんなこともあったのか、済まないことをする姉さんだと思う様子をかわいく源氏は思った。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島を過ぎ、次第に野原を登る様になると、矢張り出て来てよかったと思う様になった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾はみにくい体を持っておりますので、貴男のお側へそれ以上に近づく事の出来ないのをだんだん不平に思う様になり、そして日ましに気が短かくなって我ままになり、一年に二、三度位しか花環を買いに来て下さらない貴男のおすがたを見るために、いくたび父を門口に立たせた事でしょう。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、兎に角意久地の無くなるのは事実で、評判の気難かし家が、如何にでも私の思う様になって了う。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱陶敷て、気が滅入って、幾ら書いても思う様に書けないから、私はホッとして、頭を抱えて、仰向に倒れて茫然としていたが、「早く如何かせんと不好！",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は俄かに空腹を感じたが、何でも余は医学士の言葉の通り断食の儘で、身体の弱り果てるまで置かれる事と見える、今からひもじいなど思う様では仕方がないと、忽ち思い直して再び彼の手を引き立てると、彼の足には鎖が附いて重さが七八貫も有ろうかと思われる鉛の錘へ、極短く結び附けられて居るのだ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は少しも合点の行かぬ様子で「ハテな、穴川甚蔵と、其の姓名は私の耳に、左様さ貴方の顔が私の目に新しいと同様に新しいのです」余「エエ」先生「イヤ初めて聞く姓名です」と云って、少し余を油断のならぬ人間と思う様な素振りが見えた。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌をよんだり、短歌集を引き出して見たりしても、どうしても、ハーッと思う様なのが見つからない。",
              "citation": {
                "source": "短歌",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "只身の廻りの世話位なら誰もいやがるものもないけれども、何から何までとなると、女達も気の毒だし、第一、思う様には手が廻らないのが分って居る。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日仏様にお念仏を申しているのであるがどうしてもそれがおっくうになったり、又仏様への読経が大儀で仕様のない時には自分から怠けて見たり、お念仏も、読経をしない時さえもあるのだが、そうしたと云った所でここには誰も居ないのだから、怠けた事を恥しいと思う様な友も居ないものだからつい怠けてしまうのである。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫たち声をあわせて笑うところへ、イイダ姫メエルハイムが肘に指さきかけてかえりしが、うちとけたりとおもうさまも見えず。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿Ｑは思えば思うほど、イライラして来て耐え切れず、おもうさま怨んで毒々しく罵った。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
