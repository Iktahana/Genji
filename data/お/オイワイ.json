        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私が慇懃に彼女に、　――お祝いしますよ、アダ。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺の還暦の「お祝い」のことで帰っていてもそうなのである。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパイは、僕等の結婚や、お祝いごとまでも妨害するのだ。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよという時にゃあ、俺だって馴染み甲斐に魚っ子の一尾も持ってお祝いに行こうと思っているんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "用材出しを手伝ったお祝いのしるしに、おみき（酒）を振る舞うのは一つの習慣だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、おめでとう、と私も不自然でなくお祝いの言葉を返す事が出来ました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう百年ほど経って日本が紀元二千七百年の美しいお祝いをしている頃に、私の此の日記帳が、どこかの土蔵の隅から発見せられて、百年前の大事な日に、わが日本の主婦が、こんな生活をしていたという事がわかったら、すこしは歴史の参考になるかも知れない。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農揚げといって、この秋のとり入れと、お米ごしらえがすっかり終わったお祝いに、どこの百姓家でもそうするのです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちの花見酒で酔い潰れ、こっちのお祝い酒で奢り潰されてなあ」「太平楽なにも程がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "国中の人間はこのお布告を見ると大騒ぎをして、お祝いの支度を始めました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犬は狸のようなつまらない汚い犬でしたが、いよいよお祝いの当日になりますと、金襴の着物を着て王様のお椅子に着いて、大勢の家来や人民にお目見得をさせる事になりました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして王宮にお伴をして、今一度この若い美しい王様のためにお祝いをしました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とてもにこにこして私のところへお礼に来たその少年に、合格のお祝いを言いながら私は、少年の受験当時の様子を詳しく尋ねました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから今夜はそのお祝いで親類はみな呼ばれました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子は、誕生日のお祝いに、すずの兵隊さんたちをもらったのです。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、こんなににぎやかに、お祝いの会が開かれているのでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祝いのための大砲の音もとどろきません。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘も、いつか船の上で開かれていた、王子の誕生日のお祝いを見ていたのでした。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、お祝いの音楽も、耳にはいりません。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきの、大きな船には、クリスマスをお祝いする、色とりどりの旗がかかげられて、美しく風にはためいていました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人形たちに新しい着物がいるようになると、いつもねえさんは、誕生日のお祝いか、結婚式をやらせるんだよ。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊たちは、お祝いの大砲をうちました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祝いを申しあげに来る人たちは、いつまでもいつまでもつづきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ご婚礼のお祝いは、まる一月もつづきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちは、お祝いのかんぱいをしました。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "年はその時が六十一で還暦のお祝いがその春にある筈であったのが、思いがけなく養子の若先生が家出をされたのでその騒ぎのためにおやめになった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の後を継いで下すった御礼の意味とお祝いの意味を兼ねて誠に軽少ですが差し上げます。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私はきょうこの鼓と別れるお祝いにつまらないものを差し上げたいと思いまして……」「アッ……それは……」と私は腰を浮かした。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あやかしの鼓とお別れのお祝いですから」　というので無理に盃をすすめられたことを思い出した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあお祝いにみんなで遊びましょう」　と大喜びで遊びはじめました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
