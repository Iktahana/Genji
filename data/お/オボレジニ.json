          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "美くしい身振の、身も世もないといふやうな、迫つた三味に連れられて、チヨボの佐和利に乗つて、泣いて泣いて溺れ死にでもするやうにおかるは泣いてゐる。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "とお歌いになり、二人でざんぶと飛び込んで、それなり溺れ死にに死んでおしまいになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻が詰まったお蔭で、溺れ死にかかった少年時代の苦しみを今一度、夢に描かせられる。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にも溺れ死にそうな声を出してイビキを掻いている者など……だいぶ夜が更けているらしい光景である。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と流れが急でありましたので、二人の子供は溺れ死にました。",
              "citation": {
                "source": "真間の手古奈",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎左衛門の膝の上に蔽いかくしたまま、「実は、河の瀬で、釣していた童が溺れ死にました。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
