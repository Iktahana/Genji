        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お祭りのまえの日、というものは、清潔で若々しく、しんと緊張していていいものだ。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りのまへの日、といふものは、清潔で若々しく、しんと緊張してゐていいものだ。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私の仕事は、それを私が非常に愛してゐたがために、いつの間にか、稀有な靈感に起因する、大袈裟な行事、お祭り騷ぎになつてしまひました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の秋のお祭りに、太鼓を舁いだり、幟をさしたり、一張羅の着物を着てマチへ出る村の人々は、何等か興味をそゝって話の種になったものだが、東京の街で見るものは彼等にとって全く縁遠いものだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか気になるので、五月の末に無沙汰の詫びながら手紙を出すと、すぐその返事が来て、来月は氷川様のお祭りで強飯でも炊くから遊びに来てくれとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも急に老人に逢いたくなって、そのお祭りの日に赤坂に出て行くと、途中から霧のような雨が降って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祭りはどうしても夜のものですよ」　老人に案内されて、わたしは町内の飾り物などを観てあるいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に柳は、今はその細長い葉をすっかり落して、冷たい風にほんのすこしゆれ、そのてっぺんの青ぞらには、町のお祭りの晩の電気菓子のやうな白い雲が、静に翔けてゐるのでした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも、この、紀元二千｜七百年のお祭りの時には、二千｜七百年と言うか、あるいは二千｜七百年と言うか、心配なんだね、非常に気になるんだね。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今日はその銀河のお祭りなのですから、みなさんは外へでてよくそらをごらんなさい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩は銀河のお祭りだねえ」「うん。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもうじきちかくに町か何かがあって、そこにお祭りでもあるというような気がするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に柳は、今はその細長い葉をすっかり落して、冷たい風にほんのすこしゆれ、そのてっぺんの青ぞらには、町のお祭りの晩の電気菓子のような白い雲が、静に翔けているのでした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "又ある時は、お祭りの人ごみに立ちまじって、赤いゆもじの裾を染め、オモチャの笛をあわれみ詰まらせ、神木の肌を神さびさせ、仁王様の腕の古疵を疼き痛ませ、御神鏡の光を朧にした上に、伏しおがむ人々の睫毛までも白々としばたたかせて、昔ながらの迷信をいよいよ薄黒く、つまらなく曇らせる。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "警備の巡査、兵士、それから新聞社、保険会社、宗教団体等の慰問隊の自動車、それから、なんの目的とも知れず流れ込むいろいろの人の行きかいを、美しい小春日が照らし出して何かお祭りでもあるのかという気もするのであった。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会では感謝のお祭りがあったのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」令夫人といえども、下町娘だから、お祭り気は、頸脚に幽な、肌襦袢ほどは紅に膚を覗いた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その平扁味な処が、恰好よく乗りますから、二つかさねて、お持仏なり、神棚へなり、お祭りになりますと、子の無い方が、いや、もう、年子にお出来なさりますと、申しますので。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎の言を借りると、「結婚まえに、もうお祭りが済んでいた」訳だが、児子家の家長が多少の金を節約したさに然るべき式典を経ずして結婚するなど、権右衛門の潔よしとせぬところだったのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは、お祭りだな、と、カシワの木は、はっきりと感じました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたことが、まるで、お祭りの行列のように、つぎからつぎへと、目のまえを通りすぎていきました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、三人の兄弟はお父さんとお母さんに連れられて、山一つ向うの町のお祭りを見に行きましたが、その時お父さんが、「今日は三人に一つずつオモチャを買ってやるから、何でもいいものを云ってみろ」　と云われました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして何も買ってもらえずに、只お祭りを見たばかりでお家へ連れて帰られました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この町から一里ばかり離れたところの村に神様があって、きょうがちょうどお祭りの筈です。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ぷく三杯　お安さんという独身者で、村一番の吝ン坊の六十婆さんが、鎮守様のお祭りの晩に不思議な死にようをした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが又そのうちに、収穫が一通り済んで、村中がお祭り気分になると、後家さんの家がいつまでも閉め込んだ切り、煙一つ立てない事にみんな気が付き初めた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今でもそうだが、こんな時には、お祭りに連れて行かれず、家にひとり残された子供みたいな、天をうらみ、地をのろうような、どうにもかなわない淋しさに襲われるのだ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島大社では毎年、八月の十五日にお祭りがあり、宿場のひとたちは勿論、沼津の漁村や伊豆の山々から何万というひとがてんでに団扇を腰にはさみ大社さしてぞろぞろ集って来るのであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三島大社のお祭りの日には、きっと雨が降るとむかしのむかしからきまっていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎兵衛が二十二歳のときのお祭りの日は、珍らしく晴れていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
