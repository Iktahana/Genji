[
  {
    "uuid": "4ff5fb55-f731-5392-a20c-10b3b6860c31",
    "entry": "思い惑う",
    "reading": {
      "primary": "おもいまどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
