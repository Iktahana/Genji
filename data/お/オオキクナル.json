        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "顏が大きくなると、よつぽど氣をつけなければ、人に傲慢と誤解される。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "農鳥山は大約三峰に岐れているようだ、手近を私たちは――後の話だが――仮に南農鳥と名づけた、雪が二塊ばかり、胸に光っている、近づくほど、雪の幅が成長して大きくなる、雪の側はいわゆる御花畑で、四ツ葉塩釜、白山一華、小岩鏡などが多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方では機関部が大きくなるので積荷が自然減るから運賃の収入が減る。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後自分は両親の寝話に「児供の余り大きくなるまで守りを置くのは良くない事だ」などと話してるのを聞いたように覚えてる。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きくなるに従って物を知りたがり、卓布にこぼれた水が干上がるとどうなるかなどと聞いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなると、一面解決の端緒が見えそうになると共に、一面問題はいよいよ大きくなるでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、人は何時も少しづつ大きくなる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが化けそうに大きくなると、もう可愛いどころか、憎らしいのを通り越して何だか薄気味が悪くなりますよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子供は、少し大きくなると着物に好みが出来てくる。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに顔が大きくなると、恋愛など、とても出来るものではありません。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と叫び、金盥も打ちつづけていまして、近所近辺の人たちも皆、起きて外へ飛び出し、騒ぎが大きくなるばかりでございましたので、おまわりは、蛮声を張りあげて、二階の者たちに、店の戸をあけろ！",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかへって蜘蛛からあざけられて、熱病を起して、毎日毎日、ようし、おれも大きくなるくらゐ大きくなったらこんどはきっと虫けら院の名誉議員になってくもが何か云ったときふうと息だけついて返事してやらうと云ってゐた。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "音が近づくにつけて大きくなる、下草や小藪を踏み分ける音がもうすぐ後ろで聞こえる、僕の身体は冷水を浴びたようになって、すくんで来る、それで腋の下からは汗がだらだら流れる、何のことはない一種の拷問サ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある停留所に電車が到着する時刻の齟齬の状況は、もし個々の車の速度ならびに停留時間の平均誤差が与えられれば、容易に計算する事ができるが、要するに出発点からの距離が大きくなるほど大きくなるのは明らかである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平均の球形からの偶然な統計的異同 fluctuation が、一度少しでもできて、そうしてそのためにできた高い所が低い所よりも生長する割合が大きくなるという物理的条件さえあればよい。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ近づくメッサーの姿が窓ガラスに映ってだんだん大きくなるのが印象的な迫力をもっている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欷歔の声漸次大きくなる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもどうも曇りがとれるどころかだんだん大きくなるらしいのです。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはだんだん大きくなるようです。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはだんだん大きくなるやうです。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと大きくなるよ」　「ああ、ほんとうにそうだね、大きくなったねえ。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと大きくなるよ」「ああ、ほんとうにそうだね、大きくなったねえ。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海月に黒い影が添って、水を捌く輪が大きくなる。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が明けても、二人は帰って来ませんので、騒ぎはいよいよ大きくなるばかりです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたが大きくなるにつれ、あの人を父親であるようにあなたに信じさせることに依って、段々私自身もそんな風な夢や錯覚の中でなぐさめられようとつとめました。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　木が大きくなるにつれて、幸福な気持も高まってきました。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、大きくなるにつれて、だんだん、がまんができなくなりました。",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私は、姉の体を食べても大きくなる事が必要だったのだ。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "机を光に向け直して坐った、頭はやはり冴えているし、想念もおなじしずけさにあった、けれども風のふきとおるような心の空隙だけは、時を経るにしたがっておおきくなるように思えた。",
              "citation": {
                "source": "日本婦道記",
                "author": "松の花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
