        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の方はと云へば、尠くとも叔母の目には、中学を出たつきり上の学校へも行かず、十年ブラブラしてゐるブラ公なのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君ちやん（僕の名、実は君介、どうもブラ公みたいな名ですよ）どうも遅くなつて御免よ、富田の奥さんがいろんな話をしなさるから、あとからあとから話しなさるから。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがまた不思議に癒る（心は悪くないが、浅墓であることの象徴みたいだと予てブラ公はさう思つてみてゐるのである）。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けばその後また横浜の小学校に転任したさうであるが、ナニ、ブラ公なぞが訪ねた所で誰が喜ぶものでもあるまい。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この公平な理解と見識では、詩壇の最も高い純粹鑑賞に劣らなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はさういふ意味のことを、可成り大膽に公言した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな田舍臭い百姓歌の主人公が、灯ともし頃に羽織をきて、新宿の宿場を漂泊して居るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛公が議会で、日本主義というのは、なんですか？",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "円の面積を算出する公式も、鶴亀算の応用問題の式も、甚だ心もとなくいっそ代数でやればできるのだが、などと青息吐息の態とやや似ている。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、妙な美談の主人公になろうとして、こんな事を言っているのではありません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は馬場と上野公園内の甘酒屋で知り合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が講義のあいまあいまに大学の裏門から公園へぶらぶら歩いて出ていって、その甘酒屋にちょいちょい立ち寄ったわけは、その店に十七歳の、菊という小柄で利発そうな、眼のすずしい女の子がいて、それの様が私の恋の相手によくよく似ていたからであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の晩秋、ヨオゼフ・シゲティというブダペスト生れのヴァイオリンの名手が日本へやって来て、日比谷の公会堂で三度ほど演奏会をひらいたが、三度が三度ともたいへんな不人気であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は馬場との約束どおり、午後の四時頃、上野公園の菊ちゃんの甘酒屋を訪れたのであるが、馬場は紺飛白の単衣に小倉の袴という維新風俗で赤毛氈の縁台に腰かけて私を待っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち不勉強の学生たちを気の毒に思い、彼の知識の全部を公開する事は慎しみ、わずかに十分の三、あるいは四、五、六くらいのところまで開陳して、あとの大部分の知識は胸中深く蔵して在るつもりでいたのだろうけれども、それでも、どうも、周囲の学生たちは閉口した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は五反田駅前の公衆電話で、瀬川さんの御都合を伺った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼稚園は兼六公園の傍の北陸幼稚園であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼六公園で驚いたのは、大和武尊の銅像であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日だけの休暇を楽しむ、可憐な奉公人の子供は、何の夢を見ていることやら、と言う意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲公英の忘れ花あり路の霜　小景小情。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽春の日に、蒲公英の咲く長堤を逍遥するのは、蕪村の最も好んだリリシズムであるが、しかも都会の旗亭につとめて、春情学び得たる浪花風流の少女と道連れになり、喃々戯語を交して春光の下を歩いた記憶は、蕪村にとって永く忘れられないイメージだったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風馬堤曲に歌われた藪入りの少女は、こうした蕪村の詩情において、蒲公英の咲く野景と共に、永く残ったイメージの恋人であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も昔は同感だったが、今の考で見れば、子規の蕪村ビイキが公平を失しているように思われる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新古今集の和歌は、亡び行く公卿階級の悲哀と、その虚無的｜厭世感の底で歔欷しているところの、艶に妖しく媚めかしいエロチシズムとを、暮春の空に匂う霞のように、不思議なデカダンスの交響楽で匂わせている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公ラスコリニコフの心理と言行とが、小説の最初から大尾まで、魔法のやうに僕の心を引き捉へて居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕はニイチェを讀んで居たので、あの主人公の大學生が、ナポレオン的超人にならうとイデアした思想の哲學的心境がよく解り、一層意味深く讀み味へた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白痴」を讀んだ時は、主人公の精神病的な異常氣質が、たまたま僕とよく酷似してゐる點があるので怖くなつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、その小説の主人公である白痴の貴族が、丁度その僕と同じ精神変質者であったからだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
