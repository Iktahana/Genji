        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いつかの大嵐には黒い波が一町に余る浜を打上がって松原の根を洗うた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪の江丸さへ無事であつたら、私が巧く舵をとつて、直ぐに日本まで送つてあげるのだが、此前の大嵐の晩に、とうとう磯に打上げられて、めちや／＼になつて仕舞つたから、今更何といふても仕方が無い。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間程前の大嵐で、発動機船がスクリュウを毀してしまった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎから、海は大嵐になった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、大切な書籍をその上に詰めて、再びどつしりと鎧を背中に背負ふと、いつにも覚えたことのない不思議な自信を感じて、ぬつと、葦の繁みの中から大嵐の中へ立ちあがつた。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る年の秋、大嵐のために折れて倒れて、凄まじい響きに近所を驚かした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして拙者のやうに多年先生の御指南をうけてゐる者は、血が沸くの、胸が躍るのといふのを通り越して、腹のなかには絶えず大嵐が起つてゐて、腸が引つくり返りさうだ。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその後、幾年かの年月をたってある大嵐の日にその娘は一人のひどく奇怪な老婆となって家人に会いにやってきた。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "△地名の読み方の珍らしさ、大嵐など。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大嵐は佐竹の原の中のすべてのものを散々な目に逢わせました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために佐竹の原はたちまちにまた衰微れてしまって、これから一賑わいという出鼻を敲かれて二度と起ち上がることの出来ないような有様になり、春頃のどんちゃん賑やかだった景気も一と盛り、この大嵐が元で自滅するよりほかなくなったのでありました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大仏の末路のあわれなはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の事ではっきりとは覚えていないのだが確か安元三年四月二十八日位であったと思うが、風の物すごく吹いている日で、遂には大嵐となった日の事である。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、閨を共にする男へなんぞの色気は、大嵐の中へ吹き飛ばしたかのように、自分一人で涙を楽しんでいる風なのだ。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は冬の事で、サア出帆した所が大嵐、毎日々々の大嵐、なか／＼茶椀に飯を盛て本式に喫べるなんと云うことは容易な事ではない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何したのかと思うと、前夜の大嵐で、袋に入れて押入の中に積上げてあった弗、定めし錠も卸してあったに違いないが、劇しい船の動揺で、弗の袋が戸を押破て外に散乱したものと見える。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださえ立てつけの悪い古い家が、秋の大嵐ですっかり曲って、玄関の格子戸さえすらりとはあかなくなった。",
              "citation": {
                "source": "日々の映り",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三田は何と云つていゝか一寸躊躇したが、「何時か蟒女史の大嵐の時、びしよ濡にした一張羅を仕立直して貰つた人の話をした事があつたらう……」「あゝあの……」　横合から蟒が感嘆の聲をあげたが、あゝあの淫賣かと云はうとしたので、あわてゝ自分で口を押へて、「へえ、あんたでしたか。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい風が吹きつけてきて、今にも大嵐になりそうでした。",
              "citation": {
                "source": "強い賢い王様の話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉のような帆前船で、大嵐のただ中を通るんだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十九日は大嵐の日で、老体の医者は、来てくれなかったので注射も出来なかった。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嵐の後のように塵のかかった売れのこり品だけ。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘達は大嵐の起ろうとする前一刻の死んだ様な寂寞に身を置いて居る様な不気味さで互に袂のかげで手を堅く握り合ったり肩をぴったりすりよせたりして、何かたくらんで居るらしい若者の群を臆病に折々見合って居た。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嵐の前の静けさとは、まさにこのことだ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ大嵐のはじまりだぞ」　すると司令は、「勇士ピート一等兵。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嵐の様に通り過ぎた一度きりの史実が、其子孫或は其世近く移り住んだ人たちの、次の代あたりからは、もうすつかり忘れられた。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大嵐の中では、僕などは微々たるソヨ風、第一、半年間二十四時の怨霊に痛められた肉体というものは、旋風と化するほどの酒をうけつけてくれません。",
              "citation": {
                "source": "安吾巷談",
                "author": "巷談師退場",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、石田村の畷道の活劇は大嵐のあとのように一通り済みましたが、一つ済まないのは、役人たちの手で水田の中へおっぽり込まれた、問題の長持の後始末です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの研究所の入口に当たる設備は、悉く大熱火の為、大嵐の為、跡方も無く拭い去られた。",
              "citation": {
                "source": "暗黒星",
                "author": "シモン・ニューコム",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓らが二百十日の大嵐にもたとえて恐怖していたのも、またその勅使代理の一行であった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "というわけで　２しゅうかんのあいだは　そのままでしたが、　とうとう　おおあらしが　やってきて、　きの　てっぺんを　ふきとばし、　うえに　おっきな　あなが　あいて、　なかへは　あめが　はいりほうだい。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
