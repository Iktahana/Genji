[
  {
    "uuid": "6a99b4f8-8457-528c-acae-7668d3f0a7a4",
    "entry": "お風呂に入る",
    "reading": {
      "primary": "おふろにはいる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to take a bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お風呂に入るについて知りたいことがあります。",
              "source": "幻辞"
            },
            {
              "text": "あ、お風呂に入るがありますね。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るというのは何ですか？",
              "source": "幻辞"
            },
            {
              "text": "これはお風呂に入るの例です。",
              "source": "幻辞"
            },
            {
              "text": "彼女はお風呂に入るが好きです。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るを使ってみます。",
              "source": "幻辞"
            },
            {
              "text": "昨日、お風呂に入るの話を聞きました。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るはどういう意味ですか？",
              "source": "幻辞"
            },
            {
              "text": "このなかにお風呂に入るがあります。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るは日本語で大事な言葉です。",
              "source": "幻辞"
            },
            {
              "text": "毎日お風呂に入るについて考えています。",
              "source": "幻辞"
            },
            {
              "text": "先生はお風呂に入るの定義を説明しました。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るの使い方は難しいですね。",
              "source": "幻辞"
            },
            {
              "text": "研究ではお風呂に入るが重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るについてもっと詳しく知りたいです。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化でお風呂に入るは大切です。",
              "source": "幻辞"
            },
            {
              "text": "会社でお風呂に入るについて相談しました。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るという概念は興味深いです。",
              "source": "幻辞"
            },
            {
              "text": "本を読むとお風呂に入るの説明がありました。",
              "source": "幻辞"
            },
            {
              "text": "お風呂に入るを正しく使うことが大事です。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "カメラを離しているのは、お風呂に入るときだけだった。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お風呂に入ると、女中が湯をくみに来ながら、手紙が来て居ると云う。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも朝から低温室にはいっていますので、夕方七時頃迄やって、宿へ帰って熱いお風呂に入ると、もうぐったりしてしまうものですから」という話である。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどお風呂に入るようなもので、浴槽の外にいて湯をかけていたのではなかなかからだが温まらない。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて粹な女の人だけは、おふろにはいる時も、小唄の女の氣持ちでね、なんて、千九百三十年なのに――",
              "citation": {
                "source": "春",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
