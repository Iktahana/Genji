[
  {
    "uuid": "2b2e4300-859b-5b28-9e68-f26c3ed0cacc",
    "entry": "応酬",
    "reading": {
      "primary": "おうしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "exchange (of words, views, punches, cups, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "また若しこの一文が芥川氏に読まれる事を本旨とするならば、私がこれまでに述べた処のものを大概読んでゐてくれ、「妖婆」や「南京の基督」の如きに就いては私信で議論の応酬さへしたのだから、その反覆は氏にとつても退屈以上のものではないに違ひないからである。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、時には自己に迫つてくる処の者に対して、冷たいばかりの鋭さを持つた智の閃きで応酬する。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "初対面の時、じいさんとばあさんとは、相手の七むずかしい口上に、どう応酬していゝか途方に暮れ、たゞ「ヘエ／＼」と頭ばかり下げていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、山崎が、いつかの冗談への応酬をしていると感じながら、殊更、気づかぬ振りをしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」傍で、中尉と木谷の応酬を見ていた柿本は、決意と憤怒を眉の間に現わしながら、ぬッと、銃を握って立ちあがった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この驚愕は自分をして当面の釣場の事よりは自分を自分の心裏に起った事に引付けたから、自分は少年との応酬を忘れて、少年への観察を敢てするに至った。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを通り越して来たものは人力の如何ともすべからざること、人力以上のもののあること、それらを体験的に弁えた人であるが故に、我執も除かれ、万事、実相に明らかな眼で誰人とも応酬出来る。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "運悪く隣に坐った吉井正太郎より、例によってネチネチと、最近発表した小説をけなされている最中だったので、その方の応酬に大童であった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「借りろと言っても、借りませんよ」　信吉もすかさず応酬した。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」佐野君にしては上乗の応酬である。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その生命力はまた子の成長後かの女の愛慾との応酬にあまり迫って執拗だ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子などには反語で皮肉な応酬をするやうに、いつからか癖のやうになつて来た。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二人の応酬は、いつもこのやうに軽く、水際立つて罪が無く、巷間に言ひ伝へられてゐるやうな陰鬱な反目など私たちにはさつぱり見受けられませんでした。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも東北人は、こんな時、猿も筆のあやまりなんて、おどけた軽い応酬が出来なくて困るよ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬るか、斬られるか、真剣抜打の応酬なくんばあるべからざる処を、面壁九年、無言の行だ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "池上が例によって顔の色を蒼ざめさせ、盃の運びが早くなると反対に、嘉六は赭ら顔が少し赭い度を増した程度で、盃もだん／＼応酬の数の間をうろ抜いて行きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、違った職業の人々がおの／＼その望んで来る話題に於て満足ゆくよう応酬した。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の目がねに叶うという妻は少くとも芸人の妻として四方八面へ自在に応酬して、所帯持ちもよく、その上親孝行の嫁に外ならなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唄うほどに踊るほどに、打拳、弄弁、挑みかゝる満座の芸人と八面応酬してこれを斬り靡かすのに何の雑作もなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「バクチと色事は黙ってしなきゃア、意味ないよ」　京吉はそう応酬していたが、しかし顔色は蒼白になっていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に六十銭が七十銭になり、七十銭が八十銭となり、瞼を上げ下しするだけの無言の応酬の中に、到頭一円に迄相場がせり上げられて了った。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に痛快極まる両将の応酬ぶりである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この応酬など戦国時代の古武士の風格が偲ばれる。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ですが、先刻のハンカチーフをお返し下さいまし……」　相手のあざやかな応酬に、新子はポッと赤くなりながら、さっきから返しそびれてキレイに畳んで懐にしまっていたハンカチーフを返した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕は彼とちょっと二三語応酬し、あの短い通諜を書く、好意ある許しを得たのだった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　松代は応酬しながら寄って行った。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん我々の生存を便宜にする為に、複雑霊妙な応酬作用や代償作用が行われるのであるから、器分非器分の増減関係は必ずしも正比例的にのみには発生しない場合がある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕自身もこんなことは一度言っておけばいいことで、こんなことが議論になって反覆応酬されては、すなわち単なる議論としての議論になっては、問題が問題だけに、鼻持ちのならないものになると思っている。",
              "citation": {
                "source": "片信",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "和辻君の『応酬』といふ文は、思ひ切つていろいろなことが言つてあつて面白い。",
              "citation": {
                "source": "孤独と法身",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "社交的応酬は余り上手でなかったが、慇懃謙遜な言葉に誠意が滔れて人を心服さした。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
