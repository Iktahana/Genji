        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "人々は驚いた、豊吉のあまりに老いぼれたのに。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミューズの女神も一片のチョコレットの前には、醜い老いぼれ婆にすぎないんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんどは自分が食いかく）ミューズを老いぼれ婆にしくさったチョコレットめ、芸術家が今｜復讐するから覚悟しろ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでも土用干の着物が色とり／″＼、私は何を干さうか、支那の何とかいふ奇人のまねではないが、破れ法衣に老いぼれ身心でも干さうよ、いや現に干しつゝあるではないか。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに悪徳と冒険を誇り合い、やがて薄汚い無能の老いぼれに墜落させ合うばかりです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わあっはっはっ、と無気味妖怪の高笑いのこして立ち去り、おそらくは、生れ落ちてこのかた、この検事局に於ける大ポオズだけを練習して来たような老いぼれ、清水不住魚、と絹地にしたため、あわれこの潔癖、ばんざいだのうと陣笠、むやみ矢鱈に手を握り合って、うろつき歩き、ついには相抱いて、涙さえ浮べ、ば、ばんざい！",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "住職は痩せ細つて老いぼれてゐた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人の一生の念願とした晴れの姿は、この老いぼれた驢馬に跨り、とぼとぼ進むあわれな景観であったのか。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き頃、世にも興ある驕児たりいまごろは、人喜ばす片言｜隻句だも言えずさながら、老猿愛らしさ一つも無し人の気に逆らうまじと黙し居れば老いぼれの敗北者よと指さされもの言えば黙れ、これ、恥を知れよと袖をひかれる。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「老いぼれのぼんくらは、若い才能に遭うと、いたたまらなくなるものさ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して私が、老いぼれのぼんくらであるかどうか、今に見せてあげる。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この老いぼれ犬、どうも素振りが怪しい怪しいと思っておれば、こんな処でばてれんをやってけつかる」　為作は顔をあげた。",
              "citation": {
                "source": "放生津物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――若夫婦のところへ、こんな老いぼれの他あやんが居てみイ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前みたいな老いぼれのあんぽんたんでも、南方へ行けるのんか」　他吉は聴いて口惜しがり、「――どうせマニラも陥落したこっちゃし、マニラへも行くんやろ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんを女房にするまでまだ老いぼれてゐないよ」と、渠は憤慨してその婆々アを追ひ歸してから、暫く足を拔いてゐることも、義雄は渠から話されてよく知つてゐる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お前みたいな老いぼれのあんぽんたんでも、南方へ行けるのんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話掛けたのは、貴様の老いぼれた顔を見たくないからだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで崑は、「妻をもらって親をよろこばすことができないなら、ないほうがいい、老いぼれ蛙に怒られたって、災難を受けて死ぬまでだ」　と言ってまた十娘を出した。",
              "citation": {
                "source": "青蛙神",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを見るに、前者は若者で、後者は年寄りだがそれほど老いぼれてもいない人物と言えましょう。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふもとの村から崖を眺めるとはしっている馬の姿に似ているからと言うのであるが、事実は老いぼれた人の横顔に似ていた。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人にして梅を探る者あらば、必ずや意氣地なき老いぼれにはあらず』と陳べ立つれば、『そんな村夫子的御説法は眞ツ平なり』と冷かす。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ねこう老いぼれちゃ、こんな稼業をやってるがてんでうそなれど、事務長さんとボンスン（水夫長）とがかわいそうだといって使ってくれるで、いい気になったが罰あたったんだね」　といって臆病に笑った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いぼれたようになった馬はなつかしげに主人の手に鼻先きを持って行った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この老いぼれが隠しだてしていたのでござります」「なにッ、えッ――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "このかいわいをなわ張りの女按摩がござんすのに、ご用といえばいつもこの老いぼれをお呼びですから、男は死ぬまですたりがないとみえますよ」「むだ口をたたくに及ばぬ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに面目のないしだいでござりまするが、この子たちの嘆きをまのあたり見聞きいたしまして、いかにもふびんでなりませなんだゆえ、老いぼれの身にくふうもつかず、子を捨てろと教えたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をいうにも行き先はわからず、居どころ隠れどころもわからぬ人を呼び返そうというのでござりますゆえ、そんなことでもするよりほかに、この老いぼれにはよいくふうがつきませなんだのでござります」「いかさまな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷はたいして広くはない、築土新吾と先刻の取り次ぎ、奥にいるらしい老いぼれ武士、家内はどうやら三人らしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「墺太利皇帝は老いぼれの馬鹿者だな。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬養木堂は、自分の政友会入りを弁疏して、「おれも老いぼれて、おまけに金がないもんだで……」といつたさうだが、そんなことをいはなければならないとしても、も少しいひやうがあつたらうと思はれる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
