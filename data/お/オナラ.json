        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なにかと　もうしますと、ほかでも　ありません、おおきな　はげしい　おならを　する　ことで　あります。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうは　がちょうさんの　たんじょうびですから　おでかけ　ください」「あ、そうですか」「ところで、いたちさん、ひとつ　おねがいが　あるのですが」「なんですか」「あの、すみませんが、きょうだけは　おならを　しないで　ください」　いたちは　はずかしくて、かおを　まっかに　しました。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたちが　おならを　しなかったからで　あります。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、いたちさんが、おならを　したいのを　あまり　がまんして　いたので　こんな　ことに　なったのです。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを　なおすには、いたちさんに　おもいきり　おならを　させるより　しかたは　ありません」　やれやれ。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "客はひとり残されて、暗憺、憂愁、やるかたなく、つい、苦しまぎれのおならなど出て、それもつまらない思いで、立ち上って障子をあけて匂いを放散させ、「あれわいさのさ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、けなすことのすきな亀菊さんが「まるでゾウのおならみてえだ」といいましたので、林平さんは気をわるくしました。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことをいっても亀菊さんは、じっさいにゾウのおならを聞いたことなどありはしなかったのです。",
              "citation": {
                "source": "和太郎さんと牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、何処か見当の付かぬ処で、大きなおならの音がした。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――墓地のなかでおならする人、どう思うの。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お墓へ来て気がゆるんでおならをする人なんて。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は咄嗟の間に、おならの嫌疑を甲野氏にかけてしまった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側には山毛欅、いたやかえで、斎※樹、おおなら、大葉柏などの落葉喬木類が密生していた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分がおならひとつしたことを書いても、それが大きい活字で組まれて、読者はそれを読み、襟を正すというナンセンスと少しも違わない。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がおならをするのと、田舎出の小者のおならをするのとは、全然意味がちがうらしいのである。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒土には黄いろい草が萌え、いたやかえで、おおなら、かしわなどの木の芽が芳しい香りを匂わせていた。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人がぷうとおならをする。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少年に口説かれた女が際どい瞬間におならをする、その為に折角醸されたエロチツクな空気が消滅する、女は妙につんとしてしまふ、不良少年も手が出せなくなる――大体かう云ふ小説だつた。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木氏の小説に出て来る女工は必しもおならをしないでも好い。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし中戸川氏の小説に出て来る女は嫌でもおならをする必要がある。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇治拾遺物語によれば、藤大納言忠家も、「いまだ殿上人におはしける時、びびしき色好みなりける女房ともの云ひて、夜更くるほどに月は昼よりもあかかりけるに」たへ兼ねてひき寄せたら、女は「あなあさまし」と云ふ拍子に大きいおならを一つした。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼女はずるい目つきでわれわれを眺めながらスポンという音とともにおならを発しました。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰だか、しきりにおならをした。",
              "citation": {
                "source": "山を想ふ",
                "author": "水上瀧太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三田さん、昨晩は女衆の寢言や齒ぎしりやおならをきかされて、ようやすまれへんでしたやろ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで英語をおならひする事が出来た。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私等はこれから家事を此の先生におならひすることになりました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
