[
  {
    "uuid": "dfffd095-1256-56d7-b641-22f09ec6b5ae",
    "entry": "お持ち帰り",
    "reading": {
      "primary": "おもちかえり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
