    "definitions": [
      {
        "index": 1,
        "gloss": "to make a sound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "舎監になつたが、夜になると時々寄宿生の誰かが便所へ行く音がするきり何にも聞こえないと此の間の手紙には書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関先に夫らしい足音がすると、先刻から火鉢に凭つて時計ばかりみてゐた妻君は、忙しげに立ち上つて玄関に行つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷で鼠が物をかじる音がするから見に行ったら、床の真中に鏡が薄くくらがりの中に淋しく光っていた。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明りを消して寝ようとしていると窓外に馬の蹄の音とシャン／＼／＼という耳馴れぬ鈴の音がする。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、カチ、カチ、と音がする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれあれ、何だか火が燃えてゐるやうな、パチパチボウボウつて音がするぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふわけで、朝な朝な、此のお家では箒の音がする時に、台所では竈の中で、とろとろと火が燃えてるのでありました。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた針葉樹林を駈け下りる、水の音がするすると、樹の間を分けて上って来るようだ、水！",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入っては、私は虫が嫌いなので、障子を締め切ってしまうと、あっちでも、こっちでも障子の外で、カサカサカリカリと忍び音がする、嘴や鬚で、プツリと穴を明けて、中を覗き込んで、呪っているのではあるまいかと、神経が苛々する。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は吉田口の五合目に一泊したが、夜中絶えず、人声と鈴音がする。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体の地面よりは一段高い芝生の上に小さな猪口の底を抜いて俯伏せにしたような円錐形の台を置いて、その上にあの白い綺麗なボールを載せておいて、それをあのクラブの頭でひっぱたくと一種独特の愉快な音がする。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も声を掛けなかった、三人も菓子とも思わなかったか、やがてばたばた足音がするから顔を出してみると、奈々子があとになって三人が手を振ってかける後ろ姿が目にとまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝炊きに麦藁を焚いてパチパチ音がする。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一瞬間、それらの物音が途絶えてひつそりとすると、私の頭上の何處かで、窓を開けるらしい音がするのでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人宿だけに亀屋の店の障子には燈火が明く射していたが、今宵は客もあまりないと見えて内もひっそりとして、おりおり雁頸の太そうな煙管で火鉢の縁をたたく音がするばかりである。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、やはり夜明けごろに窓外の池の汀で板片を叩くような音がする。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って来ると、またチャブンという音がする。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少し経て、チッチッという音がすると、パッと火が現われて、彼は一ツの建物の中の土間に踞っていて、マッチを擦って提灯の蝋燭に火を点じようとしているのであった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "音がするのだから、音が聞えるのだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず病室の長い廊下のはるかに遠いかなたで時々カチャンと物を取り落としたような音がする、それから軽くパタ／＼／＼とたとえば草履で廊下を歩くような音も聞こえる。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴の奥でひとしきりゴオと風の音がすると、焔は急に大きくなって下の石炭が活きて輝き始める。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くで角笛の音がする。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりそこに立ったまま、「ポチ、食え」足もとで、ぺちゃぺちゃ食べている音がする。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は意を決して、友人の頬をなるべく痛くないように、そうしてなるべく大きい音がするように、ぴしゃん、ぴしゃんと二つ殴って、「君、しっかりし給え。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつちこつちで音がする。",
              "citation": {
                "source": "どらが鳴る",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれが木葉落ちつくしたころならば、路は落葉に埋れて、一足ごとにがさがさと音がする、林は奥まで見すかされ、梢の先は針のごとく細く蒼空を指している。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下では何ともいいようのない優しい水音がする。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸の方では燈火一つ見えないで、磯をたたく波の音がするばかり、暗くしんとしている。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "また真剣を上段から打ちおろす時にピューッと音がするようでなければならない。",
              "citation": {
                "source": "「手首」の問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々紙のがさつく音や重い物を疊の上に置く音がする。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
