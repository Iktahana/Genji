        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "父の住居｜附きのオフィスは年々｜寂寥を増した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人間が急行列車桜、高速力巡航船、ホテル、トーキー常設館、オフィス、レストラン、冬期競馬場、少女歌劇場、それらの場所にいたあらゆる階級人が、驚愕するような事件が勃起した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズや弁証法的唯物論のはやる都会でも、朝顔の鉢はオフィスの窓に、プロレタリアの縁側に涼風を呼んでいるのである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィス、デパート、工場、映画館、はだかレヴュウ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見送っていると、ふと向う側のビルディングのオフィスから、一人の男がじっとこちらを見つめているのが眼にはいった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、この辺の横町は、大小｜旧舗の問屋筋が、表附を現代のオフィス風に建て改めたのが多く、退勤時間以後は防火扉を卸して町並は黝み渡っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その板囲いが外れたところに表附はオフィス風で、何の変哲もありませんが、その造作を越したうしろに聳えている蔵造りの家が集まってるらしい瓦屋根は、勾配を四方八方へ幾つにも分ち下ろして、なにさま大きな旧家の住宅に見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュクサックを肩に、一晩泊りのハイキングに出るオフィス・ガールや青年達。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "謄写版の歴史をたどった『ガリ版文化史』の共著者、志村章子は、堀井親子が生きた「明治期のオフィス革命は、今日よりも激烈」だったと書いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはまさに本じゃないか」いっぺんにそう確信したスタッフは、パワーブックの中の本を、オフィスの仲間たちに見せて回ります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の値段の高い東京のそれでなくても狭いオフィスに、あんな図体のＰＣが何台入るか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時点でＤ博士の頭には、オフィスの中核マシン的なイメージがあった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "小型のコンピューターで、プロの作った雑誌や書籍並みの手の入ったページを作ろうとする所謂デスクトップ・パブリッシング（ＤＴＰ）には、オフィスへのＵＮＩＸの進出のきっかけとなる可能性があった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失敗してもいいから何か自分達でやろう」　東芝の子会社で、船舶の電気関係を取り扱う西芝電気に職を得ていた浮川は、一九七九年、オフコン（オフィスコンピューターという和製英語の略。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めてのオフィスは、徳島の初子の実家の応接間。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「Ｂは、オフィスの仕事を持つてゐるから日曜日だけしか遊べない。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにＹのオフィスは、あの建物の六階にあるんだから恰度好い。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の母はナッソー街に下宿屋を営んでオフィス通いの人たちに賄付きで間貸しをしていたのである。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の生産拡充の要求は、これまでならばオフィス・ガールになったであろう若い婦人たちを生産面での活動に迎えると同時に、もとならば、紡績工場へ年期の前借で売られて行った村の娘たちを、機械工業に吸収して「旬日ならずして熟練工化せんとする」方向にあらわれて来ている。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、醜として撮影された部分が人生の情景として、感情をもって見れば常に必しも醜ではなく、首都の美観の標本として示されたものの中には、却って東洋における後進資本主義の凡庸なオフィスビルディングの羅列のみしかないのもあった。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、一日の朝オフィスへ着て出た服のまま、昼夜ネクタイも取らずに吉報を待って電話の傍らに立ちつくした。",
              "citation": {
                "source": "チャアリイは何処にいる",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも君という人間は妙に出来ているんだな」　私がこういい終つた途端、ベルが鳴つて訪問者がオフィスの戸の外に立つてることを報じた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も一緒にこれから彼のオフィスに行くつもりなのである。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこんなことを考えているうちに、車は早くも藤枝のオフィスの前に止つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オフィスにはいると、彼は先ず机の上に積まれてある手紙に目を通したがやがてその中の一通をとり出した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だのにわが藤枝真太郎はこのオフィスで、一向あわてる様もなく何か悠々と机に向つて書いているではないか。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じやあした朝オフィスへ来給え。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤枝氏曰くどうも面目次第もありませんだつてさ」「おい、くだらぬことを云つておらずにさつさと出て来いよ」　こんな会話が一応電話で行われてから私はすぐに彼のオフィスにかけつけた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一誰からかかつたかも判らないんだ」「女だつてね」「そう、たしかに女だそうですがね」　私はこの時、十七日の午後、藤枝のオフィスの電話口できいたあの不気味な女の声を思い出して思わず戦慄したのである。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでともかくオフィスの方に来てもらうように云つたのだが、君もすぐに事務所の方に行つてくれないか」　無論私は喜んで出かけることにした。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
