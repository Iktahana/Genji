    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oak",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "反省が入れば入る程尚更その窮屈がオークワードになります。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近者北米オークランド湖畔の一友遙かに書を寄せて曰く、飛電｜頻々として戦勝を伝ふるや、日本人の肩幅｜日益日益広きを覚え候ふと。",
              "citation": {
                "source": "渋民村より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月××日　シドニイにて　自分で自分に休暇を与え、五週間位の予定でオークランドからシドニイへ遊びに来たのだが、同行のイソベルは歯痛、ファニイは感冒、自分は感冒から肋膜炎。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ先生、まったく別物で、オークランドにいる伯父のネッドが遺産でわたくしにと。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顏・晝顏・夕顏等、其名の如く其時に開き、西洋でもオシロイ花を、開く時に因んで、四時（フオワ・オークロック）と呼ぶ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「オークシヨン・マーケツトの悪商人が、烏の嘴を絵具で染めて、九官鳥に見せかけたが声を出されると大変だつたからギユツと喉笛を握つてゐると、苦悶の烏がしやがれた叫びを挙げた――そのやうな声だ。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして水夫のような仕事にはとても役に立たないから、幸いオークランドに小農地を持ってとにかく暮らしを立てている甥を尋ねて厄介になる事になったので、礼かたがた暇乞いに来たというのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人がきまりがわるさうに黙つてフオークを運んでゐたさまを思ひ起した。",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村屋かちくせんあたりの小紋風な浴衣をきた好い女房が、これはまた何んとしたことかドロンウオークの長襦袢をきてゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説でもなささうだ、魔術の練習かしら、不思議な人達だ――と私と女房は首をかしげたが、懸物が現はれたり、花瓶が運ばれたりして、それが周囲の人達の手に渡されてゐるのを見てゐるうちに、漸く私が、「オークシヨンだよ。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ俺は、俺のライフ・オークに取り掛るんだ。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロミオとジユリエツト」の中では、ジユリエツトに「マンドレークが地から抜き取られた時の如き叫び声、これを聞く凡ての者が気違ひになる叫び声」といはしめ、「ヘンリー四世」の中でもサツフオークをして同じやうのことを言はしめて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "心理学上の識覚について云って見ても、識覚に上らぬ働き（アンダー、コンシアス、ウオーク）が幾らあるか知れぬ。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらが、ケントやオークランドあるいはニューハンプシャーといった所に置かれたとしても、年代的には少しも違和感はないであろう。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "たか子は手先きが莫迦々々しいほど震へてフオークを持つことも出來なかつた。",
              "citation": {
                "source": "或る女",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇兄さんのお描きなつた海の風景と、チヨコレートにボンボン、コテイのオークルジヨン、雑誌が二冊、とても私の嬉しさ楽しさ、空想してみて下さい。",
              "citation": {
                "source": "谷間からの手紙",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中のオークルジョスや青緑のペンキか何かが塗られた古風な木造の洋館がトンボ釣りの私の心をいたく刺戟したものであった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "オークランドには世界平和デー委員会が設けられ、次でニューヨークには、広島を世界のピース・センターにせんとの委員会が設けられた。",
              "citation": {
                "source": "ヒロシマの声",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュージーランドの首府オークランド市に、チェイマン学校という学校がある。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それすらもう水煙｜微茫の間に見えなくなって、オークランド岡のいただきも地平線の下にしずんでしまった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "オークランド岡が森の陰にきえたとき、一同の顔にさびしい色がうかんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうです、それはぼくらです」「よし、それでは諸君のために、航路を変じてオークランドに直航し、諸君を本国へ送ることにしよう」　情けある船長のとりはからいにて、これから一路｜平坦砥のごとき海上を談笑指呼のあいだにゆくことになった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船はぶじオークランド湾についた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "オークランドの市民は、イバンスのために義捐金を集めて一せきのりっぱな商船を買い、これにチェイアマン号と名をつけておくった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、夏の末になつてから、外人に賣りつけに立派な洋犬を何匹もつれてきてゐた犬屋が、輕井澤ホテルで賣殘りの犬のオークションをやつたことがあつた。",
              "citation": {
                "source": "高原にて",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『郵船テナシチイ号』『巡礼』『欠けた人間』『ミシェル・オークレエル』これらの作を通じて見たるヴィルドラックは、その厳密な写実的手法を裏附けるに、かの詩人のみが善く為し得るところの「魂の直感」を以てした。",
              "citation": {
                "source": "仏国現代の劇作家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて、自分は、フオークで肉を刺すぐらゐのことは心得てゐながら、わざわざ手づかみで食ひ、それが却つて、「えらい」と思ふ、さういふ手合が、まだその辺にゐるやうですが、さういふ気もちもわかるにはわかるが、あまり大人げない。",
              "citation": {
                "source": "島国的僻見",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
