    "definitions": [
      {
        "index": 1,
        "gloss": "to fall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「落っこちる人は、あんたじゃなくってボーイやほかの野郎ですよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいやつが、かばわれるために、小さいやつが落っこちるのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ジュール・ラフォルグの詩にあるように哀れなるかな、イカルスが幾人も来ては落っこちる。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れなるかな、イカルスが幾人も来ては落っこちる。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「溝へ落っこちるわねえ。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼやぼやしてると落っこちるよ」「へいッ」　平吉は階段をあがって往った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が落っこちる心配はねえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀貨の価値が落っこちると、金塊相場が続騰した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何うだろう、彼の白痴が寝て居た寝台がなくなって床へ夫だけの穴が開いて居る、全く、彼の寝台が陥穽で、床が外れて、寝て居る人ぐるみ下へ落っこちる様になって居るのだ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し綱が切れて高い所から落っこちると、あたい死んじまうよ。",
              "citation": {
                "source": "梨の実",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "足を掴んでてやらないと、落っこちるぞ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、河に落ちた者から救いを求められる時、河に落っこちるような粗忽な者には危なくて手は差出されぬ、なんかと。",
              "citation": {
                "source": "失策記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清の事を考えながら、のつそつしていると、突然おれの頭の上で、数で云ったら三四十人もあろうか、二階が落っこちるほどどん、どん、どんと拍子を取って床板を踏みならす音がした。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなの、高いとこから落っこちる時、わあっと声をたてるようなもんじゃないか。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、あっし達の献納した愛国号の働きも、一向無いと見えて、この爆弾の落っこちることァ、どうです。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友は、一旦、寝床にもぐり込もうとしたが、また起き直って、荷物と、槍とを、念入りに一応調べて枕許へ置き並べると、襖を隔てての道庵が、「べらぼう様、這い出してみたところで、そう易々と落っこちる道庵とは、道庵が違うんだ」と、寝言のように言いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "チュガよチュガよチュガ公よそらそらそちらを行っては海へ落っこちるもう少しこちらをあゆびな竜燈の松が見えるよ洲崎は近いよお嬢さんが待っている金椎君も待っているチュガよチュガよチュガ公よ　　　　　　　　　十二　かくて、まだ朝といわるべき時間のうちに、早くも洲崎の、駒井の陣屋まで帰って来てしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "横棒が渡してあるので、馬も人も、舞台から落っこちる心配はありません。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがのあたしもすっかり照れて、頭を掻こうとしたひょうしにあぶなく胸壁から落っこちるところだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつっこんだのが枝に木切れの山で、落っこちるのおしまい。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつっこんだのが枝にかれ葉の山で、落っこちるのおしまい。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理の美しさ、酒のうまさ、私は久し振りのせいもあったでしょうが、頬ぺたが落っこちるのではないかと思いました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいのやら、小さいのやら、かろうじて見えるくらいのやらが、次から次へと上がってきては、みんな同じように落っこちる。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「危ねえよ、友様、そう前へ出ちゃあぶねえよ、落っこちると下だぜ」といって道庵は、窓から身をのり出した米友を、しっかり後ろから抑えました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぶねえよ――友様、冗談じゃねえぜ、落っこちると下だよ」　道庵は、ほとんど必死で米友を抑えましたが、米友はそれを顧みず、「うーむ」　もう一寸前へのたり出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身投げをする柄でもないようだし、そうかといって、捨てて置けば海へ落っこちるところを助けてやったお礼も言わず、かえって、「ちぇッ」と舌打ちを一つして、そのまま、あられもない方へ、とっとと走り出した若い者の挙動を見て、呆れ返らないわけにゆきません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは山のてっぺんから穴の底へ落っこちるような気持を経験したことがあるかい、夢にでも見たことがあるかい？",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だけど、あの子はすぐに氷の割れ目にでも落っこちるぐらいのとこだろうな。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、ときには、石みたいに、地上に落っこちるかとおもわれるほどの早さで、さっと舞いおります。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も何遍やってもおっこちるんですよ」　そう言ってＫ君は笑いました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
