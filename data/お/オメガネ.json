        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もっとも、奴さんはその工場でたった一人の大学出だということも社長のお眼鏡に適ったらしいんだが、なに、奴さん大学は中途退学で、履歴書をごまかして書いたんですよ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお眼鏡を掛けていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう表情は役所へ上司が監察にやって来る時、官吏連の顔によく現われるもので、どうやら最初の恐怖も消え去り、大体のところはお眼鏡にかなったとみえ、長官がしまいに軽口を叩いてニコニコしながら、何か一言二言いわれたりすると、ぐるりを取りまいている側近の役人連はそれに答えて二倍も笑う。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "へぼ役人どもはみんな、局長のお眼鏡にとまりたさが一杯で先を爭つて駈け出して行つたが、おれは一寸も席を動かなかつた。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変らずお眼鏡で御座いますわねえ。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上のお眼鏡まで、汚すではないか」　右源太が、こういった時、襖を開けて、足早に入って来た一人が「昨日の大作は、本物でないぞ、あいつは、大作の弟子の関良輔という人物じゃ」「ええ？",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "（医者が、侍臣が十分に、手を尽しても、助からぬのだから、何も、妻の手落ちばかりというのではないが――重役の方々のお眼鏡に叶って、御乳母役に取立てられたのに、その若君がおなくなり遊ばされた以上は、のめのめ夫婦揃って、勤めに上ることもできん。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんのお眼鏡に叶った養子というのは、藤井善一という陸軍三等軍医正、私より十二歳上の人でした。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "お眼鏡をこはしておしまひになつたの。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいりがけに、お眼鏡を外して、拭かうとなすつたらしいの。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "八洲子　　そのお眼鏡の方がお似合ひになつてよ。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ結婚しないでゐるといふのも、未亡人が淋しがる点もそれはあるかも知れないが、まあ姉さんのお眼鏡で話を探してゐるからだよ。",
              "citation": {
                "source": "朧夜",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長のお眼鏡に適つた君の言葉としては、少々受け取り兼ねますね。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、ここは畑違ひぢやないの」「だからさ、大臣のお眼鏡で、是非つていふわけだつたのよ」「ふうん、あんた好みの青年紳士だわ」「あべこべ言つてるわ。",
              "citation": {
                "source": "悪態の心理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お眼鏡持って来ましょうか。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお眼鏡にかなったのが、寮の隣室にいた三宅正太郎（のちの名裁判官）と、山本寛太郎君（正金銀行）と、そして私の三人だった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "布引銀行の社員で、眉目秀麗、才智縦横の好青年、鳥井純一というのが頭取のお眼鏡に叶い、相互の耳にも入れて、もう吉日を選ぶばかりになっていた。",
              "citation": {
                "source": "恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これならお眼鏡にかなう。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜叉王　あつぱれとの御賞美は憚りながらおめがね違ひ、それは夜叉王が一生の不出來。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんなだんな、おめがねどおりだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめがねどおりにござります」「これなるご不幸のおかたは？",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかもおめがねどおりてまえの仕組んだ狂言でござります」「そうだろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめがねどおり、親方を殺した下手人は、いかにも、この梅丸でござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめがねどおりでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあんばいじゃ、おれが出る幕じゃねえらしいな」「ところが、おめがね違い、足もとから火が出たんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもおめがねどおり、紅屋の手代幸助と申す者でござります」「と申す者でござりますだけじゃ恐れ入り方が足りねえや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おめがねどおり、古島のまがい雛をこしらえたのは、この無月めにござります」「ほほう、おぬしもさすがに名のある江戸の職人だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうじゃ、違ったか」「いいえ、おめがねどおりでござんす」「するとなんじゃな、やっぱりあの一番は、わしのにらんだとおり八百長ではなかったのじゃな」「ええ、もう八百長どころか、どうしてあんな遺恨相撲になったかと、いっしょうけんめいそれを思案していたのでごんす」「ほほうのう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのとき早くも秀の浦の殺意を見破り、あのような番狂わせの相撲となりましたゆえ、口さがない下司下郎をなまじ生かしておかば、のちの災いと存じまして、わたしが秀の浦をおびき出し、四ツ谷見付の土手ぎわで、おめがねどおりあやめたのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「しからば――」「なんでござります」「専介を討ったは辰に相違ないが、辰を切ったはほかに下手人があると申すか」「いえ、おめがね違いでござります」　当然の帰結として、伊豆守の下した推断を名人は軽く押えると、ずばりと言い放ちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
