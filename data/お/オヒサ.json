        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と、中の一人が彼方見て「まァ親分が」　と云えば他の二人も出て来て三人揃って「親分お久し振り」　半次を伴った五郎蔵の親分然たるところ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お久しいね、甚三さん」と云って、今度はかやの方に向直って、「おかやちゃん、これ（と云って若者を指さして）が松戸村（南の村落の名）の笛吹きの甚三さんですよ」とかやの、下げ髪の上に優しく手を置き乍ら、前屈みに顔をのぞき込んだ。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十「小主公お久振でござりました、よく私の声にお覚えがござりますな。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那、お久しゅう。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだって、様子を見ただけでも、お久しぶりとも、第一、お早う、とも言えた義理じゃありませんわ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分お久しぶりにお目にかかります」「田舎へ入って仕舞ってどちらへも御無沙汰ばかりです。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子の手紙一　秀雄様、お久し振りね。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、その声は楓どの」　さすがに覚えていてくれたかと、「お久しゅうございます」「…………」　普段おしゃべりの佐助が鉛のように黙っているのを見て、何故こんなに変っしまったのかと楓はあやしく心が乱れて、まるでその変り方はこの楓を嫌ってしまったせいだろうか。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お点けなされませ」そして笠の中を覗いて、「伊右衛門さんお久しゅうござります」　伊右衛門は驚いた。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……これは又……どうして……」「お久しゅう御座います」　若侍は美しく耳まで石竹色に染めて眼を輝やかした。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところがここに又、左様な天下の御威光を恐れぬ無法者が現われました……と申しますのは、その御免状を盗みました掏摸の女親分で御座いまして、当時江戸お構いになっておりました旅役者上りの、外蟇お久美と申しまする者が、その評判に割込んで参いりましたそうで……」「うむ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお久美と申しまするは、まだ二十歳かそこらの美形と承りましたが、世にも珍らしい不敵者で、この評判を承りますると殊の外気の毒がりまして、お相手のお名前は妾が存じておりまする。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久し振りですから」　とか何とかバツを合わせながら障子の蔭で鼻の頭をイライラさせつつ、急いでゆっくりとお茶やお菓子を出します。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――一別以来、さて余りにもお久しい。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ああ、ああ、さてお久しいことやぞや、お懐しい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ねえ、お久しい……二十……何年ぶりですか。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……お久さんから便りがあったのでしょう、兄さん。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お久さんだけ、一人だけよ、一人だけなら逢っても可いんでしょう、どう？",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳んだ風呂敷を持ったまま、「兄さん、お久さんは家へ来ます。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、お久さんか。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久という人は、やっとその火鉢の縁へ、鬱金の袖口を引張って、「……思ったより、あんさんは若いこと。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お久という人はまた袖を顔に当てた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄さん――さあ、お久さん……こちらへ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者になる隙があったら、――お久。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お久という人は、きょとんとしていた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯の灯も黄に白に、菊見の客が帰ったあとで、皆が揃って座敷へ入った時、お久という人は、自分の椀小皿をきれいに食べて、箸を置いて、そうしてうしろ向きで膳の上を拝んでいた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――座敷では人顔の朦朧とするまで、蟹の脳味噌の再び煮返る中を、いつの間にか、お久という人は、帰りしなに……「ちょっと」……で八郎を呼出して、連込んだものらしい。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お久という人の、めんてんの足袋で帰るのを、立合わせた台所から、お悦が送り出すと、尖った銀杏返を、そそげさして、肩掛もなしに、冷い頸をうつむけて、雨上りの夜道を――凍るか……かたかたかたかたと帰って行く。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真中に、尖った銀杏返で胸を突出しながら、額越に熟とこちらを視たのは、昨日のお久という人で、その両傍から躍り出した二人の少年が、「久の息子です、伯父さん。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、幸い、……いや推量のごとく、お久という人たちとは席が離れていた。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
