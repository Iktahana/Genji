[
  {
    "uuid": "ab36289b-1fb0-50bb-997c-17c76e3ec5d9",
    "entry": "思いやる",
    "reading": {
      "primary": "おもいやる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
