          "literary": [
            {
              "text": "「お午にはおまごつきになつたでせうね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女の方からそう尋ねかけて、私の顔をじっと見入ってきたので、私はなおまごついてしまった。",
              "citation": {
                "source": "黒点",
                "author": "――或る青年の「回想記」の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相閣下はあのとおり丈夫な方で……いや、しかしこのような温気には初めて遭われて、おまごつきかもしれない。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいこんがにんじんのようだったら、八百屋はおおまごつきだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
