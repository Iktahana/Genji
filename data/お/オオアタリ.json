        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なかんずく大評判、大当たりは、滝の白糸が水芸なり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度は大当たりだそうだな」と、兼松は笑いながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おちついているようだが狂ったか」「ところが大当たり。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも一般の観客はそんなことに無頓着で、この興行は大入り大当たりであった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「塩原多助」が大当たりを取ったので、その盆狂言には「牡丹燈籠」を上演することになったのである。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り分けて菊五郎は主人公の藤吉郎よりも、二タ役の馬丁幸吉の方が好評で、五幕目小村井梅屋敷の場で主人の跡部甲斐守（松助）に嚇されたり賺されたりして、藤吉郎の秘密を口外する件りは、松助の跡部と共に大当たりであった。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸時代には小説作者と狂言作者とのあいだに一種の不文律があって、非常に大当たりを取った小説は格別、普通は小説を劇化しない事になっていた。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　バケツは　大当たり。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "また寺院の方にては、伯州東伯郡の山間のある寺より金を借りて商法すれば、必ず大当たりであるとて、諸方よりこの寺に参詣して金を借り、一年の後にこれを二倍にして返納する所があると聞いている。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど滞在中、その家の婦人が、「近日に出産をするが、今度はぜひ男子の生まれるようにしたい」と申しておるから、余は大磯で筮竹を取り大当たりしたから、ここでも筮竹で男女を当ててやろうと思い、早速八卦を見たところが、男子が生まれる卦が出てきた。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがどうだね、大当たり大成功だね。",
              "citation": {
                "source": "乞はない乞食",
                "author": "添田唖蝉坊",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずや、我が友人ホークスと、チャレンは多数決の意志に従うことでしょう」「多数が大当たりだ」　とチャレンが率直に言った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ババは頭が切れるし、芸も大当たり。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご存知のように、私の生涯の夢は大当たり劇を書くことです。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
