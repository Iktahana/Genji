[
  {
    "uuid": "c44c820f-4fd6-55cd-a1e7-6f30f1845513",
    "entry": "お祖父さん",
    "reading": {
      "primary": "おじいさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grandfather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お祖父さんという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお祖父さんの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお祖父さんという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お祖父さんは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お祖父さんの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お祖父さんは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お祖父さんはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お祖父さんの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お祖父さんが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お祖父さんのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お祖父さんに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お祖父さんの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お祖父さんは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お祖父さんの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうすると黙ってそばに見ていた孫娘が急に老人の袖を引いて『お祖父さん帰りましょうお宅へ、ね帰りましょう』と優しく言った。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、僕は大沢先生の宅を初めて訪ねたが、別にあやまるほどの事もなく、老先生はいかにも親切にいろいろな話をして聞かして、僕は何だか急にこの老人が好きになり、自分のお祖父さんのような気がするようになった。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして外から見るとは大違い、先生の家は陰気どころかはなはだ快活で、下男の太助はよく滑稽を言うおもしろい男、愛子は小学校にも行かぬせいかして少しも人ずれのしない、何とも言えぬ奥ゆかしさのあるかあいい少女、老先生ときたらまるで人のよいお祖父さんたるに過ぎない。",
              "citation": {
                "source": "初恋",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "トシオの直ぐ傍の欅の瘤根に腰をかけて、真白い髯を房々と手でしごいて居るのは、もう五年も昔に、トシオの家から死んで行って仕舞われたお祖父さんではありませんか。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、死んだお祖父さんではありませんか」「ハハハハハハ死んだお祖父さんなんて云うか、トシオ！",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは決して死になんぞせないのに」　お祖父さんがトシオの驚きを、大笑いに笑う時、さらさらと波打つ銀の様な髪の毛は、五年前のトシオの家に居たお祖父さんと、少しも変りはありません。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですけれど僕、たしかに五年前に、僕の家から死んで行って仕舞ったお祖父さんのこと、覚えて居るんですもの。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕にあ、お祖父さんの生きてることが、信じられないのです」「それはそうじゃ、わしはたしかにお前の家で五年前に死んで、人間の世界からは、消えて仕舞ったのじゃ。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわしはその時から、直に「原始の国」という処へ、生れ変ったのじゃ」「ああ、そうですかお祖父さん。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお前達の生きて居る世界の王様でもあられるのだ」「だってお祖父さん。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前達の世界の人達は、あんまり長く神様を見ようとしなかったので、すっかり瞳が曇って仕舞ったのだ」四　お祖父さんに曇って居ると云われた自分の眼を、トシオは幾度も、しばだたいて見ました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた改めてトシオは、お祖父さんの瞳を覗きました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お祖父さんの瞳は、神様を見ることが出来たので、それでそんなにすきとおって来たのですか」「ああ、そうだ」「そしてお祖父さんはいつでもその神様の国でそんなに、長い着物を着て、銀の杖をついて居るんですか」「いいや、いつでもというわけもない。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その国ではな、一つの魂が、いつも同じ一つの形で居なければならないと云う様な不自由なことは無いのだ」「ではお祖父さん。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はお祖父さんの形が、人間になる日に当るんですか」「なに、今日がその日ともかぎらないのだよ。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、人間のお前に逢いに来るには、人間の形でなければいけないからな」「じゃあお祖父さん。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に何か用でもあってですか」　トシオは曇って居ると云われたことも忘れて、その眼をくりくり丸くして、一層、お祖父さんの顔をみつめました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父さんはそれを見て、よけい声を高めて笑いましたが、やがてまた、きっと、トシオの方を向いて、今度は厳かに、「トシオ、まったくだよ。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはな、神様を忘れて居る人間の中で毎日迷ったり悲しんだりして、不愉快に暮らして居るお前を救ってやろうと思って、今日はまた昔のわしの形になって、お前の処へやって来たのだよ」　斯う云ってお祖父さんは、懐から一つの筒形の眼鏡を取り出して、トシオに与えました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分不思議な眼鏡なんですねお祖父さん」「いや不思議でもなんでも無い。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眼鏡のなかには、人間が始めて神様につくられた時のありさまを、すっかり、フイルムに仕立てて仕舞ってあるのだからな」「お祖父さん。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父さんは、すっくと立ち上って、トシオの眼の前に現れて来るフイルムの説明を始めました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父さんが今手に取り直した、銀の杖を、きらりきらりと振る度にフイルムは廻転してゆくのでありました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　以下しばらくは、フイルムについて、お祖父さんの説明ばかりが続きます。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは「原始の国」に立って居られる神様のお姿だ」　とお祖父さんは云いました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれは神様が或日、たったひとつお生みなされた御秘蔵の玉子なのだ」　お祖父さんの説明はだんだん進んで行きます。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、お前に見せることは済んだのだ」　と云い乍ら、お祖父さんはトシオの取り落した眼鏡を、拾い上げて丁寧にチリを払って、懐へ入れてしまいました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何せ、お嫁さんのおじいさんは、槍の名人だそうですからね、大隅君だって油断は出来ません。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の夏休み中で、一番｜面白かったのは、おじいさんと一緒に上の原へ仔馬を連れに行ったのと、もう一つはどうしても剣舞だ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさん、今来る。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
