[
  {
    "uuid": "929f52d3-2f6d-5ffc-bd18-d39c4956ec4e",
    "entry": "応用",
    "reading": {
      "primary": "おうよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
