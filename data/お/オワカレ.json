        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんなに良いお天気の日に　　お別れしてゆくのかと思ふとほんとに辛い　　こんなに良いお天気の日にさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "溜息ばかり出て、何を言つてもしらじらしく、いつそもう、この邊でお別れしてしまひたいやうなものだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がこんなことを申してはおかしいですが、政夫さんとお民さんとは、あアして仲好くして居たのを、何かの御都合で急にお別れなさったもんですから、それからというもの、お民さんは可哀相なほど元気がないのです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お半、少時お別れだ」　「どうしたの？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドン停車場に於ける別離が妾達の永遠のお別れとなったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロオズ夫人にお別れした妾は、当分モスコーで暮すために旅装を整えて二つの彫像を二個のトランクに入れて、巴里停車場に車を走らせました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は即座にカバレット・トア・ズン・ドルにお別れを告げると、ローヌ河でパンツを洗濯してすっかり清浄な心と魂を持つ女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――リー・シー・ツワン、お別れがきました。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時過ぎ資生堂の前で先生とお別れした。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜店を見に行くとおつしやる先生とまだお別れしたうもない心持だつたが、だんだん強くなつてくる息苦しさには勝てなかつた。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この団体がここを引上げるという前夜のお別れの集りで色々の余興の催しがあったらしい。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はそれでお別れ申しましたが、二月に又お詣りをいたしますと、和尚様はわたくしの顔を見て、又同じやうなことを云つて溜息を吐いておいでになりますので、わたくしも何だか不安心になつてまゐりまして、『それはどうした譯でございませう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お別れにたゞ一言ご忠告いたします。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから空のみなさんにお別れしましょう。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではお別れいたします。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変に失礼ですけど、故伯爵とお別れになった後の貴女は、非常に皮肉な御生活をお始めになったようですね。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もうじき来年になるのだが、それまでにはまだ時間があるから、そこらでお別れに御馳走を食べようじゃないか」「それはいいね」　二人はそこらの御飯屋へ行って、御飯を食べ始めました。",
              "citation": {
                "source": "犬のいたずら",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はお別れの宴会ですから、皆さんは何でも思う存分に演説をして下さい。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや、槍の穂先も見えぬげに御座れば、残念ながらこれにてお別れ申そう」「いや、某もさように存じておったところ……」「さらば」「さらば」　というのでドロンゲームになったが、後にこの二人は某侯の御前で出会して、本名を名乗り合って莫逆の友となった……というような話が「常山紀談」に載っている。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ婆やいよいよお別れだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのフイルムのなかの人間は、神様にお別れしてから、どうしたの」「まあお聞き。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というて、このままお別れ致すのも心残りで御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泣いて、そのお別れの杯を頂きましょう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでね、僕は少し向うへ行かなくちゃいけないから今日はこれでお別れしよう。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南極はここから八千七百ベェスターだねえ、ずいぶん遠いねえ』なんて云っている、僕たちもふり向いて、ああそうですね、もうお別れです、僕たちはこれから北極へ行くんです、ほんの一寸の間でしたね、ご一緒したのも、じゃさよならって云うんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "濱島は船の舷梯まで到つた時、今一｜度此方を振返つて、夫人とその愛兒との顏を打眺めたが、何か心にかゝる事のあるが如く私に瞳を轉じて『柳川君、然らば之にてお別れ申すが、春枝と日出雄の事は何分にも――。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、一たび、二たび、お答へ申しましたが、四邊は眞の闇で、何處とも分らず、其儘永いお別れになりました。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴方、弥弥お別れですわ。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、つらさに、僕は、あなたと、おわかれしようと思ったのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "華麗豪壮の、せめて、おわかれの場を創りあげたかった。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
