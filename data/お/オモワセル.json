    "definitions": [
      {
        "index": 1,
        "gloss": "to make (someone) think (that ...)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "菜の花や昼ひとしきり海の音　前と同様、南国風景の一であり、閑寂とした漁村の白昼時を思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「揃ふて」という言葉によって、一家｜団欒のむつまじい平和さを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閣に座して遠き蛙をきく夜｜哉「閣」というので、相応眺望の広い、見晴しの座敷を思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の詩情には、古い故郷の家を思わせるような、あるいは昔の祖母や昔の家人の、懐かしい愛情を追懐させるような、遠い時間への侘しいノスタルジアがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓上の鮓に目寒し観魚亭「卓」という言葉、また「観魚亭」という言葉によって、それが紫檀か何かで出来た、支那風の角ばった、冷たい感じのする食卓であることを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に冬の日の薄ら日和を感じさせ、人生への肌寒い侘びを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "莟みの集団の下から、房になった黄色い四弁花が、いま電燈の蒼い光にきらびやかに匂っている、茎は一皮下には、青い血が通っているのではないかと思われるほど透き通って、有らゆる春の緑の中で、最も練り抜かれた緑である、見つめていると、早春の名残といったような淡い哀愁に加えて、物の末期の惨酷を思わせる姿である。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暁を思わせるうす紅色で、雨気を含んだ虚空に、浸み透るように、暈して描かれた自分たちの印画は、この大なる空間を跨いで、谷間へと消え落ちた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の宿屋というものを、思わせる「糸屋」と看板を出した旅籠屋には、椽側に紡車を置きっ放しにして、ひっそりかんとしている、馬車はここで停まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに上吉田は、明藤開山、藤原｜角行（天文十年―正保三年）が開拓して、食行身禄（寛文十一年―享保十八年）が中興した登山口だけあって、旧｜御師町らしいと思わせる名が、筆太にしたためた二尺大の表札の上に読まれる、大文司、仙元房、大注連、小菊、中雁丸、元祖｜身禄宿坊、そういった名が、次ぎ次ぎに目をひく。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思わせるあるものがこの作者の歌の何処かにある。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩の五言、七言の連続も、何かしらある遠い関係を思わせる。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見ると電灯かと思わせる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に籠れる歇気を吐くのであろうか、夜中に凝る乳を粒立たすのであろうか、とにかく、この湧玉をみて、そして峯を仰ぐとき、確に山の眼覚めを思わせる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スクリーンにこの光の舞踊を思わせるものが適当に映出される。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして枕もとの時計のチクタクだけが高く響く、あるいは枕に押しつけた耳に響く脈搏を思わせる雑音を聞かせるのもいいかもしれない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に私のこの希望を正当と思わせるもう一つの見地がある。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思わせるだけの根拠は相当にある。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまたマレイの「コータ」堡塁とのある関係を思わせる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "古いドイツやスペインあたりを思わせるような空気が、最も新しい西欧芸術の香と混合してそこに一種のグロテスクに近いものが生れている。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう絵には、そういつまでも同じようなものを描き続け得られないだろうと思わせるある物がある。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同じ顔を見た時の印象が、見なかった時の印象を掩蔽してそう思わせるのかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうではないか、と思わせるだけの根拠は、外の方面にいくらでもありはしないか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、原始時代を思わせる悲惨なものだった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃は河鹿と同じくそのころの渓間をいかにも楽しいものに思わせる鳥だった。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つはその家の打ち出した廂なのだが、その廂が眼深に冠った帽子の廂のように――これは形容というよりも、「おや、あそこの店は帽子の廂をやけに下げているぞ」と思わせるほどなので、廂の上はこれも真暗なのだ。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の空気のなかに窓を明け放ち、乗客も程よい電車の内部は、暗い路を通って来た私達の前を、あたかも幸福そのものが運ばれて其処にあるのだと思わせるような光で照されていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれで打ち切ってしまうのは少し危険であると思わせる理由がいろいろ他の方面から供給されるようである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧がすっきりと霽れて、前には笠ヶ岳の大尾根が、赭っちゃけた紅殻色の膚をあらわし、小笠から大笠へと兀々とした瘤が、その肩へ隆起している、遠くの空に、加賀の白山は、いつもの冷たい藍色に冴えて、雪の縞が、むしろ植物性の白い色をおもわせる。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、やがてふたたび春の近さをおもわせるような日がかえって来た。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
