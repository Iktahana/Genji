        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お零れという言葉は、様々な文脈で用いられる重要な表現である。",
              "source": "幻辞"
            },
            {
              "text": "彼はお零れの意味について深く理解していた。",
              "source": "幻辞"
            },
            {
              "text": "お零れを正しく使用することで、より自然な日本語の表現ができる。",
              "source": "幻辞"
            },
            {
              "text": "この文献ではお零れという概念が中核的な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "お零れの用例は、古典文学から現代文まで幅広く見られる。",
              "source": "幻辞"
            },
            {
              "text": "日本語学習者にとって、お零れは習得すべき重要な表現の一つである。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景を考慮すると、お零れの意味がより明確に理解できる。",
              "source": "幻辞"
            },
            {
              "text": "お零れと同義語の使い分けについては、細かい注意が必要である。",
              "source": "幻辞"
            },
            {
              "text": "学術的には、お零れは複数の関連する意味を持つことが知られている。",
              "source": "幻辞"
            },
            {
              "text": "口語表現において、お零れはしばしば省略形で用いられる。",
              "source": "幻辞"
            },
            {
              "text": "お零れの語源を追うと、興味深い言語史の一部が見えてくる。",
              "source": "幻辞"
            },
            {
              "text": "現代の日本語では、お零れの使用頻度は比較的高い傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "医学や科学の分野では、お零れが特定の技術用語として定義されている。",
              "source": "幻辞"
            },
            {
              "text": "お零れを含む表現は、詩歌や文学作品で特に効果的に使われることがある。",
              "source": "幻辞"
            },
            {
              "text": "会話の文脈によって、お零れのニュアンスが微妙に変わる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "辞書によっては、お零れに複数の定義が記載されている場合もある。",
              "source": "幻辞"
            },
            {
              "text": "お零れの使用は、特定の社会階層や世代と関連していることもある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的分析により、お零れの文法的性質が明らかになっている。",
              "source": "幻辞"
            },
            {
              "text": "お零れは、日本語能力試験などの言語試験でも重視される語彙である。",
              "source": "幻辞"
            },
            {
              "text": "同じ意味でも、お零れの代わりに別の表現を選ぶことで、印象が変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "満洲や台湾の苦力や蕃人を動物を使うように酷使して、しこたま儲けてきた金で、資本家は、ダラ幹や、社会民主主義者どもにおこぼれをやるだろう。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏滸がましゅうござりますが、従って手前どもも、太夫様の福分、徳分、未曾有の御人気の、はや幾分かおこぼれを頂戴いたしたも同じ儀で、かような心嬉しい事はござりませぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏滸がましうござりますが、従つて手前どもも、太夫様の福分、徳分、未曾有の御人気の、はや幾分かおこぼれを頂戴いたしたも同じ儀で、恁やうな心嬉しい事はござりませぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、おこぼれさえもちょうだいできねえというんで、ええくやしい、腹がたつ、憎いはこの地蔵とばかり、たちまち女の一念｜嫉刃に凝って、こんなよからぬわるさをしたにちげえねえですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々読書、おのれに籠つておのれを観た、労れると柴茶をすすつた……今日も午後はおこぼれ夕立があつた、めつきり涼しくなつて、夜明けは肌寒くさへ感じた、夜無水居を訪ふ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会ファシストは天皇制の正体を蔽うこの偽瞞的議会のおこぼれをたたえ、労農大衆に議会による救済、議会の勝利による労農大衆の勝利等の幻想をふりまいている。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "他国を侵略することにより主として利益するものは、少数の支配階級権力階級に止まり、それ以外の一般民衆は、たか／″＼そのおこぼれに霑ふに過ぎず、しかも年百年中、圧制政治の下に窒息してゐなければならぬ。",
              "citation": {
                "source": "小国寡民",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等のおこぼれで食ってるのは何だ？",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気違い景気のいく分のおこぼれにあずかり、彼も小市民らしい遊蕩をやった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官庁のおこぼれを拾って跟いて歩く一連の人民たちであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おこぼれを頂戴したその成りあがりものはそう自己弁護するのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの大将の儲けなんぞは、そのおこぼれでたくさんだ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その熱線のおこぼれが、うしろについているテイイ事務長にあたり、それで事務長は「暑い、暑くてかなわん」とさわいでいるのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって自分の仕事を始め、ブルジョアのおこぼれで、先代よりは表面運動多き生活をする。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この居候連中は宿屋や酒場にいりびたって、使い走りをしたり、いろいろ半端仕事をして、台所の余り物や、酒場のおこぼれにしこたまありつこうという算段である。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみればそれほどでなし花の山というところだろう、景気はまったくの跛景気で、今松のような素寒貧にまで分かち与えられるおこぼれはとうていなかった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義企業の利潤率が低下したので、その利潤のおこぼれで支持される民間調査機関の財源が苦しくなったのである。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大いに反省し環境に従って一段の飛躍を遂げるのでなかったら、せっかく独自の位置を築いて来た中村屋が、今後百貨店のおこぼれを頂戴する悲運に陥らぬとも限らぬ。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さて、今度は、そうしてできた新政府を横暴だ倒せなんどと騒いでいるのが、自由民権か何か知らねえが、とんかく、おこぼれば頂戴出来なかった軽輩あがりや物持のせがれ、それに少しばかりお調子もんの貧乏人のせがれが尻馬に乗ってるくらいのことよ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らはわしのうまい考えのおこぼれを食うジャッカルだ。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し法・明・立の諸大学は何と云っても、精々おこぼれを頂戴しているに過ぎない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は東洋の番犬である任務をはたして、それに対するおこぼれを期待してシベリア出兵をした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さて、今度は、そうして出来た新政府を横暴だ倒せなんどと騒いでいるのが、自由民権か何か知らねえが、とんかく、おこぼれば頂戴出来なかった軽輩あがりや物持のせがれ、それに少しばかりお調子もんの貧乏人のせがれが尻馬に乗ってるくらいのことよ。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のめあては、馬や駕籠に乗るほどでない客、ちょいとした荷物が面倒になったという客で、他人の稼ぎを横取りするとは思われない、ほんのおこぼれを貰っていると思っていたからである。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、終戦直後、ＧＩたちの、おこぼれを頂戴して飲んだ頃は、うまいなあと思った。",
              "citation": {
                "source": "清涼飲料",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "……親分様、きょうは婆もよい供養のおこぼれにあずかりましたわえ」「そう、欣んでくれると、わしも有難い。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "千歳の女将も、そのたびごとには、すくなからぬおこぼれを頂戴した。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
