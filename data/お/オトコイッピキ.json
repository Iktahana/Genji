        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "妹はいはゆる女子供のたぐひで固より論にも及ばぬが、自分は男一匹、しかも大小をたばさむ身の上である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「男一匹、そんなに弱くてよくこの世の中に生きて行けますね。",
              "citation": {
                "source": "市井喧争",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹が、雄々しく闘って行く姿！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹、泣きながら書きました。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼光をはじめ、鎮西八郎、悪源太義平などの武勇に就いては知らぬ人も無いだろうが、あの、八幡太郎義家でも、その風流、人徳、兵法に於いて優れていたばかりでなく、やはり男一匹として腕に覚えがあったから、弓馬の神としてあがめられているのである。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの晩に、私が行って嫁にあれほど腹の底を打ち割った話をして、そうして、男一匹、手をついてお願いしたのにまあ、あの落ちつき払った顔。",
              "citation": {
                "source": "嘘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はいわゆる女子供のたぐいで、もとより論にも及ばぬが、自分は男一匹、しかも大小をたばさむ身の上である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたら男一匹がこれから何をして生くる身ぞ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "石に喰い付いても我慢しなければ男一匹とはいわれまい。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹なりゃどこにころがり込んだからって、――そんな経験もおもしろいくらいのものですが、これんばかりじゃあなたが足りなかろうと思うと、面目もないんです。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五体満足な男一匹が女や腰抜の所為をして筆屋の御奉公をして腐れ死をして了つては国家に対する義務が済むまい。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹と生れたからにゃ、たったひと晩でいいから、あんなのとなにしてみていな」「そうよな。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの体のこなしなら、袈裟がけ、一刀切り、男一匹ぐれえを仕止めるにぞうさはねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あたら男一匹がこれからは何をして生くる身ぞ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "須藤南翠氏の『江戸自慢男一匹』も出版されたが、これも劇場当事者からは顧みられなかった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹どう転んだって大したことはないと肚を作ってからでなきゃ駄目だ。",
              "citation": {
                "source": "馬頭観世音",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィー、男一匹酒ぐらい呑めないでどうする！",
              "citation": {
                "source": "夜叉のなげき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にこそ、富樫でも大事な御亭主だろうが、このひろい世間で、あんな男一匹が、という風に、母は啖呵をきった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前さんたちが男一匹で、哥薩克の働らきが出来ようなんて、とても思ひもよらないよ！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く今の日本には男一匹の交際が少ない。",
              "citation": {
                "source": "人格を認知せざる国民",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし又それと同時に…………何を糞ッ……高の知れた絵巻物の一巻に、男一匹が発狂するまで飜弄されるような事が、あり得よう筈はない……ドンナ名人の手に成った如何にモノスゴイ絵であるにしろ、要するに色と線との配合以外の何者でもないだろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいことは悲しいのですが、わたしだって男一匹だ。",
              "citation": {
                "source": "破落戸の昇天",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったんはそう思って自分を慰めてみましたが、また思ってみると、自分だって世間並の男一匹の智慧しか持っていないのに気が附かずにはいられなかったのですね。",
              "citation": {
                "source": "最終の午後",
                "author": "モルナール・フェレンツ　Molnar Ferenc",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正五年五月九日南洋旅行の途上、信濃丸船中にて新渡戸稲造第一章　男一匹神と獣類の間に立つ人　外国語では人という名詞をただちに男に代用するが、わが国において人というのは西洋のいわゆるペルソン（人格）を指し、ただちに性の区別をいいあらわさない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹とは何を意味するか　しからば男という言葉もまた人もしくは女というように善意にも悪意にも用いらるるかというに、これは奇態に悪意に用うることがほとんどない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "男一匹の活動　しかしこの柔和なれと訓うるは独り耶蘇教に限ったことでない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはまさしく男一匹の心持で活動したのである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
