    "definitions": [
      {
        "index": 1,
        "gloss": "front approach to shrine or temple",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
