    "definitions": [
      {
        "index": 1,
        "gloss": "hey!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おいおい、その綱を切つちやいかん。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこつるはしはよしたまへ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、おいおい。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ堪忍してくれ、政夫……私は民子の跡追ってゆきたい……」　母はもうおいおいおいおい声を立てて泣いている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、あの音は何だい？",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、これゃなんだい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこつるはしはよしたまえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に檜を後に潜り抜けると、私が体の上あたりへ出て下を向き、（おいおい、松本へ出る路はこっちだよ、）といって無造作にまた五六歩。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい分らないか。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが自然を系統化するために用いきたった思考形式の機巧の中に最初から与えられたものの必然的な表象を近ごろになっておいおい認識しつつあるのではないかという気がするのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言い、旦那さんは、つかつかと私の隠れている机のほうに歩いて来て、おいおい、そんなところで何をしているのだ、ばかやろう、と言い、ああ、私はもそもそと机の下で四つ這いの形のままで、あまり恥ずかしくて出るに出られず、あの奥さんがうらめしくてぽたぽた涙を落しました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おいおい、あまり失敬な事を言ったら怒るぜ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泥にうつぶして、いまこそおいおい聲をたてて泣かう泣かうとあせつたけれど、あはれ、一滴の涙も出なかつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は泥にうつぶして、いまこそおいおい声をたてて泣こう泣こうとあせったけれど、あわれ、一滴の涙も出なかった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、おきたまえ。",
              "citation": {
                "source": "二ひきの蛙",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといってね、おいおい、そこ、つるはしはよしたまえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、おいおい、そこもスコップではいけない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、笛ふき、やまねこがここを通らなかったかい。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、喧嘩はよせ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、栗の木、まだ睡ってるのか。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狐もおいおい泣きだしました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このけものかね、これはボスといつてね、おいおい、そこ、つるはしはよしたまへ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、おいおい、そこもスコツプではいけない。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、どこからこぼれて此処らへ落ちた？",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山猫博士（立ち上がりながら）「おいおい、給仕、なぜおれには酒を注がんか。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）山猫博士「おいおいそいつでなしにキャッツホヰスカアといふやつをやってもらひたいな。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山猫博士「おいおい間違っちゃいかんよ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
