[
  {
    "uuid": "3c9c845f-e0e4-504d-a272-f95d4935f2d7",
    "entry": "折助",
    "reading": {
      "primary": "おりすけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
