[
  {
    "uuid": "0e95d5c3-544c-58ef-a1c5-2d26af4834be",
    "entry": "可笑しがる",
    "reading": {
      "primary": "おかしがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
