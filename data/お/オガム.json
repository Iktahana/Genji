[
  {
    "uuid": "9abb393d-aad7-5b73-87b9-adc03112422d",
    "entry": "拝む",
    "reading": {
      "primary": "おがむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
