[
  {
    "uuid": "3aba3646-e290-5c65-a75a-5b7ab191d97e",
    "entry": "応護",
    "reading": {
      "primary": "おうご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the Buddha's help (aid, succour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いつかおれはあの男が、海へ卒塔婆を流す時に、帰命頂礼熊野三所の権現、分けては日吉山王、王子の眷属、総じては上は梵天帝釈、下は堅牢地神、殊には内海外海竜神八部、応護の眦を垂れさせ給えと唱えたから、その跡へ並びに西風大明神、黒潮権現も守らせ給え、謹上再拝とつけてやった。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではお日さまに対しておそれおおうございますので、きょうはお目にかかりません。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄上は、「そのおおせはいちおうごもっともです。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうごきに、ならないように、引金をひけば、なにもかも、それまでですよ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三たび英京ロンドンに来てその様子を見たが、年をおうごとに貧富の差が大きくなって均衡を失っている。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしなぞは6675あのお部屋へ這入るのもこおうございます。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、いつか『おうごんのとら』のとりっこで、ちえくらべをしたまほうはかせだよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまえは『おうごんのとら』だったが、こんどは、この赤いカブトムシだ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おうごんのとら』のじけんで、ぼくたちしょうねんたんていだんに負けた、あのまほうはかせだ。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうごんかめんだよ」「えっ、おうごんかめんって……」「きみたちは知らないかね。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色のかおをしたおうごんかめんという大どろぼうだよ」「あっ、あのおうごんかめん。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、なぜ、こんなおめんをばらまくのでしょう」「それは、おうごんかめんが、このへんにあらわれるぞという前ぶれだよ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっ、おうごんかめんです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぎ山先生が、いつの間にか、おうごんかめんのすがたにかわって、ふたりの前にあらわれたのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそのひとは、おそろしいおうごんかめんだったのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうごんかめんこそ、人々からこわがられていたかいじん二十めんそうなのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、竹やぶの中から、おうごんかめんをつけた二十めんそうが、ぬうっとあらわれました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうごんかめんです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへくるんだ」　二十めんそうのおうごんかめんは、そういったかとおもうと、いの上くんにとびかかってだきかかえてしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あっ、いる、いる」　おうごんかめんにばけた二十めんそうが、おばけやしきのおくへあるいていくのがみえます。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりは、法皇のおこころが第一、法皇さえおうごきにならなければ――）　うとうとと眠りぎわに彼は何か心の落着きを見つけていた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは冷然と、鳥肌にそそけ立った五百之進の顔を振り顧って、「おうご主人には、いつの間にお帰りか。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に積極的な信玄がなおうごく気色を示さず、いつも消極的な献言をする山本道鬼が、口をひらくと、明快にこうすすめたのである。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事が起ったか」「さきに、早馬をもって、伊勢からお知らせ申した儀は、情勢、まったく一変いたしましたゆえ、万一のおうごきもどうかと、自分、夜を日についで、駈け参りました」「なに。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今日のお立場は、決して、軽々しくおうごきあっていいものではありません」　美濃守がまずいうと、山県昌景もともに、「故君信玄様さえ、西征の難には実に、幾たび苦杯をなめられたか分りませぬ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍王山の本陣一万五千はなおうごかない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくは詐術でしょう」「そう疑ったら限りがない」「ともあれ、都督ご自身、おうごきあることは、賛成できません。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやなんのためにじゃ」「もし宮中の御祈祷が、関東調伏の御心などにあるといたせば、かならずや、朝廷内外のおうごきには、それ一事にかぎらず、天皇御謀反の兆しが、他にもあらねばなりません。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねがね新田は、大番上洛を望んでいたので、彼には彼の好む花を持たせ、そして、幕府方針としては、一に朝廷のおうごきに、その焦点をしぼっていたのはいうまでもない。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
