    "definitions": [
      {
        "index": 1,
        "gloss": "girl's lacquered wooden clogs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "満洲や台湾の苦力や蕃人を動物を使うように酷使して、しこたま儲けてきた金で、資本家は、ダラ幹や、社会民主主義者どもにおこぼれをやるだろう。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏滸がましゅうござりますが、従って手前どもも、太夫様の福分、徳分、未曾有の御人気の、はや幾分かおこぼれを頂戴いたしたも同じ儀で、かような心嬉しい事はござりませぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏滸がましうござりますが、従つて手前どもも、太夫様の福分、徳分、未曾有の御人気の、はや幾分かおこぼれを頂戴いたしたも同じ儀で、恁やうな心嬉しい事はござりませぬ。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角評判のいい芝居がめちゃめちゃになって、小屋の連中はおおこぼしですよ」「そうか」と、半七はうなずいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、無心そうにあちこち傍見などなさりながら、ひらりひらりと、まるで小さな翼のようにスプウンをあつかい、スウプを一滴もおこぼしになる事も無いし、吸う音もお皿の音も、ちっともお立てにならぬのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、おこぼれさえもちょうだいできねえというんで、ええくやしい、腹がたつ、憎いはこの地蔵とばかり、たちまち女の一念｜嫉刃に凝って、こんなよからぬわるさをしたにちげえねえですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々読書、おのれに籠つておのれを観た、労れると柴茶をすすつた……今日も午後はおこぼれ夕立があつた、めつきり涼しくなつて、夜明けは肌寒くさへ感じた、夜無水居を訪ふ。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会ファシストは天皇制の正体を蔽うこの偽瞞的議会のおこぼれをたたえ、労農大衆に議会による救済、議会の勝利による労農大衆の勝利等の幻想をふりまいている。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラコロ、カラコロと例のおこぼをひきずって、大きい振袖でしゃなりしゃなりと歩いているその度ごとに帯が可憐に揺れる、あの情趣が京舞妓の全生命なんです。",
              "citation": {
                "source": "絵筆に描き残す亡びゆく美しさ",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "他国を侵略することにより主として利益するものは、少数の支配階級権力階級に止まり、それ以外の一般民衆は、たか／″＼そのおこぼれに霑ふに過ぎず、しかも年百年中、圧制政治の下に窒息してゐなければならぬ。",
              "citation": {
                "source": "小国寡民",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "内大臣はそんなふうでないと私へおこぼしになったことがある。",
              "citation": {
                "source": "源氏物語",
                "author": "野分",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様子の限りなく可憐であるのを宮は御覧になっても、こんな魅力が中納言を惹きつけたのであろうとお思いになり、いっそうねたましくおなりになり、御自身もほろほろと涙をおこぼしになったというのは女性的なことである。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「逢いに来たくても私の来られない間はこれを見ていらっしゃいよ」　とお言いになり、美しい男と女のいっしょにいる絵をお描きになって、「いつもこうしていたい」　とお言いになると同時に涙をおこぼしになった。",
              "citation": {
                "source": "源氏物語",
                "author": "浮舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等のおこぼれで食ってるのは何だ？",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気違い景気のいく分のおこぼれにあずかり、彼も小市民らしい遊蕩をやった。",
              "citation": {
                "source": "一九三二年の春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様が、お母様に、お前なぜ一昨年病気したときに死んでしまわなかったのだと云って、涙をおこぼしになったのよ」とおだやかな口調で云い、云い終るときっと唇を締め、身じろぎをせず私の顔を見つめたことがあった。",
              "citation": {
                "source": "鈍・根・録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "官庁のおこぼれを拾って跟いて歩く一連の人民たちであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おこぼれを頂戴したその成りあがりものはそう自己弁護するのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」モーガンはそういったあと、夫人をふりかえり、「エルダースンさんが、酒をおこぼしになったよ。",
              "citation": {
                "source": "マカーガー峽谷の秘密",
                "author": "THE SECRET OF MACARGER'S GULCH",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの大将の儲けなんぞは、そのおこぼれでたくさんだ。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その熱線のおこぼれが、うしろについているテイイ事務長にあたり、それで事務長は「暑い、暑くてかなわん」とさわいでいるのだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえって自分の仕事を始め、ブルジョアのおこぼれで、先代よりは表面運動多き生活をする。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この居候連中は宿屋や酒場にいりびたって、使い走りをしたり、いろいろ半端仕事をして、台所の余り物や、酒場のおこぼれにしこたまありつこうという算段である。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いて、「うるさくて困るものだから」とおこぼしです。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "来てみればそれほどでなし花の山というところだろう、景気はまったくの跛景気で、今松のような素寒貧にまで分かち与えられるおこぼれはとうていなかった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義企業の利潤率が低下したので、その利潤のおこぼれで支持される民間調査機関の財源が苦しくなったのである。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは大いに反省し環境に従って一段の飛躍を遂げるのでなかったら、せっかく独自の位置を築いて来た中村屋が、今後百貨店のおこぼれを頂戴する悲運に陥らぬとも限らぬ。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さて、今度は、そうしてできた新政府を横暴だ倒せなんどと騒いでいるのが、自由民権か何か知らねえが、とんかく、おこぼれば頂戴出来なかった軽輩あがりや物持のせがれ、それに少しばかりお調子もんの貧乏人のせがれが尻馬に乗ってるくらいのことよ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴らはわしのうまい考えのおこぼれを食うジャッカルだ。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し法・明・立の諸大学は何と云っても、精々おこぼれを頂戴しているに過ぎない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
