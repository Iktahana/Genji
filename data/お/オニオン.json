        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのチューブを高志が黙ってわたし、慶一はトマトとオニオンのスライスをのせ、ケチャップをかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "このオニオンのおかげで高い音が出るのだそうですが、このボルジョリが床の中で発声練習をしているのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鈴薯が枝に実ると思つた程無智な素人が、トマト、オニオン、メロン、コルフラワアから、人蔘、カブラ、イチゴ、茄子、隠元、南瓜まで、立派に模範的に作れる様になつた。",
              "citation": {
                "source": "百姓日記",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楕円形の大きなガラスの容器に、オニオン・スライスを馬が食べるほど盛りあげたのを、テーブルに置いた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やる気がわいてくるよ」「もともと、やる気です」「そりゃそうだろうけどさ」　スライスのうえに落としてあった生卵をつぶし、ソースと混ぜあわせ、オニオン・スライスによくまぶしてから、割りばしにひとつかみ、彼は頬ばった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やる気はいいけれど、おまえ、てっきり死んだと思った」「まさか」「いや、ほんとの話」「このくらいなら、だいじょうぶですよ」　男は、オニオンにさらに卵をまぶしつつ、笑った。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「左まわりのカーブで、ブラインドなのに、おまえ、トラックに追いこしかけたんだ」「しませんよ、そんなこと」「まあいいから、オニオンを食え。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは、オニオン・スライスを、つまんだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文すりゃ、いくらでもあるんだから」　オニオンを、ぼくは、口に入れた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オニオン・スライスを頬ばり、ぼくは、神妙にしていた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もそのひとりだけど」　とおりかかった制服のウエートレスをつかまえ、彼は、オニオン・スライスのおかわりを注文した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "オニオン・グラタンが先づ及第。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタンとビーフピカタ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリルで、オルドヴルとオニオングラタン、コールドラブスターを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢はうと思ってた森岩雄も発熱して帰っちまったので、すっかりあぶれ、ホテルのニューグリルで一人で食事、オルドヴルに、オニオングラタン、雛のココット、こいつはうまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュはオニオングラタン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱になり、ホテルニューグリルで、オニオングラタンに、オルドヴル、コールビーフで食事し座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタン、舌平目の洋酒煮に、クラブハウスサンドイッチ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時半の汽車で彦根駅発、京都へ着き、宿へ帰ったが、うまいもの食ひたく、一人でアラスカへ行き、ウイスキーソーダと共に、オニオン・グラタン、ヨークハム・キャシノ食ふと、ねむくなり、ふらり／＼と宿へ帰りねる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、ポークビーンズ、ハンバクステーキに、フライオニオンとマッシュポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
