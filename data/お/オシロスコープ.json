          ],
          "literary": [
            {
              "text": "スケジュールに追われて、休日、自宅でオシロスコープを睨みながら試作機の回路をいじっていたとき、後藤氏もまたラジオを聞いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の隅に置かれたオシロスコープは今のところほとんど使ったことがないが、将来的には合成音声を自分たちのサウンドに取り入れていくつもりなので、結局は楽器の仲間入りをすることになるだろう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
