    "definitions": [
      {
        "index": 1,
        "gloss": "gentler of two paths (leading up to a shrine or temple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
