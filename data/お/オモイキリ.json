        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "手でも足でも思い切り自由に伸ばしたり縮めたりしてはね回っているけれども、その運動の均衡が実に安定であって、非常によくバランスのとれた何かの複雑なエンジンの運転を見ているような不思議な快感がある。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが咲くだけ咲いてしまえば実に思い切りよく大ふうにさらさらと風にまかせて銀砂の様に私達の歩道に、その純白の粉花を一ぱいに敷きつめてくれる。",
              "citation": {
                "source": "五月の朝の花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は息を胸に一ぱい吸い込み思い切り見上げたつもりでそこで眼を止めた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の若者が団扇太鼓のようなものを叩いて相手の競争者の男の悪口を唄にして唄いながら思い切り顔を歪めて愚弄の表情をする、そうして唄の拍子に合わせて首を突出しては自分の額を相手の顔にぶっつける。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　脚は一八〇プロセントくらいに、眼と眼はうんとくっつけるか、思い切り開いて、さてこの腕をどうやろう。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "使い慣れた古道具や、襤褸や、貯えてあった薪などを、親戚や近所の者達に思い切りよくやってしまった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐすぐずしていると、ほんものの方が乗り込んで来るかも知れないというので、無暗に支度を急いだもんですから、乗物までは手がまわらないで、飛んだ唯今のお笑い草となってしまいましたよ」と、お俊はさすがに悪党だけに何もかも思い切りよくしゃべってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "各部署の戦闘のはげしさは、負傷者の数と、思い切り無遠慮なその負傷ぶりによって完全に表現されていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首の長いガラスのフラスコの底板を思い切り薄くして少しの曲率をもたせて彎曲させたものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の知っている老人で七十余歳になってもほとんど完全に自分の歯を保有している人があるかと思うと四十歳で思い切りよく口腔の中を丸裸にしている人もある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も偉大な人物はね、自分の判断を思い切り信頼し得た人々です、最も馬鹿な奴も、また同じですがね。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕たちは、眉山のいない時には、思い切り鬱憤をはらした。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「思い切り遊ぶという約束でしたね。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あの時、印刷所のおかみさんと千葉県が、も少し私に優しく、そうして静かに意見してくれたら、私はふっつりと詩｜三昧を思い切り、まじめな印刷工にかえっていまごろはかなりの印刷所のおやじになっていたのではなかろうかと、老いの愚痴でございましょうが、しきりにそう考えられてならないのでございます。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも普通のステッキでは、短かすぎて、思い切り突いて歩く事が出来ない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コールド・ウォー　（二）　こうなったら、とにかく、キヌ子を最大限に利用し活用し、一日五千円を与える他は、パン一かけら、水一ぱいも饗応せず、思い切り酷使しなければ、損だ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる原っぱへ出ると、南を向いた丘の斜面の草原には秋草もあれば桜の紅葉もあったが、どうもちょうどぐあいのいい所をここだと思い切りにくいので、とうとうその原っぱを通り越して往還路へおりてしまった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴が清水の土地を思い切り、美濃の檜木の瑞雲寺へ入って馬翁という詩僧に従ったのは、勿論、娘と得体の判らぬ心理の関係にある、その境地から逃れよう為もあったが、僧でもなく俗でもない身持で、風雅に対してだけ快楽を求める生活が、俄に不安を増して来たからだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあるとき皆三の母親から聞いた皆三の、当分独身といった言葉は、皆三の性格としては、もっともと思えるが「何という意気地なし」というような言葉で、皆三を思い切り罵倒してやり度い気持ちがお涌に湧然として来た。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の全体は、憎らしいほど落ち付き払って、枝に残った枯葉たちは、その一つ一つ小さな背へ、やがて散る前の、最後の一時の黄金色を、思い切り太陽の光から受けて、はかな相な満足にかがやいて居ます。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからやさしい腕木を思い切りそっちの方へ延ばしながら、ほんのかすかに、ひとりごとを言いました。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「睡り薬の手違いで、こんなことになった以上、おまんもお鎌も思い切りよく別れてしまえばよかったんですが、二人にはまだ未練がある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪党のくせに、よくよく思い切りの悪い奴で、そこがやっぱり女ですね」「問題の睡り薬は、どっちの女が持っていたんです」　と、私は最後に訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、一つには、今日の彼はもう思い切り享楽の限りをつくすよりほかに、苦悩を癒やすすべがなかったから、そのためにいる金を、家から持って来させようと思ったのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、店へ返して、その金で思い切り飲みましょうか？",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシマロのように豊かな顔の輪廓に思い切り短く刈り上げてしまったお河童がちっとも不自然でなくよくうつっていた。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　桂庵は今度の上りに間に合うようにとしきりに時計を気にしていたが、お神も思い切り、簿記台を開けて、しばらく帳面を調べていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼を覗き込んで私は思い切り冷やかな笑みを浮かめた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを　なおすには、いたちさんに　おもいきり　おならを　させるより　しかたは　ありません」　やれやれ。",
              "citation": {
                "source": "がちょうの　たんじょうび",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、うれしそうな声をだして、もみの木はおもいきり、枝をいっぱいのばしました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
