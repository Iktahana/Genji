          "literary": [
            {
              "text": "「さあいかがです、そろそろお休みなさいませ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（貴僧ももうお休みなさいますか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりお休みなさい」　と言われました。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩のことに私が床を延べていますと、お俊が飛んで参りまして、『どうせ私じゃお気に入りませんよ』と言いざま布団を引ったくって自分でどんどん敷き『サア、旦那様お休みなさい、オー世話の焼ける亭主だ』と言いながら色気のある眼元でじっと私を見上げましたことなどは、ただの仕草ではなかったのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――お休みなさいまし。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お掛けなさいまし、お休みなさいましと、間近な氷店で金切声。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お休みなさいまし、お懸けなさいまし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十八「女中さん、降って来そうでございます、姫様におっしゃって、まあ、お休みなさいましな」と米は程合を見計らう。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今晩はあっちにあなたの泊まるところがありますから、そこでゆっくりお休みなさい。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、お塩梅が沢山悪いんじゃありませんか、何しろお上りなすって、お休みなさいましたら何うでしょう。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）さあ、お客さまにお休みなさいをしておいでよ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人　　どなたもお休みなさい。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "小沢は自分の名前の横に「妻雪子　二十歳」と書いて、女中に渡すと、「お休みなさい」　女中は出て行った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『中央区、二千七百九○番――お嬢さんにお休みなさいまし、とね。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "快い、さりながら、強い刺戟を感じて、早瀬が寝られぬ目を開けると、先刻（お休みなさい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が「あなたは今日はお勞れでせうからもうお休みなさい。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで後の回向も頼みます」「では、すぐ御膳をさしあげますから、それをおあがりになったら、不浄な心を出さないようにお休みなさいませ、好い時刻にお起し申します」と、主翁はこう云いながら手を鳴らして婢を呼んで膳を急がした。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「せいせい、そんな息をして……ここがいい、ちょっとお休みなさいよ、さあ。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえはお疲れであろう、早くお休みなさい。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずかに、お休みなさい！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行ってお休みなさい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔だけでも、洗ってからお休みなさい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこに枕もございますから、御ゆっくりお休みなさいませ」　と、云って女は莚をおろした。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お休みなさいまし」「ありがとう、あんたはいくつ」「十六よ」「もう、お婿さんがきまっておりますか」　女の子は怒るような口元をして笑って見せた。",
              "citation": {
                "source": "虎媛",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ですから誰もあなたにお休みなさいとは申しません。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はちよつと私用もありますししますから」「え、何うぞ――」「先生も静かにお休みなさい。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "古藤がとっさの返事に窮して、少しむっとした様子で答え渋っているのを見て取ると、葉子は今度は声の調子を落として、いかにもたよりないというふうに、「日盛りは暑いからどこぞでお休みなさいましね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねぇ村川さん、お休みなさいませ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやすみなさい、お母さん」　撃柝の音は坂や邸の多い堯の家のあたりを、微妙に変わってゆく反響の工合で、それが通ってゆく先ざきを髣髴させた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやすみなさい、お母さん」三　堯は掃除をすました部屋の窓を明け放ち、籐の寝椅子に休んでいた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
