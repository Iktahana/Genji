    "definitions": [
      {
        "index": 1,
        "gloss": "to the end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ピアノの音はこの物語の終わりまでつづいて行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労または倦怠が一たんそうしたものに変わったが最後、いつも私は終わりまでその犠牲になり通さなければならないのだった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めから終わりまで繰り返さるる怒濤の実写も実に印象の強く深い見ものである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めから終わりまで道に迷い通しに迷って、無用な労力を浪費するばかりで、結局目的地の見当もつかずに日が暮れてしまうのがおちであろうと思われる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこのような参照用の大部なものを、骨折って始めから終わりまで漫然と読み通し暗唱したところで、すでになんらかの「題目」を持っていない学生にとってはきわめて効果の薄い骨折り損になりやすいものである。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまず、始めから終わりまで見た後の自分の印象からいうと、それほどいやで見ていられないような場面や、退屈で腹の立つような長町場もない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側で新聞が読めるか読めないかというくらいの明るさの時刻が開花時で、開き始めから開き終わりまでの時間の長さは五分と十分の間にある。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は黄褐色、冬は灰鼠の色に、春先は暗紫色になり、そして春の終わりから夏の終わりまでは一色の緑を刷く雑木林の丘だった。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この航海日誌をつけ始めたとき、私はそれを終わりまで書かなければならないとは考えていなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーナ嬢は終わりまで聞かぬうちに唇まで真っ青になった。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書の日本語版を訳した中野圭二の後書きには、「ある日家内がもう本は終わりまでいっていると教えてくれなかったら、まだ書いていたかもしれない」とする、彼の述懐が紹介されています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど始めから終わりまで、すっかり軽装で通してしまったこの本では、あえて最後になって打ち明けたいような話は残っていない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "事の起こりから、終わりまで、冷静に考えて見たまえ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "学びの始めから終わりまで、学ぶ者の多くが経験する悦びは、繰り返し、繰り返し習い、フツフツと次第に湧いてくる悦びである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように初めから終わりまで、全体から中心へと、聖師と賢弟子との教示と応答とを味わえば、何等の迷いも無く直ちにこの章の趣旨を理解出来るのである。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "せくからに浅くぞ見えん山河の流れての名をつつみはてずば　まだいろいろに書かれてある手紙であったが、御息所は終わりまでを読まなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕霧一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中にまたたぐいもないような精神的愛に止まったという薫の話を、必ずしも終わりまでそうではなかったであろうと宮のお思いになるのも、御自身から割り出してお考えになるからであろう。",
              "citation": {
                "source": "源氏物語",
                "author": "早蕨",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発作業は翌年の三月から五月にかけて集中して進められ、春の終わりまでには、〈光〉と名付けたプロトタイプに格好をつけるところまでこぎ着けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の終わりまでにマイクロソフトは一〇〇万本のＷｉｎｄｏｗｓ３・０を売り上げ、ＧＵＩの標準をＭＳ―ＤＯＳ上に確立するという目標の達成についにこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語を聞きに行っても二十何歳という若手が何か無理矢理に落ち着いた顔をして、人情噺などやり出すと初めから終わりまでぞくぞくと寒さを覚えて来て大変気分が悪くなります。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇〇年の終わりまで私は、ある社会的連係によって、パリーの「広場の市」につながれていて、そこではクリストフと同様に、ひどく異邦人の感じがした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "人がもし心を空しくしてこの書を初めより終わりまで読むならば、きっと何ものかを得るであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は終わりまで聞くにはよほどもどかしさを忍ばねばならなかった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、キリストによれば性欲と肉交とは初めより終わりまで肉である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし肉交の中途においてある愛人の生命に危険をおよぼすごときできごとが生じても、肉交は終わりまで達しなくてはなかなかたやすく止められぬであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く入道したいと頼むが、終わりまでせぬ。",
              "citation": {
                "source": "嫉みの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると、最初から終わりまでこの室内に人間が働いていたのであろうか。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "貸家",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして義経を想うといつも彼を終わりまで助けてくれた佐藤庄司父子の武士らしい一生を夢よりも美しい物語として私は思い出すのである。",
              "citation": {
                "source": "平泉紀行",
                "author": "──専攻科第一類歴史部──",
                "note": "青空文庫"
              }
            },
            {
              "text": "また毎句にある「月」でも一首の頭からおわりまでいろいろの位置に分配されているのに気がつく。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月のおわりまでいたのである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
