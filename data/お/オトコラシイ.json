          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "タンポポの花一輪の贈りものでも、決して恥じずに差し出すのが、最も勇気ある、男らしい態度であると信じます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、弱い男らしい。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして確かりした男らしい人でしたわ。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自分の殘酷さ、男らしい堅い沈默に堪へ得ない自分の薄志、私は決してそれを知つてゐないのではない。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりが互に一種の面目を重んじて、一種の男らしい精神を発揮して来る。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙も何も乾いてしまって、男らしい、若々しい理知を眼の内に輝かしながら唇を噛んだ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……不断は柔和で打ち沈んだ父だったけれども何んという男らしい人だったろう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は君が來る前から思つて居たんですがね、是れから必ず毎週一篇づゝ創作をやつて、土曜の晩に朗讀會をしたら如何かと思ふんですが」と相島は男らしい安坐の膝を組み直して又快活な事を云つて居る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでは少し讚美歌の練習をしませう」と軈て牧師が男らしい聲で快活に云ふと、女で居ながら人の前で決して面をかぶらない、其の細君は飾氣のない身ぶりで腰掛を立上つてオルガンに近づいた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢本さんは男らしい、正直な生蕃さんね。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二人ともこれで実はそうとう深傷を負ってるのだなあ」　私は生れて以来こんな悲壮な男らしい声を聞いたことがありません。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎から頬へかけて剃りあとの青い男らしい風貌を持っていた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌の方では、あの大人であって捌けて男らしい医師を夫と呼ぶようになるとは、あまり唐突の感じがしないでもなかった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "角の立つ様な隆鼻を中心にして、なかだかな、おとがいの張った男らしい顔の、怜悧相な額には、油もつけず幾日も梳らない為に、煤気を帯びた様な黒い、たっぷりした散髪が掩いかぶさって居る為に思いきって切れ長なま瞼の底に、濃情と憂愁とを交ぜ湛えた様な両眼の色がいやが上にも奥深く見えるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に男らしいものは、自分の仕事を立派に仕上げることをよろこぶ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒瞳勝な目元が顔の輪郭をはつきりさせて、頬から口へかけて男らしい肉のしまりがある。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "家家の屋根を越えて、青空に高くひるがへる魚の像は、子供の將來に於ける立身出世と、富貴と健康と、名譽と榮達と、とりわけ男らしい勇氣を表象して祝福されてゐる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気悪いか」　娘はまた片笑いしただけだったが、かの女は、むす子がその娘に対する挨拶に、ただの男らしい同情だけ響くのを敏く聞き取って、その女は遊び女に違いないにしろ、もっとむす子は優しく云ってやればいいのに、と思った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎から頬へかけて剃りあとの青い男らしい風貌を持つてゐた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お涌の方では、あの大人であつて捌けて男らしい医師を夫と呼ぶやうになるとは、あまり唐突の感じがしないでもなかつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみへ届けるときにはどうなつてゐたのでせうか分りませんが、二人が自分の名を自分で覚える頃には二人ともその育つ姿や生活に相応する――即ちおとうさんは女にふさはしく、おかあさんは男らしい呼名に都合よくなつて居ました。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、あの子が、そんな男らしい口をきける子だとは、どうしても思えません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、つまらぬ小細工ばかり弄して、男らしい乾坤一擲の大陰謀などは、まるで出来ない。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、友人にも時たまそれを指摘されるのだが、よっぽど、ひがみ根性の強い男らしい。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "検非違使庁の推問に遇うて、そして将門の男らしいことや、勇威を振つたことは、却つて都の評判となつて同情を得たことと見える。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、自ら新しい自己を造らんとすることは實に高尚偉大な事業で有つて、假令其の結果は甚だ振はざるにせよ、男らしい立派な仕事たるを失はぬのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處には流石に世間の苦勞を甞め盡して來た男らしい眞實味がありました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にすが子は社會主義の事を見聞して、その女性たる身體に相應しからぬ男らしい思想の人となつた。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
