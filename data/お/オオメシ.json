        "examples": {
          "standard": [
            {
              "text": "例句",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「大飯を喰うから頭が半間になるんだ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生が死なれるまで介抱をして御恩報じをしたら、あとは坊主になって日本中を旅行してやろう――なぞと思っていたから、なおのこと大飯を喰って元気を養った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常に喰うても足らぬ処へ、平生大飯｜喰いの頭山が妙な事をすると思うて理由を聞いてみると、きょうは死んだ母親何とかの日に当るけに精進をしよるというのじゃ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日一度｜大飯を喰って、日比谷の原（その頃はマダ公園でなかった）を早足で三遍も廻れば直き肥る。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、そんな事を云ッて置きながら、ずうずうしく、のべんくらりと、大飯を食らッて……ているとは何所まで押が重いンだか数が知れないと思ッて」　昇は苦笑いをしていた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共を御覧なさい、あの通りウジャウジャ居るんですからネ……加に、大飯食いばかり揃っていて」と言いかけて、学士は思い出したように笑って、「まさか、子供に向って、そんなに食うな、三杯位にして控えて置けなんて、親の身としては言えませんからナ……」　包み隠しの無い話は高瀬を笑わせた。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこうして一日とび廻っては、大飯を食っていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "目前で大飯を食っている純一のattributeはこれで尽きている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "目前で大飯を食っている純一の attribute はこれで尽きている。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "大飯を喰つて、大糞をたれて、定命五十年で、アツサリとやりたいではないか。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして若夫婦を威嚇しいしい、悠々と大飯を平らげて立去った。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬるどころか大飯喰ろうて。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又右衛門は武右衛門をつれて傷の手当をしに数馬の姻族、彦坂加兵衛の家へ行って水を飲み、大飯を食って、役人のくる迄と眠ってしまった。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより丹後国に帰りしに、仲立するものありて若狭国大飯郡高浜の専能寺に養はれて住職す。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「如何なこと、それがしは聞えた大飯食ひでおぢやる。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして実に大飯をくらう。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、大飯をくう。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "神伝魚心流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前に大飯ばっかり喰いやがって、このでれ助野郎ら。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯なくせに、大飯食ひばかり揃つて居て――はゝゝゝゝ、まあ君だから斯様なことまでも御話するんだが、まさか親の身として、其様に食ふな、三杯位にして節へて置け、なんて過多吝嗇したことも言へないぢやないか。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどラエーフスキイは気紛れで放埒で変な男ではあるが、まさか盗みはしまい、床へべっと唾もしまい、妻君のことを『大飯ばかりくらいおって働こうともしねえ』と叱りもしまい、手綱で子供をぶちもしまいし、召使に臭くなった塩漬肉を食わしもしまい。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁内の大飯と早飯は物凄かった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十六　家族は六人・目一ツ半",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋、へたばって、そこの土庇に手をついてしまうかと思いのほか、「あっはっは、大飯食らいの大声だ」　ブラリ起ちあがって、立ち去ろうとする横顔を、丹波のほうがあっけにとられて、しばしジッと見守っていたが、「何イ？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、日暮前にゃ俺らも面あ出すから、眼鼻がついても帰ってくるな――勘、われもちったあ身入れろい、なんだ、大飯ばかり喰えやがって。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "巷説蒲鉾供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘、汝もちったあ頭を働かせ、大飯ばかり食いやがって。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "梅雨に咲く花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖に大飯を食う。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大飯を食った後でタカジヤスターゼを飲む。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな時に起きて寝て、泥の中さ、へえずり廻ってな、大飯くらって屁えこいてりゃ済まあ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿見たいに見えるのと、大飯を食うのがお前の取得だと」「その吹聴は、いずれ春永に伺うとして、向島の話はどうした」「それっ切りですよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿見たいに見えるのと、大飯を食ふのがお前の取得だと」「その吹聽は、いづれ春永に伺ふとして、向島の話はどうした」「それつ切りですよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花見の留守",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の町さえ離れれば、あとは遊山旅だ」「宇太松どん」「行こうよ、お竹さん、信州へ行ったら、正直正銘の人間になって、大飯を食ってうんと働いて誰に遠慮もなく暮そうよ」「嬉しいよ、宇太松どん」　二人は暫く闇の中に、後も前も忘れて手を握り合って居りました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "お竹大日如来",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
