      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sell wholesale",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "病人を板か何かに載せて卸すと云うことは、不可能なことであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖腰を卸すとたんに、燕尾服の長い裾を丁寧に左右に開くことは忘れなかつたのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫婆の息子が帰って来たなと思っていると、果たして籠や盤台を卸すような音がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が首尾よく部屋を一周して病床に腰を卸すと親子三人はひとりでに手を取り合っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお夜食を食べ終る頃、火の番が廻って来て、拍子木が表の薄｜硝子の障子に響けば看板、時間まえでも表戸を卸すことになっている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の打ち卸す発矢とした勢いには、破壊の憎みと創造の歓びとが一つになって絶叫しているようである。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰って待っといでなさい」　と言って老人を送り出してから表戸を卸す。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ来ると、浪打際までも行かないで、太く草臥れた状で、ぐッたりと先ず足を投げて腰を卸す。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は再び窟に入って、畚を卸す準備に取懸った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀子は来る時から、別にここで、根を卸す考えはなく、来た以上は真面目に働いて借金を切り、早く引き揚げましょうと思っていたので、千葉時代から見ると、気も引き締まっており、お座敷も殊勝に敏捷にしていたので倉持にもそこいらの芸者から受ける印象とは一風ちがった純朴なものがあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は日本橋の国府へ納める荷物の中に、幾割かのロオズ物があり、それを回収して、場末の二流三流の商店へ卸すために、時々東京へ出るので、このころにもそのついでに、罐詰を土産に、錦糸堀の銀子の家を訪ね、荷はいくらでも送るから、罐詰の店を出してはどうかと、親父に勧めたりしたものだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中あんまり疲れたので、とある丘の上の青い麦畑の横に腰を卸すと不意に眼がクラクラして喀血した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴木検事の顔を正視してビクビクと咽喉を引釣らせていたが、そのままドッカリと椅子に腰を卸すと、応接机の上に突伏してギクギクと欷歔し始めた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶ちゃんのおとうさんは、うちのまわりの者から頼まれて、おやじのその商売の昇華を引卸すに相当骨を折ったものだ」　これ等がすでに清太郎の父の上に現れた池上家の人間の現実遊離の浮游性であった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "謎をこころの住家となし、この住家に於て太古の湖の静けさにも通ずるほどの憩いを希うわたくしに取って、感覚的にも外界への交通を遮断することは表戸を卸すと共に四方の窓の戸をも閉めるほどの細心緻密な心使いです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔Entru:sten〕 といふ動詞は素と甲を解く、衣を卸すといふやうな意味から轉じて、體裁も何も構はなくなる程おこることになつてゐる。",
              "citation": {
                "source": "當流比較言語學",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない島影の海岸近くをスルスルと辷るように和蘭船へ接近して帆を卸すと、ピッタリと横付けにした。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一度長崎へ帰って、風を見てから積取りに来いと云って、千六と船頭を卸すと、和蘭船はその夜のうちに、白泡を噛む外洋に出て行ってしまった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「大抵わたくし共は、こゝから五哩ほど上の入海のやうな所に船を留めてゐまして、天気の好いときに、潮の鎮まつてゐる十五分間を利用して、モスコエストロオムの海峡を、ずつと上の方で渡つてしまつて、オツテルホルムかサンドフレエゼンの近所の、波のひどくない所に行つて、錨を卸すのでございました。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を路傍へ卸す時彼は屹度縛りつけた手拭の包へ手を掛けて新聞紙の袋のがさ／＼と鳴るのを聞いて安心した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎと南の女房とは相竝んで勘次に對して交互に打ち卸す連枷がどさり／＼と庭の土を打つと硬ばつた大豆の幹はしやりゝ／＼と乾燥した輕い響を交へてくすんだ穢い莢が白く割れて薄青いつやゝかな豆の粒が威勢よく跳ね出してみんな幹の下に潜り込んで畢ふ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が大寺餅といふのかと聞くと今日はもう一串に成つてしまつたといつて女房の語る所に依れば、堺の町の大寺といふ寺の境内にある餅屋から此餅は卸すので、遠く和歌山の方までも卸しをする餅である。",
              "citation": {
                "source": "松蟲草",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "頂上に達して、始めて腰を卸す。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸尺どもは額の汗を拭く間もなしにその乗物を喧嘩のまん中に卸すと、袴の股立ちを掻い取った二人の若党がその左右に引添うて立った。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なげしに掛けてある槍を卸すと、その黒い鞘は忽ち跳ね飛ばされて、氷のような長い穂先が燈火に冷たく晃った。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坊の泣き続ける暗闇の中で仁右衛門が馬の背からどすんと重いものを地面に卸す音がした。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老漁夫はそんなことをブツブツ云ひながら、担いで来た網を舟の中へ卸すと、自分も中へ入つて、背中を丸くして網を繕ひ始めた。",
              "citation": {
                "source": "清一の写生旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "思うに、あっしゃ深川の境内に今もまだいるんじゃねえかという気がするんですがね」「そうばかり問屋でも卸すめえさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいぶかしく思いながらその後姿をそれとなく見送り縁台に腰をおろすと、馬場はにやにやうす笑いして言いだした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰をおろすと、浪の音がひときは聞えた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
