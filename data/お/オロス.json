[
  {
    "uuid": "7fc59d24-b5bd-506e-960a-0f63b6ba444d",
    "entry": "卸す",
    "reading": {
      "primary": "おろす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
