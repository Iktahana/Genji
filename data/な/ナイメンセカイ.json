        "examples": {
          "standard": [
            {
              "text": "芸術家は、豊かな内面世界を作品に表現する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "哲学書を読むことで、自分の内面世界を深く探求できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の内面世界は複雑で、誰も容易には理解できないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これらの婦人文学者たちの教養は、花圃の内面世界よりも数歩前進してヨーロッパ文学の影響のもとにあったであろう。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが或る特定の情緒のみに局限せられず、或る性格のもののあらゆる場合に於ける表現に堪へ得なければならず、勢ひ能面そのものの絶対表現は或る定まつた性格の中核的内面世界の核心を表徴するものとなる。",
              "citation": {
                "source": "能の彫刻美",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
