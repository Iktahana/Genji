        "examples": {
          "standard": [
            {
              "text": "有名作家の生原稿には、苦悩の跡が見て取れるような推敲の書き込みがいくつも残っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "印刷された文字ではなく、直筆の生原稿から伝わってくる作家の熱量に圧倒された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "編集者は作家から受け取った貴重な生原稿を、失くさないように大切にカバンにしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "引きうけたからには、良いものを見のがすことがないように、もらった雑誌はガリ版ずりでも生原稿でも、事情の許すかぎり読むように努力しているのである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生原稿を持たないものですから、ときどきでたらめに脱線しちゃう。",
              "citation": {
                "source": "美術学校時代の岡倉先生",
                "author": "板谷波山",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
