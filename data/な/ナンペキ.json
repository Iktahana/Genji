        "examples": {
          "standard": [
            {
              "text": "その古い城壁は、北壁よりも南壁の方が日当たりが良く、苔が生えにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ハイキングコースの途中で、雄大な断崖の南壁を見上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "日当たりの良い南壁に植えられた果樹は、豊かに実をつけていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "小壁のうちで特に美しいのは、入り口から左へ突き当たった隅の、東壁及び南壁である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南壁の花を持って立っている姿などは、アマゾンの像といってもいいほどに強靱でそうして艶めかしい。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟れたネクタリンや桃は庭の南壁から収穫したものだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
