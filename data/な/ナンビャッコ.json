        "examples": {
          "standard": [
            {
              "text": "このお店には、何百個もの品物が並んでいて、見ているだけで楽しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "収集家は、世界中から何百個もの切手を集めたそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このソフトウェアのバグは、何百個もあると言われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "何百個中隊、何十個大隊が横隊に並んで、それが敵前で動くことは非常な熟練を要することであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい鏡を、何百個も、よせあつめたような玉で、それがシャンデリアの光をうけて、宝石のようにうつくしく、キラキラとひかっているのです。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、サムボア他でマッチを何百個と貰って来た、これは受けるであらう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもなぜ何百個も用意しなかったんですか」　ハックネス先生がさえぎって、「簡単な理由さ。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
