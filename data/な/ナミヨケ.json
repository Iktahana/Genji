        "examples": {
          "standard": [
            {
              "text": "高潮の被害を防ぐために、海岸沿いには巨大なテトラポットの波除けが設置されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "港の波除けの陰に船を停泊させて、激しい嵐が過ぎ去るのをじっと待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "波除けの堤防には釣り人が等間隔に並び、のんびりと糸を垂らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "波除けをつくったり空樽のうしろへ入ったりしたが効果はなかった。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "波は波除けにあたり飛沫を高く浴びせかけている。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "キティ台風のときひどくやられてから、そういうふうに波除けを作ったのだという。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またお座所には夜具も入れ、波除けを忘れるな」　などと何かの指図に、忙しげな姿だった。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
