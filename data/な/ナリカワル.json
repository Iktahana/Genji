        "gloss": "to change",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冬の寒さが和らぎ、季節が春へと成り変わる気配を感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "さなぎが蝶へと成り変わる神秘的な姿を、子供たちが熱心に観察していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "街の風景が再開発によってモダンに成り変わるのを、寂しげに眺める老人がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ペリパトス派の哲学は、全ての物質において「根源的」質料が完全に同質であると断言し、地水火風の四大元素も、漸進的に循環して相互に成り変わるので、正に同じ実体から成る、と考える。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　その年の秋、悟浄は、はたして、大唐の玄奘法師に値遇し奉り、その力で、水から出て人間となりかわることができた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿は他の人物になりかわることができなかったのだ。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
