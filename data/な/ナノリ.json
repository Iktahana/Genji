    "definitions": [
      {
        "index": 1,
        "gloss": "giving one's name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "受付で「田中です」と名乗りを済ませ、会議室へと案内された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "偽名を使い続けてきた彼は、ついに本当の氏名を名乗りとして上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "司会者が「次の方、お名乗りをどうぞ」と促すと、彼は緊張した面持ちで口を開いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "フニクラレの客車で日本人らしい人に出会って名乗り合ったら、それは地質学者のＫ氏であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「灰汁桶のしずくやみけりきりぎりす」などはイディルレの好点景であり、「物うりの尻声高く名乗りすて」は喜劇中のモーメントである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩、それから、はじめて私達は互いに名乗り合ったのですから。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "もはや、槍の穂先も見えぬげに御座れば、残念ながらこれにてお別れ申そう」「いや、某もさように存じておったところ……」「さらば」「さらば」　というのでドロンゲームになったが、後にこの二人は某侯の御前で出会して、本名を名乗り合って莫逆の友となった……というような話が「常山紀談」に載っている。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しく名乗りをあげ、美しく戦い、美しく死に、又は殺すべく……人間性の真剣味を極度にまで発揮すべく……死生を超越して努力している。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はすぐその男だなと思つたが、互に名乗り合ふこともしなかつた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、道子は名乗りたかった。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時効のかかったころ、堂々と名乗り出るのさ。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のやうなものが名乗りを挙げてみたつて、どうにもならんし、どだいどうも、私たちの訪問は唐突だよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三年して、この子が五つになった時分に、近所に女中をしていた女が、堺屋に現れて、子供の母だと名乗り出た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は捨てたが、この子のために死に切れず、死ぬより辛い恥を忍んで、世間へ名乗り出ることさえした位だから、この子はもとより自分のものだと、木下の母は云った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に、」ろくろく考えもせず、すぐに大声あげて名乗り出たのは末弟である。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなにまで言われると、なおさら、その隠れた善行者は名乗りにくくなるであろう。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの酒の酔いも既に醒め、一座は白け切って、原田ひとりは血走った眼をむき、名乗り給え、名乗り給え、とあせって、そのうちに鶏鳴あかつきを告げ、原田はとうとう、しびれを切らし、「ながくおひきとめも、無礼と存じます。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても、お名乗りが無ければ、いたしかたがない。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は噴き出したいのをこらえて、「僕は名刺を持っていませんけど、田中、――」と名乗りかけると、「いや知っている。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、男同志が名乗り合う厳粛な時だと、笑いを噛みしめて、「推参なり。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、双方名乗りが済むと、三好入道はいきなり長槍をしごいて、佐助の胸をめがけて、「エイッ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざ尋常に……」と、例によって、奇妙な名乗りをあげながら、木鼠胴六の山塞へ、樊※の如き恰好で乱入して行った。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、更に赤面汗顔に価いしたのは、いよいよとなると、ただ黙々とやるだけでは芸がない、雅びた文句の数え歌に合わせてやるとて、石川五右衛門の洒落た名乗り文句をもじって、「一に石川で」で一人。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿呆の一つ覚えの名乗りを、さも得意らしく牢屋の中であげているのもおかしいが、それよりおかしいのは、俺は昨日茶店の女にきいた時、てっきり宝蔵院くずれだと思ったが、三好入道もまた山賊退治に失敗して牢の中に閉じこめられているのか、まず、佐助は自分の名を告げたあと訊ねたところ、果してその通りであった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんじら二人とも天皇のおおせに従わず、無礼なふるまいばかりしているので、勅命によって、ちゅう伐にまいったのだ」と、命はおおしくお名乗りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互いに名乗り合ったうえで矢を放とう」とお言い送りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人は名乗りませんけれども、確かにそれに相違ないと思うんです。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、敵手の中の主立たる一人は黒田藩の指南番浅川一柳斎と名乗り、五十前後の長身にて、骨柄逞ましき武士なること。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "久方振りに殿の御用で江戸表へ参いっておる中に、あの願書の当の本人、友川矩行という若侍から父の仇敵と名乗り掛けられてのう……」「ヘエッ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸を郊外山腹にある先祖代々の墓地に葬った後、なまなましい土饅頭の前に仮の祭壇をしつらえ神官が簡単なのりとをあげた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マストにのぼつた　ふなのりが。",
              "citation": {
                "source": "お月さまを",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なのりそとこしへに君もあへかもいさなとり海の浜藻のよるときどきを　　衣通姫なのりそといふ藻をまだ知らぬ女の子よ、なのりそといふ藻は小鳥がたべる、いんや、さかながたべる。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の朝　　　　　ロバアト・ブラウニング時は春、日は朝、朝は七時、片岡に露みちて、揚雲雀なのりいで、蝸牛枝に這ひ、神、そらに知ろしめす。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
