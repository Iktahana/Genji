        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歌舞伎の舞台で、役者が中央に進み出て派手な名ノリを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アニメのヒーローが変身後に決まった名ノリを上げるのは、お決まりの演出だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "悪役が登場シーンで長々とした名ノリを始めたため、主人公は少し困惑した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
