        "examples": {
          "standard": [
            {
              "text": "長野県警は、特殊詐欺事件の捜査を強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長野県警のパトカーがサイレンを鳴らして現場へ急行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長野県警のウェブサイトで、地域の安全情報を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから曲者の死体は医務室に運び込まれ、望月少佐は電話をもって名古屋憲兵隊と長野県警察部とにこのことを報じた。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん明智探偵のはからいで、塔上の二少年をすくうために、長野県警察の手で、近くの町からの電話れんらくによって、松本市の新聞社から呼びよせたものでした。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
