        "examples": {
          "standard": [
            {
              "text": "新しい棚を買う前に、設置場所の幅と奥行きの内寸を測っておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この収納ケースは内寸が小さいので、大きな物は入らないかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宅配便の料金は、荷物の三辺の内寸の合計で決まることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "子供が風邪ひいたらどないすんねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父やんにもしものことあったら、どないすんのん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷えこんだらどないすんねん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、ボートがひっくりかえったらどないすんねん？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷えたらどないすんねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、君が病院をきいたら、教えてくれつて言つたぜ」　すると、そばから、だれかが、「あら、ずいぶんまわりくどいんやなあ」「そうよ、これが尾関らしいところよ」「ユキちやん、どないすんの？",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
