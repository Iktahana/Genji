        "examples": {
          "standard": [
            {
              "text": "新しく開店したスーパーと地元商店街の間で、激しい顧客の縄張り争いが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "派閥同士の縄張り争いに巻き込まれ、若手社員たちはどちらに付くべきか困惑している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ギャングの縄張り争いによる銃撃戦が発生し、街の治安は一気に悪化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あいつらも大勢いると、自然縄張り争いか何かで仲間喧嘩をするようになるのかも知れません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜中にこのあたりのアパッシュ連中、縄張り争いでやり合うらしいんだよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの長吏法師の中には、時にはなはだしく有力なものができまして、鎌倉時代には京都清水坂の非人の長吏と、大和奈良坂の非人の長吏とが、山城の南部で縄張り争いをなし、ために血の雨を降らしたということもありました。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、もっぱら縄張り争いに熱中する役人らには、全くそれができないのである。",
              "citation": {
                "source": "役人学三則",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国にも縄張り争いがあることは日本と同様で、この計画はピック・トムソン計画と呼ばれていた。",
              "citation": {
                "source": "北海道開発に消えた八百億円",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも少し縄張り争いのようなこともあるらしいが、とにかく仕事は進められている。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に権利者に出て来られたり、縄張り争いが起ったりしては厄介と思うから、そこで、夜陰こっそり忍んで来ただけのものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだい」「賭館の縄張り争いで矢萩は猪沢市太郎を殺した」「朝倉を殺したのも、そいじゃ、やっぱり矢萩だな。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
