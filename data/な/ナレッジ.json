          "standard": [
            {
              "text": "ベテラン社員が持つ貴重なナレッジを、若手に継承していく仕組みが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "チーム内でナレッジを共有することで、プロジェクト全体の効率が大幅に向上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外部のセミナーに参加して、最新の業界ナレッジを吸収してきたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "生命の本源、生存の真髄は決して、ナレッジで啓かれ、触れられると思わない。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、インテレクトナレッジ？",
