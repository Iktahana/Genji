        "examples": {
          "standard": [
            {
              "text": "データを日付順に並べ替えすることで、過去の推移が把握しやすくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "トランプのカードを数字の小さい順に並べ替えして、ゲームの準備を整える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "本棚の整理を兼ねて、作家の名前の五十音順に並べ替えを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アマチュアのパイロットの資格を持っていたドンピアは、低い周波数の電波を受信できる小さなトランジスターラジオで天気情報を聞きながら、入力した数値を大小の順に従って並べ替える、ソートと呼ばれる作業のためのプログラムをスイッチから入れていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは集めたデータをルールに従って並べ替えるためのスーパーソート。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか古い雛段を出して来て順序よく並べ、暫くするとまた並べ替えるのでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれだけあれば証拠品としては十分過ぎる位だ」　明智は容器を一つ一つ、つまみ上げて、大切相に並べ替えて行った。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
