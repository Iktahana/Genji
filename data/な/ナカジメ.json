        "examples": {
          "standard": [
            {
              "text": "パーティーは楽しい雰囲気のまま中締めとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長時間の会議だったので、途中で一度中締めをして休憩をとった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "懇親会では、景品発表の後に中締めが行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この四軒の二階の殆どすべては年中締め切られて、「明き間あり」の張り札の懸つてゐないことはない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
