          "standard": [
            {
              "text": "MRI検査の結果、骨には異常がないが軟組織に軽い損傷が見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "腫瘍が周辺の軟組織に浸潤しているため、手術には細心の注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "怪我を早く治すために、軟組織の修復を促進するサプリメントを摂取している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もう１つは、アフリカのある人種が今日でも行なっているように、関節を外してばらばらにした後で骨からすべての軟組織を除いて埋葬する。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "マグネシウムは動物の骨にも軟組織にも見られたが、ラットで欠乏状態を作るのは困難であった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
