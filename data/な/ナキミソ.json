        "examples": {
          "standard": [
            {
              "text": "彼は些細なことで泣き出すので、クラスのみんなから泣き味噌と呼ばれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう泣き味噌じゃない！」と、子供は涙を拭いて立ち上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の弟は小さい頃から泣き味噌で、いつも私に泣きついていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "不逞不逞しいが、泣き味噌の武田さんのすすり泣きがどこかに聴えるような小説であった。",
              "citation": {
                "source": "武田麟太郎追悼",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、泣き味噌の〈めだか〉が輸入した殺人狂であります。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            }
          ]
        }
