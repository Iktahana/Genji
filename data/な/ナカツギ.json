        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "釣竿は持ち運びしやすいように、真ん中で中継ぎできるタイプを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テントのポールは、何本かの短い棒を中継ぎして組み立てる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長い柄のほうきは、中継ぎ部分で分解して収納できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
