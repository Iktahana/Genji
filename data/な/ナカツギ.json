    },
    "definitions": [
      {
        "index": 1,
        "gloss": "joining",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "鉄道の線路は、短いレールを中継ぎして長さを調整する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "途中でパイプを中継ぎしないと、届かないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長いケーブルを中継ぎして、電源を遠くまで引っ張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "地質学者の一隊が中継ぎのステーションへ向かって突進する、その荷物を橇で引いて行く犬群の頼もしく勇ましい姿は何かしらわれわれの心の奥底に触れる美しさをもっている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中継ぎに一つ捩れて、あゝ揺れる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中継ぎに捩れて海潮音に酔うて、うつゝなき形に、三稜の弁の形のビスケットが八枚と八枚を積み重ねる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房の兄の米吉もその間に立って、金銭取引の中継ぎをしているらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイス岬の無電局まで届かせて中継ぎすべきものだ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは遠野町と、花巻町との中継ぎの村で宮守というところ。",
              "citation": {
                "source": "黄昏",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車がここに着いて、この中継ぎの宿屋の門に立っていると、佐々木君も峠を越してちょうどこの村にはいって来た。",
              "citation": {
                "source": "黄昏",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが城下の味噌や米をこの俺らに中継ぎさせて、部落の奴らへ売り込んで高い分銭を儲けるにしてもあぶく儲けというほどでもねえ」「こうこう権九、拝むぜ拝むぜ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士が発見せられた女帝を中天皇（万葉には中皇命）と言うのも、博士の解説のように男帝への中継ぎの天子という意でなく、宮廷神と天子との中間に立つ一種のすめらみことの意味らしくある。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士が発見せられた女帝を中天皇（万葉には中皇命）と言ふのも、博士の解説の様に男帝への中継ぎの天子と言ふ意でなく、宮廷神と天子との中間に立つ一種のすめらみことの意味らしくある。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫であるから遠方の人は中継ぎの人を途中に幾人も配置して、昼夜兼行して帰ったものである。",
              "citation": {
                "source": "奥秩父",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりわれらは、続かす種属の中継ぎ役をしてこの世に生きているわけだ。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに生物学上から見て、そこに中継ぎをし得なく、その義務を怠っているものは、人間社会の反逆者であって、独身者はこれに属すると言っても、あえて差しつかえはあるまいと思う。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その傍に札や銀貨が積もつて行くのを、少年が二階から下りて来て中継ぎするのである。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、いつない源十郎の意気ごみが二人の胸へもひびいて、与吉は中継ぎとしてここにのこり、お藤と源十郎が栄三郎のあとを追うことになった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中別段のこともなく、私達は七月三十一日の昼頃、中継ぎのＫ港に上陸した。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もしお嬢さん、悪いことはいわないから、この下の沢までおいでなさい、そこまで行くと、こちとらの中継ぎ小屋があるから、そこで今夜は足を休めて、ゆっくりと先の相談をして上げよう。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半之助はそれをうちあけられ、手紙のなかつぎもした。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
