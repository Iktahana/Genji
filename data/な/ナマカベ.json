        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "まだ生壁だから、手で触れると跡が残ってしまうので気をつけなさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "建築中の家の中に入ると、生壁特有のひんやりとした湿気と匂いが漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生壁が完全に乾くまでは、家具を壁に寄せて配置するのは避けたほうがいい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "洋燈も珍しいが、座敷もまだ塗立ての生壁で、木の香は高し、高縁の前は、すぐに樫、槻の大木大樹鬱然として、樹の根を繞つて、山清水が潺々と音を寂に流れる。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足場をくぐってはいり込んだ勘次、生壁の蔭に潜んでひたすらおりき婆アの戸口を見守った。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "生壁色の地へ、焦げた丹と、薄い黄で、絵だか、模様だか、鬼の面の模様になりかかったところか、ちょっと見当のつかないものが、べたに描いてある。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "生壁問答　蟋蟀、みみず、陰湿な虫が昼間でもチチと啼いている牢露地をぬけると、塀際の隅に、低い、石倉がある。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで生壁へものを言っているようだ。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう責めてみても、生壁に問答をしているようなもので、一向に通じない。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
