        "examples": {
          "standard": [
            {
              "text": "勇猛果敢な将軍として、彼は隣国にまでその名を馳せていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若くしてファッション界に名を馳せる彼女のデザインは、常に斬新だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一流の料理人として名を馳せた彼は、今では自分の店を数軒構えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "だが「ＭＳ―ＤＯＳベースで視覚的な操作環境を備えたワードプロセッサーを書いてくれないか」と申し入れてきた古川を、学究肌の技術者集団による武家商法でこの後名を馳せることになる管理工学研究所は、まったく相手にしようとしなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから河内介輝勝も、一時は全くあの浅ましい享楽から遠ざかって、ひたすら戦場に驍名を馳せるより外には何の望みもなかったことゝ解釈していゝ。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
