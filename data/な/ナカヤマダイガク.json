        "examples": {
          "standard": [
            {
              "text": "中山大学は、中国広東省にある国立の総合大学である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は中山大学で、中国の歴史と文化を深く学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中山大学は、孫文によって創立された歴史ある大学だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "実は魯迅さんは広東の中山大学の文学部長であったのだが、蒋介石の乱暴にとても堪えられないで脱出して上海へ来られたのであって、十月三日に着いて共和旅館に宿泊中であったのだが、それからは八日、十日、十二日と店へ来られたらしい。",
              "citation": {
                "source": "魯迅さん",
                "author": "内山完造",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰国して、満州事変の前後には、広東の中山大学の法学部長などをしていたこともある。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
