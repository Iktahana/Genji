        "examples": {
          "standard": [
            {
              "text": "アルミ鍋に入った鍋焼きうどんをコンロにかけ、卵を落として食べるのが至福の時だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お待たせしました、鍋焼きうどんです」と運ばれてきた器からは、湯気が勢いよく上がっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風邪気味の時に母が作ってくれた、具だくさんの鍋焼きうどんで元気を取り戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "○わすれて行った本　届ける　つい　そこだって○なべやきうどんを云いつけにゆく○待っている　約束のハガキのよみちがい○お菓子のこと「あら　それをみんなたべちゃっちゃ駄目よ」○気持よさそうなので　そうすると　ローソクの灯が　急にぱっと明るくなったように　くつろいで楽に居心地よくなった。",
              "citation": {
                "source": "無題（十三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
