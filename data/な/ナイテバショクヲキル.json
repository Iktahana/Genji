        "examples": {
          "standard": [
            {
              "text": "「やあ、久しぶり！」と、友人は満面の笑みで私を迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「なるほど、そういうことだったのか！」と、彼は長年の疑問が解けたように納得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あら、まあ！」その意外な展開に、彼女は感嘆の声を漏らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "本来ならば、泣いて馬謖を斬るべきところであるが、それではまた、あまりに芝居が過ぎるとの非難もあらう。",
              "citation": {
                "source": "戯曲二十五篇を読まされた話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの揺籃の歌は「戦ひの花」に満ちてをり「泣いて馬謖を斬る」ことは、支那ではともかく、日本では朝飯前である。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
