        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「なまり節を厚めに切って、生姜と一緒に甘辛く煮付けるのが我が家の定番料理です」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「なまり節はカツオの旨味が詰まっているから、細かくほぐしてサラダのトッピングにしても美味しいわよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖母が送ってくれた特産のなまり節を使って、今夜は炊き込みご飯を作ってみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "旅費のつかい残りで、すぐに石油を買う体裁、なけなしの内金で、その夜は珍らしく肴を見せた、というのが、苦渋いなまり節、一欠片。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしもよく方々の農家から小豆餅やなまり節などをもらった。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史にもやはりイカのなま干、または鰹のなまり節のような階段があるように感じられた。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "古箪笥や行李などのあるそばで狭い猫の額のような庭に対して、なまりぶしの堅い煮付けでかれらは酒を飲んだり飯を食ったりした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
