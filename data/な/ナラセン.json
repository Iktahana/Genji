        "examples": {
          "standard": [
            {
              "text": "奈良線に乗って京都から奈良へ向かう車窓からは、のどかな田園風景が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光シーズンになると、奈良線は多くの外国人観光客で満員になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "奈良線の快速列車を利用すれば、主要駅への移動もスムーズで非常に便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "京都から奈良線で木津まで南に下り、関西本線を上って新堂駅で下車。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たち、こんなところで非常警戒していても何にもならせんよ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんで勝負にもならせん。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
