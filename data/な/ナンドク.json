        "examples": {
          "standard": [
            {
              "text": "この地名は難読なことで有名で、地元の人以外で正しく読める人はほとんどいない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「難読漢字クイズ」に挑戦したが、最初の三問で早くも行き詰まってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キラキラネームの中には、初見では難読すぎて予測不能なものも多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その日も午前から午後へかけて少し頭の疲れる難読の書を読んだ後であった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．難読な漢字には振り仮名をつけた。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二片は甚だしく毀損しているが、その一片には婚約に関する規定を記し、他の一片は殆んど全部難読であるけれども、前後の関係から推せば、これには女戸主の財産に関する規定を記しているものらしく考えられる。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "兼好、あとは読んでくれい」「それだけでは、ちと難読でございますな。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう情景は、もうなんどくり返されたかしれない。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、この一語は貴重な一語であって、なんどくりかえされてもよいものですから、その事に異論をとなえる気がありよう筈がありません。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というこの物音、なんどくり返されたかわからない。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
