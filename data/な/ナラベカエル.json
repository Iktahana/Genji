        "examples": {
          "standard": [
            {
              "text": "デスクトップのアイコンを、よく使う順に並べ替えることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼンのスライドの順番を並べ替えるだけで、話の流れがスムーズになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "文中の単語を適切に並べ替える問題に、生徒たちは頭を悩ませている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アマチュアのパイロットの資格を持っていたドンピアは、低い周波数の電波を受信できる小さなトランジスターラジオで天気情報を聞きながら、入力した数値を大小の順に従って並べ替える、ソートと呼ばれる作業のためのプログラムをスイッチから入れていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは集めたデータをルールに従って並べ替えるためのスーパーソート。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこからか古い雛段を出して来て順序よく並べ、暫くするとまた並べ替えるのでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
