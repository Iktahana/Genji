          "standard": [
            {
              "text": "夏潮に乗って、たくさんの魚が沿岸にやってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏潮は海水温を一時的に下げる効果があると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "満ちてくる夏潮の音を聞きながら、海岸を散歩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一夏潮風に吹かれて、褐色になつた顏に、樂しげな微笑を浮べてゐる。",
              "citation": {
                "source": "身上話",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏潮を蹶つて戻りて陸に立つ六月十一日　神戸入港。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏潮の今｜退く平家亡ぶ時も六月一日　満鮮旅行への途次、門司着。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
