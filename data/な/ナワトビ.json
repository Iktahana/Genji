        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎日の縄跳びは、ボクサーにとって心肺機能とリズム感を鍛えるための必須のトレーニングだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "休み時間になると、女の子たちが集まって大縄跳びで誰が長く跳べるか競い合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「縄跳びをダイエットに取り入れたら、一ヶ月で驚くほど体が引き締まったよ」と彼女は喜んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
