        "examples": {
          "standard": [
            {
              "text": "古楽の演奏家は、南呂の音程を正確に再現しようと努めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "雅楽の理論では、南呂は特定の季節や感情と結びつけられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古典的な楽曲では、南呂の響きが特徴的に用いられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "九月の末ごろ、南呂宋のサンミゲルという町に、日本人らしい男が住んでいるという噂を聞いた。",
              "citation": {
                "source": "呂宋の壺",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
