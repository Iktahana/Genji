        "examples": {
          "standard": [
            {
              "text": "このスニーカーのソールには、独特の弾力性とグリップ力を持つ生ゴムが採用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "実験室の片隅に、加工される前の塊状の生ゴムが山積みにされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い生ゴムのパッキンが劣化してベタベタになり、蓋が開かなくなってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "畜生ゴム靴をはいてやがら！",
              "citation": {
                "source": "逝けるマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ再生ゴムだからな」　　　　　５　新鋭戦艦マサチュセッツは大統領とその幕僚、それに金博士を乗せると、沖合さして二十三ノットの速度でのりだしていった。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは質のいい生ゴムでつくられてあり、例の汐ふきのような顔になっており、そして生ゴムの表面は渋色に染めてあった。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらんとして、足元の絨毯は分厚く、どうやら警戒のために、生ゴムのマットが敷いてあり、足音が全く聞こえない。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
