        "examples": {
          "standard": [
            {
              "text": "親友にはどんな小さな悩み事でも打ち明けられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は最近、何か深刻な悩み事を抱えているようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夜中まで悩み事を考えていたら、いつの間にか朝になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私、何んだか、心のありかが解らないような、頼りない気がしてきて、……――君はそんなに悩み事があるの？",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の悩み事は貴方が戻って来た時に話すわ」「私には悪魔がついて、私がこれからやろうとしていることについて私が何事も知り尽くしているかのごとく突き動かしてくれることを祈ります。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
