        "examples": {
          "standard": [
            {
              "text": "夏橙の爽やかな酸味と甘みは、夏の暑さを忘れさせてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "奶奶は毎年、自家製の夏橙のマーマレードを作ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このドリンクは夏橙の果汁がたっぷり入っていて、リフレッシュに最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「坊樣、さア此處へ入つしやい」と女は言つて坐布團を欄の下に運び、夏橙其他の果物菓子などを僕にすゝめた。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "液多くして夏橙よりも甘し。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱欒の花は夏橙や柚の花よりずっと大きくて花数もすくないが、膚橘の方はもみつけた様に花を咲きこぼす。",
              "citation": {
                "source": "朱欒の花のさく頃",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
