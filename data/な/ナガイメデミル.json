        "examples": {
          "standard": [
            {
              "text": "若者の失敗は、すぐに咎めるのではなく、長い目で見て成長を促すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "短期的な成功に一喜一憂せず、長い目で見て最終的な目標達成を目指そう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は常に、長い目で見て物事を判断する冷静な視点を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "五　或る民族は栄え、或る民族は滅び、長い目で見るとわずかの間に時勢が転変する。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長い目で見るとこの研究は高度に生産的であったことがわかった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
