        "examples": {
          "standard": [
            {
              "text": "意見が対立する二人の仲を取り持つのは、非常に根気のいる作業だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が私の仲を取り持ってくれたおかげで、彼と無事に和解することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は常に公正な立場で仲を取り持つため、周囲からの信頼が厚い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "が、もちろん私の方から名古屋へ行く折もなければ、先方がわざわざ訪ねて来るほどの用件もありませんから、そんな訪問がお互いの疎遠の仲を取り持つはずもなく、また二年三年は夢のように過ぎ去ってしまいました。",
              "citation": {
                "source": "棚田裁判長の怪死",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
