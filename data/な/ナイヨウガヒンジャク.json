        "examples": {
          "standard": [
            {
              "text": "彼のプレゼンテーションは、図ばかりで内容が貧弱だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その報告書は、表面的な情報ばかりで内容が貧弱だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もっと議論を深めるためには、内容が貧弱な意見ではなく、具体的な提案が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それは口語詩の内容が貧弱であるといふ事であつた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは口語詩の内容が貧弱であるということであった。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の生活態度はあまりに安易であつた、生活内容が貧弱になるのもあたりまへだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その教えかたは昔流儀の暗記一点張りで、内容が貧弱であるのと暗記の努力がばからしいのとで、学生一般から不評判であった。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために、内容が貧弱であり、書としての生命が枯れているのは当然である。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
