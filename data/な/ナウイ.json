    },
    "definitions": [
      {
        "index": 1,
        "gloss": "NAUI",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はナウイのダイビングインストラクターの資格を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ナウイの講習を受けて、安全なダイビングを学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ナウイは世界的に認められているダイビング指導団体だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一九八六（昭和六十一）年に出荷を開始したｕｐシリーズの製品からは、ダイナウェアもあらかじめ開発したダイナウインドウと名付けた基本ソフトに対応させて個々のアプリケーションを書く道を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はここから三十キロほどのところにある、ナウイの収容所を見に行く予定になっていた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナウイの拘禁所は兵営のあとで、陰気な壕と城壁をめぐらした要塞のような構えになっていた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「牧田君、ナウイの収容所以来、手錠をかけなくなった訳がわかったよ、僕もなにかの名目で、その島へ送られる途中なんだな。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
