        "examples": {
          "standard": [
            {
              "text": "「汝の隣人を愛せよ」という言葉は、共感と相互理解の重要性を示している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域社会では、「汝の隣人を愛せよ」という精神で、互いに助け合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この物語は、「汝の隣人を愛せよ」という普遍的なテーマを描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "汝等おのれを愛するが如く、汝の隣人を愛せよ。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれを愛するが如く、汝の隣人を愛せよ。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリストの己を愛するが如く汝の隣人を愛せよという言葉を、私はきっと違った解釈をしているのではなかろうか。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば汝の隣人を愛せよという道徳法は単に理解力に由りて明であるであろうか。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が發見すべき「道」の少くとも一つの重要なる内容は汝の隣人を愛せよといふことでなければならない。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼は、汝の隣人を愛せよ、人類を愛せよ、人と人との間の愛こそは人生最高の意義である、と説いてはいない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
