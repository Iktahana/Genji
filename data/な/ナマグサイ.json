    "definitions": [
      {
        "index": 1,
        "gloss": "smelling of fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "漁港に足を踏み入れると、潮風に乗って魚の生臭い匂いが鼻をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "手が生臭くなるのを嫌がって、彼は釣り針から魚を外すのをいつも私に任せてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このゴミ袋は生臭いから、早く外の集積場に持っていったほうがいいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "實生活の生臭い風にお顏を撫でられるのが、とてもとても、いやなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孵化場から今帰りがけのところとみえて、彼が近づくと生臭い香いがあたりに香った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と氣遣顏の私さへ、其生臭い肉を口中充滿に頬張つて居つたのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭いにおいがプンとして、はき気を催しそうだった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "怖くないことを示すという自尊心が、ぼくをして生臭い石油をまるで毒薬をのむ様な悲壮な表情で飲ませてしまったのだ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の家の門は、自分にとって、あの神曲の地獄の門以上に薄気味わるく、その門の奥には、おそろしい竜みたいな生臭い奇獣がうごめいている気配を、誇張でなしに、実感せられていたのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この「女の決闘」という、ほんの十頁ばかりの小品をここまで読み、その、生きてびくびく動いているほどの生臭い、抜きさしならぬ描写に接し、大いに驚くと共に、なんだか我慢できぬ不愉快さを覚えた。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実生活の生臭い風にお顔を撫でられるのが、とてもとても、いやなんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを塩胡椒し、家鴨の肉の截片を入れてちょっと煮込んで食べるのだが、鼈四郎は味見をしてみるのに血生臭いことはなかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭いおさかななんかは。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭旅宿の留学生臭い生活を離れて格安ホテルに暫らく自由を味ってみたり、エッフェル塔の影が屋根に落ちる静かなアパルトマンに、女中を一人使った手堅い世帯持ちの真似をしてみたり、新吉は巴里を横からも縦からも噛みはじめた。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍にたくさんの獣の骨や頭の類がころがっていて、其処から生臭い鬼魅悪い臭がして来ます。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生臭い生の肉を口に入れる気はいたしません。",
              "citation": {
                "source": "人蔘の精",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はおよそ生きてるもの、動いてるものに何か浅薄で生臭いものを感ずる性質でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、帰りは夜更けて、赤電車で、日本橋一丁目で降りて、野良犬やバタ屋が芥箱をあさっているほかに人通りもなく、しーんと静まりかえった中にただ魚のはらわたの生臭い臭気が漂うている黒門市場をとぼとぼうなだれて行くのだが、雪の日などさすがに辛かった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を降りて北へ折れると、市場で、日覆を屋根の下にたぐり寄せた生臭い匂いのする軒先で、もう店をしもうたらしい若者が、猿股一つの裸に鈍い軒灯の光をあびながら将棋をしていましたが、浜子を見ると、どこ行きでンねンと声を掛けました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋一丁目で降りて、野良犬や拾い屋（バタ屋）が芥箱をあさっているほかに人通りもなく、静まりかえった中にただ魚の生臭い臭気が漂うている黒門市場の中を通り、路地へはいるとプンプン良い香いがした。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭い口臭をかぎながら、ぺたりとその場に坐らせて、「君、寒いのンか。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "口の中に一ぱい、生臭い匂いのものを含みながら、僕は便所へ小走りに走った。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "温まるにつれて、君の周囲から蒸れ立つ生臭い魚の香は強く部屋じゅうにこもったけれども、それは荒い大海を生々しく連想させるだけで、なんの不愉快な感じも起こさせなかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒ぎの間に、一種｜生臭いような暖かい蒸気が甲板の人を取り巻いて、フォクスルのほうで、今までやかましく荷物をまき上げていた扛重機の音が突然やむと、かーんとするほど人々の耳はかえって遠くなった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭い匂が小屋一杯になった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の唇からは煮魚の、かすかに生臭い匂いがしていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こいつも泣き出したのかと気づくと、生臭いやうな不気味な風に吹かれて、私は何うすることも出来ない居たゝまれなさに襲はれた。",
              "citation": {
                "source": "心象風景（続篇）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客共は、血生臭い亡霊の呪ひにおびやかされて息を殺し、谷間は恰も墓場のやうに沈黙してゐた。",
              "citation": {
                "source": "真夏の朝のひとゝき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ればリノリウムを敷き詰めた床の上には、なるほどそのような妖怪の暴れた跡らしく、点々としておびただしいガラスのかけや血海のほかに、なんとなくぬらぬらした穢らしい色の液体が、ところかまわずベタベタと一面にこぼれており、それがまたなんとも言えない生臭いような臭気をさえ、室中に漂わせているのだ。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊博士は、はたと行き詰って、しばらくは生臭い大きな掌でもって頭をぐるぐる撫でまわし、そして左右の目くそを払いおとした。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓という窓の厚ぼったい板戸をしっかり下した上に、隙間隙間にはガーゼを詰めては置いたのだが、霧はどこからともなく流れこんできて廊下の曲り角の灯が、夢のようにボンヤリ潤み、部屋のうちまで、上海の濃霧に特有な生臭い匂いが侵入していたのであった。",
              "citation": {
                "source": "人造人間殺害事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまぐさい春のにほひがする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血なまぐさい軍服や、襦袢は、そこら中に放り出された。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "degenerate (of a monk)",
