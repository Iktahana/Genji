        "examples": {
          "standard": [
            {
              "text": "年越しには、乾麺ではなく近所の蕎麦屋で予約した打ちたての生そばを食べるのが我が家の恒例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生そばは茹で時間が非常に短いため、タイマーをセットして慎重に鍋を見守る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蕎麦粉の香りが強く残る生そばを、まずはつゆをつけずに一口食べてその風味を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは里ことば――すなわち、地方のことばですが、木曾の木とは、生糸の生、生そばの生と同じで、生のままの麻のことを言った古いことばであろうということです。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
