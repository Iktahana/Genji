        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "独占禁止法を無視して、ライバル企業同士が裏で馴れ合っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "政治家と実業家が馴れ合う姿は、国民の不信感を煽るだけだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "監督官庁と業者が馴れ合えば、公正な取引は望めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私どんなひとでも、馴れ合うことは、いやだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "万野となれあうて、お鹿をだました方が、ほんたうだらうと言ふ様な気さへする。",
              "citation": {
                "source": "辻の立ち咄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
