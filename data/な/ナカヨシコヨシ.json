        "examples": {
          "standard": [
            {
              "text": "幼い頃からの仲良しこよしと、久しぶりに再会して積もる話をたくさんした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女たちはいつも仲良しこよしで、まるで姉妹のようにどこへ行くにも一緒だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クラスの皆が仲良しこよしになれるような、楽しいイベントを企画したいと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「なかよしこよし、みんないいこ」　どうかそうあってほしいものだ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場へジャックをやったれば、めすのがちょうを買ってくる、「まあまあ、お母さん、みておいで、そのうちいいこともあるでしょよ」それからがちょうのめすとおすなかよしこよしであそんでる。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
