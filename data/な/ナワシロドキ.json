        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "苗代時ともなれば、村のあちこちでトラクターの音が響き渡り、農繁期の実感が湧く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ちょうど苗代時に降り続く雨は、稲の成長にとって恵みの雨となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "苗代時はまだ朝晩が冷え込むこともあるので、苗の温度管理には非常に気を使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "苗代時期にも、表土の充分乾き切る所を隨所に得られるといふ好條件に惠まれてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、春の訪れから分化した、苗代時の来臨を示してゐる処に注意せねばならぬ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "當麻の田居も、今は苗代時である。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "当麻の田居も、今は苗代時である。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば東北や北海道などで、普通の苗代時期に籾をまくと、水温は十度を一寸越した程度であって、発芽には十日くらいかかる。",
              "citation": {
                "source": "稲の一日",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
