        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供が皿に残ったチョコレートソースを、指で一滴残らず舐め尽くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "犬が散歩から帰ると、喉が渇いていたのか水皿を舐め尽くす勢いで飲んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ソフトクリームが溶けて垂れてくるのを、必死になって舐め尽くす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして村からは、高等小学を出たばかりの、少年や、娘達を、一人も残さず、なめつくすようにその中ぶるの箱の中へ押しこんで。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生物のやうにうごめき、きらめき、なめつくす野火に燒かれるヒースの山が、リード夫人を呪ひ脅迫した私の心の状態に、ぴつたり適合するに違ひない。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
