        "examples": {
          "standard": [
            {
              "text": "田舎の静けさに慣れっこになると、都会の雑踏が耐え難くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の毒舌にはもう慣れっこになって、聞き流す術を身につけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しい訓練も毎日繰り返せば、いつの間にか慣れっこになってしまうものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "人間はなんでも慣れっこになるなんて言うが、それはお人よしの言うことだよ」　びっこひきひきかれは食卓の回りを回って、さらやさじならべた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しいことには違いないが、それもいずれはなれっこになる。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
