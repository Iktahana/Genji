        "examples": {
          "standard": [
            {
              "text": "注射が嫌で、子供は泣きべそをかいて看護師から逃げようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部長に叱られた彼は、まるで子供のように泣きべそをかいて、言い訳を並べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そんなに泣きべそをかいてないで、しっかり前を向きなさい」と、コーチは選手を励ました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「そんな泣きべそをかく子は、いやだよ！",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分から、本を読むということを取ってしまったら、この経験の無い私は、泣きべそをかくことだろう。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニ妙光」　雑念が起ると、泣きべそをかく。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
