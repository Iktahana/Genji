        "examples": {
          "standard": [
            {
              "text": "恩師の退職の挨拶を聞きながら、教え子たちは皆、目に涙を浮かべていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合格発表の掲示板に自分の番号を見つけた瞬間、彼女は瞳に涙を浮かべた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "叱られた直後の子供が、今にも泣き出しそうな顔で涙を浮かべてこちらを見ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてそのような人でも文章を書くときには私の目には人類があると叫んで涙を浮かべることができる。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルクイスト、涙を浮かべる。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ小さなグラチア一人が、涙を浮かべるほどその音楽に感動していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
