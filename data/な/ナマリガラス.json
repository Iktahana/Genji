        "examples": {
          "standard": [
            {
              "text": "「このクリスタルグラスは鉛ガラスで作られているため、指で弾くと美しい余韻が響くんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エックス線室の観察用窓には、放射線を遮断するために厚い鉛ガラスがはめ込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「鉛ガラスは屈折率が高いから、カットを施すとダイヤモンドのように美しく輝くんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "配電盤の前に鉛ガラスの衝立を置いて技師を護る。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者の傍らについて診療する医師は含鉛ゴム製の前掛、手袋、長靴や鉛ガラス製の眼鏡でものものしく身を護る。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像してごらん、レディ・クララ・ビアドビアの欧州一高名な宝石が鉛ガラスだと分かったら。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
