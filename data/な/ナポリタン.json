        "examples": {
          "standard": [
            {
              "text": "喫茶店の定番メニューであるナポリタンは、どこか懐かしいケチャップの味がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピーマンと玉ねぎ、それに赤いウインナーが入ったナポリタンが私の大好物だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太めの麺にソースがよく絡んだナポリタンを、粉チーズをたっぷりかけて頬張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三越の特別食堂てので、スパゲティを食ってみた、淡々たる味で、（ナポリタン）うまい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーフアラモド、グリンピースのポタアジュ、マカロニ・ナポリタン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
