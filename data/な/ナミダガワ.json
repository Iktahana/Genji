        "examples": {
          "standard": [
            {
              "text": "源氏物語のヒロインは、袖が乾く暇もないほど涙川を流して悲しみに暮れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いくら涙川を流して嘆いたところで、失った時間はもう戻ってこない」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い和歌には、愛する人を想って流す涙を「涙川」に例える表現が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "涙川浮ぶ水沫も消えぬべし別れてのちの瀬をもまたずて　泣き泣き乱れ心で書いた、乱れ書きの字の美しいのを見ても、源氏の心は多く惹かれて、この人と最後の会見をしないで自分は行かれるであろうかとも思ったが、いろいろなことが源氏を反省させた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙川うき名をながす身なりとも　今一度のあふせともがな　すぐ返事を書いて正時にお渡になる。",
              "citation": {
                "source": "「平家物語」ぬきほ（言文一致訳）",
                "author": "宮本百合子訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙川憂き名を流す身なりとも　　今ひとたびの逢うせともがな　女房は唯、悲しみに言葉もなく、文をかき抱いて泣き伏していたが、暫くしてから、自分も筆をとって、重衡に別れて辛かった二年来のことを書き、終りに一首、歌を詠んで、知時に渡した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『心に泉む涙川、源は目に見えずとも、神や仏もご照覧。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴしり、第一のむちがふるわれて、膚に当たったとき、もうなみだがわたしの目にあふれ出した。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父上のご心中、戦国春秋の常とはいえ、ご推察するだに、熱いなみだがわきます。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
