[
  {
    "uuid": "4878e031-7fec-5527-a447-b4e3a69d70a0",
    "entry": "廻船問屋",
    "reading": {
      "primary": "かいせんどんや",
      "alternatives": [
        "かいせんどいや"
      ],
      "is_heteronym": false
    },
    "grammar": {
