          "literary": [
            {
              "text": "伸子は、気のりのしない表情で、皮財布のにおいをかいでいる素子の様子を見ていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、彼は細長い皮財布を持っていて、その中の金を家の小さい費用の支弁に当てていた。",
              "citation": {
                "source": "三等郵便局",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の刑事が手を伸ばして拾上げると、まだ水につかって間もない男持ちの皮財布だ。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
