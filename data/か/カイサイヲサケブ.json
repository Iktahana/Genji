    "definitions": [
      {
        "index": 1,
        "gloss": "to shout with exultation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
