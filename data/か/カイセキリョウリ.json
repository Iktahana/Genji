[
  {
    "uuid": "e11efe2c-72f0-5900-85eb-3f6376c488e1",
    "entry": "会席料理",
    "reading": {
      "primary": "かいせきりょうり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
