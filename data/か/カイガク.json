          "literary": [
            {
              "text": "疎開学童は働く楽しみのために農家を手伝ったのではなくて、そうすれば食物を貰えるから、その目的のために働きました。",
              "citation": {
                "source": "美しく豊な生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎開学童から来たといって、嬉しそうにハガキを見せることもあった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎開学童から来たといつて、嬉しさうにハガキを見せることもあつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "榛名南麓の箕輪町でも、疎開学童を受け入れることになったので、校舎の修築、炊事場の新設、井戸を新しく掘るなど、いろいろ準備に忙しい。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この隣組からはまだはじめての疎開学童で、学校の違ふほかの連中よりも一足早く出掛けることになつた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
