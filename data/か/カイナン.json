  {
    "uuid": "04adf2aa-cc89-5bdd-b713-ce0b6225a910",
    "entry": "海南",
    "reading": {
      "primary": "かいなん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "island in the southern sea (esp. Shikoku)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大阪にて海南学校出らしき黒袴下り、乗客も増したり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた胴乱と云って桐の木を刳り抜いて印籠形にした煙草入れを竹の煙管筒にぶら下げたのを腰に差すことが学生間に流行っていて、喧嘩好きの海南健児の中にはそれを一つの攻防の武器と心得ていたのもあったらしい。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八年｜蛾眉に登り、十九年｜粤に入り、海南諸勝に遊び、十一月還りたもう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "神助の凪に艦泊てて月落ちかかるバイヤス灣、椰子の葉蔭に枕ぎて夢むは誰ぞ海南島。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "会でこの作家に「海南賞」を出した気持が判らぬが、賞は秀作に出すものだから、きつと秀れた作品といふのだらう。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中海南島へ漂流したり色々と難儀の揚句、日本へ來たが、其の傳記を淡海三船が作つた。",
              "citation": {
                "source": "平安朝時代の漢文學",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "これやがて両国の文明が海南の小王国に於て相調和したのである。",
              "citation": {
                "source": "琉球史の趨勢",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、先生の海南小記のなか（３）には、竈神の起原に関した話として、かの炭焼き長者に縁因あることを明かされている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）（３）柳田國男著『海南小記』「蘆刈と竈神」というに詳しい。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が太祖は江伯兒の行爲は人倫を絶滅せる、以ての外の非行として、大に怒り之を海南島に遠謫し、且つ禮部に命じて、將來に於ける孝行旌表の事例を詳議させた。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の南方の門戸に當る海南島にも、後くも、宋元時代に、アラブ商人、然らずともイスラム教徒が、かなり移住して居つた樣子で、兔に角この住民にも、蒲姓の人が尠からざる事實がある。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、折竹の義兄が経営する海南社。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この商売の名は、海南島の勝俣翁によってはじめて知った方もあろうが、日本はともかく、海外ではなかなかの収入になる。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "号を海南といい、最初幕府の昌平塾の塾頭もして世間の人にも知られていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "公儀人は藤野正啓氏（海南）、公用人は梯渡氏、留守居は佃杢氏であった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "このホトトギスだが、これは二十九年頃であったろう、郷里の松山で柳原極堂氏が久しく俳句を作っていて、また海南新聞の記者をも兼ねていたから、その印刷機械を利用して、子規氏の俳句を宣伝する雑誌を始めた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "北は樺太までいきましたし、南は海南島から小笠原あたりまでいってみました。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳田先生が、大島で採集して来られたしよんがみい（海南小記）と同根でありさうに思ふ。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "余程どぎもを抜かれたと見え、その後は「スペインの女王」の方へも余り通はないやうであるが、それでも海南島上陸だとかヘンケル機到着といふと、好機逸すべからずとばかり、お祝ひにちよつと一杯などと言ひだす。",
              "citation": {
                "source": "市井閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それでゐて、無関心なのかといへば決してさうでない証拠に、広東でも海南島でも、やる時にはやるべしといふ決意を蔵してゐる。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへいく気かな」「その見当では、近くに海南島がありますが、まさか海南島へは、いかないでしょう。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "南島紀行の「海南小記」（東京朝日発表、後に大岡山書店から単行）の中に、つゝましやかに、言を幽かにして書きこんで置かれた八重山の神々の話が、其であります。",
              "citation": {
                "source": "翁の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那海にも広く棲んでいて、朝鮮西海岸、釜山沖、九州の玄海灘、中支から南支、海南島から佛領印度支那方面にまで分布していて、支那海一帯はトロール船の活躍場所である。",
              "citation": {
                "source": "鯛釣り素人咄",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "海南島に三年いてこの四月に復員したんです。",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海南土佐の一男子として大いにわが意気を見すべしと、そこでは私は大いに奮発して、ドシドシこの出版をつづける事にし、今迄隔月位に出していたのを毎月出すことにした。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第一部　牧野富太郎自叙伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風は昨年も『海南新聞』にて募集したるもの故よろしからず。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくわしい話は、余が『妖怪学講義』の「心理学部門」に書いておいたが、念のために、先ごろ伊予の『海南新聞』に掲げてあった一項を左に転載することにしよう。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "船過台湾海峡（船は台湾海峡を過ぐ）支那海南路、猶看皇国山、暮天雲宿処、一抹是台湾。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "お邸は大尽の、稲葉様の内だって、お小間づかいなんだもの、引摺ってなんぞいるものかね。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんには、わたししかいなんだもの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
