[
  {
    "uuid": "eab22134-8d3b-50ad-a72a-d450345630b2",
    "entry": "会読",
    "reading": {
      "primary": "かいどく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
