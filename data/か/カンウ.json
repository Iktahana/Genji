    "definitions": [
      {
        "index": 1,
        "gloss": "molting (of birds)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悪い虫のつかんうちにお祖父やんのこれと見込んだ男と結婚しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い虫のつかんうちに、お祖父やんのこれと見込んだ男と結婚しなはれ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはいかんうっかりしていて、また探偵小説論を書いていた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その返事もまだ聴かんうちから、よその家へ黙って入ってきやして、警察へ訴えて出たら、あんたはん罪人やおへんか。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この署名の下に捺してあるもん何ですか」いうたら、それはこないこないの訳でと臆面ものうその時のこと細こうに話し出すのんで、みんなまで聞かんうちに腹立って来て、「これ読んで見ると、あんたと、光子さんと、園子との関係は委しいに規定してあるが、園子の夫である私については何の考慮も払われておらん。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫のつかんうちに、子葉殿も、ひとつ心がけておいてくだされ』　と、真面目に云った。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
