[
  {
    "uuid": "9a4f81b5-4497-548c-a367-63fe7bfe7726",
    "entry": "片持ち",
    "reading": {
      "primary": "かたもち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cantilever",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "家人マルメロのカン詰をあけたりとて一片持ち来る。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんはひょっとしてチーズを一｜片持ち合していやしねえかね、え？",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三者として考えると、兄の友人とＥ氏とは性格もちがい、女性への感情の示しかたもちがう人のようです。",
              "citation": {
                "source": "三つのばあい・未亡人はどう生きたらいいか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "額の禿げかたもちがう。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたもち（年寄りたり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたもち（進み出づ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐるり、どっち見ても普通人はチラホラという中にかこまれていれば、やはりくたびれかたもちがうというようなものです、二重の刺戟みたいなもので。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃はすこしましになって口のききかたもちがいますから、お母さん吻っとしてです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
