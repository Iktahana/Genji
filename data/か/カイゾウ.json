[
  {
    "uuid": "789e75f7-2bc1-5765-ba6e-37cd53ffd7e2",
    "entry": "改造",
    "reading": {
      "primary": "かいぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
