    },
    "definitions": [
      {
        "index": 1,
        "gloss": "puppet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして人々は彼を利用し、自己の野心の傀儡にした。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから芥川氏の現在を見て誰しも気附くに違ひない事は、その創作集「羅生門」「傀儡子」時代に一期を畫して完成された芸術的境地に、云ひ換へれば、何時か其処に生じて来た作風の型に自ら飽き足りなくなつたらしい氏は、その境地を踏み出さう、その型を突き破らうとして、明に未に苦しみ続けてゐる事である。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに今自分にあの男を自分の欲望の傀儡にしようと思っていたような気がしてならないのは何故だろう。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴覚のほうが主になれば役者は材木と布切れで作った傀儡でもよい。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚絆穿で、むかし傀儡師と云った、被蓋の箱を頸に掛けて、胸へ着けた、扮装は仔細らしいが、山の手の台所でも、よく見掛ける、所化か、勧行か、まやかしか、風体怪しげなる鉢坊主。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　即ち名所の土の傀儡師が、箱から気を咲かせた草の面影なのであつた。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アアハアアアハア……」空家の傀儡踊　みんな田の草を取りに行っていたし、留守番の女子供も午睡の真最中であったので、只さえ寂びれた田舎町の全体が空ッポのようにヒッソリしていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればとて古い人を新らしく捏直して、何の拠り処もなく自分勝手の糸を疝気筋に引張りまわして変な牽糸傀儡を働かせ、芸術家らしく乙に澄ますのなぞは、地下の枯骨に気の毒で出来ない。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "造物の傀儡となり、蒭狗となつて、倦きられた時投げ出されて死するのが凡人なのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊套教育の傀儡たる教頭の野蠻な比喩が、若々しい血潮の漲つてゐるみんなを憤らしたのは云ふまでもない。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野は火のやうな櫨紅葉に百舌がただ啼きしきるばかり、何処からともなく漂浪うて来た傀儡師の肩の上に、生白い華魁の首が、カツクカツクと眉を振る物凄さも、何時の間にか人々の記憶から掻き消されるやうに消え失せて、寂しい寂しい冬が来る。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮莫、わがルーソー、ボルテイアの輩に欺かれ了らず、又た新聞紙々面大の小天地に※翔して、局促たる政治界の傀儡子となり畢ることもなく、己が夙昔の不平は転じて限りなき満足となり、此満足したる眼を以て蛙飛ぶ古池を眺る身となりしこそ、幸ひなれ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八寸ぐらいある傀儡のようなものがぐったりとなっていた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅師はその傀儡に向って云った。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の帰って来たのは、傀儡の王として再び立てられる為であった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（白人に立てられた傀儡ではない）彼等の心から推服する真の王者へと贈られた・大小酋長からの献上品だ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅師はその傀儡に向って言った。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、かつて物の命を傷うたことがございませんから、どうか許してください」「淫罪がもっとも大きいからいけない、それでも千年間修練するなら命は助かる、とにかく本の形を現わすが宜い」　それとともに傀儡は白い蛇となって、その傍に青い魚の姿も見えてきた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて自分の夫が、彼らは血も涙も持たない資財の傀儡だ！",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恥も人情も知らない資財の傀儡！",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の隣には、小き傀儡場あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧は目を瞋らして傀儡師の方を見やりて云ふやう。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど僧の叫ぶこと愈忙しく、群衆は舊に依りて傀儡師に面し談義僧に背けり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがまことの傀儡なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖像は流石人に敬を起さしめて、四圍の群衆忽ち跪けば、傀儡師も亦壇を下りて跪きぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――衝と避けて、立離るる時、その石垣に立掛けたる人形つかいの傀儡目に留る。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方教育と呼ばれるこうした教育実践が、東北の教師たちに広がっていくその一方で、一九三一（昭和六）年、日本は満州事変を引き起こし、翌年、傀儡政権を立てて満州国の建国を宣言します。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠之が江戸からの歸に兵庫の宿で、世上の聞えをも憚らずに、傀儡女を呼んだこともある。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本家及び資本家の傀儡たる重し共は、無数に並んだ沢庵桶の側で、われ等の見る世界とは似てもつかぬ世界を見てゐるのである。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだかいらいらする」「すっかりくさった」「どれもこれも癪に触って」といった種類のものです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
