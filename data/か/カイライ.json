[
  {
    "uuid": "cedad078-e711-5761-8a08-53401956739d",
    "entry": "傀儡",
    "reading": {
      "primary": "かいらい",
      "alternatives": [
        "くぐつ"
      ],
      "is_heteronym": false
    },
    "grammar": {
