    "definitions": [
      {
        "index": 1,
        "gloss": "to try to find a way out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
