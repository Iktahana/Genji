    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bail out (water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところがそれをあまりかい出すと底が見えて來て、後で入る連中の使ひ水が無くなる。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷もつに火がつくので水をかける、そのあまりをかい出すもの、舟をこぐもの分業で命からがらにげ出したのだ。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱雄といえば旅行先から、帰りがけにここへ立ち寄ると言ってよこしたが、お前はさぞ嬉しかろうなとからかい出す善平、またそのようなことを、もう私は存じませぬ、と光代はくるりと背後を向いて娘らしく怒りぬ。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「寒月君、君の事を譫語にまで言った婦人の名は、当時秘密であったようだが、もう話しても善かろう」と迷亭がからかい出す。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ水をかい出すにどのくらいかかるか、勘定していたじゃないか。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死にてえ、死にてえ」と、仏頂寺弥助が捲舌をつかい出す。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで一文なしでいたやつが、急に金をつかい出すと――それこそ犯人だとくる。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆がからかいだすと、イリューシャの心の中にけなげな精神が、むらむらと湧き起こってきたのです。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
