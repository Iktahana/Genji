[
  {
    "uuid": "594e6fc2-e869-5c4d-860b-acbb2e24612a",
    "entry": "過振り",
    "reading": {
      "primary": "かぶり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
