        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "能楽の演目『石橋』で用いられる巨大な連獅子の被りは、激しい首振りの動作に耐えうるよう、非常に強固な構造で設計されている。",
              "source": "幻辞"
            },
            {
              "text": "「まあ、なんて立派な被りでしょう」と、祭りを訪れた観光客は、黄金に輝く御輿の先導役が身につけた豪華な装束に感嘆の声を上げた。",
              "source": "幻辞"
            },
            {
              "text": "アステカの戦士たちが戦場で身につけていたジャガーを模した被りは、敵を威圧するだけでなく、精霊の加護を得るための祭具としての側面も持っていた。",
              "source": "幻辞"
            },
            {
              "text": "その菩薩像は、精緻な透かし彫りと宝石が散りばめられた華麗な被りを戴いており、当時の高度な金属工芸技術の粋を現代に伝えている。",
              "source": "幻辞"
            },
            {
              "text": "時代劇の撮影現場では、カツラの上に装着する被りの角度一つで、武将としての威厳やキャラクターの鋭さが大きく左右される。",
              "source": "幻辞"
            },
            {
              "text": "吹雪に見舞われた山岳地帯の修行僧は、被りを深く下げて顔を覆い、読経を唱えながら一歩一歩踏みしめるようにして峻険な道を登っていった。",
              "source": "幻辞"
            },
            {
              "text": "パプアニューギニアの特定の部族に伝わる、極楽鳥の羽を贅沢に使った巨大な被りは、成人儀礼において一族の誇りと社会的地位を示す重要な装束である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」と聖人は、頬被りをとつて莊重に朝の挨拶をする。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は白｜頭巾に白の上っ被りという姿である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は上着を着、帽を被り、何か用あり気に戸の近くに立ち留りいる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "前夜の雨が晴て空は薄雲の隙間から日影が洩ては居るものゝ梅雨季は爭はれず、天際は重い雨雲が被り重なつて居た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は先づ押ずしなるものを一つ摘んで見たが酢が利き過ぎてとても喰へぬのでお止めにして更に辨當の一｜隅に箸を着けて見たがポロ／＼飯で病人に大毒と悟り、これも御免を被り、元來小食の自分、別に苦にもならず總てを義母にお任して茶ばかり飮んで内心一の悔を懷きながら老人夫婦をそれとなく觀察して居た。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘二人を島に揚げし後は若者ら寒しとて毛布被り足を縮めて臥しぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日源叔父は布団｜被りしまま起出でず、何も食わず、頭を布団の外にすらいださざりき。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "初見の土地へ対しても、すつとこ被りもなるまいし……コツツンと音のするまで、帽子の頂辺を敲いて、嵌めて、「天気模様は如何でせうな。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも日本武士的、鎌倉もしくは足利期的の仏であるが、地蔵十輪経に、この菩薩はあるいは阿索洛身を現わすとあるから、甲を被り馬に乗って、甘くない顔をしていられても不思議はないのである。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお黙ってはいたが、コックリと点頭して是認した彼の眼の中には露が潤んで、折から真赤に夕焼けした空の光りが華※しく明るく落ちて、その薄汚い頬被りの手拭、その下から少し洩れている額のぼうぼう生えの髪さき、垢じみた赭い顔、それらのすべてを無残に暴露した。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒無地の紬の重ねを着てハンチングを被り、ステッキを持って旅に出かけたのである。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いままで拭き掃除していたものらしく、箒持って、手拭いを、あねさん被りにしたままで、「どうぞ。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、村のひとたちは頬被りして二人三人づつかたまつてテントのなかにはひつていつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬被りしたお客たちの怒號と拍手。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、村のひとたちは頬被りして二人三人ずつかたまってテントのなかにはいっていった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬被りしたお客たちの怒号と拍手。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心｜暫くも安らかなるなし、一度梟身を尽して、又｜新に梟身を得、審に諸の苦患を被りて、又｜尽ることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "審に諸の苦患を被りて、又尽くることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度梟身を尽して、又｜新に梟身を得、審に諸の患難を被りて、又尽くることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "審に諸の患難を被りて、又尽くることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心｜暫くも安らかなるなし、一度梟身を尽して、又｜新に梟身を得、審に諸の苦患を被りて、又尽ることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "審に諸の苦患を被りて又尽くることなし。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鬼に呼び止められた亡者のような悲し気な顔でチラリと、恐ろしそうに眉香子の顔を振り返っただけで……それでもイクラか落ちついたらしく、長椅子の上に引っかけた上衣を横筋違いに引被りながら、ヨロヨロと応接間を出て行った。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年近く被り慣れた大黒帽を被り、少しだぶだぶな焦茶色の出来合い外套を着こむともうすることはなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月になっても被りつづけている麦稈帽子、それは狐が化けたような色をしている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へん、大袈裟な真似をしやがって、　と云う声がしたので、見ると大黒帽の上から三角布で頬被りをした男が、不平相にあたりを見廻して居たが、一人の巡査が彼を見おろして居るのに気が附くと、しげしげそれを見返して、唾でも吐き出す様に、畜生。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "性情に被りついて仕舞った何という伝統の厚い皮だ。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水浴がえりの女の群の一様に大なる藁帽子かぶりたるなど目に立つ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り株ばかりの冬田の中を紅もめんやうこんもめんで頬かぶりをした若い衆が酒の勢いで縦横に駆け回るのはなかなか威勢がいい、近辺のスパルタ人種の子供らはめいめいに小さな凧を揚げてそれを大凧の尾にからみつかせ、その断片を掠奪しようと争うのである。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
