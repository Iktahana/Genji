[
  {
    "uuid": "8ba0d01d-ab73-58c2-9385-ab0303c9f86b",
    "entry": "回付",
    "reading": {
      "primary": "かいふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
