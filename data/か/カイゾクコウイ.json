          "literary": [
            {
              "text": "そのうえ海岸線では英国船が貝の密漁や海賊行為をしている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは不足によるもので、時には海賊行為と海の危険によるが、しばしば商人が供給を「買い占める」ことによる。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "オランダ人はこの捕獲が海賊行為でないことを立証するために、乗員中に宣教師がいることを主張した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペイン人はオランダ人の叛逆と海賊行為とを指摘し、オランダ人はスペイン人のペルーやメキシコの征服を指摘した。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
