          "literary": [
            {
              "text": "農夫海牛のやうな農夫よ田舍の家根には草が生え、夕餉の烟ほの白く空にただよふ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の寒ざらしの貧しい田舍で愚鈍な　海牛のやうな農夫よ。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農夫海牛のやうな農夫よ田舍の屋根には草が生え、夕餉の煙ほの白く空にただよふ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々たる海牛丸、二千五百｜噸の機関長が、コンナ部屋に跼まっているんだから推して知るべしだろう。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ・Ｇ・Ｍが海牛丸の洒落と気付かなかったばっかりにスッカリ底をハタイちゃったね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ熊城君、一七五三年にベーリング島の附近で、海牛の最後の種類が屠殺されたんだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
