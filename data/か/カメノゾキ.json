    "definitions": [
      {
        "index": 1,
        "gloss": "faint indigo blue (traditional Japanese color name)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
