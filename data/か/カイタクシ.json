[
  {
    "uuid": "09b8b136-6bb9-5ea1-8400-1c8b80253556",
    "entry": "開拓使",
    "reading": {
      "primary": "かいたくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
