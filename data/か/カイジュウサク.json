    "definitions": [
      {
        "index": 1,
        "gloss": "measure to win someone over to one's side",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
