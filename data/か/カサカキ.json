    "definitions": [
      {
        "index": 1,
        "gloss": "person with a skin disease (esp. syphilis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
