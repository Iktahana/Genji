[
  {
    "uuid": "df8fdbc1-5017-5fb4-a6ff-2bf4a39f72df",
    "entry": "解任",
    "reading": {
      "primary": "かいにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
