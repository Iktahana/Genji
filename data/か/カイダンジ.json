        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日の日本は、千の平凡人よりも一人の快男児を要し、十万百万の平凡人よりも、一人の英雄豪傑を要する時代なり、大英雄、大豪傑出でずんば、日本は世界の大舞台に立つて、宇内の第一等国となる能はず。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し定基は流石に快男児だった、愛も痴もここまでに到れば突当りまで行ったものだった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡泊洗ふが如き孤剣の快男児（蒼海）この席の談笑を共にせざるこそ終生の恨なり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "子路が他の所ではあくまで人の下風に立つを潔しとしない独立｜不羈の男であり、一諾千金の快男児であるだけに、碌々たる凡弟子然として孔子の前に侍っている姿は、人々に確かに奇異な感じを与えた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにこの頃になると、既に子路の名は孔門｜随一の快男児として天下に響いていた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "快男児なり、）も同行。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下無敵の快男児で、乱暴者ばかり扱い狃れている内田良平、杉山茂丸も持て余した程の喧嘩の専門家であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "路伴れは田所碧洋とて、蛮骨稜々たる快男児、旭川市を根拠として嚮導を求めしに、成田嘉助氏という豪の者を得たり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "余好意を謝してその容貌を見るに、魁偉にして筋骨｜逞しく、磊落にして豪傑肌なる快男児也。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その快男児ですが、変人変物という点においては、およそ天下にこんな珍しい一対はあるまいと思われる右門と伝六のところへわざわざ仲間入りするんですから、この新しいわき役なる者がまた尋常一様の男ではないので。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は彼も亦一箇の快男児であると信ずる。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "繰返して云うが、決して唯の鉄のような所謂快男児などの類ではない。",
              "citation": {
                "source": "江口渙氏の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "江口を快男児にするも善い誤解の一つだ。",
              "citation": {
                "source": "江口渙氏の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "江口は快男児だとすれば、憂欝な快男児だ。",
              "citation": {
                "source": "江口渙氏の事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "前任地では管内の博徒を顫え上らした人で、真っすぐな竹を割ったような気性の人で、よく物の分る半面には中々譲らない所があり、場合によると非常に熱狂的な快男児だった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "※夕刻のロングビイチは鉛色のヘイズに覆われ、競艇コオスは夏に似ぬ冷気に襲われ、一種｜凄壮の気｜漲る時、海国日本の快男児九名は真紅のオォル持つ手に血のにじめるが如き汗を滴らしつつ必死の奮闘を続けて遂に敗れた。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "≪夕刻のロングビイチは鉛色のヘイズに覆われ、競艇コオスは夏に似ぬ冷気に襲われ、一種｜凄壮の気｜漲る時、海国日本の快男児九名は真紅のオォル持つ手に血のにじめるが如き汗を滴らしつつ必死の奮闘を続けて遂に敗れた。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "※夕刻のロングビイチは鉛色のヘイズに覆われ、競艇コオスは夏に似ぬ冷気に襲われ、一種凄壮の気漲る時、海国日本の快男児九名は真紅のオォル持つ手に血のにじめるが如き汗を滴らしつつ必死の奮闘を続けて遂に敗れた。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦長は橘少佐、播州赤穂に生まれた快男児である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "時代と相容るゝ能はざる幾多、不覇不絆の快男児が、超世の奇才を抱いて空しく三尺の蒿下に槁死することを得ず。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠実な訳、巧妙な訳、しつかりした訳、こなれた訳、そんな褒めかたではいつこう歯の立たぬ代物で、これこそ、ボーマルシエが辰野博士にのり移り、両者の舌を一枚に重ね、作者の洋才と訳者の和魂とがにぎやかにもつれ合つて封建末期の快男児フイガロ貧雅郎の一大活劇を語り聴かしているという風な書物である。",
              "citation": {
                "source": "秘伝の名訳",
                "author": "――ボーマルシエ、辰野隆訳『フィガロの結婚』",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、快男児太刀川時夫も、ついに最期の時が来たのか。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、快男児太刀川時夫は、一たい、どうしていたか。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "快男児｜沖島　この黄いろい幽霊とは、そも、何者であろうか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水上瀧太郎はその信ずる処を言うに憚らざるの快男児なり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、実際、快男児だ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、彼は元来が芸人で、明治初年に渡米し、彼の地で芸人から商人に転業した立志伝中の快男児である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯友社の最後をかざる豪放な作家で、胸のすくような快男児であった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがいろいろの機会に発表されるようになると、これも亡くなった快男児の東健而氏が、「マッコーマックを嫌いだなんて言う奴は生意気だ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
