    "definitions": [
      {
        "index": 1,
        "gloss": "initiation into an art or discipline",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
