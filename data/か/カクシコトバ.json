    "definitions": [
      {
        "index": 1,
        "gloss": "secret language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして皆が別々に、わけの分らぬことを叫んだが、どうやらそれはこの一団の隠し言葉であって自分の名乗をあげたものらしかった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の間には何時の間にか種々な隠し言葉が出来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、忌み言葉と言ふもの、隠し言葉、隠語です。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この私たちには、いつのまにか、いろいろな隠し言葉もできた。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "産所すなわち山陰地方でいうハチヤ或いはハチと同類で、越中でトウナイというのもつまりは「十無い」で、「八」ということを避けた隠し言葉でありましょう。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた隠し言葉にもある。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば酒のことを般若湯といって見たり、甘露水といって見たり香水といったりするのはみな隠し言葉である。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半之助はそのなかで、「隠し言葉」「隠し草鞋」「隠し湯」などということを、面白く聞いた。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
