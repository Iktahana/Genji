[
  {
    "uuid": "88596c87-8fdc-53e7-af85-f2c6f3e987cc",
    "entry": "会社",
    "reading": {
      "primary": "かいしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
