        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "當選圏内の最下位者政友會の中川誠也とのひらきは三百票にすぎない。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うこんしゃっぽのカンカラカンのカアン　あかいしゃっぽのカンカラカンのカアン。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまな語尾のみじかいしゃべりやわらいごえ。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "御かいしゃくは福寿庵どのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御かいしゃくは浅井｜日向守。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんは、あるかいしゃのしゃちょうさんです。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
