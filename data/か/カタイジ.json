[
  {
    "uuid": "29debf20-9c8e-5169-bde5-d0c52f7355b3",
    "entry": "片意地",
    "reading": {
      "primary": "かたいじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
