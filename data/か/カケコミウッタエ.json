    "definitions": [
      {
        "index": 1,
        "gloss": "bypassing normal legal procedures and making a direct appeal to a top official (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この絵図面にあるとおり、屋敷の裏門前に怪しい死人がござるゆえお出まし願いたいと、駆け込み訴えをして帰ったんで、さっきから不思議に思って考えているんじゃねえかよ」「いっこうに不思議はないね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆け込み訴えがあったら考えることはねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間の経緯には、面白い話も沢山ありますが、それはグイと端折って、いよいよ、上州屋の佐吉は、女房殺しとしてお所刑になろうと決った日の夕方、南町奉行所へ駆け込み訴えをしたものがあります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第六夜　人形の獄門",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ね親分、相手がいやな事をしあがると、ここからは眼と鼻の間の龍の口御評定所へ駆け込み訴えをするからそう思え――と言って下さい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざまア見あがれ、明日は龍の口の評定所へ駆け込み訴えだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "見え隠れに八をつけてやるから、すぐ番所へ駆け込み訴えをしろ、お係り同心が出役になっているはずだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの三文字屋の娘――お美乃とかいうのが、南の御奉行所へ駆け込み訴えをやりましたぜ」「何？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "駆け込み訴えもモノによりけりだ」　平次はそう言いきって、心の底から淋しさを感じておりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから南の御奉行所へ駆け込み訴えだ」「馬鹿な事をしちゃアならねえ」　平次は驚いて飛出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "叡山の一法師が、駆け込み訴えをして来た。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
