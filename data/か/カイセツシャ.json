[
  {
    "uuid": "5ed44cd3-f86d-5f49-887c-662138bea418",
    "entry": "解説者",
    "reading": {
      "primary": "かいせつしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "commentator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この異彩ある珍書は著者、解説者、装幀意匠者、製紙工、染織工、印刷工、製本工の共同制作によってできあがった一つの総合芸術品としても愛書家の秘蔵に値するものであろう。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも解説者は小島政二郎氏であって、小島氏は、小説家としては私たちの先輩であり、その人の「新居」という短篇集を、私が中学時代に愛読いたしました。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえかな美しさにうっとりしていると、解説者は南十字星へ矢印の青い光を向けて、「――さて、皆さん、ここに南十字星が現われて、わたし達はいよいよ南方の空までやって来ました。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからあれがこうくると、こっちはこういく」将棋の解説者のようなこの手の戦評や、メーカーの謳い文句の垂れ流しは、おっさんの趣味ではなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来の解説者がここを説明して示さないは残念である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "石原氏がその学説の解説者として自身を示したアインシュタインのナチから受けた迫害などを実際に見て、果して石原氏の感想はどうであろう。",
              "citation": {
                "source": "作家のみた科学者の文学的活動",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四年間の猶予ということは、取りも直さず、ずるずるで払わないでも済んでしまうという可能性をもっていると、その解説者も明快に説明した。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "解説者は、大衆の中には一割位しか保有されていない公債であると言った。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点はラジオの解説者が力説したところであった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀に大芸術家、科学者、政治家を輩出させた社会の創造的可能性は、その矛盾の深まるにつれてしだいに萎靡して、二十世紀前半は、ほとんどあらゆる分野においてその解説者、末流、傍系的才能しか発芽させえなかった。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "写実主義時代といえば、二葉亭から緑雨、露伴の「風流仏」というのでは、解説者の努力によってのみなにかの新しい文化史的価値がそえられるという程度ではないかと危ぶまれる。",
              "citation": {
                "source": "「現代日本小説大系」刊行委員会への希望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋哲学の講釈や、東洋思想の解説者はなるほど腐る程いるかも知れない。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "三木清という哲学者は、西田幾多郎の哲学の解説者であり、戦争中は南方に出かけたりしていた。",
              "citation": {
                "source": "行為の価値",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いち早く、フランスは頽廃した文化主義で敗れたというような解説者に対して、常識はそれが全部の答えでないことを直感していた。",
              "citation": {
                "source": "今日の作家と読者",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "対話以外にそういう説明がいるときは、解説者を使うこともあるが、さまざまな音響効果、音楽、または、ギリシヤ劇風の合唱団を使つてもよい。",
              "citation": {
                "source": "ラジオ・ドラマ私見",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢字典の記載法を思ふと、解説者の、用語例に関する限界が、時には近過ぎたり、遠ざかり過ぎてゐることが多い。",
              "citation": {
                "source": "言語の用語例の推移",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、諺に対しては、ある解説を要する場合が多く、其解説者としての宿老が、何処にも居つたのである。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時事新報の将棋欄の解説者が、木村名人を評して、彼は何でも出来る人物だから、参議院議員となったらよかろう、と云っていたが、まことにバカげたことで、将棋家は将棋を一生の業とすべく、軍人が政治に口をだしたりすると国が亡びる。",
              "citation": {
                "source": "戦後新人論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある解説者は、すべての隣人を例外なしに正・負の差別なしに愛せよと教える。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「愁嘆場」で「美文」をまぜる弁士（映画解説者）の口吻は、全トーキーの今日では偲ぶよすがもなくなつてゐるが、そのころの弁士の存在たるや、下町にも山の手にも、云ひ換へると庶民階級にもインテリ階級にも、若い男女にとつて凡そかがやかしくハイカラな存在だつた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい宇宙論の提唱者かつ解説者として彼の名は、英国でベスト・セラーになり、世界各国語に翻訳されて、広く読まれている。",
              "citation": {
                "source": "エスキモーの国から",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐突な比較だが、いつぞや白洲正子さんもそれをいつてゐられたやうに、相撲放送の解説者はまことに好ましい音声を聞かしてくれる。",
              "citation": {
                "source": "棋家の文章など",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後藤は嘗て一高の校友会雑誌に「べつたら市」と云ふ詩を寄せ、「何のことだか田舎者には分るめえ」と脂下つてゐたところ、豈図らんや文藝部委員の一人がその詩の批評をし、べつたら市の解説までしたので、「一高にも少しは江戸ツ児がゐるんだな」と思つて、その解説者を調べてみると、それが私だつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で問題はいつも、この文化・この思想・この自由や人間性、これはインテリゲンチャ自身の観念からではなくて、大衆の無意識的な文化的要求の解説者で代弁者であることを委任された限りのインテリゲンチャの立場から、初めて正当に問題になるものだ、という点にあるのだ。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとじこみは、山上元という最も適切な解説者つきで、モスク※に移動して来ている在外日本革命小図書館とでもいうべきものなのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた天文学に大きな貢献をし、イギリスにおける最初のコペルニクスの解説者である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、世のいわゆる国文学解説者は、この一連の伝統を知らざるかのごとく、訓詁註釈にのみ熱心なること比々然りである。",
              "citation": {
                "source": "女性史研究の立場から",
                "author": "高群逸枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "このビザンティン期にある程度は目立った医師がいたが、彼らは主として解説者であり、医学は前進するよりはむしろ後退した。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "解剖学の本の著者でありヒポクラテス学派の著書の解説者であったサテュロスや、ストラコニコス、アエスクリオンからガレノスは学び多くのことを見たり聞いたりした。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
