    "definitions": [
      {
        "index": 1,
        "gloss": "structural alteration (of a building)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
