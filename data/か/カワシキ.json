        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "台風による増水で、普段は穏やかな流れの川敷が完全に水没し、茶褐色の濁流が渦を巻いている。",
              "source": "幻辞"
            },
            {
              "text": "川敷に設けられた広場では、週末になると地元の少年野球チームが熱心に練習に打ち込んでいる。",
              "source": "幻辞"
            },
            {
              "text": "川敷の整備工事に伴い、一部の立ち入りが制限されるため、近隣住民への説明会が開催された。",
              "source": "幻辞"
            },
            {
              "text": "自然保護団体が、川敷に生息する希少な野鳥の保護を訴え、過度な開発の中止を求めている。",
              "source": "幻辞"
            },
            {
              "text": "夏の夜、川敷から打ち上げられる大輪の花火が、川面に映し出されて幻想的な光景を作り出した。",
              "source": "幻辞"
            },
            {
              "text": "都市部において、貴重なオープンスペースである川敷は、災害時の避難場所としても重要な役割を担っている。",
              "source": "幻辞"
            },
            {
              "text": "川敷に自生する葦の群生は、水質の浄化を助けるとともに、多くの生き物たちの隠れ家となっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは、火山岩か火成岩が川敷に押しひろがっているからである。",
              "citation": {
                "source": "瀞",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、羽村から下流の多摩川の水は多摩川本来の水とは全く縁を絶って、いまでは、僅かに一本の支流秋川を合わせるのみで、他は全部田用水の落ち尻か、川敷からわき出た水ばかりである。",
              "citation": {
                "source": "香魚と水質",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵北部から上州へかけて、古川と言う小流または廃川敷と覚しき一帯の平地がすこぶる多い。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通りの暴言の締めはきつい裏拳一発、僕もかわしきれなかった。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "合祀のためかかる嘆かわしきこと多く行なわるるは、前日増田于信氏が史蹟保存会で演べたりと承る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この窟上下四方すべて滑らかにして堅き岩なれば、これらの名は皆その凸く張り出でたるところを似つかわしきものに擬えて、昔の法師らの呼びなせしものにて、窟の内に別に一々岩あるにはあらず。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に歎かわしきことならずや。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実になげかわしき至りであります。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内から吹きあげる血の苦がい、灼けるやうな飛沫が叫ぶ、とうてい身はかわしきれないと。",
              "citation": {
                "source": "逸見猶吉詩集",
                "author": "逸見猶吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主　（品位ある風采、この時代の豪族に似つかわしき服装、腰に剣をつるす。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通り抜ける途端に、風を切って何物かが落ちて来ると覚えたから兵馬は、ひらりと身をかわしたけれども、口惜しいことに、かわしきれませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――前条難渋の宿柄、実もって嘆かわしき次第にこれあり候。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "またなげかわしき事に存候。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……、人から御覧なされば、たいそう見苦しいようでござりませうが、私にとつては、実に千万金にも替へ難い宝で、真に私に似つかわしき品なのでございます。",
              "citation": {
                "source": "こわれ指環",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この稼業をしてからざっと十年、もう男の厄はとうに越しましたが、腕っ節の良いのと、人間の甘い外には取柄がなく、何時まで経っても、鼠を捕らぬ猫に例えられる、まことに慨かわしき存在だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くはかの教科書事件や日糖事件をはじめ、中央及び地方の官吏や議員の間より犯罪人を出すことが非常に多くなったのは、如何にも歎かわしきことである。",
              "citation": {
                "source": "選挙人に与う",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを普通の虚無僧だと思って、その右を通り抜けようとした時に、その虚無僧が尺八を振り上げて、風を切って打ちこんで来たのを、かわすにはかわしたが、充分にかわしきれないで、この指先を砕かれた。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を反らしたが、十之丞に足首をつかまれていたため、かわしきれずに、桑原甚内は、左京の刀下に、真二つになって仆れた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等がその準備として通常の生活と別れる際に、山に入って花を摘み、海川に下って身を潔め、少女としては容易ならぬ気づかわしき謹慎を始める事は、花やかにして、同時に物哀れな光景であったことと思う。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのねばっこい質問には、玄徳もかわしきれなくなった。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "譜代のご恩もわすれた嘆かわしき武門の廃れ、はや見ているにしのびません」「では、出陣を望むのか」「わが四ツ目｜結の旗を先に立て、そのような忘恩の大名どもへ、後日、悔いを噛むなと、言ってやりたいのでございまする」「しおらしい」　高時は、賞めそやしたが。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
