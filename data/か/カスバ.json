        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "コノール　聖僧の首長カスバの予言を覚えているか？",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスバはその眼の前に血の海を見ました、その海は次第に陸にひろがり、大谿に溢れみなぎり、高山の背を洗い浸し、山々の峰をこえて、ゲエルの全地に鳴りとどろく赤い血の洪水となって流れおち、赤い血の海にまで流れ入ったということでございます。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノール　（不安そうに、徐かに歩き廻る）カスバは最後まで見たのであろうか？",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノール　智者カスバの最後の言葉は何であったか？",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "デュアック　カスバは、すべて来るべき事を見たのでございました。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスバの予言もはずれるであろう。",
              "citation": {
                "source": "ウスナの家",
                "author": "THE HOUSE OF USNA",
                "note": "青空文庫"
              }
            },
            {
              "text": "カスバのペペル・モコみたいに、東京を望郷しておる。",
              "citation": {
                "source": "望郷",
                "author": "竹内浩三",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々の家へはいり込んで、みんなに尋ねて、ザーミ姉さんやクリスチャンやカスバル小父さんなんかをつかまえたの。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "町を一寸歩いて、うちの青年部五六名、成田のカスバへやり、十時頃床へ入ったが、結局一時すぎ迄寝られなかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
