    "definitions": [
      {
        "index": 1,
        "gloss": "way of solving (a problem)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
