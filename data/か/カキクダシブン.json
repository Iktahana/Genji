          "literary": [
            {
              "text": "一　書き下し文、および索引は、歴史的かなづかいにより、その他の部分は、新かなづかいによつた。",
              "citation": {
                "source": "古事記",
                "author": "凡例",
                "note": "青空文庫"
              }
            },
            {
              "text": "この番號は、本書の書き下し文の各歌謠の終りに記してある。",
              "citation": {
                "source": "古事記",
                "author": "歌謠各句索引",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って同じ書き下し文を書くにしても、つい六つかしい文字を使えば、送りがなも概して倹約する。",
              "citation": {
                "source": "書物を愛する道",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本外史を書き下し文に改め、漢籍を和字文にするということは岩波でも始めて居る。",
              "citation": {
                "source": "書物を愛する道",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
