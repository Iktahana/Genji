[
  {
    "uuid": "9131a37e-2ebb-515b-9150-20c373ffe8cd",
    "entry": "海浦",
    "reading": {
      "primary": "かいほ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
