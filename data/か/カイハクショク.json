[
  {
    "uuid": "d6606d61-76a9-57ce-9b5a-6bd9e53b580c",
    "entry": "灰白色",
    "reading": {
      "primary": "かいはくしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
