      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grayish white",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よく見ていると靄は水上からだんだん灰白色の厚味を増して来る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏は灰白色に變つて、脣は紫色にしぼんでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、ちょっと見ると火打ち石のように見える堅緻で灰白色で鋭い稜角を示したのもあるが、この種のものであまり大きい破片は少なくもこのへんでは見当たらない。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋の壁の鼠色も収穫小屋のまだらな灰白色も、緑蔭と日光との綾の中にさながら小跳りをしているようだ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その灰白色の穂はニヒリストのやうな白々しさしか感じさせない。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう署長に言はれて、受話器を受け取るなり耳に當てたが、向ふはグスタフソン警視でその聲は凄まじいばかりの興奮に殆ど聞き取れないほどだつたが、ソオルの顏は忽ちさつと灰白色に變つてしまつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁づとの褪めたる色、ハヒビヤクシンの傾斜面の暗青色の静止――短艇の船腹の如き雲灰白色の別館の上に薄れんとし、ヒマラヤ杉ひとり早春の風に戦ぐ。",
              "citation": {
                "source": "春の暗示",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "両側には装飾電球の支柱が各戸ごとに並んで、遠い遠い正面には工場の白い門と大きな灰白色の建物ばかりが埃りっぽく見えるだけで、妙に面白くない通りであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁づとの褪めたる色、ハヒビヤクシンの傾斜面の暗青色の静止――短艇の船腹の如き雲灰白色の別館の上に薄れんとし、ヒマラヤ杉ひとり早春の風に戦ぐ、大きなる魚の青き骨のごとく。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎろぎろする両眼の光とともに灰白色の動物の頭が見えた。",
              "citation": {
                "source": "鍛冶の母",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づきて始めて山を見し時、岩石の灰白色なるもの、其質此の如きものあるを思ふ。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "動く度に色を変える玉虫めいた灰白色の胴には、派手なネクタイの柄のように、赤紫色の太い縞が幾本か鮮かに引かれている。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰白色の搖動く幻だけが此の島の主となる日を考へると、妙にうそ寒い氣持がして來た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰白色の揺動く幻だけがこの島の主となる日を考えると、妙にうそ寒い気持がして来た。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が来るとその上からコオリ山（灰白色の紬の一種）の羽織を羽織った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "右舷の山には樹木は少ないが、灰白色の山骨は美しい浅緑の草だか灌木だかでおおわれている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入場料を払って関門を入ると、そこは二千余年前の文化の化石で、見渡す限りただ灰白色をした低い建物の死骸である。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、うめのきごけが、樹皮の乾燥している老幹に宿をかりるという、科学的な、又は自然的な関係からばかりでなく、自然の美的情緒を深めるためにも、梅の老樹を灰白色に、或いは茶褐色にぬりつぶしているような気がします。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰白色の靄が女の姿を折おり包んで見えた。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緩燃導火線であるし、いきなり爆発するものでない、という事を、百も承知していても、一間位隣りで、灰白色の煙を勢よく吹いている、ハッパ穴の前では、そんなにのんびり仕事をしてる訳に行くものではなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰白色の光線が私達の肉体を射透した。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "天を限って聳え立ったこの高いゆたかな岩山には恰もまともに夕日がさして灰白色の山全体がさながら氷の山の様な静けさを含んで見えているのであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、川の左に聳える荒削りされたような山が、山国川に臨むところで、十丈に近い絶壁に切り立たれて、そこに灰白色のぎざぎざした襞の多い肌を露出しているのであった。",
              "citation": {
                "source": "恩讐の彼方に",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ、其処へ這入つて行くと、灰白色の化粧煉瓦の如きもので腰を巻かれた、暗い水色の壁が私の眼を打つた。",
              "citation": {
                "source": "アリア人の孤独",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処には最早旅愁をそゝのかされるやうな物売の呼声を聞くことができぬ、意外に空気は急忙だしいが厳粛なものであつた、私は押し流されるやうにして、この魔宮の正門に達する大理石の舗石の如く、又は、監獄へゆく灰白色の坦道に似た長いプラツトホームを顫へながら急ぎ足に歩いた時の心地は今にも忘れることができない。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううーッ、ここを開け――開けて下さい」　灰白色の毒ガスはプスと低い音をたてて、床の上を匍い、霧のように渦をまいて、だんだんと高く舞いのぼってゆくのであった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士コハクは灰白色の毒ガスの中に、まるで塑像のように立っていた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして私達の船が、危く波の畝の上を漂つてゐる時、その時、海軍の水雷庫を出た一隻のランチは、灰白色をした軽捷な、長い船体を勇ましく波濤の中に見せて、一直線に横須賀の方へと馳つて行くのを私達は目にした。",
              "citation": {
                "source": "ある日",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "背はそれほど高くはないが、鳶色の縮れた毛髪をもち、顔は林檎のように赤く、そして男が着るような灰白色のバーバリ・コートを着て頤を襟深く隠していた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お椀のような頭蓋骨が、下に落ちると、頭蓋腔の中から、灰白色の脳がとびだしてきた。",
              "citation": {
                "source": "人体解剖を看るの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
