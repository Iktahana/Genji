          "literary": [
            {
              "text": "一九五五（昭和三十）年、稲盛和夫は鹿児島大学工学部応用化学科を卒業し、高圧電線用の碍子メーカーである京都の松風工業に入社した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等小学校時代に結核を患った稲盛は、この経験もあって大阪大学の医学部薬学科を志望したが果たせず、家族の強い勧めで二期校の鹿児島大学に進んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
