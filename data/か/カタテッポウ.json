        "examples": {
          "standard": [
            {
              "text": "立ち合いの瞬間、鋭い片鉄炮を浴びせて相手の出鼻をくじいた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "稽古中、師匠の強烈な片鉄炮を受けて土俵の端まで弾き飛ばされた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「うわっ、不意打ちの片鉄炮はやめろよ」と彼は胸を押さえながら苦笑いした。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "片鉄炮は一見単純な動作だが、片手に全体重を乗せるには高度な技術を要する。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "相手の懐に飛び込もうとしたが、突き放すような片鉄炮で押し返された。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "片鉄炮の一撃でバランスを崩し、あえなく土俵を割ってしまった。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": []
        }
