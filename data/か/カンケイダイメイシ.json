          "literary": [
            {
              "text": "関係――ええと――関係代名詞？",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそう関係代名詞だね。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は無風帯を横ぎる帆船のように、動詞のテンスを見落したり関係代名詞を間違えたり、行き悩み行き悩み進んで行った。",
              "citation": {
                "source": "保吉の手帳から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語も関係代名詞をたくさんつなげていけば日本語に比べてかなり長い文章が作れるが、そのもっとすごいのがラテン語なんだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
