    "definitions": [
      {
        "index": 1,
        "gloss": "school opening ceremony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
