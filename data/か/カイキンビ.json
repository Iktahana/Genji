        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "成程その日は十月十五日、銃猟の解禁日であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう性質の流水であるから、東海道の諸川や、栃木、茨城方面の川が、六月一日の解禁日から、もう盛んに友釣りに掛かるというのに、利根川の鮎は早くても七月に入らなければ囮鮎を追わなかった。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月一日の鮎漁解禁日がくると、引き続いて毎日出かけた。",
              "citation": {
                "source": "想い出",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月一日の鮎の解禁日に大いに釣ろうというので、三好達治は釣り竿の手入れに熱中していた。",
              "citation": {
                "source": "釣り師の心境",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおかた、今日が漁の解禁日だということを御存じないと見える。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯月は旧暦であるから五月の初め、解禁日である。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその日が解禁日、針があたったので、おもしろいほど釣れる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "各河川とも五月中旬が川開きで、川開きというと東京の花火のように聞こえるが、つまり解禁日にあたる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
