[
  {
    "uuid": "5a0ffcbb-0e27-574c-9dbb-44da65a2e0a5",
    "entry": "回顧的",
    "reading": {
      "primary": "かいこてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
