          "literary": [
            {
              "text": "さても笑止や、垣根のそとで障子張るひと、椿の花が上に真赤に輝けば張られた障子もくわつと照る、烏勘左衛門、烏啼かせてくわつと吹くよかよか飴屋のちやるめらもみんなよしよし、粉嚢やつこらさと担いで、禿げた粉屋も飛んでゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻之四、烏勘左衛門、獣の伉侠。",
              "citation": {
                "source": "春水と三馬",
                "author": "桑木厳翼",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざえもんは　くろいあたまをくうらりくらり、　とんびとうざえもんは　あぶら一｜升でとうろりとろり、　そのくらやみはふくろうの　いさみにいさむもののふが　みみずをつかむときなるぞ　ねとりを襲うときなるぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
