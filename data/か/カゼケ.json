    "definitions": [
      {
        "index": 1,
        "gloss": "slight cold",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝から少し風邪気があるようで、喉の奥がイガイガして仕事に集中できない。",
              "source": "幻辞"
            },
            {
              "text": "昨夜の冷え込みのせいか、今朝はひどく風邪気が差して、どことなく体が重く感じる。",
              "source": "幻辞"
            },
            {
              "text": "大事な商談を控えているので、風邪気をこじらせないよう、ビタミン剤を飲んで早めに布団に入った。",
              "source": "幻辞"
            },
            {
              "text": "先週からずっと風邪気が抜けないまま、鼻声で電話対応を続けるのは辛いものがある。",
              "source": "幻辞"
            },
            {
              "text": "「どうも風邪気があるみたいで、寒気が止まらないんだ。悪いけれど、今日の飲み会はキャンセルさせてくれ」",
              "source": "幻辞"
            },
            {
              "text": "季節の変わり目になると、いつも決まって軽い風邪気を感じ、体調管理の難しさを改めて痛感する。",
              "source": "幻辞"
            },
            {
              "text": "帰宅した子供が風邪気を出し、夜中になって急に熱が上がり始めたので、一晩中看病に追われた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "少し風邪気味で、大儀な時にでも無理をして勤務をおろそかにしなかった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしはもはや名曲堂の人たちに会へぬかと思ふと、急に顔を見せねば悪いやうな気がし、またなつかしくもなつたので、すこし風邪気だつたが、私は口繩坂を登つて行つた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまは、ちょっと風邪気味なんですけど。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が相談に行った時は風邪気味だとかいって逢ってくれなかったのです。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄亮までが、風邪気味で咽喉を痛めたというので、さして左が利かない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪気の庄亮に私は私の緑のレインコートを頭からかぶせた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋羽二重の肉色鹿子を掛けたる大円髷より水は滴るばかりに、玉の如き喉を白絹のハンカチイフに巻きて、風邪気などにや、連に打咳きつつ、宮は奥より出迎に見えぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その中に大納言｜殿と云われる上席の女中がいたが、それが風邪気味だと云って、出て来ない。",
              "citation": {
                "source": "女強盗",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "両親には風邪気味と申しましたので、夕方になって、近所に住んでおられる大学の助教授さんとか言う、若いお医者さんを呼んでくれましたが、別に何処と言って悪い処は御座いませんし、熱も何もなくて、脈も変っていなかったので御座いましょう。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君は風邪気味で夕方まで寝た、そしておとなしく帰宅、私はねむれないのでおそくまで漫読。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪気分、咳が出て困る、六時のサイレンが鳴つても寝床にゐた、私としてはめづらしい朝寝だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬君が今日も寄つてくれたが、風邪気味なので、ちよんびり飲んで別れた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "少々朝寝、何しろ労れたことである、風邪気分。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝秋谷で汗をかいたり風にふかれたりしたせいか、そしてその上に湯にはいったせいか、少し風邪気味で熱を感じたのだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は十二時がうつても寝つかれなかつた、無理をしたゝめでもあらう、イモシヨウチユウのたゝりでもあらう、また、風邪気味のせいでもあらう、腰から足に熱があつて、倦くて痛くて苦しかつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も人並に風邪気味になつてゐる。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日来、風邪気味なので、着れるだけ、あるだけ着て出かける、なか／＼の人出である、自動車が遠慮ぶかく乗り捨てゝある風景にも近代的地方味がある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞に出かけるつもりだつたが、風邪気味なので自重して（独身者は殊に気をつけなければならない）、閑居。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二十六日までさんざん警察によばれて取り調べられていたのだが、高橋警部が急にひろ子に目をつけるようになつてから当分呼ばれぬようになつて、ほつと安心して気がゆるんだせいか、風邪気味で二十七日から床についてしまつた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうはうちでも珍しくすこし風邪気味でお休みだし――……」　一二度麻雀に誘われて遊んだりしたことのある良人の幸治のことを云い、尚子は、「でも、私、ほんとにあなたはお偉いと思うわ」　丸い柔かいウエーヴのよく似合う顔立ちにいつわりのない色を浮かべて云った。",
              "citation": {
                "source": "二人いるとき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この子は少し風邪気のようですからお家の方がいいのね。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪気で熱のある頭の重たさに悩んでいたのだが、そんな気持は消えてしまって、はげしく動悸のする胸を押えて佇んでいた。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はい」「先生は風邪気でおやすみですから……どうですかうかがってみましょう」「どうぞお願いします、急病ですから」　千三は暗い門前でしずかに耳をそばだてた、奥で碁石をくずす音がちゃらちゃらと聞こえる。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生が風邪気なんで……」　森はこういってずんずん奥へあがりこんだ、かれはその外套と帽子を車夫にわたした、それから眼鏡をちょっと鼻の上へせりあげて病人を見やった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の身体のくせに妙な返辞だと感じたが、すこし熱もあるようなので、ようするに風邪気味なのだろうということになった。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内を乞うと彼は風邪気味で寝ていたが、快く起き出して何くれとなく注意を与えてくれた。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜――それ以前から風邪気味だつた――ばかに咳が出て、ハンカチを見ると血がついてゐたのだ。",
              "citation": {
                "source": "鬼神",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は僕はすこし風邪気味なのでね、外は寒いだろうから温くしようと思ったんだが、急に今気持ちが直って来たから、もう帽子もオーバーもいらない」　僕は苦しいいいわけをした。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し風邪気味らしいんですの。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙの風邪気、幸何ごともなし。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
