[
  {
    "uuid": "b56a160e-e22f-5d0a-a659-fdeddbc522c4",
    "entry": "風邪気",
    "reading": {
      "primary": "かぜけ",
      "alternatives": [
        "かざけ"
      ],
      "is_heteronym": false
    },
    "grammar": {
