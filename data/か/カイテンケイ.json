          "literary": [
            {
              "text": "三個の発動機は狂気のような大きなうなりを立て、回転計の指針は最大の速度を示していた。",
              "citation": {
                "source": "飛行機に乗る怪しい紳士",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちらと、回転計を見る。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側の回転計の針が、左から右へ、あがっていく。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "回転計の針は、赤く塗られたレッド・ゾーンの手前まできている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
