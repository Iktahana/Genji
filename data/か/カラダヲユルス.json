    "definitions": [
      {
        "index": 1,
        "gloss": "to give oneself to (esp. of a woman to a man)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
