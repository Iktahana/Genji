    "definitions": [
      {
        "index": 1,
        "gloss": "to give oneself to (esp. of a woman to a man)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は、彼の情熱的なアプローチに根負けし、ついには体を許してしまった。",
              "source": "幻辞"
            },
            {
              "text": "「一度体を許してしまえば、彼との関係が都合のいいものに変わってしまうのではないかと不安だった」と彼女は胸の内を明かした。",
              "source": "幻辞"
            },
            {
              "text": "真剣に結婚を考えている相手にしか、決して体を許さないという彼女の意志は固かった。",
              "source": "幻辞"
            },
            {
              "text": "酒の勢いに任せて一度だけ体を許してしまったことを、彼女は今でも深く後悔している。",
              "source": "幻辞"
            },
            {
              "text": "「愛しているからこそ体を許したのに、翌日から彼の態度が冷たくなったのは耐えがたかった」",
              "source": "幻辞"
            },
            {
              "text": "孤独な心を埋めるために見ず知らずの男に体を許してしまうほど、当時の彼女は精神的に追い詰められていた。",
              "source": "幻辞"
            },
            {
              "text": "一度体を許したことがきっかけで、二人の関係は泥沼の不倫へと足を踏み入れていった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、花嫁がよほど好色的でない限り、つまり処女の場合、例外なしに殆んど気絶状態になって夫に体を許すという儀式が、何が目出度いんでしょう。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕に身体を許すつもりか？",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして肉体を許すはずの澄江の意志は、すでにもはやそれを最も怖れはじめてしまふのだつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "太腿を出すは電車の中猶之を禁ずるに独りマラソン競走者の街上裸体を許すは何ぞや。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも物自体を許すとすれば、夫はコーエンのように、何か論理的な限界概念ででもあるとする。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "生來の習慣と住居の搆造とは寒地人民の裸体を許すものなり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
