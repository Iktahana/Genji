          "literary": [
            {
              "text": "これに対し、否、割礼を受けることは必要な条件ではない。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち割礼を受けることによって、ユダヤ人たる身分を取得するものとせられました。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって外国人がユダヤ教徒となるため、すなわちユダヤ教に改宗してシナゴグに属する者となるためには、やはり割礼を受けることが必要とせられたのです。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
