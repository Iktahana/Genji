    "definitions": [
      {
        "index": 1,
        "gloss": "to talk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "久々に再会した旧友と、居酒屋の片隅で夜が更けるまで積もる話を語らった。",
              "source": "幻辞"
            },
            {
              "text": "焚き火の爆ぜる音を聞きながら、仲間たちと将来の夢や理想の生き方を静かに語らう。",
              "source": "幻辞"
            },
            {
              "text": "縁側に腰を下ろした老夫婦が、沈みゆく夕日を眺めつつ過ぎ去った日々を懐かしむように語らっている。",
              "source": "幻辞"
            },
            {
              "text": "かつての教え子たちが恩師を囲み、学生時代の失敗談や現在の仕事の苦労を熱く語らう。",
              "source": "幻辞"
            },
            {
              "text": "異国の地で偶然出会った旅人同士が、互いの故郷やこれまでの過酷な旅路について語らう。",
              "source": "幻辞"
            },
            {
              "text": "幕末の志士たちは、この歴史ある料亭の一室で新しい国家の在り方について語らったという。",
              "source": "幻辞"
            },
            {
              "text": "深夜の学園祭の準備の合間に、教室の片隅で将来の進路について真剣に語らう学生たちの姿があった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "語りたくないのではない、語らうにもどうにも手の附けやうがないから、遂には語りたくなくなりもするのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はそれを語らうとした。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はリボンを空に送り、私は嘗て陥落した海のことを　その浪のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎兵聯隊や上肢の運動や、下級官吏の赤靴のことや、山沿ひの道を乗手もなく行く自転車のことを語らうと思ふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言へばその先生なる言葉の語韻中に、私の正に語らうとしてゐる情操のすべてが表象されてゐたわけだ。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にかつて私自身が、それを經驗した時のことを語らう。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が三つのとき、」なにげなく語らうとしたらしかつたが、しくじつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどうした苦労であつたか、語らうなぞとはつゆさへ思はぬ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何にも、だから語らうとは思はない。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は照し合う心の曇りなき様子を語らうのに、人の世の言葉の不束かなのに焦立ちさえするので御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は不景氣だ、と徒黨十餘輩を語らうて盛唐縣の塚原に至り、數十の塚を發きて金銀寶玉を掠取る。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、自分が氏に就いて語らうとするのは早計である。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共、氏に就いて語らうとする者は、この詩集を繙いて、如何に如實なる氏を知る事が出來るであらう。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子はこの若きダビデの姿をいかに語らう――ミケランヂエロの若きダビデの彫像の写真にしても、このときまだ雪子は知らない。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九歳の元旦のできごとから物語らう。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、他の津軽の町を語らう。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に今の吾人の上に就て、吾人の實際に感じ、眞箇に知るところを基として語らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "極々淺近な例を取つて語らうならば、此處に一商人があつて碁を非常に好む人とする。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の事情は姑く擱いて論ぜず、又人間の心理や生理の全部に亙る談は姑らく措いて語らないで、今は人の『氣の張弛』に就て語らうとおもふ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨それでは如何にして張る氣を保たさうといふことに就て語りたいが、之に先だつて張る氣の生滅起伏の終始に就て語らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此の條では氣息以上に及んでゐる氣の事を説きたくないから其等は姑らく措きて、猶少し氣息に關した事を語らうなら、道者は氣を足に引くといひ、猿は壽八百、好く其の氣を引くといへる類は、大體氣息の氣と解釋して宜いやうだが、猶且氣息の義のみではない。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し氣の根本の義及び用語例の例擧や分類は此の位に止めて、人の氣分氣合の上にかゝる氣に就て語らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　天狗の火、魔の燈――いや、雨の夜の畷で不思議な大きな提灯を視たからと言つて敢て圖に乘つて、妖怪を語らうとするのではない、却つて、偶然の或場合には其が普通の影象らしい事を知つて、糸七は一先づ讀しやとゝもに安心をしたいと思ふのである。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月の朝の日比谷公園の印象を語らうか。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は更に興味ある秋の夜の銀座裏町の生活を語らうか。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも春雨頃の、沈んだ三味線の音のやうに淡く寂しい深川の河岸の情緒を語らうか。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若き男女がむつまじう語らうてゐるところに、法師や武士は禁物ぢやよ。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで俺は俺の思想を一言君に物語らう。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾の坂崎氏を訪うや、女史と相見て旧知の感あり、遂に姉妹の約をなし生涯相助けんことを誓いつつ、万秘密を厭い善悪ともに互いに相語らうを常とせり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は東金より買い来たれる菓子｜果物など取り広げて湖面をながめつつ裏なく語らうのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
