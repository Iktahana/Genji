[
  {
    "uuid": "6b2bc91a-0e57-57e4-af12-34824c3c9a33",
    "entry": "語らう",
    "reading": {
      "primary": "かたらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
