    "definitions": [
      {
        "index": 1,
        "gloss": "sense of space",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここの景色は、雄大な、というほどではないにしても、建物ひとつなく、遠くまで小高い山がつらなり、開放感をあたえてくれる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本人は他のところでは大方は忘れられた行為の伝統に固執しており、また話し方や行動の、ある独特の開放感――外国人には定義が難しいのだが、教養ある日本人にはすでに自明のものである――によって特徴づけられているとも言われている。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその瞬間がすぎると、自分を押えつけていたものがすべて、こなごなに砕け散った開放感が、やがておれにも起ってきた。",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事を終えたという計り知れない開放感が訪れた。",
              "citation": {
                "source": "絞首刑",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
