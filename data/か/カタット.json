          "literary": [
            {
              "text": "」　若いお父さんは、その青白い時計をチョッキのポケットにはさんで靴をかたっと鳴らしました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて八日目の朝署長が役所へ出て出勤簿を検査してそれから机の上へ両手を重ねてふうと一つ息をしたとき扉がかたっと開いてデンドウイ属があの八日前の白服のまゝでまた入って来ました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長は思はず椅子をかたっと云はせました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舗装路の上に、靴はかたっかたっと音を立てた。",
              "citation": {
                "source": "変る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何か、かたっという音が机の上にした。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
