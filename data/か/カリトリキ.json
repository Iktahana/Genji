        "examples": {
          "standard": [
            {
              "text": "黄金色に輝く稲穂を効率よく収穫するため、村の共同組合では最新式の刈り取り機を導入した。",
              "source": "幻辞"
            },
            {
              "text": "刈り取り機の鋭い回転刃が詰まらないよう、作業の合間には付着した泥や藁を丁寧に取り除く必要がある。",
              "source": "幻辞"
            },
            {
              "text": "昔は鎌を使って手作業で行われていた麦の収穫も、大型の刈り取り機の登場によって劇的にスピードアップした。",
              "source": "幻辞"
            },
            {
              "text": "湿田での作業に耐えられるよう、その刈り取り機には足回りにクローラが装備されている。",
              "source": "幻辞"
            },
            {
              "text": "刈り取り機のエンジン音が遠くから聞こえてくると、今年もいよいよ秋の収穫シーズンが始まったことを実感する。",
              "source": "幻辞"
            },
            {
              "text": "トラクターの後部に牽引式の刈り取り機を装着し、広大な牧草地を一気に刈り上げていく。",
              "source": "幻辞"
            },
            {
              "text": "「ほら、あの刈り取り機の動きを見てごらん。実った籾だけを綺麗に選別して袋に詰めていくんだよ」と、祖父は孫に誇らしげに語った。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして過剰の収穫物は村の組合でまとめて都会へ売り、組合で最新式の耕作具や穀物の刈り取り機械を購入して、その機械を得意な人々数人に保管させたり、各家庭の収入金の三分の一を貯金し、三分の一を金貨にして床下の甕に蓄え、残りの約三分の一で税金や組合費に当てます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらも私はかえりますでは相すまないから、何かのときどこへ子供をつれてゆくか、どんな準備がいるか、ということなど、すっかりとりきめてかえります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
