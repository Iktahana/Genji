[
  {
    "uuid": "88562ed7-be43-5d84-8bf7-222c3f8f79b6",
    "entry": "改善",
    "reading": {
      "primary": "かいぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
