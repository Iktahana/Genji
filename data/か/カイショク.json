[
  {
    "uuid": "8e594f9f-bb2d-58e8-bbbd-3613b5005e41",
    "entry": "会食",
    "reading": {
      "primary": "かいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
