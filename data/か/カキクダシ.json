    "definitions": [
      {
        "index": 1,
        "gloss": "writing from top to bottom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（行を別けて横に書いた者必しも詩ではない、のべつに書き下したもの必しも散文ではない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建速須佐之男命　昭和七年盛夏、自分達の季刊誌『新詩論』の創刊に際し、油然たる感興を得て書き下した。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことさらに行を別けず其まま書き下したのもその故である。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ最近の現象で単行本の刊行も盛なやうであるし、書き下し長篇も出てゐるし、この種のものの書き下し長篇も出てゐるし、此種のものゝより旺盛化こそ望まれる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　弥生朔日から、万太夫座では愈々近松門左が書き下しの狂言の蓋が開かれた。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しい間、我々は漢文をそのままに読み、多くの学者は漢文書き下しによって、否、漢文そのものによって自己の思想を発表して来た。",
              "citation": {
                "source": "国語の自在性",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、長篇書き下し小説の流行はかつてない勢で出版界を風靡した。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌しく忙しく流行作家は長篇を書き下しつづけたのであったが、この商業的な文学の隆昌が、昭和十四年度にははっきり文学のインフレ景気という名称を蒙って、出版界の賑かさに反比例する文学の質の低下が真面目に注目されるようになった。",
              "citation": {
                "source": "昭和の十四年間",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き下し長篇小説というものが流行したが、それらの長篇小説は文学作品としてのゆたかさ、高さを示すよりもひたすらそれをひきうけた作家の健康にたよったように書きおろされ、売られ、しかも、文学らしい文学をもとめる人々の心の渇きは愈々｜医されがたいという状況にあった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き下し長篇小説の出版を可能にした軍需インフレーションは、そのような経済事情の変調をもたらす戦争によって日本の文学の真実の声を殺戮しはじめていたのであった。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうしてったって、――まず僕が是非とも国へ帰らなければならないような理由を書き下してさ。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の半分は書き下しである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "金魚豊島与志雄「金魚を見ると、僕はある春の一日のことを思い出して、いつも変な気持になる、」と云ってＳが話したことを、そのまま三人称に書き下したのが、次の物語りである。",
              "citation": {
                "source": "金魚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新人の力作は単行本として出版されたものではないが、最近の書き下し長篇中では相当読みごたへのある作品であつたにも拘らず、当時の世評が不当に苛酷であつたため、ここに取りあげてみたいのである。",
              "citation": {
                "source": "長篇小説時評",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　書き下し文、および索引は、歴史的かなづかいにより、その他の部分は、新かなづかいによつた。",
              "citation": {
                "source": "古事記",
                "author": "凡例",
                "note": "青空文庫"
              }
            },
            {
              "text": "この番號は、本書の書き下し文の各歌謠の終りに記してある。",
              "citation": {
                "source": "古事記",
                "author": "歌謠各句索引",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかっとる」　大きくうなずいた鉄斎老人、とっぷり墨汁をふくんだ筆を持ちなおすが早いか、雄渾な字を白紙の面に躍らせて一気に書き下した。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしに、玄心斎が、そっと硯と紙を持ってくると、源三郎一筆に書き下して、「押しかけ女房というは、これあり候えども、押しかけ亭主も、また珍に候わずや。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見込まれた近江屋と因業久兵衛の弱り目はさることながら、狂気の真似をし通したお高の根気、役者も下座も粒の揃った納涼狂言、十両からは笠の台が飛ぶと言われたその当時、九カ月あまりに五百両は、もし最終まで漕ぎつけえたら、瘠浪人の書き下し、なにはさて措き、近ごろ見物の大舞台であった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は少し都合があるから、見舞に来るのを見合せてくれという意味を、簡単に書き下した手紙は一分かかるかかからないうちに出来上った。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれ／＼」　手に取つて見ると、古い大福帳から引千切つた紙片で、大黒より十六間井より二十八間小判千六百枚大判二百三十枚外に――　そんなことが達筆な細字で書き下してあるではありませんか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金藏の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どれどれ」　手に取って見ると、古い大福帳から引千切った紙片で、大黒より十六間井より二十八間小判千六百枚大判二百三十枚外に――　そんなことが達筆な細字で書き下してあるではありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻頭のやや長い論文「若き世代への恋愛論」は書き下しで、あとは大体再録されたものと思う。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　論文集を読むべきこと　大抵の本屋は、書き下しの単行本を書け書けという。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "論文集や評論集にしても書き下しの論文が這入っていないと売れないと云っている。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても或る程度体系的に読まねばならぬのだが、それでは初めから纏めて書いた書き下し単行本が一等いいだろうと考えられるかも知れない。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大がかりに書き下した「体系的」な著述の類は、云わば文筆的な儀礼が大部分を占めていて、筆者の本音は仲々伝えられるものではない。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに所謂書き下し著書なるものは、一種気合いの抜けた、平均された結論が先に立っているもので、著者の思考の苦心の跡は、お客さんの前に出た主人達の夫婦喧嘩のように、ケロリと片づいて見える。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き下し長篇小説も実際には従来の意味での通俗小説めいたものになってしまっています。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
