    "definitions": [
      {
        "index": 1,
        "gloss": "opening gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "開門忽怪山為海、万畳雲濤露一峰と詩にいへるも、まことによく云ひ得たりといふべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "門外に靴音して、朝巡回の巡査、松の木の縊死を認めて、戸を叩き、「開門、開門。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ烈しく敲立つるに、玄関をがらりと開けて、執事の日下部、「門番の衆、門番の衆、開門。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お手はず万端整いましてござります」　やがてのことに、ご奏者番からご老中職へ、ご老中からご公方さままで、道々のご警備その他ぬかりのない旨、ご言上が終わると、「お成りイ――」　の声があって、ご開門と同時にお出ましがかっきり明け七ツ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論その表書き通りであったら、たやすく開門させることは困難であろうと思われたのに、しかし退屈男は、まるでその制札なぞ歯牙にもかけないといった風でした。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "開門せいッ」　と同時でした。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「開門なぞ以てのほかじゃッ」「貴公の目玉は節穴かッ」「直参であろうと、旗本であろうと、夜中の通行は制札通り御禁制じゃッ」「かえれッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうあっても開門せぬと申すか」「当り前じゃわッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういう制札であろうと、通行お差し止めと書いてあらば開門無用じゃッ」「ほほう、なかなか口賢しいこと申しおるな。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならば制札通り、禁中、お公儀の御使者だったら、否よのう開門致すと申すか」「くどいわッ、くやしくば将軍家手札でも持って参らッしゃいッ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らばそろそろ篠崎流の軍学用いて、否やなく開門させて見さしょうぞ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "開門開門とわめき立てい」「………？",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早打ちだッ、早駕籠だッ」「江戸お公儀からの早駕籠でごぜえます」「開門！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "御開門を願いまあす！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早いところ開門しておくんなせえまし！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "者共ッ、者共ッ、開門さッしゃい！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く開門してあげさッしゃい」　打ちうろたえながらギギギイと観音開きにあけたのを、編笠片手にぬッと駕籠の中から、ぬッと悠々と姿を見せたのはわが退屈男です。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えいこんなにゃ大きかない、こりゃでかいもんだ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿に太ッかいもんでないか。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしいものだが、西洋の唐茄子って、ばかに細っかいもんだな。",
              "citation": {
                "source": "西洋の唐茄子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一杯ぐらいずつあるわ」「味醂て、たかいもんだねえ、一合二十八銭もするよ」「ふーむ」　サエは、「こんどは専吉の分」そうはっきり心に思って、佐太郎の猪口に銚子をさした。",
              "citation": {
                "source": "鏡餅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっと早く帰ろうと思ったんだけれどもね、つい日が短かいもんだから」　自分の脱ぎ棄てた着物をお時に畳ませる時、お延は彼女に訊いた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
