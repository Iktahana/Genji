        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "株主総会の混乱を画策する会社ゴロが、経営陣のスキャンダルを盾に不当な金品を要求してきた。",
              "source": "幻辞"
            },
            {
              "text": "会社ゴロは、企業の不祥事や弱みを嗅ぎつけると、街宣車での抗議行動をちらつかせて口止め料を迫る。",
              "source": "幻辞"
            },
            {
              "text": "コンプライアンスの徹底が叫ばれる昨今、会社ゴロとの不透明な関係を維持することは企業にとって致命的なリスクとなる。",
              "source": "幻辞"
            },
            {
              "text": "「お宅の不祥事を記事にされたくなければ、この雑誌に広告を出せ」という会社ゴロの常套句に屈してはならない。",
              "source": "幻辞"
            },
            {
              "text": "警察当局は、組織暴力団と密接に結びついた会社ゴロの実態を解明するため、一斉捜索に踏み切った。",
              "source": "幻辞"
            },
            {
              "text": "会社ゴロによる執拗な恐喝に悩まされていた総務担当者は、弁護士と相談の上で刑事告訴の準備を進めた。",
              "source": "幻辞"
            },
            {
              "text": "かつては総会屋と並んで跋扈した会社ゴロだが、商法の改正や暴力団排除条例の施行によってその活動範囲は狭まっている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんなきざな眼鏡をかけて、古ぼけたモーニングなんか着ている小説家なんてありませんよ」相川青年が答えた通り、その二人連れは、政党の下っぱか所謂会社ゴロという様な人種以上には見えなかった。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
