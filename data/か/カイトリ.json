    "definitions": [
      {
        "index": 1,
        "gloss": "purchase",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつか私邸に呼ばれたときにその自慢の豊富な書庫を見せてもらったことがあったが、その蔵書の一部が教授の死後、わが中央気象台に買取られて保存されている。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの巴里人のならわし通りこの男も老後を七、八十｜里巴里から離れた田舎へ恰好な家を見付けて買取り、コックに一人の女中ぐらい置いて夫婦の後年を閑居しようという人達だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめてから三月程経ち、切れた電球千個を一個一銭の十円で電灯会社から買取り、五会の古電球屋に持って行くと、児子はん、あんたは商い下手や。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、マツダ側は、マツダランプ並の値で買取らされてしまった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この市隠荘はお絹等姉妹の父で漢学者の荒木蛍雪が、中橋の表通りに画帖や拓本を売る蛍雪館の店を開いていた時分に、店の家が狭いところから、斜向うのこの露路内に売家が出たのを幸、買取って手入れをし寝泊りしたものである。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その馬好ももう五十年｜前とかに亡くなり、今は県会議員である当主が老後の楽みに買取って、おなじく幽雅な料亭としてその跡を承け継いでいる。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて某は即時に伽羅の本木を買取り、杵築へ持帰り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達家の役人は是非なく末木を買取り、仙台へ持帰り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "金兵衛はその日、下谷御成道の同商売の店から他の古道具類と一緒にかの兜を買取って来たのである。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう事情で建ちぐされのままになっていた空屋敷を、わたしの父がやすく買取って、それに幾らかの手入れをして住んでいたのであるから、今から考えるとあまり居ごころのよい家ではなかったらしい。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山家徒でござるに因って、何か一軒家を買取ったも、古猿の化けた奴。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地体、一軒家を買取った者というのも、猿じゃ、狐じゃ、と申す隙に、停車場前の、今、餅屋で聞くか、その筋へ出て尋ねれば、皆目知れぬ事はござるまい。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――峠の一軒家を買取ったのは、貴婦人なんです。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど、立場が荒廃れて、一軒家が焼残ったというのも奇蹟だからと、そこで貴婦人が買取って、少い女の世を避ける隠れ里にしたのだと言います。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといって人の深切も、さすがに娘を落籍してくれるまでには到らなかったが、女腕で一人を過す片遑に端金を積立てても、なかなか蝶吉の体は買取られぬ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは橋番が内職にしている放しうなぎで、後生をねがう人たちは幾らかの銭を払ってその幾匹かを買取って、眼のまえを流れる大川へ放してやるのであった。",
              "citation": {
                "source": "放し鰻",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠告してくれる人はその小作株は一応買取つて了つてそれの転売をも防ぎ利益配当の不平等もなくするやうに――そして名実ともに公有にせよといつてくれるのであります。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（このピヤノは後に吉原の彦太楼尾張屋の主人が買取った。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日、私は早速丸善へ行って、果して一冊あったのを直ぐ買取った。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "管理人が遠廻しに、小作権を坪幾何の割で買取ってもいいとよく云ってくる。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼男子（察度）此鉄を皆買取てけり。",
              "citation": {
                "source": "浦添考",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の説はうんと儲かるように買取ってやらねば駄目。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃新画の展覧会があちこちで開かれるが、作家と絵の出来栄について何の好悪も持たない今の成金のなかには、眼を閉ぢて番組を押へるとか、又は従来自分と縁起のよかつた、25とか73とかの番号に当つてゐるのを捜すとかして、それを買取る事にきめるのがある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そんな輩は涙脆い女を見つけて、一瓶幾らといふ値段で涙を買取つて、一日も早く喪を済まさうとする。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出雲は二男か三男からしく、相応な資本を父から頒けられると、それでもつて竹本座の操り芝居を買取つて、座主、興行｜主、兼作者として奮闘し、正面の床を横に、｜人形遣ひを三人に改めたり、背景や変り道具を試みるといつた風に、色々と舞台｜向の改革を施して、その多くは成功した。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "硯箱、巻煙草入、灰落し……やくざな政党員のやうな安物ばかり買取つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「神様の所有にしても、いづれは将軍の舅さんからお買取りになつたのだらうが、どの位お仕払ひになつたか知ら。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつて、お前様、高い金出して、俺がの買取つたぢやねえか。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうさ、買取るには買取つたが、家は邸が狭いから、いま迄通りお前の許に預けておく積りだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "階級社会というもの、ロシアの人々が革命をとおしてたたかいとり、それを確固とした世界の現実としつつある社会主義。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
