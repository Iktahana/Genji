[
  {
    "uuid": "bcbd3d0b-dc90-5003-adf1-b03fd374d16a",
    "entry": "化育",
    "reading": {
      "primary": "かいく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
