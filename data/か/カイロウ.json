[
  {
    "uuid": "da46f008-6b21-529f-9a4e-2869e7e0a191",
    "entry": "回廊",
    "reading": {
      "primary": "かいろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
