      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "corridor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "左右の回廊にはところどころ赤い花が咲いて、その中からのんきそうな人の顔もあちこちに見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側の回廊の柱の下にマドンナの立像があってその下にところどころ活版ずりの祈祷の文句が額になってかけてあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "回廊の引っ込んだ所には、僧侶が懺悔をきく所がいくつもある。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめて中段の回廊へ出る。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルムホルツは薄暮に眼前を横ぎった羽虫を見て遠くの空をかける大鵬と思い誤ったという経験をしるしており、また幼時遠方の寺院の塔の回廊に働いている職人を見たときに、あの人形を取ってくれと言っておかあさんにせがんだことがあると言っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――惜しくも、彼の稀なる九折の回廊も共に消え去せたが、吾等は、常緑樹の翠の香が煙りの如く漂ふうちに――何時、何処でゞも、居ながらに、直ちに彼の悉くの珠玉の光りに接し得らるゝ――。",
              "citation": {
                "source": "珠玉の如き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "壇に向かった回廊の二階に大きな張りぬきの異形な人形があって、土人の子供がそれをかぶって踊って見せた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堅い感じのする回廊の床も壁も一面に棺で張りつめてあって、あくどい大理石像がうるさいほど並んでいた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度毎に長い回廊の硝子戸が一勢に胴震ひして、稍ともすると対手の言葉さへもが聞きとれぬ底の、りんりんたる木枯が悲鳴を挙げて吹き荒んでゐた。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡殿、回廊、社務所、額殿、祓殿、それに信者だまり、建物の数は七、八つも見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへ隠れてきなよ」　影を見とがめられないように身を隠しながら、拝殿へ近づくと、回廊にそっと上がって、やみの中から目を光らしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井は口笛を吹きながら、キュビストのピザパイの外周から、中央の回廊と部屋をつなぐドアの方向に、ひとりでずんずんと入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すっげえ」　寮のひと部屋は、中心の回廊に接したドアから、窓へむかって、扇形に開いている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の一日、玄宗が御苑に面した長い回廊を通りかかると、折から二三日降り籠めてゐた春雨が霽れたばかしのあとなので、そこらに程よく栽ゑられてゐた花樹の梢が、いづれも細い雨にぬれて、油のやうな雫をぽたぽた垂らしてゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　侍臣の手から羯皷を受取つた玄宗は、回廊の上で乱がはしいまでにそれを打ち鳴らして、春光好といふ一曲を心ゆくまでに奏した。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お筆が住んでいるのは、本屋とは回廊で連なっている離れであって、その薄暗い二階に、好んで起き臥しているのだった。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからフローラは、邪険に横蔵を追いやって、その折回廊を、慈悲太郎が通り過ごしたのも意識するではなく、ただただ父の名を呼び、いつまでも、しびれたように座っていた。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりずっと奥に回廊紆曲して障子の色まっ白に、そこらからピアノの音が栄華をほこるかのごとく流れてくる。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "松雲和尚の丹精からできた築山風の庭の見える回廊の方へも行った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには舞殿があり絵馬殿があり回廊があるか。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "維新以来、一切のものの建て直しとはまだまだ名ばかり、朝に晩に彼のたたずみながめた神社の回廊の前には石燈籠の立つ斎庭がひらけ、よく行った神門のそばには冬青の赤い実をたれたのが目についたが、薄暗い過去はまだそんなところにも残って、彼の目の前に息づいているように見えた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立薄く梅紅葉せず、三月の末藤にすがりて回廊に筵を設くるばかり野には心もとまらず……云々。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外は三重目の小さい回廊で欄干を握つて立つと、ニチヤ／＼と手につくものがある。",
              "citation": {
                "source": "斑鳩物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧サンに跟て回廊伝ひに東の方に廻つて見る。",
              "citation": {
                "source": "斑鳩物語",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな屋根は朽ち、広い回廊は傾きかけ、太い柱は歪み、見るから怪物の住みそうなありさまに、勘太郎も始めはうす気味悪くなった。",
              "citation": {
                "source": "鬼退治",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓に美味の並んでいるところもあれば、天女が美味をささげて回廊を伝って行くところもある。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中門の壇上、金堂の壇上、講堂前の石燈籠の傍、講堂の壇上、それからまた石燈籠の傍へ帰り、右へ回って、回廊との間を中門の方へ出る。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで彼は燈台のなかにはいり、圧搾空気が霧笛にはいるよう、モーターをかけてしばらくそのぐあいを見、それからまた霧笛の唸りで震動する床を踏んで、手摺のある回廊へでた。",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゼフリズは鉄梯子をつたって下の回廊におり、鉄梯子の上に立って熱心に下を見おろした。",
              "citation": {
                "source": "歌う白骨",
                "author": "THE ECHO OF A MUTINY",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
