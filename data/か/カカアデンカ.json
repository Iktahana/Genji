          "literary": [
            {
              "text": "静枝は「かかあ天下」で有名な川口の鋳物屋の娘だった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川口のかかあ天下」というのは、職人気質の亭主が鋳物作りにだけ専念していて、外部との交渉は自然と細君まかせというところからはじまったものらしく、川口のすべてがそうした家ばかりでもないだろうが、そんな気風がいつかそこの特徴になっていた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "その川口の出である静枝は、もうこの家で「かかあ天下」のようだった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かかあ天下」の兄貴の家に俺はいづらくなった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
