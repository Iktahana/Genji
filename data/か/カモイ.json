[
  {
    "uuid": "0cbec604-8b92-5b65-8146-f4a96e7889cc",
    "entry": "鴨居",
    "reading": {
      "primary": "かもい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
