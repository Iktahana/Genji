    },
    "definitions": [
      {
        "index": 1,
        "gloss": "visible light",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "人間の目は、波長がおよそ400ナノメートルから700ナノメートルの範囲にある可視光のみを捉えることができる。",
              "source": "幻辞"
            },
            {
              "text": "太陽から降り注ぐ電磁波のうち、目に見える可視光はごく一部であり、その外側には紫外線や赤外線が存在する。",
              "source": "幻辞"
            },
            {
              "text": "プリズムを通過した可視光は、波長の違いによって屈折率が異なるため、虹のような七色のスペクトルに分かれる。",
              "source": "幻辞"
            },
            {
              "text": "可視光通信は、LED照明の高速な明滅を利用して情報を転送する技術であり、電波干渉の激しい場所での活用が期待されている。",
              "source": "幻辞"
            },
            {
              "text": "深海に生息する生物の中には、わずかに届く可視光を効率よく吸収するために、特殊な眼の構造を発達させたものもいる。",
              "source": "幻辞"
            },
            {
              "text": "この光学レンズは可視光の透過率が極めて高く、色彩を歪めることなく被写体を鮮明に捉えることが可能だ。",
              "source": "幻辞"
            },
            {
              "text": "デジタルカメラのセンサーの前には、赤外線を遮断して可視光のみを通すフィルターが設置され、自然な色合いを再現している。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "海中哨戒線は、陸にあるトーチカを、点々と海底にしずめたような恰好のものであったが、或る特殊な不可視光線によって、そこを通過する潜水艦などを捕えるような仕掛けになっていた。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "深山理学士の研究問題は、この不可視光線と呼ばれる赤外線が人間にも見える装置を作ることにあった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは普通のテレヴィジョンと殆んど同じものだが、変っている点は、赤外線だけに感ずるテレヴィジョンで、可視光線は装置の入口の黒い吸収硝子で除いて、装置の中には入れない。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中でも興味ある発見は、通常火花の形として見えるものは、火花の全貌の中で可視光線を出している部分だけであって、その外に眼に見えぬ線を出している部分があるということであった。",
              "citation": {
                "source": "指導者としての寺田先生",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかんづく、電波の發生は可視光線をもその範圍に屬せしむるに至り、その頃發見されたＸ線もまた、これに包含され、また無線通信ラジオ等まで、これに頼つて發展し、世界を狹隘にしました。",
              "citation": {
                "source": "湯川博士の受賞を祝す",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれだけではまだ人間の眼に見えますから、そのランプか可視光線を吸収して紫外線だけを通す特殊の濾光障の中へ入れて置けば、人間の眼には、殆んど光が見えませんが、写真は充分に撮れます。",
              "citation": {
                "source": "女記者の役割",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思考子が完璧な可視光線に変わると言ったろ。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合、君の精神から発する思考子が可視光線の量子に転換し、これが見える。",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると可視光線が、ある思考子を伴って反射され、その思考子がこの装置で見えるまで増幅され、いうなれば認識できる」「思考子？",
              "citation": {
                "source": "観点",
                "author": "THE POINT OF VIEW",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルケリ星人は光の波長や照射時間や熱加減で繁殖率がかなり違ってきますからねえ」「可視光線より赤外線の方が繁殖率が高まるというのは本当かね」「ええ、実験のデータから明らかにそう言えますね。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に紫外線にすると可視光線より落ちるようです。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいえ電波とは電磁波であり、可視光もまた電磁波だから、単に人工的な電磁波網が地球を覆いつつある、ということでよいかも知れない。",
              "citation": {
                "source": "ぞなもし狩り",
                "author": "円城塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこれらは非常に小さくて可視光線で干渉しない。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこうした句は、印象の直截鮮明を尊ぶ蕪村として、従来の句に見られなかった異例である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこうした俳句の中にも、芭蕉の詩情するリリシズムの咏嘆がよく現われている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかしこういう場合における実際の犯人の心理を表現したものであるかどうか少し疑わしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう根本問題は別としてもまだ種々な科学的骨董趣味が存在するのである。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう場合でも、一方では音の方向知覚というものの本来不確実なために、また一方では劇場の複雑な反響のために、なおその上に、視像の暗示にだまされる錯覚のために、実際はたいした不都合は感じないかもしれない。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう歌は、こういうのが面白いから作って見ようと云って作り得らるる歌ではない。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう風に日本語を書いたものでは、今言ったような、昔の人がどれだけの音を聴き分けたかということは判りません。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうことを考えるについても、もう少しこれらの音がどういう場合にあらわれるかについて考えるがよかろうと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう教育映画を作るのはなかなか容易でないことも明白である。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう絵には、そういつまでも同じようなものを描き続け得られないだろうと思わせるある物がある。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう絵もこのままではすぐ行き詰りになりやすい。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうあらゆる杖に比べると、いわゆるステッキほどわけのわからない品物はないと思われる。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういう場合に出逢ってみるとやっぱり馬が可哀相になる。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうことにはきりがないと見える。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうめんどうなむつかしい事がらを説くには、「詩」の助けをかりなければならない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、この言葉の意味の解釈次第ではまさにそのとおりであるが、しかしこういう簡単な、わずか一二行の文句で表わされた事はとかく誤解され誤伝されるものである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこういうものもあってもいいかもしれないというまでなのである。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
