[
  {
    "uuid": "67cdfc17-b44f-567c-8c25-5a8e069d3629",
    "entry": "可視光",
    "reading": {
      "primary": "かしこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
