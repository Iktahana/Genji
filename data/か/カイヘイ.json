    "definitions": [
      {
        "index": 1,
        "gloss": "sailor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此時は、両軍の距離が十米で、陸軍の旧制服や、海兵服や莫大小の股引等の服装をした薩兵が、手にとる如く見えた。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの海兵隊の退役軍曹のことか？",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「軍曹であります、海兵隊軽装歩兵でありました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、あの男が海兵隊の退役軍曹だと。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすると君は、海兵隊の軍曹とはわからなかったと。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国には海兵隊があったな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "――海には海兵団のボートが木の葉のやうに浮び、空には飛行機が戦闘の演習をつゞけてゐるが、母艦は艦隊所属であつたから、それらは艦上機ではない。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では何処の学校や海兵団の体操を見たつて、あんな馬鹿臭いのはありはしない。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈頭のわたしは、夜になると、街の被服商で購つて来た海兵用の白の作業服を着て、一服喫すといふ場合には、徐ろに胸のポケツトから、先頃「しぐれ」進水式の折に拝領した銀製のシガレツト・ケースを取り出し、高射砲型のライターからパチンと火をつけた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く同じ造りの二階家が数軒並んで、隣の二階にもわたしと同じやうな姿の若い士官がゐて夜更まで灯りの下で勉強して居り、そのまた隣も海兵の合宿所で時々、今日ハ手ヲ取リ語レドモ　明日ハ雲井ノヨソノ空　行クモ留ルモ国ノタメ　勇ミ進ミテ行ケヨ君――と合唱する聞くだに健やかな血の湧き立つ軍歌が響いた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三軒先の合宿から折々聞えるところの、前記の「海兵わかれの歌」ばかりを、銀笛の吹奏者は、氷つた月のころから習ひはぢめてゐたが、彼はどちらかと云へば武骨過ぎる指先かと見えて、その一節さへもが容易になだらかには運ばなかつた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "更ニ他ノ一理由ハ日本ノ將來ハ陸上ニアルト同一以上ノ程度ニ於テ海上ニ在ルガ故ニ、國民教育ニ於テ只陸軍的模倣ヲナサシメテ海兵的訓育ヲ閑却スルコトノ矛盾ナルヲ以テナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹田本位ノ心身ヲ鍛冶シ十年間一貫ノ常識教育ヲ施サバ以テ海兵ニ用フベク以テ陸兵ニ用フベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では何處の學校や海兵團の體操を見たつて、あんな馬鹿臭いのはありはしない。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈頭のわたしは、夜になると、街の被服商で購つて來た海兵用の白の作業服を着て、一服喫すといふ場合には、徐ろに胸のポケツトから、先頃「しぐれ」進水式の折に拜領した銀製のシガレツト・ケースを取り出し、高射砲型のライターからパチンと火をつけた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く同じ造りの二階家が數軒並んで、隣の二階にもわたしと同じやうな姿の若い士官がゐて夜更まで燈りの下で勉強して居り、そのまた隣も海兵の合宿所で時々、今日ハ手ヲ取リ語レドモ　明日ハ雲井ノヨソノ空　行クモ留ルモ國ノタメ　勇ミ進ミテ行ケヨ君――と合唱する聞くだに健やかな血の湧き立つ軍歌が響いた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト役人に選挙された場合、普通の市民は、例えば教育委員一役に任じられるだけであるが、赤色陸、海兵は更にもう一つの委員会に委員として兼任する権利をもっている。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "検屍官Ｗ・Ａ・ブルック立合い、聖マテオ駐在合衆国海兵隊軍医Ｗ・Ｃ・チャイデスタア少佐が翌朝執刀と決まった。",
              "citation": {
                "source": "土から手が",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて一方には国権論派ともいうべきもの起こり、中央集権の必要を説き、陸海兵制の改正を説き、行政諸部の整理を説き、主として法制上の進歩を唱道せり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひなたくさい母の手紙を取り出しては、泪をじくじくこぼし、「誰がかえってやるもンか、田舎へ帰っても飯が満足に食えんのに……今に見い」私は母の手紙の中の、義父が醤油をかけた弁当を持って毎日海兵団へ働きに行っていると云う事が、一番胸にこたえた。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私一人で何もしない生活の不安さや、醤油飯の弁当を持って海兵団へ仕事に行っていた義父が、トロッコで流されたという故郷からの手紙を見て、妙に暗く私はとらわれて行った。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、義父たちが佐世保に落ちついてもう一年になるけれど、海兵団のトロ押しが、とうとう義父の働く最後であったのかも知れない。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一四年開戦瞬前に起って、さしも剛毅な海兵どもを慄え上がらせたというその不思議な出来事は、いま耳にした艇長屍体の消失と、生死こそ異なれ、まったく軌道を一つにしているではありませんか。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが陸戦隊は米国の海兵隊を襲撃して、三百人の敵兵を捕虜にした。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさまは陸兵ではなくて海兵なんだろう。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに立っております高級船員たちも、どこから見ても中国人ですが、これがみな日本人なんで、商船学校も出た者もおりまするし、予備の海兵も混っております」　虎船長は、そういって後の船員たちを指した。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、かうみえて、終戦直前に海兵を出たんです。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "問答無用の口ぢやありませんか」「僕はたゞ、おしやれがしたくつて、海兵を志願したんですよ。",
              "citation": {
                "source": "髪の毛と花びら",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、大洋漁業の標本室にはマッコーの腹から出たヤシの実があったが、戦争中、海兵の靴が片方だけ、腹から出たこともあったという。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなひとじゃけに、おとうさんも、ほんのこて、しんぼうしなはって、このごろは、めしのうえに、しょおゆうかけた、べんとうだけもって、かいへいだんに、せきたんはこびにいっておんなはる、五円なおくれんけん、二円ばいれとく、しんぼうしなはい。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
