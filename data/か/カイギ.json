[
  {
    "uuid": "76afb9fd-82f7-5d8b-bf32-c9c9aba79a3b",
    "entry": "会議",
    "reading": {
      "primary": "かいぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
