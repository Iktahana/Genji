        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただし市会議員のよこしたのだけは紙くずかごに入れるようである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に若干の老人が昔の例を引いてやかましく云っても、例えば「市会議員」などというようなものは、そんなことは相手にしないであろう。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市会議員の舌の鳴物入りの忠言なんかはこの道で苦労している彼等には真面目に対手になってはいられなかった。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視長官は市会議員に対する儀礼としてちょっと熟考の形を取ったが肚は決っていた。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕も承知しているのだ、今御膳会議で二人の噂が如何に盛んであったか。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたでいくら心配してもお母さんがあれでは駄目だ」　これが台所会議の決定であったらしい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は陸軍大佐となり王党の国会議員となり、Duke of Leinster の娘の Lady Fitzgerald と結婚した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃彼は国会議員として政治生活に入るように彼の父その他からも勧められた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治に対する興味はかなりあったが国会議員として立つ事は好まなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧師のストークスもその員に加わっており、わざわざアイルランドから出かけて来たが、会議中ただの一語も発せずに坐っていたそうである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーも会議にはあまり熱がなかったと見えて、ある人が彼にある科学上の問題を話しかけたとき、それは午後の委員会のときにゆっくり考えてみようと云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気単位に関する国際的会議のいきさつはここには略するが、この問題に関してレーリーの仕事が重要な要石となったことは明らかである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結核病研究の万国会議　来年九月二十一日より十月十二日まで米国ワシントン府で表題の会議が開かれる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体七部門に分れて、結核に関する病理、療法、予防その他一切の会議をするはずで、また開会中は該病に関する展覧会を開いて公衆に観せるそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "武漢の共産軍が敗れ、上海の市街戦で同志は一掃され、ボロジンは九江より南昌に隠れ、それ以前ボロジン夫人は密書とともに捕えられ北京の軍法会議に廻されたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は直に飛行機で広東に行き重要な三国会議に列する。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "県会議員が、当選したあかつきには、百姓の利益を計ってやる、というような口上には、彼等はさんざんだまされて来た。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの県会議員や、国会議員が口先で、政策とか、なんとか、うまいことを並べても、それは、その場限りのおざなりであることを彼等は十分知りすぎている。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのハリコフ会議の日本プロレタリア文学運動についての決議は、農民文学に関して「国内に大きな農民層を持つ日本にあっては、農民文学に対するプロレタリアートの影響を深化する運動が一層注意される必要がある。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点でも市会議員の選挙運動などよりはよほど穏やかでいいものである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究に忙しかるべき学者を、通俗講演や、科学の宣伝や、その他何々会議や何々委員や顧問に無暗に引っぱり出すのもそうである。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市会議員のような機械になってしまったのは無残である。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は近来は煙草で癇癪をまぎらす必要を感じるような事は稀であるが、しかしこの頃煙草の有難味を今更につくづく感じるのは、自分があまり興味のない何々会議といったような物々しい席上で憂鬱になってしまった時である。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も重要なる会議がナンセンスの小田原会議のごとく思われるというのはこれはたしかにそう思う自分が間違っているに相違ないからである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はそのことのために、居留民団で会議を開いた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは言え、顔を識らない人を、しかも出来るだけ多勢拾い上げて来いというんだから、命令それじしんが何だか私にも一向判然しないけれど、とにかく、ゆうべラ・トトで親分が言うには、「ジョウジや、亜米利加人かいぎりす人が一ばんいい。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、せかい星はかせかいぎ、というところで、見つけたことをきちんとはっぴょうしたんだけど、みにつけているふくのせいで、しんじてもらえなかった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "笈川玄一郎を送るために、親しい友達なかまで別宴を張って呉れたが、集まった七人のうち三人まで国詰になった経験があったから、話はしぜんその方面のことでもちきり、なかばからかいぎみの忠告や意見がしきりに出た。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
