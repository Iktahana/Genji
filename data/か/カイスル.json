[
  {
    "uuid": "b6b47c18-d98a-5fb5-b2af-d823cae55e5c",
    "entry": "介する",
    "reading": {
      "primary": "かいする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
