      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to use as an intermediary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "顧ふに、彼こそ「若い人に同情心は不足勝なものです」と言はれる場合の、その「若い人」である……）　扨、私は近代病者の一例を御紹介するが、その前に一言前置きしなければならない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "春風馬堤曲は、蕪村の試みた一種の新しい長詩であって、後に紹介する如く、彼のポエジイの最も純粋な主題的表現である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の一評者が「一時は紀行文は前人の未だ踏まない深山幽谷の奇景を、紹介するのを職とするような傾向であった、いや今でも、そういう好奇心で、紀行を書いている人もあるようだが、これはつまらぬことだろう」と言って、明らかに私に当たっている。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或地点では車の窓から見下ろされる断崖の高さが六百尺だと云つて女車掌が紹介する。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある地点では車の窓から見下ろされる断崖の高さが六百尺だといって女車掌が紹介する。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな議論が実用上どういう価値があるかは分りにくいが、ただ生物界の現象を説明するに力学を応用するようになった率先者の一人としてここに御紹介するその学者の名はダルシー・ウェントウォース・トムソンという。",
              "citation": {
                "source": "卵の形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に最近の老妓の心境が窺える一首があるので紹介する。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単平凡な例を取れば、対話中に来訪者のベルを響かせて、次に現われて来る人間を紹介する類である。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ煙の上がる処に火があるというあまりあてにならない非科学的法則を頼みにして、少しばかりの材料をここに紹介する。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも一層重要だと思うのは、万人の知っているべきはずの主要な工業経営の状況をフィルムで紹介する事である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "末広君の学術方面の業績は多数にあって到底ここで詳しく紹介することは出来ないし、またそれは工学方面の事に迂遠な筆者の任でもないが、手近な主だったものだけを若干列挙してみると次のようなものがある。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターリングにおける日常生活を紹介する。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでは彼の科学的な仕事よりはむしろこの特色ある学者の面目と生活とを紹介する方に重きをおいた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう意味で、教師は時々は我邦の科学者の研究を生徒に紹介するがいいと思う。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり面白過ぎたような考案ではあるが、如何ほどまで電気が万能な勢力であるかという一例として御紹介するのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "露国政府が純粋な科学の方面にも冷淡でない一つの例として御紹介するのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し此等のことは、私がここに拙悪な文章で紹介するまでもないことである。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「左膳俺の彼女を紹介する」　で左膳ダーとなる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今飯島を紹介すると共に、願ふことは早く元氣になつていゝものをどし／＼書いて欲しいといふことだ。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、たとへば、たとへばと諸賢のの麻雀振も紹介する積りだつたが、ちやうど許された枚數にも達したし、あとの祟りも恐ろしいので。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単に内容を紹介すると、まずその第一ページは、消防署で日夜火の手を見張っている様子を歌ってある。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら見本としてこの絵本の第一ページの文句だけを紹介する。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら記録の中で毛色の変わったのを若干拾いだした記事が机上の小冊子の中で見つかったから紹介する。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分の主観の世界における先生のおもかげを、自分としてはできるだけ忠実に書いてみたつもりであるが、学者として、作家として、また人間としての先生の面影を紹介するものとしては、あまりにも零細な枝葉の断片に過ぎないものである。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はこの老人が此夜に限らず時々得意とも慨嘆ともつかない気分の表象としてする仕方話のポーズを茲に紹介する。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつに博士は娘にまでも秘密にするほどの事であるが、余は今敬愛なる読者諸君のためにこの書面に書いてある世にも不思議なる出来事を、少しも隠さず紹介する事としよう。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら何も、霧でぼかし、丘で隔て、間に松の樹をあしらってまで、骨を折って二人を紹介するがものはなかった。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかでやや異色のものを左に一つ紹介する。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "原文は余ほど長いものであるから、今その要を摘んで左に紹介する。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……よそでぬすっとやかいするんじゃないぞ！",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
