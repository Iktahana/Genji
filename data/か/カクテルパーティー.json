        "examples": {
          "standard": [
            {
              "text": "大使館主催のカクテルパーティーに招待され、各国の外交官たちと親睦を深めた。",
              "source": "幻辞"
            },
            {
              "text": "国際会議の初日の夜にはカクテルパーティーが催され、参加者たちはリラックスした雰囲気の中で名刺を交換した。",
              "source": "幻辞"
            },
            {
              "text": "カクテルパーティーは一般的に立食形式で行われ、片手にグラスを持ちながら会場内を自由に歩き回って会話を楽しむのがマナーとされる。",
              "source": "幻辞"
            },
            {
              "text": "ホテルの最上階で開かれたカクテルパーティーでは、色鮮やかなアルコール飲料と共に、趣向を凝らした一口サイズのオードブルが振る舞われた。",
              "source": "幻辞"
            },
            {
              "text": "新製品のプロジェクトが成功したことを祝し、関係者のみを招いた内輪のカクテルパーティーが華やかに開催された。",
              "source": "幻辞"
            },
            {
              "text": "「今夜は自宅でささやかなカクテルパーティーを開くから、仕事帰りにでもぜひ寄っていってよ」と旧友から誘いを受けた。",
              "source": "幻辞"
            },
            {
              "text": "映画祭のオープニングを飾るカクテルパーティーには、世界中から著名な俳優や監督が集まり、会場は熱気に包まれた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そしてたのしく話をし、丁度二十一日に、キングズアームスホテルのカクテルパーティーに私招待されていましたので、令嬢をさそったのです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日の月曜日は、昼間、私は何をしたかすっかり忘れましたが、夜は、約束のカクテルパーティーに、令嬢を伴って、出かけたものです。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
