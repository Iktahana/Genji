[
  {
    "uuid": "9292daa0-6e89-5755-8d99-2e75d41f8b38",
    "entry": "化学作用",
    "reading": {
      "primary": "かがくさよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
