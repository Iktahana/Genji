    "definitions": [
      {
        "index": 1,
        "gloss": "uncoupling (usu. cars or wagons from a train)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「梅花の巻」に限らず、どの公案にも同様な解結の手段がめぐらされている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "個々のまたは一群の経済的・政治的・軍事的・市井的・また文化的・社会現象を、その論理と心理とを通じて、モーラリスト的視角から分解結合することが、社会時評の文学的本質なのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
