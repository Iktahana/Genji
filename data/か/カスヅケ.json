      {
        "index": 1,
        "gloss": "fish or vegetables pickled in sake lees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
