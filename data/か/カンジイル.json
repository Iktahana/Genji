    "definitions": [
      {
        "index": 1,
        "gloss": "to be deeply impressed (by)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "若い身空でこれほどまでに家業に打ち込む彼の殊勝な心がけには、誰もが深く感じ入った。",
              "source": "幻辞"
            },
            {
              "text": "老画家の筆致から溢れ出す生命力に、会場を訪れた人々はしばし言葉を失い、ただ静かに感じ入っていた。",
              "source": "幻辞"
            },
            {
              "text": "遭難者の救出に命を懸けた隊員たちの無私の精神に感じ入り、町を挙げての支援活動が始まった。",
              "source": "幻辞"
            },
            {
              "text": "異国の地で出会った人々の温かいもてなしと慈愛に満ちた眼差しに、彼は心の底から感じ入った。",
              "source": "幻辞"
            },
            {
              "text": "古典芸能の舞台を鑑賞し、一朝一夕には成し得ないその至芸の深さに、改めて感じ入るものがあった。",
              "source": "幻辞"
            },
            {
              "text": "厳しい批判にも真摯に耳を傾ける彼の誠実な態度に感じ入り、反対派の人々も次第に態度を軟化させた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それは恰度、音楽に鈍感な女の人が、オーケストラを聴いてゐて、フリュートなぞが単独に吹奏される部分でだけ、音そのものの物理的な快味にだけ感じ入るのに似てゐて、私は明治以降の殆んど全ての文学者が、外国文学の作品を読む時も、そんなやうなものであつたと云つても、強ち過言とは思はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯罪の子細などには慣れっこであるはずの刑事探偵ですら、この男の話には深く感じ入るものがあったらしい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつぱれ剛なる最期の際、感じ入る。",
              "citation": {
                "source": "國府臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "マア、僕らは、きょう千載に一遇の機会で、お目にかかれたというわけだ」「ううむ、そんな珍物かね」と、温厚学究君子のケプナラ君は感じ入るばかり。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身の孝心は、宗城、感じ入るが、父上一人の御機嫌をとるために、島津の家を亡ぼして、それが、賢人の道かの」　斉彬は、微笑して「亡びもせん。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞に其の處分有る人を見れば、實に感じ入る也。",
              "citation": {
                "source": "遺訓",
                "author": "西郷隆盛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実体そのものの価値を観てそれに感じ入る。",
              "citation": {
                "source": "古九谷観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "其御堪能さにお伴の者は、手を拱して感じ入るのみであった。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑声、讃嘆の声々湧き、播磨守をはじめ一座ことごとく感じ入る。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえー」と御両人は一度に感じ入る。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（残された跡を探して古屋のかたわらに座し、今を考えいにしえをおもって特に深く感じ入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "小品に過ぎませんが、どこからその美しい形を捕えて来るのかと感じ入るほどであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためでもありましょうが、西洋人は植物から取るこの天然藍に一入感じ入るようであります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わけて、唯今のご要意には感じ入る。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河の隠忍、自重、我慢の強さには、義元もほとほと感じ入るばかりだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちの孝心は感じ入るが、私怨に執着するは、孝のみ知って、忠の大道を知らぬものだ。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
