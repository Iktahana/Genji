[
  {
    "uuid": "7db9e13d-8d36-5287-af87-d9fe3828fdcd",
    "entry": "開閉器",
    "reading": {
      "primary": "かいへいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
