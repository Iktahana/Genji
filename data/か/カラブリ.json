        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ジョンが音をはずしてる」　まえのほうで、広岡とならんで見ている佐藤が、二死満塁のチャンスに、二球つづけて空振りした四番打者でも見ているような声でいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海さんが、顔｜馴染のフォオド会社の肥った紳士に、ゴルフを教えてもらい、なんども空振りをして、地面を叩く恰好を面白がって、みんな笑い崩れていましたが、ぼくにはつまらなかった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "東海さんが、顔馴染のフォオド会社の肥った紳士に、ゴルフを教えてもらい、なんども空振りをして、地面を叩く恰好を面白がって、みんな笑い崩れていましたが、ぼくにはつまらなかった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上二十貫の大鉞を、二度がところ空振りさせられた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、二つ三つ、腕の空振りを試みた。",
              "citation": {
                "source": "銀河まつり",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、本気だったの、忘れてるかと思っていた」「すこしは真面目に、おれを正面から相手にしてくれたらどうだい、おれはもう空振りにはたえられない」と私はいった。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "斧は空振りに空振りをかさね、朱同の姿は飛電の光にことならない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し御機嫌の悪いのはこの節しょっちゅうさ、心太の拍子木じゃあないが、からぶりぶりしてらあな。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の経過は、一時稍佳良であつたが、中途からぶり返して、とう／＼死んで仕舞つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人の経過は、一時｜稍佳良であったが、中途からぶり返して、とうとう死んでしまった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊臣時代頃から、画にも芝居にも、当世のはいからぶりをうつす事が行はれて、芝居では殊に、美しい少人がはでな異風をして練り歩くと言つた、一種の舞台の上のあるきが喜ばれた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本古来のからぶりばかりではない、おくにぶりの言葉までも、今日日常語として使えばセクト的な印象しか与えない。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、群集のなかにまぎれて、せつなに、矢来のなかへ斬りこみ、若君をはじめふたりの盟友を救いだすばかり」「心得ました」　小文治は腕をうならせて、朱柄の槍をからぶりさせた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
