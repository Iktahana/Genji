        "examples": {
          "standard": [
            {
              "text": "登山やハイキングでは、汗冷えによる体温低下を防ぐため、吸汗速乾性に優れた替え着を携行することが推奨される。",
              "source": "幻辞"
            },
            {
              "text": "「子供が公園の噴水でびしょ濡れになったけれど、車に替え着を積んでおいて本当に助かったわ」",
              "source": "幻辞"
            },
            {
              "text": "災害への備えとして、かさばらない機能性インナーなどの替え着を、家族の人数分だけ非常用持ち出し袋に常備している。",
              "source": "幻辞"
            },
            {
              "text": "出張先のホテルに到着し、カバンから明日の会議で着用する替え着を取り出して、シワにならないようハンガーに掛けた。",
              "source": "幻辞"
            },
            {
              "text": "「不注意でコーヒーをシャツにこぼしてしまったが、運よくロッカーに替え着を置いていたので事なきを得た」",
              "source": "幻辞"
            },
            {
              "text": "保育園の入園準備では、毎日の活動で汚れることを想定し、名前を明記した数組の替え着を常に持たせる必要がある。",
              "source": "幻辞"
            },
            {
              "text": "合宿中に予想外の豪雨に見舞われ、練習着が全て濡れてしまったため、近所の衣料品店で急遽全員分の替え着を買い足した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "丸ノ内界隈の職業婦人には寄り付けそうも無い、素晴らしい洋装を、殆んど毎日、取り換え引き替え着て来るようにさえなりました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第四夜　恋の不在証明",
                "note": "青空文庫"
              }
            },
            {
              "text": "おむかえぎといって長い前から用意された死衣しょうなのだが、母はおしげもなくそれをおじょうさんにきせると、おじょうさんはだまってきせられて、それからろのそばのこしかけにしずみこんで、両手で顏をかくしていた。",
              "citation": {
                "source": "ジェミイの冐険",
                "author": "片山広子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
