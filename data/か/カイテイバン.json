    "definitions": [
      {
        "index": 1,
        "gloss": "revised edition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ストックホルムにて　　　一九〇七年八月　　　　　　　　―――――――――――――――――――――――――――　ここで一言付加えておきたいことは、この改訂版で若干の補遺と修正を加えたことである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この概観は初め一九二二年に現れ、次いで一九三四年に改訂版が出た。",
              "citation": {
                "source": "世代の価値",
                "author": "――世界と日本の文化史の知識――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら熊城君、すでに僕は危険を悟って、心理学の著述などは、ロッジの『レイモンド』ボルマンの『蘇格蘭人ホーム』の改訂版以後は読まないのだし、また、『妖異評論』の全冊を焼き捨ててしまったほどだからね」　最後に至って、法水は鉄のような唯物主義者の本領を発揮した。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、ロムブローゾが称讃したというライブマイルの『能才及び天才の発達』を見ると、その中に、指が痲痺してきたシューマンやショパン、それから改訂版では、提琴家のイザイエの苦悩などが挙げられていて、なおかつ音楽家の全生命たる、骨間筋（指の筋肉）にも言及しているのです。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この全集決定版は、私が改訳に使用した改訂版とは、一冊につき数か所、文意に関係ない程度において、字句の微細な差異がある。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはおもに文章上のことであって、またあるところなどは、改訂版のほうが妥当とさえも思える。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ私は、作者の気息がもっとも直接に通じてるものとして改訂版を、改訳の台本に選んだ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今機会を得て、旧版による旧訳をこの改訂版に照合して改訳してみた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの巻頭には、作品全体の見通しをつけるに便利なものとして、改訂版四冊の序言を以下に訳出しておく。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、雑誌発行の直後であるにも拘はらず、私の意を察して、即刻「改訂版」の刊行を申出られた中央公論社の好意を謝する。",
              "citation": {
                "source": "「速水女塾」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして俺達は食えぬのを食えぬと云う事すら出来ぬのか俺達は――土のためにたたかうのだ――土のためにたたかうのだ――死ぬる迄戦うのだ――（『プロレタリア』一九三〇年十二月号に今村桓夫名で発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "死ぬる迄土地を守るのだ",
                "author": "今村恒夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『文芸戦線』一九二九年十一月号に今村桓夫名で発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "鋼鉄",
                "author": "今村恒夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『プロレタリア詩』一九三二年一月号に今村桓夫名で発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "アンチの闘士",
                "author": "今村恒夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サツマ辭書」はつまり開成所版の改訂版であるが、高橋がどれ程の造詣をこの辭書に傾けてゐるかは、私に判斷できない。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『旭川新聞』一九二九年九月十七日号に今野紫藻名で発表　一九八五年四月新日本出版社刊『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "組織された力",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『婦人戦旗』一九三一年八月号に発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "金属女工の彼女",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとおれたちは結束して起ち上るそしてソヴェート干渉戦争のインボウ者の腕をへし折ろうおれたちは交運労働者新らしい日本のプロレタリア（一九三二年四月日本プロレタリア作家同盟出版部刊『赤い銃火〔詩・パンフレット第一輯〕』に発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "屈辱",
                "author": "――市電の一労働者に代って――",
                "note": "青空文庫"
              }
            },
            {
              "text": "春はおろかこの秋までも、誰かこの生命を保証する私は死を覚悟の眼で美しき花々の下を通ってゆく（一九三五年五月十四日作『詩精神』同年六月号「今野大力特輯」に発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "花に送られる",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "―北海道××村争議団へ―」と題して今埜大力名で発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "百姓仁平",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮面のあいつこそが」（『詩精神』一九三五年六月号「今野大力特輯」に発表『今野大力・今村恒夫詩集』改訂版を底本）",
              "citation": {
                "source": "胸に手を当てて",
                "author": "今野大力",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう方針のもとに著者は自由に旧版に手を加えてこの改訂版を作った。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○原書改訂版に増補されている原注のうち一カ所を（本書の第三十頁第四行以下二行）本文の中へ繰り入れたことをおことわりしておく。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波の文庫のものはその絶版のままになっていたが、その後（昭和十八年）聖紀書房という書肆から歴史物集として上梓されたのがこの改訂版の最初であった。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "上記のごとく、本書は、当初の出発点こそ改訂版をいささか加除し修正する程度から進んだのであったが、いつしか本来の節度をかなり超えて、根本的修正が、ひとり文字の表記法のみにとどまらず、載録語詞、分量の上のみならず、かなり本質的にも及ぶことになってしまった。",
              "citation": {
                "source": "『広辞苑』自序",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三十六年六月十一日）（昭和二十四年三月初版、三十二年五月改訂版、三十六年十月新版『言林』）",
              "citation": {
                "source": "『言林』新版序",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではこれは初めの手紙の改訂版よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書はかつて『世界童話大系』の中に収められたものの改訂版であるが、訳者の微力と不注意とから依然として完璧を距ること遠いのは原著者に対して申しわけのない次第。",
              "citation": {
                "source": "『グリム童話集』序",
                "author": "金田鬼一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らすべてはガレノスの眼鏡を通して見ていたからであり各人はガレノスの解剖書の改訂版を持っていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェルズの「探偵小説の技巧」（一九二九年改訂版）第二十三章が「動機」という見出しになっているが、その分量はわずかに二頁余りで、きわめて簡略なものである。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時から「ロッパと将軍」改訂版の稽古、今夜から改訂版をやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
