        "examples": {
          "standard": [
            {
              "text": "嘉悦大学は、日本初の女子商業学校を母体として設立された歴史ある私立大学である。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "嘉悦大学の経営経済学部では、実社会での即戦力を養うための実践的なカリキュラムが提供されている。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "嘉悦大学の女子バレーボール部は全国的な強豪として名高く、数多くのプロ選手を輩出してきた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "東京都小平市に位置する嘉悦大学は、落ち着いた学習環境と地域社会との強い結びつきが特徴だ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「嘉悦大学のオープンキャンパスに参加して、先輩たちの活気ある様子を直接見てきました」",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "嘉悦大学では、学生一人ひとりの個性を尊重する少人数制のゼミナール教育を重視している。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": []
        }
      }
