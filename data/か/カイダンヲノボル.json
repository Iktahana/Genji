[
  {
    "uuid": "7d9468b9-36fa-5d98-aa32-e9137661cc5f",
    "entry": "階段を上る",
    "reading": {
      "primary": "かいだんをのぼる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
