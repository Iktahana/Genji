    "definitions": [
      {
        "index": 1,
        "gloss": "recovery",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長期療養のため活動を休止していた主演俳優が、病状が快癒したとして来月の記者会見をもって正式に芸能界へ復帰することを発表した。",
              "source": "幻辞"
            },
            {
              "text": "不慮の事故による大怪我から驚異的なスピードで快癒を遂げた彼は、リハビリを経て再びプロ野球のマウンドに立つという奇跡を成し遂げた。",
              "source": "幻辞"
            },
            {
              "text": "「恩師の御快癒を心よりお慶び申し上げます」という言葉と共に、門下生一同から退院祝いの胡蝶蘭が病室へと届けられた。",
              "source": "幻辞"
            },
            {
              "text": "術後の経過を観察していた担当医から「完全に快癒しました」との診断を受け、半年間に及ぶ厳しい食事制限からようやく解放された。",
              "source": "幻辞"
            },
            {
              "text": "古くから難病快癒の御利益があると信じられているこの薬師如来像には、今も平癒を願う参拝客が全国から絶え間なく訪れる。",
              "source": "幻辞"
            },
            {
              "text": "肺炎をこじらせて一時は危篤状態に陥った祖父だったが、家族の献身的な看病と本人の生命力によって、奇跡的に快癒へと向かった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "生命もどうかと気遣われたが幸いに快癒したので今度は Rev. G. T. Warner の学校に入ってそこで四年間の修業をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は拠ろなく手を束ねて、其の快癒に向うのを待つ中に、四五日は徒爾に過ぎた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒルトン・キュービット夫人については、その後、快癒の知らせを受け取ったものの、再婚もせず、余生を救貧事業と亡き夫の遺産管理に捧げていると聞くのみである。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴婦人の病気は、それで、快癒。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝戴いたお端書ですと、召し上がるものも追々おいしくなつて来たとの由ですから、もう油断さへ為さらなければほどなく御快癒になれますわね。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口を入るまでは、私は万福が快癒し、元気に遊んでゐる姿を見て、私自身も一緒に喜べるだらう、都合によつたら、感謝の辞まで「せしめる」ことが出来るかも知れない、きつとさうだ。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、その母の手紙を見た途端に年来の持病は一切快癒したやうだつた。",
              "citation": {
                "source": "好色夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ等の地の気の湿潤・乾燥などということは、望気術の気のように目に触れるものではないが確かに人に対して作用するもので、その湿気が水辺に親しむ釣客をしてリューマチに悩み勝なことは外国の釣書にも明記され、乾気の強い土地が或る病者に快癒を与えることなどは実験者によって強調されているところである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろになってお驚きになったように急に御｜快癒の法などを行なわせておいでになるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日蓮記」のあいだで、特にかれが快癒出勤の披露をすることになって、師匠の団十郎が羽織袴で登場して彼のために長い口上をのべた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは感激のためか、眼病がまだほんとうに癒えないためか、わたしにはよく判らなかったが、いずれにしても快癒出勤のために団十郎がわざわざ長い口上を述べてくれたということは、いかに彼が師匠からも愛せられ、劇場からも優遇されていたかを察することが出来る。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と同じ事を繰返して、稍あつてお利代は思ひ余つた様な顔をあげたが、『怎うせ行くとしましても、それやマア祖母さんが奈何にか、アノ快癒つてからの事で御座いますから、何時の事だか解りませんけれども、何だかアノ、生れ村を離れて北海道あたりまで行つて、此先｜奈何なることかと思ふと……。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と同じ事を繰返して、稍あつてお利代は思ひ餘つた樣な顏をあげたが、『怎うせ行くとしましても、それやまあ祖母さんが何うにか、あの快癒つてからの事で御座いますから、何時の事だか解りませんけれども、何だかあの、生れ村を離れて北海道あたりまで行つて、此先｜何うなることかと思ふと……。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学的に云えば、此の温泉の湯は先ず第一に皮膚病、殊に癩病に良く、次には脳病、糖尿病、という順序であるが、しかし、それなら果してそれら尽くの病体に必ず効いて快癒するものかどうかとなると、この一番に人体にとって重要なことは、易学でなければ絶対に分らない。",
              "citation": {
                "source": "馬車",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和四年の六月のはじめ、まだ梅雨の季節のやつて來ないうちに自分がこの作第一部の第二章を書き終つたのは、病床にあつた花袋君の一時快癒を聞く頃であつたと思ふ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "次男冬次郎｜労咳を患い、頼み尠く見えましたので、早速一粒を投じましたところ……」「ふうむ、やっぱり快癒したか」「さながら薄紙を剥ぐがよう」「名薬！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると不思議にも悪病は、次第次第に快癒した。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷のほうへも、私邸のほうへもお暇を乞い、神々への祭り、祓までも隙なくさせて姫君の快癒のみ待つ薫であったが、見えぬ罪により得ている病ではないのであったから、効験は現われてこなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いた尼君はいつもすぐれた健康を持っているのではない上、遠い旅をしたあとであったから、その後しばらくはわずらっていたもののようやく快癒したふうの見えたために僧都は横川の寺へ帰った。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "このくらいのところで快癒を御仏におすがりすることはやめたらいいでしょう」　と言い残して寺へ帰った。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生快癒する望みのない癈人としてぶらぶらしてゐるものの、どこかちよつとをかしいだけで、別に精神病者として警戒の必要もないし、放置してある。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、治療の効か養生が行届いたせいか、尼子富士郎医学博士が眼を丸くして驚いたほど、超スピードで快癒していった。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒が原因の病気は、酒をたちさえすれば、直ちに快癒する。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、外科手術の比較的幼稚だった南亜戦争当時でさえも、後送距離の短い場合は、そのほとんど全部が快癒しているのですからね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見た所、顔色もすぐれないようだから、あるいはまだ快癒がはかばかしくないのかと思ったが、話して見ると、格別、病人らしい容子もない。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日上様清八を召され、富士司の病はと被仰し時、すでに快癒の後なりしかば、すきと全治、ただいまでは人をも把り兼ねませぬと申し上げし所、清八の利口をや憎ませ給いけん、夫は一段、さらば人を把らせて見よと御意あり。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドノバンはまったく快癒した。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内父もいよいよ快癒して帰藩の旅をしてもよいということになり、私も勿論快復したので、そこでかつて京都留守居を引上る時に用いた高瀬舟をまた雇切って、伏見へ下り、伏見からは例の三十石の昼舟で大阪へ下ったのであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はついに枕を噛みながら、彼自身の快癒を祈ると共に、併せて敵瀬沼兵衛の快癒も祈らざるを得なかった。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹はいい、篁はいい、奥ぶかいゆゑ、冷えるゆゑ、なにかそこらのちらちらが、蝶や小蟻を明るくする。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
