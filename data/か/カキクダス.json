    "definitions": [
      {
        "index": 1,
        "gloss": "to write from top to bottom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
