    "definitions": [
      {
        "index": 1,
        "gloss": "to hire for exclusive use",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
