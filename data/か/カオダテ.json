          "literary": [
            {
              "text": "縄張りの顔立てなぞに到るまで、決して相手を高飛車にキメ附けるような侠客式の肌合いを見せない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、お人形のようだとか、美人だとかおだてられました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、猛獣はなかなかおだてに乗らず、睨み合いをつづけたまま動かない。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
