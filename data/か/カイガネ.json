        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "纖弱い肩胛骨は彫刻にも效果のある者である。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶よ、黝朱と金と、なんと豊かな肩胛骨、色めく翼のつけね。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "贄卓、花形の燭臺、そのほかの飾をば肩胛、脊椎などにて細工したり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手くびの一部分もだいぶ擦りむけていて、背中一面も同様であったが、ことに肩胛骨のあたりがひどかった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近はすこし慣れたが、それでも、肩胛骨に押しつけられる柔らかさを意識しなくなったわけではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "背中の下で、肩胛骨を突いているものの正体をたしかめようと、慶一は肩をもちあげ、右手でさぐった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、医師の検案書によると、後頭部と肩胛骨の部分とにひどい打撲傷があるばかりで、火器や刃物の傷痕もなければ毒殺の形跡もまったくないというのです。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、あの死体の打撲傷は後頭部と肩胛骨と二カ所しかありません。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、後頭部の打撲傷には後ろから力が加えられており、肩胛骨の打撲傷のほうは上から力が加えられています。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手頸の一部分もよほど皮膚が擦りむけており、それからひきつづいて右腕の背部一面に皮膚が擦りむけていたが、とりわけ、最もひどかったのは、肩胛骨の部分だった。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師の検査によると、女は束髪に結った面長の美人で、身体はうつぶしになり、顔を横向けてたおれて居たが、右側の背部の肩胛骨の下の所を衣服の上から刺されて、出血のために絶命したものらしかった。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かねて話したとおりに、これは肩胛骨から出た肉腫で、肩の骨は勿論、右の手全体切り離さねばならぬ大手術だからねえ。",
              "citation": {
                "source": "肉腫",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "五本の指、掌、前膊、上膊、肩胛骨、その肩胛骨から発した肉腫が頭となって、全体が恰も一種の生物の死体ででもあるかのように、血に塗れて横たわって居た。",
              "citation": {
                "source": "肉腫",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷は左の肩胛部と後頭部にある鈍傷で、いずれも生前にできたもの。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで次に起こる疑問は、大動脈瘤は末期になれば自然に破裂するし、また程度の進んだものなら肩胛部に加えられた打撃によってでも破裂するのではないかということですが、今度の場合その壁がかなり厚く、よほどの力が加わらなければ破裂しない程度のものでした。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の六（終局）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上言語に絶する残虐が屍体に加えてあって、何のためか、左の腋の下から左肋へ掛けて注意深く×り×き、背中の肩胛骨の真下にも、左右に各一つずつ深くナイフを×き×した痕があった。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二度といふ強度の近眼鏡を落ちさうなまで鼻先にずらした、鼠そつくりの面貌をした川島先生の、怒るとひどく吃る東北弁が終るか、前前日の午前の柔道の時間に肩胛骨を挫いて、医者に白い繃帯で首に吊つて貰つてゐた腕の中に私は顔を伏せてヒイと泣き出したが、もう万事遅かつた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンダスンの弾丸が――というのは最初に船長を射撃したのはジョーブの奴だったからであるが――肩胛骨を折って肺に触れていたが、ひどいことはなかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩胛骨や臀部のあたりは特によく一致していました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱肝は河豚の肺臓であって、肩胛骨の下側についている。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "愉快にも余は臀部及び肩胛骨に軽微なる打撲傷を受けしのみにて脳震盪の被害を蒙るにはいたらなかつたのであるが、余の告訴に対し世人は挙げて余を罵倒したのである。",
              "citation": {
                "source": "風博士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい右肩いっぱいに太い竿がどっしりと喰いこんで来て、肩胛骨のあたりがぽきぽきと鳴るような気がする。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっとうしろから忍び寄って、これぞと思う生物の肩胛骨のところへ、威勢よくそいつを突き通す。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂ぎつた薄汚い頸、幅広の肩胛骨は突き出てゐるし、短い脊中はでこぼこだ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "錐を揉みこまれるような肩の痛みが灼熱感にかわり、脱臼する直前の不気味な鈍痛が肩胛骨を抉りはじめる。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "つと、この訪問者は、肩胛骨のあたりに音をたてて、羽風を殘して去つてしまつた。",
              "citation": {
                "source": "霾",
                "author": "三好達治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り見馴れない、朱房のついた銀※の匕首で左の肩胛骨の下のあたりをの深く突刺されたまま、左脇を下にして鬢を畳に擦りつけ、「あッ……、たれか、助けて、ちょうだい……たれか、はやく。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは肩胛骨つて言ふんだ、それから――お秋　痛いよ、恵ちやん、そんなに掴むと痛いよ。",
              "citation": {
                "source": "疵だらけのお秋（四幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸を見るとわかるが、傷は左肩胛骨の下で、胸へ突き拔ける程の手際だ」「女にしては手際が良過ぎはしないか」「だがな錢形の、お北の着物に血が着いて居るのだよ」「どんな具合に？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "罠",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋書きがこうおいでなさらなくちゃ、せっかくおれさまが雨にぬれながらここでつっ立っていたかいがねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
