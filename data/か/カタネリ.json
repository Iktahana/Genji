        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "きたない風呂敷に包んだ箱を肩に引っかけて、あま酒の固練りと云って売りあるく。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甘酒や、あま酒の固練り……」　物に魘われたように二人はぎょっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "河内屋の露路を出てから、彼女はあま酒の固練りを呼ばなくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あま酒の固練り……」　この声がしずかな夜の往来に冴えてひびくと、通りぬけた駕籠の一挺が俄かに停まった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにさっき見ていると、あの婆さんの甘酒の固練りという声を聞くと、急に駕籠を停めさせてあっちのお武家が出て行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月のなかばの夕方に徳三郎が商売から帰る途中、浅草の広徳寺前でひとりの婆さんがあま酒の固練りを売っていたが、それはたしかにお熊の母のお綱であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "固練りのいいのを貰ったのがあります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "友谷さんはかたねりの白粉を首筋につけている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたねりの白粉も買わなければならない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
