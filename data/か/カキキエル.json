          "literary": [
            {
              "text": "千鳥　口ほどでもない平家の追っ手ども、掻き消えるように逃げて行ったか。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "その秀政も涙にくれ、彦右衛門も落涙して、ここの一燈は、涙に掻き消えるかと思われるばかり暗澹な夜色に沈みきってしまおうとした。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅客の群も、ほとんど掻き消える。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
