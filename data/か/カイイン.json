  {
    "uuid": "a3dabc7b-6df1-50b1-bb75-083532c32d02",
    "entry": "会飲",
    "reading": {
      "primary": "かいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drinking and carousing together",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伴れと下宿を探してゐるのだと云ふので、近いうちの会飲を約して別れる。",
              "citation": {
                "source": "五月六日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆人これを聴いて大いに慙じ入り、会飲の後将軍を取り囲みその舎を焼かんとす。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮に樹明来庵、久しぶりな会飲だつた、酒はキレイ、肴はハム、客は樹明、だから酔うてぶらつくこと例の如し。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "農学校に樹明君を訪ねて話してゐるとき、思ひがけなく周二君来訪、三人いつしよに帰庵して会飲、そして珍客芝川君を迎へた、意外であつたゞけ会合のよろこびは二乗された、千福の酔心地、広島牡蠣のうまさ、そのうまさも二重だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈで健と会飲、だいぶ痩せて元気がないから叱つてやつた、一年一度の父子情調だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――黎々火君と共に岔水居で会談会飲。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後青衣子君来訪、抱壺君父子と共に会飲、しめやかな酒であつた。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりの会飲、うれしかつた、送つて学校まで。",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言合せのために、祇園町に会飲する習わしになっていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡宰としての先生の治績には、父老会飲、賞罰の厳明の如き徳育風教の振興は勿論、社会法の徹底、均田法の施行、　雲南四郡看山遍　芸北三川度水頻　知道君恩無極已　衰来還賜自由身。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其次ハいつまで草四巻　此草紙ハ余ガ青年ノ比、柳春三、桂月池等ノ人々ト会飲スル毎ニ、各自筆トリテ見聞キシコトヲ書キタル反故ナリ。",
              "citation": {
                "source": "土用干ノ記",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては先生の寛容深くわが放蕩無頼を咎めたまはざるかと、思へばいよいよ喜びに堪へず、直に筋向なる深川亭にいざなひしが、何ぞ図らんこの会飲｜永劫の別宴とならんとは。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "松莚清潭の二子と両国の鳥安に会飲す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "松莚子と風月堂に会飲す。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、それぞれの部にある局部長らの人物もみな一トかどの人物だし、それらの者との談笑｜裡の会飲やら話のおもしろさといったらない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、錚々たる幕僚の将たちが、痛烈に会飲していた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『下手な画工が描きそうな景色というやつに僕は時々出あうが、その実、実際の景色はなかなかいいんだけれども。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこの娘さんか知りませんけれど、服装はいいというほどじゃありませんけれど、容貌はなかなかいいんですよ。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お使いなンかいいんだ。",
              "citation": {
                "source": "魚の序文",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらかいいんです。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
