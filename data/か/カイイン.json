[
  {
    "uuid": "9c4effb0-5dc2-5bdd-b396-7cb8f552fe9f",
    "entry": "会員",
    "reading": {
      "primary": "かいいん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "member",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本山岳における万年雪の罅穴の標本としては、信州白馬岳の大雪田の末、白馬尻に見ることが出来る、日本山岳会員辻村伊助氏の説明によると、この罅穴は幅約一米突深さ五米突に及んでいるそうである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二年には帝国学士院会員となった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員は恐らく二三十人もいたであろう。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員は前日※に同所着のこと。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の時代から一滴の酒も入れない家庭に育ちながら、そして母も自分も禁酒会の会員でありながら、他人の飲酒をいちがいに卑しむ心持は起らなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禁酒会員である以上は、自分の力の及ぶかぎり飲酒を諫めなければならないとも思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州ではクラブが出来ていて、クラブ会員同志は、家庭へ迎え合い、泊めたりし合います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは誰でも、光明のハイキング倶楽部の会員であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員資格のマークは仏名であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌人西行も、この倶楽部の会員でありました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をはいると、すぐ受付があって私たちはみんな求められて会員証を示しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには表に　ビジテリアン大祭次第挙祭挨拶論難｜反駁祭歌合唱祈祷閉式挨拶会食会員紹介余興　　　　以上と刷ってあり私たちがそれを受け取った時丁度九時五分前でした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美術学院の会員ですよ。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれは、毛利｜一樹、という画工さんで、多分、挿画家協会会員の中に、芳名が列っていようと思う。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にも会員になれということでなったのですが、米斎君は已に三越に入っておられたか、あるいはまだ入られず米僊先生の代りにおいでなすったか、そこはハッキリしません。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからだんだん訊いてみると、コンムニチー・シェーターというのは一種の会員組織のようなもので、突然に押蒐けて行っても入場が出来るかどうだか判らないとのことでした。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで結構とすぐに案内されて這入ると、なるほど会員組織らしい小劇場で、二階もなんにもない、極めて質素な小さい建物でした。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "発起者及び会員は朝野知名の政治家、実業家、学者を網羅し、その宣言は堂々たりしが、実績の見るべきものなくして終れり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、赤玉から頼まれてクリスマスの会員券を印刷したのが、そこへ足を踏入れる動機となってしまったのである。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員券だからおあいそ（勘定書）も出されぬのを良いことに、チップも置かずに帰った。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと会員券を買わされた時に捨てたつもりの金だったからただで遊んだような気持からでもあったが、実はその時の持ちの瞳のもてなしが忘れられなかったのだ。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会員券にマネージャの認印があったから、女たちが押売したのとちがって、大事にすべき客なのだろうと、瞳はかなりつとめたのである。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちは当局の忌諱に触れるような映画も憚りなく作って、そして会員ばかりでこっそりと見て娯しむことが出来ます。",
              "citation": {
                "source": "十年後の映画界",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、娘の親たちへ知らせなければなるまい……というので、とりあえず青年会員が二人、娘のうちへ自転車を乗りつけると、晴れ着をホコリダラケにしたその娘が、おやじに引き据えられて、泣きながら打たれている。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二科会から迎えられて、会員になりました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ君は青森県郷土史研究会の会員だつたので、郷土史の文献をかなり持つてゐた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その者は、この五百人の会員全部に聞えるように、はっきりと、大きな声で返辞をしなさい。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから御得意に挨拶に行き、会員、主任のうちに呼ばれて御馳走になり、カルタをとり、いま帰って、これを書いているのが夜十時です。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り富裕でないアグネスは英国婦人飛行協会員にはなれなかったので此の募集に自分の将来への活路を見出したように喜んでしまった。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或晩、それは欧洲の気候の内、一番よい五月の末頃、アグネスの入会して居る欧洲ハイキング・クラブの会員である巴里のイボギンヌから誘い状が届いた。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
