    "definitions": [
      {
        "index": 1,
        "gloss": "meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その会合の終り頃になつて、私は名刺を出しただけであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「常に孤独で居る人間は、稀れに逢う友人との会合を、さながら宴会のように嬉しがる」とニイチェが云ってるのは真理である。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日ミロにおける住宅で友人達と会合しあっていたとき誰かがその家に放火した。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガロンはロシア人共産党員とともに上海に入ると、直に大馬路の一隅で露支共産会合が開かれ、赤衛軍の決死隊が組織され、党員徽章が配付されると労農領事館には青天白日旗とソビエット・ロシアの聯邦旗が交錯して掲げられた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう会合できめたのであった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……日本の会合は時間の有害な浪費であると自分は思うと言った。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで日本へ帰って来ると、仕事をせよと奨励されずに、会合に出て宴会に出席して、雑誌を発刊して、演説をして、無報酬の講義をして、原稿を訂正して、仕事を妨げることに想像される有りとあらゆることをして、その時間を浪費せよと頼まれる。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りその会合たるや極めて古典的で当時温泉に浴してこれを見聞した筆者の無為を慰すること甚大であった。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都時代の私達の会合――その席へはあなたも一度来られたことがありますね――憶えていらっしゃればその時いたＡです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四月には私達の後、やはりあの会合を維持していた人びとが、三人も巣立って来ました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもともと話のあったこととて、既に東京へ来ていた五人と共に、再び東京に於ての会合が始まりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある会合の席でプランクトンの調査に関する講演を聞いた時、「今回のわれわれの調査はまだ単に量的であって質的の点までは進んでいない」という言葉を聞いて愕然として驚いたのであった。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ返すこの男と、あとから出発した直八と、中間を歩いている子供とが途中で会合することを暗示しただけで幕をおろすという暗示的な手法をとった一方で、こんな露骨なお芝居を見せるのは矛盾である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事をうかうか考えている自分を発見すると同時にまた、現在この眼前の食堂の中に期せずして笑い上戸おこり上戸泣き上戸｜三幅対そろった会合があったのだという滑稽なる事実に気がついたのであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二度目の月と醤油との会合ははなはだ解決困難であるが、前の巻の初めに、史邦の「帷子」の発句と芭蕉の脇「籾一升を稲のこぎ賃」との次に岱水が付けた「蓼の穂に醤のかびをかき分けて」を付けているところを見ると、岱水の頭には何かしら醤油のようなものと帷子との中間にまたがる観念群があるのではないかと疑わせる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四辺に人がないから、滝さんといって呼留めて、お兼は久ぶりでめぐりあったが、いずれも世を憚って心置のない湯の谷で、今夜の会合をあらかじめ約したのであった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から夜、夜から朝、引き続いた訊問は、忠良なる捜査官によつて、倶不戴天の敵なりとして続けられ、何月何日、某処に会合したその一人は既に斯の如き自白をして、汝もその時斯の如き言動をしたに相違がないと、其者は立派に陳述して居るではないか。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "会合の席には常に法被腹掛の支度で行く。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者の会合を料理屋で開くなんてけしからんと私は云つてやりました。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く所に拠れば近来も怪談大流行、到る所に百物語式の会合があると云ふ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "欠かせぬ会合にも不義理勝ちで、口繩坂は何か遠すぎた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（たしか二三年前に東京郊外在住の画家連中が同名の会合を組織していたと思う。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夜は句会、とほる君、箕三楼君、入雲洞君、そして私、つゝましい、たのしい会合だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はその發狂といふ文字に久しぶりにかいごうしたやうな氣がして快く讀み過した。",
              "citation": {
                "source": "「文藝林泉」讀後",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
