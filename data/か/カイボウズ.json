    "definitions": [
      {
        "index": 1,
        "gloss": "anatomical drawing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
