[
  {
    "uuid": "f0248912-c94b-50b9-ab3a-957565e0b6b6",
    "entry": "解散",
    "reading": {
      "primary": "かいさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "breaking up (a meeting, gathering, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海賊クラブは一日きりで解散だ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云ったからといって私は二科会や美術院の解散をすすめるというような大それた考えを持ち出す訳でも何でもない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンの遺言　数年後、欧洲大戦乱が勃発して、伯林にあった妾は一座を解散して、単独でムウドレのロダンさんのお室に身を寄せました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊教練が濟んで一先づ解散すると、分隊長の高岡軍曹は我々を銃器庫裏の櫻の樹蔭に連れて行つて、「休めつ‥‥」と、命令した。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月十五日の検挙はやる、四月十日の左翼の三団体の解散は喰らわす。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "解散」　そう言って、その若い中尉は壇から降りて眼鏡をはずし、歩きながらぽたぽた涙を落しました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、空を大きく四へん廻ったとき、大監督が、「分れっ、解散」と云いながら、列をはなれて杉の木の大監督官舎におりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "解散を命ずる」　かうして事務所は廃止になりました。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリオやカルテットの仲間がよくできては解散し、解散してはまた別の組ができるのであるが、事情を聞いてみると皆仲間の間の個性の融和がつきにくいのに帰因するようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてだんだん夜も更けましたので会長さんが立って、「やあこれで解散だ。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの会社ももうかっきり今日ぎり解散いたしまして酒は全部私の名義でつくったとして税金も納めます。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は先客の人に対して議会解散の予想などを喋喋述べて居たが、「こんなへつぽこ役人ではね、」と云つて湧き上る様に笑つた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、空を大きく四へん廻つたとき、大監督が、「分れつ、解散」と云ひながら、列をはなれて杉の木の大監督官舎におりました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今では解散したらしい）『四十女の恋』は本集の内容にふさわしくない。",
              "citation": {
                "source": "鎖ペンを握って",
                "author": "――三月十九日夜――　　山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "で何れも熱ツた頭へ水を打決けられたやうな心地で、一人去り二人去り、一と先づ其處を解散とした。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで叔父も財産を煙にして了へば、綾さんの父も息ついて、會社は解散。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの身辺の者たちは、駅の前で解散になって、それから朝食という事になるのですよ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "親はそのトラホームを非常に心配して、「兎に角、そんな所なら無理に勤めている必要もなかろう」というので、塾の方は退き、予備門へは家から通うことにしたが、間もなくその江東義塾は解散になって了ったのである。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月に至つて平民社は遂に解散を餘儀なくされた。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "平民社解散後であつた。",
              "citation": {
                "source": "小説「墓場」に現れたる著者木下氏の思想と平民社一派の消息",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝は体操が終ると、町医から流行病の予防の注意がありまして解散となりました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前の名物だった弥生座のピエルボイズも戦争がはじまる前に既に解散していて、その後弥生座はセカンド・ランの映画館になったり、ニュース館に変ったり、三流の青年歌舞伎の常打小屋になったりして、千日前の外れにある小屋らしくうらぶれた落ちぶれ方をしてしまった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の文化団体が解散して、新しい文化団体が大阪にも生れかけているが、官僚たる知事を会長にいただくような文化団体がいくつも生れても、非文化的な仕事しか出来ぬであろう。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして紫煙草舎を閉づると同時に、歌の上の門下にも解散を宣した。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで紫煙草舎解散の辞を書いた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、これで解散だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "観光団解散後の北海所見はいずれ機を得て稿を改めるつもりである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "彰義隊らとは成るべく衝突を避けて、無事に鎮撫解散させるのが薩長側の方針であったから、直ぐには攻めかかって来ない。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば東京でおむこうといふ所を大阪ではむかいさんといふ。",
              "citation": {
                "source": "用言の発展",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
