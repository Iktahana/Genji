          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "賭場を切り盛りする貸し元として、この界隈の顔役たちは一目置いていた。",
              "source": "幻辞"
            },
            {
              "text": "「貸し元に黙って勝手な真似はできねえよ」と、若衆は肩をすくめて首を横に振った。",
              "source": "幻辞"
            },
            {
              "text": "資金の貸し元を調査した結果、実態のないペーパーカンパニーであることが判明した。",
              "source": "幻辞"
            },
            {
              "text": "時代劇では、義理人情に厚い貸し元が主人公を助け、悪徳代官を懲らしめる展開がよく見られる。",
              "source": "幻辞"
            },
            {
              "text": "「へい、貸し元。今夜も景気良く張らせてもらいやすぜ」と威勢のいい声が飛ぶ。",
              "source": "幻辞"
            },
            {
              "text": "祭りの出店を取り仕切る貸し元は、その地域の治安や秩序を守る役割も担っていた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "にも拘らず、今もする関東の九郎兵衛は、貸し元とでも言ひ相な長脇ざしの感じを持つてゐる。",
              "citation": {
                "source": "辻の立ち咄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと相対性理論の存在を必要とするに至った根原は、畢竟時に関する従来の考えの曖昧さに胚胎しているのではないかと考えられる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物質不滅という考えは実はあらゆる時代に行われてきたのであるがしかしもとよりこれに関して何ら明瞭な考えはなかったのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもと／＼事務的に出来てゐるポオトフオリオが、事務家とも遊民ともつかない老年の彼にふさふか何うか考へものであつた。",
              "citation": {
                "source": "折鞄",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとより諸種の経験教養等によって発展を促されることはもちろんである。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "結論――自分の立場",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし裁判は終結しない儘休憩となり、ごろ寝をする、しかしもともと終結してゐないのであるから佗寝以上には進みやうがない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとよりそんなことにこだわっているべき場合ではなかった。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとより生活の趣味がモダンでなくてはならぬというのではない。",
              "citation": {
                "source": "女性の諸問題",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと加部福代との友達関係が、単に学校時代のクラスメートといふだけで、それも特別仲が良かつたわけでもなく、学校を出てしまへば、いくぶん互に澄し合ふといふ程度の距りもできて、勢ひ、ご亭主にもあまり関心を払はなかつたのは事実です。",
              "citation": {
                "source": "誰でもない……自分でもない",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと彼の武人｜気質は戊辰当時の京都において慶喜の処分問題につき勤王諸藩の代表者の間に激しい意見の衝突を見た時にも、剣あるのみの英断に出、徳川氏に対する最後の解決をそこに求めて行った人である。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとはやはりまず良民と賤民との中間に立っているという位のもので、大宝の頃には、良民を養子にすることを禁ぜられ、犯すものは一年半の徒刑に処するという規定もありました。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと武士には蝦夷すなわちエビス出身が多かったから、「徒然草」などを始めとして、鎌倉南北朝頃の書物を見ますと、武士のことを「夷」と云っております。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと非人とは、決してそういう意味ではない。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともとかの書は、いかにして融和を促進すべきかということを主に述べたものでありましたから、自然歴史上の説明には、あまり深く立ち入ることができませんでした。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと同じ流れの落伍者の群の人々でありますから、ついには事実屠殺を業としないものまでが、同じ仲間の非人すなわち河原者であるということで、すべてがエタと呼ばれるようになりました。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと小学校を出ただけの学歴では事務員や店員のような就職口さえなかなか見当らず、よしまた見当ったところで、一度秘密の商売を知った身には安い給料がいかにも馬鹿らしく思われ、世間は広くてもその身に適する職業は、やはり馴れた賤業の外にはないような心になるのであろう。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとより解決のつくはずはなかった。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと二千年の間培われて来た国民性の癖は、なかなか急には頭の底から抜けないのではないかという気もする。",
              "citation": {
                "source": "語呂の論理",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとはいい画であったろうと思われる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもと／＼此方に無理があるのだし、一日も早く出て貰ひたいと思つたればこそ、大概なことは聞いてやつたのに、その上リヽーまで連れて行かれて溜るものか。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもともと此方に無理があるのだし、一日も早く出て貰いたいと思ったればこそ、大概なことは聞いてやったのに、その上リリーまで連れて行かれてたまるものか。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　　　　　　　×　　　　　　×　　　　　　×　　　　　　×　この人の一生には随分過失もあったようで、従って帰幽後の修行には随分つらいところもありましたが、しかしもともとしっかりした、負けぬ気性の方だけに、一歩一歩と首尾よく難局を切り抜けて行きまして、今ではすっかり明るい境涯に達して居ります。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとの呉州を棄てて洋風のコバルトに変え、けばけばしい色になったのは残念である。",
              "citation": {
                "source": "現在の日本民窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとより口に言うまでもなく、二人はそれを知っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもとより、彼は正当の愛し方をしてるのではなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「太平記」はその景観を、いつもの古典的筆法で、日本、小国といへどか程に人は多かりしとただ驚かるるばかりなり　と言い、また元弘三年正月の“現地着到帳”の上では、諸国の軍勢八十万騎これを三手に分かちて吉野、赤坂、金剛山三つの城へぞ向けられける　としているが、しかしもとより数字は誇張にすぎない。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "gambling boss",
