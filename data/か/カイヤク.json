[
  {
    "uuid": "8f8cb4b2-c731-5c7d-ba2d-ef8a54aecfb9",
    "entry": "解約",
    "reading": {
      "primary": "かいやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
