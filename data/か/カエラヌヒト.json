        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山岳遭難事故から一週間、懸命の救助活動もむなしく、彼は帰らぬ人となった。",
              "source": "幻辞"
            },
            {
              "text": "昨夜まであんなに元気だった友人が、まさかこれほど急に帰らぬ人になるとは信じられない。",
              "source": "幻辞"
            },
            {
              "text": "戦地に赴いた若者たちの多くが、故郷の土を踏むことなく帰らぬ人となった。",
              "source": "幻辞"
            },
            {
              "text": "病院から危篤の知らせを受けて駆けつけたが、最愛の父はすでに帰らぬ人となっていた。",
              "source": "幻辞"
            },
            {
              "text": "巨大な津波は一瞬にして街を飲み込み、多くの無辜の市民を帰らぬ人へと変えてしまった。",
              "source": "幻辞"
            },
            {
              "text": "彼は帰らぬ人となったが、その遺した数々の名曲は今も人々の心の中で生き続けている。",
              "source": "幻辞"
            },
            {
              "text": "行方不明となっていた女性が数日ぶりに山林で発見されたが、残念ながら帰らぬ人の姿であった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "家を出でゝ程久しきに、母も弟も還ること遅し、鴉は杜に急げども、帰らぬ人の影は破れし簷の夕陽の照光にうつらず。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊く水は再び還らず、魯陽の戈は落日を招き還しぬと聞きたれど、何人も死者を泉下より呼起すべき術を知らぬ限は、われも徒爾に帰らぬ人を慕うの女々しく愚痴なるを知る、知って猶慕うは自然の情なり。",
              "citation": {
                "source": "父の墓",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青木大佐も帰らぬ人となった。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「都を離れた所で、帰らぬ人になってしまわれたことは、風の便りで聞きましたが、何せ自由にならぬ島暮し、直ぐにもお傍に急ぎはせ参じたいと思いつつ、とうとう、これまで打ち過ぎてしまいました。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことがあってから、熊野詣でがあり、重盛は間もなく帰らぬ人となったのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かというと、清盛の行動を邪魔立てするうるさい重盛であったが、心の底から清盛のことを親身に考えている息子でもあった重盛が、遠く帰らぬ人となってみると、清盛には、彼のえらさ、立派さがつくづくわかるように思われてならぬのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし、石の無心の風車が、無限にクルクルと廻るのも、帰らぬ人の魂を無限の底から汲み上げる汲井輪の努力かも知れない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その十一月、この老将は伊勢で病んで、ついに帰らぬ人になってしまった。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
