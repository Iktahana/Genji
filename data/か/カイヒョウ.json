[
  {
    "uuid": "576cfa80-cf06-5389-b363-79368a4c3b44",
    "entry": "開票",
    "reading": {
      "primary": "かいひょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
