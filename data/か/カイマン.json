    "definitions": [
      {
        "index": 1,
        "gloss": "ocean",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――忽ち蒼海漫々たり。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六八年版コリングウッドの『博物学者支那海漫遊記』一七二頁注に、触れたら電気を出す蛇を載す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "此地眺望最も秀美、東は滄海漫々として、旭日の房総の山に掛るあり、南は玉川混々として清流の富峰の雪に映ずるあり、西は海老取川を隔て云々、大層賞めて書いてある。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔註〕左に掲ぐるは、余が今春熱海漫遊の後、『国民新聞』に寄せたる「熱海だより」中の一なり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
