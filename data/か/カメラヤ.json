        "examples": {
          "standard": [
            {
              "text": "祖父から譲り受けた古い一眼レフを修理してもらうため、銀座にある老舗のカメラ屋を訪ねた。",
              "source": "幻辞"
            },
            {
              "text": "「駅前のカメラ屋に寄って、今度の旅行で使うための予備バッテリーを買い足しておこう。」",
              "source": "幻辞"
            },
            {
              "text": "デジタルカメラの普及とスマートフォンの性能向上により、かつて街中にあった現像取次専門のカメラ屋は激減した。",
              "source": "幻辞"
            },
            {
              "text": "現像に出していたフィルムを受け取りにカメラ屋へ行くと、店主がおすすめの撮影スポットを教えてくれた。",
              "source": "幻辞"
            },
            {
              "text": "本格的なライティング機材を揃えるなら、量販店よりもプロ御用達の専門的なカメラ屋に相談した方が確実だ。",
              "source": "幻辞"
            },
            {
              "text": "掘り出し物の中古レンズを探して、休日は都内にある中古カメラ屋を何軒もはしごするのが趣味だ。",
              "source": "幻辞"
            },
            {
              "text": "カメラ屋のショーウィンドウにずらりと並んだ最新機種を眺めていると、つい新しい機材が欲しくなってしまう。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "丸山苔水堂というカメラ屋の前まで来て、小田はおやっと思った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人それぞれ自慢のカメラや寒暖計などを持ち出して、たいへんな意気込みで乗り込むことになった。",
              "citation": {
                "source": "天地創造の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
