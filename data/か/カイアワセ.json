          "literary": [
            {
              "text": "両側のがけが、ちょうど、びょうぶを二まいむかいあわせて立てたようになっている。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのむかいあわせの屋根うらべやの窓も、また、あけひろげられて、カイとゲルダとは、アパートのてっぺんの屋根上の雨どいの、ちいさな花ぞので、ことしもあそびました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "向かいあわせ」　事務室の窓口に手をかけた高志に、慶一が声をかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、赤い絨毯をしきつめた大広間の真中に、籐椅子を向かいあわせて腰を下した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれを向かいあわせにもってきて、ぴょこぴょこさげ、両方の指がしきりにお辞儀をしているような型をやって見せた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
