[
  {
    "uuid": "4c72a8ca-cec0-5390-b00c-a71c3dfedf72",
    "entry": "改質",
    "reading": {
      "primary": "かいしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
