    "definitions": [
      {
        "index": 1,
        "gloss": "category theory",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日常語に如何に含蓄ある而も厳正な用法を与えるかというのが、ヘーゲルのカテゴリー論を一貫した文化的目標の一つであったように見える。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の考え方にはいつも微量のフィロロギー（文献学）とカテゴリー論とがある。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミー（大学の如き）とジャーナリズム（報道現象）との対語でなくてはカテゴリー論の虫がおさまらない。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
