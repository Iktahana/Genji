          "literary": [
            {
              "text": "あんだけ部屋があまってんだから、ダメだなんて、いうわけないだろ」５ラジオをつけて、グルッとダイアルを回すたちまちダンスのはじまりだ〈ダンス、ダンス、ダンス〉ビーチボーイズ　ＫＷＴＳの「開局」は、六月二十日に決まった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとは、ワラとふたりでやるからさ」　二十日の開局当日は、「局」には、高志とワラだけが入った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日月曜にはじまるこの週は、「開局記念週間」として、特別プログラムが組まれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「開局」のいそがしさで、とりあえず棚上げになっていた不満と憂鬱が、また慶一の心を占領している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二五年には、テネシー州ナッシュヴィルで、保険会社がラジオ局をひとつつくり、ＷＳＭ（「万人の生活を守る」という意味のスローガンの頭文字）と名づけ、一〇月に開局した。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
