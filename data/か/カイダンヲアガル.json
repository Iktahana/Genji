    "definitions": [
      {
        "index": 1,
        "gloss": "to go up the stairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
