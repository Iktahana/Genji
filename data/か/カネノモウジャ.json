        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は金の亡者となつて十年あまり苦しんだが、娘｜信乃には此苦しみを頒け度くはないから、萬一の場合の爲に一言申し遺す。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の守袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "話ではどこかに人でなしの冷血の老父がいて、金の亡者だそうだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら金の亡者か、財務官僚か、駐在武官といったところ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の亡者でございます。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "乏しい人道そっちのけで強欲やら、自己保身やら、金の亡者をめざし、親父は残高を忘れ、やもめは遺産を顧みない。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
