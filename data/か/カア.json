    "definitions": [
      {
        "index": 1,
        "gloss": "cawing (of a crow)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
