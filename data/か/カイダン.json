    "definitions": [
      {
        "index": 1,
        "gloss": "talks (i.e. formal discussions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翌朝、私は馬車でオスタ島の砲台附近の印度のイサックの別荘に招かれて、黒奴の紳士と会談するのであったが、でかけるときにアダは私に姿をちらとみせると故意に姿を隠してしまった。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝の新聞に宅の下手な合奏の光景が暴露されているかと思って読んでみると「……同学士をＨ町の自邸に訪えば」うんぬん、とあって、ちゃんとそのＴ氏の自宅においてＴ氏と会談したことになって記述されていたのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん会談に疲れたか、氏は「科学は情熱だからね」と殆ど泣き笑いとでもいうべき語調を床にいる夫人の方へ投げかけた。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会談一時間ばかり、そこを出てから（結城孫三郎のあやつり人形見物はやめにして）やたらに歩きまはつた、ネオンサインのうつくしさ、デパートのさわがしさ、飲んだり食べたりのいそがしさ。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "八代代議士と倉持との会談も、無論投票に関することで、倉持は原敬の依頼状まで受け取り、感激していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮坂は始め客達に目を瞠らせられた物珍らしさが過ぎると、此の不意に現われて際限もなく自分の会談を奪って居る女性達にいらいらした不満を抱き始めたらしかった。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都駅で春隆に紹介された時も、「侯爵を燕にするなんて今時悪趣味じゃないの」　と、皮肉りたいところだったが、じっと我慢して、「――ちょっとハンサムね」　という言葉で、貴子の耳をくすぐったりした――それも商売人が資本主との会談に芸者を当てがうというあの心理からだったのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "長官より会談の申込あり。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会談中マターファが私をアフィオガと呼んで、ヘンリを仰天させた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三井物産の重役が来ると不景気の救済策を授け、外務大臣が来ると軍部の実力を説いて感心させ、軍部の首脳部と会談すると外交の妙諦を説法して頭を掻かせる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この会談の場所は、佐野天妙であるとも云い、犬伏と云う所だと云う説もある。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の「嵐の夜の会談」に就いての僕の手紙が、たいへん君の御気に召したようで、うれしいと思っている。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "講演の不成功に落胆せずにポウはその草稿を書き直して間もなくプトナム出版社を訪れ、「極めて重要な件について、プトナム氏と会談したい。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなお取り次ぎによっての会談は私に経験のないことです。",
              "citation": {
                "source": "源氏物語",
                "author": "若紫",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し日がたって気の落ち着いたころに御訪問した入道の宮ででも、感慨無量な御会談があったはずである。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "有馬農相が農民文学者と、お茶をすすつて、政治と文学のために一夜を会談するといふことは、たしかにこれまでの政治家には珍らしい砕けたものがある。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治上のジレッタントと、文学上のジレッタントとの会談、多分にさうした性質を帯びてゐる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家の、オランダ人御覧が昨日｜滞りなく終ったので、カピタンを初め、二人の書記役、大小の通辞たちも、みなのびのびとした気持になっていたので、会談がいつになく賑わった。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭いインテリジェンスのひらめき、ほとんど神経質的ともいえる感性の動き、そしていっけん冷徹とも見える外貌の中に蔵された情熱、そういったものを私は博士との二時間足らずの会談のうちから得たのであった。",
              "citation": {
                "source": "小酒井不木氏",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その諜報は、アメリカの軍関係事件だの重要会談だの大ものから始まり、巷の民衆の声までを集録している。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大統領と“影”の大統領ゼルコフとの会談――。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "老博士の怪行動　せっかくの権威者会談が、青倉教授と志々度博士の意見の両立となってしまって、総監はついに、その席では、何らの措置決定をせずして、会談を閉じた。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "会談解散後、総監は、ひとり多島警視を自分の部屋に呼び込んで、二人きりの相談にうつった。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきの会談は、弱ったじゃないか。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが軍は、ここに貴提案を受諾し、只今より二十四時間後において、まず大空軍団の出動からはじまる全軍の日本攻略を決行いたします」　リット提督は本国政府から、英ソ秘密会談について、とくに英国全権の重い職務を与えられていたのであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　などと黙つてゐる彼女を、会談の圏内に入れようとする毎に、美奈子は淋しい微笑を洩す丈だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして稍暫くの間、彼の保護者である彼の母と、多くの注意事項に就いて会談の後、帰りがけに一寸彼の書斎を叩いて、「しつかりやつて呉れ、俺はお前を憎んではゐないよ。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、昨年の五六月頃、国枝氏が名古屋に居られることをきいて、一度御目にかかりたいものだと思っていると、幸いにも七月の下旬、プラトン社の川口氏の紹介で名古屋ホテルで会談することが出来た。",
              "citation": {
                "source": "国枝史郎氏の人物と作品",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、お城のそとでこそ、よくしゃべりましたが、いちどお城の門をはいって、銀ずくめのへいたいをみたり、かいだんをのぼって、金ぴかのせいふくをつけたお役人に出あって、あかるい大広間にはいると、とたんにぽうっとなってしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、へいきでえしゃくして、『かいだんの上に立っているのは、さぞたいくつでしょうね。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
