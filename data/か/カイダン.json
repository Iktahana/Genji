  {
    "uuid": "dafc5bd2-52e0-5152-b9d9-94164d857c3a",
    "entry": "解団",
    "reading": {
      "primary": "かいだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disbandment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで彼も亦ニヤリとして、「いつやるんだ」「あす昼、解団式の直後にでも決行する」「そりや、まづい」と新聞記者は云つた。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、お城のそとでこそ、よくしゃべりましたが、いちどお城の門をはいって、銀ずくめのへいたいをみたり、かいだんをのぼって、金ぴかのせいふくをつけたお役人に出あって、あかるい大広間にはいると、とたんにぽうっとなってしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、へいきでえしゃくして、『かいだんの上に立っているのは、さぞたいくつでしょうね。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、からすとゲルダとは、かいだんの上にのぼりました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでふたりは、おばあさまの家の戸口へいって、かいだんをあがって、へやへはいりました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに、高一のはいっていたたるは、海水にのってすうっともちあがると、水のすごいいきおいで、かいだんのすきまから甲板にとびだしました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白と黒の細かいだんだらの腹を、月の光りにさらしながら、頸ばかりを長く振りのばして、悲しい声に彼は叫びつづけたのである。",
              "citation": {
                "source": "一条の繩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子はそれから、大理石をしきつめた大ろうかを通って、かいだんの上まで行って、番兵のつめているへやにはいりますと、番兵らは鉄砲を肩にのせてならんだまま、ありったけの高いびきをかいてねていました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "おひめさまが、王さまや、のこらずのごけらい衆といっしょに、食事のテーブルにむかって、金のお皿でごちそうをたべていますと、そとでたれかが、ぴっちゃり、ぴっちゃり、大理石のかいだんを上がってくる音がしました。",
              "citation": {
                "source": "かえるの王さま",
                "author": "DER FROSCHKONIG ODER DER EISERNE HEINRICH",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも王子さまはあたまをはたらかせて、まえもって、かいだんをぜんぶオイルでべとべとにしておきました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、アッシェンプッテルはかいだんをかけおりたときに、ひだりのくつがひっついて、ぬげてしまいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま　かいだんを　かけあがって、　やねうらの　まどから　にげだしました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かいだんの　したは　そろそろ　いっぱい　いっぱいなの。",
              "citation": {
                "source": "つまさきチミーのはなし",
                "author": "THE TALE OF TIMMY TIPTOES",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぬは　ほえますし、　おとこのこは　あつまって　とおりで　くちぶえを　ふきますし、　すいじがかりも　おおわらいして、　すみこみの　おてつだいだって　かいだんを　かけのぼったり　おりたり、　それから　カナリアまで　ぴーぴー　ゆげを　ふくみたいに　うたうのです。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに　がしゃんと　おおきな　ものおとでも　すれば　それは　おちゃの　おぼんを　てにした　セアラが　かいだんから　すっころんだって　ことなので、　そこにある　おかしくずやら　さとうやら　ジャムのしみやらが　ねこさえ　ものとも　しなければ　ひろえるって　ことでもありますからね。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど　もぐもぐハンカが　もうひとつ　イスを　はこんでいた　そのとき、　へやのそとの　かいだんから　きこえてくる　はなしごえ。",
              "citation": {
                "source": "わるねずふたりぐみのはなし",
                "author": "THE TALE OF TWO BAD MICE",
                "note": "青空文庫"
              }
            },
            {
              "text": "グロスターの　古い　おうちには、　どこでも　木の　かべうらに、　ちいさな　ネズミ用の　かいだんと、　かくしとびらが　ありました。",
              "citation": {
                "source": "グロスターのふくやさん",
                "author": "THE TAILOR OF GLOUCESTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいだん下の　なん戸を　のぞいたり、　ちょうど　空き部屋に　なっていた　ほこりまみれの　ねどこも　さがしてみたり。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつみ１メートルくらいの　かべも　あって、　なかでは　いつも　ごとごと　へんな　物音、　まるで　ちいさな　かくし　かいだんでも　あるみたい。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいとこの　タビサは　そわそわ　みゃあみゃあと　かいだんを　下りてきて　――「お入りください。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも　見つからないのに　戸の　ばたんという　物音　それから　だれかの　かいだんを　かけ下りる　音が　ひとたび　聞こえてくるのです。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　リービと　タビサは　もう１ど　かいだんを　かけ上がります。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょびひげサミュエルは　かべ板の　すきまを　ぬけて、　あろうことか　正面かいだんを　下りて　牛乳おきばまで　バターを　取ってきます。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあと　ふたたび　板を　打ち直して、　道具を　かばんに　つめこみ、　かいだんを　下りてきました。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから　うんよく　ほんものの　メリアンには　あわないまま　かいだんを　とことこ　のぼれて。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かいだんの　とちゅうで　たちどまって　いきつぎしながら　ババールは　ふしぎに　おもいます。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいだんのようなものが、あったので、二だんのぼりました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいだんをおりると、ドアがあります。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かいだんのとちゅうでつかまってしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "くらくて、足もとがあぶないからね」　林さんは、そういって、たけしくんときみ子ちゃんを、りょうわきにかかえるようにしてだきあげたかとおもうと、まっくらなかいだんのようなところをことこととおりはじめました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
