[
  {
    "uuid": "0f326766-0a08-5030-a1f0-e7aa56d0fcd7",
    "entry": "兼ねる",
    "reading": {
      "primary": "かねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞",
        "動詞-一段"
      ],
