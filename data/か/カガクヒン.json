        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "又、電信と申す、人智では考えられぬものにも、手を着けておるが、こういう理化学品を、どんどん作るほかに、天産物に乏しいこの国の福利を計る方法は無い。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者の家や化学品を取扱う家では塩の代りにエーテルを氷へ混ぜると大層早くアイスクリームが出来ると申しますけれども激薬ですから素人には使えません。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人絹も盛に取り入れられ、染料もほとんど化学品を用います。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
