        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その人は会計士なんですけどね、赤毛連盟はどうなったんだ、て聞いてもそんな団体、聞いたこともないって言うんですよ。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "舳に立っていた会計士官の一人が眉をひそめた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計士官は提灯をふりかざし、どたどたとやって来た。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計士官らの手配にひどく満足した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした下地があるので、改正法による公認計理士（会計士）の試験を受けて資格を得たら会社入りをする考へだと語つた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに書かれた金額は間違いなくニューヨークの一流公認会計士が認めたもの。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも大学院に進学したり、司法試験や公認会計士試験や公務員試験を受験しようとする学生は文句なく勉強している。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ海軍の会計士をやっているという、ぼくとおなじ年齢の男も、妻をともなって来ていた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫然と事務をしてもしょうがないから、勉強して会計士になったの。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父は公認会計士という職業の人で、母親もそうです。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ見つけた相棒は長年こすい会計士をしていた男だ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
