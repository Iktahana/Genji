        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながら真底からおぼこな二人は、その吉野紙を破るほどの押がないのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子は書きかけた手紙を破ると、改めて姉の名で激励の手紙を書いて、送った。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、原稿用紙を破る。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "角頭の歩を突いたり、名人を自称したり、いはば横紙を破る強気も生じたのだ。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けば大層壁紙を破ることが好きで、またたびたび木器の脚を噛る。",
              "citation": {
                "source": "兎と猫",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
