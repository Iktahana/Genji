        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "このかぶらずしは、このごろは、市販品になっているが、昔はみな自分の家で漬けたものである。",
              "citation": {
                "source": "かぶらずし",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百万｜石の城下町に、いかにもふさわしい漬け物であって、それぞれ自分の家のかぶらずしを、自慢にしたものである。",
              "citation": {
                "source": "かぶらずし",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野水の「うそつきに自慢いはせて遊ぶらん」につけたもので、この鮓は、かぶらずしまたはそれに類似のものではないかと思う。",
              "citation": {
                "source": "かぶらずし",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとかぶらずしの方が、ぴったりする。",
              "citation": {
                "source": "かぶらずし",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生もかぶらずしが好きであった。",
              "citation": {
                "source": "かぶらずし",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
