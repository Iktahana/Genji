        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　中村氏は駝鳥のやうな長い首を会計課の窓に覗けて言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "健吉くんは大学を卒業してから、デパートメント・ストアで名高いＭ呉服店の会計課に勤めることになりましたが、保一くんは大学を中途にて退学し、放蕩に身を持ち崩しました。",
              "citation": {
                "source": "愚人の毒",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村康男といって、本年二十八歳、商業出の俸給六十円、会計課勤務の男と、もうひとり、永年この社の小使いをしている安藤久七という四十男、先年女房に死なれたのでその後釜を欲しがっているという。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿賀妻さん」　小柄な会計課員は懐しそうに声をかけた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから租税課長の竹場好明氏、会計課長の篠崎承弼氏は宇和島人であったが、これは留任した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は会計課員だけど。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は社長室でよく、キャッキャッと社長とふざけていたがひとたび社長室より出ると、大した威厳でもって、会計課長にも営業の重要人物にもどんどん命令し、年寄った彼等は表面へいこらしていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、四、五日前に、土木課の吏員と会計課の吏員とが喧嘩をした。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計課員はそれを不当として旅費の支出を承認しない。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計課へは銀行の女事務員が係ってくれた。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、言つたところで、男性の品定めぐらゐ、もう、おほぴらにしてもいい年ぢやないの、お互さまに……」　どつちがどう言つてもいいやうなこの種の応酬は、だんだん度数が多くなつて、同室の男たちはむろんのこと、隣の会計課の課長以下、給仕に至るまで、ひと通りこの両女性の採点表に名をつらねる光栄に浴した。",
              "citation": {
                "source": "悪態の心理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は会計課長の牧野さんへ入門し、後者は同僚の関君の誘導による。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計課長の牧野さんが竹陰と号して南画を描き、殊に竹がお得意だということは苟くも一二年勤めた社員なら皆承知する機会に行き当る。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計課長の牧野さんが立派な表装の一軸に大きな手土産まで添えて千吉君の家へ自身乗り込んだのは、それから一月ばかり後のことだった。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "千吉君は翌日出勤すると早々会計課へ寄って牧野さんに一応お礼を申上げた。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は何度、そこから会計課へかけこんだのかね。",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            },
            {
              "text": "火夫が会計課でおしゃべりすることはもうないだろう。",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            },
            {
              "text": "船から一、二メートル離れるやいなや、カルルは自分たちが今、会計課の窓が向いている側にいることに気づいた。",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            },
            {
              "text": "定例に依って会計課から送って来るのが当りまえだ」「だけど、送って来なかったらどうしましょうね。",
              "citation": {
                "source": "端午節",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分で行くことは取消されてやっぱり会計課から分送することになった。",
              "citation": {
                "source": "端午節",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
