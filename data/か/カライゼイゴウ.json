    "definitions": [
      {
        "index": 1,
        "gloss": "shi he (hexagram 21 of the I Ching: biting through)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
