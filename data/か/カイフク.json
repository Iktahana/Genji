      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "restoration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから帰宿の途中、地下鉄の昇降器の中で卒倒したが、その時はすぐに回復した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその瞬間に、私の記憶と常識が回復した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして記憶が回復された一瞬時に、すべての方角が逆転した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが次の瞬間、私は意識を回復した。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に腦症を起しかけて醫師が絶望を宣告した事、そして、家中の者が枕元に集まつて豫期された私の死に涙ぐんだ事――そんな事は回復期にはいつてから初めて看護婦の武井さんに聞かされた事だつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "衰弱しきつた體はなかなか回復しなかつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年ぶりかで久し振りに割引電車の赤い切符を手にした時に、それが自分の健康の回復を意味するシンボルのような気がした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その効験は著しいもので、お豊はそのあくる朝から神気がさわやかになって、七日ほどの後には元の達者なからだに回復した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではまた、突然の暴行の後に釈放された白い母鳥も、ほんのちょっとばかり取り乱した羽毛をくちばしでかいつくろって、心ばかりの身じまいをしただけで、もう何事もなかったように、これも瞬間の驚きから回復したらしい十羽のひなを引率してしずしずと池の反対の側へ泳いで行くのであった。",
              "citation": {
                "source": "あひると猿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "割れ目があまり大きくては困るが、しかし必ずしも 10-8 や 10-7 でなくてもミクロン程度のものならば、その間隙を液体で充填することによって割れ目の面における音波の反射をかなりまで防止し従って鐘の正常な定常振動を回復することができるであろうと考えられる。",
              "citation": {
                "source": "鐘に釁る",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、今度再び自覚を回復したときは、学校の授業を受けおおせて、いつものように書物のふろしき包みと弁当をちゃんとさげて、通りなれた川ばた道を半ばぐらいまで歩いて来たときであった。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天佑と名医の技術によって幸いに子供は無事に回復した。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして食物も衣服も住居もめいめいが自身の労力によって獲得するのであるから、天災による損害は結局各個人めいめいの損害であって、その回復もまためいめいの仕事であり、まためいめいの力で回復し得られないような損害は始めからありようがないはずである。",
              "citation": {
                "source": "天災と国防",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなくある日縁側で倒れて気息の絶え絶えになっているのを発見して水やまたたびを飲ませたら一時は回復した。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと南のほうの損害のひどかった町村ではおそらくそう急には回復がむつかしいであろうが。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生全体の細かい強い震動が、大奏楽の Finale の楽声のやうに、雄々しく狂ほしく互に打ち合つて、もう一歩で回復の出来ない破滅を招くかとも思はれるその境を、彼の心は痛ましくも泣き笑ひをしながら小躍りして駈けまはつてゐた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働に疲れ種々の患難に包まれて意気銷沈した時には或は小さな歌謡を口吟む、談笑する音楽を聴く観劇や小遠足にも出ることが大へん効果あるように食事も又一の心身回復剤である。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文彦は悪人ながらも男爵の死を悼んで杉田とともに月界に手厚く葬り、その上に紀念碑を建てて其後一週間ばかりその地に止って、博士のやや元気を回復するを待ち、博士、東助、及び主人の死後改悛の意を表して服従した平三と各々二人ずつ二個の飛行船に分乗して地球に向って出発したのである。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（兵卒らこの時｜漸く饑餓を回復し良心の苛責に勝えず。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬子も一時は失神の態であったが、これも市郎の手当に因て回復して、南向の座敷に俯向いて坐っていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十九）　目前の敵を一人殪したので、市郎は少しく勇気を回復した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑地はずいぶん広い、とても全部へは手が届かないし、またそうする必要もない、その三分の二は雑草に委任、いや失地回復させてある。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識が回復したらモチット訊問するかも知れんから……僕は向うの八百屋から本署に電話をかけて来る。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその中にやっと、いくらかの落ち着きを回復したらしかった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも遂に、理性がまた彼女に回復して来た。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康が、少しでも早く回復し、好きな食物が食へ、自由な散歩が出来たらば好いと思ふ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆるすべての事情が、今や失われた詩を回復し、文学の葬られた霊魂を呼び起そうとしているのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし、諸君にしてそこに気が付くならば、詩壇の正義は回復され、批判の眼は正しくなり、すくなくとも詩の進出を、正しき方向に導き得るのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷え冷えとした気候が、少年の頭脳のはたらきを、久しぶりにかいふくしたように思われた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気がかいふくしたうえでないと、なにを聞いてもいけないぞ」　と、エバン船長は、厳然たるなかに、深いおもいやりのある言葉をかけた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
