[
  {
    "uuid": "e76b795e-1087-5345-87d7-2cb47c02dd40",
    "entry": "回復",
    "reading": {
      "primary": "かいふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
