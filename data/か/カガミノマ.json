      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "room behind the curtain of a noh stage, where the actors prepare",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "能楽師は鏡の間で大鏡に向かい、面を掛けることで自らの精神を役へと移していく。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "揚幕の奥にある鏡の間には、出番を控えた演者たちの張り詰めた空気が漂っている。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「鏡の間に入ると、不思議と雑念が消えていくのです」と、その老練なシテ方は静かに語った。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "鏡の間で装束を整え終えた演者が、笛の合図とともに静かに橋掛かりへと進み出た。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "初舞台を控えた若者に、師匠は鏡の間における厳格な作法と立ち居振る舞いを教え込んだ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "能舞台における鏡の間は、日常の自分を捨て、非日常の幽玄な世界へと切り替わる神聖な境界とされる。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "能の進行中、すこし気に入らぬ事があると楽屋に端座している翁は眼を据えて、唇を一文字に閉じた怖い顔になりながらムクムクと立上って、鏡の間に来る。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後退りしとうなる」　＝光雲神社の鏡の間で囃子方へ＝「馬鹿どもが。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからつぎには、ローゼンボルのお城でみるような鏡の間にでました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ただ遊びじゃあ旅銭旅籠銭の余裕はなし、久ぶりで姉さんの顔は見たし、いい幸に来たんだから、どうせ見世ものなら一人でも多く珍らしがらせに、真新しい処で、鏡の間から顔を出して、緋目高で泳いでれば可いんです。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "己はあの鏡の間で御身と対坐した時、あの美しい囚人のゐる密室を、御身がために開かうと決心した。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の間の壁に嵌めた無数の鏡は、女の艶姿嬌態を千万倍にして映じ出だした。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "数町に渡った正方形の広場は、鏡の間のように光り輝き森閑として人一人通らなかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "×鏡の間より出づるとき、今朝の心ぞやはらかき。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の間には塵も無し、あとに静かに映れかし、鸚哥の色の紅つばき。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女達鏡の間より裾引きてまどに寄るなり秋の夜の月　鏡の間はベルサイユ宮殿の一室の鏡で張りつめた間のことである。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れは鏡の間の方から隣の部屋へ今出て来た皆夜会服の裾を長く引いた貴女達で、其の人達はこの間の広い窓の傍へ寄り、秋の夜の月の明るい庭を眺めるのであつたと云つてある。",
              "citation": {
                "source": "註釈與謝野寛全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ふたりは、鏡の間に出て行きました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "この音もない移動、この移動を単なる運動とするのではなくして、「同一の自分」と「移る自分」とをつなぐ神秘な重々無尽の鏡の間として、見ることが意味をもってくるのである。",
              "citation": {
                "source": "「見ること」の意味",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、帽子を腕の下に、嗅煙草入れを片手に持ちながら、鏡の間をゆっくりと通って出口の方へ行った。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日中、ギラギラと光る二枚の鏡の間に居るような気持がいたしました。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は鏡の間である。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "公爵と師父ブラウンとが再び最前の細長い鏡の間に戻った頃には、水辺や岸の柳に早や黄昏の色が立罩めていた。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは門をはいって、洞窟の中のばかの隠者を見、有名な鏡の間の不思議な働きをためしに行った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、光圀その人は、まだ楽屋の鏡の間にも来ていなかった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで、楽屋の鏡の間の袖部屋か――うしろの用部屋において、ひかえておれ。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村金五郎のワキで羽衣を舞った老公のすがたが、あざやかに橋がかりから鏡の間へかくれ、つづいて囃子方、地謡が静かに退いたあとである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水を」　と、求めると、鏡の間のひかえから、佐々介三郎、つと寄って、盆を捧げた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の間のひかえにいる佐々介三郎は、いまに老公が呼ぶか、何か、命じるかと、じっと、それのみ待っていた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼をして、介三郎は静かに鏡の間の控えにすがたを消す。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお余裕のある旨を答えると、さらばと起ち上がって一同を顧み、「少々存ずる旨あれば、鏡の間より予が呼ぶまで、其方たちもここを出て随意に休息いたしておるように」　と、いった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい終るとすぐ光圀は隣の鏡の間へはいった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人々のひそかに思うには――おそらくこの切能の春日龍神の後ジテをもって、生涯の舞いおさめと期しているらしい老公は――心ゆくまでそれを果すため、舞台へかかる前のしばらくの時間を、独り鏡の間にあって、芸に対する丹心と工夫を凝らしていたいのではあるまいか――そう当然のように察していたのである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからよべ」　鏡の間から廊下へ通じるあいだにも、一段低い部屋がある。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍医の玄桐は、役目がらすぐ鏡の間へはいった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことをしたあげく、なんどもなんどもかがみのまえで、じぶんのすがたを見つめるのでした。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "hall of mirrors (at Versailles)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ベルサイユ宮殿の「鏡の間」は、その圧倒的な豪華絢爛さで訪れる観光客を魅了し続けている。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "第一次世界大戦を終結させたベルサイユ条約の調印式は、この鏡の間で執り行われた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "夕日が差し込む鏡の間では、窓から入る光が数多くの鏡に反射し、室内は黄金色の輝きに包まれる。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "かつて王族たちの祝宴や舞踏会が開かれた鏡の間は、フランス王政の栄華を象徴する場所である。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「鏡の間を埋め尽くすシャンデリアの輝きは、まさに言葉を失うほどの美しさだった」",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "鏡の間は、バロック様式の極致とも言われる内装が施されており、美術史的にも非常に重要な価値を持つ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "宮殿の大規模な修復作業を経て、鏡の間のクリスタルガラスは往時の輝きを取り戻した。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "鏡の間に並ぶ十七の窓と、それに対向する十七の鏡のアーチが、空間に無限の広がりを与えている。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
