[
  {
    "uuid": "5385cecb-6458-5a77-be21-2c8f78efc547",
    "entry": "鏡の間",
    "reading": {
      "primary": "かがみのま",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
