  {
    "uuid": "1f26d2db-bdfc-5601-847c-9c6f5ee0b5ea",
    "entry": "蚕",
    "reading": {
      "primary": "かいこ",
      "alternatives": [
        "カイコ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "silkworm (Bombyx mori)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五月雨や蚕わづらふ桑畑　暗澹とした空の下で、蚕が病んでいるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚕種検査の御役人が帰るのだなと合点がいった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の二階から毎日見下ろして御なじみの蚕種検査の先生達は舳の方の炊事場の横へ陣どって大将らしき鬚の白いのが法帖様のものを広げて一行と話している。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は蚕種検査の先生方の借り切り船へ御厄介になった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レールに近く養蚕広告のペンキ塗の看板が、鉛のような鉱物性の色をして、硬く平ったく烈しい日の光に向って立っていたが、汽車と擦れ違いさまに、仆れそうになって、辛くも踏み止まった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚕や蛇が外皮を脱ぎ捨てるのに相当するほど目立った外見上の変化はないにしても、もっと内部の器官や系統に行われている変化がやはり一種の律動的｜弛張をしないという証拠はよもやあるまいと思われる。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "形態的には蜂の子やまた蚕とも、それほどひどくちがって特別に先験的に憎むべく、いやしむべき素質を具備しているわけではないのである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻野には麻を蒔き、蚕時には桑子を飼う。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近在で春蚕のあがったのを買集めているところです」　有志の一人は説明した。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室の中は、青い天蚕絨を張った腰掛けが、まるでがら明きで、向ふの鼠いろのワニスを塗った壁には、真鍮の大きなぼたんが二つ光ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私たちは養蚕の用もありましたので急いで学校に帰りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日農場実習　午前八時半より正午まで　　除草、追肥　　　第一、七組　　蕪菁播種　　　　第三、四組　　甘藍中耕　　　　第五、六組　　養蚕実習　　　　第二組（午后イギリス海岸に於て第三｜紀偶蹄類の足跡標本を採収すべきにより希望者は参加すべし。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、秋蚕の時分だし、畑の仕事もある。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう男は選挙に際して、嬶や子供が饉えようが、蚕が桑の葉をなくして死のうが、そんなことはかまわずに、只で運動をして歩く。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "養蚕が輸入されそれがちょうどよく風土に適したために、後には絹布が輸出品になったのである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通な農作のほかに製茶製糸養蚕のごときものも、鉱業や近代的製造工業のごときものに比較すればやはり庭園的である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時大きなのがちょうど紅葉の葉を食っているところを見付けたが、頭をさしのべて高いところの葉を引き曲げ蚕が桑を食うと同じようにして片はしから貪り食うていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畠の、端々に、点々と一と株ずつ植えられた食わずの貝のような蚕豆の花が群がって咲きかけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室の中は、青い天蚕絨を張った腰掛けが、まるでがら明きで、向うの鼠いろのワニスを塗った壁には、真鍮の大きなぼたんが二つ光っているのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに続いた桑畑が、晩秋蚕もすんでしまったいま、もう霜に打たれるばかりの葉を残して日に照らされていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは山のなかの寒村で、村は百姓と木樵で、養蚕などもしていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此鉤に種々の餌を付けて置くので、其餌には蚯蚓や沙蚕も用いる、芋なども用いるが、其他に「ゴソッカイ」だの「エージンボー」だのという、陸にばかり居る人は名も知らないようなものがある。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも鏡が悪いために実際いくぶん顔色が白けて見えたには相違ないが、そう言われて後に鏡と絵と比べてみると画像のほうはたしかに色が薄くて透明に見えて、上簇期の蚕のような肌をしていた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "形態的にははちの子やまた蚕ともそれほどひどくちがって特別に先験的に憎むべく賤しむべき素質を具備しているわけではないのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日農場実習　午前八時半より正午まで　　除草、追肥　　　第一、七組　　蕪菁播種　　　　第三、四組　　甘藍中耕　　　　第五、六組　　養蚕実習　　　　第二組　（午后イギリス海岸に於て第三紀｜偶蹄類の足跡標本を採収すべきにより希望者は参加すべし。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてわが大東京はだらしなく無設計に横に広がって、美しい武蔵野をどこまでもと蚕食して行くのである。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近在で春蚕のあがったのを置集めているところです」　有志の一人は説明した。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、蚕種取締所設置の運動のことやなにか、いろいろ話し合いましたが、こころの中では誰もみんな、山男がほんとうにやって来るかどうかを、大へん心配していました。",
              "citation": {
                "source": "紫紺染について",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井伏氏のことだから、きつと私などの氣のつかぬ、こまかいこまかいことを發見して居られるにちがひない。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、男があんまり細かいことに気のつくのは偉くなれない性分じゃないのかい」「僕だって、根からこんな性分でもなさそうだが、自然と慣らされてしまったのだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
