        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "エスプレッソを二杯に固ゆで卵をいくつ？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソと固ゆで卵なのよ、いっつも。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "固ゆで卵にタイミングを合わせてエスプレッソを二杯作って、食べるわけ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも野菜やトーストを食べるんだけど、まず最初は、ほかのものは邪魔くさいからどかしておいて、エスプレッソと固ゆで卵を恵子さんは楽しむのよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソと固ゆで卵を食べ終ってしばらくしてから、野菜とパンを食べてる。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べるものはポテトチップスをひとつかみ添えた胡瓜のサンドイッチと、かたゆで卵だけだ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたゆで卵はエッグ・カップに入れて皿に載せ、小さなふたつの容器に塩とマヨネーズをそれぞれ入れ、エッグ・カップに添える。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
