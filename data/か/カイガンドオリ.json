        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は海岸通りの女理髪店で、彼女に断髪するように勧めてみました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "親爺はＫ市の海岸通りの船具屋である、その義弟の家へ出かけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "エナメルの靴を穿かせて、細い、黒いステッキを持たせて、神戸の山の手や海岸通りを歩かせてみた。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はいつものように海岸通りを、海を眺めたり船を眺めたりしながらつまらなく家に帰りました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊太利の繁華なる港といへば、此處は國中隨一の名港子ープルス、埠頭から海岸通りへかけて商館の數も幾百千、もしや濱島は此港で、其商會とやらを營んで居るのではあるまいかと思ひ浮んだので、實に雲を掴むやうな話だが、萬が一もと旅亭の主人を呼んで聽いて見ると、果然！",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、学校を出たばかりで恰度神戸へ遊びに行っていたんだけど、海岸通りの石道を昼間一人で何の気もなしに歩いていたの。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　海岸通りを、そろそろ歩いた。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金を貯めて、小鈴とやがて産れる子供と三人で地道に暮すつもりやと北田はいい、そして、高峰、お前も温泉場の料理屋へ板場にはいり、給金を貯めて、せめて海岸通りに焼鳥屋の屋台を張る位の甲斐性者になれと意見してくれた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬君は人通りの少ない海岸通りの方へ足を向けながら話しつづけた。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小舍を出てから、わざ／＼※り道をして、チャモロ家屋の多い海岸通りを歩いて歸つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居小舎を出てから、わざわざ廻り道をして、チャモロ家屋の多い海岸通りを歩いて帰った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで社長から海岸通りに大きな地面を貰っているんだが、結婚前に家を建てなくちゃならんし、自動車も買わなくちゃならねえてんで、中野さんが慌て出している。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は五六年前、××君が横浜にいる時、海岸通りの淋しい処から投身しようとしているのを助けたものであった。",
              "citation": {
                "source": "二通の書翰",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、海岸通りへ往ったらありますよ、ちょと往って来ます」「御飯は」「どこかで喫いましょう」「そう」　謙作は入口と思われる方へ往ってそこの扉を開けた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこか海岸通りの宜い旅館へ伴れて往け」　車は謙作を積んで走りだした。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっしは是非一度行って見たいと思っていたんですよ」　一昨年（安政六年）の六月二日に横浜の港が開かれると、すぐに海岸通り、北仲通り、本町通り、弁天通りが開かれる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクにでも乗つて、あてどもなく海岸通りなどをまはり、春霞みを衝いて出てゆく船を眺め、ゆつくりと支那料理屋にでも休んでから、夜はまたひとりでオデオン座の特等席になりとをさまつて、居眠りでもして来ようといふやうな、何とわたしには全く珍しい「好日」には違ひなかつたのである。",
              "citation": {
                "source": "好日の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "方角や歩数等から考えると、私が、汚れた孔雀のような恰好で散歩していた、先刻の海岸通りの裏｜辺りに当るように思えた。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの半分腐れかかって、倒れかかって、いろいろなガラクタと、白蟻と、ホコリで一パイになっている廃屋は、ちょうどあの海岸通りの四角にスックリと立っている、赤煉瓦の天主教会が校長先生のいろいろな美徳のホームでありましたように、ずっと以前から校長先生のいろいろな悪徳の巣になっているのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく海岸通りの方へ少し歩き出したとき、突然彼の名前が呼ばれ、彼の目の前に飛び出してきた女があった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇黒がＬＩＳＢＯＡの海岸通りを包むとき！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "主事の住いはと訊くと、『あの、海岸通りの家だ』と教えられた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこの海岸通りへ出た。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸通りに出ると、チッチッと舌を鳴らして行く船員の群が多かった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　海岸通りに出ると、チッチッと舌を鳴らして行く船員の群が多かった。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどこを通って行ったのか、よくわからないけど、何でもこのスウェツランスカヤから横路地伝いに公園の横へ出て、公使館の近くを抜けながら海岸通りへ出たようなの。",
              "citation": {
                "source": "支那米の袋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
