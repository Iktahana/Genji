[
  {
    "uuid": "6730f7b3-2075-5205-aa8b-02da5921d969",
    "entry": "格差",
    "reading": {
      "primary": "かくさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
