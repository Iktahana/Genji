          "literary": [
            {
              "text": "また掛け汁は、茱萸とやまももの実を煮詰めて、絞ったものだ、ということであった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ失敬、この掛け汁にむせちゃって」　彼は手拭で、口の端を拭き、わきを見ながらそう云った。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョウの骨折は、すべて失敗におわり、アスパラガスは、一時間もにてまだかたく、パンは黒くこげ、サラダのかけじるは食べられるしろものではなく、えびには手こずり、じゃがいもはなまにえ、白ジェリイはぶつぶつだらけでした。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
