        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "刺身などが出されたから、まごついて下をむいたまま黙々とたべ終り、漬物の醤油の余りを嘗めていると、叔母は、お前は今日から丸亀のぼんぼんやさかいそんなけちんぼな真似せいでもええといい、そして女中の方を向いてわざとらしい泪を泛べた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう梅雨ちかいそんな或日、突然殿があの祭の日からはじめてお見えになられた。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
