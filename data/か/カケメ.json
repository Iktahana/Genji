[
  {
    "uuid": "4b7e71e8-bc59-56d8-9d56-dbf6d4be34af",
    "entry": "掛け目",
    "reading": {
      "primary": "かけめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
