[
  {
    "uuid": "a5846638-657c-5a4b-b7cd-d2ecb0196bc6",
    "entry": "欠片",
    "reading": {
      "primary": "かけら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fragment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "震災の爪痕が残る海岸で、少年は波に洗われて角の取れた青磁の欠片をそっと拾い上げた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「あんなひどいことをしておきながら、彼には反省の欠片も見られない」と遺族は憤りをあらわにした。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "崩落現場にはコンクリートの欠片が鋭く尖った状態で散乱しており、不用意に近づくのは危険だ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "机の引き出しの奥から出てきた色褪せた写真の欠片が、かつての賑やかな家族の食卓を思い出させた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「このお皿、おばあちゃんの形見だったのに……」彼女は床に飛び散った磁器の欠片を、途方に暮れた様子で見つめていた。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "巨大な彗星から剥がれ落ちた氷や岩石の欠片が、流星群となって冬の夜空を彩った。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "計画が成功する見込みが欠片でもあるのなら、我々は全力を尽くしてその可能性に賭けるべきだ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なお半里も来て、下氷瀬というところになると、枯木と、石の欠片の沙漠地で、水は、細く、片寄せられて、流れている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "成程、羽織を着たものは、ものの欠片も見えぬ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悍しい、峻しい、冷たい、氷の欠片のような厳しい光の眼であった。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまの皿ア打挫いて、欠片にバタをつけて一口だい。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生芋の欠片さへ芋屋の小母さんが無代では見向きもしない時は、人間よりはまだ氣の知れない化ものゝ方に幾分か憑頼がある、姑獲女を知らずや、嬰兒を抱かされても力餅が慾しいのだし、ひだるさにのめりさうでも、金平式の武勇傳で、劍術は心得たから、糸七は、其處に小提灯の幽靈の怖れはなかつた。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一度顔を、と思うよって……」　丸官の握拳が、時に、瓦の欠片のごとく、群集を打ちのめして掻分ける。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷張る河のうへ、ぴしりうつ欠片、氷。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ月から剥がれた粉が雨のように降り注いでゆくさながら月の欠片でできた蝶の群れ地にあって天空に焦がれながらまたも降り落ちてゆき（けして想いの叶わぬものたち！",
              "citation": {
                "source": "ポオ異界詩集",
                "author": "エドガー・Ａ・ポオ　Edger A. Poe",
                "note": "青空文庫"
              }
            },
            {
              "text": "生芋の欠片さえ芋屋の小母さんが無代では見向きもしない時は、人間よりはまだ気の知れない化ものの方に幾分か憑頼がある、姑獲女を知らずや、嬰児を抱かされても力餅が慾しいのだし、ひだるさにのめりそうでも、金平式の武勇伝で、剣術は心得たから、糸七は、其処に小提灯の幽霊の怖れはなかった。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅費のつかい残りで、すぐに石油を買う体裁、なけなしの内金で、その夜は珍らしく肴を見せた、というのが、苦渋いなまり節、一欠片。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらのこしらえる贋金の地金は、貧乏徳利の欠片を細かに摺り潰して使うんだが、それがこの頃はだんだん上手になって、小さい南京玉をぶっ掻いて地金にするということを俺はかねて聴いている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒月子の図も成りければ、もとのところに帰り、この塚より土器の欠片など出したる事を耳にせざりしやと問えば、その様なることも聞きたるおぼえあり、なお氷雨塚はここより少しばかり南へ行きたる処の道の東側なる商家のうしろに二ツほどありという。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "血海の中に冷く光っているガラス瓶の欠片でつけたものであろう、顔から頭へかけて物凄い掻傷が煮凝のような血を吹き、わけても正視に堪えぬのは、前額から頭蓋へかけてバックリ開いた大穴から、なんと脳味噌が抜きとられて頭の中は空っぽだ。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬や春は川底に味噌漉のこわれや、バケツの捨てたのや、陶器の欠片などが汚なく殺風景に見えているのだが、このごろは水がいっぱいにみなぎり流れて、それに月の光や、橋のそばに店を出している氷屋の提灯の灯影がチラチラとうつる、流れる水の影が淡く暗く見える。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲一つない鋼鉄色の空には、鎗の穂よりも鋭い星が無数に燦いて、降つて来る光が、氷り果てた雪路の処々を、鏡の欠片を散らかした様に照して居た。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の家の天井に、斯うした油断のならぬ節穴があったことさえ、夢にも知らない事であったのに、その上、誰が持ち込んだものか、望遠鏡やら、活動写真の撮影機やら、吹矢やら、またパンの欠片や蜜柑の皮といった食物まで運ばれていた――など、何が何やら、彼にとって薩張り訳の判らないことであった。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皿を壁へ叩きつけてね、そのまた欠片をカスタネットの代りにしてね、指から血の出るのもかまわずにね、……」「カルメンのように踊ったのかい？",
              "citation": {
                "source": "カルメン",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを一瞬の間に、覆してしまうような、怖ろしい力が現われたとき、人は不可抗とだけで、悔いの欠片も残さずケロリと断念めてしまうものである。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の死には、人間の生理が一変してしまわないかぎり、どこにも、疑義の欠片さえ差し挟む余地がないのである。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには唯｜苔の生えた上に煉瓦や瓦の欠片などが幾つも散らかつてゐるだけだつた。",
              "citation": {
                "source": "或阿呆の一生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昼間｜階下の暗いのに飽いて二階へ上つて来て居る子供等が、紙片や玩具の欠片一つを落してあつても、「この穢いのが目に着かんか。",
              "citation": {
                "source": "遺書",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞樹だけでなくて沢山｜双生児の欠片が出来たと私は驚きます。",
              "citation": {
                "source": "遺書",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄の歴史研究家の中には、青磁の欠片が出たというだけで倭寇の遺跡だというのはおかしいという人もあるらしいが、そこで出て来る分量が問題になってくる。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしディヴィッドはそんな私の気分を読み取らず、想像力の欠片もない、それでいて完璧に合理的な質問へと進んだ：「カルヴァートは殺られたと思うか？",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、変わってしまった息子の振る舞いには、親子の愛情の欠片もなかったのだ。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "この建物が他人にも自分同様邪悪に見えると知って彼は興奮し、お巡りさん(*10)が繰り返した昔話の裏面にどんな真実の欠片があるのだろうかと思った。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういった散歩の中で、時折私は古代の石造建築のほとんど埋もれた欠片に足をつまずかせたものだった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の瞬間には、私は石の欠片に飛び上がりよじ上り、下方の深みへ向かった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡の集簇といつも犬のように彼につきまとう小型多面体とによってそこに連れて行かれたのだが、より遠くにあるこの究極の暗黒の虚空の中では、それらは彼自身と同様に霧の欠片に変容していた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前を何か別のものが進んでいった――より大型の欠片で、時々名状し難い形態めいたものに凝集する――そして彼は、自分たちの針路は直線ではなく、むしろ、あらゆる想定可能な宇宙の物理学や数学にとって未知の法則に従って動くエーテル渦流が形作る異様な曲線や螺旋に沿ってきているのだと考えた。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "ounce (of truth, conscience, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は自分の非を認めるどころか、反省の欠片も見せようとはしなかった。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "彼の語る大層な武勇伝には、真実の欠片も含まれていない。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「あいつには人の情けってものが、これっぽっちの欠片もありゃしないよ」",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "数十年ぶりに訪れた故郷には、当時の面影の欠片も残っていなかった。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "権力にしがみつく今の彼に、政治家としての矜持の欠片も感じられない。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "厳しい現実に直面し、抱いていた淡い期待の欠片も吹き飛んでしまった。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": []
        }
      }
