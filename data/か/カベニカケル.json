          "literary": [
            {
              "text": "」　お杉は参木の服を壁にかけると湯を沸した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "喇嘛教の曼陀羅、これは三尺に五尺位な切れで壁にかけるやうになつて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで用もなしに上服をとって外から見えないように壁にかけるとけろりとしていた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子絵の窓だの噴水だの薔薇の花だの、壁にかける氈だの、――そんな物は見た事もありますまい。",
              "citation": {
                "source": "長崎小品",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな真似をしながらも、私は若干の写生をすることが出来たが、その中の一つは、前から非常に写生したかった、壁にかける美しい板なのである。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
