    "definitions": [
      {
        "index": 1,
        "gloss": "brilliant achievement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
