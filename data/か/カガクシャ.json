[
  {
    "uuid": "c8abc614-0386-5f3d-813a-8c65aa7e4adf",
    "entry": "化学者",
    "reading": {
      "primary": "かがくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
