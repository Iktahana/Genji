        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕はおかあさんを起そうかとちょっと思いましたが、おかあさんが「お前さんお寝ぼけね、ここにちゃあんとあるじゃありませんか」といいながら、わけなく見付けだしでもなさると、少し耻しいと思って、起すのをやめて、かいまきの袖をまくり上げたり、枕の近所を探して見たりしたけれども、やっぱりありません。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあほんとうにあつい、　こんな『かいまき』をかけてちゃあゆだっちゃう。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『女中』にそう云って赤いうすい『かいまき』を出させて下さいな。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気がつけば、私は離れの十畳に寝ており、姉がかいまきをかけてくれている。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかいまきの袖から手を出して何かよんでいらっしゃるかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
