[
  {
    "uuid": "2041898d-4d57-5795-a84e-5151ad7d0773",
    "entry": "角丸",
    "reading": {
      "primary": "かどまる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
