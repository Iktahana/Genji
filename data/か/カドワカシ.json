        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸の町を震撼させている勾引しは、菓子で子供を誘い出し、人混みに紛れて忽然と姿を消すという。",
              "source": "幻辞"
            },
            {
              "text": "「知らない人についていってはだめだよ。勾引しに連れて行かれたら二度とお母さんに会えなくなるよ」と、母は幼い娘の手を強く握りしめた。",
              "source": "幻辞"
            },
            {
              "text": "奉行所の調べにより、男が借金の返済に窮して良家の令嬢を連れ去った、卑劣な勾引しであることが明らかになった。",
              "source": "幻辞"
            },
            {
              "text": "街道沿いの茶屋にいた旅人が、一瞬の隙を突かれて幼い連れ子を勾引しに攫われたという。",
              "source": "幻辞"
            },
            {
              "text": "犯人は身代金を目的とした組織的な勾引しの一味であり、入念な下調べの末に犯行に及んでいた。",
              "source": "幻辞"
            },
            {
              "text": "闇夜に紛れて獲物を探す勾引しの毒牙から逃れるため、村人たちは子供を一人で外出させることを固く禁じた。",
              "source": "幻辞"
            },
            {
              "text": "かつての日本では、人買いと結託した勾引しが貧しい村々を回り、幼い子供を攫っていく事件が頻発していたという。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "この四ヵ月近くの月日は、これ程までにわたくしを、少女の世界から大人の世界の女に勾引し去ったのでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日私は彼を勾引し、拒む彼を私の人力車に乗せて写真師のところへつれて行き、彼の最初にして唯一の写真をとらせた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "けど刑事かってそれぐらいなこと分ってますよって、その夫婦もん怪しいと睨んで勾引したんやそうですが、その時枕もとの乱れ籠に入れてあった光子さんと綿貫の着物着て、そのまま警察い連れて行かれた。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは一種のかどわかしで、身分のありそうな武士や女に化けて来て、容貌のいい娘をさらって行ったに相違ない、と半七は鑑定した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦かどわかされた娘をようよう連れ戻して来たところ、その悪者どもが付けて来て、再びかどわかして行ったのであろうということにすれば、こちらに油断の越度があったにもせよ、世間からは気の毒だと思われないこともない。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂町の伊豆屋の女房をかどわかして何処へやった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "この善兵衛というのは叔父と同じ年ごろで、表向きは堅気の商人のように見せかけながら、半分はごろつきのような男であったそうですから、女をかどわかしたりすることには馴れていたのかも知れません。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかしは重罪である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "金右衛門を斬って、娘のおさんをかどわかしたのは、下総屋の茂兵衛の仕業です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたりかどわかしたうえで、どこぞ遠いところの色里へでも売り飛ばしたのでござりましょうか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のうわさによれば右七百両、あまりよろしからざる金子とかにて、女衒のかたわら、おりおりいとけなき子ども等かどわかしそうろうてためあげたる不義の金子とか申す由にそうろう」「なにッ」　名人の眼がぴかりと光った。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかしは法網をくぐりながら、人を盗み、人をさらって売る暗い稼業です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女衒とても、もとより芳しい稼業ではないが、女の前身にかどわかしの暗い影があるというにいたっては、じつに聞きのがしがたいことでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "子どものかどわかし！",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかしという人の恨みを買うにじゅうぶんな陰があった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちこっち流して歩くうちに、かどわかしたおマキを見つけて、いちずの恨みにぎゅうとやりました、といったところがまずこのなぞの落ちだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかして売った金を取り返しにでも来るだろうと思い違えましたものか、ご亭主に小判の包みを埋めてこいとか隠してこいとか、しかりつけるようにいって表へ出しましたゆえ、様子をうかがっておふろへはいったところを見すまし、窓からふたり忍びこんで、わたしが首を、貞坊がお乳を押えて絞め殺したのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつが矢飛白をかどわかしたのだそうだ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかし、賭博、喧嘩、刃傷、すり、泥棒というようなことが、昼夜となく行なわれ、しかも法網をくぐっている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははアやったな、かどわかしを！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう面だ、かどわかしつらだ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「姫はどうした、君尾はどうした※」「文三と申す裏切り者、もったいなくもかどわかし！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人攫いめー　かどわかしめ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かどわかしてよいものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこいつがあべこべに、女が男をかどわかしているなら、飛び込んで行って助けるんだが、そうでないんだからおれは知らんよ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文三という悪党が、かどわかしたということだが、今の野郎が文三かもしれねえ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人の秘蔵っ子をかどわかして、その親をゆすって金を取るという手は往々ある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、佐吉らは乳母のお福と云い合わせて、玉太郎をかどわかしたものと認められる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者は他人を腐敗させはしないが、前者は他人を腐敗させ、その心をかどわかして真理の認識に対して無能力にするのである。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の馬を馬賊に売る約束をしたり、ジウラをかどわかして、人質にやらうとしたり、悪いことばかりをしてゐるな、こちらには一々分つとるぞ！",
              "citation": {
                "source": "ラマ塔の秘密",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
