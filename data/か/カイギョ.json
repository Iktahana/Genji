[
  {
    "uuid": "4ca9e40a-2194-53e2-8e24-a7dadeb4f180",
    "entry": "海魚",
    "reading": {
      "primary": "かいぎょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ocean fish",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "魚の中に於て、海魚は潮汐によつて其の氣が張弛するが、河魚は朝間詰夕間詰に於て著しく活溌になることは、老漁の看取して十二分に信じて居ることである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは海の遠い所ですが、鳥のおかげで、案外に海魚の新らしいのを拾うことが出来ると云うのは、何が仕合わせになるか判りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の中に於いて海魚は潮汐によってその気が張弛するが、川魚は朝間詰と夕間詰（日出前、日没後の明るい時間帯）に著しく活発になることは、老漁師の観察で十二分に信じられていることである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に遠いところであるから、生きた海魚などはなおさら少ない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お目に懸れるのは、骸骨に、腐った鉄材、それに深海魚ぐらいのところだろうよ」「いや、必ず持って来てやるよ、はははは」　談笑が、煙草の煙とアルコールの強い匂いで飽和したサロンの空気をかきまわす。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "索引を調べると、彼女の小伝は、ユダヤ教のラビと深海魚関連の論文を書いた海軍中佐の間に挟まれていた。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の郷里にて小鯛、鰺、鯔など海魚を用ゐるは海国の故なり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの御相談は、何もかも来月の十日｜過にお願いしますわ」　ハッと感激に打たれた江馬は深海魚のように眼を丸くして呉羽の顔を凝視した。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西國などは山國にて海魚に乏しく、山家の民は牛乳のみを以て滋養の食物と爲せり。",
              "citation": {
                "source": "肉食之説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまに見給え、あの三匹の深海魚は、きっと自分の胃腑を、僕の前へ吐き出しにくるに相違ないのだから」とそれから法水は、彼が演出しようとする心理劇が、いかに素晴らしいかを知らせるのだった。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "マスと同じやうで、斑点があつて、海魚の形をしてゐるから、釣つて美しい。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "イワナは他の海魚のやうに貪婪にぐいと来るし、ヤマメも鱚に似て少しく遅鈍な感覚である。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の鯉もその点ではなかなか手腕を要するが、然し自然の海魚には較べものにならない。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣堀は、鯉、鮒、或は海魚のもあるが、弊害は賭博釣りだ。",
              "citation": {
                "source": "日本の釣技",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてふつうの魚はいなくなって深海魚ばかりになります。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな深海魚は気味のわるい形をしたお魚です。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟泥を背景として、人骨がちらばっており、深海魚の燐光が気味わるく点いたり消えたりするところもとび越えて、底知れぬ岩の斜面にそっておりていく。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってこの町では、下へさがればさがるほど魚はないんですからね」「深海魚ならいるんだろう」「いえ、そこには第一水がなくて土と岩石ばかりです。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな深海魚だそうである。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が今立っているところは、昨日の夜までは、海水が満々とたたえられていたところで、深海魚どもの寝床であったんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄いろいような、赤味のついているような岩質で、黒ずんだ醜い深海魚とは、およそ反対の感じのものだった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは深海魚であった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年ぶりに海魚の刺身を食う、と片山さんが嘆息する。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣ってきた魚であれば、それが川魚であろうが海魚であろうが、これに越した活きのいい味の立派なご馳走はないのである。",
              "citation": {
                "source": "釣った魚の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにその下流の馬入川では、淡水魚と海魚が混じって釣れる。",
              "citation": {
                "source": "水の遍路",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から鯛を海魚の王者と言ったが、透き通るような肉の鮮味は、これに敵う魚が他にあるであろうか。",
              "citation": {
                "source": "葵原夫人の鯛釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "深刻な色彩と複雑な模様にいろどられた深海魚は銀座人種によく似ているし、フグに似た肥満型、イシダイに似た女将型、ハモやサヨリのような外人男女も泳いでいる。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸オコゼにも似た形をしてゐるが、カムルチ的のムツチリした仲々捨て難い味を持ち、川魚と言ふよりも寧ろ海魚の味である。",
              "citation": {
                "source": "異國さかな雜談",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
