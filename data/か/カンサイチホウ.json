[
  {
    "uuid": "e43533e2-b353-5bb3-8bcc-0fc649074e1e",
    "entry": "関西地方",
    "reading": {
      "primary": "かんさいちほう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
