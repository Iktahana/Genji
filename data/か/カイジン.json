[
  {
    "uuid": "3b7d6cfd-4ff6-5427-bec7-b335696a225a",
    "entry": "怪人",
    "reading": {
      "primary": "かいじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mysterious person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「オペラの怪人」という綽名を友人達から貰って、顔をしかめ、けれども内心まんざらでもないのでした。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木偶芝居　あの怪人物が手にもつ一つの巨大な棒を見よ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今この怪人物、ぬっと屋台店に這入り来り、やあ老人、やってるな、と叫び候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三味線松の近くには眼も鼻もない怪人があらわれることがあった。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "某日の黄昏隣村から帰っていた村の女の一人は、眼も鼻もない怪人のことが気になるのでこわごわ歩いていると、前を一人の女が往っている。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実や、文化よりして、慶応の頃まで生存した、加賀｜大野港に一代の怪人、工匠にして科学者であった。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、おそるべき怪技を有する怪人でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "覆面の小がらなそれなる怪人は、岸へ泳ぎつくと、ぐっしょりぬれた着物からぽたぽたと水玉をおとしながら、まるで何かの物の化につかれてでもいるかのごとく、ひょうひょうふらふらと歩きだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門の大喝一声とともに、ふわりふわりと風に乗ってでもいたかのように歩みつづけていた怪人が、いきなりそこにばたりと倒れてしまいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、妖怪変化にでも化かされているようじゃねえか」　けげんな顔をしながら舟龕燈をさしつけて、じっとうち倒れている怪人の姿を見調べていましたが、とっぜん意外なことをでも発見したかのごとく、おどろいて叫びました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一方その怪人物は、解けた綱を手繰り上げると、友田看守の腹の上に坐った岩片のほうも解いて、階段から降りると物音に驚いて登って来る人に見られるから、ランプ室の外のデッキの手すりへおなじように綱をひっとき結びにして、それをつたって下の高い岩の上へ降りる。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみませんが、ちょっとあなたのてのひらを見せて下さい」　――ああ東屋氏は、てのひらの胼胝で怪人物を突き止めるつもりだ。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして窓が明放されて、その外の雪の上に、確かに片手に子供を抱えて行ったらしい片杖のスキーの跡がある――と、ここまで観察されるうちに、もうあなたは、その窓から子供を奪った怪人が逃げ出して行った、と云うように推理されてしまったでしょう。",
              "citation": {
                "source": "寒の夜晴れ",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士もまた既に怪人団のために搬び去られたものとばかり思っていた水戸は非常に意外にも感じ、そして大きな拾い物をしたことを悦んだ、だが博士はぐったりしている。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "“アメリカが誇りとするワーナー博士とその調査団一行十名が、近来頻発する大西洋海底地震の調査のために昨日来大西洋の海底に下りて観測中であったが、博士一行は図らずも同海底に国籍不明の怪人集団と、それが拠れる海底構築物を発見した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に、その怪人集団は吾人の想像に絶する巨大なる力を有するものの如く、而もその性情は頗る危険なるものの如くである。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにだ、もし博士一行が海底で全部死んだものなら、海底に怪人集団を発見したことを報告できやしないよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "“――既報の大西洋海底に蟠居する怪人集団は、従来地球上にその存在を確認されたことのない高等生物の集団だと認むべき理由が発見された。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下のところ彼等怪人集団の勢力は大したものではないが、われら世界各国民は一致協力して、直ちに大警戒を始めねばならない。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはいわずとしれた、大西洋海底の怪人集団に対するわが全世界の態度と処置を議するためのものだった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは怪人集団に対する全世界の歩調一致はすぐさま可決されたのであるが、それでは如何にこれを処置すべきかという問題については一向信頼するに足る具体的方法が発見されないためだったといえる。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、果して大西洋海底の怪人集団が、現代の最強武器である原子爆弾によって完全に壊滅するものであろうかという危惧、それからもう一つ、たとえ現在蟠居する彼等を殲滅し得たとするも、彼等の後続部隊が後になって大挙襲来するのではなかろうか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大西洋海底におけるワーナー博士一行の遭難事件、それによって明らかにされた戦慄すべき怪人集団の暴行。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪人集団の一件だろう」　船長はにやにや笑った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「解釈は君の勝手さ」「――その地点は……」「間違いなく例の海域だった」「機雷攻撃ぐらいで、あの怪人集団が参るでしょうか」「機雷じゃないと思うね。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしやあの怪人……」「そうらしいんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らにも最初のうちはよく分らなかったけれど、船長や一等運転士などといろいろ意見を交換し合った結果、これは例の怪人集団の写真だという推定に落付いたんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのボイラーみたいなものは、怪人たちが立籠っている城塞なんだろうよ」「なにッ、あれが怪人集団の城塞だって。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは例の怪人集団の城塞と思われる円筒型の構築物が、さっきの場合よりずっと上方から俯瞰した状態でうつっていた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、どんなにんげんにでも、どんなどうぶつにでもばけることのできるせかい一のめいじんだよ」「それじゃ、おじさんは、かいじん二十めんそうだな」「うふふふ……、そのとおりだ。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
