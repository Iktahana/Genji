    "definitions": [
      {
        "index": 1,
        "gloss": "meeting place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに月光がさして忽然と清談の会席が眼前に現われる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧寒な拓本職人の家で、女餓鬼の官女のような母を相手にみじめな暮しをするより、若い女のいる派手で賑かな会席を渡り歩るいてる方がその日その日を面白く糊塗できて気持よかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私は眼の前の会席膳の食品の鮮やかさに強て念頭を拭った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の料理も、本式の会席膳で鯛なども附いていた。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸処から取集めた百有余円を、馴染の会席へ支払いの用があって、夜、モオニングを着て、さて電燈の明い電車に乗った。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "訣れに池上は昼、霞ヶ関の茶寮で会席料理を御馳走して呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "訣れに池上は昼、霞ヶ関茶寮で会席料理を御馳走して呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都亭の主人から、大阪の会席料理屋で修行し、浅草の寿司屋にも暫くいたそうだが、うちは御覧の通り腰掛け店で会席など改った料理はやらず、今のところ季節柄河豚料理一点張りだが、河豚は知ってるのかと訊かれると、順平は、知りまへんとはどうしても口に出なかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少くとも私たちは何一つ与えられないで、公会堂の歓迎会席場へなだれ込むより外なかったのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してこの『おかる勘平』が同年の暮、日比谷の松本楼で開かれた“PAN”大会席上に於て、私自身に依て朗読せられ、その翌年同詩所載の『屋上庭園』第二号が風俗壊乱としてその筋より発売頒布を禁ぜられたといふ事実が、之をして愈意義あらしめ、私達をして益亢奮せしめたものである。",
              "citation": {
                "source": "雪と花火余言",
                "author": "東京景物詩改題に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "都亭の主人から、大阪の会席料理屋で修業し、浅草の寿司屋にも暫くいたそうだが、家は御覧の通り腰掛け店で会席など改った料理はやらず、今のところ季節柄河豚料理一点張りだが、河豚は知ってるのかと訊かれると、順平は、知りまへんとはどうしても口に出なかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを佩ると、心落ちつき食慾が進むとて会席の客がその冠を戴いた。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａ氏は一｜度Ｒ国へ行く友人の送別会席上で見知りになつたＲ国人であつたので、私はいさゝか心強く感じて、導かるゝまゝに奥へ通つた。",
              "citation": {
                "source": "微笑の渦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは屹度今夜の会席で吾々に踊らせようとするダンスで、見習へ！",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が命じたのか彼は知らなかつたが、父の会席膳も用意されて来た。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには広い宴会席が二階にあって、下は漫々とした水のまわりに、様式に変化をもった小窓が幾箇もあった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "箸と猪口の載った会席膳が、じきに二人の前におかれて、気づまりなほど行儀のいい女が、酒のお酌をした。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は会席料理のもてなしを受くる約あり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は始めての会席料理なれば七十五日の長生すべしとて心覚のため書きつけ置く。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃ち　　題釜氷解けて水の流るゝ音すなり　　　　　子規（三月二日）　料理人帰り去りし後に聞けば会席料理のたましひは味噌汁にある由、味噌汁の善悪にてその日の料理の優劣は定まるといへば我らの毎朝吸ふ味噌汁とは雲泥の差あることいふまでもなし。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、茶の会席料理は皆食ひ尽すやうに拵へた者で、その代り分量が極少くしてある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月三十一日）八十一○食物につきて数件一、茶の会席料理は普通の料理屋の料理と違ひ変化多き者ならんと思へり。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒に物の多きを貪りて意匠なきは会席の本意に非ず。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに筍の料理、これ一色でも会席は出来ることで、何も目黒くんだりまでゆかずともではあるが、ここの土に育ったが最良とせらるるその本場へ、態々歩を運ぶという気分、人はこの気分に生きたいものだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
