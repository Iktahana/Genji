        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「賢太郎は、そりやアもう好く働くわよ、これ、あらかたひとりで……」　周子は、さう云つて、だらしなくからげて転がつてゐる夜具の包みなどを指差した。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "思へばあの後つきは、帶の結びかたひとつで色氣をもたせてゐたといつてもよいほどであつた。",
              "citation": {
                "source": "夏の女",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "○山本宣治氏刺殺された事件、今日『国民』を見ると、記事のとり扱いかたひどく用心して、センセーションをおこさぬようおこさぬようとしてある。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れを非人・かたひ・ゑたなど、人まじろひもせぬ同じ様のものなれば、紛らかして非人の名を穢多に付けたるなり。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「レイテって、どんなところだ」「そうだな、台湾の山奥のようなところだと思えばいいよ」「山奥へ入ってだな、一人でまァ三年なり五年なりやっていけるか、ということだが」「それァやりかたひとつよ。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、小萩は、落ちつきはらつて、「だつて、あたしが自由になるか、ならないかは、長久保の出かたひとつなんですもの。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの草屋根の葺きかたは、中世からこのかたひじょうに進歩した。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
