    "definitions": [
      {
        "index": 1,
        "gloss": "irreplaceable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "俺がこうした莫迦げた事柄への貪婪を以て（しかも哲学者的な冷徹な思索を欠いて）生れて来ているということこそ、唯一のかけがえの無い所与なのだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしにはどうしてもあきらめられない、十七のとしまで大事に育てた、かけがえの無いひとり娘を、おそろしい蛇の人身御供にするのを黙ってあきらめていられるお前さんは、ほんとうに羨ましい。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで見ても彼がその頃学者として他にかけがえの無い人であり、どれほど重きを置かれていたかがわかるわけです。",
              "citation": {
                "source": "ラヴォアジエ",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にとって、それは、かけがえの無い唯一の、したがって貴重なものであった。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は到頭、麻雀に、かけがえのない命までを賭けてしまったのです……　宿にかえってから、それでも矢張り何となく胡の云った言葉が気にかかっていたと見えて、扉に鍵を下ろして窓をすっかり閉めてから、さて、密かにその牌をあらためて眺めました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（いいえ、技師の先生の方ですが、その方のお大事なものが残らず、お国でおかくれになりました奥様のお骨も、たったお一人ッ子の、かけがえのない坊ちゃまのお骨も、この中に入っていらっしゃるんですって。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに専門の書き手以外でも、日々の行き暮れを機として織り上げたかけがえのない思いを、できることならば本に残したいと願う人は多いはずだ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけがえのない大きな幸福を、棒に振ってしまわなければならなくなった。",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "富山県の文化人諸君に会って土地の文化状勢を聞くことの出来たのは、かけがえのない利益であった。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍部と政党とに相当の信頼があるということ、所謂国内相剋の緩和者としてかけがえのない人物であること、等々であるらしい。",
              "citation": {
                "source": "近衛内閣の常識性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの一歩は、われわれの一生にとってかけがえのない一歩である。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、わたしたちの貴重な、そして誰にとってもかけがえのない一生を気分や現象で、はぐらかされ、かどわかされてしまわないようにという決心である。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「田中君とは僕はかけがえのない親友なんですよ」　だが大村は云うだけ云ったというような調子で、くるりと田中や角井の方へ向き直って云った。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが大内は、うらやましいほどの士気の高まりを見せる渡辺たちの勢いをかけがえのない宝と思えばこそ、どこまで育つか定かではないパーソナルコンピューターと彼らを心中させる危険は避けたかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "前橋高校に籍を置いて過ごした一五歳からの数年は、松本吉彦にとって、万華鏡の空に向かって一つ一つ窓を開いていくようなかけがえのない時期だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気半導体事業グループの渡辺和也のチームは、西とマイクロソフトにとってかけがえのない育ての親だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初子に続くかけがえのない発展の原動力の芽生えを福良に感じとった浮川は、ジャストシステムの成長のシナリオを描くことで、貴重な人材を確保しようと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツと西のあいだには、もっとも野心的なビジョンを共有できるかけがえのないパートナーとしての信頼があった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "諺にも、「賢妻は家の鍵なり」というが、どうして、うちの内儀さんときては大切な金庫のかけがえのない錠前だわい、と猪之さんには内儀さんを誇りにする気もちがある。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "森源にとっては、実子にも増す、かけがえのないルミが、路傍の人であった私の為に、科学の常識を無視して、彼を棄ててしまったのである。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけがえのないひとりむすこですし、それに、ずいぶんのんきで、ずぼらで、なまけものでしたが、ほんとうは気だてのやさしい子でしたから、母親は、あけてもくれても、ジャック、ジャックといって、それこそ目の中にでも入れてしまいたいくらいにかわいがって、なんにもしごとはさせず、ただ遊ばせておきました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折はすでに愛情は冷却して、そのくせ女の方は、あまり高価な、かけがえのない犠牲を払って来た若き日の、あの尊とかりし我熱情の、徒らに消耗された事を思い嘆くあまりの、焦燥から来た我執とみなければなるまい。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もいま、師匠のかけがえのない好い芸を、心の中で惜んでいたのに、このお爺さんは見世ものの中へ出すのか――と思ったからだ。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こうした夜、こうして閑であることは、ああ何というかけがえのない恵みであろう！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "意外にも、それは、こないだ、蔵前八幡の境内で邂逅した、雪之丞に取っては、かけがえのない文学の師、孤軒先生にまぎれもなかったのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "館の殿と云うのは二十の声をおととしきいたばかりの若人、ともにすむ母君と弟君、二人ながらこの世の中に又とかけがえのない大切な一人きりの方達で有る。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことがあれば、小屋がこわれるばかりではなく、おおぜいの観客が怪我をするであろうし、かけがえのないすぐれた芸をもっている団員もまたたおれてしまうであろう。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "）地上に二人とかけがえのない大人物を今迄すつかり忘れきつてゐたのではないか！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回目の金策は当然この人物へ行くべきもので他の何人へ廻ることも不可解であり、然して見給へ、第二回目と出向く必要はないところの、地上に一人のかけがえのない人物ではないか！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけがえのない人物は全くもつて意気好みの万事が派手で綺麗な男だ。",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
