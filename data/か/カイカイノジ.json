        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、ちょうど発起人を代表して、当夜の人気だった一俳優が開会の辞を陳べ終った処であった。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の開会の辞も下手、れいの有名人の演説も何が何やら、わけがわからぬ、とその所謂父の「同志たち」が怒声に似た口調で言っているのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の大会は博士の報告演説だけで独占されることになっていたので、司会者の開会の辞がおわると、村木博士が割れるような拍手を浴びて登壇した。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「開会の辞」で武田が出た。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "編者の微意は本文中の「開会の辞」に悉されているから、ここに重ねて言わない。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "凡例",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織委員長レーワルト氏の式辞の後、ヒットラー総統の開会の辞がすむと、突然号砲が鳴り渡る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、所管署築地警察署では、「働く婦人の夕べ」の集会届けも余興の興行届けもちゃんと手続を経て受けつけ、許可しておきながら、いよいよその日になって開会の辞を中條百合子が一分ばかり話したら、中止！",
              "citation": {
                "source": "日本プロレタリア文化連盟『働く婦人』を守れ！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えて四月に至り、第二回講演会を本郷区仏教青年会館に開催したが、長谷川の開会の辞半ばにして突如臨監の警官から解散を命じられたことは吾々主催者として最も意外とするところであった。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機がすむと、伊津野氏の開会の辞があった。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹事が立つて、一言開会の辞を述べる。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹事が立って、一言開会の辞を述べる。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラリサ・レイスネルの夫だったラスコーリニコフ開会の辞。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジヨン・ガブリエル・ボルクマン」開演の当夜、開幕に先だつて開会の辞を述べるべく舞台に現れた小山内氏は、実にさう云ふ青年であつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "定刻ともなれば、古きフロック・コートに赤白青の村長綬章を襷掛けにした村長が、開会の辞をかねて一席弁じたが、その演説の要旨こそは、さすがのクレマンソーも靴下一枚で一目散の代物、書かでも御想像を願いたい。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "八人の小悪魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、テーブルの端で埃でも払うような手付をすると、低い声で、「今晩は――」と開会の辞めいた挨拶をしはじめた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後一時をややすぎて、まず栗原彦三郎が拍手の裡に立って開会の辞をのべた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は故人の安達正太郎君という雄弁会の幹事が出て、開会の辞をやり、次いで私が決議文をよんで、さてこれから私が演説を始めるという時に、黒マントを被った、柔道部、相撲部の連中が殴り込んで来た。",
              "citation": {
                "source": "まあまあ居士の弁",
                "author": "私の歩いてきた道",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長新原重志の開会の辞につづいて、小笠原郡守の祝辞、霧社警察分署主任警部佐塚愛祐の訓辞が滞りなく終った。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "立花君が開会の辞を述べて、「これから指名しますから、当った人は成るべく詳しく自己紹介を願います。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
