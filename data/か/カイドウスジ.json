    "definitions": [
      {
        "index": 1,
        "gloss": "highway route (Edo period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
