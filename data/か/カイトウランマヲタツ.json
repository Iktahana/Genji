    "definitions": [
      {
        "index": 1,
        "gloss": "to cut the Gordian knot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
