    "definitions": [
      {
        "index": 1,
        "gloss": "developer (of software, video games, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
