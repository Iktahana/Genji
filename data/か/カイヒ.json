[
  {
    "uuid": "cf8428db-b167-556d-a5a9-6fd77003c931",
    "entry": "会費",
    "reading": {
      "primary": "かいひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
