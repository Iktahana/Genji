      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "membership fee",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "会費は年末賞与の三プロセント、但し賞与なかりし者は金弐円也とあった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は会費は一円か二円で済んだという。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "会費について二三照会せられた方がありますから、ざっくばらんにここへ書き添えて置きます。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰る時には、たしかな学友を選んでその者に、充分の会費を手渡す事を忘れるな。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三両の会費であったら、五両。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五両の会費であったら十両、置いてさっと引き上げるのが、いい男です。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで会費をとられるんじゃないか、と心配しながら飲んで損をした。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな隙潰しをしないでも、交際会の会費なら、その場で請取って直ぐに払いを済したら好さそうなものだが、一先ず手許へ引取って、更めて夫子自身を労するのは？",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、会費を衣兜にして、電車に乗ったのは事実である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは会社に出勤、忘年会とか、いちいち社員から会費を集めている。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三十銭の会費を出し渋ったり、役不足を云ったり、稽古を厭がったりする者があると、帰って来てからプンプン憤って、「老先生に済まん済まん」と涙を流していたという。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、自流の名を冠した会を起し、会費を取り、いろいろの催しや、刊行物なぞを出しているのもある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おきまりの会費で存分愉しむ肚の不粋な客を相手に、息のつく間もないほど弾かされ歌わされ、浪花節の三味から声色の合の手まで勤めてくたくたになっているところを、安来節を踊らされた。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと年会費六千円で使い放題と格安の上に、容量がかなり制限されるとはいえ、今度は自分の情報が発信できます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と彼は呟いた、会費僅か六十銭で酒が出て、とにかく板のやうではあつたが肉の揚げたものが一皿ついた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒好き党は、結局禁酒党の会費の分にまで割込んだかたちで一本乃至一本半の酒がのめた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番片岡君の為め祝宴を開いて万歳を称へやう、」と伊勢武熊は傲然として命令するやうに、「そこで会場は横町の牛店として駿河君は実業家ぢやから会費の半分を負担し、亀井君は懸賞小説が当選るさうぢやから登用人材の片岡君と共に残る半額を負担すべし。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "七円と云う高い会費が、今日の聴衆を、可なり貴族的に制限していた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い会費を取るんだろう」「まあ二円ぐらいだろう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに会費なんか、心配しなくってもいい。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは今夜の会費もそのうちから出ている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、会費のようなものも、甲乙丙の三種で、師匠分の人は甲、独立している程度の所は乙、まだ年季中の者で、弟子連中は丙というように公平に取り扱い、会の維持法等については、合理的に能く相談を致し、また会頭、幹事並びに理事部長の任期何年という事を討究の末ほぼ決定しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、会費三百円ね」　と、山崎がかっぱえびせんの袋を芝にトスした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "会費なんかその時次第だがイクラもかからない。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "会費はイクラだい」「たしか十円と思いましたが……」「高価えなあ」「オホホ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "会費の十円の意味も読めるし、幹事の白鷹君の隅に置けない手腕のほども窺われる。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのお話というのは大抵、校友会費に関係した事ばかりで、お二人でその誤魔化し方を熱心に研究なさるのでした。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから校長先生が、校友会費を流用して、川村さんの弟さんの名前でゲンブツという相場をなすって、お金を儲けて、傴僂の川村さんと山分けにしていられるようなお話も聞きました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "▽会費　一ヶ月金三円（毎月三回会合）。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人前五十銭の会費に、有志からの寄付が五六円あった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
