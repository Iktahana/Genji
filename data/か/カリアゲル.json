    "definitions": [
      {
        "index": 1,
        "gloss": "to harvest all of (a crop)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一年に一度刈り上げる國土に來ても、固定した信仰行事の上では、二秋の舊郷土の俤を殘したものらしい。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "分らないと吉川が答えると、では月に千円ばかりあげることにしよう、足りなかったらまた言って下さい、と母がきめてしまったとか。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これを、すっかりあげるから、役にたてて下さいよ。",
              "citation": {
                "source": "死の前後",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め、週に一回ずつ隆吉の学課をみてやることになった時、謝礼は月に十円ばかりあげる、というのが横田の言葉だった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして可愛がってばかりあげる」　一角は、ふいに、傘の下を、脱け出した。",
              "citation": {
                "source": "無宿人国記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
