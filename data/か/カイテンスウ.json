    "definitions": [
      {
        "index": 1,
        "gloss": "number of revolutions (i.e. as an engine speed)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
