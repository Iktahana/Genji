          "literary": [
            {
              "text": "すでに戒法なし、いづれの戒を破るによりてか、しかも破戒あらんや。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を助ける出家の身が、鰻掻きをして殺生戒を破るさえ無茶苦茶なのに、彼岸に達する救世の船。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "丑松に言はせると、自分は決して一生の戒を破るのでは無い。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの銃声も火事もみんな我々の警戒を破るためだったのです。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            }
