[
  {
    "uuid": "550366b7-a891-5e25-b4fb-e5e86ad45ba1",
    "entry": "快楽",
    "reading": {
      "primary": "かいらく",
      "alternatives": [
        "けらく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pleasure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども俺は快楽主義者だ。",
              "citation": {
                "source": "〔蒼冷と純黒〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "予の家庭は寧ろ平和の坦道を通過して来たのであるが、予は自らの家庭を毫も幸福なりしとは信じない、悲惨と云う程の事もなかった代り、尋常以上の快楽もなかった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達の祖先が献身的であったころ、アルチバセフの快楽主義にさえ身顫いしたロシア婦人は欧羅巴スタイルの淫事も、寝床で踊る未来派の怪奇も、断髪にする苦痛さえもなし、公爵婦人の名誉さえ瞬間に地に葬ったのです。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋々々の壁の伝説のニデイアの像のかけられた下を快楽のために奴隷にされたフィリッピン人の拳闘家が、床下を犬のように這いながらときどき兇暴なうなり声を出した。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶卓のクロース皮膚の汚点をつけて、無上の快楽については妥協政治で解決する弾力のある男女がおか惚同士のように話しつづけた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――あら、快楽のためにはフォードだってかまわない、山間を疾駆するじゃありませんか。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　街に展いた窓の出張に置かれた洋紅色の花鉢を寝台の枕もとに持ってくると、夜の女は眸の快楽のために、「――その女房と云うのはどんな役目なの？",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間は、快楽の結果として恋愛病に罹る。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　午後五時すぎに田村英介氏の部屋の卓上電話が、ジャバの女の快楽のときの悲鳴に似たときのこえをあげる。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の生命も分らないということが常に心にあって、今日のうちに出来るだけ快楽をむさぼっておかないと損だ、というような気持になるのだ。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、なおもう一ツ、こういう際どい芸当は、彼には、むしろ快楽となる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "快活らしい元気な表情の中には、ただ、ゼーヤから拾ってきた砂金を掴み取り、肌の白い豊満な肉体を持っているバルシニヤを快楽する、そのことばかりでいっぱいだった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから涯しのない快楽を私は抽き出すことが出来る。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ寐られない晩にしても吉田の心にはもうなにかの快楽を求めるような気持の感じられるような晩もあった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に、生物がはげしい衝撃を受けると肉体と精神との結合が破れて後者が前者の孔から逃げ出すというような考えから、苦痛や快楽の物質的説明を試み、「笑いの元子」などというものはないと言ったりしている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "去勢されたような男にでもなれば僕は始めて一切の感覚的快楽をさけて、闘争への財政的扶助に専心できるのだ、と考えて、三日ばかり続けてＰ市の病院に通い、その伝染病舎の傍の泥溝の水を掬って飲んだものだそうだ。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "快楽とか苦痛とか名の付くようなものでなく、何んだか分らぬ目的物を遠い霞の奥に望んで、それをつかまえよう／＼としていた。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来快楽を目的とする音楽でさえもドイツ人の手にかかるとそれが高等数学の数式の行列のようなものになり、目を喜ばすべき映画でさえもこの国でできたものは見ていておのずから頭痛のして来るようなのがはなはだ多い。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴が清水の土地を思い切り、美濃の檜木の瑞雲寺へ入って馬翁という詩僧に従ったのは、勿論、娘と得体の判らぬ心理の関係にある、その境地から逃れよう為もあったが、僧でもなく俗でもない身持で、風雅に対してだけ快楽を求める生活が、俄に不安を増して来たからだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この快楽を菜食ならば著しく減ずると思う。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚々々皺をのばして、胴巻きにしまっているものを、見す／＼あっという間の快楽のために失ってなるものか。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "危険はドリアンにとってはむしろ快楽であった。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに、女は、男よりも快楽をよけいに頬張る事が出来るようです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ「心には悩みわずらう」事の多いゆえに、「おもてには快楽」をよそわざるを得ない、とでも言おうか。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、苦悩がないということは、常にその一面において、快楽がないということと相殺する。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いて何よりも悲しいことは、かつて青年時代に得られなかった、充分の自由と物質とを所有しながら、肉体の衰弱から、情慾の強烈な快楽に飽満できないという寂しさである。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気は、丁度さういふ寡欲さで、人をエピクロス的の快楽主義者にする。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈もそれの境地に安住すれば快楽であり、却つて詩興の原因でさへあるといふことを、私は子規によつて考へさせられた。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
