[
  {
    "uuid": "42048846-1d1a-570e-b65c-05f17b8200f0",
    "entry": "会葬者",
    "reading": {
      "primary": "かいそうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "attendants at a funeral",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故人の生前の幅広い交友関係を物語るように、式場の外まで溢れんばかりの会葬者が詰めかけた。",
              "source": "幻辞"
            },
            {
              "text": "受付では、混雑を緩和するために会葬者名簿への記入をスムーズに行えるよう、複数の記帳台が用意されていた。",
              "source": "幻辞"
            },
            {
              "text": "喪主は悲しみをこらえながら、参列した会葬者一人ひとりに丁寧な挨拶を述べ、故人との最後のお別れを共にした。",
              "source": "幻辞"
            },
            {
              "text": "著名な実業家の葬儀には政財界から多くの会葬者が訪れ、会場周辺は朝から物々しい警備体制が敷かれた。",
              "source": "幻辞"
            },
            {
              "text": "突然の訃報にもかかわらず、遠方からも多くの会葬者が駆けつけ、祭壇に飾られた故人の遺影を前に遺徳をしのんだ。",
              "source": "幻辞"
            },
            {
              "text": "会葬者に手渡される会葬御礼の封筒には、遺族からの心からの感謝の言葉を綴ったハガキが添えられていた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "子規の葬式の日、田端の寺の門前に立って会葬者を見送っていた人々の中に、ひどく憔悴したような虚子の顔を見出したことも、思い出すことの一つである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ人を目当てにしたものか、遺族ないしは会葬者に対して読まれるものだろうか、それとも死者に呼びかける形式で会葬者に話しかけるものだろうか。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者が思い思いに退散するうちに、半七はわざと後れて座を起った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は母を見ても妹を見ても、普通の会葬者を見るのと何の変もなかった。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者は、座敷にも椽にも並み余り、本堂の周囲の土に立っている。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは会葬者中の親族席を見廻す。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門は正座に据つて自分のこの土地に於ける勢力を象徴するものゝやうに、本堂もひしめくばかり集つた大勢の会葬者の群を見廻した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、死んでも銅像や記念碑、爵位勲等、生花、放鳥又は坊主の頭数、会葬者の人数、死亡広告の大きさやお墓の高さなぞに取り付いて行こうとするのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上塩町に三十年住んで顔が広かったからかなり多かった会葬者に市電のパスを山菓子に出し、香奠返しの義理も済ませて、なお二百円ばかり残った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時の会葬者の中には前のＳ氏の顔も見えた。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者に踏み荒された庭の土があり／＼と思出されるやうな気がする。",
              "citation": {
                "source": "蓑田先生",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは乱心の縊死ということになっているので、世間の手前、あまり華やかな葬式を営むことを遠慮したのであるが、それでも会葬者はなかなかに多かった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大津屋の重兵衛も会葬者の一人に加わっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも芸人であるだけに、相当の会葬者がその時刻の前から店先へあつまっていると、大きい霰がその頭の上にはらはらと降った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋作の寺は小梅の奥で、半七も会葬者と一緒にそこまで送ってゆくと、寺の門内には笠を深くした一人の若い侍が忍びやかにたたずんでいて、この葬列の到着するのを待ち受けているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会葬者のうちに延津弥との関係を知っている者があって、中田屋の大将が死んでは師匠も困るだろう、お前さんがその後釜を引受けてはどうだなどと、冗談まじりに話していたのが、ふと町方の耳にはいった。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "店先にあつまる会葬者の群れの中に、手先の一人もとうから入り込んでいて、千生はすぐに引っ立てられて行った。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の不幸な夭折が、特に多くの会葬者を、惹き付けているらしかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "千に近い会葬者が、集まろうとも、青年の臨終に侍したのは、自分一人ではないか。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそうした感激に耽りながら、じっと会葬者の群を眺めていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊柩が式場の正面に安置せられると、会葬者も銘々に、式場へ雪崩れ入った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者達は、銘々慎しみの心を、表に現わして紫や緋の衣を着た老僧達の、居並ぶ祭壇を一斉に注視しているのであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、会葬者の殆ど過半が、此無遠慮な闖入者に対して叱責に近い注視を投げたのである。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者の注視を引いた事などには、何の恐れ気もないように、翼を拡げた白｜孔雀のような、け高さと上品さとで、その踏段から地上へと、スックと降り立ったのは、まだうら若い一個の女性だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "会葬者達は、場所柄の許す範囲で、銘々熱心な眼で、此の美しい無遠慮な遅参者の姿を追った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
