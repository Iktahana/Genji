    "definitions": [
      {
        "index": 1,
        "gloss": "tenpai with all potential winning tiles visible on table (impossible to win)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
