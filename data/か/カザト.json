          "literary": [
            {
              "text": "一七　富土、風戸　昔の人の感情は驚くべく粗大であった。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "発戸・風戸・払戸と言う多くの地名は、例の関東の促音で皆このフトであると信ずる。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "後閑の間道から風戸峠へと、やがて、悍馬は死にもの狂いでのぼってゆく。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐藤の畑はとにかく秋耕をすましていたのに、それに隣った仁右衛門の畑は見渡す限りかまどがえしとみずひきとあかざととびつかとで茫々としていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿のおばさんが「あかざ」の葉をむしてゐる、あかざとはめづらしい、そのおひたし一皿いたゞきたい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
