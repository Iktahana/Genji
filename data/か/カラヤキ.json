        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから、素直に、正面からやきもちを焼くなどということは、彼女の誇が絶対にさせないことである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがとう、ついでになにか食べ物がいただけませんか、きのうからなにも食べないのです」　モコウが走って、食堂からやき肉、固パン、茶、および一｜杯のブランデーを持ってきた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして一緒にやらないのさ、野伏と一緒だからやきを廻しているのねと、すては密林がそよともしない山凪の中でいった。",
              "citation": {
                "source": "舌を噛み切った女",
                "author": "またはすて姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪火に橋の前後からやきたてられると、すすむもひくもほのお。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根からやきつけてくるんだもの。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは気持よい写真だからやきましして貰って一枚おめにかけましょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
