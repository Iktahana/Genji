    "definitions": [
      {
        "index": 1,
        "gloss": "to write down (what someone says)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "観測の方法は、鉛筆と手帳をもって、数秒ごとに四つの昇降機のダイアルの示す数字を書き取るだけである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字にして原稿紙へ書き取る暇さえ、ゆっくり与えてはくれないからであった。",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か考へてそれをそのまゝ書き取ると云ふ事は、実に骨の折れる仕事だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "地震波の偵察した結果を書き取る器械、これを地震計と名づける。",
              "citation": {
                "source": "地震の話",
                "author": "今村明恒",
                "note": "青空文庫"
              }
            },
            {
              "text": "講義のときに、彼が口を開いて話し出すと、それを書き取るためにペンや鉛筆があわただしく動かされた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "オブライエン局長はこの指令を手帳に書き取るような愚かな真似はしなかった。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしはのどぼとけをかくことはなかったが、あるとき六本の槍をつけられてもまだ死ななかった例があって、それ以後のどをかきとることがはじまったといわれる。",
              "citation": {
                "source": "せいばい",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
