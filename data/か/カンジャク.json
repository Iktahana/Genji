        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "人里離れた山中に建つその古刹は、四季折々の自然に彩られながらも、常に閑寂な趣を湛えている。",
              "source": "幻辞"
            },
            {
              "text": "都会の喧騒を離れ、奥多摩の閑寂な温泉宿で週末を過ごすことで、日々の疲れが静かに癒やされていく。",
              "source": "幻辞"
            },
            {
              "text": "彼は若くして華やかな社交界を去り、郊外の小さな庵で閑寂を友とする隠遁生活を選んだ。",
              "source": "幻辞"
            },
            {
              "text": "その枯山水の庭園は、巧みに配置された石と白砂の紋様だけで、宇宙の広がりと深い閑寂を表現している。",
              "source": "幻辞"
            },
            {
              "text": "夕暮れ時の湖畔は訪れる人も途絶え、冷ややかな風が吹き抜ける閑寂な世界へと静かに沈んでいった。",
              "source": "幻辞"
            },
            {
              "text": "茶室に一歩足を踏み入れると、外界の騒がしさが遮断された閑寂な空気に包まれ、自然と背筋が伸びる思いがする。",
              "source": "幻辞"
            },
            {
              "text": "都心の高級住宅街でありながら、高い塀に囲まれた邸宅が並ぶこの一帯は、驚くほど閑寂な情趣に満ちている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしヘルンが仕事をしている時は、家人が皆神経質に注意しているので、家中がひッそりとして閑寂に静まり返っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "爛熟し、頽廢し、さうしてさびた揚句の果が、こんな閑寂にたどりついたので、私は、かへつて、このせまい裏路に、都大路を感ずるのである。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西行を好み、閑寂の静かさを求め、枯淡のさびを愛した芭蕉は、心境の自然として、常に「老」の静的な美を慕った。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花や昼ひとしきり海の音　前と同様、南国風景の一であり、閑寂とした漁村の白昼時を思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には白い雲が浮び、自然の悠々たる時劫の外、物音一つしない閑寂さである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句を読むと、田舎の閑寂な空気や、夏の真昼の静寂さや、ひっそりとした田舎家の室内や、その部屋の窓から見晴しになってるところの、広茫たる一面の麦畑や、またその麦畑が、上風に吹かれて浪のように動いている有様やが、詩の縹渺するイメージの影で浮き出して来る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、温泉などといふものは、周囲が極めて閑寂であるから、之れと反映するために、生活の気分を華やかにする必要がある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要所、要所の手くばりもあらましここにすみぬれば手代が下知の一聲に家臺をゆする物音やたまたま晝の閑寂に庭の椿の落つる頃。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この幼い子供達のうちには我家が潰れ、また焼かれ、親兄弟に死傷のあったようなのも居るであろうが、そういう子等がずっと大きくなって後に当時を想い出すとき、この閑寂で清涼な神社の境内のテントの下で蓄音機の童謡に聴惚れたあの若干時間の印象が相当鮮明に記憶に浮上がってくる事であろうと思われた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の山懷の一隅には非常時の嵐が未だ屆いて居ないのか、妙にのんびりした閑寂の別天地である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には森を背負ひ、門前の小川には小橋がかゝつて居る、何となしに閑寂な趣のある好い土地だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代の厭人病者は、むしろ都會の雜鬧中に孤獨で居ることは好んでも、かういふ閑寂の自然の中に孤獨でゐることは好まないだらう。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の特殊な美しさも、静かな夢のような閑寂さも、かえってひっそりと気味が悪く、何かの恐ろしい秘密の中で、暗号を交しているように感じられた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜半の都会が同盟｜罷業のような閑寂さを感じさせた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に軒の雨垂れを聞きながら静かに浴槽に浸っている心持は、およそ他に比較するもののない閑寂で爽快なものである。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな閑寂な武蔵野の片隅で、こういうものを聞くということが何となく面白かった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日常人事の交渉にくたびれ果てた人は、暇があったら、むしろ一刻でも人寰を離れて、アルプスの尾根でも縦走するか、それとも山の湯に浸って少時の閑寂を味わいたくなるのが自然であろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物男の狂歌師、赤猪口兵衛の独住居はすべて二、三日前の通りに閑寂である。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろには森を背負い、門前の小川には小橋がかかっている、なんとなしに閑寂な趣のあるいい土地だと思う。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中では普通の意味での閑寂は味わわれない。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど他には一人も客がなくて無月の暗夜はこの上もなく閑寂であった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにも訪ふことのない、　　　　私の心は閑寂だ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計な心配だが、これから五年あるいは十年の後、工事｜了りて元の閑寂なる山村に帰った時、初めて眼醒むる彼等の苦痛は、一旦心に印せられた惰弱の風と共に永久に消ゆるの時がなかろう。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これを見ると、羨ましいか、桶の蔭から、むくと起きて、脚をひろげて、もう一匹よちよちと、同じような小狗は出て来ても、村の閑寂間か、棒切持った小児も居ない。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと松笠風鈴の音のよろしさ、其中庵はあたらしく一つの声を与へられて、ひとしほ閑寂のおもむきを増した。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の日の庵はいよ／＼閑寂なり、閑寂を愛するは日本人老来の伝統趣味なり、私は幸福なるかな。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよこの閑寂な室内の光線はうす紅くそこにもまた力のない蠅のうたごゑぶむ　ぶむ　ぶむ　ぶむ　ぶむ　ぶむ。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚無の歌　　ヱビス橋のビアホールは、省線の惠比壽驛に近く、工場區街にあり、常客の大部分が職工や勞働者であるため、晝間はいつも閑寂にがらんとしてゐるのである。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
