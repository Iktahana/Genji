    "definitions": [
      {
        "index": 1,
        "gloss": "person who beheads someone to end a seppuku",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幕の内へは先ず介錯人が詰めた。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯人馬場は三尺隔てて背後に立った。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯人の小坂は少し慌てたらしく、西村がまだ右へ引いているうちに、背後から切った。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯人落合は為損じて、七太刀目に首を墜した。",
              "citation": {
                "source": "堺事件",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で頸を突いた人も、介錯人に首を打落させた人も、その首を継ぐために、幾重にも、白布を巻いていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どこの誰とも、おくびにも語つたことはないが、さてはあの十郎左どのの胸に祕められてゐた人は、この琴の爪の持主か」　傳右衞門が、さう察して、白と黒の幕を張りめぐらした切腹の庭をふり返ると、そのときもう介錯人の一陣の刄風が、戞と彼方にひびいてゐた――といふのである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿怨の介錯人一　詮議は、極秘の裡に行われているらしい。",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……嫌な役目だがひとつ引受けてくれんか』『何ですか』『介錯人だ』『……？",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いや――時刻はまだ――半刻の余もござるが、介錯人の事でござる』『寔にお手数で……』『番衆の内より、高安平四郎を選びました故、左様御承知ねがいたい』『えっ』　甚三郎は、髪の毛まで顫かせて、『平四郎が、私の介錯人ですとな？",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――海野甚三郎の介錯人は、かくいう平四郎に吩咐けられましたぞ』『げッ……。",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――介錯人の使命をうけたのを幸に、甚三郎の細首を落して無念をはらし、明け方迄には、他国へ逐電と考えていたが、もうこう口を割ったからには、お城へも戻れまい。",
              "citation": {
                "source": "夏虫行燈",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに宗治の郎党｜難波七郎次郎が櫓を把って控え、介錯人を命ぜられた幸市之丞が端にいた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、検使に首桶を渡して帰ると、郎党の七郎次郎も、介錯人の市之丞も、主人に殉じてともに後を追った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "水裃　大目付｜荘田下総守を大検使として、副使多門伝八郎、大久保権右衛門の三名は、介錯人、その他十人を従えて、『御免』　と、真っ直に、大書院まで通った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "警固の者、検使役、介錯人など、人は邸上にも邸下にも満ちてはいるが、咳声する者はない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、介錯人の磯田武太夫はそれを提げて、『御用意』　と、内匠頭の後に立つ。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
