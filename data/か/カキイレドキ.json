        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたくし共は今が書き入れ時でございます」　云いながら彼は、行燈の暗い火に顔をそむけて立っているお鉄に眼をつけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "休日はビット・インの書き入れ時である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "民需中心の家電メーカーなら、年末や休日などの書き入れ時に社員を量販店に送り出し、販売のサポートをさせることなど日常茶飯事である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の日は、飲み屋の書き入れ時で、うす汚れの暖簾をぴらぴらさせた屋台がいくつも並ぶ。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月と盆は女衒の書き入れ時ですから。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、炭運びが出来やしない、書き入れ時だというのに。",
              "citation": {
                "source": "荒蕪地",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前にとっては苦手の玻璃窓、そいつが江戸から消えたとあっては、ふふん、全く書き入れ時だ。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからが酒場の書き入れ時、浜路の腕の揮い時。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今が書き入れ時である。",
              "citation": {
                "source": "大雪山二題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時こそ手癖の悪い連中の書き入れ時であった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
