    "definitions": [
      {
        "index": 1,
        "gloss": "to buy more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを云ってわたくしがお登久にからかいますと、お登久はまじめな顔をして、女っていうものは皆んなそんなもんですって……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでもう、やっと私どもにも、あとつぎが出来たというわけですわ」「金も出来たし」　と客のひとりが、からかいますと、ご亭主はまじめに、「いろも出来、借金も出来」と呟き、それから、ふいと語調をかえて、「何にしますか？",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑用夫が部屋への案内を買って出てくれて向かいますと、三階の狭い廊下の奥にありました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業の衰退というその後の大きな流れの中で、力強く育てようと彼らが願った村は、過疎化に向かいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、妾は、妾の心の中に今でも生きているあの人の魂をかけてちかいますが、あの人は決してそういう人でなかったのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は北から来て、わたくしは南からむかいます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん大切に取りあつかいますし、複写ができ次第お返しいたしますから、是非お聞きとどけを願いたいと思います」「よろしゅうございます」　こう言って大村夫人は、機嫌よく俊夫君の申し出を聞いてくれました。",
              "citation": {
                "source": "墓地の殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は六七時頃、三度のうちでは一ばん御馳走のある食卓にむかいます。",
              "citation": {
                "source": "身辺打明けの記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからは、小舟で蒸気船に向かいます。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというものは、軌道のてっぺんに立つと、眼が本能的にあなたの方へ向かいます。",
              "citation": {
                "source": "或る精神異常者",
                "author": "モーリス・ルヴェル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッ、あすこに誰かいますわ」　すると、はるか向うの光苔の微光のなかに、一人の、葉か衣か分らぬボロボロのものを身につけた、瘠せこけた男が横たわっている。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の上に、何かいますよ」「なにッ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "二百円ずつの月賦販売も取りあつかいます。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……拙者その手に向かいまする。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まいりますからます／＼深くなるという次第で、伊之吉が来ると岡焼半分に外の女郎が花里にからかいます。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし――外務大臣ランタの名誉にかけてちかいます」「そうですか。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、かならず戻ってくるとちかいますと、怪獣も、それなりゆるしてくれたうえ、から手でかえることはないからといって、ゆうべねむったへやへ、もういちど行ってみよといってくれました。",
              "citation": {
                "source": "ラ・ベルとラ・ベート（美し姫と怪獣）",
                "author": "ヴィルヌーヴ夫人　Madame de Villeneuve",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、塔の中に誰かいますよ」「なに、いるかい。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家へ忠誠をちかいます」「知らないんだ、本当に」「ほんとですか。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の夜は蛍が飛びかいますが、誰も気に止めません。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大津経由で、木曾街道の方に向かいます。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言って呼んでくる声を聞くようになりますと、さすがに山家もいい陽気に向かいます。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、私は、強そうなのをよって、向かいますと、善ちゃんの強い、正ちゃんのをみんな切った茎が、もろく破れて、私のに負けてしまいました。",
              "citation": {
                "source": "草原の夢",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか不思議な子どもがひとり現れて、むかついたり、同情したり、いろいろな心の変化があって、そしてクライマックスへと向かいます。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも君の方にだれかいますか。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前置詞も冠詞も無茶苦茶につかいますでのう。",
              "citation": {
                "source": "アラメダより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちからを　あわせて　きのえだで　こぶりの　いかだを　つくって、　みなもを　こぎこぎ、　どんぐりを　あつめに　ふくろうの　しまへ　むかいます。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
