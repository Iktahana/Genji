    "definitions": [
      {
        "index": 1,
        "gloss": "monster",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "純潔な処女をこの一角の怪獣の棲家へ送り込むと、ウニコールがすっかり大人しくなって処女の胸に頭をすりつけて来る。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ妄想という怪獣の餌食となりたくないためばかりに、私はここへ逃げ出して来て、少々身体には毒な夜露に打たれるのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光は暗夜に怪獣の眼のごとし。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　公使館のあたりを行くその怪獣は八田義延という巡査なり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠っているように思っている植物が怪獣のごとくあばれ回ったり、世界的｜拳闘選手が芋虫のように蠢動するのを見ることもできるのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠山桜あるあたりは、公園の中にても、眺望の勝景第一と呼ばれたる処に候へば、式の如き巨大なる怪獣の腹の下、脚の四ツある間を透して、城の櫓見え、森も見え、橋も見え、日傘さして橋の上渡り来るうつくしき女の藤色の衣の色、あたかも藤の花｜一片、一片の藤の花、いといと小さく、ちらちら眺められ候ひき。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に樹立深く、柳松など生茂りて、くらきなかに、その蒼白なる光を洩し、巨象の形は小山の如く、喬木の梢を籠めて、雲低き天に接し、朦朧として、公園の一方にあらはれ候時こそ怪獣は物凄まじきその本色を顯し、雄大なる趣を備へてわれわれの眼には映じたれ。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は怪獣の眼かと市郎は屹と瞰上げる途端に、頭の上から小さな石が一つ飛んで来たが、幸いに身には中らなかった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人間……狂人……超人……野獣……猛獣……怪獣……巨獣……それらの一切の力を物ともせぬ鉄の怒号……如何なる偉大なる精神をも一瞬の中に恐怖と死の錯覚の中に誘い込まねば措かぬ真黒な、残忍冷酷な呻吟が、到る処に転がりまわる。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の下宿のすぐ裏が、小さい公園で、亀の子に似た怪獣が、天に向って一筋高く水を吹上げ、その噴水のまわりは池で、東洋の金魚も泳いでいる。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼を閉じるとさまざまの、毛の生えた怪獣が見える。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に会うという期待の下へ消していた「おれはスリを働いた」という悔恨の火が、会えずに帰る北山の背中に執拗に迫り、それを振り切って逃げようと焦る行手には、恐怖が怪獣のように立ちはだかり、ペロペロと法律の赤い舌を出しているのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "西海岸の真岡から、樺太庁の所在地たる豊原まで、二十余里の山野を、蝦夷松、椴松、白樺の原生林を技けて、怪獣のごとくまた疾風のごとく自動車で横断することは、少くともこの旅行中の一大壮挙にはちがいない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それがまた怪奇なもので、どちらも若い女と怪獣の姿です。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの神話にも見当らないような怪獣……。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その怪獣と若い女……。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その当時、わたしはコダックを携帯していたので、その怪獣を撮影して置きたいと思ったのですが、遺族の手前、まさかにそんな事も出来ないので、そのままにしてしまいました。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方のうす暗いときに、なんだか得体のわからない怪獣がわたしの家の台所をうかがっていたといって、年のわかい女中が悲鳴をあげて奥へ逃げ込んで来たこともあった。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上は高くして樵夫なども見えず、下は深うして虎狼怪獣が多い。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "其暑い頂点を過ぎて日が稍斜になりかけた頃、俗に三把稲と称する西北の空から怪獣の頭の如き黒雲がむらむらと村の林の極から突き上げて来た。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千トンの重さと大きさとの、怪獣のうなりにも似た轟音と共に錨は投げられた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「レビヤタン」は日月蝕を起す怪獣であって「レビヤタンを激発すに巧なる者」はこの怪獣をして日月蝕を起さしむる魔術者のことである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて『僧伽羅刹所集経』一と二に有翅飛鬼、また羅刹有翅とあり、ハーバート・スペンセルが欧州で天魔に翅を画くは、蝙蝠を怪獣とせるに基づくといえるごとく、インドの羅刹鬼に翅ありとするは幾分蝙蝠に象ったるべきも、右に引いた経文で見ると、多分はコルゴに根源すというべし。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その以上のことは判らなかったが、ともかくも一種の怪獣があらわれて、家々の飼馬を恐れさせ、さらに次郎兵衛後家を踏み殺したというのは事実であることが確かめられたので、甚七と市五郎とは満足して引揚げた。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しい女の正体は、おそらく年古る狐であろうということに諸人の意も一致して、森のかげ、堤の下、石垣の隙き間まで隈なく猟り尽くした末に、二十四あまりの狐、狸、鼬、貂のたぐいを狩り捕えたが、この古城のぬしらしい怪獣は遂に見あたらなかった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に屋上でおこなわれたという、「ＯＫ屋上の決闘」とか、「三大怪獣　屋上最大の決戦」などと呼ばれた、この大立ちまわりについて、慶一は他人の目撃談でしか知らない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、決着がつかなかったことはよいとしても、その後、なにかにつけていっしょに行動するようになった、「三大怪獣」たちの仲のよさは、慶一にはまったく理解できない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　せかいじゅうのくにぐにから、旅行者が皇帝のみやこにやってきました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "せかいじゅうをちょっととびまわった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
