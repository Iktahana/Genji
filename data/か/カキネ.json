    "definitions": [
      {
        "index": 1,
        "gloss": "hedge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春になると、庭の垣根に植えられたツツジが一斉に鮮やかな花を咲かせ、通り行く人の目を楽しませてくれる。",
              "source": "幻辞"
            },
            {
              "text": "隣家との境界にある垣根が伸び放題になっていたので、週末を利用して丁寧に剪定作業を行った。",
              "source": "幻辞"
            },
            {
              "text": "部署間の垣根を取り払い、風通しの良い組織文化を築くことが、イノベーション創出には不可欠だ。",
              "source": "幻辞"
            },
            {
              "text": "近年はデジタル化の影響により、出版と放送、ITといった業種間の垣根が急速に低くなってきている。",
              "source": "幻辞"
            },
            {
              "text": "地域の祭りは、世代の垣根を越えて住民が親睦を深め、伝統を次世代へと繋いでいく貴重な機会となっている。",
              "source": "幻辞"
            },
            {
              "text": "クラシック音楽をもっと身近に感じてもらえるよう、初心者向けの解説を交えたコンサートを開催し、鑑賞の垣根を低くする試みが続いている。",
              "source": "幻辞"
            },
            {
              "text": "彼は誰に対しても気さくに接するので、初対面の人でもすぐに心の垣根が解け、和やかな雰囲気で会話が弾む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "からたちの垣根萩原朔太郎からたちの垣根の中に女のはしやぐ聲のする夕餉の葱のにほひする灯ともしごろからたちの垣根を過ぐる侘しさよ。",
              "citation": {
                "source": "からたちの垣根",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雨や同車の君がさざめ言白梅や誰が昔より垣の外妹が垣根｜三味線草の花｜咲ぬ恋さまざま願の糸も白きより二人してむすべば濁る清水かな　蕪村の句の特異性は、色彩の調子が明るく、絵具が生々しており、光が強烈であることである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白梅や誰が昔より垣の外　昔、恋多き少年の日に、白梅の咲く垣根の外で、誰れかが自分を待っているような感じがした。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今でもなお、その同じ垣根の外で、昔ながらに自分を待っている恋人があり、誰れかがいるような気がするという意味である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹が垣根｜三味線草の花咲きぬ　万葉集の恋歌にあるような、可憐で素朴な俳句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前掲の「妹が垣根」や「白梅や」等の句と対比して鑑賞する時、こうした蕪村俳句の共通する抒情味がよく解るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事は、彼の孤独な伝記に照して見ても肯けるし、前に評釈した「白梅や誰が昔より垣の外」や「妹が垣根｜三味線草の花咲きぬ」やを見ても、一層｜明瞭に理解され得るところであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしおそらく彼の場合は、恋愛においてもその詩と同じく、愛人の姿に母の追懐をイメージして、支那の古い音楽が聞えて来る、「琴心挑美人」の郷愁から妹が垣根｜三味線草の花咲きぬ　の淡く悲しい恋をリリカルしたにちがいない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の窓は田園の遙けきながめにて、垣根に近き駒紫蘇の花、今ぞ日光をうけて、くれなゐの色滴らむばかりなる。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小枝の先に散り残った枯れ／＼の紅葉が目に見えぬ風にふるえ、時に蠅のような小さい虫が小春の日光を浴びて垣根の日陰を斜めに閃く。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍、溝の畔に萩みだれ、小さき社の垣根に鶏頭赤きなど、早くも園に入りたる心地す。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宅の女中が近所の小母さん達二、三人と垣根から隣を透見しながら、何かひそひそ話しては忍び笑いに笑いこけているので、自分も好奇心に駆られてちょっと覗いてみると、隣の裏庭には椅子を持出してそれに楠さんが腰をかけている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高知近傍には寒竹の垣根が多い。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙間なく密生しても活力を失わないという特徴があるために垣根の適当な素材として選ばれたのであろう。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った祖母と幼い自分とで宅の垣根をせせり歩いてそうけ（笊）に一杯の寒竹を採るのは容易であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の垣根の外には近所の子供が二、三人集まって、声高に何か云っているが、その声が遠くのように聞える。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その草庵の垣根越しに、そつと覗いてみた者は、なあんだ、とがつかりさせられる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民家の垣根に槙を植えたのが多く、東京辺なら椎を植える処に楠かと思われる樹が見られたりした。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば四つ目垣でも屋根でも芙蓉でも鷄頭でも、未だ嘗て此れで稍滿足だと思ふやうに描けた事は一度もないのだから、いくら描いてもそれはいつでも新しく、いつでもちがつた垣根や草木である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」達二は、垣根のそばから、楊の枝を一本｜折り、青い皮をくるくる剥いで鞭を拵え、静に牛を追いながら、上の原への路をだんだんのぼって行きました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑゝ言ふ事を聞かぬ我まゝ者め、何うともお爲と捨てぜりふ言ひて心ともなく庭を見るに、ぬば玉の闇たちおほふて、物の黒白も見え分かぬに、山茶花の咲く垣根をもれて、書生部屋の戸の隙より僅かに光りのほのめくは、おゝまだ千葉は寢ぬさうな。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野暮は垣根の外がまへ、三千楼の色｜競べ、意気地くらべや張競べ」というように、「いき」は媚態でありながらなお異性に対して一種の反抗を示す強味をもった意識である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野暮は垣根の外がまへ、三千楼の色競べ、意気地くらべや張競べ」というように、「いき」は媚態でありながらなお異性に対して一種の反抗を示す強味をもった意識である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリヤスや靴下を並べた台の前には人間の垣根が出来てその垣根から大小色々な無数の手が出てうごめきながら商品をつまぐり引っぱり揉みくたにしている。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣根の竹につかまって、池へはいらずに上げることができた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の夜　庭の芭蕉のいと高やかに延びて、葉は垣根の上やがて五尺もこえつべし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからちょうど二年目だったがある朝小十郎があんまり風が烈しくて木もかきねも倒れたろうと思って外へ出たらひのきのかきねはいつものようにかわりなくその下のところに始終見たことのある赤黒いものが横になっているのでした。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かに頭の上で「さよなら、一郎さん、」と云ったかと思うとその声はもう向うのひのきのかきねの方へ行っていました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かきねのずうっと向うで又三郎のガラスマントがぎらっと光りそれからあの赤い頬とみだれた赤毛とがちらっと見えたと思うと、もうすうっと見えなくなってただ雲がどんどん飛ぶばかり一郎はせなか一杯風を受けながら手をそっちへのばして立っていたのです。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりのこどもは、おたがい肩にしっかりと手を組みあって、こっそり行ってみましたが、どのざしきにもたれもいず、刀の箱もひっそりとして、かきねの檜が、いよいよ青く見えるきり、たれもどこにもいませんでした。",
              "citation": {
                "source": "ざしき童子のはなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
