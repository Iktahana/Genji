    "definitions": [
      {
        "index": 1,
        "gloss": "demolition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は山を包む濃雲に絶望しながらも、屋根へ這い上って、虚空を見ていると、眼の前を灰色の霧は、渦巻いて、髯を伝わる呼吸が、雫となってポタポタ落ちる、鉛筆をポッケットから出して、弟が寒暖計を見て報告する温度を、手帖に記していると、傍から鉛筆の墨が滲んで、文字が紙の上で解体するほどの霧だ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死は人間の解体である。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "破壊は社会の解体である。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "沈没汽船引揚、及解体作業が完成して、愈々銅鉄品を売捌くに当って、闇取引をしたのである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代詩壇に於ける自由詩は、その始め、実に新体詩から解体して、次第に済し崩しになったのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我我の肉体は解体して、他の物質に変つて行く。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質と細胞とで組織され、食慾し、生殖し、不断にそれの解体を強ひるところの、無機物に対して抗争しながら、悲壮に悩んで生き長らへ、貝のやうに呼吸してゐる悲しい物を。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉田玄白の「解体新書」や「蘭学事始」などもその中にあった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所在の南師、聞く者皆解体す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝形成りて而して復北に渡らば、将士解体せざらんや、公等の見る所は、拘攣するのみと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し豪傑主義から云えば、勿論のこと、神に献げる犠牲などは論ずるにも足らぬことで、其様なことを否認などしては国家の組織は解体するのであるから、巌窟に孤独生活でも営んでいる者で無い限りは犠牲ということを疑ってはならぬのが、人間世界の実状である。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの文字を長く見詰めている中に、いつしかその文字が解体して、意味の無い一つ一つの線の交錯としか見えなくなって来る。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……もっとも、こんどのはたいした仕事じゃなく、お話にならんくらいのちいさな船の解体で、たいして乗気じゃなかったんだが、しかし大阪ときくと懐しくてね、ついふらふらと来てしもたわけですよ」　次郎は君枝にどの程度の親しさで語って良いか、迷っているような言葉づかいであった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいに潜水夫の仕事は、沈船作業（単に荷物を揚げるような簡単なものから、爆破解体、巨大船の浮上のような大規模なもの）のほかに、築港、橋梁、船渠等の水底土木作業や水産物の採集などであるが、沈船作業は主として春から夏の頃の凪ぎの海に限られており、水産物採集には勿論漁期がある。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしだ、それも二度か三度か跳ね廻ると、意外にもくたくたと解体して、青毛布は尻尾の方にずるずると持って行かれてしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦国時代は此の遠心的な足利幕府の解体過程の中に生れて来たのである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃ、なるほど危険なことは危険だが、それだけにまた、これまでどの解体業者もこいつには手を出せなかったんだが、しかし、君、説教するようだけど、もう今じゃ、引揚事業って奴はただの金儲けじゃないんだから。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズは大冊を伏せ、「結社の突然の解体とオープンショウが書類を持ってアメリカから消えた年とが一致する。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時オレが与太を飛ばしていた広島の片田舎にも、「アメリカはベトナムから出ていけ」だの「東大解体」だの「日帝打倒」だのの胴間声は響いていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともアメリカがベトナムから手を引く奇跡よりは、東大解体は現実味を帯びて見えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールド・タイマーが結集したＧＯ社の手書きシステム、ＰｅｎＰｏｉｎｔによる挑戦は、僕には解体した幻想を再び築き上げようとする試みに見えるのです。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、新たに入社するものはこの伝統の社風に同感するものでも、また必ずしも沼南の人物に推服するものばかりでもなかったから、暫らくすると沼南の節度に慊らないで社員は絶えず代謝して、解体前の数年間はシッキリなしにガタビシしていた。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文学会は後には次第に有象無象を狩集めて結局文人特有の放肆乱脈に堕して二、三年後に自然的に解体したが、初めは最も選ばれたる少数者の集団であって、当時の私設｜翰林院を以て目されていた。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄白は、とうとう自分一人の名前で、ターヘルアナトミアの翻訳たる解体新書を上梓する決心をした。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、幾分寄木細工的な感ある現在のマルクス主義芸術論を解体して、政治的部分と芸術的部分とに還元し、これを明白に規定しなほす必要があると思ふのである。",
              "citation": {
                "source": "政治的価値と芸術的価値",
                "author": "マルクス主義文学理論の再吟味",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちおう、横須賀くんだりまでいってみたんだけど、ＥＭの解体の側杖くらって、いっしょに更地になってた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説が次第に解体して進歩らしい進歩を停止してからもう余程になるので、この主張には、少なくも非常な魅力があることは争われない。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし小説の解体が、従来のような意味における詩の復活の方へ向かうかどうかという問題は、まだまだ考慮の余地があるだろう。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然主義勃興時代、自然主義解体時代すなわち新理想主義勃興時代、そして現代のプロレタリア文学およびモダニズム文学勃興時代等が、この周期に相当する。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、貴様やったな」　飛ぶようにして、カーテンのところへ駈けつけたミルキ閣下は、そのカーテンの向うにバラバラに解体された精巧な器械の固まりを見た。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
