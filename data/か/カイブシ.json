    "definitions": [
      {
        "index": 1,
        "gloss": "smoking out mosquitoes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
