[
  {
    "uuid": "6016770e-bd5b-5a6d-be8e-9c7cb1f51300",
    "entry": "介錯",
    "reading": {
      "primary": "かいしゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beheading (as the ending to a seppuku)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼れは妻の介錯は夫がするのが一番いゝのだと云つて動かなかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは私が御介錯、舌を噛切ってあげましょう。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その一方では近藤六郎兵衛の女房がお岩を介錯して出て来たが、明るい方を背にするようにして坐らしたうえに、顔も斜に向けさしてあった。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「どいまつ」は後に七人程人を殺して、某という老人の介錯で自刃したとのことであった。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平七は二十三歳にて切腹し、小姓磯部長五郎｜介錯いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は磯田十郎に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野又三郎介錯いたし候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は入魂の山伏の由に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯はかねて乃美市郎兵衛勝嘉殿に頼みおき候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "道すがらまた、新兵衛の女房の介錯で、お菊を隣村の夜祭りへ連れ出したことや、雉子が鳴いたり、山鳥が飛んだりする、春の野へお菊をまぜた三四人の女達とわらびをとりに行った時のたのしさなど思い出さずにはおられなかった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お小夜の母も、つい去年までは病躯を支えて二人の子供を介錯した。",
              "citation": {
                "source": "新万葉物語",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときかねて介錯を頼まれていた関小平次が来た。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤本｜猪左衛門が介錯した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は池田八左衛門であった。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は門司源兵衛がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は鎌田源太夫がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄の介錯は高田十兵衛、弟のは村上市右衛門がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉村｜甚太夫が介錯した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "切腹したとき阿部｜弥一右衛門の家隷林左兵衛が介錯した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤安太夫が介錯した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は河喜多八助がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "松野右京の家隷田原勘兵衛が介錯した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は恵良半衛門がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "切腹のとき、高野勘右衛門が介錯した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は仲光半助がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "介錯は吉村｜嘉右衛門がした。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五助が墓地にはいってみると、かねて介錯を頼んでおいた松野｜縫殿助が先に来て待っていた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに居て、立派に死なれるのを拝見もすれば、介錯もして上げます。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十太夫は介錯の役目滞りなく致した上で、この一通を支配頭屋敷へ持参いたせ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして外記にむかって、この上は尋常に腹を切れ、叔父が介錯してやると迫った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
