    "definitions": [
      {
        "index": 1,
        "gloss": "mantissa (of a logarithm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何だかすう／＼風が來るい。",
              "citation": {
                "source": "胡瓜の種",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども其｜穏やかな眠のうちに、誰かすうと来て、又すうと出て行つた様な心持がした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして膝を組んで、壁の薄浮彫の淡いニユアンスを眺めながら、細巻のシガレツトを一本ふかすうちには、どんな重苦しい思想の悪夢でも退散させることができるものである。",
              "citation": {
                "source": "忠告",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、何のためにさまで憎く思ったかといえば、その前日、彼女が師の家にて同門の友達と雑談にふけったおり、誰彼の噂に夜をふかすうちに、姦しきがつねとて、誰にはかかる醜行あり、彼れにはこうした汚行ありと論つらうを聞いて、彼女はもう臥床に入ろうとした師歌子の枕｜許へいって身の相談をしようとした。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "やきものは正しい形を造つても乾かすうちに歪みがくる、素燒で又狂ひがくる、藥をかけて燒きあげると又多少の歪みが出る。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　……筆勢あまって嚇し文句を連ねてはみたが、ここで金博士が、間髪を容れず、顔にあたった大蜘蛛を払いのけ、きゃあとかすうとかいってくれれば、作者も張合があるのであるが、当の博士は、別に愕きもなにもしない。",
              "citation": {
                "source": "毒瓦斯発明官",
                "author": "――金博士シリーズ・５――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや釣れましたかね、後世恐るべしだと野だがひやかすうち、糸はもう大概手繰り込んで只五尺ばかり程しか、水に浸いて居らん。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもその穏やかな眠のうちに、誰かすうと来て、又すうと出て行った様な心持がした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや釣れましたかね、後世｜恐るべしだと野だがひやかすうち、糸はもう大概手繰り込んでただ五尺ばかりほどしか、水に浸いておらん。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "行くだけムダかも知れねえや」　目をさまして顔を洗う習慣のない一助、シブシブ起きてグチの一ツも言いながら二三度手足を動かすうちに仕事着に着終っている簡易生活。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんかすうすう風通しばかりよくつて……。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて熱い湯漬を一杯やらかすうち待って下さい、八五郎にも振舞ってやります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "猿回し",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
