        "examples": {
          "standard": [
            {
              "text": "毎朝8時前には家を出て、満員電車に揺られながら会社に出るのが長年の日課となっている。",
              "source": "幻辞"
            },
            {
              "text": "業務のデジタル化が進みテレワークが中心となった現在でも、対面での打ち合わせが必要な際は会社に出る。",
              "source": "幻辞"
            },
            {
              "text": "ひどい風邪を引いて寝込んでしまい、締め切り直前だったが数日間会社に出ることができなかった。",
              "source": "幻辞"
            },
            {
              "text": "「明日の午前中は役所での手続きを済ませてから会社に出る予定ですので、連絡は午後にお願いします。」",
              "source": "幻辞"
            },
            {
              "text": "定年退職を迎える最後の日、これまで何十年と通い慣れた道を通り、感慨深い思いで会社に出た。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトの追い込み時期は、トラブル対応のために土日であっても会社に出る必要が生じることがある。",
              "source": "幻辞"
            },
            {
              "text": "働き方改革の一環として、育児や介護と両立しながら無理なく会社に出られるよう、短時間勤務制度が活用されている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "夏あたりから例の会社に出る筈なんだから、まアもう暫く遊べ／＼。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならこの次の富山発の汽車へ乗れなかったら、明日は会社に出ることができないからです。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が保険会社に出るようになったのも、女が奔走してくれたからなんです。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がまた会社に出るのを見ましたらどんなに安心致すか分りません。",
              "citation": {
                "source": "過渡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の道具をつめたスーツケースを梅田の駅にあずけておいて、自分は会社に出る。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
