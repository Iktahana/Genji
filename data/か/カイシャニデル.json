        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夏あたりから例の会社に出る筈なんだから、まアもう暫く遊べ／＼。",
              "citation": {
                "source": "父を売る子",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならこの次の富山発の汽車へ乗れなかったら、明日は会社に出ることができないからです。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が保険会社に出るようになったのも、女が奔走してくれたからなんです。",
              "citation": {
                "source": "林檎",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がまた会社に出るのを見ましたらどんなに安心致すか分りません。",
              "citation": {
                "source": "過渡人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の道具をつめたスーツケースを梅田の駅にあずけておいて、自分は会社に出る。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
