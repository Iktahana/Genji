    "definitions": [
      {
        "index": 1,
        "gloss": "rotation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隣の部屋からキンキン早すぎる回転の安蓄音器が、きしりわめく。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い沫が、その上を回転して、両崖の森林を振りかえりながら、何か、禍の身に迫るのを、一刻も早く遁げたいというように、後から後から、押し合って、飛んで行く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ富士という彫刻品の、線と面の回転だ、そこに驚くべき変化と偉大さを発見するだろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は棺に入らないで回転窯の中へ入ってしまいましたわ。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五にごく近頃、ハンブルヒのシュリックという有名な造船家が大きな独楽を船中に取付け、これを迅速に回転すると横揺れがほとんど止まるという巧みな考えを出し、小形の船で実験したら非常に好結果を得たので更に目下エルベ、ヘリゴランド間通いの千トンくらいの客船に取付けるのを製造中だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界的百貨店、ウェルトハイムの大飾窓に煌めく満天の星、神木の木の下の女神を取巻く小鳥、獣類、人間の小児、それらを囲る幽邃な背景が、エンジンの回転仕掛けで、めぐる、めぐる。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁盤縞がそのまま左右いずれへか回転して、垂直線と四十五度の角をなして静止した場合、すなわち、垂直の平行線と水平の平行線とが垂直性および水平性を失って共に斜に平行線の二系統を形成する場合、碁盤縞はその具有していた「いき」を失うのを常とする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "槌のような形をした物の中に小さい電動器があってこれが回転すると槌がブルブルふるえる、そこで槌の頭を肩なり腰なり、すきな処へ当てれば、好い工合に按摩が出来るという仕掛けである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この機械の主要な部分は発信機と受信機と両方に精密に同時に回転する車輪である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合には土器を漏れる水の代りにフィルムを巻いた回転円筒が使われ、棒に刻んだ線を人間が眼で見て烽火を挙げる代りに真空光電管の眼で見た相図を電流で送るのである。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもおもしろい試みであろうが、どうせここまで来るくらいなら、いっそのこと、もう一歩進んで、たとえば碁盤目に雑多の表象を配列してクロスワード・パズルのようなものを作るとか、あるいは六面体八面体十二面体の面や稜に字句を配置してそれをぐるぐる回転するとかいうところまで行ってはどうかと思うのである。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマンチシズムとクラシシズムの両極の間に世界が回転する。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、見事な癇高いうなり声をあげて回転する独楽のように、そこら中を、はげしくキリキリとはねまわった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は左右のものを見、上下のものを視むるとき、さらにその顔を動かし、首を掉ることをせざれども、瞳は自在に回転して、随意にその用を弁ずるなり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時々大きな渦ができ、それがちょうど竜巻のようなものになって、地面から何尺もある、高い柱の形になり、非常な速さで回転するのを見ることがあるでしょう。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "回転台の上へ一塊の陶土を載せる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ回しながらまずこの団塊の重心がちょうど回転軸の上に来るように塩梅するらしい。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、このすえ付け作業がすむと今度は、両手を希薄な泥汁に浸したのちに、その手で回転する団塊の胴を両方から押えながら下から上へとだんだんなで上げると、今まではただの不規則な土塊であったものが、「回転的対称」という一つの統整原理の生命を吹き込まれただけで忽然として「生きて」来る。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間の寿命がモーターの回転数で計られるようになることが幸か不幸かはそれはまた別問題であろう。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方でかみ合ったままで、ぐるりぐるりと腹を返して体軸のまわりに回転する。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニコルを回転すると、それにつれて、この斑点もぐるぐる回る。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右の羽根の刺激の不平均のために、無意識に自動的に羽根の動きの不平均が起こって、結局左右が平均するまでからだを回転させ、そうして刺激を増大するような方向に進行させるという自動調整器を持参しているのであろうか。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　鏡の中の俳優Ｉ氏　某百貨店の理髪部へはいって、立ち並ぶ鏡の前の回転椅子に収まった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち直角だけ回転している。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの二三年前、偶然な機会から椿の花が落ちるときにたとえそれが落ち始める時にはうつ向きに落ち始めても空中で回転して仰向きになろうとするような傾向があるらしいことに気がついて、多少これについて観察しまた実験をした結果、やはり実際にそういう傾向のあることを確かめることができた。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし低い木だとうつ向きに枝を離れた花は空中で回転する間がないのでそのままにうつ向きに落ちつくのが通例である。",
              "citation": {
                "source": "思い出草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで発火後風向はだんだんに南々西から西へ西へと回転して行ったに相違ない。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつまでもマスかいてんじゃねえぞ」　という怒鳴り声と、またドアが悲鳴をあげる音。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私ね、先生、ちかごろ、小説かいてんのよウ。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネエ、先生、私イ、探偵小説、かいてんのよウ」　私は羞しさに混乱して、お魚女史の言葉などは、もう、きこえなかった。",
              "citation": {
                "source": "お魚女史",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
