    "definitions": [
      {
        "index": 1,
        "gloss": "to give money",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒風の吹く街角で、空き缶を置いて座り込む男にポケットの小銭を数枚恵む。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「ただ金を恵むだけでは、彼らの自立を妨げることになりかねない」と支援団体は指摘した。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "かつての豪商も、今や道行く人に金を恵んでもらって食いつなぐという、落ちぶれた生活を送っている。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "彼は困窮している旧友に対し、相手の自尊心を傷つけないよう配慮しながら金を恵んだ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "喜捨を乞う遍路の鉢に、通りがかった巡礼者たちが次々と金を恵んでいく。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「施しとして金を恵むのは勝手だが、人前で見せびらかすような真似はやめろ」と釘を刺された。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            },
            {
              "text": "「ほら、これで温かいものでも買いなさい」と言って、老婦人は震える少年に金を恵んだ。",
              "citation": {
                "source": "幻辞AI",
                "author": "Gemini",
                "note": "gemini-2.0-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわち僕の友人は答うるに事実のままをもってしたが、裁判官はこれをそのままに受けないで、憐れであるから金を恵むというも、一円や二円の額ならその申し開きも受け取れるが、数千の金を出すにいま述ぶるがごとき申し訳けは取り上げがたいと告げた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "という風に考えて、結局これはあんな大金を恵むのが僕に対してきまりが悪かったのだ、とこう解釈しました。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
