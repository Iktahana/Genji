          "literary": [
            {
              "text": "風の噂では、ドレッバーは財産の大半を何とか金に換えて大金持ちとして出発したが、それに比べて道連れのスタンガスンは金がなかったとか。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "其他は風の噂、新聞の報道などで想像して居るやうな譯であります。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗賊どもは自分たちが見つけたものを急いで埋めてしまったが、風の噂に事件を聞きつけた州警察が注意深い捜査を行った。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
