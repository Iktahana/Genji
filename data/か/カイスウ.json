    },
    "definitions": [
      {
        "index": 1,
        "gloss": "number of stairs or stories (storeys)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さては熊谷の石原にしるしの碑の立てりしもこの御神のためなるべし、ことさらにまいる人も多しとおぼゆるに、少しの路のまわりを厭いて見過ごさんもさすがなりと、大路を横に折れて、蝉の声々かしましき中を山の方へと進み入るに、少時して石の階数十級の上に宮居見えさせ玉う。",
              "citation": {
                "source": "知々夫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、衣嚢から格子紙の手帳を取り出して、階段の階数をかぞえ、それに何やら電光形めいた線を書き入れたらしい。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "階数が、だんだん減っていくのだ。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、ここは地下建築なのであるから、上へいくほど、階数は減る。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "御用の階数を早く仰有って下さいまし、二階御用の方はございませんか。",
              "citation": {
                "source": "遊星植民説",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "階数表示の矢印が、九階から順に下っていくのを、北原は確認した。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのすぐ向こうで、操作盤にならんでいる階数のボタンが、七、八、九と、順番に点灯していった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボタンを押した彼女は、三基あるエレヴェーターのうちどれが降りてくるのか、階数表示の明かりを見上げて待った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "建水分神社の宮司岡山氏が、私たちのため、雨傘を翳し添えて、石階数百段を木履で案内してくださる。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
