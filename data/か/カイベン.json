[
  {
    "uuid": "af459ab0-6c9a-5852-a006-c6197f3e3cd1",
    "entry": "快弁",
    "reading": {
      "primary": "かいべん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
