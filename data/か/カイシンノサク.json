    "definitions": [
      {
        "index": 1,
        "gloss": "work after one's heart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "トマトはうまいな、いつ食べても、――会心の作が二句できた。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく作者も会心の作ではなからうかと、想像するわけである。",
              "citation": {
                "source": "月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くだらない出来がこれほどなら、会心の作というのはたいしたものでしょうね」とかなんとか。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしきくところによると、本誌に発表されたものは、氏の最も会心の作だということである。",
              "citation": {
                "source": "探偵小説壇の諸傾向",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "額のかかっている応接間まで歩いて来られ、ラグーザ玉子が、老年なのに心から絵に没頭していて質素な生活に安らいでいることや、孝子夫人の心持をよろこんで、会心の作をわけたことを快よさそうに語られた。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その大家は、過去の作品だからと言って、自分の作を軽々には取り扱わず、却って、「あれこそ、自分のもっとも会心の作」　であると言い切ったところに、この大家の偉さがあるのではないでしょうか。",
              "citation": {
                "source": "旧作",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は私の手を執って、会心の作を得たことを悦び、私達のピエル・フォン生活の記念として私に贈った。",
              "citation": {
                "source": "ゼーロン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｐ教授は到頭我慢し切れなくなって、最近の会心の作の前で、「この絵は如何でしょう」と聞いてみた。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はほとんど見限りをつけたが、去る日始めて会心の作に巡り逢うことができた。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから何方が会心の作か一寸判断に苦むが、兎に角僕の成長をこれほどまで祝してくれたかと思ったら嬉しかった。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、朝に、自己の会心の作を研ぎあげて、　しめた！",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵としても怖らく会心の作ではなかったろうか。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "邸に帰って眠った後も、それが心にかかって工夫していたが、深夜、ふいに起きて燈下で一気に描いたところ会心の作ができたので、初めて悟って、傍らの門人へこういったそうである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
