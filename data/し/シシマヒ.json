        "examples": {
          "standard": [
            {
              "text": "事故による脊髄損傷で四肢麻痺となったが、彼は懸命にリハビリを続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "四肢麻痺の患者さんが一人で外出できるよう、街全体のバリアフリー化が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は四肢麻痺という重い障害を抱えながらも、口に筆をくわえて美しい絵を描き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかししまひには、とう／＼かたつむりのからの上にゆびをつけました。",
              "citation": {
                "source": "かたつむり",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭らしい話はするししまひには踊り出すし、わたしはもう懲り懲りした。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
