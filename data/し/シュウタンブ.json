        "examples": {
          "standard": [
            {
              "text": "染色体の終端部であるテロメアは、老化現象と深い関わりがあると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "道路の終端部には頑丈な車止めが設置されており、海への転落を防いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長い文章の終端部に、作者からのメッセージが添えられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それらの内二本の終端部には鉤爪ないし鋏があり、第三のものの終端部には赤色をしたラッパ状付属肢が四つあった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に標高の高い部分は南緯八二度東経六〇度から南緯七〇度東経一一五度を結ぶ強大な弧を描いて、我々のキャンプに向かって凹形を成し、海側の終端は長大な氷に閉ざされた岸辺となって、南極圏限界線からウィルキス及びモーソン(*32)が瞥見したのはその終端部の丘々である。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
