        "examples": {
          "standard": [
            {
              "text": "敵艦からの至近弾によって船体に大きな亀裂が入り、浸水が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "砲弾の直撃は免れたものの、至近弾の爆風で多くの兵士が負傷した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "至近弾が次々と着弾し、シェルターの中にいても激しい震動が伝わってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "高志と慶一のいるあたりは、至近弾をかわして進む巡洋艦のブリッジという様相になってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの友人の家が至近弾で倒れかかって、友人は数日間僕の家に避難してきてまるで宿屋のような騒ぎもあった。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにせ至近弾なのだから。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
