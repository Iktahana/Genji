        "examples": {
          "standard": [
            {
              "text": "「この辺りには、透き通った水が魅力の『自然湖』がたくさんあるんだって。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「キャンプ場から歩いてすぐの『自然湖』で、ボートに乗るのが最高だったよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「地図で見ると、この大きな『自然湖』は古代の氷河によって作られたらしい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その製造事業がさかんになると、しぜんこのへんの村々へも大きな金が流れこむことになりますわい。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄武社の社中はみなめみえ以上であって、しぜんこの勤労奉仕の徴用はまぬがれないから、悲憤の情もまた強烈であった。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "京の庶民の生態にはしぜんこうした保護神経が身についてしまっている。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
