        "examples": {
          "standard": [
            {
              "text": "市民の利便性を高めるため、駅前のビルの中に臨時の収税所が設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "収税所の窓口には、期限ギリギリに納税の手続きに来た人々が長い列を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての収税所の建物は、現在では歴史博物館として一般に公開されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "イエス様はレビという男――これはマタイ伝を書いたマタイと同じ人だと言われますが、この人が収税所に坐っているのを見て「我に従え」と言われたところ、レビは立ち上がってイエスに従いました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "取税人というのは政府の収税所の下請けをして、税金を取り立てる人です。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
