    "definitions": [
      {
        "index": 1,
        "gloss": "work hours",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "フレックスタイム制を導入し、個人の事情に合わせた就業時間を選べるようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "定時が過ぎても、彼は連日遅くまで就業時間を超過して働いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週の就業時間は40時間と定められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "賃金、就業時間、休息その他の勤勞條件に關する基準は、法律でこれを定める。",
              "citation": {
                "source": "新憲法の解説",
                "author": "日本國憲法",
                "note": "青空文庫"
              }
            },
            {
              "text": "就業時間は百貨店と同様でありますが、販売員一人当りの能率は、著名な百貨店のそれよりも立ち勝ることとなりました。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて、就業時間が長いというのではない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "(2)賃金、就業時間、休息その他の勤労条件に関する基準は、法律でこれを定める。",
              "citation": {
                "source": "日本国憲法",
                "author": "施行、昭和二二年・五・三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の就業時間は、三時間交替だと言うのだった。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "数歩だけ歩いたところで立ちどまり、「あと一時間で就業時間は終わりなの。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
