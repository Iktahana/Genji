        "examples": {
          "standard": [
            {
              "text": "リュミエール兄弟が発明したシネマトグラフが、映画の歴史の幕を開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館で動態展示されている古いシネマトグラフの機構に、子供たちが興味津々だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シネマトグラフの粗い映像には、現代のデジタル映画にはない独特の詩情がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "急がしきシネマトグラフの中なれば、誰とわかねど突拍子もなく現はれて気狂のごと自転車乗の若紳士走り廻れり、何時までも何時までも銀の輪の走り廻れり。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してまた公園の昼のアーク燈を、白昼のシネマトグラフの瞬き、或は薄い面紗のかげに仄かに霞む人妻の愁はしい春の素顔を。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（編）訳注(*1) a series of moving pictures、キングスフォードの生きていた時代は、エジソンのキネトスコープやリュミエール兄弟のシネマトグラフ以前でした。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
