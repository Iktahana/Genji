        "examples": {
          "standard": [
            {
              "text": "今回の求人倍率は、就職希望者数に対して求人数が大きく下回っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "説明会には、会場に入りきらないほどの就職希望者が詰めかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「就職希望者の皆さん、面接では自分の強みを具体的にアピールしてください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "進学一本やりの高校では、大学受験のための進路指導は手厚く行われても、就職希望者への指導には経験も力もない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新家庭をそのまゝ、日本にない、職業紹介事業といふものをこれからやるところで、君は、ぼくがお世話をし出した就職希望者の第何號かだといつてゐた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
