        "examples": {
          "standard": [
            {
              "text": "戦争が終わり、ようやく四海波静かな時代が訪れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい指導者のもと、国は四海波静かで繁栄している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の紛争が解決し、四海波静かな日々が戻ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "四海波静かにて、波も動かぬ時津風、枝を鳴らさぬ御代なれや、と勿体ない、祝言の小謡を、聞噛りに謳う下から、勝負！",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち許嫁の男子（雄）と女子（雌）とが初めて交会し、四海波静かにめでたく三三九度の御盃をすませる。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
