        "examples": {
          "standard": [
            {
              "text": "肥料として〆粕を畑に撒いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "伝統的な製油所では、今も〆粕が副産物として積み上げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この地域では〆粕を家畜の飼料として再利用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「佳味えな」とおつぎがいつた時「〆粕で作つからよ」勘次はいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那ぢや、〆粕許り使あんだつぺか」おつぎは自分の知らぬ不廉な肥料のことに就いて聞いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の粒でがすから、わしがに相違ありあんせん、彼等がな此んなに出來つこねえんですから、それ證據にや屹度自分の畑のがな一つ穗でも伐つちやねえから見さつせ、わしが此んでも〆粕入えて作つたんでがすから」被害者は熱心にいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
