          "standard": [
            {
              "text": "大学の入学志願書には、将来の抱負を具体的に記述した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は転職のために、何枚もの志願書を熱心に書き上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターネットで簡単に志願書が提出できるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "志願書を出して間もなく選衡試験が行われる。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年は三十四五、社長の親戚に当るばかりか、社員の中でも古顔の一人であるが、女の方は半年ほど前に新聞の広告を見て志願書を出して雇つて貰つたばかり。",
              "citation": {
                "source": "男ごゝろ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
