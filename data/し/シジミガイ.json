        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "海岸を散歩していたら、波に洗われて真っ白になったしじみ貝が砂に埋まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、食べた後のしじみ貝をきれいに洗って、ままごとの道具にしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "しじみ貝の模様をよく観察すると、成長の跡が同心円状に刻まれているのがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
