        "examples": {
          "standard": [
            {
              "text": "仏教では、生きとし生けるものは生死輪廻の苦しみから逃れられないとされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は生死輪廻の理を悟るため、山に籠もって厳しい修行に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い経典には、果てしない生死輪廻を断ち切る道が記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "第二〇回　精神的原因によりて生死輪廻すること　さて、霊魂不滅論をだんだん進めてここに至れば、仏教の三界流転、六道輪廻説をも弁明せねばならぬことになりました。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、その静水を真如に比し、波動を生滅に比すれば、たやすく生死輪廻の道理が分かりましょう。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二六回　多苦多患の人に満足を与うるは霊魂不死説にあること　仏教の生死｜輪廻は全く因果の規則によることは、ただいま述べたるとおりでありますが、仏教中の漸教と申す方では、永き年月の間生死輪廻を経て、真如、涅槃の世界に至ることを説けども、頓教と申す方では、一足飛びに生滅界より真如界に至ることを説きます。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
