        "examples": {
          "standard": [
            {
              "text": "この商品は完全に死に筋になってしまった。早急に在庫処分を検討する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もうこの企画は死に筋だ。撤退しよう」と彼は冷静に判断した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年続いたあのブランドも、最近では死に筋商品ばかりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "食い物の味など槙三には分らないらしく、出るものをみな黙って食べていたが、鶏だけは特別気に入ったと見えて、爪附きの片足をひっ掴んだまま、口もとをバタの油で濡らしては必死に筋を食い破っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒は置き石を生かして白を圧迫し、黒に充分の碁ですが、隅の黒石に平凡な死に筋があるのを見落して、せっかくの好局を負けにしたのでした」　千代はこう答えて、目にアリアリと黒の見落した筋を思い浮べた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
