          "standard": [
            {
              "text": "深刻なバグを修正したアプリの修正版が、本日午前十時にApp StoreおよびGoogle Playで公開された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「前回の会議で指摘されたグラフのミスを直した、企画書の修正版を送ります」とメールを送信した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "来年度から使用される教科書の修正版では、不適切な差別表現がより配慮の行き届いたものに改められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ジード旅行記やその修正版、それに対する各方面の批評（最近はフォイヒトヴァンガーによる批評）、それからこれに連関してソヴェート清党運動についての文化的関心、も亦見逃すことの出来ないセンセーションであった。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
