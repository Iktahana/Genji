    "definitions": [
      {
        "index": 1,
        "gloss": "defeating in an instant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
