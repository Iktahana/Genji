        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "トレーラーの死軸は駆動力を伝えないが、車体の荷重を支える重要な役割を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この古い台車は死軸構造になっており、シンプルな作りが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "死軸のベアリングが摩耗して、異音が発生し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "藁くずなど、踏み散らしじくじく湿っていて、年じゅうぬかるみの絶えないような低湿な小路である。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
