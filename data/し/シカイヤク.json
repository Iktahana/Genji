        "examples": {
          "standard": [
            {
              "text": "彼は会議の司会役を務め、議論をスムーズに進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "結婚披露宴の司会役は、友人夫婦に頼むことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経験豊富な司会役のおかげで、パネルディスカッションは大成功だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此ういふ時、いつも司会役の雑誌記者の頭の程度が低くて馬鹿々々しくなる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その司会役をたのまれる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
