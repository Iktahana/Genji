        "examples": {
          "standard": [
            {
              "text": "彼は幼少期から収集癖があり、道端の変わった形の石を拾っては箱に詰めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分でも病気かと思うほどの収集癖で、家の中が骨董品で溢れかえっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君のその収集癖、少しは自制しないと置き場所がなくなるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "数年前、ある専門学校の某教授は収集癖の偏執の古墳の発掘という罪を犯したが、この犯罪の文化上の意義については当時誰もいい及ぼしたものはいなかったようだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は元々骨董収集癖が病的に嵩じた結果らしいので、別に盗んだ五輪の塔を売って金に代えようという意志はないのだから。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
