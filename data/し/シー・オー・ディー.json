        "examples": {
          "standard": [
            {
              "text": "工場排水のCOD値が高いと、河川の汚染が進むおそれがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "水質検査では、BODと並んでCODが重要な指標として用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境規制により、特定の産業では排水のCOD基準が厳しく定められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『ＣＯＤＥ』『コモンズ』などの著作で知られ、この裁判で原告代理人もつとめた法学者のローレンス・レッシグらは、保護期間延長への批判と抵抗を、今も続けている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
