    "definitions": [
      {
        "index": 1,
        "gloss": "resuming work after the New Year's vacation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "1月4日は多くの会社で仕事始めとなり、社員たちが新年の挨拶を交わす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事始めの日は体がなかなか仕事モードに切り替わらず、メールの返信だけで精一杯だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年の仕事始めには、社長から全社員に向けて新しいビジョンの訓示があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "タイプライターと、夕刊新聞のタクシーと、自転車で疾走する給仕の金ボタンと、江東一帯の工場地から聞える仕事始めのサイレンの音響と人物の交錯のなかを、太田ミサコは小肥なボッブの昨夜の女記者の太い脚がアスハルトの道路をふんでやってくるのを認めた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事始めに職工の手に渡されたのは、外でもないカアライルの原稿だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず五月の風景は私の野外における仕事始めのかき入れ時である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は仕事始めに、それをやるんで。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日はやはり仕事始めで、大畑の湊には船玉の祝があり、初町が立って塩と飴と針とを売った。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
