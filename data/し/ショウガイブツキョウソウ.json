          "standard": [
            {
              "text": "運動会の障害物競走で、網をくぐるのに手間取って順位を落としてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "パン食い競走は、障害物競走の中でも一番盛り上がる種目だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "障害物競走の練習中、平均台から足を踏み外して転んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "午後、小児の盲目競走および大人の障害物競走あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の向に見える迷路の二つの入口から、別々に入って、早く中心の「奥の院」へ着いたものが勝ち、という障害物競走だ。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
