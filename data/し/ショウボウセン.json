          "standard": [
            {
              "text": "港湾施設での火災に備え、強力な放水銃を装備した消防船が待機している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "消防船は、海上の船舶火災だけでなく、沿岸部の火災にも対応が可能だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "パレードの最中、消防船が空高く色とりどりの水を噴射する祝賀放水を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "たとえ高圧水道が出来ていようが、消防船が幾台出来ていようが、おそらくそんなものは何にもなるまい。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
