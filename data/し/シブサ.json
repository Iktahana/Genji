        "examples": {
          "standard": [
            {
              "text": "相撲の土俵の上には、東西南北を示す四房が吊るされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "四房の色は、それぞれ青（東）、赤（南）、白（西）、黒（北）を表している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "横綱土俵入りの際に、力士は四房の下をくぐり抜ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "なんでもないのにさういふ雨垂れ落ちを古くとり統べた心が、細かいところはどこまでも微かく行つた茶庭の精神を、しぶさ以上のしぶさで感じた。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて書きはじめた者は、自身の未熟さ、しぶさ、すっぱさみんなかくもののうちに露出しつつ風浪のなかで、育つものなら育って来るから、一つの完成の線に止っていられなくてその点ではなかなか荒くのびて来ます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
