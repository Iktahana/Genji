        "examples": {
          "standard": [
            {
              "text": "帝王切開の既往がある場合、経膣分娩時の子宮破裂のリスクを考慮する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "分娩中に激しい腹痛を訴え、緊急手術の結果、子宮破裂が確認された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子宮破裂は母子ともに命に関わる重大な産科合併症だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところがもう六度の手術で子宮の組織がすっかり破壊されてしまって居たので、胎児の発育を持ちこたえられず子宮破裂で　その女は死んでしまった。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
