        "examples": {
          "standard": [
            {
              "text": "源氏物語にも登場する承香殿は、内裏の七殿五舎の一つである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "承香殿で行われる宴の様子を想像しながら、古典の授業を聞く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "平安時代の宮廷行事において、承香殿は重要な社交場だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "承香殿の女御を母にした第四親王がまだ童形で秋風楽をお舞いになったのがそれに続いての見物だった。",
              "citation": {
                "source": "源氏物語",
                "author": "紅葉賀",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に承香殿の女御の兄である頭中将が、藤壺の御殿から出て、月光の蔭になっている立蔀の前に立っていたのを、不幸にも源氏は知らずに来た。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "当帝の御子は右大臣の女の承香殿の女御の腹に皇子があった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宮には承香殿の女御のお生みした皇子がお立ちになった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "承香殿の東のほう一帯が尚侍の曹司にあてられてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
