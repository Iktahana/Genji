        "examples": {
          "standard": [
            {
              "text": "古刹には、声聞僧たちが修行したとされる古い舎利塔が残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、声聞僧の戒律を守り、質素な生活を送っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "声聞僧の教えは、個人の解脱を重視したが、後に大乗仏教へと発展していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "口に衆生のために法を説かず、ただ自利をのみもっぱらとすというもの正にこれに相当するが、声聞を羊に譬えたことをもってこれと思い合わさば、羊僧すなわち声聞僧で、単に卑しい僧との義に用いたものと解せられるのである。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
