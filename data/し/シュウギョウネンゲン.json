        "examples": {
          "standard": [
            {
              "text": "この専門学校の修業年限は2年で、卒業するとすぐに社会に出られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学院の修業年限は通常2年間だが、博士課程ではさらに延長される場合もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "修業年限内に必要な単位を取得できなければ、卒業はできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "修業年限がおそらく長すぎるのである。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、高等教育の修業年限はかなり短縮された。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚少女歌劇養成会の教育方法は、すべて東京音楽学校の規則にのっとり、入学資格だけは小学校修業十五歳以下の少女にかぎり、修業年限を三年とし、その間に器楽、唱歌、和洋舞踊、歌劇を教授するものであって、我が国でもはじめての試みであった。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            }
          ]
