          "standard": [
            {
              "text": "大切な試合に負けて、選手たちは皆しょげ返っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "失敗を責められた子供は、しょげ返って何も話さなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "どんなにしょげ返ることがあっても、すぐに立ち直る強さが彼女にはある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もののあわれということが、はっきりつかめないままにも何かしら、悲しいのでもなく、落胆でもなく、しょげかえるものでもない。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
