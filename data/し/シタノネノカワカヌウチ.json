        "examples": {
          "standard": [
            {
              "text": "彼は怒り出すと止まらず、舌の根の乾かぬうちに次々と不満をまくし立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は謝罪したかと思うと、舌の根の乾かぬうちにまた同じ間違いを繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "依頼された仕事を終えた途端、舌の根の乾かぬうちに別の依頼が舞い込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "例えば、その舌の根の乾かぬうちに、新内語りの話をきいて、さすがに信吉は舌を巻いて、驚いたのだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
