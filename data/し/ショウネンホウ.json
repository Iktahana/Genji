        "examples": {
          "standard": [
            {
              "text": "少年法の改正により、18歳と19歳は「特定少年」として扱われるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "少年法は、刑罰を与えることよりも少年の更生を支援することを目的にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "凶悪な事件が起きるたびに、少年法の適用範囲を見直すべきだという声が上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "少年法を二十歳まで適用しては、罰が軽くなりすぎるとばかり心配している。",
              "citation": {
                "source": "修身",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも毎日新聞（十二月十五日）では「反戦・反軍をあおる少年の犯罪が激増しており」それらの子供たちの「逮捕留置」が、いまの少年法では困難だ、と論じられている。",
              "citation": {
                "source": "修身",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
