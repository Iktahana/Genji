        "index": 1,
        "gloss": "land-tax rate during the Edo period, in which the government took 70 percent of the year's crop and the farmers kept 30 percent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
