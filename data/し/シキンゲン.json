        "examples": {
          "standard": [
            {
              "text": "テロ組織の資金源を断つために、国際社会が連携して金融資産の凍結を実施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その政治家の裏の資金源が、カジノ業者であるという疑惑が週刊誌で報じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アルバイトで貯めたお金が、私の世界一周旅行の唯一の資金源だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "先生にはべつに資金源があるらしく、翌日は自分で外出し、日が昏れてから泥酔して帰った。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私達には女の持参金という資金源があるんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生はこのような生活をしっかりした資金源もなく続けることは不可能であることを理解し始めていた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
