          "standard": [
            {
              "text": "傘を差しても全く役に立たないほど、篠を突くような雨が夕暮れの街を襲った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山道を歩いている最中に篠を突く雨に見舞われ、一行は近くの洞窟へ避難した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昨夜の篠を突くような豪雨が嘘のように、今朝は澄み渡った青空が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "＊　　　　　　　　　＊　　　　　　　　　　　　　＊　　　　　　　　　＊　ある日鷹狩の歸りに一天俄かに掻き曇り、雨は篠を突くやうにザア／＼降つて來た。",
              "citation": {
                "source": "「雨の降る日は天氣が惡い」序",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            }
          ]
        }
