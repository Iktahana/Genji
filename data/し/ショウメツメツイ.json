        "examples": {
          "standard": [
            {
              "text": "『諸行無常 是生滅法 生滅滅已 寂滅為楽』という経文は、人生の真理を表している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "修行の末に生滅滅已の境地に達した高僧は、穏やかな表情で入寂した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生と死のサイクルを超越した、生滅滅已の静寂こそが仏教の目指す究極の悟りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "晨朝は生滅滅已、入相は寂滅為楽と響くなり。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「是生滅法、生滅滅已」と弁信は合掌してから、南無阿弥陀仏、南無阿弥陀仏、南無阿弥陀仏、と限りなく、念仏の声が口をついて出でました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
