        "examples": {
          "standard": [
            {
              "text": "株価が支持線付近まで下落してきたので、ここから反発するかどうかが注目のポイントだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テクニカル分析において、過去に何度も下げ止まったラインを支持線と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強い売り圧力によって支持線を割り込むと、さらに下落が加速する恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
