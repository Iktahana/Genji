        "examples": {
          "standard": [
            {
              "text": "消防署長は会見で、今回の山火事の原因と今後の対策について説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年末の特別警戒を前に、消防署長が隊員たちの士気を高めるための訓示を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "消防署長として長年務めた功績が称えられ、彼は叙勲の栄誉に浴した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――「巴里の消防署長が、火事のときに消防夫に給与する白葡萄酒を今度から廃めるそうですよ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々はいつとはなしに、何處かの都市の貧民街に火事があると、先づ第一に現場に到着するものは、消防署長の馬車、その次が「アグレイア」粉を積んだ車で、最後にポンプだ、といふやうなことを言ふやうになつた。",
              "citation": {
                "source": "水車のある教會",
                "author": "オウ・ヘンリ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
