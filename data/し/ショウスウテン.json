        "examples": {
          "standard": [
            {
              "text": "答えは小数点第2位を四捨五入して、第1位まで求めてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "計算を間違えて小数点の位置を一つずらしてしまい、とんでもない数値になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "コンピュータ内部では、浮動小数点方式によって実数が表現されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "僕はπを小数点下八位まで記憶している。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "オプションとして示されたものには、最大二五六ＫバイトへのＲＡＭの拡張、プリンター接続用アダプター、カラーもしくは白黒のディスプレイ、八インチのディスクドライブ、浮動小数点演算用プロセッサー、ジョイスティックがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが七歳だったとして、浮動小数点演算（なにそれ）、対数、サイン、行列反転や核反応炉に関する計算といったものに大してこだわらないとしましょう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小数字が負の時は小数点下になる。",
              "citation": {
                "source": "墨流しの物理的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限小数であるから、小数点以下無限の先までつづいている。",
              "citation": {
                "source": "神仙道と科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "√５＝2.236068……，√６＝2.449489……であって、これ等も小数点以下無限につづく数であるが、前の例とはちがって、いくら先まで行っても循環しない数である。",
              "citation": {
                "source": "神仙道と科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
