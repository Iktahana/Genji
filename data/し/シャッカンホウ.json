        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の料理本では、今でも尺貫法で材料の量が書かれていることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高齢者は、尺貫法の方が感覚的に分かりやすいと言う人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "メートル法に移行する際、尺貫法からの切り替えに苦労した人も多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それで自分の頭にあるだけの尺貫法を基礎にして、世の中をそこまで退歩させて、自分の頭に調子を合させようとします。",
              "citation": {
                "source": "ニッポン音楽",
                "author": "――音楽学校の邦楽――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の尺貫法だってチャンとメートルに基いて法定されているということを、無知なアメリカ人などは知らないだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
