        "examples": {
          "standard": [
            {
              "text": "いじめが原因で、ついに彼は自ら命を絶つという悲劇的な選択に死に追いやられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過酷な労働環境が、多くの従業員を精神的に追い詰め、死に追いやる結果となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社は不祥事の責任を全て彼に押し付け、事実上、彼を死に追いやったも同然だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "騙して死に追いやる、まさに我が手にかけるかのようだ。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
