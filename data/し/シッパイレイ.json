          "standard": [
            {
              "text": "過去の失敗例を分析した結果、コミュニケーション不足が最大の原因だと判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "他社の失敗例から学び、同じ轍を踏まないように対策を立てる必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マニュアルには、典型的な失敗例とその対処法が詳しく記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それには御迷惑でも住友寛一氏の製陶失敗例も出ようし、頼母木桂吉氏の九谷窯？",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "間違いを誤魔化さず間違えた理由を詳細に研究するなら失敗例は成功例より有益である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
