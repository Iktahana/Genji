        "examples": {
          "standard": [
            {
              "text": "最高裁判所は、国の最高司法機関である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "司法機関は、法律に基づいて紛争を解決する役割を担う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "司法機関の公正な運営は、国民の信頼に直結する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "オランダ、ハーグにある国連の司法機関、国際司法裁判所は、国連総会と世界保健機関から、核兵器の違法性に関する「勧告的意見」を求められました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お召しになっている、その略服のボタンから拝察すれば、大審院か、あるいは、少なくとも司法機関にお勤めのはずですが、僕は文部関係のものですからね。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一裁判所、裁判官、警察官その他の司法機関が足らぬ。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
