        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大政党の間で埋もれがちだが、その小政党は環境問題に関して独自の提言を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "選挙の結果、いくつかの小政党が議席を獲得し、多党制による議論が活発化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "資金難に苦しむ小政党にとって、ボランティアによる地道な草の根活動は命綱だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "絶望し、分別を失ったドイツの民衆は、それがなんであろうと目前に希望をあたえ、気休めをあたえるものにすがりつき、いかがわしい予言者だの、小政党だのが続々頭をもたげた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方的な小政党であったナチスを一九三三年の選挙で第一党にした背後の力は、国内では軍需生産企業の親玉たちと保守的な国家主義者・軍人・地主たち、判断にまよった小市民層の人々であり、国外においてはナチスに投資した外国の資本家たちであった。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスやスペインのように、少なくとも複雑な小政党対立の関係がある時に限って、氏は人民戦線という言葉を使うことを許可するものであるらしい。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
