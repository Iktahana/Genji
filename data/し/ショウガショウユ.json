        "examples": {
          "standard": [
            {
              "text": "脂ののった戻り鰹の刺身には、ニンニクよりもさっぱりとした生姜醤油がよく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "揚げたての厚揚げにたっぷりの刻みネギをのせ、生姜醤油を垂らして食べるのが大好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焼きなすの皮を丁寧に剥き、冷やしてから生姜醤油でいただくと、夏を感じる一品になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仁輪加なんか無論わかりそうにないノッソリした奴が多いのであるが、その中でも代表的と見える色の黒い、逞ましそうな奴が、骰子の目に切った生鰤の脂肉の生姜醤油に漬けた奴を、山盛にした小丼を大切そうに片手に持って、「ええ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒を抜いて輪切にしますとちょいとお惣菜には結構ですよ」○ソーダ松魚の料理は本文の外に丸のまま臓腑を抜去り白焼になし生姜醤油にて食してもよし。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "揚げたてを生姜醤油で食ふのである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
