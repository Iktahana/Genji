        "examples": {
          "standard": [
            {
              "text": "一時間で100ミリを超える猛烈な集中豪雨により、道路が冠水した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "集中豪雨の恐れがあるため、川の近くに住む住民には早めの避難が呼びかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近は気候変動の影響か、予測困難なゲリラ的な集中豪雨が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、このパターンをはずれたときは、長い乾期のあとのように、チャンスの集中豪雨がやってくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雷は接近せず、雨だけが集中豪雨さながらに降った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
