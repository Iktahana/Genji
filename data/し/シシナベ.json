        "examples": {
          "standard": [
            {
              "text": "「雪が降る寒い夜は、味噌仕立ての猪鍋を囲んで一杯やるのが最高だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山間部の旅館で供された猪鍋の肉は、臭みが全くなくて非常に滋味深かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猪肉を牡丹の花のように盛り付けた猪鍋は、見た目も華やかで冬の風物詩だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "猪鍋をかこみあって、老公も箸を出しているのである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪鍋に天女が天降って来るとは、むかし噺にもない」　と、手の杯を、額のうえに押しいただいて、「帰妙頂来」　と、さけんで、ひとを笑わす男などもあった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　酒も冷えよう、猪鍋も煮えつまろう。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝めしを抜き、早おひるに、その猪鍋を突っつき合い、田辺から山越えでくるバスを待ち合わせる。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
