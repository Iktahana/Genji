          "standard": [
            {
              "text": "「こう」「そう」「ああ」といった指示副詞は、動作の様子や程度を指し示す役割を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そう言わないでください」の「そう」は、直前の発言内容を指す指示副詞だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指示副詞を効果的に使うことで、同じ言葉の繰り返しを避け、文章をすっきりとさせることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
