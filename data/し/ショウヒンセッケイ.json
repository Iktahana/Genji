        "examples": {
          "standard": [
            {
              "text": "環境への負荷を最小限に抑えるため、設計段階からリサイクルや廃棄のしやすさを考慮したサステナブルな商品設計を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長時間の使用でも疲れにくいよう、人間工学のエキスパートのアドバイスを取り入れた緻密な商品設計がなされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新のAIを搭載しつつ、機械に疎い高齢者でも直感的に操作できるという、難度の高い商品設計が今回のテーマだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "要するにこの商品設計そのものにはまったく興味はない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしここでも述べているとおり、ビジネス手帳の電子版という商品設計には全く興味がない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話機能を中心に据えるべきと考える小生の目には、システム手帳をなぞる商品設計には疑問が残る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
