        "examples": {
          "standard": [
            {
              "text": "戦時中の燃料不足を補うため、松の根を掘り起こして松根油が精製された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父から、昔は松根油を灯火の代わりに使ったこともあると聞かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の展示室には、当時の松根油を抽出するための釜が置かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一人の年寄は態と立留まつて、まるでそれをはじめて眺めるやうに、「ははあ、なるほど、松根油か。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "松根油が出るから日本は勝つさうな」と、からからとわらひだした。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村の人々が松根油でさんざ苦しめられてゐるらしいことを、ふと私はさとるのであつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
