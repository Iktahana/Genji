        "examples": {
          "standard": [
            {
              "text": "潮干潟は、多くの生き物が暮らす豊かな生態系だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏休みには、子供たちが潮干潟でカニやヤドカリを探して遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この辺りの潮干潟は、絶滅危惧種の鳥たちの重要な飛来地となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "葉子は不思議なものを見せつけられたように茫然として潮干潟の泥を見、うろこ雲で飾られた青空を仰いだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに鳴海の潮干潟……ほんとに、この海が、どのくらい、古代の旅人を悩ませたかわからない」と女の人が言いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに鳴海の潮干潟、傾く月に道見えて……と太平記にもありますね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
