        "examples": {
          "standard": [
            {
              "text": "この製造ラインでは、部品の失敗率を1%未満に抑えることが目標だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新薬の臨床試験において、副作用による失敗率が高かったため開発が中断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "複雑な手術であればあるほど、術後の合併症を含めた失敗率は上昇する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いくら考えても直接グサリとやるよりも失敗率のすくない仕掛などは殆どない。",
              "citation": {
                "source": "推理小説について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この案ならば八方円満に納まり、しかも捜査の目的も達するのであるが、惜しいことにこの案には十に一つぐらいの失敗率を見込まなければならない。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし十に一つの失敗率でも内閣はたちまちつぶれてしまう。",
              "citation": {
                "source": "“指揮権発動”を書かざるの記",
                "author": "犬養健",
                "note": "青空文庫"
              }
            }
          ]
        }
