        "examples": {
          "standard": [
            {
              "text": "決定的な物的証拠が見つかったことで、検察側の主張の証明力は格段に高まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判官は、被告人の供述は変遷しており、証拠としての証明力は低いと判断した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "DNA鑑定の結果は、犯人を特定する上で非常に強力な証明力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "クリティシズムの科学性、それは批評に際しての一種の証明力あるリアリズムとでも云うべきものであったが、之はやがて思想にとっての科学性の特色でもなければならぬ。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "解釈学的方法そのものの根本的な弱点乃至トリックに就いては後に触れるとして、こうした場合の文義的解釈に対する不信用は、恐らく夫が何かの証明力・説明力を持つかのように説かれたり又受け取られたりするからだろう。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
