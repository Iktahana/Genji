          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "事故の強い衝撃で、彼は現場に倒れ込んだまま正気を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "脱水症状でふらつき、駅のホームで正気を失いそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "処置が早かったおかげで、正気を失っていた患者がようやく目を覚ました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
