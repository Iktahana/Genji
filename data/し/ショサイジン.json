    "definitions": [
      {
        "index": 1,
        "gloss": "person who spends a lot of time in their study",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は生粋の書斎人で、読書と執筆が日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書斎人の彼にとって、静かな環境は何よりも重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は書斎人だが、社会との関わりも大切にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "落ちつきをとりもどしてガサツなところはなくなっていたが、昔のなんの衒いもなかった書斎人の青木の面影とはどこかしら違ったものだ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は書斎人の一徹で、何か一方的に思いこんでいるのである。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日か二日がかりで言葉をつくして説明すれば、半分ぐらい説得できるかも知れないが、そうまでして、この単純に思いこんだ書斎人を説得する根気もなかった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが同じく書斎人と云っても色々ある。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちのような書斎人といわれる者すら、ままそんな非文化的な徒労をやって、あとから辞典に見いだして、ひと知れずよく苦笑する。",
              "citation": {
                "source": "辞典のすすめ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二六・七・二二）宮島の巻　書斎人には、寝足が多い。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
