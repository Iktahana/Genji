          "standard": [
            {
              "text": "「一人のシチズンとして、今回の選挙には必ず足を運び、自分の意思を示したい」と彼は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シチズンの腕時計は、その精巧な技術力と耐久性から、世界中のビジネスマンに愛用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "グローバルシチズンという意識を持ち、国境を越えた課題に協力して取り組むことが求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "周囲のアメリカン・シチズンスの不用意な表情姿態の上に反映したフーヴァーのほうがはるかに多くフーヴァーその人を物語るのである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
