          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "拾い上げた焼骨を、家族一人一人が慎重に骨壺へと納めていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海への散骨を希望していた父の焼骨を、風の穏やかな日に撒きに行った。",
              "citation": {
                "source": "幻辭AI",
