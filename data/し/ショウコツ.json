        "examples": {
          "standard": [
            {
              "text": "高いところから飛び降りて、踵骨にひどい打撲を負った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "踵骨は足の骨の中で最も大きく、歩行時の衝撃を支える重要な役割を持つ。",
              "citation": {
                "source": "幻辭AI",
