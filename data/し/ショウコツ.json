        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故人の遺志により、葬儀の後は速やかに焼骨が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "焼骨が終わるのを待つ間、遺族たちは静かに控室で過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地域によっては、焼骨の方法に独自の伝統的な作法がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "ashes (of a cremated person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
