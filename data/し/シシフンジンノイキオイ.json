        "examples": {
          "standard": [
            {
              "text": "発売されたばかりの新製品が、獅子奮迅の勢いで市場のシェアを塗り替えていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猛特訓を積んだ彼は、大会当日、獅子奮迅の勢いで自己ベストを更新した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今の彼には獅子奮迅の勢いがあるから、誰にも止められないだろう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はまたこれがために、今やドイツ人の暴虐を懲罰せんがため、獅子奮迅の勢いをもって軍国の大事に当たりつつある。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子奮迅の勢いで暴れまくる。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
