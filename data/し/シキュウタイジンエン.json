        "examples": {
          "standard": [
            {
              "text": "糸球体腎炎と診断されたため、彼は専門医の診察を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "糸球体腎炎の治療には、食事療法と薬物療法が用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "慢性的な糸球体腎炎は、腎不全に進行する可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "1827年にロンドンのリチャード・ブライト（1789-1868）はブライト病とも呼ばれている腎臓の病気（＊糸球体腎炎）の本性の認識および腎臓病の一般的性質ついて刊行した。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "過食もまた広がっているブライト病（＊糸球体腎炎）および動脈硬化の主な原因である。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
