        "examples": {
          "standard": [
            {
              "text": "バレエのレッスンの最初のステップは、いつもシャッセから始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "社交ダンスでは、滑るようなシャッセの動きが特徴的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "フィギュアスケートの選手が、流れるようなシャッセで観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はそこに、メルブ・ブレーヌにいたヒルを呼び、ブレーヌ・ラルーにいたシャッセを呼び寄せた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウェリントンは、シャッセの一個旅団を右翼から抜きウィンケの一個旅団を左翼から抜き、それを中央に加え、次にクリントンの師団をも加えた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一つはニヴェルからゆく道にある防寨で、シャッセ旅団のオランダ兵の銃剣がひらめいていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
