        "examples": {
          "standard": [
            {
              "text": "「『自然崇拝』は、世界中の多くの原始的な文化に見られる宗教的形態です。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「山や川、星々といった自然の力に畏敬の念を抱くのは、『自然崇拝』の一種と言えるでしょう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「『自然崇拝』の伝統は、現代でも一部の地域で受け継がれています。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すなわちそれはすでに自然数的な加数ではなくして、無理数的な切断の無限をも連想せしめる。",
              "citation": {
                "source": "リズムの構造",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
