    "definitions": [
      {
        "index": 1,
        "gloss": "food safety",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "消費者が安心して食品を購入できるよう、食安対策は非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "政府は、食安に関する新しい基準を導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "食安に関する法律を遵守することは、食品製造業者の義務である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "燕王張玉の死を聞きて痛哭し、諸将と語るごとに、東昌の事に及べば、曰く、張玉を失うより、吾今に至って寝食安からずと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "起来就食々終眠、飽食安眠過一年、他日若遇相識問、欧天不異故郷天今日になって一々記憶もないが、余程日本流の事が多かったと思われます。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
