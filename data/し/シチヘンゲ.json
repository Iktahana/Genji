    "definitions": [
      {
        "index": 1,
        "gloss": "dance in which the dancer quickly changes his clothes seven times",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その舞台では、役者が七変化の妙技を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統芸能の七変化は、見る者を飽きさせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、七変化の舞を完璧にこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「おう、七変化芝居大一座――珍らしいな」と純之進は云った。",
              "citation": {
                "source": "丹那山の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "草双紙の挿絵を例にとって言えば、『金花七変化』の鍋島猫騒動の小森半之丞に、トンビ合羽を着せたり、靴をはかせたりしている。",
              "citation": {
                "source": "明治十年前後",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのただ、それだけの、いわれさえなきいろものではあったけれど、「五変化」「七変化」などという、江戸の所作事を見るように、何か、我ら、少年の日の胸ときめかせたものであった。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "床を畳んで掃除をして、着換えをして化粧を直すのですから、それはもう田舎芝居の七変化ほどの騒ぎです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日猶まことに壮健である財閥の七変化的存在への助力。",
              "citation": {
                "source": "逆立ちの公・私",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
