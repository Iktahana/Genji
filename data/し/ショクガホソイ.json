        "examples": {
          "standard": [
            {
              "text": "最近、祖母は食が細くなり、心配なので栄養のあるものを勧めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は元々食が細いほうだが、病気をしてからさらに食べる量が減った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子猫の時は食が細くて心配したが、今ではもりもり食べるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その言葉によると、兄の淡窓は身体が弱く、食が細いので、始終遠慮｜勝と少食の損を知つてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいしかったわ」「食が細いねえ。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
