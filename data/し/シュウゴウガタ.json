        "examples": {
          "standard": [
            {
              "text": "Pythonでは、重複する要素を持たない集合型を簡単に扱える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "データベースの設計において、集合型フィールドの使用はデータの正規化に役立つ場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プログラミング言語の集合型には、要素の追加や削除、共通部分や和集合の操作がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "問合わせの結晶の一つに、砲弾集合型のものがあった。",
              "citation": {
                "source": "南極・北極・熱帯の雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "単独のものも、集合型も、ともに一つの特徴をもっている。",
              "citation": {
                "source": "南極・北極・熱帯の雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
