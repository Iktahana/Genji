        "examples": {
          "standard": [
            {
              "text": "「最近、世界中で頻発している『自然災害』には本当に心を痛めるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この地域は、過去に大きな『自然災害』に見舞われた経験がある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「『自然災害』への備えとして、避難経路の確認は大切だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "他の病気は寒さ、食事の誤り、などによるものとしてかなり説明できたが疫病は自然災害のように天罰による病気として多数の人たちが同時に罹り大火災のように広がった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "年代記によるとペストは大きな自然災害に続いて起きたことを記録している。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも自然災害は誰にも起こるし、平民同様に苦しみに耐えられます。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
