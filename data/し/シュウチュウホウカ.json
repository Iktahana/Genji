        "examples": {
          "standard": [
            {
              "text": "味方の援護射撃により、敵の拠点は激しい集中砲火にさらされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「撃て！」の号令と共に、大砲からの集中砲火が海上の標的を捉えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "要塞を陥落させるため、四方八方から集中砲火を浴びせ続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「第一師団は、マニラの北方二百キロのリンガイエン湾に敵前上陸し、三日目にはマニラを去る六十キロのバコロ附近まで進出したのじゃったが、そこで勝手の悪い雨中戦をやり、おまけに山一つ向うのオロンガボオ軍港からの四十｜糎の列車砲の集中砲火を喰って、その半数以上が一夜のうちにやられたということじゃ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には、それがまるで急行列車のように、或いは集中砲火のように、砂漠の嵐のようにとんでくるんだ。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
