        "examples": {
          "standard": [
            {
              "text": "新しいカフェを開くには、かなりの初期投資が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初期投資を抑えることで、リスクを低減できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はスタートアップ企業の初期投資家として成功した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この初期投資のほかに、数年分の生活費と体裁の良い馬車を雇う金も用意せねばなりません。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、セカンドソースとなるメーカーにとっては、ゼロからの開発に伴う膨大な初期投資を抑えられることになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
