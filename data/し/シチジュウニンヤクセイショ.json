          "standard": [
            {
              "text": "七十人訳聖書は、旧約聖書がヘブライ語からギリシャ語に翻訳された最初期の重要な資料だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神学の講義で、七十人訳聖書における語彙の選択が後のキリスト教義に与えた影響を考察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "図書館の奥深くにある貴重書庫で、羊皮紙に記された七十人訳聖書の写本を見学した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "七十人訳聖書では、ヘブライ語のアドナイをキュリオスというギリシャ語に翻訳してあり、そして当時 YHWH はアドナイと発音されていたのであるから、YHWH はキュリオス（「主」）と訳された。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
