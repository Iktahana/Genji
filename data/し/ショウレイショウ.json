        "examples": {
          "standard": [
            {
              "text": "彼女の独創的な作品は、今年の美術展で奨励賞を受賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "惜しくも入賞は逃したが、その努力が認められ奨励賞が贈られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "奨励賞は、将来の活躍が期待される若手アーティストに贈られることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "フィナレで、越路吹雪が、この「女優物語」で、大阪府教育委員会から芸術祭賞（奨励賞）を受賞したので、賞状持って帰った菊田一夫からそれを渡す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
