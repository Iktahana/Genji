        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母が作ってくれた牛肉の時雨煮は、生姜の風味がピリッと利いていてご飯がよく進む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お土産にいただいた蛤の時雨煮を肴に、今夜はゆっくりと冷えた日本酒を楽しもうと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この時雨煮、甘辛い味がしっかり染みていて、お弁当の隙間に入れるのに重宝するのよね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "酒のさかなには山家の蕗、それに到来物の蛤の時雨煮ぐらいであるが、そんなものでも簡素で清潔なのしめ膳の上を楽しくした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "しぐれ、しぐれにぬれてかへつてきた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "講堂は水を打ったようにしずまった、しぐれに打たるる冬草のごとくそこここからなき声が起こった、とそれがやがてこらえきれなくなって一度になきだした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "春日山の城は蝉しぐれにつつまれて再度出征の気ぶりもないのだ。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉しぐれに包まれた母屋の一室で、快げに昼寝していた小六は、「なに！",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫しぐれにつつまれて、いと密やかな裡に、天下一変の大評議は、行われていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
