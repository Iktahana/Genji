        "examples": {
          "standard": [
            {
              "text": "システムエンジニア（SE）は、ITプロジェクトの企画・設計・開発・保守といった一連の工程で中心的な役割を担います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は大学卒業後、システムエンジニア（SE）としてキャリアをスタートさせ、現在ではプロジェクトマネージャーとして活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "システムエンジニア（SE）には、高度な技術力はもちろんのこと、顧客との円滑なコミュニケーション能力も不可欠です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "配属決定前の面接で、早水はシステムエンジニアを志望し、府中の電子計算機開発本部の装置部にまわされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
