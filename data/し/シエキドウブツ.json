        "examples": {
          "standard": [
            {
              "text": "古くから馬や牛などの使役動物が、農業や運搬に利用されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "象は、アジアの一部地域で使役動物として重宝されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会においても、警察犬や盲導犬など、様々な使役動物が人々の生活を支えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何故に、鳥獣の糞は自然を飾り、人間の使役動物たる牛馬の糞は自然と相容れず、人間の糞は自然を汚すのか。",
              "citation": {
                "source": "「自然」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
