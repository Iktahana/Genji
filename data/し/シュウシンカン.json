        "examples": {
          "standard": [
            {
              "text": "中世のヨーロッパでは、一部の裁判官や高官に終身官としての身分が与えられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "終身官は政治的な圧力に屈することなく、独立した立場で職務を遂行できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "独裁国家において、彼は自らを終身官に任命し、権力の永続化を図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしその翌年に、下院議員のジョン・フーラーという人が金を寄附してくれて、新たに化学の教授を置くこととなり、ファラデーを終身官として、これを兼任させた。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            }
          ]
        }
