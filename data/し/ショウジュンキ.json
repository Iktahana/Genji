        "examples": {
          "standard": [
            {
              "text": "新しいライフルに、最新式の光学照準器を取り付けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦闘機のパイロットは、照準器の中に敵機を捉えようと必死だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "暗所でも標的が見えやすいよう、ドットサイト付きの照準器を使用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "戦法は先ず度を合して照準を定めることだが、照準器はめちゃくちゃだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲手は、一生けんめいに、きりきりと照準器を手でまわした。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この爆撃照準器の使い方は、ちょっとむずかしいんだが、おれはかねて、こんなこともあろうかと、あらかじめ研究しておいたのだ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライフルは十字形照準器がついたドイツ製の逸品だった。",
              "citation": {
                "source": "象を撃つ",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
