        "examples": {
          "standard": [
            {
              "text": "食後の食器洗いは、家族みんなで手伝うのが我が家のルールだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日は私が食器洗い担当だから、ゆっくりしてていいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "手が荒れるので、食器洗いをする時はゴム手袋を着用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二年兵の食器洗い、練兵、被服の修理、学科、等々、あとからあとへいろ／＼なことが追っかけて来るのでうんざりする。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに集ってる者共は君に主人から食器洗いの者までの名前を教えてくれるだろう。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこのやつらは君に、主人から食器洗いの女中まで、あらゆる評判を教えてくれよう。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "この村の民家の台所で始めてクシ（松の一木作りの俎板兼食器洗い）が使われているのを見た。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
