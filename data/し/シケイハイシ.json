    "definitions": [
      {
        "index": 1,
        "gloss": "abolition of the death penalty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "国際的な人権団体は、全ての国家に対して死刑制度の即時停止と死刑廃止を強く求めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「死刑廃止論者の意見は理解できるが、凶悪な犯罪によって家族を奪われた遺族の心境はどうなるのか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "死刑廃止を採択した国際会議の決議を受け、国内の法学者たちによるシンポジウムが開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "『刑罰の目的は改過遷善に在り』など云う死刑廃止論者などは、自分の妻なり子なりを強盗にでも殺されて見れば、私の憤慨がどんなに自然であり、正当であるかを了解するだろうと思います。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑廃止論者はさぞ満足することだろう」と。",
              "citation": {
                "source": "殺人狂の話",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすべてが、死刑廃止の主張へと集約される。",
              "citation": {
                "source": "死刑囚最後の日解説",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "死刑廃止論の古典であるベッカリヤを訳して詳しい研究をつけて出版したことは、記憶されねばならぬ。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしかすると、あなたは死刑廃止論者というあれかもしれないし、特にこのような機械で死刑執行するとなれば、なおさらです。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、司法省のいやしい一使用人が、どうでもよいことなのに、椅子から立ちあがって、「さて、もう誰も死刑廃止のことを考えていないから、また首切りをはじめてみるかな。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
