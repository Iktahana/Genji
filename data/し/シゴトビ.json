        "examples": {
          "standard": [
            {
              "text": "月曜日から金曜日までは仕事日なので、夜更かしをしないように気をつけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「明日は仕事日なのに、こんなに遅くまで飲んでいて大丈夫か？」と友人に心配された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事日のランチはいつも慌ただしく、コンビニのおにぎりで済ませることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、パリのお針娘たちは、仕事日には、黒い、絹ではない紡績の靴下をはいてつとめに出るということだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
