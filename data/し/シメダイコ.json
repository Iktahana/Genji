        "examples": {
          "standard": [
            {
              "text": "お囃子の中心となる締太鼓が、軽快なリズムを刻み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締太鼓の皮を紐でギュッと締め上げ、音の高さを調整する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は子供の頃から地元の祭りで締太鼓を叩いており、腕前はプロ級だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "地は笛と締太鼓に銅拍が加わったのが躍動的でよく乗った。",
              "citation": {
