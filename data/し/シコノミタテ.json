        "examples": {
          "standard": [
            {
              "text": "忠実な家臣は、自らを「醜の御楯」と称し、主君を守るために命をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代の武将は、戦場において「醜の御楯」として戦う覚悟を示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この物語では、主人公が「醜の御楯」の精神で仲間を護る姿が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "大｜皇の醜の御楯といふ物は、如此る物ぞと進め。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○天皇は神にしますぞ天皇の勅としいはばかしこみまつれ　（橘曙覽）大皇の醜の御楯といふものはかかるものぞと進め眞前に　（同）大皇の勅頭にいただきて揮はむ太刀による仇あらめや　（同）　右は、橘｜曙覽の作で、概ね出陣する人に贈つたものが多い。",
              "citation": {
                "source": "愛國歌小觀",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日よりは　かえり見なくて　　　大君の　醜の御楯と　　出で立つ　われらは◯暢彦が英に聞いている。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "醜の御楯といでたつ我は。",
              "citation": {
                "source": "堕落論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
