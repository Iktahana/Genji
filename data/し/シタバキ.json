    },
    "definitions": [
      {
        "index": 1,
        "gloss": "undershorts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "快適な睡眠のためには、通気性の良い下ばきを選ぶことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スポーツをする際には、動きやすくサポート力のある下ばきが推奨されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい下ばきを何枚か購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "白いメリヤスのシャツと下ばきばかりの若い男もあった。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも先日同様のもしくは類似の服装であるが、茂手木と岸井は洋服に靴下、吉田八十松も洋服に靴下ばきで九太夫と辰男が足袋である。",
              "citation": {
                "source": "心霊殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "くたびれてポケンとしていたものだから健坊とタア坊のお土産に買ったマリと、あなたのために涼しい下ばきを買ったのをタクシーの中に忘れてしまって、いねちゃんのところの玄関でター坊に歓迎の声をあげられて、ア、忘れたと又戸外へ出たがもとより後かたなし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布、下ばきも届きました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "下ばきは惜しいことをしましたね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ズボンと婦人の下ばきとの合の子みたいなハカマを、スカートのようにはき（割ったスカートといった方が適している）、衣服のヒラヒラするのを身に着けた学生が、一杯いる大きな講堂は、私にとっては新奇な経験であった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛糸は高木の足袋であったり、セーターであったり、千恵子の防寒用の下ばきであったりした。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
