        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "登頂ルートの途中に巨大なシェラックが立ちはだかり、慎重な判断が求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "氷河の急斜面でシェラックが崩落する音が、静かな山々に響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クレバスの間を縫うように、不安定なシェラックを避けて進んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
