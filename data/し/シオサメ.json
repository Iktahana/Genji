        "examples": {
          "standard": [
            {
              "text": "「今年一年、怪我なく無事に舞台を終えられたのが、最高の為納めです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "見事な千秋楽の演舞をもって、今シーズンの公演の為納めとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一日の為納めに、職人たちは使い込んだ道具を丁寧に磨き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "吉兵衛という妙好人の言葉を借りると、「為始めで為納め」、つまり「為直しのない」ことなのである。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世でのしおさめに、力のかぎり出してやるのだ。",
              "citation": {
                "source": "春になる前夜",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
