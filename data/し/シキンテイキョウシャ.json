        "examples": {
          "standard": [
            {
              "text": "彼はこのプロジェクトの最大の資金提供者であり、経営方針にも強い影響力を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "研究の成果を社会に還元することで、資金提供者たちの期待に応えたいと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "匿名の資金提供者から多額の寄付が寄せられ、新しい図書館の建設が実現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてその結果は、漁場主は資金提供者の束縛を脱することはできず、不景気の影響でただでさえ年々下落する一方である製品の価格はそのためにぐんと落され、毎年喰い込むばかりであった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はＥ・アシャトン・スミスと名乗り、大口の資金提供者となった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
