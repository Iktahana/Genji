        "examples": {
          "standard": [
            {
              "text": "願書の締め切り日が近づいているので、早めに投函しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "カレンダーに大きく赤い丸をつけて、レポートの締め切り日を忘れないようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "締め切り日が休日と重なる場合は、その前日が期限となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二三日は暫く問はず、締め切り日を前に控へた以上、誰でも一日のうちに書かないものはない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女人渇仰」は、昨年八月、文学界編集者Ｋ君の強要によつて、これも珍しく、わたくしは東京のある盛り場のホテルに部屋をとり、雑誌の締め切り日に追はれて、なにかを書かねばならぬ破目に陥つた。",
              "citation": {
                "source": "「道遠からん」あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
