        "examples": {
          "standard": [
            {
              "text": "急いで準備をしたせいで、一番大切な書類を持っていくのを為落としてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「返信を為落とすと失礼にあたるから、メールはこまめにチェックして」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんなにベテランの職人でも、疲れていると手順を為落とすことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「たるのなかにおしこめて、それをくぎづけにして、山の上から川のなかにころがしおとすのがいちばんでございますよ。",
              "citation": {
                "source": "森のなかの三人の小人",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "此｜雪頽といふ事｜初編にもくはしく記たるごとく、山に積りたる雪二丈にもあまるが、春の陽気下より蒸て自然に砕け落る事｜大磐石を転しおとすが如し。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
