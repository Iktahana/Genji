    "definitions": [
      {
        "index": 1,
        "gloss": "unfailing devotion to one's country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "楠木正成は、湊川の戦いで最期を悟った際、「七生報国」を誓って自刃したと伝えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての戦時下では、「七生報国」という言葉が愛国心を煽るスローガンとして多用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で、七生報国という精神が後の日本人の死生観に与えた影響について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのため「七生報国」は、日本国民の血液にひそむ大悲願なのであります。",
              "citation": {
                "source": "国防と文化",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "暢彦は学校で最近「七生報国」という言葉を教わって来たので、しきりにそれを口にする。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も「七生報国」と書いて、玄関の上にかかげた。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "以て、正成公の信念もわかるし、七生報国の実もわかる。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、むかしから余りにも有名な“七生報国”のことばなども、これを史観、文学観、今日の眼からどうみるべきか。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛国という語がなまごろしになっているように、正成といえば“七生報国”もおもい出されよう。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその“七生報国”の末期のことばなどは、それそのままではなかったろう。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
