        "examples": {
          "standard": [
            {
              "text": "演習場の中央に設けられた指揮所では、刻一刻と変わる状況が地図に反映される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害対策本部の指揮所として、臨時に小学校の体育館が使用された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指揮所からの撤退命令が、ノイズ混じりの通信機を通じて前線に届く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "帆村たちは、地上指揮所の前に整列した。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは忍谷基地の地上指揮所の屋内である。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上の指揮所でも、一号艇や二号艇の内部が、壁間の受影幕にうつっているのだから、その像のうつっているかぎり、両艇は安全な飛行をつづけているなと安心していられるのである。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電文は地上指揮所にとどいて、すぐさま同じ文句を地上からうちかえしてきた。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのような女の子がふらふらＧＨＱへ出かけたりするのは、戦場の真中にある戦闘指揮所へ遊びに行くよりまだ頓狂なはなしだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
