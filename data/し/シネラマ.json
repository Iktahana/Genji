        "examples": {
          "standard": [
            {
              "text": "1950年代に登場したシネラマは、3台の映写機を使う巨大な湾曲スクリーンが特徴だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつてシネラマ専用だった映画館が、今では最新のIMAXシアターに改装されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シネラマの圧倒的な没入感は、当時の観客に大きな衝撃を与えたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "やがて、頭上三メートル、二メートル、ひとりひとりの裸女が、シネラマの巨人となった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時に女中起しに来る、今朝、ＯＳ劇場のシネラマを見るので。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シネラマ「世界の楽園」の初日、いゝ席で見たが、そのつまらなさに呆れた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
