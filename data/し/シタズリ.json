        "examples": {
          "standard": [
            {
              "text": "子供はまだ舌足らずで、何を言っているのか聞き取るのが難しい時がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自分の考えをうまく言葉にできず、舌足らずな説明になってしまうことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "緊張のあまり、彼女は舌足らずになり、伝えたいことがうまく表現できなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "毎日の新聞原稿でも、その一回一回ゲラ刷り（下刷り）を取り寄せて、せっかく組ミの出来ている版へまっ黒なほど筆を入れる。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
