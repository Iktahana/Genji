        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔ながらの「写婚」は、写真スタジオで撮る記念写真のことを指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、華やかな衣装を着て、スタジオで写婚を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「結婚式の準備が忙しくて、写婚に手が回らなかった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
