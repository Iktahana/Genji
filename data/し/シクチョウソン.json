        "examples": {
          "standard": [
            {
              "text": "住民票の写しが必要な場合は、お住まいの市区町村の窓口で申請してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地方交付税は、各市区町村の財政状況に応じて配分される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "防災訓練は、各市区町村が主体となって定期的に実施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私たちは市区町村会議員の選挙権及び被選挙権すら持っておりません。",
              "citation": {
                "source": "選挙に対する婦人の希望",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長は最も多く贈賄した部下の訓導を首席につけ、視学や市区町村会議員や府県会議員に贈賄する。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "市区町村会や府県会の議員と同じに、地方的情実に基いた「有力者」で、中央の所謂名士ではないが、この地方的、地区的、有力者であることが、この種の議員と同格に、小学校校長の「腐敗」を招くのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
