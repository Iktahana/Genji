        "examples": {
          "standard": [
            {
              "text": "教育課程の改訂について、各学校は指導主事の意見を参考に検討を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市の教育委員会から指導主事が来校し、授業の様子を視察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "指導主事が巡回して、新しい学習方法が適切に実施されているか確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その中安斉さんという老人が指導主事として采配をふるっている。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はご指導主事として反対の趣をお殿様へも申し上げたのですが、大勢はなんともいたし方ありません。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
