        "examples": {
          "standard": [
            {
              "text": "俳句大会で発表された彼の作品は、審査員から秀吟と称えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの応募の中から、一際輝く秀吟が選ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "万葉集には、数多くの秀吟が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "酔いしれた人を総がかりで花かげの俥に乗せつけている近代句に比して秋色の句、才気ほとばしり、当時では秀吟であったらしいが、桜あぶなしという所、危い技巧の山とも見えて、秋色桜を脚本としてかきおろされる筋の面白味は充分あるけど、句としては従来余りに高く評価されすぎている様に思う。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたいに義士たちの辭世や壯擧前後の歌句には秀吟が多い。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
