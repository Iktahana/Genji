        "examples": {
          "standard": [
            {
              "text": "遠洋航海に出る商船には、自国の商船旗が掲げられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "港に停泊する船を眺めながら、それぞれの商船旗が示す国の多様性を想像した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この船の商船旗は、珍しいデザインですね。どこの国の船か分かりますか？」と、船員に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は負傷してはいたが、素速く動くことは驚くべきほどで、彼の白髪雑りの髪の毛は顔に振りかかり、その顔は焦心と憤怒とで英国商船旗のように真赤だった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "「商船旗もだしておりませんし、さっきから観察していますと、多分にあやしむべき点があります」　副長が、傍から説明をはさんだ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
