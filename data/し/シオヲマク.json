        "examples": {
          "standard": [
            {
              "text": "嫌な客が帰った後、縁起を担いで玄関先にたっぷりと塩をまいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "土俵の上で力士が力強く塩をまく姿は、見ていて非常に清々しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "葬儀から帰宅した際、家に入る前に自分の体に塩をまいて清めるのが習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "あとで、チップもない客だと、塩をまく真似されたとは知らず、己惚れも手伝って、坂田はたまりかねて大晦日の晩、集金を済ませた足でいそいそと出掛けた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩をまくことは清浄化することと思われているので、偶然塩をこぼすと縁起がいいとされる。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
