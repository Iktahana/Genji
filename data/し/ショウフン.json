        "examples": {
          "standard": [
            {
              "text": "出世のためなら上司に嘗糞するような真似も厭わない彼の姿勢は、同僚から軽蔑されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての王宮では、王の機嫌を取るために嘗糞に近い媚びを売る家臣が後を絶たなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はプライドを捨てて権力者に嘗糞し、ついに念願だった高位のポジションを手に入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "不學嘗糞陋　　嘗糞の陋を学ばず、不顧利名羈　　利名の羈を顧みず。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            }
          ]
