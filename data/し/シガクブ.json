          "standard": [
            {
              "text": "彼は医学部か歯学部かで進路に悩んでいたが、最終的に歯学部に決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歯学部では、歯科医療に必要な専門知識と技術を習得する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難関の歯学部に入学するため、毎日遅くまで勉強を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "飛躍をかけたジャストシステムの挑戦のきっかけを作ったのは、会社に遊びに来るようになっていた徳島大学歯学部の学生、福良伴昭だった。",
              "citation": {
                "source": "パソコン創世記",
