        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "細胞は、病原体を取り込むために食胞を形成します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "免疫細胞が細菌を捕食する際、食胞が関与します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわっ、この細菌、食胞に飲み込まれちゃった！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
