        "examples": {
          "standard": [
            {
              "text": "彼の計画は、紙上計画の段階で頓挫してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "実現可能性の低い紙上計画に、多くの時間を費やすべきではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これはあくまで紙上計画ですから、実行に移すには課題が多い」と担当者は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いわゆるマジノ延長線は紙上計画に止まり大体有事の日、工事に取りかかる考えであったが、開戦後は労働力の不足等の関係で大して工事を施されていなかった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
