      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Supreme Being",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "多くの宗教では、至上者を創造主として崇拝している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自らを人類の至上者であるかのように振る舞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「神様、至上者よ、どうか我々をお導きください。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はクリスト教オルソドックスのまっただ中に生き、至上者法王と常に顔を合せながら、彼はまったくその外側に息づいていた。",
              "citation": {
                "source": "（私はさきごろ）",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカイア中の至上者を尊とまざりし過を、アートレ，デース、權勢のアガメムノーンに知らせずや！",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
