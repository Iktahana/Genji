        "examples": {
          "standard": [
            {
              "text": "毎年この時期になると、市民税の納税通知書が届くので気が重い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市民税は、公園の整備やゴミの収集など、私たちの身近な行政サービスに使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "収入が減少した場合は、申請することで市民税の減免を受けられる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "同じ学生でも、夜の学校に行っているものは、昼間勤めて月給をとっているという理由で、市民税を納めることになった。",
              "citation": {
                "source": "今日の耳目",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の仕送りをうけている学生は市民税は払わない。",
              "citation": {
                "source": "今日の耳目",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民税を納めることに、勤労市民の一人としての誇りを感じようとする心は、上級学校への道の封鎖や戸主であるなしの問題、その他の現実を思いめぐらしたとき、前途に洋々たる展望を描き出すことの困難さに当惑するであろうと思われる。",
              "citation": {
                "source": "今日の耳目",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
