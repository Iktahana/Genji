        "examples": {
          "standard": [
            {
              "text": "庭にたくさんの石を敷き詰めて、趣のある小道を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部屋の床には、ふかふかのカーペットが敷き詰められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チョコレートで一面を敷き詰めたケーキは、見た目も豪華だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この人は、たいへんなお金持で、町の大通りをすっかりと、そのうえ小さな横町までも、銀貨でぎっしりと、しきつめることができるくらい、お金を持っていました。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方にはドッシリした錦の織物を下げて床には深青の敷物をしきつめる。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
