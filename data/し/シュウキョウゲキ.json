        "examples": {
          "standard": [
            {
              "text": "毎年クリスマスの時期には、教会で子供たちによる宗教劇が上演される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中世ヨーロッパでは、聖書の物語を題材にした宗教劇が盛んだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この宗教劇は、観る者に深い感動と信仰の喜びを与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "成立後の田楽・幸若・猿楽・歌舞妓などが、或者は亡び、或者は固定しきつた今日にすら、思ひがけない地方に、原始的な宗教劇が、どうかすればくり返されて居る。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、我々に訣つてゐるところでは、彼等の行うた人形芝居は、宗教劇には関係がない様である。",
              "citation": {
                "source": "偶人信仰の民俗化並びに伝説化せる道",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教劇　宗教的な題材によつて、その宗教の教義の伝道乃至信仰の昂揚を目的とするもの。",
              "citation": {
                "source": "演劇の様式――総論",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "純忠はこの祭を盛大にするために、会堂の隣りの地に大きい舞台を造り、周囲に多数の桟敷を設けて、二千人の公衆の前に宗教劇を演ぜしめた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
