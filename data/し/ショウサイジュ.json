          "standard": [
            {
              "text": "僧侶が力強い声で消災呪を唱えると、堂内の空気が浄化されるように感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災いを除き、家内安全を願って、毎朝仏壇の前で消災呪を読経する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "お守りの中には、小さな文字で消災呪が書かれた紙が入っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "或る農家で、おかみさんが皿に米をいつぱい盛つてくれた、くれやうが多すぎるから何かあるなと思つてゐたら、果してさうだつた、小さい子に鉄鉢をいたゞかせてくれといふ、消災呪を唱へてあげた、此頃は鉄鉢をさゝげてあるく坊主も稀だし、また子供が頭剃を嫌はない禁厭として鉄鉢をいたゞかせてくれといふ事も稀である。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
