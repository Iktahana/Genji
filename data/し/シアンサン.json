        "examples": {
          "standard": [
            {
              "text": "シアン酸は不安定な化合物であり、特定の条件下で尿素へと変化する性質を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "化学実験室でシアン酸の誘導体を合成する際、ドラフト内での慎重な作業が求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は卒業論文のテーマとして、シアン酸塩の構造解析と反応性について研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水中の鉛をすぐに検出する他の方法はチオシアン酸カリウム（＊chazic acid はHCNの古い名前）であり、ポレット氏が最初に指摘した。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者（鉄）は虫こぶのチンキ、アンモニア、フェロシアン酸カリウムにより、後者は塩化バリウムによる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "1828年にヴェーラーはシアン酸アンモニウムを熱して尿素ができることを示した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "10年ほど後にドイツでヴェーラーはシアン酸銀を塩化アンモニウムと加熱して尿素が得られることを見いだした。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、そのリュシアンさんにたいしてはあなたの方が悪いんですよ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
