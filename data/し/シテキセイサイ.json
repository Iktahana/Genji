        "examples": {
          "standard": [
            {
              "text": "ネット上のリンチや晒し行為は、法に基づかない私的制裁であり、許されるべきではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警察を信じられなくなった男は、犯人に自ら手を下すという私的制裁に及んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "村八分という習慣は、かつての農村社会における過酷な私的制裁の一つだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "殊に隊内に私的制裁の行なわれているのは遺憾に堪えない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍隊が正しき理解の下に私的制裁を消滅せしむる事は日本民族昭和維新の新道徳確立の基礎作業ともなるのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
