        "examples": {
          "standard": [
            {
              "text": "戦争が終わった後、多くのボランティアが戦場の収骨作業に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大規模な災害現場では、行方不明者の収骨作業が何日も続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史学者たちは、古代遺跡から発掘された人骨の収骨と分析を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
        "gloss": "putting cremated remains in an urn",
