        "examples": {
          "standard": [
            {
              "text": "あの映画の主人公は、妹へのシスコンぶりが際立っていて、少し複雑な感情を抱かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔から妹に甘すぎて、周りからは「シスコンだね」とからかわれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼はシスコンの傾向があり、妹のこととなると、つい過保護になってしまう癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
