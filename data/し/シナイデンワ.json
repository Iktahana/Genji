        "examples": {
          "standard": [
            {
              "text": "出張先で急用ができ、近くの公衆電話から市内電話をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の家には、必ず一台は市内電話が設置されていたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "携帯電話が普及する前は、隣の家への連絡も市内電話を使っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大佐の声はすこしはずんでいるが、その声の大きさは、市内電話と同じくらいだった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
