        "examples": {
          "standard": [
            {
              "text": "大手自動車メーカーが、資金繰りの悪化した部品メーカーに対し資本参加することを決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アジア進出の足がかりとして、現地の有力な流通企業に資本参加する交渉を進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ぜひ私たちの宇宙開発プロジェクトに資本参加して、夢を共有してください」と起業家が説得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "＊一九九一年十一月二十八日、ソニーとモトローラーはジェネラル・マジックへ資本参加し、パーソナル・インテリジェント・コミュニケータの開発に向けて両社の技術を提供していくとの方針を明かにした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工骨など医療用セラミックスの製造と販売にあたるニューメディカルと、人工宝石のクレサンベールの二つの子会社を設立してセラミックスのあらたな応用分野を開こうと試みる一方で、宝石用台座の加工にあたる日本キャストと、通信、音響、事務機器メーカーのサイバネット工業に資本参加していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
