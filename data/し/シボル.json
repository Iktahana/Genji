        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新鮮なオレンジを絞って、ジュースを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レモンを半分に切って、ぎゅっと絞ると香りが広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この機械は、リンゴを丸ごと絞ってジュースにする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
