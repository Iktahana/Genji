        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔は市外電話をかけるたびに、ダイヤルを回すのが面倒だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な連絡のため、実家に市外電話をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの時、市外電話が繋がらなかったら、どうなっていたんだろうね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……それから時々、市外電話がかかって来ると、長兄は忙しげに出掛けて行く。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "市外電話で順一を呼出そうとすると、どうしたものか、その夜は一向、電話が通じない。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから時々、市外電話がかかつて来ると、長兄は忙しげに出掛けて行く。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "市外電話で順一を呼出さうとすると、どうしたものか、その夜は一向、電話が通じない。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十分と経たないうちにタッタ一通話の市外電話を受取った警視庁は俄然として極度の緊張振りを示した。",
              "citation": {
                "source": "老巡査",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
