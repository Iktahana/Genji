          "standard": [
            {
              "text": "彼は大学で歯科医学を専攻し、再生医療を利用した新しい治療法の研究に没頭している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "近年の歯科医学の飛躍的な進歩により、自分の歯を長く保つことが可能になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外の歯科医学の論文を読み解き、最新の知見を毎日の診療に取り入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本人は既に外国の歯科医学を勉強しているが、彼等の特殊的な、そして繊細な機械的技能を以てしたら、間もなく巧みな歯科医が出来るであろう。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで三郎は思わず道草を食って、その部屋を眺めたことですが、それは偶然にも、東栄館の止宿人の内で、三郎の一番虫の好かぬ、遠藤という歯科医学校卒業生で、目下はどっかの歯医者の助手を勤めている男の部屋でした。",
              "citation": {
                "source": "屋根裏の散歩者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
