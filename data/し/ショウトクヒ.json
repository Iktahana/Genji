        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "父の功績を称える頌徳碑が、郷里の寺院に建てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この学校の創立者の頌徳碑は、正門の脇にひっそりと建っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年の地域貢献に対する彰徳と頌徳の意味を込めて、記念式典が催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二十七年　今の陝西の西部及び甘肅方面　二十八年　今の河南・山東・安徽・湖北・湖南方面　二十九年　今の河南・山東・山西方面　三十二年　今の直隷・山西方面及び陝西の北部　三十七年　今の湖北・湖南・江蘇・浙江・山東方面　彼はかく四方を巡行しつつ、到る處に秦の頌徳碑を立てた。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "突き当りにある楼門のような所へ這入ったら、今度は大きな亀の背に頌徳碑が立ててあった。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "城壁のこわれを修繕させたとか、下水の掃除をさせたとかすれば、望みどおり頌徳碑くらいは建てて貰えようが、分別のある人間はそんな真似はしないだろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
