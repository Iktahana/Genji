          "standard": [
            {
              "text": "予算委員会での質問時間は、各党の議席数に応じて割り振られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "会議の最後に十分な質問時間を設けたので、不明な点はすべて解消してほしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予定していた質問時間が残り少なくなり、議員は早口で捲し立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "質問時間には、学生同士が自主的に討論することを許されているらしかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁重な質問時間は終了だ。",
              "citation": {
                "source": "黄金薔薇",
