        "examples": {
          "standard": [
            {
              "text": "農作業の準備として、畑の仕拵えを始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい家を建てるための土地の仕拵えは、来週から開始される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭師は、春の花壇の仕拵えに余念がなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "兵隊が帰って来た晩の街頭の人肉市場の光景もかなりに露骨であるが、どこか少しこしらえものらしいところもある。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにも拘わらず、まがい物ならぬ本物の印伝皮で揉めしこしらえた贅沢きわまる煙草入がころがっていましたものでしたから、いかで退屈男の逃すベき！",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにも拘わらず、まがい物ならぬ本物の印伝皮で揉めしこしらえた贅沢きわまる煙草入がころがっていましたものでしたから、いかで退屈男の逃すべき！",
              "citation": {
                "source": "旗本退屈男",
                "author": "第三話　後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちの方の砂地に雪が降ったら、おれは雪を掻きわけて空地を少しこしらえて、短い棒でもって大きな竹を撒くのだ。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにリーズにおくり物を買ってやるお金も少しこしらえたかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしこしらえたいと思ったら！",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
