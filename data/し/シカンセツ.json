        "examples": {
          "standard": [
            {
              "text": "指関節を曲げるたびにポキポキと音が鳴るのが、長年の癖になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "リウマチの症状が悪化し、全ての指関節が赤く激しく腫れ上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "指関節の可動域を正確に測定するために、理学療法士が丁寧に触診した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私自身の偶然に受けた指関節の切傷は、ほんの蚤の喰ったくらいのものだった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソーントンは斧の柄でハルの指関節をなぐつて、ナイフを地面へ叩きおとした。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハルがそれを拾いあげようとするとまた指関節をなぐつた、それでやめておいて、自分でそのナイフを拾いとり、二打ちしてバックの輓革を断ち切つた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳軟骨の黒くなった色が皮膚を通して見えて耳の穴が濃青灰色になったり結膜の上や顔の皮膚にまで黒い斑が現れたり指関節が青っぽい色になったりする。",
              "citation": {
                "source": "先天性代謝異常",
                "author": "INBORN ERRORS OF METABOLISM (1909)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
