    "definitions": [
      {
        "index": 1,
        "gloss": "an ideal topography for the four Taoist gods, with a river in the east, a broad avenue in the west, a basin in the south, and a hill in the north",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "京都の都造りは、四神相応の理想的な地形に基づいて設計されたと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この城下町は、四神相応の条件を満たす、風水的にも恵まれた土地に築かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古来より、四神相応の地は繁栄をもたらすと信じられてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "四神相応の地をしめし、後に浅間山日光山そびえ、東に筑波山、西に富士山箱根山軒端につらなり、和光の影に曇りなく仏法を守護し給ひ、月真如の光をかゝげ、前には生死の海まんまんとして波煩悩のあかをすゝげば、無始の罪障も消滅すると覚えたり。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
