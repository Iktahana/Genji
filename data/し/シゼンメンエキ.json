        "examples": {
          "standard": [
            {
              "text": "過剰なストレスは、体の自然免疫を低下させる可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "バランスの取れた食事と十分な睡眠は、自然免疫を強化するのに役立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ワクチン接種は、病原体に対する獲得免疫だけでなく、自然免疫の働きも助ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてたぶん化学が基礎であると思われる違いに移ると、薬にたいするアレルギーや感染にたいする種々の程度の自然免疫は、動物の属や種におけるはっきりと違うものと比べて、個々の人間のあいだおよび人類のいろいろな人種においては、あまり顕著でないだけである。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
