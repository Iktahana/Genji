        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は休日の午後を、町の小さな書房で過ごすのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しくオープンした書房は、個性的な品揃えで多くの本好きを魅了している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、よく近所の書房で漫画を立ち読みしたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
