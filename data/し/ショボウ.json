    "definitions": [
      {
        "index": 1,
        "gloss": "study",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父はいつも書房にこもり、静かに読書を楽しんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の家の書房は、壁一面が本棚で埋め尽くされ、知的な雰囲気に満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書房の窓から見える庭の景色は、読書の合間の良い息抜きになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんど河出書房から、近作だけを集めた「女の決闘」という創作集が出版せられた。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十一年に、砂子屋書房から出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年は、竹村書房から「愛と美について」砂子屋書房から「女生徒」女生徒は、ことしの五月に再版になりました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年は、竹村書房から「皮膚と心」京都の人文書院から「思い出」河出書房から「女の決闘」が出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、すぐまた砂子屋書房から「晩年」の新版が出るそうです。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて筑摩書房から「千代女」が、高梨書店から「信天翁」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書房主山崎剛平氏は、私でさえ、ひそかに舌を巻いて驚いたほどの、ずぶの夢想家でありました。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに、書房の名の砂子屋は、彼の出生の地、播州「砂子村」に由来しているようであります。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年十二月、「ランボオ学校時代の詩」を三笠書房より刊行。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年は、竹村書房から「皮膚と心」京都の人文書院から「思ひ出」河出書房から「女の決鬪」が出ました。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、すぐまた砂子屋書房から「晩年」の新版が出るさうです。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版元、第一書房主も、もつとこの本の宣傳をしなければいけない。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂子屋太宰治　書房を展開せられて、もう五周年記念日を迎へられる由、おめでたう存じます。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "書房主山崎剛平氏は、私でさへ、ひそかに舌を卷いて驚いたほどの、ずぶの夢想家でありました。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに、書房の名の砂子屋は、彼の出生の地、播州「砂子村」に由來してゐるやうであります。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、砂子屋書房版「晩年」の中に編入されて在る。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、竹村書房版「愛と美について」の中に編入されて在る。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のわがままを許容して、そのやうな冒險を敢へてしてくれた竹村書房主に、あらためて禮を言ひたい。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、砂子屋書房版「女生徒」の中に編入されて在る。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂子屋書房の山崎さんには、第一創作集の時から、實に世話になつた。",
              "citation": {
                "source": "『思ひ出』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「晩年」の初版は昭和十一年に砂子屋書房といふところから出版せられた。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにその後、竹村書房に對して、讀者からの直接の註文が、かなりあるので、竹村書房主はその註文を受ける度毎に憂鬱、なんとかして讀者の求めに應じたいと煩悶、あげくの果は一日、著者の陋屋をおとづれ、名案なきかと相談に及ぶ始末であつた。",
              "citation": {
                "source": "『老ハイデルベルヒ』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
