        "examples": {
          "standard": [
            {
              "text": "このイベントは室内外両方で楽しめるプログラムが用意されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "室内外問わず使える防水スピーカーを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "室内外の温度差が激しいと体調を崩しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わが国に於てこの種のブルジョア観念論の「認識論」が、自然科学や社会科学・歴史科学・に於ける科学論として、相当に研究室内外で実際上の成績を挙げることが出来たのも、亦決して偶然な一時現象に止まるものではあるまい。",
              "citation": {
                "source": "認識論とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内の再調べが行なわれ、室内外の写真がとられた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
