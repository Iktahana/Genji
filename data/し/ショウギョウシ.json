        "examples": {
          "standard": [
            {
              "text": "日本の商業史における、江戸時代の役割を考察する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商業史の資料を読み解き、当時の物価指数を推計する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商業史を学ぶことで、経済の循環が見えてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "が、天下の大富豪と仰がれるようになったのは全く椿岳の兄の八兵衛の奮闘努力に由るので、幕末における伊藤八兵衛の事業は江戸の商人の掉尾の大飛躍であると共に、明治の商業史の第一｜頁を作っておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その割合には名前が余り知られていないが、一生の事業と活動とは維新の商業史の重要な頁を作っておる。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギルバート氏はその『古代商業史』において論じて曰く、島地の商業に便利を呈するはたいていの場合において大陸諸国よりはるかに大なるものとす。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな現象は商業史上どこにも見られない。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
