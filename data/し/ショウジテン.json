        "examples": {
          "standard": [
            {
              "text": "通学に便利なように、ポケットに入るサイズの英和小辞典を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この小辞典は語数は少ないものの、重要語句の解説が非常に丁寧だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "机の隅に置いてある使い込まれた小辞典が、彼の勉強家ぶりを物語っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "おい、その哲学小辞典を持って来ておくれ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口へ出かける、下井田君のところで新聞を読み、それから古本屋へ行つて、最後の一冊――机上の小辞典――を五十銭紙幣一枚に代へる、途中こらへきれなくなつて幾日ぶりかの一杯をひつかけ、そして焚付の木切を拾うて帰つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩波の小辞典をお送りしました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
