        "examples": {
          "standard": [
            {
              "text": "人口爆発に伴う食料や水の資源問題は、21世紀における人類最大の懸念事項だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "資源問題を根本的に解決するには、化石燃料から再生可能エネルギーへの転換が急務である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学校の授業で、北極圏の領有権を巡る資源問題について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それはつまり、資源問題だ。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争もない、資源問題もない。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれは君たちの思いちがいだということを、いずれお悟りになることでしょう」「ふむ、ふむ」「第三に、君たちはさし迫った重大資源問題のため、はるばる地球へやって来たのです。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後、日本の資源問題がやかましく論ぜられた頃は、ＴＶＡを範とする総合開発が、一時天下を風靡した形であった。",
              "citation": {
                "source": "科学ブームへの苦言",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
