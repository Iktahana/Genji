        "examples": {
          "standard": [
            {
              "text": "消極的自由とは、他者からの干渉がない状態を指す政治哲学の概念だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は「何々からの自由」、すなわち消極的自由の重要性を説いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現代社会において、個人のプライバシーを守ることは消極的自由の一環だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただ面倒くさい位の心持から、消極的自由を保っていることも判っていた。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が氏によると、そんな自由はただの消極的自由のことでしかない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "この自由は云うまでもなく、個人が或るものから隔離し逃避することの内に初めて成り立つ処の消極的自由にしか過ぎない。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
