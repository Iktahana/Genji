        "examples": {
          "standard": [
            {
              "text": "あの書店は専門書の品揃えが抜群で、研究者にも重宝されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スーパーの品揃えを見ると、その地域の客層がなんとなくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "季節に合わせて品揃えをガラリと変えるのが、この店の戦略だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼らが関心を持ったのは、価格であり、アプリケーションの品揃えであり、メインテナンスの面倒見であり、せいぜいが使い勝手と外側から見た限りでの機能だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの　いまでも　ほりだしものの　しなぞろえは　ばっちり。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
