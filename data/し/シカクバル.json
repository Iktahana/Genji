        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "披露宴の挨拶だからといって、そう四角張る必要はありませんよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は四角張った性格で、冗談を言っても生真面目に返してくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなに四角張らないで、楽に座ってください」とホストは微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
