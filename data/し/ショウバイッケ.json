        "examples": {
          "standard": [
            {
              "text": "彼女には、常に「商売っ気」があって、どこに行っても何かビジネスチャンスを見つけようとする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの人は、子供の頃から「商売っ気」が強く、お祭りの屋台で一人で商売をしていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「商売っ気」がないと、この世界で生き残るのは難しいかもしれないね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "職人気質の父にさっぱり商売っ気がないことを承知していた古山は、ウサギを飼って小遣いを稼ぎ、部品を買い集めてはラジオや電車の模型を組み立てることを覚えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
