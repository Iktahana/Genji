      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school of commerce",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "商学部に入学して最初に驚いたのは、公認会計士を目指して猛勉強している学生の多さだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「早稲田の商学部は実学の殿堂だ」と先輩に言われ、気を引き締めて講義に臨んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "商学部では英語の授業も重視されており、ビジネスシーンで通用する語学力を養っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これを聞いて一応止めたが、このため商学部長は心臟マヒを起して死んだ由。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "「描けばなんでも描けてしまいますから、とりたてて得意というわけでもありませんでした」「美術の学校へいく、というような気持ちはなかったのね」「私大の商学部ですから。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終ってすぐ早稲田大隈講堂早大商学部大会へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
