        "examples": {
          "standard": [
            {
              "text": "毎年、正月には多くの神道信者が初詣に訪れ、一年の無事を祈願する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は代々続く神社の家系に生まれ、熱心な神道信者として育った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "神道信者は、自然の中に神を見出し、八百万の神々を敬う心を大切にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "老いたる下男は、黒住教か何かの神道信者で、毎晩、神棚の下で、祝詞を唱へてゐた。",
              "citation": {
                "source": "幼少の思ひ出",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
