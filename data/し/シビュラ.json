        "examples": {
          "standard": [
            {
              "text": "巫女シビュラが告げる神託は、ときに国の滅亡を予言する恐ろしいものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洞窟の奥深くに住むシビュラを訪ね、若き勇者は自らの運命を問いかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ミケランジェロが描いたシビュラの姿は、女性とは思えないほどの筋骨隆々とした力強さがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "昔の預言者やシビュラと全く同様に、内なる目が開くのは寝ている間かトランス状態になっている時だった。",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはすべての未開人たちに知られている家庭医学、かなり粗雑な手術、シビュラの書による処方箋を知っており、魔術に頼っていた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元前399年にはシビュラの書の命令によって疫病を防ぐためにローマ市で最初のレクティステルニウムの大祭（lectisternium）が行われた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ローマの大疫病（紀元前291年）にさいして、シビュラの書により使節がエピダウロスに送られ、アスクレピオスに助けを求めた。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
