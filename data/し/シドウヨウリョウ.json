        "examples": {
          "standard": [
            {
              "text": "文部科学省は、学習指導要領を改訂し、新しい教育内容を導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この教科書は、最新の学習指導要領に準拠して作成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "教師は、学習指導要領を熟読し、日々の授業に生かす必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第二　戦争指導要領の変化一　戦争本来の目的は武力を以て徹底的に敵を圧倒するにあり。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二章　戦争指導要領の変化第一節　戦争の二種類　国家の対立ある間戦争は絶えない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代、兵器が極めて単純であった時代は、国民性の会戦指導要領に及ばす影響は比較的大であり得た訳である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "作曲も学習指導要領に要求され、図画や手工と同様創作教育として一般化されてきた。",
              "citation": {
                "source": "歌詞とその曲",
                "author": "信時潔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
