        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "収税官が突然家を訪ねてきたとき、父は何か書類の不備があったのではないかと狼狽した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その収税官は非常に厳格な人物で、一円の計算ミスも決して見逃さないことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "聖書には、当時の人々から疎まれていた収税官が登場する場面がいくつかある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "税金「条文がちゃんとあります」――収税官吏はノワルミエに言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「条文がちゃんとあります」――また収税官吏は言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のほうも、収税官吏の言い分を妻に説明して聞かせるにつれて、だんだん、わかり方がぼんやりして来た。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆくゆくも考えますのは、彼はヒマラヤ山中の人間の中でもすばしこい奴だからもし眼を覚して私がどこへ行ったということを尋ねてツァーランに行ったという時分に、なあにあいつはラサに行ったんだ、俺を欺いて酒を飲ましたとこう悟ってタズンの収税官吏に告げはすまいか。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、支那の今日を見るに、収税官がおらぬ。",
              "citation": {
                "source": "三たび東方の平和を論ず",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、公家の荘園の方にまで地頭という収税官を配置した。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
