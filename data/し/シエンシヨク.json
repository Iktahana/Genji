        "examples": {
          "standard": [
            {
              "text": "私怨私欲に囚われては、公正な判断を下すことはできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の行動は、表面上は正義のためと見えたが、その裏には私怨私欲が隠されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史を動かした人物の中には、私怨私欲を超えて大業を成し遂げた者もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ことに、維新の際は、私怨私欲のための殺人でなく、国家のために、止むを得ざるに出でた殺人であるから、そなたのように、一途に山田、吉川などを恨むのはいかがであろうか。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
