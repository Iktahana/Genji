        "examples": {
          "standard": [
            {
              "text": "個人事業の会計で、店主が自分の財布から店の備品を買った場合は資本主勘定で処理する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "決算作業において、一年間の営業努力の結果である当期純利益を資本主勘定に加算した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この資本主勘定の動きを見れば、事業が着実に成長していることが一目で分かります」と税理士が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "資本主勘定は、貨幣の貸主である資本家の数に細分せられ得る。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主勘定は、一〇、〇〇〇フランの払込みがあったのであるから、一〇、〇〇〇フランの貸方残高がある。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            }
          ]
        }
