        "examples": {
          "standard": [
            {
              "text": "メキシコの「死者の日」には、街中がオレンジ色のマリーゴールドとカラフルなガイコツで飾られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家族が集まって「死者の日」を祝い、亡くなった親族の好物をお供えして思い出話に花を咲かせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "観光客たちは、夜通し行われる「死者の日」のパレードの熱気に圧倒されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それはともかく、十月二日の「死者の日」には、いつも亡くなられた夫人さんの写真に菊の花を飾るが、お盆に墓まいりとはきいたこともなかった。",
              "citation": {
                "source": "黄泉から",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "光太郎はふと十月二日の巴里のレ・モール（死者の日）のしめやかなようすを思いだした。",
              "citation": {
                "source": "黄泉から",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "光太郎は「死者の日」によくそこへ出かけて行った。",
              "citation": {
                "source": "黄泉から",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
