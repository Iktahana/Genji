          "standard": [
            {
              "text": "小児喘息の持病がある娘のために、部屋をこまめに掃除してダニや埃を除去している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は成長して体が丈夫になるにつれ、以前あんなに苦しんでいた小児喘息の症状が出なくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あら、また咳が出始めたわね」と、母は小児喘息の発作を心配して吸入器を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "小児喘息でつや子は弱いから、自動車のついでのあるところがいいし、泰造の友人の娘たち三人もその女学校を卒業したり在学中だったりしているということで、つや子は小学校からずっとそこの女学校へ通わされていたのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
