        "examples": {
          "standard": [
            {
              "text": "小さな青い羽を光らせて舞う小灰蝶を、道端のタンポポで見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小灰蝶の仲間は種類が多く、羽の裏側の細かい模様を見分けるのが非常に難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アリと共生する珍しい生態を持つ小灰蝶が、この山には生息しているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが中でいちばん小さかったしじみちょうははねがあまりつよくなかったので、小川のふちで休まなければなりませんでした。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しじみちょうが小川のふちの水草の葉にとまってやすんでいますと、となりの葉のうらにみたことのない虫が一ぴきうつらうつらしていることに気がつきました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としじみちょうがききました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としじみちょうがさそいました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しじみちょうは、「そんなことはありません。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
