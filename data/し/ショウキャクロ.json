        "examples": {
          "standard": [
            {
              "text": "最新の焼却炉はダイオキシンの発生を抑える設計になっており、周辺環境への影響が少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大型の焼却炉が故障したため、市内のゴミ回収スケジュールが大幅に変更された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家庭用の小型焼却炉は、煙や臭いの苦情を招く恐れがあるため使用を控えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「こないだの、焼却炉のことがバレたんじゃないの」　こんな奴は相手にしてもしかたがないので、慶一は無視して、大森に話しかけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまともじゃないし、我々は自前の焼却炉を持つべきだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最後の一グラムまで焼却炉で焼くべきだ。",
              "citation": {
                "source": "死の土壌",
                "author": "THE DUST OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
