          "standard": [
            {
              "text": "屋根の防水性を高めるために、下葺き材としてアスファルトルーフィングを施工した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "建築基準法に基づき、屋根材の下には必ず下葺き材を敷設しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急勾配の屋根でも、下葺きをしっかり行うことで雨漏りを防ぐことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "鹿沼は麻の名産地といわれる位の処で、垣根も屋根の下葺きもすべて麻柄を使ってあって、畠は麻に占められているから、五穀類は出来ません。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "栃の木で老猿を彫ったはなし",
                "note": "青空文庫"
              }
            }
          ]
        }
