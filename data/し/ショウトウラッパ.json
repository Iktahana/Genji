        "examples": {
          "standard": [
            {
              "text": "夜が更け、兵営に響き渡る消灯ラッパの音で、兵士たちは就寝の準備を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かつては、消灯ラッパの合図で一斉に灯りが消されたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "映画で見た、消灯ラッパが鳴るシーンは、独特の雰囲気を醸し出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "司令官、兵ニ破ッタ始末書ヲ渡シ、海ヘ捨テロト云フ　兵室ヲ出ル、消灯ラッパ聞コエル　兵戻ッテ来ル　司令官「遅レタ罪ダ」ト兵ヲ叱ル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り大人気ないので私は、それに対し何も言ったことはなかったが、起床時刻には連隊に出ており、消灯ラッパを通常は将校集会所の入浴場で聞いていた私は、宿に帰れば疲れ切って軍服のまま寝込む日の方が多かったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
