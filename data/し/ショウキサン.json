      {
        "index": 1,
        "gloss": "small statue of Shōki the Plague-Queller (placed on the overhang of traditional houses in parts of Kyoto and Nara)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お隣の屋根に新しい鍾馗さんが乗ったね」と、京都の路地で近所の人たちが噂している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "向かいの家の鬼瓦の呪いを跳ね返すために、我が家も屋根に鍾馗さんを据えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "町並みを歩くと、色々な表情をした手乗りの鍾馗さんが軒先で見守っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
