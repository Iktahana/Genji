        "examples": {
          "standard": [
            {
              "text": "ボーナスの支給額は、会社の業績によって変動する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は残業代の支給額が少ないと不満を訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この手当の支給額は、地域や家族構成によって異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "イングランドには親類知己がひとりとしておらず、空気のように気ままであり、一日一一シリング六ペンスの支給額の許す限りは勝手に過ごせた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、労働賃銀増額、――水火夫、舵手、大工ら下級船員全体に対して、月支給額の二割を左の方法によって増給すること。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
