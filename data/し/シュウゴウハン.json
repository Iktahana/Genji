    "definitions": [
      {
        "index": 1,
        "gloss": "single crime that naturally consists of a number of incidences and is charged as only one count (e.g. habitual gambling)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
