        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "コーヒーを一杯飲んで気合を入れてから、午後の仕事に掛かろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "朝一番でメールの返信を済ませ、すぐに本番の仕事に掛かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "準備が整ったので、ようやく設計図の作成という具体的な仕事に掛かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」と、漁師はいいましたが、やがてしごとにかかると、それなり、さよなきどりのこともわすれていました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、すぐと、しごとにかかるがよい。",
              "citation": {
                "source": "ルンペルシュチルツヒェン",
                "author": "RUMPELSTILZCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、民さんはしごとにかかる前に、おぼえのある彼処此処に眼にとめていたが、かれの最初の言ったことは庭は十五年前とはずっとよくなった、どこにもみがきがかかっていて、どこでも眼が遊べるようになっていますと、えらいことを言った。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、しごとにかかるまえに、人殺しどもは、まず食卓につきました。",
              "citation": {
                "source": "なぞ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、しごとにかかるまえに、いっぷくしましょう。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
