        "examples": {
          "standard": [
            {
              "text": "兄弟喧嘩の末に、兄は弟を部屋から締め出して鍵をかけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "騒がしい通行人を締め出すために、私有地への立ち入りを禁止した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国内の農家を守るため、安価な輸入品を市場から締め出す動きがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私は世の中には、健忘症の男もあるものだと思ったが、それほどに、美人画を締め出すことは、珍しいのかも知れない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国政府は今次の戦争(*5)を始めるにあたり、文学界のインテリゲンチャを締め出す意向を多かれ少なかれ公式に表明していた。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々夕方が長くなり、雨戸をしめるとき、夜をしめだすという感じ。",
              "citation": {
                "source": "日記",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに女を所有した私は、食器を部屋からしめだすだけの純潔に対する貞節を失つたのである。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに女を所有した私は、食器を部屋からしめだすだけの純潔に対する貞節を失ったのである。",
              "citation": {
