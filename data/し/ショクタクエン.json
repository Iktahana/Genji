        "examples": {
          "standard": [
            {
              "text": "料理の味を調えるために、食卓塩を少々加えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食卓にはいつも食卓塩と胡椒が置いてある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高血圧の人は、食卓塩の摂取量に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして皿に盛ってから、各自が自分の好みに応じて、食卓塩をふりかけて食べる習慣になっている。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓塩ばかりでなく、いろいろなソース類もたくさん食卓に並んでいて、好きなものをかけて食べるのである。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓塩のように粉のまま使う場合は猶更のことである。",
              "citation": {
                "source": "塩の風趣",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
