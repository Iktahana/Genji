        "examples": {
          "standard": [
            {
              "text": "友人に急な出費で困っていると相談したら、快く信用借りさせてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「信用借りだから、必ず返すよ」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "信用借りとはいえ、返済計画はしっかり立てるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "親ゆづりで自分の所有に落ちた建て物を事業費調達の爲めに抵當に入れても、なほ不足した分は僅かに短い期限の信用借りで間に合はせた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "べらぼうな預金をすれば、この国じゃ好きなだけ信用借りできる。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
