        "examples": {
          "standard": [
            {
              "text": "彼は感情に流されず、完璧に任務を遂行するプロの仕事人だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "依頼者の要望を120%叶える彼の仕事人っぷりには、いつも感服する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "華やかな表舞台の裏には、それを支える多くの仕事人たちがいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "13　よっつめの星は、しごとにんげんのものだった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しごとにんげんは、かおを上げた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しごとにんげんは、ほっといてはもらえないんだと、あきらめた。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、しごとにんげんは、ぶっきらぼうにへんじをした。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、しごとにんげんはいった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、きみは星のためにはなってません……」　しごとにんげんは、口もとをひらいたけど、かえすことばが、みつからなかった。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、王さま、みえっぱり、しごとにんげんやのんだくれなんかよりは、ばかばかしくない。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さま、みえっぱり、のんだくれ、しごとにんげんから。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "かぞえてみると、王さまが（もちろん黒いかおの王さまも入れて）111にん、ちりのはかせが7000にん、しごとにんげんが90まんにん、のんだくれが750まんにん、みえっぱりが３おく1100まんにんで、あわせてだいたい20おくのおとなのひとがいる。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたまのいいひとにとっては、しらべるものだし、あのしごとにんげんにとっては、お金のもと。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
