          "standard": [
            {
              "text": "彼は、熟練した射撃手として、施条銃を正確に扱うことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館には、歴史的な施条銃が多数展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、その古い施条銃、まだ撃てるの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そして一同は素破と言えば直ちに起き上れるように、施条銃や拳銃を握りしめたまま、床についたのであったがもちろん眠れるものではなかった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
