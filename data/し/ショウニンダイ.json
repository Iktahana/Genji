        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は証人台の前に立ち、右手を挙げて真実のみを述べることを厳粛に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ドラマの最終回で、真犯人が証人台でついに自身の罪を涙ながらに認めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "証人台に向かう被告人の足取りは重く、その表情には深い後悔の念が滲んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "菅氏は通訳として、その限度の中での証人として、証人台に立ったのです。",
              "citation": {
                "source": "若き僚友に",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逮捕がもう一週間も遅かったら、確実に黄泉の国へ行っていたはずの最後の愛人、十九歳のセグレェなどは、ランドリュにとって不利な証言はすべて拒否し、証人台の上からランドリュにたいする深い思慕の情を述べている。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでラレイは、この不条理な誹謗を否定するために証人台に立たねばならなかった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
