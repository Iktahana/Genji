        "examples": {
          "standard": [
            {
              "text": "数学の授業で、正四面体の展開図から模型を組み立てる課題が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "四面体のサイコロを使ってボードゲームをしたら、なかなか出目が読めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ピラミッドのような形をした四面体は、安定感のある立体構造だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「雅」は、上品と地味と渋味との作る三角形を底面とし、Ｏを頂点とする四面体のうちに求むべきものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乙」とは、この同じ三角形を底面とし、下品を頂点とする四面体のうちに位置を占めているものであろう。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
