        "examples": {
          "standard": [
            {
              "text": "釣り上げたのは立派な縞河豚だったが、素人が捌くのは危険なのでリリースした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "縞河豚のヒレ酒は香ばしく、冬の夜にじっくりと味わうには最高の贅沢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市場に並ぶ縞河豚の鮮やかな黄色のヒレは、他のフグとは一線を画す美しさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "有馬の小娘ひとりのことでも、酔余の癇癪にまかせて、切支丹教師追放を思ひ立つてしまふぐらゐ、有り得ない話ではなかつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいが自分を最も無責任に投りだしてしまふぐらゐ容易なことはないのである。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            }
          ]
