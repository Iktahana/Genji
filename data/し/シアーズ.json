        "examples": {
          "standard": [
            {
              "text": "かつてアメリカの小売業に君臨したシアーズのカタログは、人々の生活に欠かせないものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はシカゴを訪れた際、ランドマークとして知られるシアーズ・タワーを見上げてその高さに驚いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父は古いシアーズの工具セットを今でも大切に手入れして使い続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＩＢＭはこのＰＣを、従来からの自社の販売ルートに加えて、シアーズローバックやコンピュータランドを通じて売ることを明らかにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが流通大手のシアーズローバックが展開しはじめたシアーズビジネスセンターは、従来のパパママストアー的なショップとははっきりと一線を画し、ＩＢＭ ＰＣやＵＮＩＸの載ったマシンを並べて明確にビジネスを志向していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
