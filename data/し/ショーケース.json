        "examples": {
          "standard": [
            {
              "text": "宝石店のショーケースには、高価なネックレスが美しく陳列されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この美術館は、貴重な美術品を保護するために特殊なショーケースを使用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の才能は、このプロジェクトを通して見事にショーケースされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いかにも外国人向の店で、小指に指環をはめ、変にフカフカ口をきく男が、ガラスのショーケースの上に、まるで空気をクッションにするように音を立てずに見せたものを置く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規の古白の後期俳句に対する断罪的態度にも関わらず、「古白遺稿」を古白俳句のショーケースと看做して問題ないことの保証がより強まったといえよう。",
              "citation": {
                "source": "藤野古白句集",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
