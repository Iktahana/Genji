        "examples": {
          "standard": [
            {
              "text": "コンサートで演奏されたシャコンヌは、壮大で感動的だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "バロック音楽のシャコンヌは、しばしば変奏曲形式で作曲される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの作曲家のシャコンヌは、独特の悲壮感があって引き込まれる。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "エマニュエル・ド・ファッリャをしてシャコンヌ舞曲を作らしめよ！",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの時のバッハの『シャコンヌ』を記憶している。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィタリーの『シャコンヌ』（Ｊ八六五一―二）が注目される。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィッシャー　Edwin Fischer　バッハ弾きとして有名なフィッシャーが、始めてＨＭＶに、ヘンデルの『シャコンヌ』とバッハの『半音階的幻想曲』を入れた時、一部の人には相当に騒がれたが、一般的には一向問題にならなかった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『シャコンヌ』はいかにも美しかった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いてヘンデルの『シャコンヌ』（ＪＦ一六）と『組曲＝ニ短調』（愛好家協会レコードＲＬ二）を挙げることには誰も異論はあるまい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかには『シャコンヌ』一枚でも事足りる。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
