        "examples": {
          "standard": [
            {
              "text": "警察は、違法に廃棄されたごみの収去を業者に命じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不良品が発見されたため、市場からの製品の収去が決定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故現場から車両の収去作業が行われ、道路の交通規制が解除された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
