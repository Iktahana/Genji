        "examples": {
          "standard": [
            {
              "text": "彼は司法試験に合格するため、毎日徹夜で勉強した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "司法試験の合格率は非常に低い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は司法試験の勉強を始めて、今年で三年目になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "東大法学部に進んで司法試験を目指していた兄のようにエリートコースを進んでほしいとの両親の願いとは、このときを境に決別することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも大学院に進学したり、司法試験や公認会計士試験や公務員試験を受験しようとする学生は文句なく勉強している。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強しなおすとは、司法試験を受ける、ということだった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡部はそのまま大阪にとどまり、勉強はうまくいったのだろう、司法試験に合格した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
