        "examples": {
          "standard": [
            {
              "text": "CPUのアーキテクチャについて学んでいると、RISCとCISCの違いが興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの初期のマイクロプロセッサは、CISC（複雑命令セットコンピュータ）設計を採用していました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "CISC命令セットは、比較的複雑で、一つの命令で多くの処理を実行できるのが特徴です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なぜならば、あなたの旧友であるフランシスク・サルセエ氏は、その劇評に於て、常に自由劇場の上場脚本を批難攻撃してゐるに拘はらず、この度に限つて、「娼婦エリザ」は毫も上演に差支なきものであることを述べてゐます。",
              "citation": {
                "source": "仏国議会に於ける脚本検閲問題",
                "author": "――ゴンクウルの『娼婦エリザ』――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランシスクス・シルヴィウスはファン・ヘルモントの弟子であり、ヨーロッパで最初にライデンに化学実験室を作り、彼は近代臨床教育の導入に貢献した。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はフランシスクス・シルヴィウスが近代の人たちのあいだで最初に体系的な臨床教育をライデンで組織化したことを既に述べた。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            }
          ]
        }
