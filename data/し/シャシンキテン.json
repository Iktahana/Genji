        "examples": {
          "standard": [
            {
              "text": "新しいレンズを探しに、近所の写真機店を何軒か回ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "写真機店で店員さんに相談しながら、自分に合ったカメラを選ぶことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの写真機店は、古いカメラも扱っていてコレクターにも人気があるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "つい最近、桜橋の交叉点でむかし品川の写真機店で一緒に奉公していた男に出会った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち話にきくと、今では堺筋に相当な写真機店を出しているということだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おみおりが出来たのよ、他にはもう通し物もないと思って、勘定して来たのよ、手廻しがいいのでしょう」　天風は体が苦しいのでもう冗談も云わずに、大きな蟇口を出してその中にしまってある、写真機店の番頭からもらった拾円紙幣二枚のうちの一枚をたくさんあるようにして手際好くだした。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
