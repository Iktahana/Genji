        "examples": {
          "standard": [
            {
              "text": "神経細胞同士の接合部であるシナプスを通じて、情報は伝達される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しいことを学習すると、脳内のシナプスの結合が強化されるという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "加齢に伴いシナプスの可塑性が低下するが、適度な刺激で維持できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "感情にせよ知覚にせよ思考にせよ人間のあらゆる意識は脳細胞のシナプス一つ一つの運動として捉えることができる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にこれはシナプスを構成する原子一つ一つの運動として四つの軸の座標系に置換でき、最終的には１と０の膨大な配列として表現され得る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイッチが入るように彼の脳のシナプスがオンになった。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
