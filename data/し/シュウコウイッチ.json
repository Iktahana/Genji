        "examples": {
          "standard": [
            {
              "text": "会議では、その提案について衆口一致で賛成の意見が出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "我々のチームは、新しいプロジェクトの方向性について衆口一致で進むことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、衆口一致だね。この計画でいこう！」とリーダーが言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここには秀吉との対立観念もなければ利害もないので、正直にみな羽柴様羽柴様とその徳を称え、小谷の藤吉郎どのといえば、衆口一致して、（あれは偉いそうだ……）という。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また毛利家との往来はますます頻繁を加えている」　ほとんど、これは訛伝でなく、いやいやながら信長もその事実を認めざるを得ないほど、衆口一致していた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
