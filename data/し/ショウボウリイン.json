          "standard": [
            {
              "text": "消防吏員は、法律に基づいて火災予防のための立入検査を行う権限を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「消防吏員」とは、階級を持つ消防職員を指す公務員としての正式な名称だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "消防吏員としての自覚を持ち、市民の模範となるような行動を心がける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "決して物ずきな少数学者の気まぐれな研究に任すべき性質のものでなく、消防吏員や保険会社の統計係の手にゆだねてそれで安心していられるようなものでもなく、国家の一機関として統制された研究所の研究室において徹底的系統的に研究さるべきものではないかと思われる。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
