        "examples": {
          "standard": [
            {
              "text": "歴史の資料によると、その巨大な運河は数万人もの囚人労働によって短期間で完成したという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "刑務所内での囚人労働の一環として、地元の名産品である木工玩具の製作が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人権団体は、強制的な囚人労働が生み出す不当な利益について厳しい批判の声を上げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの道路開発の重労働がもっぱら「懲役」と当時よばれた囚人労働によって行われたことを忘れてはならぬ。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが資本家どもの政変と陰謀的祝賀と僕らの次の餅のエピソードとの起源となったのだ―――八人に一人づゝ囚人労働の短縮を申しわたされ「祝」と書いた餅が僕らに二つづゝ配られた裾綿のちぎれた赤い筒袖を羽織りながら、みんなはツアーの「恩典」を話し合った―――八ヶ月………受けるか？",
              "citation": {
                "source": "餅の歌",
                "author": "――全農の林延造氏に――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
