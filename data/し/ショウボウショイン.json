        "examples": {
          "standard": [
            {
              "text": "消防署員が戸別訪問を行い、住宅用火災警報器の設置状況を確認している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "避難訓練の際、消防署員から消火器の正しい使い方について指導を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "緊急通報を受けると、消防署員は直ちに現場へ急行し、的確な処置を施す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ヘルメット姿の、あれは消防署員だろうか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車ポンプのエンジンが動きだし、消防署員はホースの筒口をとって身がまえました。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "十人のほかに、たくさんの警官や消防署員がやってきて、町から町をしらべまわったのです。",
              "citation": {
                "source": "黄金豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
