        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は軽やかなシフォンのスカーフを首に巻いて、エレガントな印象を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の結婚式には、風になびくシフォンのドレスが涼しげで人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "シフォンの生地は透け感があり、重ね着することで様々な表情を楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "蓬莱和子は、黒のシフォンヴェルヴェットのワンピースを着て、昨日、夫が買って来てくれた真珠の首飾りをしていた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シリア、パレスティナ、新ペルシャ地区、ダマスクス、エルサレム、クテシフォン、は彼らのものになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立ち姿――立像とむしろ言いたい、その不動の、黒いシフォン・ベルベットに包まれた照子の姿には、ぞっとするくらい、凄味があった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に自然の必然に抵抗するのは、自分の騾馬と蹴合いをしたクテシフォン＊の狂態を再び演ずることである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　プルタルコスの「いかに怒りを制すべきか」の中に、子供がかんしゃくをおこすと、見境なく何にでも食ってかかる話と共に、この剣士クテシフォンの話が出てくる。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また馬に乗れるなんてとても嬉しいし、たとえ他人の習慣だとしても、やりこなしてみせます」　見れば、大量のシフォンがあり、目の前で毛布がひらひらたなびいている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "モールとか蝶結びとか、シフォンには戸惑います。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
