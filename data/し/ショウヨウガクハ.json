        "examples": {
          "standard": [
            {
              "text": "アリストテレスが創設した逍遥学派では、広範な学問が探求された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古代ギリシャの哲学史において、逍遥学派はプラトンアカデメイアと並ぶ重要な学派である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の講義は、まるで現代に蘇った逍遥学派のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は歳を取っていてアリストテレス逍遥学派の支持者で最高のサークルに属していた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、テオフラストスはアリストテレスの後継者で逍遥学派の第２代学頭であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
