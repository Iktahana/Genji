        "examples": {
          "standard": [
            {
              "text": "その民事訴訟は、地元の州裁判所で審理されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アメリカでは、州裁判所と連邦裁判所とで管轄が分かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は州裁判所で無罪を主張し、証拠を提出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "奴は州裁判所の役人を連れてくるから、拒否できない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん州裁判所の執行官を有名パブへ置き去りにして、単身で示談しに来る。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、州裁判所の役人がパブに足止めされているか確認してくれ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
