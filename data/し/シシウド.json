        "examples": {
          "standard": [
            {
              "text": "初夏の山道を歩いていると、背の高い猪独活が白い花を咲かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "猪独活はセリ科の植物で、その力強い茎の姿は遠くからでもよく目立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこに咲いているのは猪独活かな？」と、植物に詳しい友人が指を差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "嘉門次はふと草原を切り靡けたような、路のあるのを見出して、太い短かい杖で、猪独活をあしらいながら、「熊が通った路だあ」と言った、草はよほどの重量を、載せたように、右に左に押し倒されて、その凹んだ痕が、峰の方へ、斜に切って、するすると登って行く。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんにたくさんあってだれにもいちばんに目につく「ししうど」と称するものでも、みんながはたして同じものかどうか子細に見ていると疑わしくなって来る。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
