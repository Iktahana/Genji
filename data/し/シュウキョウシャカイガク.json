        "examples": {
          "standard": [
            {
              "text": "宗教学科では、宗教社会学の視点から現代社会の宗教現象を分析する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マックス・ウェーバーは、宗教社会学の基礎を築いた重要な思想家だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宗教社会学の研究により、信仰と社会構造の複雑な関係が明らかになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このことは宗教社会学に就いてもそのままあて嵌まる。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "信仰の真偽内容と絶縁した宗教社会学は少なくとも宗教批判の出来る社会理論ではあり得ない。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識社会学と宗教社会学とは、夫々の価値論を中心とすることによって、初めて有機的連関に這入ることが出来る（認識論と宗教学との結合を実証したデュルケムの労作はこの点に就て重大な功績をもたらした）。",
              "citation": {
                "source": "現代唯物論講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
