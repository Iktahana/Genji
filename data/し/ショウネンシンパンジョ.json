        "examples": {
          "standard": [
            {
              "text": "少年審判所の建物は、威圧感を与えないよう温かみのある設計になっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "事件の真相を究明するため、少年審判所での審理が慎重に進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "少年審判所は、処罰よりも教育的な措置を優先する場所である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "またある人が不良少年の教化に特別の興味を感じて少年審判所に勤めていても、官制の関係上その勤務をつづけるかぎり、ある程度以上に官等も上らず俸給も上ることをえない。",
              "citation": {
                "source": "役人学三則",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "警察からすぐに少年審判所送りになって、八丈島の感化院へやられるのさ。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
