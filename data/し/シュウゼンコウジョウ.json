        "examples": {
          "standard": [
            {
              "text": "事故で大破したスポーツカーが、近所の修繕工場に運び込まれて解体作業が始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この修繕工場では、クラシックカーのパーツを特注で製作してくれる貴重なサービスがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "修繕工場から聞こえてくる火花の音と金属を叩く音が、職人の活気を感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二人の子供は、コムプレッサー、鍛冶場、変電所、見張り、修繕工場、などを見て歩いたが、その親たちは見当らなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、まだ出来上っていないが、波浪にゆれないように、鉄塔が水面につくところには、波浪平衡浮標というものをつけることになっているそうだし、飛行甲板の下につけることになっている専属修繕工場や住居室もでき上っていない。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
