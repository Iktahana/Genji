        "examples": {
          "standard": [
            {
              "text": "毎月発行される社内報には、会社の最新ニュースや従業員の活躍が掲載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、社内報の編集部で、記事の企画から取材、執筆までを担当していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この号の社内報、私の部署の活動が大きく取り上げられてるよ！」と、同僚が嬉しそうに教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「カラー写真で撮っても黒白のフィルムで撮っても、おなじに写る後藤美代子のファッション、と社内報に書かれたことがあります。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
