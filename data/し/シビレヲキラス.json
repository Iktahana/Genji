        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人がいつまで経っても来ないので、痺れを切らして先に店に入ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "担当者からの連絡がなかったので、痺れを切らしてこちらから電話をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の決断を待っていたが、あまりにも時間がかかるので、痺れを切らして別の方法を考え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "若ければ諦めをつけているが、もう中年へ差しかゝっているのに先が全く閊えていると思うから痺れを切らす。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そろそろ旦那が痺れを切らすんじゃないかと心配ですな。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫が好かんやつはきらいさ」「それはそうだろうが、もっとはっきりと区別できないかな」　ケンは伯爵の返答にしびれをきらす。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
