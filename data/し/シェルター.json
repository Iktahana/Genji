        "examples": {
          "standard": [
            {
              "text": "激しい雨から逃れるため、近くの公園にある小さなシェルターに駆け込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害時に備えて、避難所となる地下シェルターの場所を事前に確認しておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "野生動物の保護施設では、傷ついた鳥たちが安全なシェルターで回復を待っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで巨大な地下シェルター作りを試みて失敗し、それにもめげず妻子から複数の妾総ぐるみで最も安全性の高いと信じるブラジルへの移住計画を腕力で推し進める。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
