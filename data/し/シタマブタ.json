        "examples": {
          "standard": [
            {
              "text": "「昨夜は遅くまで起きていたから、下まぶたにクマができてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「アイクリームを下まぶたに優しく塗って、寝る前にしっかり保湿しよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「先生、この下まぶたの腫れは、アレルギーのせいでしょうか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は、下まぶたに大きな汚点のある袋のついた眼を細め、マッチを持ち添えスパスパ火をよびながら、「や」と曖昧に声をかけた。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰色の上にすこし黄がかってドロリとした大きな二つの眼が愛嬌の笑いを下まぶたのしわにまでたたえながら二人の女の上にすえられた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬に伝わる涙が、風圧で、下まぶたのすぐ下から、つうっと、横に流れる。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "のり子のふっくりしたまぶたや顎のところが、上簇まえの蚕の肌のような鈍い透明な色になった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
