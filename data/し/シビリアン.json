          "standard": [
            {
              "text": "軍人ではない一般のシビリアンとして、戦争が早く終わることを切に願っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "シビリアンであっても、紛争地帯に立ち入る際には防弾チョッキの着用が推奨される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はシビリアンの立場から防衛政策を厳しく批判し、多くの支持を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "九月十七日（日）　サイパンが陷落する前、閣議で青木大東亞相が、「シビリアンは死なせないで、生命を全うさすべきだ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語に飜譯すれば「シビリアン」（市民）で、直ちに諒解されるところであるが、まだ使ひなれぬ字句なのでもの珍らしく感ぜられる。",
              "citation": {
                "source": "新憲法の解説",
                "author": "解説",
                "note": "青空文庫"
              }
            }
          ]
        }
