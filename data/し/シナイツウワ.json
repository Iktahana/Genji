        "examples": {
          "standard": [
            {
              "text": "友人との長電話で、市内通話なのに気がつけば長時間話してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は市内通話でも料金がかかったが、今は無料のサービスが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社の電話は、基本的に市内通話のみ可能となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "外国人との電話は、市内通話でも苦手なところへ、相手がひどく急きこんでゐて、おまけにクロワート訛りがひどいらしく、最初のうちは殆ど一ことも聴き取れない。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            }
          ]
        }
