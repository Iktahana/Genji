        "examples": {
          "standard": [
            {
              "text": "「え、このAI、日本語も理解できるの？すごいね！まるで『自然言語』みたい！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっと、このマニュアル、専門用語ばっかりで全然わかんないよ。もっと『自然言語』で説明してほしいなあ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「子供が初めて話す言葉って、本当に愛おしいよね。あれこそが、彼にとっての最初の『自然言語』なんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "逆に普段人間が使っている言葉、自然言語に近く、理解しやすいというニュアンスを、「高級」の二文字は表わしている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の学問は、最初、言語に対する深い愛情から起つたものであるから、自然言語の分解を以て、民俗を律しようとする傾きが見えぬでもない。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
