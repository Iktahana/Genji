        "examples": {
          "standard": [
            {
              "text": "年末には、たまった書類整理をしてオフィスをすっきりさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な書類を見つけやすくするために、定期的な書類整理が欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は書類整理の達人で、どんな書類でもすぐに探し出すことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はそれを特別に大事なものに思ひ、余り大事にし過ぎ、家宅捜索など受けるやうな場合に没収されてはと、別置きにして居たものだから、書類整理箱のどの抽出しを調べて見ても、今は見付からない。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁のものとは対照的に、床には美しいトルコじゅうたんが敷かれ、ソファ、革製のアーム・チェア、書類整理用の棚がある。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
