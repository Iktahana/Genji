          "standard": [
            {
              "text": "超音速旅客機が通過する際、地上では衝撃波による大きな騒音が発生する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "爆発によって生じた衝撃波が窓ガラスを粉々に砕き、周囲の建物に甚大な被害を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宇宙船が再突入する時、機体の前方には非常に高温の衝撃波層が形成される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ソニーのＳＭＣ―70は、開発をほぼ完了した段階でＰＣの発表という衝撃波に見舞われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚愕の第一衝撃波が過ぎ去ると、レックミア侍従は持ち前の冷静さを取り戻した。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
