      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anthology (of poems)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は古今東西の名詩を集めた豪華な詞華集を、毎日少しずつ読み進めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その若手詩人の作品は、権威ある現代詩の詞華集に収録されることが決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "詞華集をめくっていると、今の自分の気持ちにぴったりの一行に出会うことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "サッフォの熱い想ひと、ギリシャ詞華集のあの強靱なやさしさとは、共にその詩に具はつてゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古文の絶妙なる一部分を詞華集に収めて、研究翫味する時は、原文のほうが好かろう。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる古日本の詞華集よ、おんみの上に、明障子に囲はれたる平和あれ！",
              "citation": {
                "source": "鳥獣剥製所",
                "author": "一報告書",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすべての詞華集とカルピスソーダ水とを嫌ふ。",
              "citation": {
                "source": "橋の上の自画像",
                "author": "富永太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
