  {
    "uuid": "56f8d09d-f8b3-5223-aaab-1ac8fb79d8ac",
    "entry": "詞華集",
    "reading": {
      "primary": "しかしゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
