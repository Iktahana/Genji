          "standard": [
            {
              "text": "バイクの消音器を改造して大きな音を出すのは、道路交通法違反になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "中古で購入した車の消音器が錆びていたため、新しいものに交換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "消音器の内部構造を工夫することで、排気効率と静粛性を両立させている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "隘路を吹き捲くり唸りを上げ笛のように叫び立てる風と消音器を下ろした発動機の爆音の中、ダンフォースと私は専ら怒鳴り声で感銘深い一瞥のことを話し合った。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
