        "examples": {
          "standard": [
            {
              "text": "壁紙を貼る作業では、糊刷毛を使って均等に糊を塗っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供と一緒に工作をするため、糊刷毛と糊を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "糊刷毛が汚れたら、すぐに水で洗ってきれいにしておくのが長持ちの秘訣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "糊刷毛かなにかでもって書いたものらしく、仰山に肉の太い文字で、そのうえ目茶苦茶ににじんでいた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにまた、碧い包装紙を拡げ、検査された完全紙の層を、としりとしとしと載せ、重ねて、揃えて、整えて、またパタパタと四方から包み、サッサッと糊刷毛で掃き、レッテルを貼り、押し、叩き、次の荷造場へ送る中年おんなの活躍もさることだが、彼女らもまた同じ種の高麗鼠である譏りは徹頭徹尾｜免れない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "トン／＼トン／＼と店の方で打つ経師屋らしい糊刷毛の音は、寝胼胝のあたつた内儀さんの身体に響けて来る。",
              "citation": {
                "source": "死の床",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "糊刷毛は何処へやつた。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は糊刷毛を手に持ったまま耳を澄した。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "糊刷毛のような白い毛を羽根の先に残しているだけで、全くの丸裸になってしまっている。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
