        "examples": {
          "standard": [
            {
              "text": "彼は新しいプロジェクトが成功して、今日はすっかり乗り乗りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試合に勝ったチームは、みんな乗り乗りで勝利を祝っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お気に入りの音楽を聴きながら、私は乗り乗りで家事をこなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いっ刻おくれりゃ、いっ刻よけいむごい目にも会わなきゃならねえに違げえねえんだから、ひと乗り乗り出しておくんなせえまし、後生でござんす！",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語のアリスやキャラとも、語る相手にも、つかず離れず少し距離と取りつつつらつらと語るキャロルの筆致は、乗り乗りで楽しみにあふれたものでありながら、どこか落ち着いていて内省的でもあり、時に冷淡ささえ感じられます。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            }
          ]
        }
