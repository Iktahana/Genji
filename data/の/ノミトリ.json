        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は学生時代からの飲み仲間と、今でも月に一度は集まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい街に引っ越してきたばかりで、まだ気の合う飲み仲間がいない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "久しぶりに会った飲み仲間と、学生時代の思い出話に花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "」「そこまでは分りませんが、大和という天眼通がノミ取り眼で探しても出てこなかった真珠ですから、この行方は謎ですね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠くて床に入るのに、チクリと体がビクつく位やられるので、むっくり起き上り、永年愛用の水色エナメルはげかかりの円い首ふりスタンド（竹早町以来の）ふりかざして、文字どおりノミ取りまなこを見はってつかまえます、わたしの眼もその位になったとはお目出度いと、目白のお医者様は祝賀をのべて下さいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノミ取り屋さん」　気取った声で呼びこんで、タマちゃんや、ミイちゃんのために、ノミを取らせる。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノミとりまなこを見はると、眠けさめてしまって過敏になって、体中チカチカあついようになってノミも食いあき、こちらも疲れると眠るのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
