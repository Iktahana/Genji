        "examples": {
          "standard": [
            {
              "text": "電車の乗り口は、いつも混雑している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バスが止まったら、後ろの乗り口から乗車してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ドアが閉まる直前に、彼女は慌てて乗り口に駆け込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "上野駅の電車の乗り口で呆んやりしていると、何処へ行くのかと話しかけて来た男がいた。",
              "citation": {
                "source": "淪落",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
