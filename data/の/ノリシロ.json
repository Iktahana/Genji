        "examples": {
          "standard": [
            {
              "text": "箱を組み立てる際は、糊代をしっかりと貼り合わせるのがコツだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "設計図には、糊代の幅が正確に記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この紙工作は糊代が小さいので、貼るのが難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と、書いた紙が、糊代りに使った飯粒のボコボコを見せて、貼らさってあった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
