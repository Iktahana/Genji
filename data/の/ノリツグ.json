        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大阪駅で新幹線を乗り継ぎ、実家へと帰省した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飛行機が定刻に着いたおかげで、スムーズに次の便に乗り継ぐことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "慣れない海外の空港で、言葉の壁がありながらも何とか乗り継ぐことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここで私達はいままでの馬車を降りて、遠野から来ている馬車に乗り継ぐのである。",
              "citation": {
                "source": "遠野へ",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、モスク※を通過する旅客がそうするように、その日の夜シベリア鉄道にのりつぐまでの時をすごすために佐々一行を、大使館へ案内しようとした。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多計代が、シベリア鉄道へのりつぐためにモスク、そこに藤原威夫がいる、と、その一つに焦点を合わせたようにして、彼と連絡したのだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白絹も、広島でのりつぐのであった。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
