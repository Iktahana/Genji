        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私の兄はのんびり屋で、いつも自分のペースを崩さない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "締め切りが迫っているのに、のんびり屋の彼はまだ焦る気配がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チームには、せっかちな人と合わせてのんびり屋も必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ことに、こんな熱帯の孤島では、ビール樽にでもなったつもりで、のんびりやることだ」　そういって玉太郎の両肩にかるく手をおいた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、スペクタクル本来の要素はどうかと云へば、個々の材料、例へば、装置とか衣裳とか、俳優とかは別に取り立てゝ云ふほどのことはなく、寧ろ甚だお粗末であるが、最も注意すべきことは、俳優が下手は下手なりにのんびりやつてゐること、鯱こばつてゐないことである。",
              "citation": {
                "source": "ロツパの「楽天公子」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんびりやっているということ、家が淋しくないということにも。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "報知のジャズまつり、昼夜、三益と歌ふ（100）、ハリキリとアホかいな、オーケストラと合せてなかったので、ひどくのんびりやられてクサる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
