        "examples": {
          "standard": [
            {
              "text": "この古くて重い自転車は、坂道が多くて本当に乗りにくい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めて乗るタイプのバイクだったので、最初は少し乗りにくく感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "観光地のレンタルサイクルは、サドルの位置が合わなくて乗りにくいことがよくある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "とは言え、この乗りにくい橇が私の旅の心を喜ばせた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "――下駄を履いた竹馬なんてのは、乗りにくいネ」　見ると、竹馬の下には、犬の足のように彫った木の栓まで付けてあるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の足跡",
                "note": "青空文庫"
              }
            }
          ]
        }
