        "examples": {
          "standard": [
            {
              "text": "新幹線から在来線への乗り換え場は、少し離れた場所にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "混雑した乗り換え場で、友だちとはぐれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "広々とした乗り換え場には、ベンチがたくさん設置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小さな停留場には一切止まらず一気に走って、重立った停留所や乗り換え場所だけ拾って行く。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶はここに暗黙のうちに敷かれたレールの両極は一致すべきものと信じていたが、今のところ、いかなる国際列車もまだ乗り換え場所が幾つも必要だと思わざるを得なかった。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
