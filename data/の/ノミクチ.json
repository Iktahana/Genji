[
  {
    "uuid": "b591b9ad-54f3-573a-90ed-e7e3d15439bd",
    "entry": "飲み口",
    "reading": {
      "primary": "のみくち",
      "alternatives": [
        "のみぐち"
      ],
      "is_heteronym": false
    },
    "grammar": {
