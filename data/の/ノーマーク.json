        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "サッカーの試合で、相手チームのエースストライカーがノーマークになってしまった！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「マークをしっかり！ノーマークは一人も出すなよ！」と監督は選手たちに檄を飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、ディフェンスの隙をついて、ノーマークの味方にパスを出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
