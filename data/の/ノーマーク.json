        "examples": {
          "standard": [
            {
              "text": "警察は、その怪しい人物がノーマークだと思っていたが、実は裏で糸を引いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの株は、まだノーマークだから、今のうちに買っておくといいかもしれない」と投資家は囁いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、周りの注目を浴びずに、ノーマークで計画を進めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
