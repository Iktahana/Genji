          "standard": [
            {
              "text": "「ノーモア、戦争！」と平和を訴えるデモ隊が街を練り歩いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、二度とあんな失敗はしないと心に誓い、「ノーモア！」と叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ノーモア、この苦しみ！」と患者は痛みに耐えながら言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "どうして僕は原子爆弾のことばかり書いたり考へたりするのだらう、ノーモア・ヒロシマ、ノーモア・ヒロシマ……と。",
              "citation": {
                "source": "長崎の鐘",
