        "examples": {
          "standard": [
            {
              "text": "昔、ノースウエスト航空を利用してアメリカへ行ったことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はノースウエストの貨物便で荷物を輸送した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の出張では、ノースウエストの路線を使う予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ノースウエスト航空会社のＤＣ四型という四発機。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日の午前十時に丸ビルのノースウエスト航空会社へ集合することになっていた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑草が必ずノースウエスト航空会社の窓の外で立止って中をのぞきこむのは、その中に高峰秀子と乙羽信子の両嬢がいるためだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノースウエスト機も、日航機も、氷河地帯のすぐ近くの海上を飛ぶからである。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェーンはハワイ島ヒロ行きのノースウエスト機に飛び乗った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノースウエスト、ハマートンガーデン二十四番地だ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
