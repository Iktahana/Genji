          "standard": [
            {
              "text": "ノースウエスト航空は、かつて日本の主要都市とアメリカを結ぶ重要な航空会社だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ノースウエスト航空の機内で、フライトアテンダントが親切に対応してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行雑誌でノースウエスト航空の特別運賃が紹介されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ノースウエスト航空会社のＤＣ四型という四発機。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日の午前十時に丸ビルのノースウエスト航空会社へ集合することになっていた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑草が必ずノースウエスト航空会社の窓の外で立止って中をのぞきこむのは、その中に高峰秀子と乙羽信子の両嬢がいるためだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
