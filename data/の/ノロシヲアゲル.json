        "examples": {
          "standard": [
            {
              "text": "救援隊に自分たちの居場所を知らせるため、狼煙を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦国時代、敵の接近を知らせるために山頂で狼煙を上げるのは一般的な方法だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遭難したパイロットは、煙を出すことで狼煙を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "クロさえ蛾次郎の手からとり返せば、のろしをあげるまでもなく、あの偉大なつばさで一はたきで、寒松院の並木にいる味方へ、このようすをお知らせにも飛んでいける。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
