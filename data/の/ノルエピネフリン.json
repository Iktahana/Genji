        "examples": {
          "standard": [
            {
              "text": "ノルエピネフリンは、神経伝達物質の一つである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ストレス応答において、ノルエピネフリンが重要な役割を果たす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医師は、患者のノルエピネフリンレベルを注意深く監視した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "精神を集中させ、脳からノルエピネフリンの分泌が促進されることを念じながらオーラの発散を活性化させる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はいつになくノルエピネフリンの調子がいいらしい。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファ波、オーラ、ノルエピネフリン、この三つの要素のうちどの二つを数量化して関数を作ってみても、微分すれば必ず正になる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
