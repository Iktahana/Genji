        "examples": {
          "standard": [
            {
              "text": "最近のノート型PCは、デスクトップ並みの性能を持つものも増えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このノート型パソコンは軽くて持ち運びやすく、出張先での仕事に最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私はカフェで集中して作業するために、いつも小さなノート型デバイスを持ち歩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第一は、ノート型のもの。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりここに問題のあるＭＳ―ＤＯＳを使っている以上、スタイルがノート型になったとしても、それは手段を目的に先行させた谷川ユズルにおけるバンドのようなものなのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一キログラム切るノート型でデジタル携帯電話を積んだ『安い』マックを、あなたがフェローという顧問的な立場にあるアップルコンピュータはいつになったらだしてくれるのかいな」　標準のしがらみを断てば、新しい技術には飛び移りやすい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
