        "examples": {
          "standard": [
            {
              "text": "海賊たちは商船に乗り取り、積荷を奪い去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "敵の城に乗り取り、重要な情報を手に入れる計画だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつての英雄は、一人で多くの城を乗り取り、名を馳せたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、うちの主人の話では、横田がセメント会社を乗り取る時に、株式のことやなんかで、ずいぶんいかがわしいことをしたらしいの。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "久左衛門たち一族は、持て余したか、うろたえたか、伊丹城へも戻らず、尼ヶ崎を乗り取る術もなく、（身こそ大事）　と、ついにその醜劣な性根をあらわして、思い思いにそこから逃亡してしまった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
