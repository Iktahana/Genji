    "definitions": [
      {
        "index": 1,
        "gloss": "to help a long-term employee to establish a branch of the same shop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "親方は、一番弟子に店の一部を任せ、のれんを分ける準備を進めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は修行を終え、いよいよ師匠からのれんを分けてもらうことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年勤めてくれた職人に、独立してのれんを分けてやるのが、私の夢だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さてこうなると店員のために主家ののれんを分けることは甚だ困難で、また分けて見ても分け甲斐のないものになった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどういうことかというと、同一な特長を持った店の対立は許されないということが考えられ、すなわち支店や分店は必要でない――のれんを分ける余地は現在ではもはやないということなのである。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
