        "examples": {
          "standard": [
            {
              "text": "ノーベル化学賞は、毎年科学の発展に大きく貢献した研究者に贈られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、画期的な新素材の開発でノーベル化学賞の有力候補とされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ノーベル化学賞の発表は、いつも科学界の大きな話題となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼の科学上の偉大な仕事に対しては、諸所の学会から表彰を受けましたが、特に一九〇八年にはその放射能に関する研究に対してノーベル化学賞が授けられ、学界最高の栄誉をにないました。",
              "citation": {
                "source": "ロード・ラザフォード",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "単分子層の研究でノーベル化学賞を貰ったラングミュア老先生までが、中間子の湯川さんの噂をするのにはちょっと驚いた。",
              "citation": {
                "source": "湯川秀樹さんのこと",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
