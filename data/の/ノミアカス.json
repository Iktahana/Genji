        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学生時代の友人と再会し、昔話に花を咲かせながらホテルの部屋で朝まで飲み明かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事の悩みを抱えた後輩に付き合い、バーのカウンターで静かに飲み明かす夜もある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "リーグ優勝という最高の結果を分かち合うため、ファン同士で一晩中飲み明かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鰯のヌタに蒲鉾が肴だったというが、二人とも長酒で、そんな場合はいつも徹宵飲み明かすのが習慣だったので、娘さんは肴に心配をして近所の乾物屋から干鰯を買って準備していたというね。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまた一晩中、秦淮あたりの酒家の卓子に、酒を飲み明かすことなぞもある。",
              "citation": {
                "source": "奇遇",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一晩飲み明かすに相違ない。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は徹夜で飲み明かす。",
              "citation": {
                "source": "血ぬられた懐刀",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはお誂え向きじゃないか、本当に飲み明かすか」　脇田信造がそう云うと、笑い声がどっとあがった。",
              "citation": {
                "source": "山椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲らしめのため、今夜はこゝで飲み明かす」「困るよ、そんな予定で出て来たんじゃない。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
