        "examples": {
          "standard": [
            {
              "text": "愛車のノーズが少し上向きで、威厳のある佇まいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "犬が興奮して、私のノーズをクンクンと嗅いできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飛行機は滑走路を離陸し、ゆっくりとノーズを上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ストーニー・ポイントの攻撃で戦死したという人もいるし、アントニーズ・ノーズのふもとで嵐にあって溺れ死んだという人もおるがね。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "（クランチャー氏自身はわが主の紀元のことをいつもアナ・ドミノーズと言っていた。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミノーズ　　二十八箇の牌子を使って二人または数人でやる遊戯。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをわがクランチャー君はアナという名の女がドミノーズを発明した年という意味だと思っていたのである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボードの前部に体重をかけたノーズ・ライディングだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さく空中にアーチを描いた赤いボードは、ノーズから海に落ちて波間に軽く浮かんだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
