        "examples": {
          "standard": [
            {
              "text": "ノースウェスタンの地方には、手つかずの自然が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はノースウェスタン地方の出身で、冬の寒さには慣れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "探検隊はノースウェスタンを目指し、未踏の地を進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしそれは先年までノースウェスタン大学の教授だったバッシン氏の夫人であった。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トムは、ノースウェスタン大学の物理を出て、修士課程は、イリノイ大学でやった。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、娘は慶応の二年生になっていたので、ノースウェスタン大学の二年に編入を頼んだ。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め二年間一緒に暮したが、私たちが帰国する時に、上の娘二人はノースウェスタンの寄宿舎に残してきた。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノースウェスタンで学生課程を終えた後、修士をどこでやるか、大分迷ったらしい。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
