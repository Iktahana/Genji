        "examples": {
          "standard": [
            {
              "text": "終電を乗りはぐれてしまい、タクシーで帰る羽目になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "道を間違えて時間がかかり、最終便を乗りはぐれてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大雪の影響でバスが運休になり、次の交通手段を乗りはぐれて困った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここらの車夫は百姓の片手間なので、前から頼んで置かないと乗りはぐれることがあるそうです。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は車が待たせてあるから好いが、己はぐずぐずすると電車に乗りはぐれる。",
              "citation": {
                "source": "里芋の芽と不動の目",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
