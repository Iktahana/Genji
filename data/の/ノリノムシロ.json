          "standard": [
            {
              "text": "お寺では、僧侶が法の筵で人々に教えを説いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "師は法の筵で、多くの弟子たちに悟りの道を指し示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの場所は、かつて多くの人々が法の筵に集い、信仰を深めた聖地だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さすがに貴公子らしいと後にただようほのかな人格のかおりを禅房の人々はゆかしく思いあうのであったが、誰も、その人と同じ人間が先ごろから数日のうち道場の聴法の筵に俗衆のうちにまじっていたとは気のつく者はなかった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
