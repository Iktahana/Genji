    "definitions": [
      {
        "index": 1,
        "gloss": "leaving a pub, restaurant, etc. without having paid for one's drinks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "苦手な味の酒だったので、コップに半分ほど飲み残してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もったいないから、飲み残した分は私がもらおうか？」と友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、どんなお茶でも最後まで綺麗に飲み干すので、飲み残すことは滅多にない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "飲み逃げや喰い逃げは無論全部共通である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きながらしかし、店の内が変な事に気が附いて涙のこぼれてゐる顔をキヨロつかせる）……ウエーン、逃げやがつた／＼、畜生、飲み逃げだあ。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、飲み逃げするほど落ちぶれちゃあいねえ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを顔へぶつけられて、居酒屋のおやじが、痛いッといいながら両手で顔をおおうと、暖簾の内から覗いていた客の大勢が、「ひでえ奴だ」　と、又八の行為を憎み、「飲み逃げ奴」　罵ると、いっせいに、「――たたんじまえ」　と、外へ出て来た。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
