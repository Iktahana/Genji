        "examples": {
          "standard": [
            {
              "text": "彼の小説は、その革新的なスタイルから、ノーベル文学賞の有力候補と目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか自分がノーベル文学賞をいただけるとは、夢にも思っていませんでした」と受賞者は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ノーベル文学賞の発表を、世界中の文学愛好家が固唾を飲んで見守った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一九二〇年八月豊島与志雄付記――ロマン・ローランは「ジャン・クリストフ」を中心にする著作によってノーベル文学賞を授与されたが、その後、「魅せられたる魂」の大作をはじめ幾多の著作があり、一九四四年末に病歿した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした文学上の活躍が認められて、一九〇九年には、女の人としてはじめての名誉であるノーベル文学賞を受けました。",
              "citation": {
                "source": "「ニールスのふしぎな旅　上」まえがき",
                "author": "矢崎源九郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした文学上の活躍が認められて、一九〇九年には女の人としてはじめての名誉であるノーベル文学賞を受けました。",
