        "examples": {
          "standard": [
            {
              "text": "私は昔から勉強の飲み込みが悪くて、新しい公式を覚えるのにも人一倍時間がかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「彼は決して飲み込みが悪いわけではないが、納得するまで先に進まない慎重派なんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飲み込みが悪くて迷惑をかけている自覚があるから、毎日予習と復習を欠かさず行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "広間の戸が閉まってはいましたが、鍵はかかっておらず、患者を中に入れた手伝いの者は新入りの少年で、飲み込みが悪いのです。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は子供たちに飛びつくようにして、どなりつけたり、さとしたり、人の大勢いる前で踊り方や歌い方を教えたり、なんのためにこんな事をするのか言い聞かせたりしたが、子供たちの飲み込みが悪いのに業を煮やして、彼らをたたくのであった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
