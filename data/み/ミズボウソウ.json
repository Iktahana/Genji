        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供の頃に水疱瘡にかかり、全身に赤い発疹ができてかゆくて大変だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "息子が水疱瘡の予防接種を受けたので、一安心だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "保育園で水疱瘡が流行していると聞き、注意を促す張り紙がされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、子供が銭湯で水疱瘡という奴をしょって来た。",
              "citation": {
                "source": "芝、麻布",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがての果てに、フェージャは水疱瘡にかかり、そのうえに感冒性の胸の痛みが併発して、そこで少年は病いの床についた。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は昔し一番目の娘に水疱瘡の出来た時、健三の態度が俄かに一変した実例を証拠に挙げた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後水尾上皇がまだ天皇の位におられたときに水疱瘡を患われた。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが水疱瘡を治すには、おきゅうがいいということであったのだが、現人神たる玉体におきゅうをすえるということは許されないという異議が出たために、ついに譲位をなさって、おきゅうの治療を受けられた。",
              "citation": {
                "source": "「人間宣言」のうちそと",
                "author": "前田多門",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
