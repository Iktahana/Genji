        "examples": {
          "standard": [
            {
              "text": "このプロジェクトは優先順位が低いため、まだ未着手の状態だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山積みの宿題の中で、最も難しい作文だけが未着手で残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "未着手のタスクを一覧にして、週明けのスケジュールを組み直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ポーツマウスの条約に挙国の不平が沸騰した時に偶然東京朝日の編輯局で書いた「ひとりごと」と題する桂首相の心理解剖の如きは前人未着手の試みで、頗る読者に受けたもんだ。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あるいは前人未着手でないかも知れぬが、これほど巧みにこれほど小気味｜能く窮所を穿ったものは恐らく先人未言であったろう。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪崩の恐ろしさ、吹雪の恐ろしさ、雪が人間の生活に及ぼす影響特に生理上の障害等々を数えあげれば、その一つの項目についても優に一冊の書物になり得るような研究題目のみであるが、残念ながら現在の所ではまだ殆ど未着手の状態である。",
              "citation": {
                "source": "雪",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
