          "standard": [
            {
              "text": "アフリカの原住民は、蜜教の行動を観察して蜂の巣を見つけるという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蜜教が巣の場所を教えてくれるという民間伝承は、とても興味深い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ガイドブックには、珍しい鳥である蜜教の生態が詳しく紹介されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "高野山にありて蜜教を学び、後生国に皈り大浦の蓮花寺に住し、行脚して越後に来り、三嶋郡｜野積村里言のぞみ海雲山西生寺の東、岩坂といふ所に錫をとゞめて草庵をむすびしに、貞治二年癸卯十月二日此庵に寂せり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
