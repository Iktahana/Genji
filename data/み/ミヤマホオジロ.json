        "examples": {
          "standard": [
            {
              "text": "茂みの奥から、深山頬白の澄んださえずりが聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深山頬白は、頭の上の黄色い冠羽がチャームポイントの可愛らしい鳥だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "バードウォッチングの最中、運良く枝の先に止まった深山頬白を双眼鏡で捉えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "深山頬白鳴きかへる十六夜薔薇の葉がくれに、またもひと本見出しては、『今日』を祝ひの花の環に。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳をすませば瑠璃鳥、深山頬白、くろつぐみ、駒どり、ひよどり、また昼時鳥までが、谺するばかり啼き交わしているのだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
