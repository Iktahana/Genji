        "examples": {
          "standard": [
            {
              "text": "第二次世界大戦後、GHQ内に設置された民間情報教育局は、日本の社会改革に大きな影響を与えました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この研究では、民間情報教育局が発行した資料を分析し、当時の占領政策の実態を明らかにします。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "国立公文書館には、民間情報教育局に関する貴重な記録が数多く保管されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一九四七年八月十一日民間情報教育局新聞課長インボデン少佐の名によって絶滅の方向が示された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在は著作権が既に消滅している著者のもの、および原著者から翻訳発行の許可があってＧＨＱの民間情報教育局がそれを承認したものに限られている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
