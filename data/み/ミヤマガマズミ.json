        "examples": {
          "standard": [
            {
              "text": "秋になると、深山莢蒾の枝には宝石のような真っ赤な実がたわわに実る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深山莢蒾の白い小さな花が、初夏の山道に明るい彩りを添えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭木として植えた深山莢蒾が、季節ごとに異なる表情を見せてくれるのが嬉しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "同属中の別の種類、例えばミヤマガマズミなどは奥山にも産すれど、ガマズミは畢竟里近い樹で断えて深山にはこれを見ない。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
