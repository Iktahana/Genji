        "examples": {
          "standard": [
            {
              "text": "冬になると、大陸から渡ってきた深山烏の群れが電柱にびっしりと止まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深山烏は、嘴の付け根が白っぽくなっているのが一般的なカラスとの見分け方だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "田んぼのあぜ道で、深山烏が熱心に土の中の虫を探してついばんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "教会の高いゴシック式の尖塔はこの木のうえにすっくりと聳えたち、いつも深山烏や烏がそのあたりを舞っていた。",
              "citation": {
                "source": "寡婦とその子",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに数世紀のあいだ巣をつくっていた深山烏を邪魔するといけないからである。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
