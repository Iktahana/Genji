        "examples": {
          "standard": [
            {
              "text": "ボクシングのミドル級タイトルマッチが、今夜ラスベガスで開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はミドル級とは思えないほどのスピードと、重量級並みのパンチ力を兼ね備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "減量に苦労した甲斐あって、無事にミドル級の規定体重をパスすることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それからミドル級の勝ち抜き戦になり、終りのヘビー級となると一対一か、せいぜい三者対立くらいで勝敗を争うことになる。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
