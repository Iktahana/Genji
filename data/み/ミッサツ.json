        "examples": {
          "standard": [
            {
              "text": "要人を密殺する計画が、極秘裏に進められていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の闇には、多くの密殺された人物の記録が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "敵国のスパイは、任務遂行のために標的を密殺した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「……壕舎ばかりの隣組が七軒、一軒当り二千円宛出し合うて牛を一頭……いやなに密殺して闇市へ売却するが肚でがしてね。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで豚を飼って、密殺して食べていられたのとちがいますか」「君もしつっこい男だね。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直にいってくだされば、密殺のほうは、大目にみてあげます」「そういうことなら、この事件は、永久にしめくくりがつかないだろうよ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "農林省の課長までしたひとが、豚の密殺をしたりするかどうか、考えたってわかるでしょう。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
