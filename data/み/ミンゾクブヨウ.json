        "examples": {
          "standard": [
            {
              "text": "収穫を祝う祭りのハイライトは、村人全員で輪になって踊る賑やかな民俗舞踊だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は世界各地の民俗舞踊を研究しており、来月はスペインのフラメンコを調査に行く予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台で披露されたダイナミックな民俗舞踊に、観客席からは惜しみない拍手が送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "能自身にも、石橋系統以外の民俗舞踊式の獅子のあつた事を示してゐる。",
              "citation": {
                "source": "獅子舞と石橋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして民謡試聴会場に這入ると必、何か農耕と関係の深い民謡や民俗舞踊を見せて貰ひました。",
              "citation": {
                "source": "東北民謡の旅から",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民俗舞踊民謡が、まづ地方生活を匂はしくするはずの時が来向うてゐるのである。",
              "citation": {
                "source": "民俗芸能の春",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民俗舞踊に於いての採集の態度で、舞踊家もすゝんでくれてこそ、古典の復活も意義を生じてくる。",
              "citation": {
                "source": "歌舞伎とをどり",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "タラントの民俗舞踊は「タランテラ」でありこの地区にいるクモが「タラントゥラ」である。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
