        "examples": {
          "standard": [
            {
              "text": "占領軍から任命された民政長官は、現地の文化を尊重しながらインフラの復旧を指揮した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "激しい戦闘が終わった後の瓦礫の山を前に、民政長官は復興への決意を新たにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "民政長官の交代に伴い、厳しい外出禁止令が緩和されるという噂が広まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "印度産の極上品よりもズット芳香の高い、味の美い烏龍茶を一つ毛唐に宣伝してみろってえ、その時の民政長官の男爵様で、後藤新平てえ方が……ヘエ。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の佐久間台湾総督と内田嘉吉民政長官とが、生蕃事件で退いた後を引受けた安東貞美総督は、養家の叔父に当っていた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして民政長官に選ばれたのが下村宏君であった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
