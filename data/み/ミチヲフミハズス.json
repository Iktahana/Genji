        "examples": {
          "standard": [
            {
              "text": "悪い仲間と付き合って、彼はとうとう道を踏み外してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度道を踏み外すと、元の生活に戻るのは難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "親は子供が道を踏み外さないよう、常に目を光らせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そういう歩行中でも彼の思索に探り入る習慣は立派な鍛錬となって、決してわきの刺戟によって思索の軌道を踏み外すようなことはなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断して林道を踏み外すと全身雪の中に埋没してしまう。",
              "citation": {
                "source": "釜沢行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
