        "examples": {
          "standard": [
            {
              "text": "毎朝、母が私の髪を綺麗に三つ編みにしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は赤いリボンで三つ編みの先を結び、鏡を見て微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小麦を収穫した後、茎を三つ編みにして飾りを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三つ編みにしたり、おさげにしたり、肩のへんでゆらゆらさせることが面倒で、朝起きても櫛を使うことは滅多になかった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっぱしのトリガーセンが女の尻に敷かれ、髪を三つ編みに編まれてたまるか。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼女の頭を抱えて三つ編みの真ん中あたりの髪にキスをした。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼は小さな三つ編み髪とロケットを欲しがってるんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にあれを返してあげなきゃ、あれは暖炉の上だな」　ウージェーヌは灰色がかったブロンドの髪を三つ編みにした鎖を取りにいった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
