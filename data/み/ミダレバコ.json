        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "洗濯前の衣類は、乱れ箱に入れておく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の部屋には、おしゃれなデザインの乱れ箱が置いてあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乱れ箱が満杯になったら、洗濯する日だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いや、こうしてはいられない、洋服はどこにあるのでしょう」　榻の枕元の台の上に乱れ箱に入れて洋服やシャツが入れてあるのが見えた。",
              "citation": {
                "source": "港の妖婦",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御衣服、櫛の箱、乱れ箱、香壺の箱には幾種類かの薫香がそろえられてあった。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゃんと、台所わきの行燈部屋に、乱れ箱が出ている。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンは、乱れ箱に入れてある衣類を取り、親方に着せた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白粉ぎたない女達が、鏡台をならべて、脱ぎ捨てた衣裳のなかに行儀わるく坐っている所へ、すしを食べ散らした錦出の大皿や、たばこ盆や、団扇や、乱れ箱やらが雑然と同居していて、舞台と楽屋の間を往来する道具方の黒い足が、それをまた感傷なくズカズカと踏んづけて通ります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たみは、火を放けるために後へ残って、反古や木屑や乱れ箱などを、手当り次第に、部屋の中ほどへ積み上げる。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
