        "examples": {
          "standard": [
            {
              "text": "これは政治的な問題というよりも、もっと民事的な契約トラブルの側面が強い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "民事的な解決策として、まずは金銭的な補償を提示してみてはどうだろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "刑事告訴をちらつかせて脅すのは、民事的な紛争解決の手段としては不適切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこから過度の臆病さが生まれたのであって民事的伝統としては七月十四日（一七八九年）を有し軍事的伝統としてはアウステルリッツを有する人民にとっては、それはかえってわずらいとなるものだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
