          "standard": [
            {
              "text": "雪解け直後の高山地帯で、深山金梅の黄色い花がいち早く春を告げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "岩場にへばりつくように咲く深山金梅の姿に、自然の厳しさと美しさを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深山金梅の花びらはハートの形をしていて、とても可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "頂上は割合に広く、三角点を取巻いて深山小田巻草、深山金梅、岩梅、白馬黄者、白山一華、深山塩竈などの高山植物が今や全く花盛りで、紅や白や黄や紫が入り乱れて艶を競うている。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
