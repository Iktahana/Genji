        "examples": {
          "standard": [
            {
              "text": "「同じ料理でも、盛り付けや器などの見せ方次第で高級感に大きな差が出る。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「プレゼン資料は内容も大切だが、図解を多用するなど情報の見せ方も工夫すべきだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「SNSでは自分をどう魅力的に演出するか、その見せ方にこだわっている若者が多い。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大臣やその夫人に対する義理と思って、なお娘を忘れぬ志があるなら、その時には誠意の見せ方があると、妹君をそれにあてて玉鬘夫人は思っているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "竹河",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、どんなインテリ層にだつて面白く愬へるものがあるし、それから一般大衆もやり方によつて、見せ方によつて、面白く片唾を呑むところがある。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "見せ方の問題であるし、最後の切札というものは、決してそれを見せなくとも、握っているだけで効果を発揮することができる。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
