        "examples": {
          "standard": [
            {
              "text": "寝殿造りの奥座敷には、貴人が休むための御帳台が設置されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館の展示で、豪華な刺繍が施された御帳台のレプリカを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "御帳台の中に隠れていた姫君は、外の様子を伺いながら息を潜めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "御病気を聞き伝えて御帳台のまわりを女房が頻繁に往来することにもなって、源氏は無意識に塗籠（屋内の蔵）の中へ押し入れられてしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼すら真夜に等しい御帳台のあたりにも、尊いみ声は昭々と珠を揺る如く響いた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼すら真夜に等しい、御帳台のあたりにも、尊いみ声は、昭々と珠を揺る如く響いた。",
              "citation": {
