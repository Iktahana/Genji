        "examples": {
          "standard": [
            {
              "text": "将軍は信頼のおける腹中に、敵地への潜入を命じる密令を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "王の密令を帯びた使者が、闇夜に紛れて城を抜け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その密令には、失敗した場合には自決せよとの厳しい指示が含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "密令校尉數人至王第。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼塚元帥からの密令のことも、欧弗同盟国と汎米連邦の開戦説のことも、また、その両国が連合して、大東亜共栄圏を脅かそうという風説のことも……。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、すばやく一等運転士パイクソンのもとに、ある密令をつたえた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "密令　パイクソンは、無電器械について、すこしは知っていた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "クイーン・メリー号が海上に出たというので、うれしまぎれに、恐ろしいのもわすれて甲板に出ていた人たちの間をぬって、避難の密令は伝えられ、一同は急いで船内にかえってきた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くべき警報と、何事かの密令とが、方々にとんで行ったのである。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "書入れしてない書式用紙に…………　　当時、フランスの王は御璽で封印した逮捕または拘禁の秘密令状を寵臣貴族たちに与えたのであった。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原氏の密令をうけた九州の神司の習宣のアソマロという者が、宇佐八幡の神託と称し、道鏡を天皇の位に即けたなら天下平らならん、と奏上した。",
              "citation": {
                "source": "安吾史譚",
                "author": "道鏡童子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は×××国の密令を帯び、日本在住の間諜と密接な連絡をとるため、アラスカの某地から、日本の某海岸まで海底電線を敷設していたのである。",
              "citation": {
                "source": "流血船西へ行く",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話すうちに分ったのだが、僕達を特に密令を帯びて出張した刑事だと思ったのである。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "城中では、すでに京師からの密令で、このことは知っている。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
