        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あ、ここにあった！ 見っけ！」と子供が隠れていたおもちゃを見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長い間探していた鍵を見つけて、「見っけ！」と声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友達と宝探しをしていて、「僕が最初に見っけ！」と叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "税務署に見っけらへれば、罰金取らへる。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見っけらへなぃば、すっこすっこど葡ん萄酒呑む。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻は躍るし、目はまわるし、振り落されないだけが見っけものなんだ。",
              "citation": {
                "source": "一夕話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸で飛び出さなかったのが見っけ物で、煙草盆を蹴飛ばさなかったのが勿怪の幸いです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、感情がいつも緊張しており、何かしら新しいものを見っけては喜んで寄りかかるが、さて、ゆっくりした気分になりはじめると、それから離れ去らずにいられなくなり、新しいものにふたたび注意を奪われ、それをまた見棄てて別の新しいものを求めるのだった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが私のにわか芸で、どうやら今日まで寿命をのばして来ただけが見っけものだと諦めてね、早くこの小屋から別れておくれ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
