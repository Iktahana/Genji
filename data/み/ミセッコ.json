        "examples": {
          "standard": [
            {
              "text": "「幼稚園の砂場で、子供たちが作った泥だんごを誇らしげに見せっこしている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お正月に買ってもらったお年玉袋を、友達同士で見せっこして中身を自慢し合った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お互いの描いた似顔絵を見せっこして、あまりの似てなさに二人で大笑いした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "祭にも出られず、出仕も出来ない若い男や女房はこの折々をそれにかえて衣服の見せっこ、きりょうのくらべっこ、をしてよろこんで居るので有る。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉というものは、物の名前だから、話をしようとするときには、その物を持って行って、見せっこをすれば、しゃべらなくても意味は通じるというのです。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
