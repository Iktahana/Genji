        "examples": {
          "standard": [
            {
              "text": "クヌギの木を見上げると、立派な角を持った深山鍬形が樹液を吸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "深山鍬形は体に細かい毛が生えているのが特徴で、子供たちに大人気の昆虫だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "標高の高い涼しい場所を好む深山鍬形を探して、早朝の山道を歩き回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "頂上は小沢岳より狭く且高さも十六、七米低いが、二等三角点を取り巻いて岩塊の狼藉たる上に、偃松や石楠が枝を延し、四、五寸の小笹に交って苔桃、御前橘、イワハゼ、ウイキョウ、深山鍬形、三葉黄蓮など、山の植物も乏しくないので、確に小沢岳よりも高山相を呈している。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
