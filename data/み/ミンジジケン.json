        "examples": {
          "standard": [
            {
              "text": "警察は「民事不介入」の原則があるため、単なる金銭トラブルという民事事件には踏み込めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弁護士事務所の壁には、これまでに解決してきた複雑な民事事件の記録が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "交通事故の示談がまとまらず、民事事件として法廷で争うことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "芥川賞事件も殺人から民事事件に及んで、誰がワガママ身勝手であるか、ワカラズ屋は誰であったか、その足跡正体をおのずから筆の内外に叙述するとすれば、日本の文運、これによって隆盛をきたすこと明かである。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの事件に関しても第三者の事件に関しても、刑事事件に関しても民事事件に関しても。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
