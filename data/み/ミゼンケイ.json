      {
        "index": 1,
        "gloss": "irrealis form (of Japanese verbs and adjectives; used with auxiliaries to form negative, causative, passive and volitional constructions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
