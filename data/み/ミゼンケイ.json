        "examples": {
          "standard": [
            {
              "text": "日本語の動詞には、未然形、連用形、終止形などの活用形がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「書く」の未然形は「書か」だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "未然形は、「ない」「よう」などの助動詞と結びついて使われることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "否定をあらわすには、「ない」といふ語を、未然形に付けよと云はれなくても、恐らくこれを誤まるものはないであらう。",
              "citation": {
                "source": "国語科学習指導要領試案（文法編）",
                "author": "時枝誠記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラ、助動詞の未然形。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ササは、動詞爲の敬語の未然形だろう。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "二四　ケは、時の助動詞キの古い活用形で未然形。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "セは敬語の助動詞スの已然形とすれば、動詞言うの未然形に接續するはずであるのに、イヘセとなつているのは、言うが下二段活か。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
