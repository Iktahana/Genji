        "examples": {
          "standard": [
            {
              "text": "結婚式では、新郎新婦が色鮮やかな刺繍が施された民族衣装に身を包んで現れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外国からの観光客を歓迎するために、空港のスタッフが色とりどりの民族衣装で出迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "民族衣装は、その土地の気候や風土に適した素材と形で工夫されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "四谷見附橋のところで民族衣装をまとったインド人の女性から輪廻転生を解いたヒンズー教布教のためのパンフレットを買ってほしいと言い寄られたが、浩はウォークマンを聞きながらそのせいで聞こえないふりをしてやり過ごし、上智大学の｜Ｈ・Ｈの部室に向かう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "全員がスカートにショールという民族衣装だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
