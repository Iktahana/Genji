    "definitions": [
      {
        "index": 1,
        "gloss": "to misjudge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これほどの実力者だったとは、正直言ってあなたの能力を完全に見損なうところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな素晴らしい映画を、単なる娯楽作品だと思って見損なうなんて勿体ない」と熱弁された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の隠れた優しさを見損なうことなく、いち早く気づけたのは私だけだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "見損なうにも程があるぞ」「どうぞどうぞ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "滅多にお客を見損なう男じゃないがなあ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見損なうなよ、この吉次を！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「見損なうなよ、一式小一郎を」　とたんに、「うん！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見損なうなよ」　などと啖呵をきる。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろい、糺明所へでもどこへでも突き出してもらおうじゃねえか」「いいおったな」組んで捻じ伏せようとすると、「見損なうなっ」いきなり拳を侍の横顔へ見舞って、あっとよろめく腰を蹴とばした。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういちど、その男は、「やりやがったな」　と、顔じゅうを、火にして起ちかけたところを、「見損なうな」　と、勘太も一酬して、かれのわめく顔を、草履で踏んづけた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、ぞろぞろ、いやに静かに近づいていくもんだから、わざと知らん顔しているに違えねえ」「だが、一度はお土砂をかけておかねえと、俺ッちを甘く見損なうッてこともあらあ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにっ、おれにも腕を貸さないかと、見損なうな。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "○いつも方便の恋　○その癖心のよい人と思ってつかみそこなう。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、「大岡政談」の「岡」という字が、変則に書いてあるものだから「衆」という字に見えたがって、一歩読みそこなうと「大衆政談」になります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰頭を仰ぐと危岩が転げ落ちそうで、思わず首がすくむ、足下は何十丈だかしれぬ深谷、ちょっとでも踏みそこなうものなら、身も魂もこの世のものとは思われぬ。",
              "citation": {
                "source": "穂高岳槍ヶ岳縦走記",
                "author": "鵜殿正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐずぐずしていると、材料をつかみそこなう。",
              "citation": {
                "source": "オスカー・ブロズキー事件",
                "author": "THE CASE OF OSCAR BRODSKI",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to misjudge (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんな卑怯な手を使う人だったなんて、本当にあなたを見損なったわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「親友だと思っていたのに、困った時に助けてくれないなんて見損なったよ」と突き放された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "誠実だと思っていた部下が嘘をついていたと知り、彼を信じていた自分を恥じ、彼を見損なった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to miss seeing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
