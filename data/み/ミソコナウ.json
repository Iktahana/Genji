          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "テレビの特集番組を録画し忘れてしまい、一番の見どころを見損なうという失態を演じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「流れ星が見えたのに、よそ見をしていたせいで見損なうなんてついてないな」とぼやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人混みに阻まれて、パレードで一番人気のキャラクターを完全に見損なうことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
