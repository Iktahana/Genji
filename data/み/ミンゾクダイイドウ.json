        "examples": {
          "standard": [
            {
              "text": "ゲルマン民族の大移動は、ローマ帝国の衰退を決定づける歴史的な転換点となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "飢饉から逃れるために始まった何十万人もの民族大移動は、周辺諸国に大きな混乱を招いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で地図を見ながら、太古の昔に行われた人類の壮大な民族大移動の足跡を辿った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "初めは傭兵として部分的に入り込み、或は北方の国境地方に於て徐々に侵透しつつあったのであるが、四世紀末の民族大移動につれて旺然とローマ帝国内になだれ込むようになった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝国の首都を東に移したコンスタンチヌス大帝がその統一の事業のためにキリスト教徒の勢力を利用し、その挙句この教を公の宗教として認許したのは三一三年であって、民族大移動の開始に先だつこと僅か六十年である。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族大移動の時代が始まった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "民族大移動の始まりについては既に述べた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふつう中世は４世紀の民族大移動に始まるとされている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元400年から1100年のあいだの民族大移動にさいして遊牧民とともに東からヨーロッパに流れ込んだと考えられる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
