        "examples": {
          "standard": [
            {
              "text": "祖母は、風邪をひくといつも、生姜湯のような民間薬を作ってくれました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "科学的根拠は乏しいものの、一部の民間薬には症状緩和の効果があるという報告もあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "田舎では、今でも健康維持のために様々な民間薬が使われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二樹の葉が当時民間薬として用いられていたからである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに二十二銭茂吉薬代とあるのは、僕が絵具に中毒して黄疸になつたとき、父は何処からか家伝の民間薬を買つて来てくれた。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
