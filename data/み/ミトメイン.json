          "standard": [
            {
              "text": "回覧板に認め印を押して、隣の家に持っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "重要な契約ではないので、実印ではなく認め印で構わないと言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は珍しい苗字なので、既製品の認め印がなかなか見つからず苦労している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仲通りの仲買店とか、関内芸者の花柳地が近いので、お茶屋の帳場印だの、往来の客がふと実印や認め印などを稀に註文しに入って来るぐらいなものだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
