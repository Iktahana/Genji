        "examples": {
          "standard": [
            {
              "text": "明治政府は近代国家の体裁を整えるため、ボアソナードを招いて民法典の編纂を急がせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この注釈付きの民法典は、実務家にとっても非常に使い勝手が良い名著だ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "法制史の講義で、19世紀のフランス民法典が各国の法制度に与えた影響を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "現にナポレオン皇帝でさえ、彼の民法典に初めて解釈を加えた本を作られた際に、「わが法典失われたり」という嘆声を発したと伝えられているくらいだから、初学者がそう考えやすいのは至極尤もなことである。",
              "citation": {
                "source": "法学とは何か",
                "author": "――特に入門者のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の言うことが正しい、何もかも私の言う通りだ、当然だ、民法典だ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "[66] 民法典　一八〇四年に制定され、その後ナポレオン法典になった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
