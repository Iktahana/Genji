        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼らの密か事は、やがて周りの人々に知られることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "密か事に夢中になり、仕事がおろそかになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小説の中の主人公は、危険な密か事を経験する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
