        "examples": {
          "standard": [
            {
              "text": "調査船は、南極海でミンク鯨の群れに遭遇し、その生態を観察しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ミンク鯨は、他の大型鯨類に比べて比較的小型ですが、その数は非常に多いと言われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "漁業関係者は、ミンク鯨の増加が漁獲量に影響を与える可能性について懸念を示しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "白ナガス鯨、イワシ鯨、小さなミンク鯨というあたりが美味の由。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中も近海捕鯨は大いにやってたそうだが、近海でとれるのはマッコー鯨とミンク鯨が主だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはミンク鯨であった。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            }
          ]
        }
