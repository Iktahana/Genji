        "examples": {
          "standard": [
            {
              "text": "著作権侵害を理由に、有名アーティストがIT企業に対して民事訴訟を提起した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "民事訴訟を起こすには、まず訴状を作成して裁判所に受理される必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多額の費用と時間がかかる民事訴訟を避け、和解による解決を図ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "民事訴訟の紛紜、及び余り重大では無い、武士と武士との間に起ったので無い刑事の裁断の権能をもそれに持たせた。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち被害者またはその親戚らより起訴して、原被両告の対審となることは、民事訴訟と同一であった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "万一、発覚しても最初は民事訴訟じゃからね、という観察の下に現金を集めたのじゃ。",
              "citation": {
                "source": "奇術考案業",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "民事訴訟を無視した結果、ある野蛮な商人によって、未払い借金をたてに、いつ何どき刑務所送りにされかねません。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
