        "examples": {
          "standard": [
            {
              "text": "祭壇には、三角柏の葉の上に供物が並べられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "三角柏は、神聖な場所で使われることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は三角柏の葉を丁寧に選んで、儀式に用いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "みつぬかしは（三角柏・御綱柏）や、みづきと通称せられるいろいろの木も、禊ぎに用いた植物で、海のあなたから流れよって、根をおろしたと信じられていたものらしい。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "みつぬかしは（三角柏・御綱柏）や、みづきと通称せられる色々の木も、禊ぎに用ゐた植物で、海のあなたから流れよつて、根をおろしたと信じられてゐたものらしい。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
