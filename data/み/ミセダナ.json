    "definitions": [
      {
        "index": 1,
        "gloss": "display shelf (in a store)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「店棚に並べられたクリスタルのグラスが、スポットライトを浴びてキラキラと輝いている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「商品の配置を工夫して、お客様の目に留まりやすいように店棚を整理した。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「子供が走り回って店棚にぶつかり、飾ってあった花瓶が割れてしまった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "三郎といふ女のやうにきれいな子が自家の店棚から清酒の四合壜を一本盗んで来た。",
              "citation": {
                "source": "文学に現れたる東北地方の地方色",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的裕福な家の炉端がその臨時の店棚となる。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳屋の店先に立った私を迎えたのは、店棚の陰に白い団扇を手にして坐っていた清ちゃんの姉さん一人だった。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、そういう場合に大楼の店先などを通って、銭金を湯水の如くつかう人や、物売りの店棚でおいしい御馳走のにおいをプンプン嗅がせられた時など、彼もクラクラと眼がくらんで、フラフラと足が顫えることがありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い一間半位の通路の両がわに、玩具、絵草紙、文房具、はては箪笥、鏡台、漆器類、いろ／＼のものを売る店があって品物をならべた「みせだな」の一角に畳一畳位の処に店番の人が小さな火鉢や行火をかかえてちんまりと座って、時分時にささやかな箱弁当でも食べていようという光景はとても大正昭和の時代にはふさわない。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
