        "examples": {
          "standard": [
            {
              "text": "「特定の銘柄に大量の注文を出し、すぐに取り消すという見せ玉行為を繰り返していた疑いがある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見せ玉によって他の投資家を誘い込み、不当な利益を得ることは証券取引法違反だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「板を注視していると、明らかに約定させる気のない見せ玉と思われる注文が散見される。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何故にかく不興なる面もちを見せ玉ふか。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
