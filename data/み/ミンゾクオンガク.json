        "examples": {
          "standard": [
            {
              "text": "山あいの村で耳にした民俗音楽は、どこか懐かしく、力強い大地の鼓動を感じさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は各地の民俗音楽を録音して回り、失われつつある伝統的な旋律を保存している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "民俗音楽のリズムを取り入れた新しい現代曲が、今、若者の間でブームになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
