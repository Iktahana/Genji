        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "イギリスのパブで、熱々のミートパイとビールを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自家製のミートパイは、焼きたてが一番美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供のお弁当に、小さなミートパイを作って入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "戦前のジャーマン・ベーカリーは、独特のバームクーヘンや、ミートパイなど、他の店に無いものが揃っていた。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミートパイは、戦後のジャーマン・ベーカリー（有楽町駅近く）でも、やっているが、昔の方が、もっと大きかったし、味も、しっとりとしていて、美味かった。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、ミートパイは、あんまり他に無いので、僕はわざわざ有楽町の店へ行くが、「ミートパイは、土曜日だけしか造りません」などと言われて落胆する。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "話をもう一度、ミートパイに戻す。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミートパイは、八重洲口の不二家でも売っているが、これはアメリカ式で、ゴツイもの。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケテルさんの経営するデリケテッセン（並木通り）にも、終戦直後から、ドイツ流のミートパイがあるが、これは菓子というよりも、酒の肴である。",
              "citation": {
                "source": "甘話休題",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミートパイがあったので試みた。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャマンベーカリーのミートパイのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ・サンジェルメンに、カールイナ・ミートパイ、これがうまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
