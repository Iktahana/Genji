        "examples": {
          "standard": [
            {
              "text": "老朽化した家の壁の裏には、古い鉄製の水パイプが通っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台所のシンクの下から水が漏れていると思ったら、水パイプに亀裂が入っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭に新しい花壇を作るために、既存の水パイプの位置を確認する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから安全弁をひらくやら、給水パイプのコックをひねるやら大騒ぎをして、やっとエンジンの壊れるのを救った。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "環境保全委員会がこの冷却排水パイプをめぐって海洋生態環境の調査をやりなおしたところ、冷却排水パイプをさらに沖へ向かって数百メートル延ばさなくてはいけないことになった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷却排水パイプの延長を命じられた電力会社は、工事の方法をさまざまに検討した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷却排水パイプの延長にともなうコンクリート桶の建造はあらゆる意味で合法的であり、地域社会の発展に大きな利益をもたらす、というステートメントを発表したきりだった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
