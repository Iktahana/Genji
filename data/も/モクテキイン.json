    "definitions": [
      {
        "index": 1,
        "gloss": "final cause (one of Aristotle's four fundamental types of answer to the question \"why?\")",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
