        "examples": {
          "standard": [
            {
              "text": "疲れた子供たちは、母親の膝に心地よくもたれ合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっと疲れたから、肩貸してくれない？」「うん、もたれ合おう」と、二人はソファに座ってリラックスした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕暮れの公園で、老夫婦は静かに手を取り合い、ベンチにもたれ合っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二個の酔漢はよろよろと互いに相もたれ合うようにしてその下を当てもなくさまよい歩いた。",
              "citation": {
                "source": "六月",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
