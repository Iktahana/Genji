        "examples": {
          "standard": [
            {
              "text": "昔の医学書では、統合失調症の特定の状態を妄想病と呼んでいたこともある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分が常に監視されていると訴えており、典型的な妄想病の症状を呈している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "妄想病が悪化すると、現実社会での生活を維持することが困難になるケースが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これまで自分の考えたようないろいろの心配などは畢竟誇大妄想病者の空中に描く幻影のようなものかもしれない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "解つてゐる部分だけを眼近く取りあげて幾度となく私は、夢を払つて細工に取りかゝらうと振ひ立つたが、いつの間にか私の心身は共に疲れたと見えて、実務に対する凡ての働きが臆劫になり、数理的の観念が消えて、反動の如く強く徒らに妄想病が募るばかりであつた。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
