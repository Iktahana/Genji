        "examples": {
          "standard": [
            {
              "text": "戦後のガソリン不足の時代には、煙を吐いて走る木炭車が街で見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "博物館のイベントで、動態保存されている貴重な木炭車のデモ走行が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "木炭車は坂道になると極端にパワーが落ちるため、運転にはコツが必要だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "木炭車の車を貸したげる”といわれましたので、これも女房のためだと思いまして、一時間ほどしゃべりました。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、木炭車の車を借りまして、ちょうど折りふし、花のころでしたから、吉野山へ行ったんです。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木炭車でやっと上までのぼりまして、あの如意輪堂のはるかに見える一目千本というあたりですか、あの谷をへだてましたガケぷちへきましたら、運転手さんが、この辺がちょっといいですというんで、車をとめて、ぼくは煙草を一本もってひょいと降りたんです。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは心のふるさとかひさの思ひに詣づれば世にさかしらの恥かしくうたゝ童にかへるかな　木炭車、神橋のそばに待ちながら、ブウブウ風圧をかけている。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
