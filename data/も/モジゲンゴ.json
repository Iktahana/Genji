        "examples": {
          "standard": [
            {
              "text": "口承文化では文字言語が発達しなかったため、歴史の記録が残りにくい傾向があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は異なる文字言語を持つ国々を旅し、それぞれの文化に触れるのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "文字言語の習得は、高度な抽象思考能力の発達に寄与すると言われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "如何となれば生中血行の事などを文字言語によりて知つて、之をいぢり廻しては惡果を來さぬとも限らぬからである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら生半可に血行の事などを文字言語で知って之をいじり廻しては、悪い結果を来たさないとも限らないからである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば先其教を棄てよう、其政を棄てよう、其文字言語をも棄てよう、よろしい思想其物迄も棄ててしまへ。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "表現の媒介の相違によつて、音声言語、文字言語の区別が考へられる。",
              "citation": {
                "source": "国語学と国語教育との交渉",
                "author": "――言語過程説の立場における――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
