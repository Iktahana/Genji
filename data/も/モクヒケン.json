        "examples": {
          "standard": [
            {
              "text": "弁護士は、依頼人に黙秘権の重要性を説明しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "逮捕された者は、直ちに黙秘権があることを告げられます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、不利な証言を避けるため、黙秘権を行使することを決めました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "平作は捕えられたが、黙秘権を行使して一言も物を云わない。",
              "citation": {
                "source": "山の神殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "キミは黙秘権というのを、やれよ」「この際アベコベでしょう。",
              "citation": {
                "source": "影のない犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそういう場合のためには、黙秘権というものがあるから、それを使えばよいわけである。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "法廷ならば本当の黙秘権であり、友人同士の間ならば、にやにやしていればよい。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙秘権という不思議な権利の意味は、今までよく分らなかったが、今度子供をアメリカの小学校へ入れてみて、初めてその意味が了解された。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人には黙秘権があります。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
