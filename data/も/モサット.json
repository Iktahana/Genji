        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その服を着ると、どうしてももさっとした印象になってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "髪が伸びっぱなしで、全体にもさっとした感じに見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の話し方は、いつももさっとしていて覇気がない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
