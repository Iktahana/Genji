        "examples": {
          "standard": [
            {
              "text": "このフォントファイルには、各文字の形状や幅に関する詳細な文字情報が含まれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "文字認識システムは、画像から文字情報を抽出し、テキストデータに変換します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "データベースに格納されている各文字のメタデータは、文字情報として活用できます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "パソコンは、視覚障碍者、特に全盲の人達に、文字情報へのアクセスの壁を壊す力強いメディアとして活用されてきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにインターネットと結び付いてからは、文字情報のやりとりを支援するパソコンの役割は、より大きなものとなった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
