        "examples": {
          "standard": [
            {
              "text": "「私はリンゴを食べる」という文では、「リンゴ」が動詞「食べる」の目的語になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自動詞は目的語を必要としないが、他動詞は必ず目的語を伴うのが基本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "英語の文構造を解析する際、まずはどれが主語でどれが目的語かを特定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その余の存念推察して邪魔立てせざりし汝の好意――その好意もて貝十郎、田沼の旅の目的語れ！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも自動詞が目的語乃至補足語を取らねばならぬ様になつた結果、寝るをいぬる、泣くをねなくと言ふ様になつた。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
