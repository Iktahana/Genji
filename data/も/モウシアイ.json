          "standard": [
            {
              "text": "稽古場では、力士たちが激しい申し合いを行っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "申し合いを通じて、若手力士たちは互いに技を磨き合います。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の申し合いは、白熱した展開になりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "息子の友達寄り集い申すよう、「われら二、三人申し合い、遊山がてら箱根へ湯治に赴く催しなり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "わびられたとて、どうなろう」「なにとぞ、いまは早や一刻もおはやく」「落ちろとか」「仲時、また時益も、斬り死にいたさんと申し合いましたなれど、いや、主上をはじめ両院その他の方々を、ここで敵手にまかせては、御運のほどもいかがあらん……。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
