        "examples": {
          "standard": [
            {
              "text": "地理の授業で、先生はエベレストの模型地図を使って山の高さを説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "博物館には、地域の地形が詳細に再現された模型地図が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山計画を立てる際、模型地図があるとルートの起伏がよくわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "下になるだけ雪が斑らになっている遠い麓に、谷でも流れているか、丁度模型地図を見るとおなじく幾つとない細長い窪みが糸屑を散らした様にこんがらがっている中の一個所にそんな温泉があると聞いて私の好奇心はひどく動いた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその刳れた所に模型地図の山脈などに見る幾つかの高まりが縦横に岩面を走っているのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
