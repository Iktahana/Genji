          "standard": [
            {
              "text": "お昼にモスバーガーで、ソースたっぷりのテリヤキバーガーを頬張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モスバーガーのポテトは太切りで、ジャガイモ本来のホクホク感が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "友達とモスバーガーに寄り道して、期間限定のシェイクを飲みながらお喋りした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "新宿御苑を通り過ぎ、十字路を渡るとモスバーガーが見出せた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンバーガーを食べ終えるとモスバーガーを出て更に同じ方向へ進んで行く。",
              "citation": {
