        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "富を独占する者と持たざる者の格差が、社会問題として深刻化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "持たざる者としての誇りを持ち、どんなに苦しくても正道を守り通した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史上、持たざる者たちが団結して現状を打破しようとした例は少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "やつらは持つ者、私は持たざる者、ですから追うのは容易いことではありません。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリップの見物人は、持たざる者の悲しさを最も端的にあらわしている。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "持たざる者、難民の悲しき姿である。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            },
            {
              "text": "父と子とともに八月の草に寝て、何物をも持たざる者の幸福を悟ることも必要だ。",
              "citation": {
                "source": "八月の星座",
                "author": "吉田絃二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男に對立したる意味の女に對して、僕は唯自ら持たざる者を持てる人に對する親愛と尊敬とを感ずる。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "封建的社会に遊廓という形があり、よりすすんだ資本主義の社会に、もつものともたざるものとの溝に咲く夜の花のあることは、ヨーロッパも同じである。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
