    "definitions": [
      {
        "index": 1,
        "gloss": "reading classical Chinese aloud without trying to understand the meaning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "意味を考える前に、まずは漢文を文字読みして、そのリズムを体に叩き込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寺子屋では、子供たちが経典を文字読みする声が響いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は文字読みは得意だが、内容を解釈する段階になると途端に黙り込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "法然が亡くなった後は善恵房を頼んでいたが、結縁の為めに四帖の疏の文字読みばかりを受け、遂に出家して実信房蓮生と号しその後夢に善光寺の本尊を感得したりなどして承元元年十一月十二日芽出度い往生をとげた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "reading a kanji compound using the Japanese pronunciation of each of its characters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
