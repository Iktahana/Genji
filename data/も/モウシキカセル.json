        "examples": {
          "standard": [
            {
              "text": "彼は子供に、危ない場所には行かないよう申し聞かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部下に、仕事の優先順位を申し聞かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "監督は選手たちに、試合への心構えを申し聞かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "委細はあらためて申し聞かせる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいか、よくこの事を主人に申し聞かせるのだぞ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "申し聞かせるすじがある」　言い捨てて源十郎、スタスタ奥へはいっていったから、はて！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「申し聞かせるのは、お宅の勝手ですがね」　彼は言った。",
              "citation": {
                "source": "記憶",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
