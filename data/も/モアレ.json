        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "細かいストライプの服を着てテレビに出ると、画面にモアレが発生して見づらくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "印刷物の写真をスキャンした際に出るモアレを除去するために、画像編集ソフトで補正をかける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "網戸越しに景色を撮影したら、格子が重なって妙な幾何学模様のモアレが写り込んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
