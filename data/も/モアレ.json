        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女が着ているシルクのドレスには、上品なモアレの波紋模様が浮かび上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アンティークの椅子に、モアレ加工が施された重厚な生地を張り替えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モアレのカーテンが風に揺れるたび、光の干渉で模様が生きているように動いて見える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「腐ッテタラ犬ニヤレバイヽジャナイノ、アナタ達ハ面白ガッテ何デモアレヘ投ゲ込ムンダネ、アンナモノヲ買ワナキャヨカッタ」ソウ云ッテ颯子ハ後悔シテイタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語動作ガキビ／＼トシテ、目カラ鼻ヘ抜ケルヨウデ、ソレデイテ情味モアレバ愛嬌モアッテ人ヲ外ラサナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日モアレヲ着テ歩イテイル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
