        "examples": {
          "standard": [
            {
              "text": "人生で初めての入院生活は、中学生の時に受けた盲腸炎手術だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近の盲腸炎手術は腹腔鏡で行われることが多く、体への負担が少ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "盲腸炎手術を終えた彼は、翌日には歩行訓練を始められるほど回復した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "盲腸炎手術の経過にいわく――　老齢に加うるに栄養物絶無の折柄とて、体力の回復遅々として捗らぬは、じれったくてなりません。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "青柳信雄の家へ行く、盲腸炎手術後のへたりで、ねてゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
