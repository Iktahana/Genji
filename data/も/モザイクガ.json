        "examples": {
          "standard": [
            {
              "text": "シチリア島の教会の天井には、きらびやかなモザイク画が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "モザイク画のワークショップに参加して、自分だけの作品を制作した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのモザイク画は、何万もの小さな石片で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お京さんへの土産に買って来た伊太利フローレンス製の大理石のモザイクが小さな箱に納まったブローチとなって加奈子のポケットへ忍ばせてあった。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで氏の頭脳の中には、実に精緻を極めた論理のモザイクが組みたてられる。",
              "citation": {
                "source": "文学の本質について（二）",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "○同じ席上にて　こちらにはこれだけいろいろな木の種類があるのだから、いいモザイクが出来ますね。",
              "citation": {
                "source": "台湾の民藝について",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどこの生活モザイクが自分にはちっとも矛盾でもふしぎでもないのだった。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
