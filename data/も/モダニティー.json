          "standard": [
            {
              "text": "グローバル化は、現代社会におけるモダニティーのあり方を問い直している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、ポストコロニアル理論の観点からモダニティーの概念を分析した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「モダニティーの恩恵を、すべての人が平等に受けられる社会を目指したい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この太い線一本で生きて行かれる女が現代にもあると思うとかえって彼女にモダニティーさえ感じた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
