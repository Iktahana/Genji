          "standard": [
            {
              "text": "春の野原には、可愛らしい捩摺（もじずり）がたくさん咲いていました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "捩摺の繊細な花びらの形は、日本の伝統的な文様にも見られます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域では、捩摺が自生しており、春の風物詩となっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "はしけやししのぶもじずりかかるとき　　　　　　　　るすのかみがみいともかしこし　ほう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "磐城の連山の雲霧の彼方に、安達ヶ原がある、陸奥のしのぶもじずりがある、白河の関がある、北海の波に近く念珠ヶ関もなければならぬ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
