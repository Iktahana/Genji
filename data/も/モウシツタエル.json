        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お客様からのご要望を、担当者に申し伝えます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「社長には私が責任をもって申し伝えます」と秘書は答えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は先輩の伝言を忘れずに後輩に申し伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それがさ、石地蔵と申し伝えるばかり、よほどのあら刻みで、まず坊主形の自然石と言うても宜しい。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜こそ一大事をことごとくその方に申し伝える。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それらの方々へは拙者これより、その宿元までひそかに参り、申し伝える所存でござる」浜松の異変　この同じ夜のことであった。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那様早速そう申し伝えるでございます。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……のう、吉千代』『その進藤や、小山の叔父には、疾くに話してあること故、改めて其方から申し伝えるには及ばぬ』『えっ……では、それ程、御用意の上で』『うむ』　深く――大きく頷いて――内蔵助は、凝と彼女を見ながら云った。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
