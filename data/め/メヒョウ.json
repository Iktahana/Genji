        "examples": {
          "standard": [
            {
              "text": "夕暮れのサバンナを、一頭の女豹が音もなく獲物を探して歩いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女のしなやかな身のこなしは、獲物を狙う女豹のような力強さと美しさを兼ね備えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あのモデルの眼差し、まるで野生の女豹みたいに鋭くてカッコいいね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "千世子は愚な民をその白い手で征服して居る女王の様な又いくじない動物達の群の中を胸をはって進む女獅子か女豹の様なかがやかしいおごった気持になった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」　無言ではあったが織江は必死、身を守ろうと拳を固め、女豹のように構え込んだ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたも一緒に行らっしゃい」　夫人は荒原の女豹が獲物を捕える時のように生き生きとした眼を輝かせながら、私を伴れて外へ出た。",
              "citation": {
                "source": "情鬼",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            }
          ]
        }
