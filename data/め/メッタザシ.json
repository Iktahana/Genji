        "examples": {
          "standard": [
            {
              "text": "殺人犯は被害者をメッタ刺しにし、逃走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ホラー映画のワンシーンで、主人公が怪物にメッタ刺しにされる場面があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "感情的になった彼は、怒りに任せて相手をメッタ刺しにしようとした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "傷はいずれも背後から鋭利な刃物で突かれたもので、背中に四ヵ所、頸一ヵ所、メッタ刺しにされている。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから蘇生を怖れて執拗にメッタ刺しに刺しぬいたに相違ないという話であった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、土居先生の巧妙な監視に掩護されつつ、あやか夫人は居室を忍びでて階下へ降り、内海さんをメッタ刺しに刺し殺して帰られた。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの　りすたちは　やぶを　かけまわって　どんぐりを　ひろっていたと　いうのに　ナトキンは　イバラから　おちた　むしこぶを　あつめて　みんな　マツバの　はりで　めったざしに　してしまいました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
