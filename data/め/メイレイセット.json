        "examples": {
          "standard": [
            {
              "text": "ARMプロセッサは、RISC（Reduced Instruction Set Computer）の代表的な命令セットを採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいCPUアーキテクチャでは、既存の命令セットとの互換性を維持することが重要視される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プログラマは、特定の命令セットに最適化されたアセンブリ言語でコードを書くことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "（ここに出てきたＲＩＳＣという暗号は、縮小命令セット・コンピューター＝ Reduced Instruction Set Computer という念仏の略である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルトのハードウエアの開発にあたって、パロアルト研究所のエンジニアはノバのＣＰＵの命令セットにもとづき、これを大幅に強化する道を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
