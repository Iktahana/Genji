        "examples": {
          "standard": [
            {
              "text": "ワクチンを接種すると、体内で抗体が作られ、その病原体に対する免疫反応が起こる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アレルギーは、体が特定の物質に対して過剰な免疫反応を示すことで発症する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この検査キットは、検体中の微量な物質を検出するために、特異的な免疫反応を利用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "両者はモルモット、ラット、マウスに接種したときの僅かではあるがはっきりとした反応の違いがあることと、あまりに技術的なのでここでは述べない免疫反応によって区別することができる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
