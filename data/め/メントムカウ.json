        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "電話やメールではなく、一度きちんと面と向かって謝罪したいと考えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "いざ本人と面と向かうと、用意していた厳しい言葉が喉の奥に引っ込んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「大事な話があるんだ。今日の夜、面と向かってゆっくり話せないかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それをどこまでも知り抜きながら、そして身につまされて深い同情を感じながら、どうしても面と向かうと殺したいほど憎まないではいられない葉子の心は自分ながら悲しかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹は蔭でそうは言っても、面と向かうと当擦りを言うくらいがせいぜいであった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "決心はしたものの、こうして面と向かうと何といって切り出したらいいか、わからなかった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女性を軽蔑する点では、男性に対すると変わりなさそうで、女に面と向かうといかにも四角ばって、ほとんど近寄ることができないくらいにふるまった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば面と向かうことができるようになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに顔を見られたくないとみえて、面と向かうときには、必ずハンカチでもって鼻から下を押えてましたからね」　チンドン屋は、いかめしい将軍ひげにも似合わぬボンヤリ者らしく見えた。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
