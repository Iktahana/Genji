        "examples": {
          "standard": [
            {
              "text": "画面上部のメニューバーから「ヘルプ」を選択すると、FAQのページへ飛ぶことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ウィンドウを小さくしすぎるとメニューバーの端が隠れてしまうため、配置を工夫した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メニューバーの内容を整理して、よく使う機能にワンクリックでアクセスできるようにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一方マッキントッシュは、画面の上に横一列に文字で項目を並べる、リサに採用されたメニューバー方式を踏襲していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと小さな画面を、メニューバーを常時表示しておくことで、マッキントッシュがなおいっそう小さくしている点にも、納得がいかなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
