        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うちの息子は本当になんでも後回しにするめんどくさがり屋で、困っちゃうわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "めんどくさがり屋の彼が書いたコードは、いかに楽をするかが追求されていて意外と効率的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自他共に認めるめんどくさがり屋だが、趣味の釣りのためなら夜明け前に起きるのも苦ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お君さんの養母やお君さんの子供や、何だかごたごたしたその家庭は、めんどくさがりやの私にはちょいと判りかねる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君さんの養母やお君さんの子供や何だかごたごたしたその家庭は、めんどくさがりやの私にはちょいとわかりかねた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畫よりも建設的である文學の方の人には、家のことなどかまつてゐられるか、その暇に讀み思索するといつた、めんどくさがりやが多いやうに思はれた。",
              "citation": {
                "source": "家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
