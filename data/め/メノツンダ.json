        "examples": {
          "standard": [
            {
              "text": "目の詰んだ最高級のカシミアで編まれたマフラーは、驚くほど軽くて抜群に暖かい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このバイオリンは目の詰んだ古い木材で作られており、非常に深みのある音色を奏でる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目の詰んだしっかりした厚手の生地を選んで、長年愛用できる仕事用の鞄を仕立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "五　南辻橋の空地、粗末な葭簾張の小屋に、青竹の手摺をぐるりと繞らしたところへ、界隈の女子供は目の詰んだ笊や、風呂敷持参で朝のうちから詰めかけて来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "江戸阿呆宮",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、少くとも私には大変にくつろぎになり、たっぷりさになり、生活のめのつんだ成長の感じで、この一月からの緊張したものが健康にほぐされてゆく工合です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分など、稲ちゃんなど、本当に沈潜して真面目に真面目に沈潜してめのつんだ小説をかかなければならないと思って。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
