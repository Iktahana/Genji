        "examples": {
          "standard": [
            {
              "text": "面接者が質問を投げかけるたびに、室内の空気がぴんと張り詰める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "面接者は、相手の職務経歴書を確認しながら詳細について質問を重ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "熟練の面接者は、さりげない会話から応募者の適性を見抜くことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
