        "examples": {
          "standard": [
            {
              "text": "どんなに細かい修正依頼でも、彼女は面倒がらずに丁寧に対応してくれるので信頼されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「面倒がらずに毎日コツコツ練習することが、上達への一番の近道なんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は雨の中、面倒がらずに駅まで友人を見送りに行き、傘を貸してあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「いたるところで調和を保つアリストクラート」として、周囲に集まる弟姉らをもさしてめんどうがらずに悠々と心のバランスを保って暮らしていることと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰軒はまた、めんどうがらずに、かたっぱしからその始末をつけてやるんです。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
