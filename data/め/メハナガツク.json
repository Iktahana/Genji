        "examples": {
          "standard": [
            {
              "text": "徹夜で作業を続けたおかげで、報告書の作成にようやく目鼻が付いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "資金調達の目鼻が付いたので、新しい事業を来月からスタートさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「大掃除もようやく目鼻が付いたから、ちょっと休憩にしようか」と声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "さア歸らう、これで段々目鼻が付く。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "碁敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――兎に角、八五郎が歸つて來て、淺川團七郎の素姓と居所が判りさへすれば、目鼻が付くと思ふ」　平次はそればかりを頼みにして居る樣子です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "活き佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――とにかく、――八五郎が帰って来て、浅川団七郎の素姓と居所が判りさえすれば、目鼻が付くと思う」　平次はそればかりを頼みにしている様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "活き仏",
                "note": "青空文庫"
              }
            }
          ]
