        "examples": {
          "standard": [
            {
              "text": "祖父の墓には、家族の名前が一つずつ銘を刻むように彫られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この記念碑には、偉大な功績を称える言葉が銘を刻むように刻まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の功績は、歴史に銘を刻むように、長く語り継がれるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "仕事をする人たちも、自分の名誉にかけて作る風が残り、鑚彫で見事な書体で「土州住国光」とか「豊光」とか「国清」とか、古鍛冶に見られるような銘を刻むことを忘れません。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
