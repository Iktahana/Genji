    "definitions": [
      {
        "index": 1,
        "gloss": "catching someone's attention by winking and tugging at their sleeve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "二人はパーティー会場の隅で目引き袖引きしながら、こっそり抜け出す合図を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あそこで目引き袖引きしている人たちは、何か良からぬ相談でもしているのかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "言葉に出さずとも、目引き袖引きの仕草だけで彼女の言いたいことが手に取るように分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "生徒の方でも目引き袖引きして此の名も知らぬ若い教師を眺めた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いらっしゃい」と一人の女中が云って、僕等を見て、今一人の女中と目引き袖引き笑っている。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "真白な肉附きの好い肌が役者のように美くしかったので、近所の若い女が目引き袖引き垣根から隙見したそうだ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、目引き袖引きする、無知な年とった女どもにかこまれている彼女の境遇に同情を持った。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「電車の中で余所の奥さん方が目引き袖引きしているじゃありませんか？",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目引き袖引き、覗き見していた近所のほうが、かえって、罪を犯したみたいにしいんとしていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
