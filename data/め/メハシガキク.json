        "examples": {
          "standard": [
            {
              "text": "彼は非常に目端が利くので、上司が何を求めているか言われる前に察知する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「君は本当に目端が利くな」と、迅速な対応を褒められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目端が利くスタッフのおかげで、混雑する店内もスムーズに回転している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その老巧な松井佐渡も、利休七哲の随一と呼ばれた忠興の家に仕へながら、茶器の鑑定にかけては、目端が利くはうでもないので、そんなことには平素からあまり手出しをしないことに決めてゐました。",
              "citation": {
                "source": "小壺狩",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに僕と違って目端が利く。",
              "citation": {
                "source": "村一番早慶戦",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
