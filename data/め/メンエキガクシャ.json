        "examples": {
          "standard": [
            {
              "text": "その免疫学者は、新しいワクチンの開発に生涯を捧げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ノーベル賞を受賞した免疫学者の講演は、聴衆に深い感銘を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私の友人は、子どもの頃からの夢だった免疫学者になり、現在は最先端の研究に従事している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "免疫学者の多田富雄が書いた『免疫の意味論』を読んだときには、自分の身体で体験した狂ったオーケストラの大音響に、別の角度から強い光を与えられた気がして、「ああそうなのか」と深くため息をつきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "免疫学者にとって驚きだったのは、そうした物質の構造が、すでに知られていた他の働きに関与するものと全く同じだったことです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
