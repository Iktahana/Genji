        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強い日差しがまぶしくて、彼は目を細くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くの景色を見るために、目を細くして集中した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "んー、見えにくいな。目を細くしてよく見てみよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「やあ、しばらく」　苦味走って、とっつきにくい感じだが、目を細くすると、笑ったような顔になる。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を細くすると、これらの船がただその重みだけでゆれているように見える。",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
