        "examples": {
          "standard": [
            {
              "text": "「あ、めんちゃい、間違えちゃった！」と、彼は照れくさそうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "めんちゃい、少し遅れちゃったけど、大丈夫かな？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の可愛い「めんちゃい」という一言で、誰もが笑顔になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」と、殊子に肩先をつねられそうなのを、仰山に飛びのいて、「めんちゃい！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああちゃん、かんにんよ、こうぼいい子よ、めんちゃい――」　おせんは喘いだ、髪が逆立つかと思えた、そして狂気のように引返して走りだした。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めんちゃいね幸坊、ああちゃんが、悪かった、あんな恥ずかしい思いをさせて本当に悪かったわ、誰がなんと云ってもいい、幸坊はああちゃんの大事な子よ、なにもかもいつかはわかるんだもの、それまでがまんして辛抱しましょう、いまにきっと、――きっとなにもかもよくなってよ」　それからさらに近所の眼が冷たくなった。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
