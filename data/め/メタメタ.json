        "examples": {
          "standard": [
            {
              "text": "転倒してカメラがめためたに壊れてしまった、もう修理できないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ああ、もうめためただよ！宿題を全部忘れてきちゃった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年使っていたこのぬいぐるみ、さすがにめためたになってしまって、捨てるしかないかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "思わずめためた坐って了った。",
              "citation": {
                "source": "魚服記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と話をして被入っしゃるところを側から聞いてますと――『ようごわす』――だの――『めためた』だの――」「お前もナカナカ隅へは置けなく成ったよ」　二人とも鼻へ皺を寄せて笑った。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも　やさウサギを　めためたに　ひっかいたのです。",
              "citation": {
                "source": "ごくあくウサギのものがたり",
                "author": "THE STORY OF A FIERCE BAD RABBIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お開きうんぬんの前にあの黒板がめためたになりそう！",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            }
          ]
        }
