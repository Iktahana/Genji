        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ようやく暖かくなり、庭の木々が一斉に芽吹き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の間に枯れていたように見えた草木も、春になると力強く芽吹く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域では、3月の終わり頃から多くの植物が芽吹く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "赤芽吹く春日のどけみ。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "パロアルト研究所を超えて芽吹くダイナブックの種子　一九七〇年代半ばからのパーソナルコンピューターの台頭は、誰もが所有できて情報に関する要求のほとんどをみたすダイナブックの成立の条件を、ハードウエアの側から整えつつあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹々の梢が芽吹く季節は、一年中で最も快い。",
              "citation": {
                "source": "岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "余裕――身にも心にも、生れてはじめてといっていい余裕というものが、ようやく春の日を芽吹く枝々のように生じてきた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには御神の精神が宿っているから、時が来ればそれは蘇りまた芽吹くから。",
              "citation": {
                "source": "夕映えのむこうの国",
                "author": "時代を超えた童話",
                "note": "青空文庫"
              }
            },
            {
              "text": "芽吹く木々おの／＼韻を異にして三月十五日　物芽会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
