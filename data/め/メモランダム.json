          "standard": [
            {
              "text": "会議の前に、配布資料としてメモランダムが配られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はチームメンバーに、重要な決定事項を記したメモランダムを送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "メモランダムには、今後のプロジェクトの進捗が詳細に記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "旅行記の日附（昭和二、六、二十一）を僕のメモランダムとすれば、その前日に僕等は、わたりがはゆきといふことばを造つてゐた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年のメモランダム忘れぬ為に（六月二十三日　下呂にて）　下呂温泉・湯の島館の春慶寮といふ部屋で、今日一日は朝から晩まで、何の用もなくのんびりとした気持である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
