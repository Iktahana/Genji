        "examples": {
          "standard": [
            {
              "text": "夜更かしが続いたせいで、朝起きたら目の下にひどい目袋ができていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、疲れているのか、目袋が目立つようになってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "目袋を隠すために、クマ隠し用のコンシーラーを使っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ある日なんぞは、蜜柑を三貫目袋に入れて、背負って、山から汽車へ駈けつけ、へとへとになった事があった。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人の顔は皆目袋の中へ隠れて、身にはけば／＼しい友禅の振袖を着、足に白足袋を穿いては居るものゝ、折り／＼かざす踊りの手振りに、緋の袖口から男らしい頑丈な手頸が露われて、節くれ立った褐色の五本の指が殊に目立ちます。",
              "citation": {
                "source": "幇間",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
