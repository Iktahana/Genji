        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "暑さと人混みで気分が悪くなり、思わず目を回しそうになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "注射が苦手な彼は、血を見て目を回してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "やばい、立ちくらみが…。目の前が真っ暗で、目を回しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "海は彼の下に目を回すような深さにたたえていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
