        "examples": {
          "standard": [
            {
              "text": "彼のメリハリの効いたスピーチは、聴衆に強い印象を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "役者は、メリハリの効いたセリフ回しで役柄を表現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "メリハリの効いた声で話すと、相手にメッセージが伝わりやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だが文字の鮮明さや読みやすさ、いろいろな書体、いろいろな大きさの活字を使ってめりはりのきいた文書を作るといった点では、紙に遠く及ばなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが十年まえの彼女の魅力のなかに感じていた、ふとしたときに見せるきわめて男まさりな、めりはりのきいたアクションを、ぼくはマタドールの動きのなかに思い出した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
