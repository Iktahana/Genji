        "examples": {
          "standard": [
            {
              "text": "カーテンを開けると、富士山の雄大な姿が目に、いきなり飛び込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "森の奥深くを歩いていると、突然目の前に美しい湖が目に飛び込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "美術館の入り口に飾られた大きな絵画が、私の目に飛び込んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "向けた目に入ってくるのは、大通りのあちらこちらに立つ旗、祝い事のしるしだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなに歩くわけでもなくすぐにヤヨイウサギのおうちが目に入ってくる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ山の影すら詩人の目に入ってくることなく、ときには月光が船客の寝台を照らす。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "見慣れた自分の書斎がまず目に入ってくる。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
