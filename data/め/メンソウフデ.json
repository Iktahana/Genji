        "examples": {
          "standard": [
            {
              "text": "ジオラマの人物の表情を描くために、細い面相筆を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "書道で名前を書く際、面相筆で丁寧に仕上げるのがポイントだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "絵付け師は、面相筆を巧みに操り、繊細な模様を描き込んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "筆　非常に軟かいものがよいので、私は日本画の彩色筆を大小五、六本と、面相筆を二、三本用意しています。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆　非常に軟かいものがよいので、私は日本画の彩色筆を、大小五六本と、面相筆を二三本用意しています。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ氏と同郷の会津蒔絵師の仲間がよく遊びに来ては、ぼくの使う面相筆のうごきや構図を覗いて「初めてじゃあンめえがのし。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
