        "examples": {
          "standard": [
            {
              "text": "肌寒い季節には、綿フランネルのシャツが暖かくて手放せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、手触りの良い綿フランネルの生地でパジャマを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の寝具には、優しい肌触りの綿フランネルのカバーが最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "服裝はあまり見よくもないのみならず襯衣の如きは綿フランネルの手縫のやうなものであつた。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い綿フランネルだのメリンスの半襟だの私はおいよさんの為めに買つて来た。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "近在の男女は風俗もまちまちで、紫色の唐縮緬の帯を幅広にぐるぐると巻付けた男、大きな髷にさした髪の飾りも重そうに見える女の連れ、男の洋傘をさした娘もあれば、綿フランネルの前垂をして尻端を折った児もある。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
