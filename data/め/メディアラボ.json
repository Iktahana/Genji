        "examples": {
          "standard": [
            {
              "text": "MITのメディアラボでは、世界中から集まった天才たちが未来の暮らしを変える発明に取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メディアラボの客員教授として招聘され、最新のヒューマン・コンピュータ・インタラクションを研究する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの有名な電子インクの技術も、元を辿ればメディアラボの研究プロジェクトから始まったものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "特殊撮影技術を集めた『ＳＦＸミュージアム』や、映像作家たちの仕事をさらう『映像の先駆者』シリーズの関連で、初めて渡米すると、ＭＩＴ（マサチューセッツ工科大学）の研究所、メディアラボに籍を置くというボブ・スタインという人物から連絡がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このプロジェクトがアタリの財政難で打ちきりになると、ケイはＭＩＴのメディアラボに招かれ、スタインもここに移りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
