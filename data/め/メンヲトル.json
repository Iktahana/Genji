        "examples": {
          "standard": [
            {
              "text": "料理の煮崩れを防ぐために、大根の角を丁寧に面を取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "DIYで製作した棚の角が危なくないよう、やすりで面を取っておいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "職人はカンナを使って、一本一本の木材の面を取る作業を黙々と続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "（新吾と長七は面を取る。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、おじいさんは顔からお面を取ると、いいました。",
              "citation": {
                "source": "お面とりんご",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何うして、神棚から繪圖面を取る氣になつたんだ、誰に頼まれたんだ」　不思議な娘心を、平次も追及せずには居られません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "城の繪圖面",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうして、神棚から絵図面を取る気になったんだ、誰に頼まれたんだ」　不思議な娘心を、平次も追及せずにはいられません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "城の絵図面",
                "note": "青空文庫"
              }
            },
            {
              "text": "囃子も、踊りも、ひときわ休息に入ったけれども、この連中のすべてが仮面を取ることをしませんから、誰がどうだと正体のほどはわかりません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、覆面の客は少女を後に従えて、ずっと玄関を通ってしまって、ゆるゆると内部の見学にとりかかったのだが、それにしてもこの女客は、堂内へ入ってすらもその覆面を取ることをしませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
