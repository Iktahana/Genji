        "examples": {
          "standard": [
            {
              "text": "日々の読書と瞑想によって、智を磨くことを心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "若い頃から、自己啓発のために常に智を磨く努力をしてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この困難な時代を生き抜くためには、日夜、智を磨く必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "とにかく何彼につけて疑問を出し理智を磨く習慣を作るのがよい。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "理智を磨くには数学とか、進化論とか、動植物学とか、心理学とか、法律学経済学とかの書物を読む習慣を作るのもよい。",
              "citation": {
                "source": "婦人と思想",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上とも実戦のたびには、日頃の小智にとらわれず、よく大智を磨くがよい」　語り終って、曹操は、杯をあげた。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
