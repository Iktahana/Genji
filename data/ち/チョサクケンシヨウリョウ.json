        "examples": {
          "standard": [
            {
              "text": "音楽配信サービスでの再生回数に応じて、アーティストに著作権使用料が支払われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テレビ番組でヒット曲を使用するたびに、放送局は膨大な著作権使用料を納めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「著作権使用料の分配ルールが不明確だ」と、若手作曲家たちが声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "○社団法人東京音楽協会では著作権使用料問題からパリ著作権聯盟（カルテル・デ・ソチエテー・ドツエル）の代理人ドクトル・プラーゲの代理人たることを拒否する旨通告したのに対して去る十月四日パリのカルテルから東京音楽協会宛に次の如き入電があった。",
              "citation": {
                "source": "「プラーゲ旋風」の話",
                "author": "山下博章",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
