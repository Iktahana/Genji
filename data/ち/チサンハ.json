          "standard": [
            {
              "text": "智山派の寺院は、美しい庭園と歴史的な建造物で知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は智山派の教えを深く学び、その精神を広めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の古刹は、智山派に属する由緒ある寺院だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今眞言宗新義派の智山派に屬す。",
              "citation": {
                "source": "鹿野山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おいちさんは泥棒をした。",
              "citation": {
