        "examples": {
          "standard": [
            {
              "text": "子供たちはちりめん紙を使って、カラフルな飾りを作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ちりめん紙は、柔らかくて加工しやすいのが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誕生日パーティーの飾り付けに、ちりめん紙の花をたくさん作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本から輸入されたらしい桃色のちりめん紙で鉢を包んでもらって、すぐその近所の先生の宅へ持って行った。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大輪な薄紫の西洋菊が咲いている鉢なのだが、花のまわり、鉢のまわりを薄桃色に染められた経木の大幅リボンが園遊会の柱のようにまきついて、みどりのちりめん紙でくるんだ鉢のところで大きい蝶結びになっている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
