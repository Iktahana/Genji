        "examples": {
          "standard": [
            {
              "text": "敵の攻撃は激しく、船は直撃弾を受け炎上した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "不運にも、そのビルはテロリストの直撃弾によって崩壊した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦争映画では、直撃弾によって一瞬で状況が変わる場面がよく描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "直撃弾を受けたら痛いだろうなと思った。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直撃弾は、あたらなかった。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしても直撃弾なら為方もないことですが、その外では、破片と爆風とが恐しいのですから、これを防ぐには穴に入るより外ありません。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "直撃弾を喰って帰りたいにも、自宅のなくなってしまった人も大勢いるし、僕と小山は吉祥寺の亀井勝一郎君の許に一週間ほど御厄介になったのだ。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
