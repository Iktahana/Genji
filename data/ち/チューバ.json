          "standard": [
            {
              "text": "オーケストラで「チューバ」は低音を支える重要な楽器だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は高校で「チューバ」を担当している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「チューバ」の重厚な響きは、音楽に深みを与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "主婦と娘と、家事の見習いかたがた手伝いに来ているというスチューバー嬢と四人で行きました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつしはいままでに舞台を踏んだ中じや一番みごとなチューバル（「ベニスの商人」に登場する端役）だつたぜ。",
              "citation": {
                "source": "村の吸血鬼",
                "author": "THE VAMPIRE OF THE VILLAGE",
                "note": "青空文庫"
              }
            }
          ]
        }
