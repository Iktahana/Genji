          ],
          "literary": [
            {
              "text": "「いいちょんの間だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げたらあかんし」と蓮葉に言って、赤い斑点の出来た私の手の甲をぎゅっと抓ると、チャラチャラと二階の段梯子を上って行ったが、やがて、「――ちょんの間の衣替え……」と歌うように言って降りて来たのを見ると、真赤な色のサテン地の寝巻ともピジャマともドイスともつかぬ怪しげな服を暑くるしく着ていた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルロ・ナインも起して連れて来てもいい……ほかはちょんの間に寝かしとけあいい。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょんの間なら、一円五十銭でも自分を売ろうという呼びかけである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、すまねえが、ちょんの間、そうしてもらおうか」　林冲は、彼らのなすままに委せていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ちょんのま、ここへ姿を現わしたのは、彼の道術“神行法”の秘を使って、風のごとくさっと忍んで来たのである。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
