        "examples": {
          "standard": [
            {
              "text": "隣国との緊張が高まり、国境に駐兵された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その国は、自国の安全保障のために他国への駐兵を要請した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国連は、紛争地域への駐兵を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それを拂ふ拍子に私はふと、出入口の方から私の靴を見てゐる進駐兵のあるのに氣付いた。",
              "citation": {
                "source": "おばあさん",
                "author": "ささきふさ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、関東説に与せば天誅すべしと、軟論公卿の表門へ貼紙があるころ、さきの小笠原図書頭の淀駐兵以来ひそかに醸成されつつあったクーデターの気運も熟して、中川宮の密参内と薩会淀の連合兵力による「八月十八日の変」を見た。",
              "citation": {
                "source": "尊攘戦略史",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
