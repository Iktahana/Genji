        "examples": {
          "standard": [
            {
              "text": "今回の衆議院選挙では、地方区から多くの新人候補が立候補しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その候補者は、地方区での草の根運動を通して支持を広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "残念ながら、彼の選挙区は地方区なので、私が投票することはできないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "参議院には民主的教育者三名が全国区から当選、地方区で三名が当選している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ウラル経済地方区中心）　○朝窓をあけたら淡雪が黄色い草の上にまばらにあった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一五七一年九月、惟政の戦死後間もなく、フロイスはインド地方区長に宛てて惟政に関する愛情のこもった長い書簡を送っている。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
