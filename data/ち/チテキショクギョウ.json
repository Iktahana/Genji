          "standard": [
            {
              "text": "医師や弁護士は、一般的に知的職業に分類されることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は知的職業に就くことを目指し、日々勉強に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "知的職業に求められるのは、単なる知識だけでなく、思考力や判断力だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女は、彼女の父親の代から属していた有産階級と絶縁し、家庭教師その他知的職業によって生活する一人の無産者となった。",
              "citation": {
                "source": "アンネット",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
