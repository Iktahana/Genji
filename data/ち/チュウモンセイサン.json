        "examples": {
          "standard": [
            {
              "text": "この工場では、顧客の細かい要望に応えるため、注文生産を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オーダーメイドの家具は、すべて注文生産で制作される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "注文生産にすることで、余分な在庫を抱えるリスクを軽減できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "研究の方向や結論が与えられて、注文生産的研究調査を強いられることが多い。",
              "citation": {
                "source": "調査機関",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが人口が群集し分業が進むにつれ、漸次注文生産に移る。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが近代においてこの注文生産は漸次に廃れ、商品時代へと転じた。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
