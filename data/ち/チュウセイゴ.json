        "examples": {
          "standard": [
            {
              "text": "中世語の研究は、日本語の歴史的変遷を理解する上で不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "平安時代から室町時代にかけての日本語は、中世語と呼ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "その古文書には、現代語とは異なる中世語の表現が多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "われわれが現実詩をば、古語・中世語又は、近古語で列ねるのも、其と同じ事で、やはり一つの文体として認めねばならぬ。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯言語の一部分に於て、われわれの知っている中世語或は古語の結びつきを見る事もある。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ／＼が現実詩をば、古語・中世語又は、近古語で列ねるのも、其と同じ事で、やはり一つの文体として認めねばならぬ。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯言語の一部分に於て、われ／＼の知つてゐる中世語或は古語の結びつきを見る事もある。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の古語中世語に渉つて、かなしはかはゆい・いとしい・愛すべきもの或は繊細なものを意味してゐた。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち山人の男子のやや年輩の者を、幾分尊んで用いた称呼にして、正しく山姥と対立すべき中世語であった。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガンドは中世語で強盗のことだから、まず極端なる誇張であるが、以前は断りなしに雛の供物を取ってゆくのが、子どもには何よりの楽しみだったらしい。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
