        "examples": {
          "standard": [
            {
              "text": "著名なアーティストが、プライベートのチャーター機で世界ツアーを行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "災害発生時、緊急支援物資を運ぶためにチャーター機が使われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "我が社では、海外出張の際に時々チャーター機を利用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "監督やカメラマン、主演の俳優たち、それにセカンド・ユニットまで、映画づくりのためのスタッフが、チャーター機でいっぺんに島へやって来る。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャーター機は時間どおりに到着した。",
              "citation": {
