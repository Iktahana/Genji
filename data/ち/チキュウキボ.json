        "examples": {
          "standard": [
            {
              "text": "インターネットの普及により、地球規模での情報のやり取りが瞬時に行える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新型ウイルスの流行は、地球規模のパンデミックを引き起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経済のグローバル化によって、地球規模での格差問題が深刻化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "突き崩したところに、地球規模で共有できる新しい精神を育み得るのかを、私たちはこれから問われていくのでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすれば、生まれつつあるのは、地球規模の枠組みで新しい共通の価値を見いだすための触媒ではないだろうか。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "推測を交えずに定量的な推定を行うことは不可能だが、退廃彫刻が製作されてから百万年も経っていないのではないかと思われ、また都市の放棄が完了したのは、全地球規模でみた通常の更新世の幕開け――五十万年前――をかなり遡る時期だったと思われた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
