        "examples": {
          "standard": [
            {
              "text": "1993年にチェコスロバキアは解体され、チェコとスロバキアという二つの国に分かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "冷戦時代のチェコスロバキアで起きた「プラハの春」は、歴史の重要な転換点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "父が持っている古い切手アルバムには、今はなきチェコスロバキアの切手が並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ドイツからチェコスロバキアを通り、ポーランドの国境へ着いたのが午前四時半、すると突然、剣付き鉄砲を持った四人の兵隊に汽車から降されてしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五　百姓弥之助は東京から植民地への帰りに、新聞を見るとドイツ軍のオースタリー侵入の記事が目に附いた、それと共にチェコスロバキアがふるえ上って居るという脇見出しもある。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このビールはコクがあって、日本のどのビールよりもうまいのはもちろん、アメリカ、イギリス、ドイツ、チェコスロバキア、フランスのビールよりもうまい。",
              "citation": {
                "source": "デンマークのビール",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "チェコスロバキアのビールは、ちょいと中将湯のようなにおいと味とを持っています。",
              "citation": {
                "source": "デンマークのビール",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレマイヤ　はははっ、黒人ロボット、スウェーデン人ロボット、イタリア人ロボットに中国人ロボット、あとチェコスロバキア人ロボット、それから――ヘレナ　ハリィ！",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
