        "examples": {
          "standard": [
            {
              "text": "家督争いの結果、敗れた方は蟄居閉門の処分を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は不祥事の責任を取り、蟄居閉門を命じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その武士は、主君の怒りに触れて蟄居閉門となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "殿さまが座敷牢にでもおはいりかい」「いいや、家老がね、なんの罪もねえのに、もう三月ごし、蟄居閉門を食っているというんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家から特別の御賞美をたまわっているだけに、かれの責任はいよいよ重いことになって、軽くても蟄居閉門、あるいは切腹――将軍家からはさすがに切腹しろとは申渡すまいが、当人自身が申訳の切腹という羽目にならないとも限らない。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年｜内匠頭様刃傷の際にも、大垣の宗家を始め、わが君侯にも連座のお咎めとして、蟄居閉門をおおせつけられたではないか。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
