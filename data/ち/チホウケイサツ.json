        "examples": {
          "standard": [
            {
              "text": "事件の解決には、地方警察と連携して捜査を進める必要があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地域の安全を守るため、地方警察は日夜パトロールを強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行中、困ったことがあったら、近くの地方警察に相談するといいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "リクリエーション運動の指導は地方警察と連絡すべしというような反民主的な本質をもっている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとほとんど同時刻に、クロスレイも二つの新聞をまとめて、彼は地方警察へではなく、直接注意を促して｜ロンドン警視庁へ送り付けた。",
              "citation": {
                "source": "浴槽の花嫁",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為には地方警察の協力が必要だろう。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
