        "examples": {
          "standard": [
            {
              "text": "レーシングカーのボンネットに、派手なチェッカー模様のステッカーを貼った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "白と黒のチェッカー柄のミニスカートが、今年の春のトレンドらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "モノトーンのインテリアに、チェッカー柄のクッションが良いアクセントになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
