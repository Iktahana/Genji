        "examples": {
          "standard": [
            {
              "text": "公園を横切るのが一番の近回りだと教えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "急いでいたので、細い路地を通って会場まで近回りをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地図で見ると遠そうだが、地下通路を使えばかなりの近回りになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そのころから重吉は小さい舟でいろいろなものを近回りへ運ぶ海の上の便利屋のような仕事をしていた。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川は大して曲がりくねりもせずドラムガニョールの古い百姓家の近くを通っていたため、そのような時には家に帰る住民が近回りをするための道のようになっていたのです。",
              "citation": {
                "source": "ドラムガニョールの白い猫",
                "author": "Ｊ. Ｓ. レ・ファニュ　J.S.Le Fanu",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
