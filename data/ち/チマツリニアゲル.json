        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古代の部族は、戦の勝利を祈願して敵兵を血祭りにあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "勇猛な戦士が敵の隊長を血祭りにあげ、味方の士気を大いに高めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らは敵将を捕らえ、見せしめのために血祭りにあげたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
