        "examples": {
          "standard": [
            {
              "text": "初めてのデートで、彼と少しぎこちないチークダンスを踊ったのを覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のワンシーンのように、二人は優雅にチークダンスを舞った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "懐かしい音楽に合わせて、年配の夫婦が楽しそうにチークダンスをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "チークダンス　チークダンスの実況写真が某紙にスッパ抜かれて、ダンスのタイハイこゝに至る、ホール業者、ダンス教師、御愛好の男女代表、ダンサー、文部省、警視庁、御歴々が御参集あって協議あらせられたとある。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この写真に見参するまで、私はもっぱらカストリなどにかゝりきっていて、チークダンスという言葉も知らなかった。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンスは、ダンスを踊って交合の低さとワイセツでしかない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり我々の多くが、男女関係というと、チークダンスのようなことにしか主点がない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは亭主関白とオサンドンとの関係であり、裏面ではチークダンスの関係である。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンス愛好家は悪趣味、無教養というだけのことであるから、その対策はフンジバルこととは別だろうと私は思う。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チークダンスの必要がないのだもの。",
              "citation": {
                "source": "安吾巷談",
                "author": "田園ハレム",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
