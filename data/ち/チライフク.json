        "examples": {
          "standard": [
            {
              "text": "易経における地雷復は、物事が元の状態に戻る「復」の象徴とされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な状況の中、地雷復の卦を読み解き、希望を見出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の人生は、まさに地雷復の卦が示すように、一度は失ったものが再び戻ってくる経験の連続だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その五十九　抽斎はしばしば地雷復の初九爻を引いて人を諭した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
