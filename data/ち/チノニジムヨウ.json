        "examples": {
          "standard": [
            {
              "text": "このプロジェクトを成功させるには、血のにじむような努力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は血のにじむような練習を重ねて、ついに夢を掴んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「血のにじむようだったけど、諦めずにやり遂げたよ」と彼は達成感をにじませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この一本の山茶花のほかの何ものをも残し得なかった生涯、六十何年間の、血のにじむような、労苦に満ちた人生だったとも言えるのである。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室も生徒も他の女学校と見たところ同じようなもので、タダの女学校の教室よりも揃ってマジメに授業をうけているオモムキはハッキリしているけれども、特に血のにじむような気魄がこもっているところは全くありません。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "石田夫妻は、石田氏がまだ農林省の下級技官だった時代に、先代に見こまれて夫婦養子の縁組みをしたが、見かけだけは、胆をつぶすような宏荘な邸に住んでいたため、わずかばかりの俸給で身分不相応な体裁を張るのに、何年となく、血のにじむようなやりくりをしてきたものだった。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために彼は血のにじむような苦痛を重ねていたのだ。",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
