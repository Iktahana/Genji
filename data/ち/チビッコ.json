          "standard": [
            {
              "text": "公園には、たくさんのちびっ子たちが遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ちびっ子向けのイベントが開催され、会場は賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "妹のちびっ子時代は、本当に手がかかる子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「里っ子、ちびっ子、よういよい。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちびっ子、じろっ子、よういよい。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちびっ子のくせに骨を折らしやがった」　悪漢はそう云うと、麻酔剤の為に眠りに落ちていった文子をそこに寝かして、わめいた。",
              "citation": {
                "source": "骸骨島の大冒険",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかい　ふく　きた　ちびっこが　てには　ぼうきれ、　のどには　こいし、　このなぞ　とけたら　おだちんやるぞ。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            }
          ]
        }
