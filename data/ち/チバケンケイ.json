        "examples": {
          "standard": [
            {
              "text": "千葉県警は、特殊詐欺の被害防止を呼びかけるキャンペーンを実施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "交通事故が発生し、すぐに千葉県警のパトカーが現場に駆けつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新聞記事によると、千葉県警が新たな防犯対策を導入するらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "姉夫婦が、悲惨な最期を遂げたのも、つまりは千葉県警察の怠慢であるように思いまして、私は此の刑事を頭から罵倒してやりたいようないらいらした気持をさえ感じました。",
              "citation": {
                "source": "ある抗議書",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉県警察部長の談では、警察官吏、及警察医の報告によれば合意の心中であった事が明確ゆえ、たとい相手方の一人が仕損じて生存していたとて何らの犯罪も構成しない。",
              "citation": {
                "source": "芳川鎌子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
