        "examples": {
          "standard": [
            {
              "text": "王陽明の唱えた知行合一の思想は、実践の重要性を説いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ただ知識を得るだけでなく、それを実践してこそ知行合一と言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は知行合一を座右の銘とし、常に行動を伴うことを心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "プラトーンは、王陽明などと同じ樣に、知行合一を唱へた。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸象山云って曰く、――我心は天の与うるもの、万物の理は心内に在り、心内思考一番すれば、一切の理を認識すべしと――ところが陽明先生であるが、その象山の学説よりおこり、心即理、知行合一、致良知説を立てられた。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
