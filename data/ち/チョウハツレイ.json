        "examples": {
          "standard": [
            {
              "text": "地方当局は、必須医療用品の徴発令を発令した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "徴発令には、必要な正確な数量が明記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、緊急時のための財産の徴発命令を受け取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "匈牙利に石油が少くなって、陸軍から石油の非常徴発令が発せられた。",
              "citation": {
                "source": "生きている戦死者",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、綸旨の名による体のよい借用状、徴発令に、現実の大きな実力がないことは分明である。",
              "citation": {
                "source": "織田信長",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遷都令と同時に軍費徴発令をお発しありたいと存じます」「いいようにやれ、いちいち法文を発するには及ばん」「では、ご一任ください」　李儒は五千人を選んで、市中に放ち、遷都と軍事の御用金を命ずると称して、洛中の目ぼしい富豪を片っぱしから襲わせた。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
