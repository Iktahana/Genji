        "examples": {
          "standard": [
            {
              "text": "著作者人格権は著作者本人に専属する権利であり、他人に譲渡することはできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "作品のタイトルを勝手に変えられた著者は、著作者人格権の侵害を訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「公表権や氏名表示権も、著作者人格権の重要な一部を構成しています」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "法の用語では、前者を「著作者人格権」、後者を狭い意味での「著作権」と呼ぶ。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「著作者人格権」には、三つの権利が束ねられている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「著作者人格権」と「著作財産権」は、共に著作者に認められた権利であるが、いつまで認められるかという点では、際だった違いがある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「著作者人格権」には、期限の定めがない。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「著作者人格権」には期限がなく、もう一方の「著作財産権」はある時点で消滅すると定められている事情は、そもそも著作権法が、何を目指しているかを確認すれば、理解できる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文化の発展に寄与する」という目的に照らせば、「著作者人格権」に期限を設けないことには、妥当性がある。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
