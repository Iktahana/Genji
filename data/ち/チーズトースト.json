        "examples": {
          "standard": [
            {
              "text": "休日の朝食は、とろけるチーズが乗ったチーズトーストに限る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "簡単に作れるのに美味しいから、小腹が空いた時にチーズトーストをよく作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カフェで食べたチーズトーストは、カリカリのパンととろーりチーズの相性が抜群だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夕刻迄ゐて、日東コーナーハウスのチーズトーストを食ひ、銀座裏の道八てふしるこやへ寄り、七時前に今日の会場、青山のいろはへ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、チーズトースト、コールドコンソメ、ピロシキー一、タンシチュウ・マッシュドポテト添。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食ひものも、チーズトースト、それにマカロニ・グラタン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "サントリータンサン、チーズトースト、伊藤にお任せの、ビーフ・ミニツステーキ風、バタライス、マッシュポテト添。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
