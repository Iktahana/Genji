        "examples": {
          "standard": [
            {
              "text": "人間の行動は、脳と脊髄からなる中枢神経系によって制御されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は事故で中枢神経系に重度の損傷を負い、長いリハビリが必要となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しい治療法は、中枢神経系の疾患に苦しむ患者に希望を与えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "生理学の初歩の書物を読んでみると、皮膚の一部をつねったりひねったりするだけで、腹部の内臓血管ことにその細動脈が収縮し、同時に筋や中枢神経系に属する血管は開張すると書いてある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って僅か20年のあいだに中枢神経系の重篤なウイルス疾患の少なくとも３つの新しい型が出現した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、判っていない環境で多くのウイルス感染は中枢神経系の障害を起こすことがある。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
