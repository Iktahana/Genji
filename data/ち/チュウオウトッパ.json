        "examples": {
          "standard": [
            {
              "text": "サッカーの試合で、彼は中央突破から見事なゴールを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "敵の防衛線を中央突破するのは非常に難しい作戦だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は困難な状況を中央突破し、プロジェクトを成功に導いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "物凄い中央突破である。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに於てナポレオンは、砲七十門をもって普軍の中央に対し準備砲撃を加え、近衛の一部、騎兵第四軍団、第六軍団を以ってリーニーに向い中央突破を敢行せしめた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "本会戦はナポレオン得意の中央突破戦法であって第二線決戦の好範例である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違えば生命を失う決心をして、彼は怪事件解決のために、中央突破を敢行したわけだった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
