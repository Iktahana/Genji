        "examples": {
          "standard": [
            {
              "text": "独裁政権を転覆させるため、市民たちは秘密裏に地下組織を結成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は表向きは実業家だが、実は巨大な犯罪地下組織の幹部という顔を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スパイ映画のような展開だが、戦時中の地下組織の活動記録が最近になって発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ファシストの地下組織が千葉で発覚しています。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉のファシスト地下組織は、もと上海特務機関中尉である大島軍司という人物を中心にして、千葉県知事、市長、成田山の僧正、千葉市警察署長、その他各地の警察署長とれんらくして、大島は警察パス、外務省パスを所持して、現在は法務庁に籍を持っているそうです。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "噴水の鶴が最近に至って鳴き始めたのは今いったような地下組織の変化が原因しているものと思う。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンウッドは秘密儀式や地下組織にのめり込む性癖がありました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
