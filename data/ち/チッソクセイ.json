        "examples": {
          "standard": [
            {
              "text": "この空間は、窓が閉め切られていて窒息性だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "強い締め付けのある服は、窒息性で息苦しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は人混みの中で窒息性を感じ、気分が悪くなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "糜爛性ガス、催涙性毒ガス、窒息性毒ガス、あのガラスの筒が投下された瞬間を想像するとぞっとしてしまふのだった。",
              "citation": {
                "source": "稲妻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "窒息性のホスゲンは堆肥くさく、催涙性のクロル・ピクリンはツーンと胡椒くさく、糜爛性のイペリットは芥子くさいから、瓦斯のあるなしはすぐわかるのだ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、どういうものですか」「軍では『コロンジット』という秘匿名で呼んでいるが、窒息性のホスゲン瓦斯なんだから問題だ。",
              "citation": {
                "source": "悪の花束",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
