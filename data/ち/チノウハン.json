        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は長年の捜査で多くの知能犯を追い詰めてきたベテラン刑事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その知能犯は証拠を残さないように細心の注意を払っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "メディアは彼を「平成最後の知能犯」と呼んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
