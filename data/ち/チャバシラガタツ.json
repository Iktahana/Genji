        "examples": {
          "standard": [
            {
              "text": "今朝、お茶を飲んでいたら茶柱が立って、なんだか得した気分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「見て、茶柱が立ってるよ！今日はきっといい日になるね」と彼女が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茶柱が立つのは珍しいから、何か幸運が訪れる前触れかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「おばアちやん、清治のお茶、また茶柱が立つてゐますよ」　雪見障子から薄い朝の陽が射し込んでゐる。",
              "citation": {
                "source": "夜福",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
