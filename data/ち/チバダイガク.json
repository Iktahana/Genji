        "examples": {
          "standard": [
            {
              "text": "友人が千葉大学の医学部に通っていて、毎日忙しそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "千葉大学は、様々な分野で優れた研究成果を上げている総合大学だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏には千葉大学のキャンパスで、地域の子供たち向けのイベントが開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "千葉大学工学部電子工学科に籍を置いていた彼が学生生活の最後の年を過ごしている夏に、日本電気からＴＫ―80が発売され、大変な人気を集めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七（昭和五十二）年四月に千葉大学工学部電子工学科から日本電気に入社し、マイクロコンピュータ販売部に配属された土岐泰之は、アメリカ西海岸で吹きはじめた風にいち早く反応した一人だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
