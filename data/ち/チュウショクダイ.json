        "examples": {
          "standard": [
            {
              "text": "今日の昼食代は私が払うよ、いつもごちそうになっているからね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎月の昼食代が予想以上にかさんでいるので、節約を考えなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "社員食堂を利用すれば、昼食代を安く抑えることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "電車賃や、昼食代を差引くと、いくらも残らない額だった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "段取りをして、昼食後半時間リカビー氏と話ができたら、十ポンド差し上げた上に、昼食代を持ちやす。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこそ心の気晴らし、昼食代は相手持ちだし、実に贅沢だ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
