        "examples": {
          "standard": [
            {
              "text": "寺院の梵鐘とは異なり、朝鮮鐘は独特の形状と音色を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この朝鮮鐘は、国宝に指定されている歴史的価値の高い逸品だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い寺院の庭園に、静かに佇む朝鮮鐘が風情を添えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "併し社務所へ案内せられて、宮司さんから泡盛の神酒を頂き、國寶の鐘を拜觀した處、これは又々日本全國に遺つてゐる朝鮮鐘數十口のうちでも、第六位に古いもので、顯徳三年太歳丙辰正月廿五日の銘がある。",
              "citation": {
                "source": "沖繩の旅",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
