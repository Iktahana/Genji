        "examples": {
          "standard": [
            {
              "text": "土壌サンプルから多数の虫卵が検出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "農作物を荒らす害虫の虫卵を駆除することが、収穫量を増やす鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館の展示では、様々な昆虫の虫卵が紹介されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "知らない間に空気から結核菌を得、水や野菜から十二指腸虫卵を得、アノフェレスから瘧を得るようなことは、招かずして得た疾病である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
