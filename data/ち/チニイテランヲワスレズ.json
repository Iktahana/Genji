        "examples": {
          "standard": [
            {
              "text": "災害が少ない地域でも、治に居て乱を忘れず、常に備えが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "平穏な時代だからこそ、治に居て乱を忘れず、危機管理を怠らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "リーダーは、治に居て乱を忘れずの精神で、常に最悪の事態を想定しておくべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "メリケンが怖くてはメリヤスのシャツも着れないという意味の洒落にちがいないと、私はかねがね他アやんが洒落の名人であったことを想い出し、治に居て乱を忘れずとはこのことだと呟いているところへ、只今と帰って来たのは他アやんの細君であった。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
