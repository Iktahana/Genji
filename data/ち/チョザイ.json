        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「樗材の私をお引き立ていただき、身の引き締まる思いでございます」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自分のことを樗材と卑下するが、その勤勉さは誰もが認めるところだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "樗材と思っていた木が、実は高級家具の材料として珍重されるものだと判明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「偶作」中にも亦「樗材居世不如愁」、「伝家宝只有書蔵」等の句があつてわたくしの目を惹いた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "useless person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
