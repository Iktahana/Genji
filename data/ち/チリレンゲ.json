        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ラーメンのどんぶりに添えられた散り蓮華で、熱々のスープを掬う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "陶器製の散り蓮華は口当たりが滑らかで、チャーハンがより美味しく感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "セットの中華皿と一緒に、お揃いの柄の散り蓮華を並べて食卓を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ただに食器に散り蓮華があるのみでない。",
              "citation": {
                "source": "巨椋池の蓮",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油注ぎ、手塩皿、ちりれんげ、なぞの載っている盆を持出した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
