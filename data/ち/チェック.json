        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "多額の現金を運ぶのは危険なので、支払いはすべてチェックで行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は小切手帳を取り出し、サインを書き添えて千ドルのチェックを切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "銀行の窓口で、受け取ったチェックを現金化する手続きを済ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
