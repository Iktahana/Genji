          "standard": [
            {
              "text": "家を出る前に、忘れ物がないかカバンの中を最終チェックした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "メールを送信する前に、宛先と添付ファイルに間違いがないかチェックしてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "健康診断の結果を詳しくチェックして、食生活を改善することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
