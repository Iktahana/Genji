        "examples": {
          "standard": [
            {
              "text": "歴史の授業で、中共軍が果たした役割について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の研究テーマは、戦後の中共軍の組織再編だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国境付近で中共軍の動きが活発になっているとの報告があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "国府軍と中共軍とは実に悠長に戦線を波動させている。",
              "citation": {
                "source": "新たな世界主義",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまえに、私が戦争中にその目撃者からきいた国民党政権下の中共軍パルチザン部隊の老兵士の話を思いだしてみます。",
              "citation": {
                "source": "抵抗のよりどころ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
