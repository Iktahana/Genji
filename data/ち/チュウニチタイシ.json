        "examples": {
          "standard": [
            {
              "text": "新しい駐日大使が着任し、両国関係の更なる発展に期待が寄せられています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "駐日大使館では、文化交流イベントが頻繁に開催されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本の首相は、新任の駐日大使と会談し、友好関係を深めることで合意しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "九月二十五日頃から毎日新聞にもとのアメリカ駐日大使グルーの回想記がのりました。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "前駐日大使ポール・クローデルはヴァレリイと並んでフランス詩壇の大御所であった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これについては、先日前駐日大使のグルウさんとも話し合ったのでありますが、グルウさんもまったく私と同じ意見でありました。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
