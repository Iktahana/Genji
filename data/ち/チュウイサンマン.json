        "examples": {
          "standard": [
            {
              "text": "彼の注意散漫な態度は、会議の進行を妨げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テスト中に注意散漫になり、簡単なミスを連発してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンは、現代人の注意散漫の原因の一つと言われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "年じゅうきょろきょろしている彼は、「注意散漫」という特性が刻印されていた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　不仕合わせに育った子供の一人である塚原義夫を、ちっとばかり幸福にしてやるために――つまりは彼の特質である哀しい注意散漫を削ってやるための一つは、〇・五しかない視力を近眼鏡で補ってやることであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽気なピロちゃんは、すこし注意散漫の傾向がある。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意散漫のピロちゃんが、また妙なものを見つけた。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
