        "examples": {
          "standard": [
            {
              "text": "巻末に掲載された膨大な著作目録から、著者がいかに多作であったかが伺える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "研究の第一歩として、まずは先行研究の著作目録を徹底的に洗うことから始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "著作目録を整理することで、その分野の歴史的背景が浮き彫りになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "リルケの著作目録を上げますから。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處で自分は上野の圖書館に通つて、あらゆる文藝雜誌を借覽して「泉鏡花先生著作目録」といふものを作つた。",
              "citation": {
                "source": "貝殼追放",
                "author": "購書美談",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　椀貸し淵大和の水木直箭さんの作つた柳田先生の著作目録の中にも、一つの重要な項目になつてゐるものに「椀貸し塚」がある。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
