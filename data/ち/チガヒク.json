        "examples": {
          "standard": [
            {
              "text": "恐ろしい光景を目の当たりにして、サーッと顔から血が引いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の重大なミスに気づいた瞬間、血が引くような感覚に襲われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幽霊を見たという彼の話を聞いて、思わず血が引く思いがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その視線のもとで、彼女は突然頬に血を漲らし、その血が引くと、薄い皮膚が透き通って見えるほどに緊張した。",
              "citation": {
                "source": "非情の愛",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まことに残念ですが」予期したこととはいいながら、途端に私は自分の顔から颯と血が引くのを感ぜずにはいられなかった。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだスウェデン文學は、その國語たるスウェデン語で書かれてゐますが、瑞典語と他の二國語との相違は殆んどいくらもないといつてよろしいので、まづ東京語と、名古屋語と、大阪語とのちがひくらゐと言へば言へませう。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
