        "examples": {
          "standard": [
            {
              "text": "この通りの標識には、「駐車禁止」と大きく書かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "早朝のこの時間帯は、交通の流れを確保するため駐車禁止だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、うっかりして！ここは駐車禁止だったのか」と彼は慌てて車を動かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
