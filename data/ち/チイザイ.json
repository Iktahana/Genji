        "examples": {
          "standard": [
            {
              "text": "地位財は、他人との比較によって価値が決まる財であるとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経済学では、地位財と非地位財の概念が幸福論と関連付けて議論される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高級車やブランド品は、典型的な地位財の例として挙げられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして今の地位財産を貴方のお手にお返し申上げなければなりません。",
              "citation": {
                "source": "鉄の処女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる地位にあろうとも、父祖の地位財宝を擁しているだけでは、凡人以下の凡人である。",
              "citation": {
                "source": "青年の天下",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
