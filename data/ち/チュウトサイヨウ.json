        "examples": {
          "standard": [
            {
              "text": "我が社では、経験豊富な人材を求めるため、「中途採用」に力を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、前職での経験を活かし、「中途採用」で現在の会社に入社した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「中途採用」の面接では、これまでのキャリアパスと今後の目標について詳しく聞かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さらに秋には、中途採用の高卒組が一小隊ほど入ってきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ビデオ事業の拡張に伴い、人材を募集する」とした中途採用の募集広告を見た藤井は、大企業を覗いてみるのも経験と考えて電話を入れてみた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
