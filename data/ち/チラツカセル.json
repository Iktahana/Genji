        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "空にはまだ雲が厚く、時折白いものがちらつかせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小雪が風に舞い、遠くの山々が白くちらつかせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の訪れを告げるように、雪がちらつかせ始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
