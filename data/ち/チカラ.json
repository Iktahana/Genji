        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はまだ若いが、リーダーとしてチームをまとめる力は十分にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自分の持てる力をすべて出し切ったので、結果がどうあれ悔いはない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "読解力を養うためには、ジャンルを問わず多くの本を読むことが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "efficacy",
