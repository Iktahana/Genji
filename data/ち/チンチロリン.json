    "definitions": [
      {
        "index": 1,
        "gloss": "chirping",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の夜長に、庭先からちんちろりんと虫の鳴く声が聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "風鈴が風に揺れて、ちんちろりんと涼しげな音を響かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ちんちろりん、ちんちろりん」と、子供が鈴を鳴らしながら遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "水門の上を蒼白い月がのぼり、栴檀の葉につやつやと露がたまれば膽のわななきもはたと靜止して足もとにはちんちろりんが鳴きはじめる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あかあかと阿波の鳴門の巡禮が泣けば…………ころべば…………韮の葉が…………芝居小屋の土間のむしろに、ちんちろりんと鳴いづる。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘村で名代の鐘撞男月がよいのでうかうかと鐘をつくのもつひわすれ灯のつく街がこひしさに山から港へではでたが日がくれるのに山寺の鐘はつんともならなんだ村長さまはあたふたと鐘撞堂へきてみれば伊部徳利に月がさしちんちろりんがないてゐた。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "新納武蔵守は薩摩武士の生粋で例の戯談好きな太閤様の歌にある、ちんちろりんのやうな長い鬚を生やした男だつたが、矢張り薩摩者に有りうちの、ちんちろりんのやうに雌を可愛がるので聞えた男だつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちんちろりんは随分な嫉妬焼きで雌が他の雄と談話でもしてゐようものなら、いきなり相手を後脚で蹴飛ばすさうだが、薩摩者もこの点ではちんちろりんに劣らぬ道徳家である。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　はつと思つて、女が袖の下へそれを隠すと、武蔵はちんちろりんのやうな顔で袖の下を覗き込む。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵も少しは歌を咏んだ男だけに、ちんちろりんのやうな顔に涙を流して不憫がつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度秋も末で、窓の外にはちんちろりんが意気な小唄を謡つてゐる頃であつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほどよく帰つて寝た、ちんちろりん／＼、いつしか睡つてしまつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "めづらしく宵寝、いろ／＼の夢を見た、とき／″＼眼が覚めて、孤独のおもひが澄みわたつた、身に迫つてちんちろりん、虫もさびしいのだろう！",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "草はすでに露にしめり、ちんちろりんが渓を隔てて鳴き合っている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
