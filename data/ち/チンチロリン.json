        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "山道に落ちていたちんちろりんを拾って、クリスマスリースの材料にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お母さん、見て！大きくて綺麗なちんちろりんを見つけたよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、森で集めたちんちろりんを宝箱の中に大切にしまっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
