        "examples": {
          "standard": [
            {
              "text": "正月の集まりで、親戚たちと少額を賭けてちんちろりんに興じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はちんちろりんのルールに詳しく、あっという間に周りのチップを巻き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どんぶりの中でサイコロが踊る、ちんちろりん特有の音が部屋に響く。",
              "citation": {
                "source": "幻辭AI",
