        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ちんちろりんの声に誘われて外に出てみると、満月が綺麗に輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "草むらの中でちんちろりんが鳴き始めると、ようやく秋の訪れを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ちんちろりんの鳴き声を録音して、リラックスするための環境音にしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
