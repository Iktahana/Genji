        "examples": {
          "standard": [
            {
              "text": "重い機械を持ち上げるために、作業員たちはチェーンブロックを設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "チェーンブロックを使えば、一人でも重量物を安全に移動させられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場の天井には、いくつものチェーンブロックが吊り下げられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "司祭館の焼け跡に、注文しておいたかのごとくチェーンブロックがあったのはいったいどうしたことだったろう。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから煉瓦塊の山に丸太をわたし、それにチェーンブロックをつけた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにチェーンブロックのかぎを引っかけた。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
