        "examples": {
          "standard": [
            {
              "text": "彼は中二病をこじらせていて、いつも意味深な言葉を口にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさか自分が世界を救うなんて」と呟く彼の様子は、完全に中二病だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中二病だった頃の恥ずかしい日記を読んで、顔から火が出る思いをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
