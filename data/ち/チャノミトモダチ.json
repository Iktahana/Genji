          "standard": [
            {
              "text": "おじいちゃんとおばあちゃんは、まさに茶飲み友達のような夫婦だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "定年後、穏やかな日々を茶飲み友達として共に過ごしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年連れ添った茶飲み友達と、静かな老後を送る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
