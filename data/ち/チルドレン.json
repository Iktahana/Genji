        "examples": {
          "standard": [
            {
              "text": "公園の噴水の周りで、チルドレンが元気に走り回って遊んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "戦争の犠牲になったチルドレンを救うため、世界中で募金活動が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この施設は、恵まれない環境にいるチルドレンの自立を支援している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ツルゲーネフの作物、就中『ファーザース・エンド・チルドレン』中のバザーロフなんて男の性格は、今でも頭に染み込んでいる。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もいったツルゲーネフの『ファーザース・エンド・チルドレン』の冒頭を、少々ばかり訳したことなどもあるが、坪内さんに見せたばかりで物にはならなかった。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「ア・ウーマン」といったのに、これでは「ア・グループ・オヴ・ウイメン・エンド・チルドレン」である。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気の直前に、ドビュッシーの『チルドレンス・コーナー』の入った時は、全く文字通り驚倒した。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実桜林は私たちのチルドレンス・コウナアであった。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
