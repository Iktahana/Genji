        "examples": {
          "standard": [
            {
              "text": "両親に蝶よ花よと育てられた彼女は、世間知らずなところがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "一人娘を蝶よ花よと甘やかして育てた結果、わがままになってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう大学なのに、まだ蝶よ花よ扱いなの？」と友人にからかわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "蝶よ花よと育てた愛女が、堕落書生の餌になる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだおやじがまだ都の東京で盛んに商売をやっていた時分は、わたしも朝湯寝化粧だったけれど、あの娘も蝶よ花よと小さいときからの芸仕込み。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
