        "examples": {
          "standard": [
            {
              "text": "誕生日のお祝いに、家族みんなで豪華なちらし寿司を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デパートの地下食品売り場で、様々な種類のちらし寿司が売られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "海外の友人に、日本の伝統的な料理としてちらし寿司を紹介した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "妻の料理の中で最もうまいのは、何といつても郷土風のちらし寿司である。",
              "citation": {
                "source": "わが妻の記",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ツ目うなぎ屋の横町で、三十銭のちらし寿司をふんぱつする。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
