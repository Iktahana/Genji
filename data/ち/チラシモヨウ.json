        "examples": {
          "standard": [
            {
              "text": "着物には、小花が散らし模様になった上品な柄が描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壁紙の散らし模様は、部屋全体に落ち着いた雰囲気を与えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が作った陶器の皿には、金箔の散らし模様が施されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "（ヒョイと見ると、その純白の上着の肩から胸へかけて、眼がさめるような原色の油絵具がベタベタと散らし模様のようにくっ付いている）タン　こりゃ、どうも！",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い地に沢山の揚羽の蝶が散らし模様になっていましたよ」　私は覚えていた。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
