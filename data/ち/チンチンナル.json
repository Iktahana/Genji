        "examples": {
          "standard": [
            {
              "text": "風鈴が心地よい音を立ててちんちんと鳴っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "首輪につけた鈴が、歩くたびにちんちんと鳴って可愛らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鍵束がポケットの中でちんちんと鳴り、居場所を教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "第一電車のちんちん鳴るので驚いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからそのちんちん鳴るあいだに、非常に多くの人間が乗ったり降りたりするので驚いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
