        "examples": {
          "standard": [
            {
              "text": "駅の中央口で友人と待ち合わせをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デパートの地下には、食品フロアへ続く中央口がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "混雑を避けるため、美術館の中央口ではなく別の入り口を利用した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "水をかけた土の穴からとめどなく這い出て来る蟻のように、中央口から背広姿の無個性なサラリーマンたちが群をなしてせわしく次々に吐き出される。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "出タノハ丸ノ内側ノ、中央口ニ近イ特別通路ノ外ノ御車寄デアッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
