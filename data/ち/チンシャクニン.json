        "examples": {
          "standard": [
            {
              "text": "大家は、賃借人（ちんしゃくにん）に対して、家賃の支払いを期日までに済ませるよう通知した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このアパートの賃借人リストによると、あなたは一番長く住んでいる方ですね。」と、管理人が話しかけてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "賃借人の許可なく、勝手に家の中に入ることはできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、賃借人に用役の享受を得せしめることである。",
              "citation": {
                "source": "純粋経済学要論",
                "author": "ELEMENTS D'ECONOMIE POLITIQUE PURE OU THEORIE DE LA RICHESSE SOCIALE",
                "note": "青空文庫"
              }
            }
          ]
        }
