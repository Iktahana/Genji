    "definitions": [
      {
        "index": 1,
        "gloss": "China and North Korea",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "経済制裁の影響で、中朝間の貿易が増加したという報道があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この地域における地政学的なバランスを考える上で、中朝関係は常に注目される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近、中朝の国境地域で、人々の往来が活発になっているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それに私も近い中朝鮮に伴れて行かれるのだから最早此世で會うことが出來るか出來ないか分りません。",
              "citation": {
                "source": "少年の悲哀",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "船中朝の食事は「スープ」の他冷肉、「ライスカレー」、「カフヒー」それに香料の入つた美麗しき菓子、其他「パインアツプル」等極めて淡泊な食事で、それが濟むと、日出雄少年は何より前に甲板を目指して走つて行くので、夫人も私も其後に續いた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吏人は見ず中朝の礼、麋鹿　時々　県衙に到る。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから床の間の掛物は年が年中朝日と鶴。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは性急な、しかし良家に育った人らしい調子で、「宅じゃこの通り朝顔狂ですから、小諸へ来るが早いか直ぐに庭中朝顔鉢にしちまいました――この棚は音さんが来て造ってくれましたよ――まあこんな好い棚を――」　と高瀬に話した。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒中朝寒い時に宿屋を出て、河を渡ろうと思て寒風の吹く処に立て一時間も船の来るのを待て居る、ヤッと船が着て、やれ嬉しやこの船に乗ろうと云う時に、不意と後ろから葵の紋の侍が来るとその者が先きへその船に乗て仕舞う、又アト一時間も待たなければならぬ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木大將と共に有名になつた『中朝事實』といふ書物があるが、之は山鹿素行先生の著で、中朝とは我が日本を指したものである。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "古來支那以外の東亞の國で、中朝と稱したものはない。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し日本人の立場からいへば、支那が中國と稱する以上、日本も中朝と稱すべきである。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年中朝から晩まで働いても、満足には喰えないのが定められた運命でした。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日連中朝三時から働きはじめて、夜かえったのは九時なり。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶらぶらしていると島の人は、何だ遊びほけていると言うし、仕事をしようにも道具はないし、叔母さんの家にいるのだが、その叔母は起きているとしょっちゅう何かしろと言うし、ひる日中朝から晩まで床の中にもぐっている。",
              "citation": {
                "source": "石ころ路",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おとなしい酒で、酔ってもにこにこしているが、一年中朝からにこにこされているのには家族の者も閉口した。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "また石鏃は何處の國でも打製が多く、就中朝鮮には非常に精巧なものがある。",
              "citation": {
                "source": "石鏃の思出話",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六時中朝夕、ものの道を悟るべく修行し、かつ、悟らしむるべく知らしむべき職責をもつ人々だ。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長になる前にはどこかの県知事も務めたそうであったが、見るからに詰らん好々爺で年がら年中朝顔と菊の栽培でばかり苦労していた。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから蘇木・胡椒の類を購い取って、これを中朝に貢献したという代償物は、いわゆる海肥すなわち宝貝以外にはあったとも思われぬから、それを運んだのもまたこの島の船であったろう。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
