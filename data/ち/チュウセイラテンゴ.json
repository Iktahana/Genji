          "standard": [
            {
              "text_content": "中世ラテン語は、古典ラテン語とは異なる特徴を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "多くの哲学的・神学的著作が、中世ラテン語で書かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "中世ラテン語は、現代ヨーロッパ諸語の発展に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "背筋の凍る鈍雷のような声で話しはじめ、訛りのひどい、主に学術に用いられた中世ラテン語と推察される、私が研究の中でたびたび見た古代の錬金術の書や悪魔を扱った論書に近しいものであったと感じました。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
