        "examples": {
          "standard": [
            {
              "text": "歴史上、周辺地域の文化の中国化が進んだ時期があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "少数民族の中国化政策は、しばしば国際社会から批判される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "食文化の中国化は、その地域に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一時中国化した琉球でも離島では一種の英雄をオオオヤといっており、沖縄の政治制度では判任官が親子、奏任官が親雲上と職名に書くなど、オヤの字の使用されている例が非常に多い。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
