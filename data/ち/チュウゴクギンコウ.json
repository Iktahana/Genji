        "examples": {
          "standard": [
            {
              "text": "中国銀行は、世界中に支店を持つ大手銀行だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は中国銀行で人民元を両替した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "中国の経済発展とともに、中国銀行の規模も拡大している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十元に対して、金票十二円三十銭の相場を持続していた交通銀行と、中国銀行の大洋紙幣が、がた落ちに落ちた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
