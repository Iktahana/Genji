        "examples": {
          "standard": [
            {
              "text": "新しい政権は、権力の中央集権化を推し進めようとしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "経済の中央集権化は、地方経済の衰退を招く可能性がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、政府の中央集権化の動きに対し、強い懸念を表明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "フランス、プロイセン、オーストリア、ロシア、のような絶対主義政府の国々では公衆衛生行政は中央集権化されて家父長的であったが、一方イギリスのように支配的哲学が自由主義である民主主義国では地方官庁に多くの行動の自由が残されていた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、神権主義が復活されて、中央集権化のために、天皇が利用されたのである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
