        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "二人は夕暮れの海辺で、一生共に歩むことを誓い合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "チーム全員が円陣を組み、必ず優勝旗を持ち帰ることを誓い合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "困難な状況にあっても、互いに裏切らないと固く誓い合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どの場合、何の言葉にもこの二人は長く変わらぬ愛を誓い合うのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも精神的には永久に離れまいと誓い合う愛人どうしである。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊歩廊を歩く男女の組は身体をぴったりとよせ合い、も早や通る他人の顔どころでなく、それぞれの愛情を誓い合うかのような切なげな眼差しで廻っていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
