        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古代中国の音楽理論では、黄鐘、大呂、太簇、夾鐘、仲呂、蕤賓など、十二律があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "琵琶の演奏で、仲呂の音階が美しく響き渡った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "仲呂は、五音階における特定の音程を示す言葉です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "うちゅうりょこうにでも出かけるような気持でした。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "上にも星、下にも星、ほんとうにうちゅうりょこうです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
