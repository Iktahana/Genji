      {
        "index": 1,
        "gloss": "chartist (someone who uses charts to predict market trends)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
