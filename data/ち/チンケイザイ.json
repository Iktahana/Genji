        "examples": {
          "standard": [
            {
              "text": "医師から処方された鎮痙剤を飲むと、お腹の痛みが和らいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乗り物酔いの予防に、鎮痙剤を携帯している人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この鎮痙剤は即効性があり、服用後すぐに効果を感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "臭剥（シュウボツ）という薬（臭化カリウムを土台にしてつくる鎮痙剤）はうちの家庭薬で（母の代から）三年ほど前あの栄さんと山に行った秋の夏、いちどきに仕事しながらつかれると盛にあれをのんだらおでこや何かにそのためのホロホロが出来てね、それを疲労からだと思いちがいしたことがありました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドリデントブロバリントノクターントハ鎮痙剤デハナク睡眠剤デアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
