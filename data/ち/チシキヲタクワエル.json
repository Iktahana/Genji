          "standard": [
            {
              "text": "「将来の起業に備えて、今はがむしゃらに実務の知識を蓄える時期だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「図書館に通い詰めて知識を蓄えるのが、彼の唯一の趣味なんです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、若いうちにたくさん知識を蓄えておかないと、後で苦労するわよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてその会では、俳諧や、絵画の研究の外に、いろいろ変った料理を味って、この方面の知識を蓄えることも忘れなかった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
