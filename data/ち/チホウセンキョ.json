        "examples": {
          "standard": [
            {
              "text": "来月行われる地方選挙に向けて、候補者たちが街頭演説を行っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の地方選挙は、若い世代の投票率が注目されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友達が地方選挙のボランティアをしているんだけど、大変そうだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "地方選挙からひきつづく選挙を通して、日本の婦人の代表は、第一回の婦人代議士と全くちがった勤労人民層から、民主的政党からだされなければなりません。",
              "citation": {
                "source": "今度の選挙と婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し二者其の一を選まざれば、地方選挙区に籠城するか、若くは中央政界の批評家たるに過ぎざるべし。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方選挙戦を眼前にして、青年を把握していることへの嫉視は当然予想さるるところである。",
              "citation": {
                "source": "地方文化運動報告",
                "author": "――尾道市図書館より――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
