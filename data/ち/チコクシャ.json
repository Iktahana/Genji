        "examples": {
          "standard": [
            {
              "text": "会議が始まってしばらくしてから、数名の遅刻者が入ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生は遅刻者に対して、厳しく注意を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遅刻者が多いと、全体のスケジュールが遅れてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "酒は不潔な堕落のような気がして、このとしになるまで盃をふくんだ事がなかったのですが、国内に酒が少し不足になりかけた頃に、あわてて酒の稽古をするとは、実に、おどろくべき遅刻者であります。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、在籍人員から出席人員をマイナスすることが容易じゃなく、報告する前に数秒かかって口の中でくりかえし計算し、電車の事故などで遅刻者が多い時など、どうしても副級長に計算してもらわねばならなかった。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
