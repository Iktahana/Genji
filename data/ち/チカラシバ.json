        "examples": {
          "standard": [
            {
              "text": "夏の公園では、力芝の穂が風に揺れているのが見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭の隅に生えた力芝を、手作業で抜くのは一苦労だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "力芝は丈夫で、乾燥した場所でもよく育つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ちからしばなどといふ雑草が群り繁るのを見ると、これも図案になる。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦以来、あの研究所の施設は取り壊した方がいいだろうという勧告を、日本の人たちからしばしば受けた。",
              "citation": {
