        "examples": {
          "standard": [
            {
              "text": "日本語の「中止法」は、動詞を連用形にして文をつなげる文法である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は中止法を駆使して、流れるような美しい文章を書いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この教科書では、中止法の様々な使い方について詳しく解説されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "知らは知るの第一変化、には否定の助動詞の第二変化で、中止法によく使ふ形。",
              "citation": {
                "source": "古代中世言語論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三句の、「入日さし」と中止法にしたところに、小休止があり、不即不離に第四句に続いているところに歌柄の大きさを感ぜしめる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
