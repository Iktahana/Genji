        "examples": {
          "standard": [
            {
              "text": "あの図書館は、まさに知識の泉と呼ぶにふさわしい場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "知識の泉から溢れる情報を貪欲に吸収する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は知識の泉を求め、世界中を旅した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "たとい一本の草、一塊の石でも細かに観察し研究すれば、数限りもない知識の泉になるというのです。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "思文　　学校の尊厳と魅力とは、それが豊かな知識の泉であるといふこと以外にはない筈です。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            }
          ]
        }
