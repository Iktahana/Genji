        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「引越しのために用意した段ボール箱は、積み重ねやすいように綺麗な直方体の形をしている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「算数の授業で、直方体の体積を求めるために縦・横・高さの三辺の長さを定規で測った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この巨大なモノリスのような直方体のオブジェは、都会のビル群の中で異彩を放っている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「なんか、呆気なさすぎるな」　ワラに借りたブラウンを、アゴの下ですべらせながら、七枚のＣＤがつくりだした小さな直方体を見て、高志がいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の低い大きな直方体のブロックがあり、側面が正確に垂直なため長方形の低い堡塁が真っすぐ立ち並んでいるように見え、アジアの古城が切り立った山肌を這い上がっているレーリッヒの絵のようだ。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車に受信機を積んでね、人の頭がすっぽり入るほどの大きさの、直方体の黒い箱のようなスピーカーをミラーから下げてさ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "引出しの下の、小さなアルコーヴのようになった直方体の空間には、奥の壁に寄せてカレンダーが立てかけてあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
