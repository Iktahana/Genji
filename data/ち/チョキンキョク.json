        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔は郵便局の貯金局が、一般市民の貴重な金融機関だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "郵便貯金は、かつては国営の貯金局で扱われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母は貯金局で通帳を作り、お金を預けていたと懐かしそうに語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は、その二百五十円を何人に依って何処の郵便局で盗まれたかを検べるために、貯金局に願って、出入の明細表を作って貰った。",
              "citation": {
                "source": "易と手相",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはその通帳も貯金局の原簿とともに焼けてしまって、永久引き出す道がなくなるのではないかとまで心配になる。",
              "citation": {
                "source": "震災日誌",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際の使用上においても逓信省貯金局あたりでやっているように極めて敏捷なものである。",
              "citation": {
                "source": "文化史上より見たる日本の数学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりにすこしばかり貯金局のグループが来ていてキャッチボールなんかしていて、閑静なの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
