    "definitions": [
      {
        "index": 1,
        "gloss": "bending (a guitar string)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ギタリストの彼は、絶妙なチョーキングで感情豊かなメロディーを奏でた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このブルースの曲には、深いチョーキングが不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "正確なチョーキングは、ギター演奏の表現力を大きく左右する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「わるいかよ」「わるくはないけど……でも、高志が完全に入りこんで、目をつぶってチョーキングしてる姿なんか、ちょっと想像できない」「クラプトンみたいなイモといっしょにするな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼等にチェッカースや、チョーキング・オン・ゼ・フロワ、その他四、五の遊びを教えた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
