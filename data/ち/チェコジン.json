        "examples": {
          "standard": [
            {
              "text": "私の隣の席に座っているチェコ人は、日本の浮世絵に深い関心を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "有名な作曲家のドヴォルザークは、誇り高きチェコ人として数々の名曲を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "そのチェコ人の友人は、冬になると毎週のようにスキーを楽しんでいるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "四　この若いロシア人のほかに、まだ七、八人の、多少年輩のロシア人やポーランド人やチェコ人やユダヤ人がいた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、アメリカに籍はあるがチェコ人。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり彼も、チェコ人で梵語学者である。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、国をうしなったチェコ人の願いは、どこか地図にない国があれば、そこへ往きたい。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "折竹は、しみじみ神国にいるじぶんの幸福を感じたが、案外、おなじチェコ人でもアメリカ育ちの、ダネックは感じないようにみえた。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
