        "examples": {
          "standard": [
            {
              "text": "祭りの太鼓の音を聞くと、江戸っ子の血が騒ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "難解な事件を前にして、探偵としての血が騒いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勝負の時が近づき、じっとしていられないほど血が騒ぐ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お縫は額さきに洋燈を捧げ、血が騒ぐか細おもての顔を赤うしながら、お太鼓の帯の幅ったげに、後姿で、すっと台所へ入った。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈周平は倫子を豊川におしつけたい気があり、いちどそういう話をしかけたが、豊川は、「おやじの血が騒ぐから」と膠もなくはねつけ、倫子のほうも、てんで問題にしなかったというような噂も聞いた記憶があった。",
              "citation": {
                "source": "川波",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は階段を上りながら血が騒ぐのを感じた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
