        "examples": {
          "standard": [
            {
              "text": "遺言がない場合、財産は直系卑属に相続されるのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、自らの直系卑属のために財産を築いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "直系卑属とは、子、孫、曽孫などの直系の親族で、自分より後の世代にあたる人々を指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "允成の直系卑属は、今の保さんなどに至るまで、一人も煙草を喫まぬのだそうである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうできれば、水上氏の臨終のご意志も疎通するわけだから」「山岸さんの芳夫さんが、言っていましたが、日本では父の遺産は、たとえどんな遺言書があっても、一応、直系卑属のところへ全部行くものなんでしょう？",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、皇族の数は、皇族が、天皇の直系卑属（子、孫、など）の人だけに限られているところから、その数が無限であるはずがない。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
