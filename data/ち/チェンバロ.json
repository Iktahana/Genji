        "examples": {
          "standard": [
            {
              "text": "バロック音楽を聴くと、チェンバロの美しい音色が心を癒してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はチェンバロの演奏家として、世界中で活躍している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この博物館には、18世紀に作られた貴重なチェンバロが展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ここまで書いた時に宅のラジオが鳴り出して、バッハのト短調、チェンバロ・コンチェルトというのを聞かせてくれた。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「チェンバロとヴァイオリンのソナタ」もいくつかレコードされている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても「第五」のヘ短調のソナタは荘厳な美しい曲である（これらはチェンバロの代りにピアノを用いていることは言うまでもない）。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原曲はチェンバロとヴァイオリンのソナタで、ピアノに編曲してマルセル・マースが付き合っている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもピアノではなく本格的にチェンバロを使った愛すべき演奏である。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
