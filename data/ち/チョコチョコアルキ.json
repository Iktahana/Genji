        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "一歳半になる息子が、公園の芝生の上をちょこちょこ歩きで追いかけてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "着慣れない着物を着た彼女は、歩幅を狭めてちょこちょこ歩きで駅へ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭い廊下をペンギンがちょこちょこ歩きする姿に、観光客から歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "清さんはチンチンと手鼻をかんでちょこちょこ歩きをする。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お座敷から帰る者、これから出掛ける者、客を送って行く者、往来で立話している者、アスファルトの舗道の上をちょこちょこ歩きの高い下駄の音に交って「今程は」「左様なら」など呼び交す艶めかしい嬌音が方々から聞えた。",
              "citation": {
                "source": "早稲田神楽坂",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょこちょこ歩きに、地の上を浮いて走っているようですね。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒下駄のちょこちょこあるきに、石段下、その呉羽の神の鳥居の蔭から、桃割ぬれた結立で、緋鹿子の角絞り。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょこちょこあるきは精出すが、4265飛んで空へは上がられぬ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
