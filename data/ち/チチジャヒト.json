        "examples": {
          "standard": [
            {
              "text": "戦国の世では、父者人が子に家督を譲ることが多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "彼は父者人の教えを守り、立派に家を継いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text_content": "若い頃は反発していた父者人の言葉が、今になって身にしみる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "お馨さんの父者人であった。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馨さんの父者人は、十六にして父に死なれ、一代にして巨万の富をなした。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お馨さんの父者人、母者人と三度目の対面をした。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "粕谷の彼は起ってお馨さんと彼等の干繋を簡単に述べ、父者人に対して卑怯なる虚言の罪を謝し、終に臨み、お馨さんの早世はまことに残念だが、自身の妹か娘があるならば、十人は十人矢張お馨さんの様に戦場に送りたいと思うと言った。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしの父者人は、戦で死んだのだ」　それは、父なき少年の、せめてもの誇りでもあった。",
              "citation": {
                "source": "剣の四君子",
                "author": "林崎甚助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
