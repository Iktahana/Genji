        "examples": {
          "standard": [
            {
              "text": "この塗料は引火性が高いため、火気の近くでの使用は絶対に避けてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「物質の引火性を知ることは、安全な取り扱いのためには不可欠です」と化学の先生が説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "製品の安全データシート（SDS）には、詳細な引火性に関する情報が記載されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「引火性の高い溶剤は、換気の良い場所で、少量ずつ慎重に扱う必要があります」と工場長が指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "引火性を帯びた堂々めぐりの憤怒の吐き出し口を心に開けていたことが、むしろはじまりだったのではないか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厨房ストーヴに使う新式のケロシン油は、いきなり火になるむかしの石油のような引火性がなく、じれったいような緩慢な燃えかたをするものだということを、太郎は知らなかった。",
              "citation": {
                "source": "母子像",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
