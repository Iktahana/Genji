          "standard": [
            {
              "text": "彼の鋭い反論に、思わず「一本取られた！」とつぶやいてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンで質問攻めにあい、最後は社長に一本取られた形になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人の予想外のジョークに、皆が一本取られたとばかりに笑い出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "きれいに一本取られたかっこうの、痛い指摘でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹刀ならばお胴一本取られただけですむかも知れない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちが早いか知れねえが、なにぶんお頼み申すよ」「なるほど、お前も腕一本取られたのがあきらめ時だ、江戸へ落着いたら、そんなことで畳の上の往生を専一に心がけてくんねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "女子と小人の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうです」「それにしては、文章はやや平凡だね」「でもアイディアぜんたいは、これは一本取られた、と読むたびに思いますから」「自殺する画家の話は面白かったね。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら一本取られたようだな……」　＊＊＊＊「葡萄酒を一杯やりませんか。",
