      {
        "index": 1,
        "gloss": "alpine gesneriad (Conandron ramondioides)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
