        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母は庭で採れた里芋の芋がらを軒下に吊るして乾燥させていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "乾燥させた芋がらは、水で戻してから煮物にすると独特の食感が楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "味噌汁の具に芋がらを入れると、どこか懐かしい味わいになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "それから小城さんの白雲閣を襲ふ、赤ん坊が生れてゐる、おめでたい、主人がすゝめられるまゝに、二階で飲む、牛肉がうまいやうに芋がらもうまかつた、酒のうまさは握飯のそれに匹敵した。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅町の弦光の借屋の膳の上には、芋がらの汁と、葡萄豆ぽっちり、牛鍋には糸菎蒻ばかりが、火だけは盛だから炎天の蚯蚓のようだ、焦げて残っている、と云った処で、真珠を食ったあとだから、気が驕って、そんなものには、構っておられん。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで山姥は裏の畑へ行って、芋がらを取って、手の先にぐるぐる巻きつけました。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
