        "examples": {
          "standard": [
            {
              "text": "今月は利益が出たが、来月はいい後は悪いかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "昨年の成功の後、いい後は悪いのか今年は苦労している。",
              "source": "幻辞"
            },
            {
              "text": "良い結果が続かないのは、いい後は悪いということだろう。",
              "source": "幻辞"
            },
            {
              "text": "子どもの頃の楽しい思い出も、いい後は悪いで今は辛い。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトの成功後、いい後は悪いで次々と問題が起きた。",
              "source": "幻辞"
            },
            {
              "text": "昨年の大ヒットの後、いい後は悪いで今回は失敗に終わった。",
              "source": "幻辞"
            },
            {
              "text": "恋愛でも、最初の幸せな時間の後、いい後は悪いことがある。",
              "source": "幻辞"
            },
            {
              "text": "試験に合格した後、いい後は悪いで就職活動は失敗した。",
              "source": "幻辞"
            },
            {
              "text": "人生とは、いい後は悪いの繰り返しなのかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "好調な時期も、いい後は悪いで衰退の時期は必ずくる。",
              "source": "幻辞"
            },
            {
              "text": "幸運な出来事も、いい後は悪いで次は不運が訪れる。",
              "source": "幻辞"
            },
            {
              "text": "良いニュースを聞いた後、いい後は悪いで悪いニュースが続く。",
              "source": "幻辞"
            },
            {
              "text": "成功体験を重ねても、いい後は悪いで失敗はまた来る。",
              "source": "幻辞"
            },
            {
              "text": "最高の気分を味わった後、いい後は悪いで落ち込みが深い。",
              "source": "幻辞"
            },
            {
              "text": "順調な人生も、いい後は悪いで思わぬ困難が生じる。",
              "source": "幻辞"
            },
            {
              "text": "業績が良かったら、いい後は悪いで次期は悪くなるだろう。",
              "source": "幻辞"
            },
            {
              "text": "嬉しいことが起きた後、いい後は悪いでしょんぼりすることもある。",
              "source": "幻辞"
            },
            {
              "text": "栄光の時代も、いい後は悪いでいずれは過ぎ去るのだ。",
              "source": "幻辞"
            },
            {
              "text": "幸せな時も、いい後は悪いを忘れずに備えておくべき。",
              "source": "幻辞"
            },
            {
              "text": "人間関係も、いい後は悪いで気をつけなければならない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いい後は悪いというのは本当ですね、阿古長さん。",
