          "standard": [
            {
              "text": "火災が発生した時、消防車はいざって時の訓練を思い出しながら素早く対応した。",
              "source": "幻辞"
            },
            {
              "text": "いざって時に備えて、毎月防災訓練を行っている。",
              "source": "幻辞"
            },
            {
              "text": "子どもが高熱を出した時、母は冷静にいざって時の対応マニュアルを確認した。",
              "source": "幻辞"
            },
            {
              "text": "地震が起きたいざって時に、すぐに机の下に身を隠した。",
              "source": "幻辞"
            },
            {
              "text": "仕事中に緊急電話を受け取ったいざって時、彼は動揺せず指示を仰いだ。",
              "source": "幻辞"
            },
            {
              "text": "手術台の上で、医師はいざって時の判断を迫られた。",
              "source": "幻辞"
            },
            {
              "text": "チームが劣勢だったいざって時に、キャプテンが発奮を促した。",
              "source": "幻辞"
            },
            {
              "text": "経営危機に直面したいざって時には、社長の決断力が問われた。",
              "source": "幻辞"
            },
            {
              "text": "交通事故が起きたいざって時に、目撃者が警察に通報した。",
              "source": "幻辞"
            },
            {
              "text": "システムがダウンしたいざって時に、エンジニアは手動対応を指示した。",
              "source": "幻辞"
            },
            {
              "text": "親が病院から呼び出されたいざって時、息子は一人で幼い妹を守った。",
              "source": "幻辞"
            },
            {
              "text": "プレゼンの途中で質問が飛んだいざって時に、彼の知識が光った。",
              "source": "幻辞"
            },
            {
              "text": "家が停電に見舞われたいざって時に、ろうそくと電池を準備していた。",
              "source": "幻辞"
            },
            {
              "text": "犯人が逃走しようとしたいざって時に、警察官が素早く追跡した。",
              "source": "幻辞"
            },
            {
              "text": "旅行中にパスポートを失くしたいざって時に、大使館に連絡することができた。",
              "source": "幻辞"
            },
            {
              "text": "氷が張った川で溺れたいざって時に、近所の人が救助に当たった。",
              "source": "幻辞"
            },
            {
              "text": "会議で意見が対立したいざって時に、新人が冷静な提案をした。",
              "source": "幻辞"
            },
            {
              "text": "飛行機内で機体トラブルが発生したいざって時に、乗務員が訓練通りに動いた。",
              "source": "幻辞"
            },
            {
              "text": "愛する者が危機に陥ったいざって時に、彼は身を挺して守った。",
              "source": "幻辞"
            },
            {
              "text": "人生の岐路に立たされたいざって時に、親友の助言が頼りになった。",
              "source": "幻辞"
            }
