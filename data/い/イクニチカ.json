          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いく日かして病院から帰宅できるようになった。",
              "source": "幻辞"
            },
            {
              "text": "いく日か経つと状況は大きく変わっていた。",
              "source": "幻辞"
            },
            {
              "text": "いく日かの間、彼は返事をしなかった。",
              "source": "幻辞"
            },
            {
              "text": "いく日か前の新聞にこのニュースが出ていた。",
              "source": "幻辞"
            },
            {
              "text": "いく日か後に再び同じ問題が発生した。",
              "source": "幻辞"
            },
            {
              "text": "いく日か、彼女の消息は分からなかった。",
              "source": "幻辞"
            },
            {
              "text": "いく日かの観光の後、彼は故郷に戻った。",
              "source": "幻辞"
            },
            {
              "text": "いく日か休息すれば体力が戻るだろう。",
              "source": "幻辞"
            },
            {
              "text": "いく日かの雨が降り続いている。",
              "source": "幻辞"
            },
            {
              "text": "いく日かして仲直りの話し合いが実現した。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトが始まってからいく日か経っている。",
              "source": "幻辞"
            },
            {
              "text": "いく日か旅をしてから帰社する予定だ。",
              "source": "幻辞"
            },
            {
              "text": "いく日か経つと古いニュースは忘れられてしまう。",
              "source": "幻辞"
            },
            {
              "text": "いく日かの間、警察は犯人を探していた。",
              "source": "幻辞"
            },
            {
              "text": "いく日か療養してから仕事に復帰したい。",
              "source": "幻辞"
            },
            {
              "text": "いく日かの滞在期間を過ごすことになった。",
              "source": "幻辞"
            },
            {
              "text": "いく日か前に予約した部屋が準備できているか確認した。",
              "source": "幻辞"
            },
            {
              "text": "いく日かしてから報告書を提出する。",
              "source": "幻辞"
            },
            {
              "text": "いく日かの交渉の末、契約が成立した。",
              "source": "幻辞"
            },
            {
              "text": "いく日かして初めて事態の深刻さに気づいた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "乙の少女　　　　　「渡り鳥よ　　　　　いく日かかつて　　　　　ここまで来たの。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて私は同じような試みに悩ましいいく日かを送ったことがある。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いく日かかゝつて、たうとう大きないかだを、つくり上げました。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "エキモスは、いく日かのんきな旅をして、ようやく都につきました。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼は、その日から、設計をやり直し、工事の完全な結果を見届けて、自己の責任を果した末、いく日か後に、ひそかに自殺した――といふ話である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、それからいく日かののち、ひいさまとご婚礼をすませました。",
              "citation": {
                "source": "六羽の白鳥",
                "author": "グリム兄弟　Bruder Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしていく日かたちました。",
              "citation": {
                "source": "千本木川",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、はやいく日か、たったころ、母はひとりごとのように、「ゆうべ、あの子が特攻隊へはいった夢をみたが。",
              "citation": {
                "source": "兄の声",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いく日かの後でした。",
              "citation": {
                "source": "うずめられた鏡",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の遠刈田は不潔で蚤が多く、青根の宿は部屋と部屋との境が紙よりも穴の方が多い障子で――「その頃の」というよりも、「当時の僕が通された部屋は」といった方が穏当かも知れない――一向に有難くなかったが、両方の中間にある早川牧場で暮したいく日かは、温泉こそ無けれ、いまだに楽しい思い出である。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからいく日か、家具ひとつない、がらんどうの空家で、紛争が落着するまで、毎夜、建築構造物の保護にあたる役目は、石田氏にとっても、ありがたいものではなかったろう。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いく日か生きのびるためにはね。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　それから、いく日かが過ぎた。",
              "citation": {
                "source": "悪態の心理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もういく日かしめっぽい日が続いたあとでは、わたしたちも顔にかみつくようにぶつかる北風を、いっそ気持ちよく思っていたが、まもなく空は大きな黒い雲でおおわれて、冬の日はすっかりかくれてしまった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いく日かのあいだかれはその手に絶対の安静をあたえなければならなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがていく日かたつと彼の目の前に青々とした山脈を見ることが出来ました。",
              "citation": {
                "source": "母を尋ねて三千里",
                "author": "アミーチス",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつさ長き昼につかれし　子等はいねたりこの日照り　いく日かつゞく。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり運びこむのにはいく日かかるだろう、ちょうど三日目の日暮れのことであった。",
              "citation": {
                "source": "伝四郎兄妹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十　気も狂ひさうな日がいく日かつづいた。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いく日かのあいだ、ヤッローはこんな悲しい見はり番をさせられました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
