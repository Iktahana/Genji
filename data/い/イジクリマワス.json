        "examples": {
          "standard": [
            {
              "text": "子どもがおもちゃをいじくり回しながら遊んでいた。",
              "source": "幻辞"
            },
            {
              "text": "細かい部品をいじくり回して、ようやく故障の原因を特定できた。",
              "source": "幻辞"
            },
            {
              "text": "機械の内部を無理にいじくり回すと、さらに悪化する可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "彼はいつも何か物をいじくり回す習癖がある。",
              "source": "幻辞"
            },
            {
              "text": "修理職人は、壊れた時計をいじくり回しながら直している。",
              "source": "幻辞"
            },
            {
              "text": "素人が電化製品をいじくり回すと、保証が無効になることがある。",
              "source": "幻辞"
            },
            {
              "text": "思い出の品をいじくり回しながら、懐かしさに浸った。",
              "source": "幻辞"
            },
            {
              "text": "パソコンの設定をいじくり回したため、システムに問題が生じた。",
              "source": "幻辞"
            },
            {
              "text": "退職後、彼は庭の土をいじくり回しながら野菜を育てている。",
              "source": "幻辞"
            },
            {
              "text": "考古学者たちは、出土品をいじくり回しながら歴史の謎を解き明かす。",
              "source": "幻辞"
            },
            {
              "text": "神経質な人ほど、細かいことをいじくり回す傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "芸術家は、素材をいじくり回しながら作品を創作する。",
              "source": "幻辞"
            },
            {
              "text": "エンジニアは、設計をいじくり回して最適なバージョンを求める。",
              "source": "幻辞"
            },
            {
              "text": "患者が注射針をいじくり回そうとするのを医師が制止した。",
              "source": "幻辞"
            },
            {
              "text": "音楽の製作過程では、音声ファイルをいじくり回して調整する。",
              "source": "幻辞"
            },
            {
              "text": "古い手紙をいじくり回していると、あちこちが傷むようになった。",
              "source": "幻辞"
            },
            {
              "text": "彼女は不安な時、髪をいじくり回す癖がある。",
              "source": "幻辞"
            },
            {
              "text": "歯科医は、患者の歯をいじくり回しながら治療を進める。",
              "source": "幻辞"
            },
            {
              "text": "実験中、科学者は試薬をいじくり回して反応を観察する。",
              "source": "幻辞"
            },
            {
              "text": "プログラマーは、ソースコードをいじくり回してバグを修正する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まことに氏は抽象的概念をいじくり回す単なるロジシャンではない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "解釈家は文献が主な相手であって文献をいじくり回すことが学究の主な仕事であるのは、どこの国でも大差ない処だろう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "張子の虎をあてがわれてもそれをいじくりまわすことはなく、ゆらゆら動く虎の頭を退屈そうに眺めているだけであった。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえ、うろたえて、いっそてまえごときがまごまごといじくりまわすよりも、そなたのご助力仰いだが早道と思うて、取るものも取りあえず駆けつけたのじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟というのは、不発爆弾をいじくりまわすまやかしの『科学者めいた』反逆者です……時代おくれの理想主義者です。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            }
          ]
        }
