        "examples": {
          "standard": [
            {
              "text": "夜の公園で、友達とIngressのポータルを奪い合ってるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のスマホには、Ingressのマップが常に表示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "え、Ingressのイベントで、こんなに遠くまで来たの？すごいね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Ingressプレイヤーたちは、現実世界を舞台に、陣取りゲームを楽しんでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
