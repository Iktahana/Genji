        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子どもに『食べたければ野菜も食べるようにして』と親が指導する。つまり、親はいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "会社が『在宅勤務制度を導入します』と決定し、従業員の働き方をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "政府が『税制改正』を実施して、経済をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "医師が『この薬を飲んでください』と処方して、患者の症状をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "コーチが『この練習方法を試してみてください』と提案して、選手の成績をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "親が『大学に進学しなさい』と勧めて、子どもの将来をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "マネージャーが『このプロジェクトを改組しましょう』と提案して、業務をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "都市計画部が『この地区を開発します』と計画して、地域をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "教育者が『こういう学習方法が効果的です』と推奨して、学生の成長をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "友人が『この人とのお付き合いはやめた方がいい』とアドバイスして、あなたの人間関係をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "看護師が『こういう生活習慣が健康的です』と指導して、患者の健康をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "営業管理職が『営業手法を変えましょう』と指示して、売上をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "建築家が『この配置の方が住みやすいです』と提案して、建物をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "トレーナーが『栄養管理を改善してください』とアドバイスして、クライアントの健康体を作ろうとしている。",
              "source": "幻辞"
            },
            {
              "text": "エディターが『この章の順序を変えましょう』と編集して、本の内容をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "園長が『子どもたちの学習環境を充実させます』と宣言して、保育をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "環境活動家が『このプラスチック使用を削減しましょう』と呼びかけて、環境をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "親が『スマートフォンの使用時間を制限しましょう』と提案して、子どもの習慣をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "カウンセラーが『この考え方を変えてみてください』と助言して、クライアントの心理状態をいいようにしようとしている。",
              "source": "幻辞"
            },
            {
              "text": "起業家が『新しいビジネスモデルを採用します』と決定して、事業をいいようにしようとしている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "まあぼくがいいようにするから歌をはじめよう。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が自分で話をきめなくても、お出先と私とでいいようにするから、そのつもりで一生懸命おやんなさい。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は自分でいいようにするからといっているという。",
              "citation": {
                "source": "黒猫",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は俺のいいようにする。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつらはね、あなたをわなにかけて銭をゆすろうて計略なんだ、ぼくが引きうけていいようにするから安心していらっしゃい」「でも私新ちゃんに四十銭と活動のお銭を返さなきゃならないわ」「いいよ、それも僕が引きうけたから」　手塚は文子の家近くまで送ってきた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それではお前のいいようにするさ。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、そこはいいようにするさ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしの冥加はあたしが自分でいいようにするんだから」　彼女は、こう言い放ったものの、内心、あまり穏やかでない。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尾久の喜八｜兄哥がいいようにするだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃあ、私がいいようにするよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいようにするさ。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、もう少し待って下さらない、もう少し、――秋になるまで」「同じことだ」「もう少し待って下されば、すっかりいいようにしてお逢いしますわ」「なにを」と半三郎はただこの顔を見た、「なにをいいようにするんだ、云ってごらんただこ、おれたちの邪魔をしているのはどんな事だ」　ただこは彼の胸へ顔を隠した。",
              "citation": {
                "source": "鵜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいようにするだろう」　こんな風に、通夜の三日｜祀りもすぐすんで、武大の葬儀は、無事に終った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしお姑様などへ、粗相があるといけませんから」「それやあ、どっちでも、其女のいいようにするがよいが」　一歩、家庭を出れば、もう生きて帰るか帰らぬか、心は主君と戦にのみあって、妻には、余りにも素気なくさえ見える良人だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、あれっきり会いもしねえが、相良金吾をばらす方に廻っている秦野屋の九兵衛などにも悪くはねえか」「なるほど、それもそうか」「大体そんな相談をするというのが、少し意気地のねえ話、おれはおれ独りで、きっと万太郎を片づけてみせるからお前たちはどうでもいいようにするがいい。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
