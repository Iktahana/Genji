[
  {
    "uuid": "7f557e51-e6a6-5ae2-875c-4305aee02723",
    "entry": "いちこめ",
    "reading": {
      "primary": "いちこめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "100 metre individual medley (swimming)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いちこめはどんぶりの料理だ。",
              "source": "幻辞"
            },
            {
              "text": "調理法としていちこめは少し複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "いちこめを作るには下準備が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "飲食店ではいちこめが定番メニューだ。",
              "source": "幻辞"
            },
            {
              "text": "いちこめは比較的安価で提供されている。",
              "source": "幻辞"
            },
            {
              "text": "学食ではいちこめが人気メニューの一つだ。",
              "source": "幻辞"
            },
            {
              "text": "いちこめの味付けは店ごとに異なる。",
              "source": "幻辞"
            },
            {
              "text": "いちこめはお弁当でも見かけることがある。",
              "source": "幻辞"
            },
            {
              "text": "家庭でいちこめを再現してみた。",
              "source": "幻辞"
            },
            {
              "text": "いちこめは栄養のバランスが良い食事だ。",
              "source": "幻辞"
            },
            {
              "text": "いちこめの具は季節によって変わることもある。",
              "source": "幻辞"
            },
            {
              "text": "わたしはいちこめが好きで週に何度も食べる。",
              "source": "幻辞"
            },
            {
              "text": "いちこめを注文すれば無料でつゆがもらえる。",
              "source": "幻辞"
            },
            {
              "text": "いちこめの器は丼が使用される。",
              "source": "幻辞"
            },
            {
              "text": "いちこめはどんぶりステーキとは別の料理だ。",
              "source": "幻辞"
            },
            {
              "text": "いちこめの相性は辛めの汁が合う。",
              "source": "幻辞"
            },
            {
              "text": "いちこめと味噌汁の組み合わせが基本だ。",
              "source": "幻辞"
            },
            {
              "text": "いちこめの価格は手頃だと思う。",
              "source": "幻辞"
            },
            {
              "text": "いちこめはダイエット食としても注目されている。",
              "source": "幻辞"
            },
            {
              "text": "いちこめを食べると満足感がある。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
    ],
