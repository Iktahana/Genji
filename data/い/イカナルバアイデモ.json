[
  {
    "uuid": "9fe28a70-eca7-5ec1-8578-9351f90cbfcd",
    "entry": "いかなる場合でも",
    "reading": {
      "primary": "いかなるばあいでも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
