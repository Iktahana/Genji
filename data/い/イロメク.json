        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "月明かりの下、二人の間には静かに色めいた雰囲気が漂った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう、こんな時間に電話なんて。ちょっと色めいてきたじゃない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古びた喫茶店の、薄暗い照明とジャズ音楽が、どこか色めいたムードを作り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
