        "examples": {
          "standard": [
            {
              "text": "「最近、牛乳を飲むとお腹がゴロゴロするんだよね。乳糖イントレランスかもしれない」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宗教的なイントレランスが原因で、歴史上多くの争いが繰り返されてきた事実は否定できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「食物イントレランスの検査を受けたら、今まで気づかなかったアレルゲンが見つかったよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "多様性を認める社会において、他者の価値観に対するイントレランスは克服すべき課題の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私が父につれられ亭劇に、セシル・Ｂ・デミルの「イントレランス」を見た時には、まったく、そのローマのセットの偉大なのには子供心に驚異を感じ、それより増しておどろいたのはその入場料がたしか五円か七円だったと思う。",
              "citation": {
                "source": "私の洋画経歴",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人類の歴史』などというと、昔帝劇で十円の入場料をとって見せた『イントレランス』を連想されるかたがあるかもしれない。",
              "citation": {
                "source": "映画『人類の歴史』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
