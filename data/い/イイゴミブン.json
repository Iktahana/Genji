        "examples": {
          "standard": [
            {
              "text": "そんないいご身分で育った人間には庶民の苦労がわからないだろう。",
              "source": "幻辞"
            },
            {
              "text": "富豪の子息はいいご身分で何不自由なく育てられている。",
              "source": "幻辞"
            },
            {
              "text": "『いいご身分だな』と貧困層の人々から皮肉を込めて言われた。",
              "source": "幻辞"
            },
            {
              "text": "彼はいいご身分の出身のため、お金に対する執着が少ないようだ。",
              "source": "幻辞"
            },
            {
              "text": "その会社の幹部はいいご身分で接待の日々を送っているらしい。",
              "source": "幻辞"
            },
            {
              "text": "親はいいご身分で大切に育てたのに、子どもは親の努力を理解していない。",
              "source": "幻辞"
            },
            {
              "text": "映画の主人公はいいご身分から一転して貧困を経験し、人生観が変わる。",
              "source": "幻辞"
            },
            {
              "text": "いいご身分にあるからこそ、社会への責任が大きいと慈善家は語った。",
              "source": "幻辞"
            },
            {
              "text": "外交官の家族はいいご身分で世界各地を転々とする生活を送ることが多い。",
              "source": "幻辞"
            },
            {
              "text": "いいご身分の人間がこそ、社会改革の先頭に立つべきだと社会活動家は主張した。",
              "source": "幻辞"
            },
            {
              "text": "王族はいいご身分で守られているが、それは大きな責任をも意味する。",
              "source": "幻辞"
            },
            {
              "text": "大企業の重役はいいご身分で優遇措置を受けることが労働組合から批判されている。",
              "source": "幻辞"
            },
            {
              "text": "『いいご身分だこと』と社長は部長の給与水準に関して嘆いた。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には貴族階級はいいご身分で農民とは大きな差がある生活をしていた。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではいいご身分の登場人物が現実の厳しさに直面することが題材にされることが多い。",
              "source": "幻辞"
            },
            {
              "text": "いいご身分の者も年老いれば人生の理不尽さを感じることになると人生経験者は語った。",
              "source": "幻辞"
            },
            {
              "text": "その有名人はいいご身分だからこそ、社会に向き合う責任がより大きいのではないかと評論家は指摘した。",
              "source": "幻辞"
            },
            {
              "text": "いいご身分で育った者が真の成功を手にするためには人一倍の努力が必要である。",
              "source": "幻辞"
            },
            {
              "text": "恵まれたいいご身分から脱出して自立を目指す人生を選択する人も少なくない。",
              "source": "幻辞"
            },
            {
              "text": "社会階級の固定化の中でいいご身分の継承は世代を通じて繰り返される傾向がある。",
              "source": "幻辞"
            }
          ],
