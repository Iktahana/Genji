        "examples": {
          "standard": [
            {
              "text": "古い神社の裏手には、苔むした斎み垣が静かに佇んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祭りの期間中、村人たちは斎み垣の周囲を綺麗に掃き清める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "神域を隔てる斎み垣の向こう側は、空気が一段と張り詰めているように感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "巨細によく調べてみると、まず第一に目についたものは、相当使い古したものらしいにかかわらず、少しの手あかも見えないで、ぴかぴかと手入れのいいみがきがかけられてあったことでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりか、自分の手品の術をせいぜいみがきなさるがよい」　そして旅人は行ってしまいました。",
              "citation": {
                "source": "手品師",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
