        "examples": {
          "standard": [
            {
              "text": "手術室には最新鋭の医療機器が多数導入されており、高度な処置が行える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医療機器の定期的なメンテナンスは、患者の安全を確保するために重要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの企業は革新的な医療機器の開発で世界的に知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "使い捨ての医療機器が増え、感染症予防に貢献している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ＡＴバスと３８６とＭＳ―ＤＯＳはパーソナルコンピューターの規格としてもまだまだ生き残り、さらに事務機器や医療機器、自動販売機や家電などに潜り込んでいつまでたっても死にゃあしないゾンビ化すると考えているオレは、３８６に安くなる圧力や新しいメリットが付く圧力がいかにかかっていくかに大いに興味がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしソナーの開発を数年間続けたのち、大内は日本電気が手を染めたことのない医療機器分野に、かなり強引に進出を図っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
