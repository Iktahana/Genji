        "examples": {
          "standard": [
            {
              "text": "専門的な治療が必要かどうか判断を仰ぐため、まずはかかりつけの一般医に相談してみるつもりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は大病院の心臓外科を辞め、地域の人々の健康を幅広く支える一般医としての道を歩み始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ちょっとした喉の痛みなら、総合病院で何時間も待つより近所の一般医に診てもらった方が早いよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで抽斎も、一般医学を蘭軒に受けた後、特に痘科を京水に学ぶことになった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンターの主な意義は外科的な観察および実験の分野を一般医学に開きすべての医師に注目させたことにあると私は考えている。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビシャ自身は1796年に「医学競進協会」を設立し若い医師たちは一般医学の問題について集まって討論した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビシャの興味を持ったのは何よりも一般医学だったからである。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
