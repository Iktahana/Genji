        "examples": {
          "standard": [
            {
              "text": "後輩をいびるのは職場のトラブルの元になる。",
              "source": "幻辞"
            },
            {
              "text": "先輩がわざと後輩をいびるパターンは昔からあった。",
              "source": "幻辞"
            },
            {
              "text": "彼はいじめのような形で同期をいびっていた。",
              "source": "幻辞"
            },
            {
              "text": "いびるような経営方針は優秀な人材の流出を招く。",
              "source": "幻辞"
            },
            {
              "text": "職場でいびることは労務トラブルの原因になる。",
              "source": "幻辞"
            },
            {
              "text": "集団心理学でいびる現象が群衆の行動パターンとして分析されている。",
              "source": "幻辞"
            },
            {
              "text": "いびるという行動は社会的圧力の表れとして科学的に説明される。",
              "source": "幻辞"
            },
            {
              "text": "小説の人物関係でいびるという行動が複雑な感情を表現する。",
              "source": "幻辞"
            },
            {
              "text": "いびるという行為は文学作品の登場人物の心理描写に欠かせない。",
              "source": "幻辞"
            },
            {
              "text": "いびるような行動は被害者の心身の健康を害する行為として医学的に認識されている。",
              "source": "幻辞"
            },
            {
              "text": "いびられた経験は PTSD のようなメンタルヘルス問題を引き起こすことがある。",
              "source": "幻辞"
            },
            {
              "text": "人間関係の力学の中ではいびるという現象が頻繁に発生する。",
              "source": "幻辞"
            },
            {
              "text": "組織文化がいびる傾向を強化することもあれば、抑止することもある。",
              "source": "幻辞"
            },
            {
              "text": "いびるという行動の背景には多くの場合、加害者自身の心理的問題がある。",
              "source": "幻辞"
            },
            {
              "text": "学級経営の課題としていびるという行動への対応が重視されている。",
              "source": "幻辞"
            },
            {
              "text": "いびるという表現は文学的には人間の悪質な側面を描き出す有効な手段である。",
              "source": "幻辞"
            },
            {
              "text": "社会的地位や力関係がいびるという行動の発生と関連していることが研究で示されている。",
              "source": "幻辞"
            },
            {
              "text": "いびるような環境では組織全体のモラルが低下する傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "教育と啓発を通じていびるという行動を減少させることが可能である。",
              "source": "幻辞"
            },
            {
              "text": "人権啓発活動ではいびるという行動が人間の尊厳を傷つけることが強調される。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「私が寝台の上に乗っけよう、そのかわり、奥様の後で、私がいびるのですよ」　年増はふうふうふうと云うように笑いながら、讓の体を軽がると抱きあげて寝台の上へ持って往った。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私が寝台の上へ乗つけやう、その代り、奥様の後で、私がいびるんですよ、」　年増はふうふうふうと云ふやうに笑ひながら、譲の体を軽軽と抱きあげて寝台の上へ持つて行つた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜更けに、婆さんの癖にどこをほうついてたろう、嫁と喧嘩でもして、出て来たかも判らない、この比は、嫁をいびるよりか、姑をいびる嫁が多いなんて、ひどく婆さんの肩を持って、その方を見ると、黄ろな頬の肉の厚いちょいと因業らしい婆さんですよ。",
              "citation": {
                "source": "雪の夜の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなにいびるくらいなら、余所へくれた方がいいわ。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いびるのは、お前やあらへんか」　百城が「その義観が？",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまりいびるでねえ、こら」　さう云ひすてゝ、彼は檻を小屋の中へしまひ、小屋の戸に鍵をかけ、それから、ふと思ひ出したやうに、そこにゐる若者の一人に、「おい、昨夜の集りでお前たちや何を相談した？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり坊ちゃんをいびるんじゃない？",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、いびる気なんかまるっきりないよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは確と申しあげときますがね、あの男はリーザを、あの年端もゆかないリーザをまで、そりゃ酷くいびるんですよ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりまえなら、一週間くらいで、犬神を追いだすのじゃが、今度は十日にして、はげしゅう、お前をいびるらしい」「勝手にさせとけ」　土中に全身を埋めた犬に、永い間、餌をあたえずに置く。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝やれ、寝てたもよいお子よ宵の節句にゃ、何買うた伽羅の糸巻銀の針泣くな、いびるなよいお子よ宵の節句にゃ、なに縫うた鉢の木帯にまろ小袖……　何処かで誰が唄うのか、哀々とした子守唄の節と、嬰児の泣き声が聞えてくる。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
