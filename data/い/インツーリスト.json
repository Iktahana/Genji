        "examples": {
          "standard": [
            {
              "text": "昔、モスクワを旅行した際、インツーリストのオフィスで現地のツアーを申し込んだ経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ソ連時代の記録映像に、インツーリストのバスが観光客を乗せて走る様子が映っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "両親の古いアルバムに、インツーリストで手配したらしいロシア旅行の写真があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サンクトペテルブルクでの観光は、インツーリストのガイドブックを参考に計画した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "インツーリストへ行ったらプロッカルトのことは出来るという。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "インツーリスト奴、ワゴンリーにのせやがった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
