        "examples": {
          "standard": [
            {
              "text": "「伊藤忠テクノサイエンスが、サン・マイクロシステムズのワークステーションを日本に導入した功績は大きい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「社内報のバックナンバーを整理していたら、伊藤忠テクノサイエンス時代の古い写真が出てきた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「『当時は伊藤忠テクノサイエンスっていう社名だったんだよ』と、ベテラン社員が懐かしそうに語った。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「伊藤忠テクノサイエンスは、高度な技術力を持つシステムインテグレーターとして業界を牽引していました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日本サンは、東芝、富士通を初めとする各社に製品をＯＥＭ供給し、ＣＴＣ（伊藤忠テクノサイエンス）をはじめとする代理店経由の流れを加えた間接の販売ルートに、売り上げの約九十パーセントを負っている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
