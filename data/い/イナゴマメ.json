        "examples": {
          "standard": [
            {
              "text": "田植え後、いなご豆の収穫が始まった。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆の佃煮は、ご飯のおかずとして最適だ。",
              "source": "幻辞"
            },
            {
              "text": "農家の直売所でいなご豆が売られていた。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆を使った加工食品のビジネスを展開している。",
              "source": "幻辞"
            },
            {
              "text": "地方創生の一環としていなご豆の販売を促進している。",
              "source": "幻辞"
            },
            {
              "text": "昆虫学の研究でいなご豆の栄養価が分析されている。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆の成分分析により新しい健康食品が開発された。",
              "source": "幻辞"
            },
            {
              "text": "食育の授業でいなご豆の栄養学を学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "環境学の教科書で持続可能な農業としていなご豆の栽培が取り上げられている。",
              "source": "幻辞"
            },
            {
              "text": "田舎の風景詩にいなご豆が自然描写として現れる。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆の繁茂する畑は郷愁の象徴として描かれる。",
              "source": "幻辞"
            },
            {
              "text": "地方の民俗文学ではいなご豆が文化的象徴として登場する。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆を題材にした民話が伝わっている。",
              "source": "幻辞"
            },
            {
              "text": "栄養学の研究でいなご豆がタンパク質の優良供給源であることが示されている。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆を含む食事は健康寿命の延伸に貢献する可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "秋の風物詩として、いなご豆の旬を迎える季節が来た。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆の産地では毎年収穫祭が開かれている。",
              "source": "幻辞"
            },
            {
              "text": "祖母が作るいなご豆の佃煮の味は忘れられない。",
              "source": "幻辞"
            },
            {
              "text": "いなご豆の薬膳としての効果が注目されている。",
              "source": "幻辞"
            },
            {
              "text": "児童文学の中でいなご豆が故郷の象徴として描写されることが多い。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いなごまめ、なつめしゆろ（海棗）、あさなどは雌雄異株植物だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いなごまめはフランスのごく南の方に出来る。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、気候がよくて、いなごまめが此辺の畑にも生えるものだとしたら、吾々はどのいなごまめを植えたらいゝだらう。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけを植ゑたのでは、雌蕋のあるいなごまめは年々花は開くが少しも実を結ばない。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "雌蕋のあるいなごまめの傍に、雄蕋のあるいなごまめを植えてみる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、残念な事に私はいなごまめを知りません。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なつめしゆろは、いなごまめと同じやうに、やはり雌雄異株植物だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
