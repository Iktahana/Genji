        "examples": {
          "standard": [
            {
              "text": "いいって言うという表現は日本語で重要な意味を持つ。",
              "source": "幻辞"
            },
            {
              "text": "日常会話ではいいって言うがよく使われる。",
              "source": "幻辞"
            },
            {
              "text": "いいって言うの意味を正確に理解することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "学習者にとっていいって言うは習得が難しい場合もある。",
              "source": "幻辞"
            },
            {
              "text": "いいって言うを使った例文は多く存在する。",
              "source": "幻辞"
            },
            {
              "text": "文化の中でいいって言うがどのように機能するかを知ることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "他の言語ではいいって言うに該当する表現がないこともある。",
              "source": "幻辞"
            },
            {
              "text": "いいって言うの用法を正確に把握するには多くの事例を学ぶ必要がある。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス場面ではいいって言うの使い方が微妙に異なることがある。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではいいって言うが効果的に使用されることがある。",
              "source": "幻辞"
            },
            {
              "text": "いいって言うを含む文章を読むことで、その使用法を学ぶことができる。",
              "source": "幻辞"
            },
            {
              "text": "教育現場では{entry_text}の指導が強調されている。",
              "source": "幻辞"
            },
            {
              "text": "時間とともに{entry_text}の意味や用法が変化することもある。",
              "source": "幻辞"
            },
            {
              "text": "異なる地域では{entry_text}の意味が微妙に異なることもある。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}に関連する語彙を習得することも重要である。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}の反対の概念も日本語に存在する。",
              "source": "幻辞"
            },
            {
              "text": "心理学や社会学の観点から{entry_text}を分析することも有興味深い。",
              "source": "幻辞"
            },
            {
              "text": "年代によって{entry_text}の使用頻度が異なることが言語学で示されている。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}は複数の意味を持つため、文脈から判断する必要がある。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}を習得することで日本語の表現力が格段に向上する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あなたと父さんがいいって言うなら、もう言うことなんて何もない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だけど女ばかりで、そんなことをして、後で莫迦を見るようなことでも困るから、よく考えてからにした方がいいって言うんですの。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はほんの一週間も、洗うなら洗ってみてもいいって言うんですの。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のお父さんなんかこっちの方がずっといいって言うもの」「病気はどうなの？",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "須貝　……いいって言うのは、何う言うことです。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは、いいって言うんです。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、川の中へ釣針を沈める手伝いをしたほうがいいって言うだろう」「できることなら、おれに仕事を見つけてくれたいんだよ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "登美　だって……（佐田を頤で示して）……向うで会っちゃって、いいって言うのに、ついていらっしゃるんですもの。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんがお金を貰って、私にこの役を勤めてみるがいいって言うんです」「フーム」「私も、いつまで経っても浮ぶ瀬のない貧乏暮しに、すっかりイヤ気がさしていました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二人浜路",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「五段や六段残したって仕様がないし、先方でも、出来るだけまとまった方がいいって言うからね。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうふざけた貴族野郎が私の娘達を虐めていいって言うんだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――そんなことどうだっていいじゃありませんか」「いやどうだっていいっていう訳にはいかないよ」「僕をモデルにするからですか」「うん」　小田策之助はしきりに鼻糞をほじくっていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「んだら、どうせばいいっていうんだ！",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、おれのはまるで氷だ……盲は勘がいいっていうが、おれなんかはまだそれほど鋭くなっていない。",
              "citation": {
                "source": "暗中の接吻",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、セリファンに出来るだけ急ぐようにと命じながら、心の中では、『だが、葬式に出会ったのは縁起がいいぞ、死人に出会えば幸先がいいっていうからな』などと考えていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんにすれば、啓坊だって可愛いさ、腹を痛めて産んだ子供だものねえ……」「可愛いければ何も……」「連れて行けばいいっていうんだろう。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子を入れるとき、常任幹事は半分本気で、「文化学院あたりの卒業生かなんかなら、手弁当でもいいっていうのが相当いるんだろう。",
              "citation": {
                "source": "築地河岸",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分さえよければいいっていうんじゃあ国家は立って行きませんや。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おけいさんがあの人がいいっていうならあの人の所へ行きます。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それでお前、いいっていうのか。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那さんは、泥がついてたほうがズボンの持ちがいいっていうんだ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたらいいっていうの？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだといったって容子がいいっていうまでのことさ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隣へ行って灸すえてもらって来たよ」と帰って来て話すので、「なぜそんなことをした」と聞くと「みながすえていて、お腹のためにいいっていうから、僕もすえてもらって来た」などという。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二コマとんでいいっていうならこうなるじゃないか」「違うさ、それじゃ斜の線だもの、同じ線の上でなくちゃ」「だって、こうだぜ、君は強情っぱりだなア」　竹村もそんなことをいう気分になった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしには、いろいろなことがわからないけれどね、いい方法って……保さんのいいっていうのはどういうのさ」「絶対に正しい方法」　伸子は、また新しい不安を覚えた。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そう言えばそうだな」「元気がいいっていうばかりじゃなく。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "試験なんかどうでもいいっていう気でいたんだから、眠くなりゃあ、試験の最中でも眠ったのさ。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "（プリムスに向かって）それじゃあ、お前は命を捨ててもいいっていうのか？",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ君は、学校にも、修身はおいた方がいいっていう説』『それやあ、問題がちがうじゃないか。",
              "citation": {
                "source": "押入れ随筆",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
