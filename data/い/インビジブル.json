        "examples": {
          "standard": [
            {
              "text": "「このインビジブルインク、特殊な光を当てないと見えないんだよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、透明人間のようにインビジブルになれたら、どんなに楽しいだろうと思ったものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議では、彼女の意見はほとんど聞かれず、まるでインビジブルな存在のようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "５秒前、４秒前、３、２、１、キュー」　サイバネティック・スキゾイドの『インビジブル・スレッド』がＢＧＭに流れてくる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "５秒前、４秒前、３、２、１、キュー」　ＢＧＭに『インビジブル・スレッド』。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の曲はそんなＥ君の孤独に捧げる『インビジブル・スレッド』」　サックスが空間を引き裂くような狂った音を無秩序に響かせ、それとは対照的にベースが規則正しいリズムを刻んでいく。",
              "citation": {
                "source": "脳細胞日記",
