    "definitions": [
      {
        "index": 1,
        "gloss": "registering a seal (with the local government)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
