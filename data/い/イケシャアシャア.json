        "examples": {
          "standard": [
            {
              "text": "彼はいけしゃあしゃあとして平然とした態度を取った。",
              "source": "幻辞"
            },
            {
              "text": "嘘をついてもいけしゃあしゃあとしている者がいる。",
              "source": "幻辞"
            },
            {
              "text": "悪いことをしたのにいけしゃあしゃあとしているのは許せない。",
              "source": "幻辞"
            },
            {
              "text": "彼女はいけしゃあしゃあとして知らぬふりをした。",
              "source": "幻辞"
            },
            {
              "text": "その男はいけしゃあしゃあと不正な取引をしていた。",
              "source": "幻辞"
            },
            {
              "text": "詐欺師はいけしゃあしゃあとして被害者を騙す。",
              "source": "幻辞"
            },
            {
              "text": "彼はいけしゃあしゃあと他人の失敗を笑う。",
              "source": "幻辞"
            },
            {
              "text": "そのような態度でいけしゃあしゃあとしているのは失礼だ。",
              "source": "幻辞"
            },
            {
              "text": "政治家がいけしゃあしゃあと約束を破るのは問題だ。",
              "source": "幻辞"
            },
            {
              "text": "彼のいけしゃあしゃあとした対応に皆が呆れた。",
              "source": "幻辞"
            },
            {
              "text": "厚顔無恥な態度でいけしゃあしゃあとしている。",
              "source": "幻辞"
            },
            {
              "text": "いくら注意してもいけしゃあしゃあとしている者もいる。",
              "source": "幻辞"
            },
            {
              "text": "彼はいけしゃあしゃあと不当な利益を得ようとした。",
              "source": "幻辞"
            },
            {
              "text": "いけしゃあしゃあとした返答は信用できない。",
              "source": "幻辞"
            },
            {
              "text": "そのような無責任な態度でいけしゃあしゃあとしている。",
              "source": "幻辞"
            },
            {
              "text": "彼女はいけしゃあしゃあと自分の間違いを認めない。",
              "source": "幻辞"
            },
            {
              "text": "いけしゃあしゃあとした子供も大人も存在する。",
              "source": "幻辞"
            },
            {
              "text": "社長がいけしゃあしゃあと不正を隠蔽しようとした。",
              "source": "幻辞"
            },
            {
              "text": "その俳優はいけしゃあしゃあと存在しない経歴を宣伝する。",
              "source": "幻辞"
            },
            {
              "text": "平然とした顔つきでいけしゃあしゃあとしている者は信じてはいけない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "尼になる気持で……などと云うたら口を縫いこむぞといいきかされていた美津子は、いけしゃあしゃあと、わてとあんたは元から許嫁やないのといった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、こいつ等、いけしゃあしゃあとした面をしていたって、どの鼠が白いか黒いか俺がもう睨んでいるんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹見の奴も、いけしゃあしゃあと、案内に立っていやがるんです」「なに、もうノルマン一行が来たか。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで道庵先生が、ちょっと人混みの中へ姿を隠したかと思うと、今坂餅を三｜蒸籠ばかり出店商人に持たせて、いけしゃあしゃあとして再び楽屋口へ乗込んで来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どこさ行ってきようが来まいが」と、セルゲイはいけしゃあしゃあと、「旦那、あっしはもうそこにいやしませんや、ねえボリース・チモフェーイチ」と切って返す。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに、いけしゃあしゃあと黄色い花をつけている様子はあたかも道ばたで摘んできたかのよう。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
