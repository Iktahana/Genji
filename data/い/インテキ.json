        "examples": {
          "standard": [
            {
              "text": "彼女の返答は、直接的な拒否ではなかったが、陰的なニュアンスで断られたことが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この小説の登場人物たちは、多くを語らず、陰的な行動で心理を表現する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議での発言は、表面的には賛成でも、陰的な懸念が感じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その絵画は、明るい色彩の裏に、鑑賞者が気づくかどうかの陰的な悲しみを秘めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の態度は、一見友好的だったが、どこか陰的な抵抗感が漂っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも目指すところは、禅法門では寂定を主としているので、いわば純陰的である。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
