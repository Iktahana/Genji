[
  {
    "uuid": "2696e89c-64bd-54aa-b6a3-2835c02319cd",
    "entry": "いぶし銀",
    "reading": {
      "primary": "いぶしぎん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "oxidized silver",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その俳優の落ち着きはいぶし銀のような味わいがある。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀の魅力は派手さではなく深い味わいにある。",
              "source": "幻辞"
            },
            {
              "text": "長年の経験がいぶし銀のような風格を与えてくれた。",
              "source": "幻辞"
            },
            {
              "text": "その企業のいぶし銀の経営手腕は業界で定評がある。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀の営業スタイルが長期的な信頼関係を築いた。",
              "source": "幻辞"
            },
            {
              "text": "金属学でいぶし銀の表面処理技術が研究されている。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀の化学的特性は工業応用に価値がある。",
              "source": "幻辞"
            },
            {
              "text": "美学の講座でいぶし銀の表現が古典作品の美学を説明する。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀のような文体は俳句や和歌の美意識を体現する。",
              "source": "幻辞"
            },
            {
              "text": "銀の医療応用でいぶし銀のような表面処理が抗菌性を高める。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀コーティングは医療機器に採用されることがある。",
              "source": "幻辞"
            },
            {
              "text": "日本文化の美意識においていぶし銀は渋さを示す最高の表現である。",
              "source": "幻辞"
            },
            {
              "text": "工芸品としてのいぶし銀は職人の技術と審美眼を示す。",
              "source": "幻辞"
            },
            {
              "text": "映画や演劇の表現でいぶし銀のような演技が高く評価される。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀のようなキャリアを歩む人物は物語の中で尊敬の対象となる。",
              "source": "幻辞"
            },
            {
              "text": "建築物のいぶし銀のような外観は時間の流れを物語る。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀という美学概念は日本の茶道や生け花に見られる。",
              "source": "幻辞"
            },
            {
              "text": "ファッション業界でもいぶし銀のような落ち着きが高級感として価値がある。",
              "source": "幻辞"
            },
            {
              "text": "人生経験が深まるにつれていぶし銀のような魅力が備わる。",
              "source": "幻辞"
            },
            {
              "text": "いぶし銀の価値は派手な装飾品とは異なる奥深さにあると考えられている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と、左手の方に人家の燈灯がぼんやり光つてゐた――Ｆ町かな‥‥と思ひながら闇の中を見透すと、街道に沿うて流れてゐる狹い小川の水面がいぶし銀のやうに光つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇った硝子ごしに、前の棟の屋根の上の空気ぬけの塔が、霧から晴れるやうにはっきりとして来て、いぶし銀のやうな空を彼女は見た。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芸の術』という名のもとに、つや布巾をかけ、とくさをかけ、小粒な、まるまっちい、ピカピカ光る――そうでなければいぶし銀的の、たいして要でもない小道具類をつくり、威張りっこをするのが流行している、きょうこの頃の浮世には、わけてもこれはいい事だよ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　ロスアンゼルスヘの外港、サンピイドロの海は、巨艦サラトガ、ミシシッピイ等の船腹を銀色に光らせ、いぶし銀のように燻んでいました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　ロスアンゼルスへの外港、サンピイドロの海は、巨艦サラトガ、ミシシッピイ等の船腹を銀色に光らせ、いぶし銀のように燻んでいました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "すげ笠のかげで、彼の白髪はいぶし銀のように清々しく光っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅い月が出て植え込みの葉が、いぶし銀のように光っている蔭から、男女の話し声が聞こえて来た時には、しかし貝十郎も耳を澄ました。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪がまだらに、淡く残っている処は、いぶし銀の様に、くすんだ、たとえ様もない光を放して居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の上の空を、いぶし銀のように彩って、西に傾いた夕日は赤く見えていました。",
              "citation": {
                "source": "港に着いた黒んぼ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノは古くて、もう音量が足りなくなってはいたが、高いほうの音を、いぶし銀を思わせるほど柔かにする、弱音ペダルを使えば、ずいぶんふしぎな効果をあげることができたのである。",
              "citation": {
                "source": "道化者",
                "author": "DER BAJAZZO",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく露出光のない間接照明で、広いへやがいぶし銀のように輝いていた。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりの樹々は少しずつ様相を変えて、落葉松のいぶし銀のような芽ぶきがちらほら見えはじめてきた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、そこには万花鏡の様な華かな色彩がある訳ではなく、空も森も水も、空はこの世のものならぬいぶし銀、森は黒ずんだ緑と茶、そして水は、それらの単調な色どりを映しているに過ぎないのだ。",
              "citation": {
                "source": "火星の運河",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぶし銀のようにくすんだ色の広間の中に、鈍く光った寄木細工の床の上に、種々様々の変装をこらし、お揃いのマスクをはめた十七人の男と、十七人の女が、ムッツリと黙り込んだまま、今にも何事か奇怪な出来事の起るのを待設けでもするように、ある者は静止し、ある者は蠢いているのです。",
              "citation": {
                "source": "覆面の舞踏者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらんなさい、この景色を」　彼が指さす眼下には、いぶし銀の様にかすんだ、昼間の二倍の広さに見える不忍池が拡がっていた。",
              "citation": {
                "source": "目羅博士の不思議な犯罪",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりは、いぶし銀のように、白く光っていました。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "左がわはダイヤをちりばめた置時計、右がわはダイヤとルビーの王冠、そして、そのまんなかには、高さ二十センチほどの、つぶよりの真珠を、何千と集めてこしらえた三重の宝塔が、月光殿のように、いぶし銀にかがやいていました。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
