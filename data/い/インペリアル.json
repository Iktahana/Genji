        "examples": {
          "standard": [
            {
              "text": "インペリアルホテルで豪華なディナーを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このワインは、インペリアルコレクションの中でも最高級の一本だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女がまとっていたインペリアルブルーのドレスは、高貴な印象を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "その時のついでに彼はインペリアルカレッジの実験室に長子をおとずれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「此間パヽ達とインペリアル・シアタに行つた時それと同じなものを着たナイトを見たけれど、そのナイトは非常に勇敢に戦つた！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルダー・ダムの完成によって、下流のインペリアル・ヴァレイは、一変して沃野となり、その一地方だけで、毎年九千万ドル（三百億円）の農産物収入を挙げるようになった。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五四年型のクラウン・インペリアル……気に入ったら、取っておきなさい。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ年、ファッツ・ドミノは、インペリアルからヒット『でぶ』を出した。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
