    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good thing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いいとこという表現は日本語で重要な意味を持つ。",
              "source": "幻辞"
            },
            {
              "text": "日常会話ではいいとこがよく使われる。",
              "source": "幻辞"
            },
            {
              "text": "いいとこの意味を正確に理解することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "学習者にとっていいとこは習得が難しい場合もある。",
              "source": "幻辞"
            },
            {
              "text": "いいとこを使った例文は多く存在する。",
              "source": "幻辞"
            },
            {
              "text": "文化の中でいいとこがどのように機能するかを知ることは重要である。",
              "source": "幻辞"
            },
            {
              "text": "他の言語ではいいとこに該当する表現がないこともある。",
              "source": "幻辞"
            },
            {
              "text": "いいとこの用法を正確に把握するには多くの事例を学ぶ必要がある。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス場面ではいいとこの使い方が微妙に異なることがある。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではいいとこが効果的に使用されることがある。",
              "source": "幻辞"
            },
            {
              "text": "いいとこを含む文章を読むことで、その使用法を学ぶことができる。",
              "source": "幻辞"
            },
            {
              "text": "教育現場では{entry_text}の指導が強調されている。",
              "source": "幻辞"
            },
            {
              "text": "時間とともに{entry_text}の意味や用法が変化することもある。",
              "source": "幻辞"
            },
            {
              "text": "異なる地域では{entry_text}の意味が微妙に異なることもある。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}に関連する語彙を習得することも重要である。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}の反対の概念も日本語に存在する。",
              "source": "幻辞"
            },
            {
              "text": "心理学や社会学の観点から{entry_text}を分析することも有興味深い。",
              "source": "幻辞"
            },
            {
              "text": "年代によって{entry_text}の使用頻度が異なることが言語学で示されている。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}は複数の意味を持つため、文脈から判断する必要がある。",
              "source": "幻辞"
            },
            {
              "text": "{entry_text}を習得することで日本語の表現力が格段に向上する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あんな、いいところは無い。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がいいところへ案内してやる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言つても私の語調には勢ひが無く、ちつともいいところが無くなりました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さん、はじめは、ぎよつとしたが、しかし、お酒飮みといふものは、お酒を飮んでゐない時には意氣地が無くてからきし駄目でも、醉つてゐる時には、かへつて衆にすぐれて度胸のいいところなど、見せてくれるものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あそこは遊ぶには、いいところだ、それだけは保證します。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんないいところは、他に無いのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、あんないいところで遊ぶ資格は無かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に、何のいいところも無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても、いいところですと、興奮して言ふかも知れない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃はこの頃でいいところがあるよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度いいところだった。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても我慢して見て、強いていいところを捜してやろうという気になれないのである。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "富田渓仙の巻物にはいいところがあるが少し奇を弄したところと色彩の子供らしさとが目についた。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "園内の芝生は割合に気持のいいところである。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちはこんないいとこを旅して、じき神さまのとこへ行きます。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（こんなしずかないいとこで僕はどうしてもっと愉快になれないだろう。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたちここで天上よりももっといいとこをこさえなけぁいけないって僕の先生が云ったよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてやはりいいところと悪いところと両方を具体的に指摘してほしい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしユダヤ人というものの概念のはなはだ希薄な日本人には、おそらくこの映画の本来のねらいどころは感ぜられないであろうし、あるいはかえってそのおかげで日本人にはいやみや臭味を感ずることなしにこの映画のいいところだけを享楽することができるかもしれない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをすればおもしろいであろうが、この芝居では映画のいいところを大略もぎ取ってしまって、それに代わるいいものを入れるのを忘れているように思われた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉山の年齢は、はたち前後とでもいうようなところで、その風采は、背が低くて色が黒く、顔はひらべったく眼が細く、一つとしていいところが無かったけれども、眉だけは、ほっそりした三ヶ月型で美しく、そのためにもまた、眉山という彼女のあだ名は、ぴったりしている感じであった。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つも、いいところないじゃないか、こいつは。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言いながらも、また、心の隅で、それでもどこか一ついいところがあるのだと、自分をたのみにしている頑固なものが、根づよく黒く、わだかまって居るような気がして、いよいよ自分が、わからなくなります。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "景色のいいところですね。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きざではあるが、なにかひとつぐらゐ、いいとこがあるまいか。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいところがあるよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに犬が、それを胡乱な武器と感ちがいして、さかんに吠えたてるかも知れぬのだから、一つとして、いいところが無い。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどいいところであった。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいところが、ありますか。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　べつにいいところでも無いけれど、そこだったら、まえにもしばしば行っているのだから、私がこんな異様な風態をしていても怪しまれる事は無いであろうし、少しはお勘定を足りなくしても、この次、という便利もあるし、それに女給もいない酒だけの店なのだから、身なりの顧慮も要らないだろうと思ったのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
