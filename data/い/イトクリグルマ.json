        "examples": {
          "standard": [
            {
              "text": "古民家カフェの片隅には、アンティークの糸繰り車がインテリアとして飾られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "博物館の体験コーナーで、実際に糸繰り車を回して糸を紡ぐという貴重な経験をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "童話の挿絵に描かれていたような木製の糸繰り車が、おばあさんの家の屋根裏部屋から見つかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "カラカラと音を立てて回る糸繰り車の動きに、子どもたちはすっかり見入っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "糸繰り車の音も水車の音ももはや聞えず。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野の角に背を後ろに日和ぼっこをして、ブンブン糸繰り車をくっている猫背の婆さんもあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
