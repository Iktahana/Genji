        "examples": {
          "standard": [
            {
              "text": "国土交通省が管理するこの一級河川は、大雨のたびに氾濫の危険性が指摘されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "源流から海までいくつもの県を跨いで流れる一級河川の水質調査に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "週末は一級河川の広い河川敷で、バーベキューを楽しむ家族連れで賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "一級河川の堤防沿いに整備されたサイクリングロードを、自転車で一気に駆け抜けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "発車した電車は駅を出ていき、すぐむこうにある一級河川にかかる鉄橋にむけて、走り去った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
