        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人が手伝いを申し出たので、『いいよ、ありがとう』と受けた。",
              "source": "幻辞"
            },
            {
              "text": "子どもが『出かけてもいい？』と聞いたので、母は『いいよ、早めに帰ってきてね』と許可した。",
              "source": "幻辞"
            },
            {
              "text": "同僚が『少し時間をください』と言ったので、上司は『いいよ、急ぎませんから』と返した。",
              "source": "幻辞"
            },
            {
              "text": "友人が『ごめんね、遅刻する』と電話したので、『いいよ、待ってるから』と気遣いなく言った。",
              "source": "幻辞"
            },
            {
              "text": "部下が『新しい方法を試したい』と提案したので、マネージャーは『いいよ、やってみて』と支持した。",
              "source": "幻辞"
            },
            {
              "text": "患者が『もう薬をやめたい』と言ったので、医師は『いいよ、ただし経過を見ましょう』と承認した。",
              "source": "幻辞"
            },
            {
              "text": "子どもが『友人と遊んでいい？』と聞いたので、父は『いいよ、でも宿題を先に済ませてね』と条件をつけた。",
              "source": "幻辞"
            },
            {
              "text": "顧客が『納期を延ばしてもらえませんか？』と相談したので、営業は『いいよ、どのくらい必要ですか？』と柔軟に対応した。",
              "source": "幻辞"
            },
            {
              "text": "学生が『卒論のテーマについてアドバイスをもらいたい』と頼んだので、教授は『いいよ、研究室に来てくれ』と応じた。",
              "source": "幻辞"
            },
            {
              "text": "友人が『泊めてもらえませんか？』と頼んだので、『いいよ、いつでも来てね』と温かく招待した。",
              "source": "幻辞"
            },
            {
              "text": "部員が『このプロジェクトから外してほしい』と申し出たので、リーダーは『いいよ、別の役を探そう』と受け入れた。",
              "source": "幻辞"
            },
            {
              "text": "患者が『セカンドオピニオンを聞きたい』と言ったので、医師は『いいよ、それは患者の権利です』と支持した。",
              "source": "幻辞"
            },
            {
              "text": "同僚が『資料を見てもいい？』と聞いたので、『いいよ、どうぞ』とファイルを渡した。",
              "source": "幻辞"
            },
            {
              "text": "子どもが『このゲームを買ってもいい？』と聞いたので、親は『いいよ、ただしお小遣いの範囲内でね』と返した。",
              "source": "幻辞"
            },
            {
              "text": "ボランティアが『手伝わせてもらいたい』と申し出たので、スタッフ代表は『いいよ、こちらこそ助かります』と感謝した。",
              "source": "幻辞"
            },
            {
              "text": "学生が『授業を録音してもいい？』と聞いたので、講師は『いいよ、ただし個人的な利用に限ってね』と許可した。",
              "source": "幻辞"
            },
            {
              "text": "スタッフが『定時で上がってもいい？』と聞いたので、上司は『いいよ、今日は特に急ぎがないから』と許可した。",
              "source": "幻辞"
            },
            {
              "text": "会社の同期が『一緒にランチに行こう』と誘ったので、『いいよ、楽しみだな』と快く応じた。",
              "source": "幻辞"
            },
            {
              "text": "友人が『悩みを聞いてもらいたい』と相談したので、『いいよ、いつでも相談してね』と支持した。",
              "source": "幻辞"
            },
            {
              "text": "後輩が『先輩の意見を参考にしたい』と言ったので、『いいよ、何でも聞いてくれ』と親身になって応じた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかしこんな事はどうでもいいような気がする。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむしろ意味のわからないほうがいいような気がしていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、燕麦の用意はいいよ。",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、時宜にも合はないおまへの陽気な顔を眺め、　　かなしく煙草を吹かすのだ、一服、一服、吹かすのだ……妹よ夜、うつくしい魂は涕いて、　　――かの女こそ正当なのに――夜、うつくしい魂は涕いて、　　もう死んだつていいよう……といふのであつた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿つた野原の黒い土、短い草の上を　　夜風は吹いて、　死んだつていいよう、死んだつていいよう、と、　　うつくしい魂は涕くのであつた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆はのっけに打ってかかってもいいようなものの、昭青年の意気込みには、鯉魚と答える一筋の奥に、男が女一人を全面的に庇って立った死物狂いの力が籠っています。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、いいよ、いいよ、マドモアゼル。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って一ぺん起した方がいいよ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「毛布の中へ包めばいいよ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丁度いいよ、七十ある。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、萱で串にしておけばいいよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからこそ恐ろしく頭の悪い博士もあれば、図抜けて頭のいいよく出来るただの学士も捜せばいくらでも居るであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の Edward Strutt が大学卒業後農事に身を入れるようになったので、一八七六年に家産全部の管理を弟に一任し、生涯再び家事には煩わされなくてもいいようになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爺っつあん、何を笑ってるんだい」　「今日は」　「静坊、一杯呉れ、冷でいいよ」　「はい」　お静、酒を出し乍ら、　「七五郎さん、兄さんったらね、知らないうちにお嫁さん貰ってるのよ」　「石松が……？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "コオセットをはめてるところ………………靴下はもちろん黒檀色がいいよ、だが門外不出、自分で自分を監禁することはできないって？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、五がつくのなんて半｜端な処がなくて馬※にいいよ。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "為吉とおしかは、もうじいさん、ばあさんと呼ばれていいように年が寄っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士たちは、こういう植民地の労働者を殺戮するために使われ、植民地を帝国主義ブルジョアジーに最も都合がいいように確保するために使われ、（そのために負傷する者もある。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら白痴でも、鳥のまねをする人がありますかね、」と言って少し考えて「けれどもね、お前は死んだほうがいいよ。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヴァンガルドというのは未見であるが、ともかくもわれわれはフランス映画の将来にある期待をかけてもいいように思われる。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず「無駄を伴わない滓を出さない有益なものは一つもない」という言明は、どうも少なくも一つの作業仮説として試みに使ってみてもいいように思われる。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えてみると、道楽息子でもやはり学校へやった方がいいように思われ、分からないむずかしい本でも読んだ方がいいようであり、ろくでもない研究でも、しないよりはした方がいいようにも思われ、またこんな下らない随筆でも書かないよりは書いた方がいいようにも思われてくるのである。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日の朝は風邪もよくなったようだし胃もいいような気がした。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ釣って来たのは雄の鯉で、その雌が取り返しに来たんじゃあるめえかな」「返してやったからいいようなものだが、なんだか気味が悪いね」「どうも変だな」　と、藤吉は今更のように表をみかえった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをしなくってもいいよ。",
              "citation": {
                "source": "ペンネンノルデはいまはいないよ　太陽にできた黒い棘をとりに行ったよ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
