        "examples": {
          "standard": [
            {
              "text": "「さて、何から始めようか」「いっとうさいしょに、問題点を整理しよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "いっとうさいしょに言っておくが、私はその計画には反対だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "会議のいっとうさいしょに、前回の議事録の確認が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼が部屋に入ってきたいっとうさいしょの言葉は、「腹が減った」だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "佛文科へ入ることは一等最初から極めてゐた。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "横佩家の侍女たちは、何時も夜の起きぬけに、一等最初に目撃した物事で、日のよしあしを占うて居るやうだつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが男のモデルの一等最初の人である。",
              "citation": {
                "source": "美術学校時代",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            }
          ]
