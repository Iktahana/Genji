        "examples": {
          "standard": [
            {
              "text": "本日の特別講演者は、DNA解析の第一人者である著名な遺伝学者です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "テレビの取材クルーは、近親交配による遺伝的疾患の研究を進める遺伝学者に話を聞きました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「将来は、困っている人々のために遺伝学の知識を活かせる遺伝学者になりたい」と学生は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "生物学者や遺伝学者は生命を切り砕いて細胞の中へ追い込んだ。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺伝の事実については専門の遺伝学者に教えられない限りは危険でさえある。",
              "citation": {
                "source": "科学と科学の観念",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "★それから間もなく、イギリスの遺伝学者ゴールトン Sir Francis Galton （ダーウィンの従弟）が指紋の万人不同と生涯不変の事実を学問的に論証し、その分類法を発表した。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
