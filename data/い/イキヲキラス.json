    "definitions": [
      {
        "index": 1,
        "gloss": "to be out of breath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長距離ジョギングを終えたランナーは、息を切らしてゴールした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急な坂道を一気に駆け上がったので、彼は息を切らし、立ち止まってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "発作を起こした喘息の患者は、苦しそうに息を切らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "終電に乗り遅れまいと必死に走った結果、駅に着いた時には息を切らし、しばらく動けなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー、きつい登りだったな！もう息を切らしちゃったよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試合終了のホイッスルが鳴ると、選手たちは激しい運動で息を切らし、ピッチに倒れ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それに不思議なことには、咳をするたびにぜいぜい苦しそうに息を切らすことだった。",
              "citation": {
                "source": "童子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の人たちが歌をうたう時に、お前は息を切らすようになるんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い顔で息を切らすも、一瞬たりとも爵位と威厳を失うことは無かった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
