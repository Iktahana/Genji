        "examples": {
          "standard": [
            {
              "text": "個人の遺伝情報は究極のプライバシーに関わるため、取り扱いには厳格なガイドラインが設けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "生物の設計図とも言える遺伝情報は、細胞核内のDNAの塩基配列として暗号化されて保存されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "採取した血液サンプルから遺伝情報を解析し、どのような生活習慣病にかかりやすいかのレポートを作成するサービスが増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "遺伝情報の不当な利用による就職や保険加入での差別を防ぐための法整備が急務だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "連中はまず、遺伝情報を伝えるメディアとして二重らせん構造のＤＮＡのモデルを作り、そこから情報がどう読み込まれて生物が作られるかの仮説を打ち立てた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の遺伝情報複合体の指令に従って、我が肉体が形成されているという知識は、当時のオレにはなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔の形から体の大きさ、指紋、そしてＤＮＡの遺伝情報までわれわれ一人一人みんな違っているのに、何故“知的志向性”だけは平等に分配されているのか。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
