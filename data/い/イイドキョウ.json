          "literary": [
            {
              "text": "何分、いい度胸だよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、いい度胸だね。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、着物の血を洗って、あすこへほして、きょうも相変らず小屋へ出て行きました」「いい度胸だな。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "現内閣は、政権をとったら、何より先に公約は果せないことを確認して、いい度胸を見せた。",
              "citation": {
                "source": "平和をわれらに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こりゃ面白え、いい度胸だ。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "序にこの船の秘密を看破ってやれという気になってここまで降りて来たのは、いい度胸だったかも知れないが、そいつがドウモ感心しなかったね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にサッパリしたいい度胸だったが、聞いてる吾々は笑おうにも笑えない気持がしたよ。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将なんざ、いい度胸だってんで感服してるんです」　一〇、コルシカ人の急所は大鍋の中に。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "タラノ音頭　――コルシカ島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい度胸だと褒めてもやろうよ。",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい度胸だな」「へえ、よい度胸でごぜえます」田舎者は臆面がない。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いい度胸ですねえ」「何んだと」「あっしゃア、どういうものか、ご浪人が好きで、これまで随分世話を見てあげましたが、ご浪人に因縁つけられたなア今日が初めてで」「つけるだけの因縁が……」「いい度胸だ」「褒められて有難え」「百二十五両お持ちなすって。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカゴのように、いちばん近い海までが八百マイル近くもあるというようなところで、海の魚を飼おうという気を起すだけでも、ちょっといい度胸である。",
              "citation": {
                "source": "異魚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこそは、峰の殿様、品川に足どめを食ってるはずの源三郎で……」「声が高いぞ」　と丹波は、押っかぶせるように、「一同を品川に残して、そっと当方へ単身入りこんだものであろうが、はてさて、いい度胸だ」「あなた様は、前から御存じだったので？",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、いい度胸だ。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい度胸さ、十八なんだよ。",
              "citation": {
                "source": "刺青",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「逃げたくても、もう手遅れだと言いたいのか」「いい度胸。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがは明智の片腕といわれるほどあって、いい度胸だ。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい度胸をしています」「全くえらいよ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに言うことがあるか」「雇用主の俺に対して、いい度胸だ」「雇われているんだったら、そういうことだろう。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはとろりと、寝ていたらしい」「いい度胸だの。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、江戸橋前まで来ると、自身番の灯が見えたので、頭巾や黒衣を道ばたへ脱ぎすて、蔭間茶屋の色子だと出たら目をいって、番太郎の小屋へ泊めてもらったわけなんですよ」「ふーむ……」と、大亀も三平も、そういうお燕の顔を、今更のようにしげしげ見て、「いい度胸だなあ。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
