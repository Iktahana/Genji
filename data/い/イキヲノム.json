[
  {
    "uuid": "9f5ba097-dfbb-501f-860e-87b99cda7af3",
    "entry": "息を呑む",
    "reading": {
      "primary": "いきをのむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
