[
  {
    "uuid": "a80c4963-618f-543e-bc0f-f3c43f042bf1",
    "entry": "いざ知らず",
    "reading": {
      "primary": "いざしらず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
