        "examples": {
          "standard": [
            {
              "text": "あの飯綱使いは、小さな祠で狐の霊を祀っているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飯綱使いが祈祷を始めると、不思議な風が吹き始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔、この村には疫病を鎮める飯綱使いがいたと伝えられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大内義弘亡滅の後は堺は細川の家領になったが、其の怜悧で、機変を能く伺うところの、冷酷｜険峻の、飯綱使い魔法使いと恐れられた細川政元が、其の頼み切った家臣の安富元家を此処の南の荘の奉行にしたが、政元の威権と元家の名誉とを以てしても、何様もいざこざが有って治まらなかったのである。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
