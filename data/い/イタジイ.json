        "examples": {
          "standard": [
            {
              "text": "いた椎は西日本の雑木林に見られる樹木だ。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の樹皮は暗褐色で特徴的である。",
              "source": "幻辞"
            },
            {
              "text": "樹高はいた椎は10メートル程度に達することがある。",
              "source": "幻辞"
            },
            {
              "text": "いた椎はクヌギやコナラと同じブナ科に属する。",
              "source": "幻辞"
            },
            {
              "text": "林業の従事者はいた椎を有用な樹種として認識している。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の落葉は土の栄養分となる。",
              "source": "幻辞"
            },
            {
              "text": "野鳥はいた椎の実を食べることが観察されている。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の材質は建築部材として使用された時代がある。",
              "source": "幻辞"
            },
            {
              "text": "環境保全の視点からいた椎の保護が推進されている。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の群落は生態系の重要な構成要素だ。",
              "source": "幻辞"
            },
            {
              "text": "植物図鑑ではいた椎について詳細な記載がある。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の枝を折ると樹液の香りがする。",
              "source": "幻辞"
            },
            {
              "text": "地域によってはいた椎の実を食べる風習がある。",
              "source": "幻辞"
            },
            {
              "text": "いた椎とアカマツの混合林は自然林の典型例だ。",
              "source": "幻辞"
            },
            {
              "text": "現在でもいた椎の古い樹が数多く存在する地域がある。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の薪は燃料として優良とされていた。",
              "source": "幻辞"
            },
            {
              "text": "虫食い穴から見つかるいた椎の虫は珍しい種類もいる。",
              "source": "幻辞"
            },
            {
              "text": "いた椎の天然更新は多くの地域で確認されている。",
              "source": "幻辞"
            },
            {
              "text": "いた椎とその周辺の生態系は密接に関連している。",
              "source": "幻辞"
            },
            {
              "text": "老齢のいた椎は森の歴史を刻んでいる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "燻製料理は、金博士にとって、恰もジーグフリードの頸に貼りついた椎の葉の跡のようなものであった。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束は伐り払ったままになっていた椎の木の枝を片づけに一日頼んだ夕方に出来上ったのであった。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆の十六日の次の夜なので剣舞の太鼓でも叩いたじいさんらなのかそれともさっきのこのうちの主人なのかどっちともわからなかった。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あっちこっち、見知越の顔を見付けては、ひそひそ話をしていたじいやが、相談するように一郎の顔をのぞき込んだ。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は郊外の小さな家を借りて、まだまだ話相手にもならない行雄と、私のおさない時から世話をしてくれていたじいやの作衛と暮しているのだった。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は飛鳥のようなす早さで、サッと身をかわし、今まで腰をかがめてヨボヨボしていたじいさんが、まるで青年のようなおそろしい元気でやみの中にスックと仁王立ちになったではありませんか。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで山奥の猟師とばかり思っていたじいさんが、にわかに若々しい声になって、東京弁を使いはじめたではありませんか。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "セトモノ屋の店を、二十メートルもはなれると、つえにすがってヨボヨボしていたじいさんの足が、にわかに早くなりました。",
              "citation": {
                "source": "探偵少年",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
