        "examples": {
          "standard": [
            {
              "text": "嘘の情報を流して、敵軍に一杯食わせる作戦が功を奏した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの詐欺師は、巧妙な手口で高齢者に一杯食わせて荒稼ぎしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "サプライズパーティーのために、主役には一杯食わせておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "見事に一杯食わせてやった時のあいつの悔しそうな顔が忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "泰さんは始新蔵から、お島婆さんがお敏へ神を下して、伺いを立てると云う事を聞いた時に、咄嗟に胸に浮んだのは、その時お敏が神憑りの真似をして、あの婆に一杯食わせるのが一番近道だと云う事でした。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ彼は、人をかつぐ名人として通っていたし、仮装舞踏会などで、まんまといっぱいくわせる妙技を謳われていたからである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
