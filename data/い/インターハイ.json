        "examples": {
          "standard": [
            {
              "text": "彼女は高校最後の夏、インターハイの決勝で自己ベストを更新し、見事優勝を飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年のインターハイは、競技日程が厳しく、選手たちは体調管理に細心の注意を払っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターハイ出場を決めたチームは、学校全体から盛大な激励を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「よし、来年のインターハイこそは全国大会に出るぞ！」と彼は心に誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "早い方ではなかったが、当時としてはそれでインターハイの予選ぐらいには出場出来た。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
