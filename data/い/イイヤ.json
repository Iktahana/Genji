        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "『手伝ってくれ』と頼まれたが、彼は『いいや、自分でやってくれ』と返した。",
              "source": "幻辞"
            },
            {
              "text": "飲み会に誘われたが、彼は『いいや、家で休みたい』と言った。",
              "source": "幻辞"
            },
            {
              "text": "新しい提案をされたが、経営陣は『いいや、今のままでいい』と判断した。",
              "source": "幻辞"
            },
            {
              "text": "デザインの変更案を見たが、デザイナーは『いいや、元の方がいい』と譲らなかった。",
              "source": "幻辞"
            },
            {
              "text": "新しい技術を導入しようとしたが、技術者は『いいや、従来方法で十分だ』と述べた。",
              "source": "幻辞"
            },
            {
              "text": "昇進を勧められたが、彼は『いいや、今の職位でいい』と丁寧に辞退した。",
              "source": "幻辞"
            },
            {
              "text": "引っ越しを提案されたが、母は『いいや、この家がいい』とこだわった。",
              "source": "幻辞"
            },
            {
              "text": "転職の誘いをもらったが、彼女は『いいや、今の会社で頑張りたい』と答えた。",
              "source": "幻辞"
            },
            {
              "text": "旅行に招待されたが、友人は『いいや、今は金銭的に苦しいから』と控えめに言った。",
              "source": "幻辞"
            },
            {
              "text": "新しい車の購入を勧められたが、祖父は『いいや、この車でいい』と言い張った。",
              "source": "幻辞"
            },
            {
              "text": "結婚を勧められたが、独身男性は『いいや、今はそういうタイミングじゃない』と答えた。",
              "source": "幻辞"
            },
            {
              "text": "会食に誘われたが、同僚は『いいや、家族との時間を大切にしたいから』と丁寧に辞退した。",
              "source": "幻辞"
            },
            {
              "text": "新しい商品の購入を進められたが、客は『いいや、基本的なモデルで十分です』と言った。",
              "source": "幻辞"
            },
            {
              "text": "子どもが『ケーキを食べたい』と言ったが、親は『いいや、晩御飯を先に食べなさい』と返した。",
              "source": "幻辞"
            },
            {
              "text": "スタッフが『デザイン案を三つ用意しました』と言ったが、上司は『いいや、最初の案で決定しよう』と述べた。",
              "source": "幻辞"
            },
            {
              "text": "友人がプレゼント購入を申し出たが、相手は『いいや、気遣いだけで十分です』と遠慮した。",
              "source": "幻辞"
            },
            {
              "text": "顧客が『オプション機能の追加を考えています』と言ったが、営業は『いいや、まずは基本機能を使いこなしてください』とアドバイスした。",
              "source": "幻辞"
            },
            {
              "text": "助言をもらったが、彼は『いいや、自分の判断で進めたい』と独立心を示した。",
              "source": "幻辞"
            },
            {
              "text": "部下がお詫びの品を用意しようとしたが、上司は『いいや、真摯な態度が重要だ』とそれを遠慮させた。",
              "source": "幻辞"
            },
            {
              "text": "医師が新しい治療法を提案したが、患者は『いいや、今の治療を続けたい』と希望した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『いいや、さうぢやない、さうぢやない！",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と彼が云ふ『ちがつてゐるよ』と僕がいふ『いいや、いいや！",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かといつてどう改良したらいいかといふことになると、結局やつぱりこの儘でいいやといふやうなことになつて来て、此の事ならず一切が、実に屁下手く退屈なのが人生である。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、「たとえ、この男が、伯母さんに失恋した、いわば伯母さんの剰りものにしたところで、いいや、あたしはこの男を得るかも知れない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいや、僕は今度遠い所へ行くからね、その前｜一寸お前に遭いに来たよ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいや、とてもとても、話にも何にもならん。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいや、僕は今度遠い所へ行くからね、その前一寸お前に遭いに来たよ。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいややっぱり靴ははこう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいや、此処じゃない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいや、此処このまんまの標本だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいや葛丸川じゃない。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっから来たろうって云ったら風で飛ばされて参りましたでしょうて云やいいや。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの場合で、クキがクッキーでグキットしたとはいいやすいが、アマノがアマゴとアナゴを間違えたといおうとするとうまく口が廻らないで多少の努力を要する。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、まあいいや、久し振りでこっちへ登って来たから、鬼子母神様へ御参詣をして、茗荷屋で昼飯でも食おうじゃねえか」　二人は田圃路を行きぬけて、鬼子母神前の長い往来へ出ると、ここらの気分を象徴するような大きい欅の木肌が、あかるい春の日に光っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいやあいつは中学校なんど入りやしない。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいや、西風ゴスケでない　そんならホースケ、蜂だか？",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいやたしかに沈まない、きっと浮ぶにきまってる。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいや五斗五升などじゃない。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門が、Ｔ「早速貴殿の奥方様にお目に掛りましょう」　敬四郎が驚いて、　「いいや」Ｔ「身共の家内は身共が調べる」　右門が、　「では」Ｔ「拙者もお立合致します」　と言われては敬四郎も、　「勝手にさッしゃい」という他なし。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎左衛門が、Ｔ「お類が昨夜から帰らぬが……」Ｔ「お前何処かへ連れて行ったな」　伊吉、　「そんな馬鹿な事」　いいやと太郎左衛門、Ｔ「怒りはしないよ」Ｔ「お前の女だ好きな処へ連れて行きなさい」　違うんです、伊吉が云えば、　太郎左衛門は、Ｔ「その代り約束だから」　「えッ」　と伊吉が驚くも道理。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六は右門に、Ｔ「おふみちゃんの想ってる男ッて誰でしょうね」　おふみ、　「まァそんな事言ッちゃ嫌」　伝六尚も、Ｔ「旦那御存じですか」　「いいや」と右門おふみを見る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "便りにしていたものが崩れてゆく何とも云えないいやな気持です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
