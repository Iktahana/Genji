        "examples": {
          "standard": [
            {
              "text": "この有機化合物は、特徴的なイミダゾール環を分子構造に含んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医薬品開発において、イミダゾール誘導体は幅広い生理活性を示すため注目されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "実験室では、特定の反応でイミダゾールを触媒として添加することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "生体内でヒスタミンなど、重要な生理活性物質の多くがイミダゾール骨格を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ヒスチジンは３原子の窒素を含み２個はイミダゾール環にあり１個は側鎖のαにある。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "分子内における同位体の位置を決定するためにヒスチジンは亜硝酸によってイミダゾール乳酸に変化させた。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒスチジンが必要なときにラットはイミダゾール乳酸のヒドロキシ基をアミノ基で置き換えることによって生成させることができる。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
