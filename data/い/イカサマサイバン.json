        "examples": {
          "standard": [
            {
              "text": "その事件の裁判は多くの不正証拠に基づいており、いかさま裁判として後に見直された。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には、権力者が有利になるようにいかさま裁判が行われることもあった。",
              "source": "幻辞"
            },
            {
              "text": "戦時中、反体制派に対していかさま裁判が行われたと言われている。",
              "source": "幻辞"
            },
            {
              "text": "映画のプロットでは、主人公が不公正ないかさま裁判に掛けられる。",
              "source": "幻辞"
            },
            {
              "text": "法学部の学生がいかさま裁判の歴史的事例について研究している。",
              "source": "幻辞"
            },
            {
              "text": "その国の司法制度改革は、過去のいかさま裁判を防ぐためのものだった。",
              "source": "幻辞"
            },
            {
              "text": "小説家が架空のいかさま裁判を描写して、読者に司法への疑問を投げかけた。",
              "source": "幻辞"
            },
            {
              "text": "人権活動家がいかさま裁判の廃絶を目指して活動している。",
              "source": "幻辞"
            },
            {
              "text": "国連のレポートでは、特定の国でいかさま裁判が行われていると指摘した。",
              "source": "幻辞"
            },
            {
              "text": "弁護士がいかさま裁判の被害者を救済するために尽力している。",
              "source": "幻辞"
            },
            {
              "text": "ドキュメンタリーでは、過去のいかさま裁判の実態が明かされた。",
              "source": "幻辞"
            },
            {
              "text": "その無罪判決は、かつてのいかさま裁判を象徴していた。",
              "source": "幻辞"
            },
            {
              "text": "裁判制度の改革は、いかさま裁判の再発を防ぐことを目的としている。",
              "source": "幻辞"
            },
            {
              "text": "法廷では、いかさま裁判を防ぐための新しいルールが導入された。",
              "source": "幻辞"
            },
            {
              "text": "その逆転判決は、数十年前のいかさま裁判を是正するものだった。",
              "source": "幻辞"
            },
            {
              "text": "市民は、透明性を欠くいかさま裁判について政府に抗議している。",
              "source": "幻辞"
            },
            {
              "text": "法律専門家がいかさま裁判の防止について講演会で議論している。",
              "source": "幻辞"
            },
            {
              "text": "その地域の歴史博物館では、いかさま裁判の遺物が展示されている。",
              "source": "幻辞"
            },
            {
              "text": "思想家が、民主主義社会ではいかさま裁判が起こりにくいと論じている。",
              "source": "幻辞"
            },
            {
              "text": "被害者の家族が、いかさま裁判で失われた数十年の補償を求めている。",
              "source": "幻辞"
            }
