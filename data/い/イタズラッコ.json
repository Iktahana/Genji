[
  {
    "uuid": "24b1b3a4-49bf-5d47-bf34-c177905d163f",
    "entry": "いたずらっ子",
    "reading": {
      "primary": "いたずらっこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "mischievous child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その子はいたずらっ子で学校でも有名だ。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子の彼は今やエンジニアになっている。",
              "source": "幻辞"
            },
            {
              "text": "小学生のいたずらっ子たちが校庭で暴れている。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子だった少年時代が懐かしい。",
              "source": "幻辞"
            },
            {
              "text": "うちのいたずらっ子は毎日何かやらかしている。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子の笑顔には何も言う気が起きない。",
              "source": "幻辞"
            },
            {
              "text": "映画のいたずらっ子のキャラが可愛いと娘が言う。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子の兄が妹をからかっている。",
              "source": "幻辞"
            },
            {
              "text": "あのいたずらっ子も高校生になったと聞いた。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子たちの秘密基地を見つけた。",
              "source": "幻辞"
            },
            {
              "text": "近所のいたずらっ子に庭を踏み荒らされた。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子の味方をするのは親くらいだろう。",
              "source": "幻辞"
            },
            {
              "text": "その子はいたずらっ子だがボランティア活動をしている。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子の集団は手に負えない。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子のあだ名をつけられてしまった。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子でも友情は本物だと思う。",
              "source": "幻辞"
            },
            {
              "text": "親戚のいたずらっ子が家に遊びに来た。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子の悪戯も大人目線では微笑ましい。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子たちのために遊び場を作った。",
              "source": "幻辞"
            },
            {
              "text": "いたずらっ子と呼ばれることにもう慣れた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "なるほど、傍で砂いじりしている子はおいたさんと呼ばれるほどの一くせありげないたずらっ子の男児だ。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてひどい、いたずらっ子でしょう！",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのキューピッドというのは、なんといういたずらっ子だ！",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、このキューピッドというのは、いたずらっ子です。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、キューピッドが、すごいいたずらっ子だということを、忘れないでくださいよ。",
              "citation": {
                "source": "いたずらっ子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、あのいたずらっ子たちも、こなごなにこおってしまうの？",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だけど、あのいたずらっ子たちに、しかえしをしてやっちゃいけないの？",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、さいしょに歌をうたいはじめた、あのいじわるの、いたずらっ子には？",
              "citation": {
                "source": "コウノトリ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の息のまれに見るいたずらっ子が、悪たれたり、あばれたりすればする程、氏は愛情の三昧に這入ります。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらっ子だけれども、性質は素直なの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いたずらっ子の美和子は、知ってか知らずにか、前川を更に心配させるような返事をした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきなり二人は頭を引っこめた、そしていたずらっ子僧の様に忍び笑いをしながら、「見つけたねえ、きっと。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ことに）いたずらっ子。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうす笑いをしたかおを手の上ににぎって見たり、向うの方にほうりつけて見たり、髪の毛の間にたくし込んでしまったり、ややしばらく、いたずらっ子が猫をおもちゃにする様に自分もうす笑いをしながらたのしんで居た。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ローリイは、いたずらっ子らしく、「あなたは知っていますよ。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、顔を出すと水をかけたり、いたずらっ子は、そばを通ると、小石を拾って投げたりしました。",
              "citation": {
                "source": "ねこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "母ねこは、いたずらっ子のない静かな家をと思って、ある日、子ねこをつれて、一｜軒のお家へきました。",
              "citation": {
                "source": "ねこ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "いたずらっ子にでも殺されたか、悪いくもの巣にでもかかって、かえれないのかもしれません。",
              "citation": {
                "source": "はちの巣",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "また――いたずらっ子に殺される――というしんぱいも、ないではなかったのです。",
              "citation": {
                "source": "はちの巣",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いたずらっ子に殺されたのか、わるいくもの巣にかかったんだろうって、お母さんがおっしゃってよ。",
              "citation": {
                "source": "はちの巣",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、その湯沸かしは、黒くすすけて、まるでいたずらっ子の顔を見るように、墨を塗ったかと思われたほどだからです。",
              "citation": {
                "source": "人間と湯沸かし",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体此のセーカンが然しありようは大のいたずらっ子で、表てなどで「ナンブセーカン」と聞くと私達こどもは逃げたものである。",
              "citation": {
                "source": "少年の食物",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名をどうして記憶しているかというと、私の北条にいたころ、家主の家の子が幸吉といういたずらっ子で、そいつが私の家へ来ていたずらをする。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉田筑後の家に使われている、ことし十三の虎吉という無類のいたずらっ子です。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も何か用事で廊下へ出て来た拍子に、小さい伸子が来かかるのを見て、ひょいと掬い上げたというのならば、そうするポリニャークに陽気ないたずらっ子の笑いがあったはずだし、伸子も、びっくりした次には笑い出す気分がうつったはずだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いたずらっ子らしく笑った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいたずらっ子を除いてすべての悪徳を持っていた……」　フランシス・ベイコンもまた彼について多くの厳しいことを言っている(5)。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "はははは」　少年は両手をポケットへつっ込んで室の中をあちこち歩きながら、鎖につながれた猛獣にからかっているいたずらっ子のように気楽に力んでいる。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のマーガレット・ブレーアムという青白い可愛い、いたずらっ子らしい顔と銅色の髪の毛を持った少女もいた。",
              "citation": {
                "source": "秘密の庭",
                "author": "THE SECRET GARDEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "用心をしたまえ――途中でいたずらっ子につかまってその美しい脚をもがれないように。",
              "citation": {
                "source": "蝗の大旅行",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
