        "examples": {
          "standard": [
            {
              "text": "いっとうこうかいしは、船長の補佐役として、航海の安全に責任を持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "嵐の中、いっとうこうかいしは冷静にクルーへ指示を出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "彼は大型貨物船のいっとうこうかいしになるのが夢だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "船が港に着くと、いっとうこうかいしは荷役の監督も行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "残ったのはただひとり、一等航海士だけだったが、その男は勇敢な、力の強い男だった。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            }
          ]
