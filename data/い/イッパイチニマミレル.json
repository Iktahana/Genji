        "examples": {
          "standard": [
            {
              "text": "王者の慢心が仇となり、挑戦者の前に一敗地に塗れる結果となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "今期の総選挙では、長年与党だった政党が一敗地に塗れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "あの強豪校が初戦で一敗地に塗れるとは、誰が予想しただろうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "新規事業の立ち上げに失敗し、彼は完全に一敗地に塗れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここで期せずして敵の兵力が一敗地に塗れるのが、もうわたくしには見えるようです。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            }
          ]
        }
