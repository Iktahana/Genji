        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "いじめられっ子は、学校生活で大きなストレスを抱えている。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の多くは、自分に原因があると思い込むことがある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子を支援するために、親との連携が不可欠である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が相談しやすい環境を作ることが、学校の責務である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の心理状態を理解することが、対策の第一歩である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が被害を小さく見せようとする心理を認識することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の周囲に、味方がいることが救いになることもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が転校を余儀なくされるケースもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の成長過程では、トラウマを克服することが課題になる。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の家庭内での様子に異変がないか、親は注意深く観察すべきだ。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が大人になった時、その経験が人生にどのような影響を与えるかは様々である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が自殺を考えるほど追い詰められたケースもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子を守ることは、人間として当然の責務である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の親が学校に相談しても、対応が不十分なことがある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が本当の友人を見つけることで、状況が改善することもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子だった経験が、その人の人格形成に影響を与えることがある。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子を守るために、クラス全体での意識改革が必要である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が不登校に陥るのを防ぐために、早期介入が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子の悩みに耳を傾けることが、解決への第一歩である。",
              "source": "幻辞"
            },
            {
              "text": "いじめられっ子が学校で安心感を感じられるようになることが、教育の目標である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いじめっ子と、いじめられっ子とである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私なんぞは典型的な、いじめられっ子で、学校への行き帰りは、毎日、泣かされてばかりいた。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
