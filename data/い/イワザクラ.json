          "standard": [
            {
              "text": "登山客は、岩場に可憐な岩桜（いわざくら）が咲いているのを見つけて歓声をあげた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "植物園のロックガーデンには、珍しい品種の岩桜が植えられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この岩桜、すごくきれい！」と、写真家は興奮気味に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "唯岩崖に咲く日蔭躑躅の上品な黄花がほのかに明るい色を浮べ、小岩桜の紅花が時に眼を楽しませる外に、盛り上るように花をつけた石楠や躑躅の大群落が思わず足をとめて眼を見張らせるであろう。",
              "citation": {
                "source": "秩父の渓谷美",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
