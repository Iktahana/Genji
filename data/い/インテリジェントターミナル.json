          "standard": [
            {
              "text": "ネットワーク管理者は、リモートからでも機器を制御できるインテリジェントターミナルを導入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "顧客は、店舗に設置されたインテリジェントターミナルで商品情報を検索したり、注文したりできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「へえ、これ一つで色々できるんだ！インテリジェントターミナルってすごいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "一方Ｎ６３００には、「インテリジェントターミナル」と銘打ったこの装置のためにあらたに日本電気の半導体セクションが開発した、八ビットのＤＴ―１が組み込まれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
