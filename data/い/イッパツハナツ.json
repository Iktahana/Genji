        "examples": {
          "standard": [
            {
              "text": "静かな会議中に、お腹が鳴るかと思ったら、うっかり一発放ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お腹の調子が非常に悪く、人前で一発放ってしまわないかヒヤヒヤした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "満員電車の中で、隣の人が明らかに一発放ったので、思わず顔をしかめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何をするか知らぬと思う間もなく、三日半も干乾にして庭樹の枝に縛り付けてあった囚人目がけてズドンと一発放つや否や、キャッという叫び声。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "キクッタはこゝぞと、その心臓をめがけてドンと一発放つと、みごとに命中しました。",
              "citation": {
                "source": "熊捕り競争",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
