          "standard": [
            {
              "text": "その作家は、インセストという重いテーマを扱った小説で有名になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "近親相姦（インセスト）は、多くの文化でタブーとされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、そんなことが…」と、彼はインセストの噂を聞いて信じられない様子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "素朴単純なる推理法において、人類の起原をインセストに托するは自然であった上に、彼らの間にはまたノアの箱船と同じように、世界が大水になって神の思召しに叶うた者のみが、生き残ったという信仰さえあったのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
