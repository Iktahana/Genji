[
  {
    "uuid": "fd083233-06ef-585e-8bca-72b0b3305061",
    "entry": "いがみ合う",
    "reading": {
      "primary": "いがみあう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to snarl (at each other)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近所の二匹の犬が毎日のようにいがみ合っている。",
              "source": "幻辞"
            },
            {
              "text": "兄弟は些細なことでいがみ合うようになった。",
              "source": "幻辞"
            },
            {
              "text": "政治的な意見の相違でいがみ合う人々を見ていた。",
              "source": "幻辞"
            },
            {
              "text": "競争相手たちはどうしてもいがみ合わざるを得ない立場だ。",
              "source": "幻辞"
            },
            {
              "text": "仲が悪くなると、みんなの前でいがみ合うようになってしまう。",
              "source": "幻辞"
            },
            {
              "text": "野球の試合では二つのチームがいがみ合う様子が見られる。",
              "source": "幻辞"
            },
            {
              "text": "彼らは利権をめぐっていがみ合う関係になってしまった。",
              "source": "幻辞"
            },
            {
              "text": "企業間の競争でいがみ合う状況は珍しくない。",
              "source": "幻辞"
            },
            {
              "text": "猫たちが縄張りをめぐっていがみ合う光景は毎年のことだ。",
              "source": "幻辞"
            },
            {
              "text": "動物園の派閥がいがみ合う状態が続いている。",
              "source": "幻辞"
            },
            {
              "text": "訴訟で相手方といがみ合うのは避けられない。",
              "source": "幻辞"
            },
            {
              "text": "親族がお金の問題でいがみ合うのは悲しい。",
              "source": "幻辞"
            },
            {
              "text": "舞台上の二人の俳優がいがみ合う迫力は圧巻だ。",
              "source": "幻辞"
            },
            {
              "text": "国境をめぐっていがみ合う隣国との関係は改善しない。",
              "source": "幻辞"
            },
            {
              "text": "事業をめぐっていがみ合う兄弟の話を聞いた。",
              "source": "幻辞"
            },
            {
              "text": "地域の有力者たちがいがみ合う政治構図が長年続いている。",
              "source": "幻辞"
            },
            {
              "text": "野党と与党はいつもいがみ合っているようだ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な対立によっていがみ合う二つの民族がある。",
              "source": "幻辞"
            },
            {
              "text": "権力をめぐっていがみ合う派閥の存在は組織を弱める。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの試合でチーム同士がいがみ合う姿は興奮を生む。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「鼠を捕る知恵もまだ出ないんです」　明るい白昼の日が隣りの屋根の古い瓦を照らして、どこやらで猫のいがみ合う声がやかましく聞えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやはたちまちその殻に抑え切れ無い程な好奇心と愛着を生じてしまって、まだほかに幾つも幾つも欲しかった、それを見付けるために、雑朶の間をあちらこちら歩いて居ると、後の方の婆やと吉蔵との間に、いがみ合う様な笑い声が突然起った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいかわらず、対手さえありゃいがみ合うんだよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯しろ裸の叔母がそこにやって来て、またくだらぬ口論をするのだと思うと、泥の中でいがみ合う豚かなんぞを思い出して、葉子は踵の塵を払わんばかりにそこそこ家を出た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はいがみ合う犬のように組み合って倒れた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ喧嘩ということになると、武家の子は武家方、町家の子は町家方、たがいに党を組んでいがみ合うようになります。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鬱憤から始まった口争いでお柳とせきがいがみ合うのが、台所で、もちについた魚のしがくをしていたいしの癇癪に悉く触った。",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、食事の時いがみ合うことは殆んどなかった。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、今、わしが隠居すると、わしの育てた理財家と、斉彬の愛しておる急進派とが、きっと又、いがみ合うにきまっておる。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてもちっぽけな日本国内で、いがみ合うことなどは大嫌いだよ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の猟師が、一頭の大熊を獲ってきたのを高利貸、地主、滞納処分の役場吏員が取り囲んで、吹雪の吹き込む土間で、その処分についていがみ合う。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――天動説、地動説と、なにもかんかんになっていがみ合うことはない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "……内ん中のゴタゴタ、財産を兄さんにつがせたらいいの、私に婿を取って相続させたがいいの、ゴタゴタゴタゴタ……お父さんとお母さんが眼くじら立てていがみ合うし、親戚連は親戚連で二派に分れて策略の弄しくら……私、いやでいやでたまらなくなった。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってても、いがみ合うのを、よしゃしねえんだ。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに、問題外の極く些細な事柄が、いつも議論の対象となり、殆ど狂的にまでいがみ合うのであった。",
              "citation": {
                "source": "灰神楽",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬と猿とは仲がわるいといいますけれど、相手がこんな小さな豆猿では、いがみ合うはりあいもなかったのでしょう。",
              "citation": {
                "source": "新宝島",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあんな奴等といがみあうのは堕落を意味する。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
