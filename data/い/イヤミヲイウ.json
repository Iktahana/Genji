        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも私にだけ、わざと聞こえるように嫌味を言う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "人の揚げ足を取って嫌味を言うのが彼の悪い癖だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "陰でこそこそ嫌味を言うくらいなら、直接本人に伝えればいいのに。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "新人がミスをするたびに、隣の席の先輩がぼそっと嫌味を言うのが聞こえてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "ポマード男、倉光さんに酒を飲ませすぎはしないかと、じわじわ嫌味を言うのです。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よう、八五郎｜兄哥、お指図を頼むぜ」　誰やらが早くも見付けて嫌味を言うと、「あ、いいとも」　臆れた色もなく、こう言って反身になる八五郎だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "双生児の呪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこともしまいには効かなくなって、へっ、うちの嫁はん景気えいことやんのやな、育ちがえいさかいようけ銭でも持ってきたんやろ、といやみをいう。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
