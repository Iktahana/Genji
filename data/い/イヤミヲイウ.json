    "definitions": [
      {
        "index": 1,
        "gloss": "to make snide remarks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
