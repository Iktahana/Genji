        "examples": {
          "standard": [
            {
              "text": "この家電製品は、現金で一括払いすれば割引が適用されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンの機種代金は、分割払いではなく一括払いを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学の授業料は、前期分を一括払いで納入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自動車保険を年払いで一括払いすると、月々払うよりも保険料が安くなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、期間一年の契約で私の終身年金証書を四〇〇フラン一括払いで質入した、ゴプセックの爺さんの店だ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
