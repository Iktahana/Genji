        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "医者の勧めで転地療養へ向かう老人が「いざさらば」と呟いた。",
              "source": "幻辞"
            },
            {
              "text": "人生の終わりが近づいている、いざさらばと思いながら眠りについた。",
              "source": "幻辞"
            },
            {
              "text": "別離の時、妻に「いざさらば」と伝えた。",
              "source": "幻辞"
            },
            {
              "text": "移転日の朝、家族に向かって「いざさらば」と言った。",
              "source": "幻辞"
            },
            {
              "text": "夜行列車に乗り込む時、駅にいる人々に「いざさらば」と手を振った。",
              "source": "幻辞"
            },
            {
              "text": "人間関係に疲れて、「いざさらば、この場所から逃げ出そう」と思った。",
              "source": "幻辞"
            },
            {
              "text": "親友との別れが決まり、涙ながら「いざさらば」と言葉にした。",
              "source": "幻辞"
            },
            {
              "text": "長い人生に別れを告げるように、老人は「いざさらば」と最後の手紙に書いた。",
              "source": "幻辞"
            },
            {
              "text": "故郷への帰路、「いざさらば、都会の生活」と思い返した。",
              "source": "幻辞"
            },
            {
              "text": "退職式で「いざさらば」と同僚に挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "転職が決まり、「いざさらば、この会社」と心で呟いた。",
              "source": "幻辞"
            },
            {
              "text": "留学生が空港で両親に「いざさらば」と言い別れた。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちの独立を見送りながら、親は「いざさらば」と感慨深くつぶやいた。",
              "source": "幻辞"
            },
            {
              "text": "海外赴任の辞令を受け、「いざさらば」と覚悟を決めた。",
              "source": "幻辞"
            },
            {
              "text": "入院が決まった日、家に「いざさらば」と別れを告げた。",
              "source": "幻辞"
            },
            {
              "text": "離縁した妻に向かって、静かに「いざさらば」と言った。",
              "source": "幻辞"
            },
            {
              "text": "師匠のもとを離れる弟子が「いざさらば」と一礼した。",
              "source": "幻辞"
            },
            {
              "text": "人生最大の決断の前に、「いざさらば」と心を定めた。",
              "source": "幻辞"
            },
            {
              "text": "時代の流れに逆らえず、「いざさらば、旧世界」と思った。",
              "source": "幻辞"
            },
            {
              "text": "生涯を終える準備をしながら、静かに「いざさらば」と呟いた。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
