        "examples": {
          "standard": [
            {
              "text": "公園で子供たちが「色鬼だよ！」と叫びながら追いかけっこをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「赤！」と言われたら、子供たちは赤いものに触れようと必死だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "暑い夏の日、友達と公園で色鬼をして遊んだのが懐かしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「次は何色にしようか？」と、色鬼のルールを決めるのも楽しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "予は今後断じて神に依らず、予自身の手を以て、予が妹明子をこの色鬼の手より救助す可し。",
              "citation": {
                "source": "開化の殺人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "一条弥平、一色鬼童、これは琢磨流の忍術家であった。",
              "citation": {
                "source": "五右衛門と新左",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
