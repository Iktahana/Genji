        "examples": {
          "standard": [
            {
              "text": "彼はＥＳＰの能力を持っていると主張し、透視や予知を行うという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "信じるか信じないかはあなた次第だが、ＥＳＰに関する実験は昔から行われてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "物語の主人公は、偶然にもＥＳＰの力が目覚め、事件解決に貢献する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ＥＳＰＡＤＡのベルモントが、一同を代表して司会者――これはたいがい皇后さまか宰相夫人か、とにかく女性にきまってて、この日は赤十字マドリッド支部長としての市長夫人だった――へ、大芝居に騎士的な一礼をしている。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
