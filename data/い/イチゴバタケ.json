        "examples": {
          "standard": [
            {
              "text": "春になるといちご畑が赤く色づく光景は美しい。",
              "source": "幻辞"
            },
            {
              "text": "農家の息子はいちご畑の管理を毎日行っている。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑の収穫時期は主に春から初夏である。",
              "source": "幻辞"
            },
            {
              "text": "観光客がいちご畑でいちご狩りを楽しむ季節がやってきた。",
              "source": "幻辞"
            },
            {
              "text": "新しく開拓したいちご畑は、この地域では最大規模だ。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑の土壌管理には、高度な知識と経験が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "近所のいちご畑から、甘い香りが漂ってくる。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑全体にビニールハウスが設置されている。",
              "source": "幻辞"
            },
            {
              "text": "この村の主要産業はいちご畑での生産と販売である。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑の害虫駆除は有機栽培の重要な課題だ。",
              "source": "幻辞"
            },
            {
              "text": "気象条件がいちご畑の収量に大きく影響する。",
              "source": "幻辞"
            },
            {
              "text": "隣家はいちご畑に隣接した農業専用地域に位置している。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑を管理するロボットの導入が進んでいる。",
              "source": "幻辞"
            },
            {
              "text": "季節労働者がいちご畑の収穫を手伝いに来た。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑のすぐ脇には冷蔵保管施設がある。",
              "source": "幻辞"
            },
            {
              "text": "遠方からいちご畑の視察に訪れた農業関係者が多い。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑の規模拡大が地域経済に貢献している。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちはいちご畑での体験学習を通じて農業を学んだ。",
              "source": "幻辞"
            },
            {
              "text": "いちご畑のストレス管理は栽培技術の中核である。",
              "source": "幻辞"
            },
            {
              "text": "毎年いちご畑の生産性向上に向けた工夫が続けられている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いちご畑６・７東京日日（夕）　世の中に新聞記者ほど、無謀な訪問客はまたとなからうと思はれる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも町に売っておるいちごは古くていかぬというので、虚子と碧梧桐が毎朝一日がわりにいちご畑へ行て取て来てくれるのであった。",
              "citation": {
                "source": "くだもの",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は病牀でそれを待ちながら二人が爪上りのいちご畑でいちごを摘んでいる光景などを頻りに目前に描いていた。",
              "citation": {
                "source": "くだもの",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の高いかなめ垣をへだてて左手は庫裡になり、それについて右へ曲ると内庭で花壇やいちご畑があり、切りのこされた老木があちこちに大きな暗い蔭を落してゐる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬丁とボーイが十人もたかつてしやべつている大きな厩舎、幾列もある蔓草のからんだ召使の住居、整然と果てしなく並んだ納屋、長々とつづく葡萄棚、緑の牧場、果樹園、いちご畑などがあつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
