    "definitions": [
      {
        "index": 1,
        "gloss": "unlucky day (according to astrology)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日は「仏滅」だから、結婚式のようなお祝い事は忌み日として避けられる傾向がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母は何か新しいことを始める日は必ず暦を確認し、忌み日でないか気にするタイプだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行の計画を立てる際、偶然にも出発日が忌み日と重なり、少しばかり不安になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼が生まれたのは旧い太陰暦ではたまたま忌み日とされる八月七日であったため、信心深い昔気質の両親は恐れまた嘆いている。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "成年戒を授かつた後の男子は、忌み日として外に集つて居籠るのではなく、神人の一人として、群行神の一人に扮して、女の家に訪れて行く資格を得るのである。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村とつながっているためらしいが、なになに祝いとか、忌み日とか、なにそれ祭りとかいって、定日のほか月にたいてい二三回は休みがある。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私人の忌み日に、こだわって居る筈はない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
