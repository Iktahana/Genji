        "examples": {
          "standard": [
            {
              "text": "現場検証で、凶器と思われる遺留物が発見された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "密猟者が残したと思われる遺留物からは、彼らの追跡に繋がる手がかりが得られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "海岸に打ち上げられた遺留物の中には、異国の船から流れ着いたものもあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今盛んに燃焼している部分を完全に消し留めることによって、これから先燃焼するであろう物件を助け出し、それによってゼムリヤ号の搭載荷物とか遺留物品を点検して何かの新しい手懸りを得ようとするのであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
