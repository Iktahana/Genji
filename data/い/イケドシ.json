        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その人は今年がいけ年だという迷信を信じている。",
              "source": "幻辞"
            },
            {
              "text": "いけ年だからこそ特に注意するべきだと言われた。",
              "source": "幻辞"
            },
            {
              "text": "女性のいけ年は厄年よりも気をつけるべき時期だ。",
              "source": "幻辞"
            },
            {
              "text": "いけ年にお参りに行く風習は今でも残っている。",
              "source": "幻辞"
            },
            {
              "text": "彼女はいけ年だから特別な祈祷を受けることにした。",
              "source": "幻辞"
            },
            {
              "text": "いけ年の間は大きな決断を避けるべきというが根拠は不明だ。",
              "source": "幻辞"
            },
            {
              "text": "その女優もいけ年について公言しているという。",
              "source": "幻辞"
            },
            {
              "text": "いけ年だから婚約を後延ばしにするべきだと親に言われた。",
              "source": "幻辞"
            },
            {
              "text": "いけ年を過ぎるまで重要な仕事は避けたいと考えている。",
              "source": "幻辞"
            },
            {
              "text": "いけ年の厳密な定義は地域によって異なるようだ。",
              "source": "幻辞"
            },
            {
              "text": "迷信ではあるがいけ年を気にする人は多い。",
              "source": "幻辞"
            },
            {
              "text": "その祭りではいけ年の人々が特別に祝福される。",
              "source": "幻辞"
            },
            {
              "text": "いけ年について医学的根拠はないというが信じる人は多い。",
              "source": "幻辞"
            },
            {
              "text": "いけ年を乗り切るためにお守りを買った。",
              "source": "幻辞"
            },
            {
              "text": "その神社ではいけ年の祈祷が最も高額らしい。",
              "source": "幻辞"
            },
            {
              "text": "いけ年だからといって人生が変わるわけではないだろう。",
              "source": "幻辞"
            },
            {
              "text": "古い文献にはいけ年の記載が複数見られる。",
              "source": "幻辞"
            },
            {
              "text": "いけ年の概念は日本の民間信仰に深く根ざしている。",
              "source": "幻辞"
            },
            {
              "text": "いけ年だから車の運転に気をつけるという人もいる。",
              "source": "幻辞"
            },
            {
              "text": "いけ年に関する言い伝えは実に多くの種類がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いや、膝だの、女の背中だのといって、いけ年を仕った和尚が業体で恐入るが、話が、話じゃからそこはよろしく。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "分別盛りの好い年をして、という顔色の尋常ならぬに得右衛門は打笑い、「其方もいけ年を仕ってやくな。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけ年を仕って、貴女が、去ね、とおっしゃったを止せば可いことでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――松村さん、木戸まで急用――　いけ年を仕った、学芸記者が馴れない軽口の逃口上で、帽子を引浚うと、すっとは出られぬ、ぎっしり詰合って飲んでいる、めいめいが席を開き、座を立って退口を譲って通した。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、膝だの、女の背中だのといつて、いけ年を仕つた和尚が業体で恐入るが、話が、話ぢやから其処は宜しく。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処で死ぬ身と考える、と心細い身の上ぢやが、何と為ても思切れぬ……　いけ年を為た爺が、女色に迷ふと思はつしやるな。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけ年を仕って何も万八を極めるにゃ当りません。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけ年を仕てもとかく人｜真似は輟められぬもの、況てや小供という中にもお勢は根生の軽躁者なれば尚更、※忽その娘に薫陶れて、起居挙動から物の言いざままでそれに似せ、急に三味線を擲却して、唐机の上に孔雀の羽を押立る。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
