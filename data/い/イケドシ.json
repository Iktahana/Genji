    "definitions": [
      {
        "index": 1,
        "gloss": "old enough (to know better, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
