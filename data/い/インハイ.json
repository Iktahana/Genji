    },
    "definitions": [
      {
        "index": 1,
        "gloss": "high and inside pitch",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の得意なコースは、相手バッターの胸元をえぐるようなインハイだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インハイに力強いストレートが決まって、バッターは思わずのけぞった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "キャッチャーはインハイのサインを出したが、ピッチャーはコントロールを乱しボールになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あのバッターはインハイの球に弱いから、そこを狙っていくぞ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "監督は「インハイを有効に使って、相手打線を抑えろ」と指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "獨逸語のヴイルトシヤフトリツヘ、アインハイト（Wirtschaftliche Einheit）、英語のエコノミツク、ユニツト（Economic Unit）、即ち『經濟上の單位』を能く有効にしやうと云ふのが目的である。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稻造",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸語のヴィルトシャフトリッヘ、アインハイト（Wirtschaftliche Einheit）、英語のエコノミック、ユニット（Economic Unit）、即ち「経済上の単位」を能く有効にしようというのが目的である。",
              "citation": {
                "source": "教育の目的",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
