          "standard": [
            {
              "text": "オフセット印刷では、ブランケット cylinder と版 cylinder 間の印圧調整が仕上がりに影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試し刷りをして、印圧が強すぎないか、インクが滲んでいないか確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い活版印刷機では、印圧の均一性を保つのが職人の腕の見せ所だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
