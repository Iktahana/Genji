          "standard": [
            {
              "text": "約束を守れなかった責任を取るため、彼は監督に一札入れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "借金が返せない場合は、保証人に一札入れてもらう必要があるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の不正行為が発覚し、会社から一札入れるように求められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "場合によつては、金策のために上京される必要があるとしたら、例えば、借用証書を一札入れるとか、出来れば、相当な保証人をお立てになるとか……」「ないですよ、そんな保証人なんか」　にべもなく言つてのける岡本の口吻に、増田は、むかむかと腹が立つた。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
