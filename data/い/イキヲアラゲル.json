        "examples": {
          "standard": [
            {
              "text": "短距離走のゴール直前、選手は激しく息を荒げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "急峻な山道を登り終えた登山家は、疲労で息を荒げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "突然の物音に驚き、子供は息を荒げて母親にしがみついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自分の不正を暴かれ、彼は怒りに顔を紅潮させ、息を荒げて反論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「はぁ、はぁ、この坂はキツイな…もうちょっとだ！」と、少年は息を荒げながら友人に言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ま、まさか…そんなことが起こるなんて」彼女は息を荒げ、言葉を失っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "激しい攻防の末、両チームの選手たちは息を荒げ、コートに倒れ込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
