        "examples": {
          "standard": [
            {
              "text": "決意を固めた彼は、いざ行かんと言って故郷を後にした。",
              "source": "幻辞"
            },
            {
              "text": "大事な局面を迎え、いざ行かんと腹を決めた。",
              "source": "幻辞"
            },
            {
              "text": "もう迷いはない、いざ行かんと船に乗り込んだ。",
              "source": "幻辞"
            },
            {
              "text": "敵陣に突っ込む時、兵士たちが「いざ行かん」と叫んだ。",
              "source": "幻辞"
            },
            {
              "text": "修行僧が山に入る時、いざ行かんと歩き始めた。",
              "source": "幻辞"
            },
            {
              "text": "新天地へ向かう決心をして、いざ行かんと出発した。",
              "source": "幻辞"
            },
            {
              "text": "危険を承知で、いざ行かんと前へ進み始めた。",
              "source": "幻辞"
            },
            {
              "text": "覚悟を決めた者たちが、いざ行かんとともに歩んだ。",
              "source": "幻辞"
            },
            {
              "text": "人生の大事な選択の前に、いざ行かんと言い聞かせた。",
              "source": "幻辞"
            },
            {
              "text": "望郷の念もあったが、いざ行かんと決めて旅に出た。",
              "source": "幻辞"
            },
            {
              "text": "最後の岐路で、いざ行かんと力強く宣言した。",
              "source": "幻辞"
            },
            {
              "text": "後ろを振り返らずに、いざ行かんと前進した。",
              "source": "幻辞"
            },
            {
              "text": "長年の準備を経て、いざ行かんと踏み出した。",
              "source": "幻辞"
            },
            {
              "text": "一世一代の機会に、いざ行かんと決断を下した。",
              "source": "幻辞"
            },
            {
              "text": "恐怖心を押し殺して、いざ行かんと戦地へ赴いた。",
              "source": "幻辞"
            },
            {
              "text": "迷いや恐れを払拭して、いざ行かんと船出した。",
              "source": "幻辞"
            },
            {
              "text": "心に火をつけて、いざ行かんと新しい道を切り開いた。",
              "source": "幻辞"
            },
            {
              "text": "生死を覚悟して、いざ行かんと突撃した。",
              "source": "幻辞"
            },
            {
              "text": "真理を求めて、いざ行かんと修行の地へ向かった。",
              "source": "幻辞"
            },
            {
              "text": "運命に従うかのように、いざ行かんと歴史の舞台へ出た。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いざ行かん露もつ尾花をみなへし目うつりのよき野辺の秋見に武人。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは行かんいざ行かん。",
              "citation": {
                "source": "偏奇館吟草",
