        "examples": {
          "standard": [
            {
              "text": "お昼は外で買ったいなり寿司を食べた。",
              "source": "幻辞"
            },
            {
              "text": "運動会のお弁当にいなり寿司を詰めた。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司は作り置きができて便利だ。",
              "source": "幻辞"
            },
            {
              "text": "コンビニで販売されているいなり寿司は大事な収益源だ。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司のビジネスモデルは効率的な生産方式を実現している。",
              "source": "幻辞"
            },
            {
              "text": "食品科学でいなり寿司の保存技術が研究されている。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司の調理プロセスは食品衛生学の教科書に掲載されている。",
              "source": "幻辞"
            },
            {
              "text": "日本の民俗文化に根ざしたいなり寿司の美術表現がある。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司は伝統工芸の絵付けのモチーフになっている。",
              "source": "幻辞"
            },
            {
              "text": "日本文化研究の授業でいなり寿司の歴史が講義される。",
              "source": "幻辞"
            },
            {
              "text": "調理学科ではいなり寿司を教材にした実習が行われている。",
              "source": "幻辞"
            },
            {
              "text": "栄養バランスの観点からいなり寿司は医学的に推奨される軽食である。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司は消化に優しい食事として医療現場でも活用されている。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司の起源は江戸時代の商人文化と関連している。",
              "source": "幻辞"
            },
            {
              "text": "地域によっていなり寿司の味付けが異なることが食文化学の研究対象である。",
              "source": "幻辞"
            },
            {
              "text": "学校の給食メニューとしていなり寿司は人気が高い。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司は稲荷信仰との関連で民俗学的な意味を持つ。",
              "source": "幻辞"
            },
            {
              "text": "飲食業界ではいなり寿司を新しい価値提案で展開する企業が増えている。",
              "source": "幻辞"
            },
            {
              "text": "いなり寿司は旅の携帯食として古くから愛用されてきた。",
              "source": "幻辞"
            },
            {
              "text": "おふくろの味の代表としていなり寿司は多くの人に思い出される食べ物だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――林檎が一個一ルーブル、玉子一ツ五十カペック、――まだ驚きましたのは、バイカルを過ぎた頃売りに来た、いなり寿司のやうな食料です。",
              "citation": {
                "source": "シベリヤの三等列車",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂柳子と某と我と、そば、すし、いなりずし、大福もちなど食らいて日を送る。",
              "citation": {
                "source": "貧を記す",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、だんな、ごらんなせえよ、あそこに名物いなりずしとありますぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも四十まえの年配で、秩父名物のさるまわしなんですが、それぞれ、一匹ずつのさるをひざにかかえながら、しきりといなりずしをつまんでいるのに、眼光が少しばかり烱々として底光りがありすぎるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間の淫売婦が、いなりずしを頬ばりながらはいって来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此間の淫売婦が、いなりずしを頬ばりながらはいって来る。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も二、三日おきに、団子とかいなりずしとかいう風のものを度々見舞に貰うのであったが、それが幼な心によほど嬉しかったとみえて、今でもおぼろげな記憶の片隅にそのような場面のいくつかが残っている。",
              "citation": {
                "source": "温泉１",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いなりずしでも作ろうというと、「わあっ！",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "八津の墓にもいなりずしもってってやろう。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の膳、いなりずし、さんまのすし。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
