          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "傷一つない滑らかな表面と深い艶、間違いなくこの真珠は一級品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼はまだ若いが、包丁さばきと食材を見極める目はすでに一級品と言っていい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "祖父の遺品から出てきた万年筆は、時代遅れではあるものの細工の精巧さは一級品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この農園で採れるマンゴーは糖度が異常に高く、贈答用の一級品として高値で取引されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "数は多くはないが、粒よりの一級品であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十八　踊る時計",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べ物は料理に至って職人の腕の相違というものも現れ、大きな開きもついてくるかも知れないが、素材自体の開きなど、一級品同志になれば知れたものであろう。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の見たのは大雄寺（ダイオージとよむ）の身長三尺ぐらいの小さな仁王一対と、国分寺の伝行基作という薬師座像と観音立像とヒダのタクミ自像二ツですが、大雄寺の仁王は日本一の仁王だと思いましたし、国分寺の薬師と観音に至っては日本の仏像でいくつもない第一級品中の一級品ですよ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛騨・高山の抹殺――中部の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、昔から大阪にまぐろの一級品が運ばれないので、まぐろの味を知らないからである。",
              "citation": {
                "source": "お茶漬けの味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "配給には顔を見せたことのない見事なもの、まながつおという一級品だそうである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも正規の配給ルートによらぬ一級品の大魚を──　これはいわゆる横流しのやみ魚であろう。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふるくなって、少し匂いのついた鯛と、一級品の数の子とくらべれば、別の話になる。",
              "citation": {
                "source": "御馳走の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁清の鶴の香炉は、最近美術館に寄贈されたもので、国宝の中でも一級品と認むべきものである。",
              "citation": {
                "source": "根強い北陸文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは云へ、常に当代の第一級品の模造にのみ志してゐた所は、只の鼠ではなく、彼が詩歌の鑑識にかけては夙に一隻眼を具へた批評家であつたのを証するに足るものであらう。",
              "citation": {
                "source": "新詩社と石川啄木",
                "author": "――一つのおぼえ書き――",
                "note": "青空文庫"
              }
            },
            {
              "text": "志賀の小説は一級品だ。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原敬、高橋是清、米内光政、今村均というような人は、人間として一級品であるが、その他は、大抵、くだらなかった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、新聞記者として、明治大正の一流人物には大抵、逢ってきたが、少々ばかり皮肉っぽいのを別にすれば、首相としても、外交官としても、吉田さんは、やはり一級品だと思う。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
