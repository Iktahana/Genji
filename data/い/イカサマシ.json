        "examples": {
          "standard": [
            {
              "text": "その男は詐欺で逮捕され、プロのいかさま師として知られていた。",
              "source": "幻辞"
            },
            {
              "text": "カジノで働く人員は、いかさま師を見分ける訓練を受けている。",
              "source": "幻辞"
            },
            {
              "text": "映画の主人公はいかさま師で、巧みな手口で富豪を騙す。",
              "source": "幻辞"
            },
            {
              "text": "警察がいかさま師の一味を一斉に逮捕した。",
              "source": "幻辞"
            },
            {
              "text": "小説では、老年のいかさま師が若い弟子を育てるストーリーが描かれている。",
              "source": "幻辞"
            },
            {
              "text": "マジシャンの世界では、いかさま師との違いについて議論がある。",
              "source": "幻辞"
            },
            {
              "text": "その詐欺グループのリーダーは、一流のいかさま師として恐れられていた。",
              "source": "幻辞"
            },
            {
              "text": "銀行の職員は、いかさま師による不正取引を検出する訓練を受けている。",
              "source": "幻辞"
            },
            {
              "text": "テレビ番組で、いかさま師のテクニックが暴露された。",
              "source": "幻辞"
            },
            {
              "text": "競馬場の警備は、いかさま師による不正を防ぐために厳重になっている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に有名なはいかさま師の事件は、映画化されたほどだ。",
              "source": "幻辞"
            },
            {
              "text": "裁判所で、いかさま師の巧妙な手口が明かされた。",
              "source": "幻辞"
            },
            {
              "text": "FBI は、国際的ないかさま師の追跡に力を入れている。",
              "source": "幻辞"
            },
            {
              "text": "自伝で元いかさま師が、犯罪人生について語った。",
              "source": "幻辞"
            },
            {
              "text": "詐欺対策の専門家がいかさま師の心理について分析している。",
              "source": "幻辞"
            },
            {
              "text": "家族が、親族のいかさま師活動に気づいたのは、逮捕時だったという。",
              "source": "幻辞"
            },
            {
              "text": "古い記録には、江戸時代のいかさま師についての記述がある。",
              "source": "幻辞"
            },
            {
              "text": "ドキュメンタリーで、プロのいかさま師の日常が映された。",
              "source": "幻辞"
            },
            {
              "text": "心理学者がいかさま師の行動パターンについて研究している。",
              "source": "幻辞"
            },
            {
              "text": "ポーカートーナメントでは、いかさま師の参入を防ぐセキュリティが敷かれている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "こういういかさま師どもと一緒に、習慣は幾分異にしているが、やはり一つ穴の貉といったような種の連中を、私はしばしば認めた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその背後にいかさま師がひそんでいる場合のあることも聞いている。",
              "citation": {
                "source": "中西氏に答う",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いんちきばくちのいかさま師が使う仕掛けのコロじゃねえかよ」「へえ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の年寄りだっても、いんちきばくちのいかさま師がいねえとはかぎらねえんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、眼のとおり、一見していんちきばくちのいかさま師と思われる遊び人ふうの男をおなわにしていたものでしたから、あば敬の鼻の高いこと、高いこと。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の二匹は、同じいかさま師の一家にちげえねえんだ、やつらの仲間がうしろに隠れて、何か細工をしているに相違ねえよ、舌をかみ切った野郎が白状しねえのもそれなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あるいかさま師の手に入っていたのを見つけ出して、勝手ながらその時のままの姿で出場させたわけです」「どうもあなたの慧眼は驚くべきものです。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみを常に新たにされるというばかりでなく、ああいう標は、いろんないかさま師に何か思いつかせるきっかけになるのではないかと、その家に残っている女の人々の日常の感じが思いやられる。",
              "citation": {
                "source": "今日の耳目",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公はオスタップ・ベンデルという山師で、北極飛行で世界に有名なシュミット博士の息子と称するいかさま師である。",
              "citation": {
                "source": "音楽の民族性と諷刺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人としては「すり」「いかさま師」の様な都会風の悪事から、田舎わたらひをする者は、高野聖一類の詐偽脅嚇の罪を犯して廻つた。",
              "citation": {
                "source": "江戸歌舞妓の外輪に沿うて",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳兵衛は備中玉島を脱走して一時でも非人の群れに入つて、喧嘩の尻押しに買はれたり、目的は悪くなかつたにしろ、人に雇はれて偽種姓を語り、泣き落しに身の上話をする、いかさま師見たいなこともした男である。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかさま師の老輩義平次に拾ひあげられ、肴のふり売りしたものが、段々喧嘩で名を売つた挙句が、色町で武家奉公人を斬つて入牢したのがこの戯曲における主人公である。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎兵衛は、浮浪児から拾ひ上げられて、いかさま師に養はれ、其家の娘と野合したと言ふ男である。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中はいかさま師許りで、御互に乗せつこをして居るのかも知れない。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、諸君、いかさま師を引つ張つて来た。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかさま師をうんと云ふ程、酔はしてくれ玉へ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中はいかさま師ばかりで、お互に乗せっこをしているのかも知れない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、諸君、いかさま師を引っ張って来た。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかさま師をうんと云うほど、酔わしてくれたまえ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「が、あの我慢の出来んいかさま師のことなら、私は断言するが、あの男の振舞は男らしくない、海員らしくない、全然イギリス人らしくない、と思うよ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、「早駈けヘッセ人」などは大でたらめのいかさま師だと見くびっていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの人達はいかさま師じゃ」と手酷しくやっつけた。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でも芸術家として、内面的にはいつだって充分いかさま師ですからね。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかさま師でさあね――カルタ師じゃありませんよ」「あなたはいかさまカルタ師だったんですか」「さよう、いかさまカルタ師でもあったんで」「どうです、なぐられた事もあるでしょう！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅回りサーカス団のいかさま師だと揶揄する人もいます。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともそれが陪審員の判決よ」「俺がいかさま師だと、あてこすっているのかい。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "無言で、警告もせず、いかさま師がアメリカ人に突進してきた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊達に十年も賭場に通ってんじゃねえ、いかさま師を知らいでか。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "一味の裏にこっそり隠れてやがるイヤリングの男だ」　見つかったいかさま師が渋々前に出てきた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、あれを御聞きなせえまし、夜業でもしておりますものか、あの通り槌の音が聞えますゆえ、棟梁達の首は大丈夫でごぜえます」　権次の言葉に耳を澄まして見ると、いかさましんしんと冴え渡る夜気を透して、幽かに裏口のあたりからトントンカチと伝わって来たものは、まさしく大工達の槌の音でした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
