        "examples": {
          "standard": [
            {
              "text": "1857年、インド大反乱は、英国東インド会社の支配に対する大規模な抵抗運動の引き金となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "反乱軍の兵士たちは、勇敢に戦ったが、最終的には装備の差で制圧されてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この反乱の後、インドの統治は英国王室の直接統制下に置かれることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "クリミアでもインド大反乱でもめざましい働きをし、以来ことあるごとに名を挙げてきた。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "摩訶不思議なことに、インド大反乱を呼びこんだ狼煙のように、辺りに飛び火し、パブが急襲された。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
