        "examples": {
          "standard": [
            {
              "text": "回路設計において、コイルのインダクタンス成分がノイズにどう影響するか精査する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわ、この回路、インダクタンスが大きすぎて信号が歪んじゃってるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "高周波回路では、配線パターン自体が持つわずかなインダクタンスも無視できない要素となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "可変インダクタンスを利用して、受信機の同調周波数を微調整する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "電気学の書を理解するためには、インダクタンスとか、キャパシティとかいう術語の意味を熟知している必要がある。",
              "citation": {
                "source": "古代東洋への郷愁",
                "author": "――『仙書参同契』の解説――",
                "note": "青空文庫"
              }
            }
          ]
        }
