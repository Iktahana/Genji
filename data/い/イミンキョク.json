        "examples": {
          "standard": [
            {
              "text": "パスポートとビザの更新で、今日こそ移民局に行かないと！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "移民局の窓口、いつも行列だけど、今日は早めに来たから大丈夫かな？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "転居したら、速やかに移民局に住所変更届けを出さないとダメなんだよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "うわー、移民局の申請書類、複雑で間違えそう！誰か詳しい人いない？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「百点、Ａ１」としてパスしたが、Ｂ・Ａ・Ｌの意向では、この船は喜望峰廻り濠洲行きの、主として移民船に設計した関係上、内務省移民局の検査も受けなければならない。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．どんな卑しい動機からにせよ亞米利加で誰かを片附けようとすれば、追放法令のお蔭で、移民局の迅速な救助を期待できる。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の祖母のところで大きくなり、移民局の食堂ではじめて母というひとの顔を見たわけだった。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
