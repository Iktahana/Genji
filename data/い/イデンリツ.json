          "standard": [
            {
              "text": "知能の個人差における遺伝率を推定する研究が行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ある形質がどの程度遺伝的要因に影響されているかは、遺伝率で示される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "農業分野では、家畜の成長率や生産性に関する遺伝率が高い品種が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "環境要因も影響するため、遺伝率が100%でない限り、環境の重要性も考慮する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
