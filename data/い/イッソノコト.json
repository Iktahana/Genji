        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この文ではいっその事が重要な役割を果たしている。",
              "source": "幻辞"
            },
            {
              "text": "いっその事の意味を正しく理解することが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はいっその事という言葉をよく使う。",
              "source": "幻辞"
            },
            {
              "text": "文脈からいっその事の意味が推測される。",
              "source": "幻辞"
            },
            {
              "text": "いっその事は日本語の表現の中で一般的である。",
              "source": "幻辞"
            },
            {
              "text": "この例文ではいっその事がどのように使われているか注目しよう。",
              "source": "幻辞"
            },
            {
              "text": "いっその事の使い方は様々な場面で見られる。",
              "source": "幻辞"
            },
            {
              "text": "著者はいっその事という表現を好んで使う。",
              "source": "幻辞"
            },
            {
              "text": "日常会話ではいっその事がよく聞かれる。",
              "source": "幻辞"
            },
            {
              "text": "いっその事の定義を知ることで、文章の理解が深まる。",
              "source": "幻辞"
            },
            {
              "text": "複数の意味を持ついっその事の用法に注意が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "いっその事という語彙は初級者にとって習得が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "文法的にいっその事の位置が重要な役割を持つ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に見ると、いっその事の使用法は変化している。",
              "source": "幻辞"
            },
            {
              "text": "いっその事をテーマにした文学作品が多く出版されている。",
              "source": "幻辞"
            },
            {
              "text": "辞書ではいっその事の複数の意味が記載されている。",
              "source": "幻辞"
            },
            {
              "text": "いっその事という表現は、文化的な背景を反映している。",
              "source": "幻辞"
            },
            {
              "text": "翻訳時にいっその事の言語間での対応が課題となる。",
              "source": "幻辞"
            },
            {
              "text": "いっその事の使用頻度は、年代によって異なることがある。",
              "source": "幻辞"
            },
            {
              "text": "学習者がいっその事を習得するには、実践が重要である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もし東京にあの風が吹かなかったら、もし東京の街の泥と塵がなかったら、そして電車の数を増すか、あるいはいっその事に全部無くしてしまったら、それだけでも東京市民の顔は幾分か柔らかく快いものになりはしまいかと思われる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "争議が解決した後も、いっその事思い切って従業員の制服を全廃して思い思いの背広服ないし和服着流しにする事を電気局に建言したらどうかと思ってみたのであった。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事全部分からないアラビア語ででもあればかえって楽であろうが、困った事には時々ところどころ分かる日本語であるからいけないのである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで自分の素人考えでは、いっその事、どこか「家屋の鎖骨」を設計施工しておいて、大地震がくれば必ずそこが折れるようにしておく。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし足はどうなってもいい、靴さえ減らなければいいというのならば、いっその事全部鋼鉄製の靴をはけばいいわけである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いっその事、飲んでから二、三日目に死ぬ毒薬を下さい」",
              "citation": {
                "source": "医者と病人",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような考えから、私はいっその事日刊新聞というものを全廃したらよくはないかという事につい考え及んだわけである。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事、あなた方は思い切ってライオンや象を買って、その骨を入れたら大きくて丈夫でよくはありませんか」　と又笑い出しました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事、死んだ親父の遺言通りに、この叔父の禿げた脳天をタタキ破ってやった方が功徳になりはしまいか……なぞと考えた事もあった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事、これに目鼻をつけてもらいましょうか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事だと、手前の口へね、喇叭と遣った……こうすりゃ鳥の精がめしあがると同じ事だと……何しろ腹ン中は鴛鷲で一杯でございました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからと云うものは、店も何もなくしてしまったわたしが、何遍もいっその事死んでしまおうかと思ったのを、小さい手でわたしの胸をいじって、大きい目でわたしの顔を見て笑う、可哀いお玉を一しょに殺す気になられないばっかりに、出来ない我慢をして一日々々と命を繋いでいた。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでとうとう感情の背反が起こって来た時に、これが両方とも人間であるか、あるいはいっその事両方とも象である場合にはかえって始末がいいかもしれないが、困った事には一方が人間で一方が象であったのである。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "えゝ、いっその事死んでくれ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にしてもこれは井ノ口の奥さんが一世一代の精魂を打ち込まれた物だから、いっその事、娘の名前で氏神様に上げてしまった方がよかろう」　という事になりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな例がある一方に、上級生の堕落やおのろけや、落し文が、下級生を刺戟しているのではあるまいかと考えられる廉もあるから、いっその事、同級生ばかりを一室に入れて成績を見てはどうかという意見が教員間に持ち上っている……云々。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事二人共身体中グショグショになればいいとおっしゃった事はお忘れでないでしょうね」　なぞとあるのを、福岡の或る教育家が見て驚いて、「ペン習字は絶対に禁止せねばならぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事彼女に打明けてしまおうか――。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしい馬鹿馬鹿しさの心と、不平の心が心の中をはしりまわって居る、いっその事ここにかくれて居て彼の女の様子を見て居ても見ようか。",
              "citation": {
                "source": "砂丘",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タペストリの裏で二人の話しを立ち聞きした時は、いっその事｜止めて帰ろうかと思うた」と低いのが正直に云う。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事黙って後を付けて行く先を見届けようか、それではまるで探偵だ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドュルタルは現世界に愛想をつかして、いっその事カトリック教に身を投じようかと思っては、幾度かその「空虚に向っての飛躍」を敢てしないで、袋町から踵を旋らして帰るのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじ事実を一つでも探り出して今更其の信仰を動かすよりは、いっその事ますます其の信仰を強くしてそれを以て世を治めて行こうとお考え遊ばしたのではございませんでしょうか。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事、ひと思いに死にたいとも思う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事、神田の職業紹介所まで行って、また、あの桃色カードの女になってみようかと思う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事、ひと思いに殺されてしまいたい。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜平もこゝに心身共に疲れ、こんなに責められるなら、いっその事死んだ方がましだと、それから二度目の自殺を謀ったのであります。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事予定通り此野郎が死んでいて呉れたら、そしたら？",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっその事上陸して山陽を行こうと思い付いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそのこと……）「おまい、寝られないのかい？",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
