        "examples": {
          "standard": [
            {
              "text": "その英語のイディオムは、直訳しても意味が通じないことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現地のイディオムを覚えることは、言語学習において非常に重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はそのイディオムを使って、巧みに相手の意図を表現した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もとより文法や語彙の正確なのに越したことはないが、飽くまで、「自分のもの」をそれで伝へる工夫をすべきであつて、英米人風の云ひ廻し――つまりイディオムなどといふふうなものは、日本人が無理に使ふのは不見識だといふことである。",
              "citation": {
                "source": "外国語教育",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
