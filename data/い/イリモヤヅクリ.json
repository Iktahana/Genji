        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その城は、壮麗な入母屋造りの天守閣がそびえ立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、なんて趣のある建物！入母屋造りが素敵だね」観光客は感嘆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "伝統的な日本家屋の多くは、風情のある入母屋造りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "法隆寺の建築に入母屋造りの多いこともここに関係がある。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寄棟造りの単純明快なのに比べて、この金堂の屋根に複雑異様な感じがあるのは、入母屋造りのせいであるともいえよう。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし入母屋造りがみな同じ印象を与えるというのではない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
