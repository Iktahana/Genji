        "examples": {
          "standard": [
            {
              "text": "すみません、10階まで行きたいのですが、このＥＬＶ（エレベーター）のボタンを押していただけますか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このビルは古いですが、ＥＬＶは最近改装されたようで、乗り心地が良いですね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "足が不自由なので、ＥＬＶは移動に不可欠な設備です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ＥＬＶが故障していて、階段で上がらなければなりませんでした。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "（カントリー・ジョ・マクドナルド）10　ＥＬＶＩＳ　ＩＳ　ＢＡＣＫ　提供はミシン会社のシンガーだった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
