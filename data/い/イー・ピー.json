    "definitions": [
      {
        "index": 1,
        "gloss": "extended-play (record)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女のデビューＥＰは、予想を上回る売上を記録し、すぐにフルアルバムの制作が決まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このバンドは最近、新しいサウンドを試した実験的なＥＰをデジタルリリースしたばかりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔、レコード店で手に入れたインディーズバンドのＥＰを、今でも大切に持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼らのライブ会場で限定販売されたＥＰは、あっという間に完売してしまったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが少年の日の寝床に溢れたあの終わりを恐れる涙を、一九九〇年七月十一日、神宮球場脇のイベント会場、ＴＥＰＩＡで開かれたマイクロソフトワークス（以下ワークスと書く）の発表会場で、なんとオレはまざまざと思いだしてしまった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＴＥＰ・ＯＮ・ＩＴ！",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、で見た、マコーイズ（うっかり、マッコイズなどと発音すると、ワラに死ぬほど馬鹿にされる）の〈ハング・オン・スルーピー／フィーヴァー〉というシングル、そして、『ポップ・ギア』と同時上映になっていた、『五人の週末』という映画に出ていた、デイヴ・クラーク・ファイヴのＥＰを、友人の長兄にさしだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ここには十数枚のシングルと、六枚のＥＰ、それに三枚のＬＰしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "広岡が、ビートルズをジャケットにもどし、ＥＰをポータブルにのせ、一曲目を飛ばして、二曲目に針を落とす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "広岡はＥＰをひっくりかえし、こんどは一曲目から針を落とす。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、スピイドのない享楽の狩猟、ＰＥＰを欠く狂噪、ＣＨＩＣの見られない街路進歩、何という神さまに忘れられた砂漠がハルビンであろう！",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "開演の迫った合図――軍楽隊のＯＮＥ・ＳＴＥＰだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ＥＰＲＯＭ（Erasable Programable ROM）と呼ばれる特殊なタイプなら、いったん書き込んだ情報を紫外線を照射するなどの処置を施して消してから、再度新しい内容を書き込むことができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コストで比較すれば、ＥＰＲＯＭはマスクＲＯＭに比べて大幅に高くなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが「なにが起きるか分からない」との古山の意見を入れて、取りあえず初期の出荷分はＥＰＲＯＭで臨み、これ以上大きな問題は起こらないと見極めがついた時点でマスクＲＯＭに切り替えるという方針が採用された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが増設ボード化とＥＰＲＯＭという二重の保険をかけて古山が取り組んだ賽の河原の石積みのゴールは、この時点でもまだ先が見えなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リズム・アンド・ブルースのＥＰも数多くならんでいたし、グレン・ミラーもあればチェット・ベイカーやバルネ・ウィランもあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇二年頃の『ネーチュル』に、インドにある英人ジー・イー・ピール氏が寄書して、犬の両眼の上に黄赤い眼のような両点あるものは、眠っていても眼を※り居るよう見えるから、野獣甚だこれを恐れて近附かぬと述べた。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
