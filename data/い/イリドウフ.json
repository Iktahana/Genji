        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今夜のおかずは、ヘルシーな煎り豆腐にしようかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が作る煎り豆腐は、優しい味付けでいつも美味しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "栄養バランスを考えて、ひじきと人参入りの煎り豆腐を作った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "居酒屋のメニューに、定番の煎り豆腐があったので注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷めても美味しい煎り豆腐は、お弁当のおかずにもぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "喰べたくないときにやる弁当の礼で、このあいだは鯖の味噌煮と煎り豆腐と、菜の胡麻よごしだったけれど、あんなにうまい物を喰べたのは生れて初めてで、喰べながら涙が出てしようがなかった。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
