        "examples": {
          "standard": [
            {
              "text": "レポート執筆中、言葉の意味が曖昧なときは、まず岩波国語辞典を引くことにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この辞書は、その網羅性と正確さから、多くの研究者に愛用されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "岩波国語辞典には、古語から現代語まで、幅広い語彙が収録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "文章をまとめる際は、『岩波国語辞典』から始まって、『広辞苑』や講談社の『大字典』、平凡社の『大百科事典』、岩波書店の『近代日本総合年表』などを引きづめです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、『岩波国語辞典』と『リーダーズ英和辞典』という最も使用頻度の高い二つは、マシンで引いています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに「岩波国語辞典」、「広辞苑」、「大字典」、「平凡社大百科事典」といった、日常、本を読む際に使用している参考図書の類も、電子本のページから呼び出したい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
