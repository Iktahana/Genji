        "examples": {
          "standard": [
            {
              "text": "彼はいやしん坊で、いつも無一文だった。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊は貯金できず、給料日前は苦しい思いをする。",
              "source": "幻辞"
            },
            {
              "text": "兄がいやしん坊のため、妹はお小遣いをもらえない。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊の傾向がある経営者は従業員の給与を抑える傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "給与体系の見直しはいやしん坊の経営からの脱却を示している。",
              "source": "幻辞"
            },
            {
              "text": "経済学でいやしん坊という心理的傾向が消費行動に影響することが研究されている。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊の行動パターンは行動経済学の対象である。",
              "source": "幻辞"
            },
            {
              "text": "心理学や人格心理学の研究でいやしん坊という気質が分析される。",
              "source": "幻辞"
            },
            {
              "text": "行動経済学ではいやしん坊の消費行動パターンが教材として用いられる。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊という性格がもたらす経済的損失は生涯にわたって蓄積する。",
              "source": "幻辞"
            },
            {
              "text": "金銭教育ではいやしん坊な傾向を改善することが重要なテーマとされる。",
              "source": "幻辞"
            },
            {
              "text": "社会心理学ではいやしん坊という人格特性が社会的階層と相互関係があることを指摘する。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊な親に育てられた子どもはその傾向を受け継ぐことが多い。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊という性格は人間関係にも悪影響を及ぼすことがある。",
              "source": "幻辞"
            },
            {
              "text": "自己啓発の観点からはいやしん坊な傾向の克服が個人の成長の一要素とされている。",
              "source": "幻辞"
            },
            {
              "text": "栄養学的観点からいやしん坊の傾向がある者の食事内容が偏る傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊と健康寿命の関係が疫学的に研究されている。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊な性質が人生の選択肢を限定してしまう悪循環が研究対象である。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊の心理を理解することは人間心理の研究において重要である。",
              "source": "幻辞"
            },
            {
              "text": "いやしん坊から脱却することは個人の自由と幸福度の向上に寄与する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「こんなところでいやしんぼうすると、断層の中へ落ち込みますよ。",
