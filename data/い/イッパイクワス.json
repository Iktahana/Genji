        "examples": {
          "standard": [
            {
              "text": "まさかあの新人に一杯食わされるとは、思いもよらなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "契約の土壇場で競合他社に一杯食わされ、プロジェクトは白紙に戻った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "相手の裏をかいて見事に一杯食わしてやったときの爽快感はたまらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "すっかり騙されて、見事に一杯食わされたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "萩原は後にどうも変な奴だと思ったが、まんまと一杯食わされたといい、私ははじめから一杯食わすつもりで出掛けたのだと言って笑った。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをこんな所で、夜鷹みてえにしゃがみこんでいるンだもの、分りッこありゃしねえ」「まあそれでも落ちあえたからいいじゃないか」「またうめえことをいッといて、一杯食わすんじゃないかと、少しお冠が曲りかけていたところなンで」「そうしたらどうおしだえ？",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「とんとわけのわからない男だ、あるいはいっぱいくわすのかもしれないぞ！",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
