        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいダム建設プロジェクトでは、詳細な環境影響評価（ＥＩＡ）が実施されます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "開発計画の承認には、ＥＩＡ報告書の提出が義務付けられています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この地域のＥＩＡ、結果はどうだったのかしら？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ＥＩＡの結果、建設予定地周辺の生態系への影響が懸念されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 2,
