        "examples": {
          "standard": [
            {
              "text": "ピアノの先生から「バッハのインヴェンション第13番を来週までに仕上げてきて」と言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現代音楽の文脈において、この技法は独創的なインヴェンション（創意）と言える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "楽譜の隅に、インヴェンションの装飾音の弾き方についての書き込みがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「インヴェンションとシンフォニアのCD、どれがおすすめかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "熟睡することが出来ず絶えずバッハのインヴェンションが頭の中にぐるぐるまわっていた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この若者たちのなかに、あとでフランク・ザパのマザーズ・オブ・インヴェンションに加わるデニー・ブルースのような少年もいたのだから。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "メキシコとの国境ちかくのＸＥＲＢ局は、フランク・ザパのマザーズ・オヴ・インヴェンションのＬＰをはじめて電波にのせた局で、ロサンゼルスの黒人の靴みがき少年たちは、ほとんどがトランジスタ・ラジオのダイアルをこの局にあわせていたのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
