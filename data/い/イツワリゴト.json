        "examples": {
          "standard": [
            {
              "text": "あの政治家が口にする耳障りの良い公約は、しょせん有権者を騙すための偽り事にすぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "子どもの頃は、親の気を引くために些細な偽り言を並べてはよく叱られたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "誠実そうに見える彼のその言葉が、まさか全て偽り事だったとは思いもしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "偽り言うては相成らんぞ」「へえへえ、もうほかならぬ御前様でござりますゆえ、偽りはゆめおろか、毛筋程のお世辞も言わぬがこの亭主の自慢でござります。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その六人の女中のうち、ひとり目立って貧しげな女の子に、声高く夫婦約束をしてやって、なおそのうえ、女の微笑するようないつわりごとを三つも四つも、あらわでなく誓ってやったものだから、女の子、しだいに大学生を力とたのんだ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その記事によれば、不知火といえるは、かたもなきいつわりごとである。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
