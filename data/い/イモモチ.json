        "examples": {
          "standard": [
            {
              "text": "北海道旅行で食べた芋餅が美味しくて、お土産に買って帰った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖母が作る芋餅は、素朴な甘さで懐かしい味がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焼きたての芋餅に醤油を少しつけて食べるのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "芋餅は五月五日の定まつた食物にもなつて居るが、別にその莖を食料にすることも栽培の一つの目的であるらしい。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋餅は五月五日の定まった食物にもなっているが、別にその茎を食料にすることも栽培の一つの目的であるらしい。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "好き嫌いももちろんあるし、極上等の油煙墨の色を未だ知らないせいもあるが、私は油煙墨では絵を描く気がしない。",
              "citation": {
                "source": "硯と墨",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
