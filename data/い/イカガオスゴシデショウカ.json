        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長年連絡の途絶えていた友人に、メールで『お変わりなくいかがお過ごしでしょうか』と書いた。",
              "source": "幻辞"
            },
            {
              "text": "年賀状の冒頭に『皆様いかがお過ごしでしょうか』と記した。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス文書で『平素はお世話になっております。貴社の皆様はいかがお過ごしでしょうか』と書いた。",
              "source": "幻辞"
            },
            {
              "text": "新年の挨拶状で『昨年は大変お世話になりました。本年はいかがお過ごしでしょうか』と記した。",
              "source": "幻辞"
            },
            {
              "text": "季節の挨拶として『春もいよいよ本番となりましたが、いかがお過ごしでしょうか』と書いた。",
              "source": "幻辞"
            },
            {
              "text": "取引先への定期メールで『日頃からのご支援ありがとうございます。いかがお過ごしでしょうか』と述べた。",
              "source": "幻辞"
            },
            {
              "text": "長期出張から帰社して『出張中はご迷惑をおかけしました。皆様いかがお過ごしでしょうか』と挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "病気で休職していた同僚が職場復帰した際『長らく休みをいただきました。皆様いかがお過ごしでしょうか』と述べた。",
              "source": "幻辞"
            },
            {
              "text": "転職先での初日に『新しい環境に来ました。皆様はいかがお過ごしでしょうか』と前職の同僚に連絡した。",
              "source": "幻辞"
            },
            {
              "text": "異動後の初メールで『新しい部署に来ました。前部署の皆様はいかがお過ごしでしょうか』と書いた。",
              "source": "幻辞"
            },
            {
              "text": "久しぶりに顧客訪問した際『最後の訪問から随分経ってしまいました。いかがお過ごしでしょうか』と挨拶した。",
              "source": "幻辞"
            },
            {
              "text": "季節の変わり目に『寒い日が続いておりますが、いかがお過ごしでしょうか』と定期レターに記した。",
              "source": "幻辞"
            },
            {
              "text": "昇進した知人へのお祝いメールで『新しい役職でのご活躍をお祈りしております。いかがお過ごしでしょうか』と書いた。",
              "source": "幻辞"
            },
            {
              "text": "定年退職者へのお手紙で『退職後の生活はいかがお過ごしでしょうか』と丁寧に尋ねた。",
              "source": "幻辞"
            },
            {
              "text": "海外駐在員との連絡で『異国での生活はいかがお過ごしでしょうか』と気遣った。",
              "source": "幻辞"
            },
            {
              "text": "長距離通勤をしている友人への手紙で『毎日お疲れのことと思いますが、いかがお過ごしでしょうか』と記した。",
              "source": "幻辞"
            },
            {
              "text": "新居に引っ越した人へのお祝い状で『新しいお家でのご生活はいかがお過ごしでしょうか』と尋ねた。",
              "source": "幻辞"
            },
            {
              "text": "業界の先輩へのビジネスメールで『いつもお忙しいことと思いますが、いかがお過ごしでしょうか』と始めた。",
              "source": "幻辞"
            },
            {
              "text": "独身の友人へ『相変わらずお忙しいと思いますが、いかがお過ごしでしょうか』と親友として書いた。",
              "source": "幻辞"
            },
            {
              "text": "高齢の親族へ『季節の移ろいを感じることと思いますが、いかがお過ごしでしょうか』と思いやりを込めて書いた。",
              "source": "幻辞"
            }
          ],
