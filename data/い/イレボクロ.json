        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台メイクで、頬に小さく入れぼくろを描いて役に臨んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はファッション誌を見て、モデルの真似をして目の下に繊細な入れぼくろを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「その入れぼくろ、本物かと思った！」と友人に驚かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女芝居の一座や、女牢の中なんぞでは、女同士が言い交わして、入れぼくろまで、するようなこともあるんだって……」「そうか」　伝七が、腕をこまねいて考え込んだところへ、帰った来たのは竹道だった。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから眼の縁の青い隈取り、頬紅、入れぼくろ、唇の線、鼻筋の線、と、殆ど顔のあらゆる部分が不自然に作ってあります。",
              "citation": {
                "source": "痴人の愛",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
