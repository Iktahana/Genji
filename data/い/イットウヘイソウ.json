        "examples": {
          "standard": [
            {
              "text": "荒れ狂う冬の海の上で、ベテランの一等兵曹が若い水兵たちを厳しく叱り飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は一等兵曹としての誇りを胸に、最後まで沈みゆく艦の機関室に残り続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "潜水艦の狭い通路ですれ違う際、新兵は一等兵曹の鋭い眼光に思わず身を固くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "どうだ入野一等兵曹、あと三十｜浬で飛行島にぶつかる筈だが、西南西にあたって、なにか光は見えぬか」「はい、なにも見えません。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦橋に立つ入野一等兵曹は、行手にあたって、ほの明るい光のかたまりを見出した。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから五分ばかりたって、艦橋当直の入野一等兵曹の声、「副長。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝声管が鳴って、当直入野一等兵曹がかけよる。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等兵曹の服装をしているが、紅顔の美少年だ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯の水兵と三等兵曹とは服に異ひはないとか、服の左腕についてゐる山形は善行証であるとか、一等兵曹の直ぐ上は上等兵曹、それから準士官だとか、さうしたことを知つてゐるのを彼は私に誇つた。",
              "citation": {
                "source": "ある職工の手記",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
