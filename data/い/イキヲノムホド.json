        "examples": {
          "standard": [
            {
              "text": "グランドキャニオンの夕日は、息を呑むほどの絶景だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの選手の最後のジャンプは、まさに息を呑むほどでしたね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オーロラが夜空を舞う光景は、息を呑むほど神秘的で、言葉を失った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "サグラダ・ファミリアの内部構造は、その複雑さと美しさにおいて息を呑むほどの芸術作品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女のピアノ演奏は、技術的な正確さだけでなく、感情表現においても息を呑むほど深かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その映画のスケール感は息を呑むほど圧倒的で、観客は皆、スクリーンに釘付けになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
