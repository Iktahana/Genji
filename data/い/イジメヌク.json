        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "学校の上級生たちが、新入生をいじめ抜いていた。",
              "source": "幻辞"
            },
            {
              "text": "その人物は、自分の立場を利用して部下をいじめ抜いた。",
              "source": "幻辞"
            },
            {
              "text": "意地悪な性格の者が、一人の生徒をいじめ抜いた結果、その生徒は登校拒否になった。",
              "source": "幻辞"
            },
            {
              "text": "会社内でいじめ抜かれた従業員が、精神的な病を発症した。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜かれた者は、しばしば社会への不信感を持つようになる。",
              "source": "幻辞"
            },
            {
              "text": "兄弟姉妹をいじめ抜く子どもに対しては、親の厳しい指導が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "職場でいじめ抜かれるという経験は、人生に大きな傷跡を残すことがある。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜かれた被害者が、その後加害者側に回る可能性も指摘されている。",
              "source": "幻辞"
            },
            {
              "text": "クラス全体でいじめ抜こうという風潮は、非常に危険である。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜かれていた生徒が、ついに親に相談を決意した。",
              "source": "幻辞"
            },
            {
              "text": "長年いじめ抜かれ続けた者の心の傷は、簡単には癒えない。",
              "source": "幻辞"
            },
            {
              "text": "権力を持つ者がいじめ抜くケースは、特に悪質である。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜く行為は、加害者にとっても人格の歪みをもたらす。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜かれた時期が長いほど、心的外傷は深刻になる傾向にある。",
              "source": "幻辞"
            },
            {
              "text": "人間は、いじめ抜かれることで初めて他者の苦しみを理解することもある。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜く側の多くは、その行為の深刻さを認識していない。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜かれた経験を持つ大人たちが、被害者支援の活動に携わっている。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜く文化が存在する環境では、新人はすぐに去ってしまう。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜かれていることに気づかない親も少なくない。",
              "source": "幻辞"
            },
            {
              "text": "いじめ抜く行為の責任は、加害者だけではなく傍観者にもある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "たまたまその居処を烏が見付けると、寄ってたかっていじめ抜くのはそのためだといっている。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど残酷に私一人をいじめぬくためには、よほど重大な原因があったのだろう。",
              "citation": {
                "source": "おみな",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
