        "examples": {
          "standard": [
            {
              "text": "サバンナを疾走するインパラの群れは、絵葉書のような光景だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チーターに追われるインパラが、驚異的なジャンプでかわす様子は息をのむほどだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あそこにインパラがいるよ！」と、ガイドが興奮気味に指差した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし蝗やフラミンゴーに限らず、ゼブラでもニューでも、インパラでもジラフでもみんな群れをなして棲息している。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "インパラという動物の跳躍も見物である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
