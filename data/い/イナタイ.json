          "standard": [
            {
              "text": "駅前のいなたい雑居ビルが取り壊されることになった。",
              "source": "幻辞"
            },
            {
              "text": "そのいなたい外観とは違い、内部は最新の設備が整っている。",
              "source": "幻辞"
            },
            {
              "text": "いなたい景観を改善するため、街おこしプロジェクトが始まった。",
              "source": "幻辞"
            },
            {
              "text": "いなたい施設をリノベーションして新しい商業施設を作った。",
              "source": "幻辞"
            },
            {
              "text": "その企業はいなたい工場を最新工場に改築した。",
              "source": "幻辞"
            },
            {
              "text": "建築技術の進歩により、いなたい構造の補強が可能になった。",
              "source": "幻辞"
            },
            {
              "text": "いなたい建物の耐震性能を向上させるため、新技術が導入された。",
              "source": "幻辞"
            },
            {
              "text": "建築学の講義でいなたい構造の分析が行われる。",
              "source": "幻辞"
            },
            {
              "text": "都市計画学ではいなたい地域の再開発が研究テーマである。",
              "source": "幻辞"
            },
            {
              "text": "いなたい景観とは違い、その町の人情は温かい。",
              "source": "幻辞"
            },
            {
              "text": "港湾エリアのいなたい倉庫が文化施設に変わった。",
              "source": "幻辞"
            },
            {
              "text": "現代アートの表現手法としていなたい美学が注目されている。",
              "source": "幻辞"
            },
            {
              "text": "いなたい建物をキャンバスに見立てたストリートアートが人気だ。",
              "source": "幻辞"
            },
            {
              "text": "いなたい外観の古い家屋に足を踏み入れると、別世界が広がっていた。",
              "source": "幻辞"
            },
            {
              "text": "都市再生プロジェクトではいなたい地区が最優先地域として指定された。",
              "source": "幻辞"
            },
            {
              "text": "写真家はいなたい風景を美的対象として撮影していた。",
              "source": "幻辞"
            },
            {
              "text": "いなたい建築様式はレトロの美しさとして再評価されている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的遺産としてのいなたい建物の保存が検討されている。",
              "source": "幻辞"
            },
            {
              "text": "観光地化する前のいなたい町並みが記録映像に残っている。",
              "source": "幻辞"
            },
            {
              "text": "復興事業ではいなたい地域の特性を活かした計画が立てられている。",
              "source": "幻辞"
            }
