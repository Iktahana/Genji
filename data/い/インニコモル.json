    "definitions": [
      {
        "index": 1,
        "gloss": "to stay bottled up inside oneself",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「最近、元気ないね？」「うーん、ちょっと色々あってさ、一人で陰にこもってたんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと話したら？ いつまでも陰にこもってちゃダメだよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、大事な相談があると、つい陰にこもってしまう癖がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試験に落ちてから、彼女はすっかり陰にこもり、誰とも話さなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "なにも陰にこもるわけじゃねえが、そもそもこのあな（事件）はあっしのところへころがり込んできたんだ、といったようなわけだからね、てがらのおすそ分けに、さいわい両国までは遠くねえし、屋形船かなんかを浮かべて、ぱいいち涼み酒とはどんなものかね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と抜刀をさげた一同が、きょろきょろあたりを見まわしていると、近くにあたって、「うふ、ふふふ……」　と陰にこもる含みわらい。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京温泉」を、初めに出すために、陰にこもるのではないかといふ山野の説、或ひは然らん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to have a melancholic appearance, atmosphere (of a person, object, place)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その古い洋館は、夕暮れ時になると、なんとも陰にこもる雰囲気を帯びる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の絵には、いつもどこか陰にこもるような、物悲しい色彩が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "訃報を聞いた彼の顔には、隠しきれない陰にこもる表情が浮かんでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "静かな雨音を聞きながら、部屋全体が陰にこもるような気分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
