        "examples": {
          "standard": [
            {
              "text": "敗北の恥辱に耐えかね、彼は単身、敵陣に乗り込み引決した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "武士道精神に則り、万死を覚悟の引決を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう後には引けない。ここで引決するしかない。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の選択は、長年の苦悩の末の、究極の引決であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "曰く、吾聞く、前代の大臣の吏に下さるゝや、多く自ら引決すと。",
