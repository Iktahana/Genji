    "definitions": [
      {
        "index": 1,
        "gloss": "to hold one's breath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "警備員の巡回ルートを避け、彼は闇の中で息を潜めて進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "重要な発表を待つ間、会場全体が息を潜めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "物音一つ立てず、獲物の気配を感じ取ろうと、狩人は息を潜めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鳥の巣を壊さないように、観察者は息を潜めて距離を保った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "かくれんぼで、鬼の足音が近づいてくるのを聞き、子供たちは物陰で息を潜めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まさか、こんな展開になるとは！」と、観客は息を潜めてスクリーンに釘付けになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "潜水士は、水圧の変化に注意しながら、息を潜めて作業を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あの人が歸つたらまた遊びませうね（子供を左手の室へやり後をしめる、心配さうに息を潜める）私にお話があるとおつしやるのですか？",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍観する自分の眼前で、その恐ろしい、息を潜めるような瞬間が実現せられたら、目撃者である自分は、どうしたらよいのか。",
              "citation": {
                "source": "渋谷家の始祖",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
