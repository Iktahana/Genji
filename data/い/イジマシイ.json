        "examples": {
          "standard": [
            {
              "text": "その行為は、いじましい心根から生まれたものだった。",
              "source": "幻辞"
            },
            {
              "text": "彼のいじましい性格は、多くの人を不快にさせる。",
              "source": "幻辞"
            },
            {
              "text": "いじましい考え方では、人生で大事なものを見落としてしまう。",
              "source": "幻辞"
            },
            {
              "text": "その人物のいじましさは、言動の隅々に現れている。",
              "source": "幻辞"
            },
            {
              "text": "いじましい欲望が人間を醜くする可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "いじましい気持ちを持つことは、人間らしい感情の一つだが、それに支配されてはいけない。",
              "source": "幻辞"
            },
            {
              "text": "貧困の中でもいじましい心を持たない人がいる一方で、富裕層の中にいじましい者もいる。",
              "source": "幻辞"
            },
            {
              "text": "いじましい争いよりも、寛大な心を持つことが尊いのではないか。",
              "source": "幻辞"
            },
            {
              "text": "その契約には、いじましい条項が数多く含まれていた。",
              "source": "幻辞"
            },
            {
              "text": "いじましい態度では、信頼を得ることができない。",
              "source": "幻辞"
            },
            {
              "text": "人間の最も醜い側面の一つが、いじましさだと言えるだろう。",
              "source": "幻辞"
            },
            {
              "text": "いじましい嫉妬心が、多くの悲劇の原因となってきた。",
              "source": "幻辞"
            },
            {
              "text": "いじましい理由で他人を傷つけることは避けるべきだ。",
              "source": "幻辞"
            },
            {
              "text": "その提案には、いじましい意図が隠されているように見える。",
              "source": "幻辞"
            },
            {
              "text": "いじましい計算高さは、人間関係を破壊する。",
              "source": "幻辞"
            },
            {
              "text": "社会の中で、いじましさは一種の病気のように蔓延することがある。",
              "source": "幻辞"
            },
            {
              "text": "いじましさを克服することが、精神的な成長への第一歩である。",
              "source": "幻辞"
            },
            {
              "text": "歴史上のいじましい行為は、多くの教訓をもたらしている。",
              "source": "幻辞"
            },
            {
              "text": "いじましくない寛容さを持つことが、文明社会の基礎である。",
              "source": "幻辞"
            },
            {
              "text": "いじましい心を持つ自分自身と向き合うことが、自己啓発である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いじましい職業を忘れかけていもすれば、貧富も忘れかけている。",
              "citation": {
                "source": "「見ること」の意味",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくともぼくにとって人間たちの世界は、そんないじましい、見えない巨人の足が一踏みすればたちまちあらゆる秩序も正義も美しさも跡形もなくなり、ただの瓦礫に化してしまう、インチキなその場その場のウソのお城だとしか考えられなかった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
