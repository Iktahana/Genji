        "examples": {
          "standard": [
            {
              "text": "旧システムのデータを新システム用に一括変換する作業に一日かかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デジカメで撮った数百枚の写真を、専用ソフトでJPEG形式に一括変換した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レポート提出前に、ワードファイルからPDFファイルへ文書を一括変換しておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この動画編集ソフトには、複数の動画ファイルを同時に別の形式へ一括変換する機能がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "単漢字変換のイージーワード　１・０版は「これじゃ売り出しても勝負にならんわ」というわけでデビューには至らず、一九八五年九月、五百字までの一括変換をサポートするバージョン２・１で初めて発売となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百字の一括変換が結構まともに動作するのには、当時感心した覚えがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
