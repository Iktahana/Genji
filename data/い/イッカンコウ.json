        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "中高一貫校に入学してから、受験に縛られず部活動に打ち込む毎日を送っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "あの学校は小中一貫校として改組され、異学年交流が盛んに行われているらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一貫校のメリットは、高校入試がない分、独自のカリキュラムで先取り学習ができる点にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "私立・中高一貫校と大学で教育を受けているから、この藩王は英国人として通用する。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "国王は人生の盛りを、英国一貫校で無駄に五年も過ごしていない。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこれらの部下達は決まって私立中高一貫校や大学の代表選手であり、容易に欧州の最高クラブに入会できた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
