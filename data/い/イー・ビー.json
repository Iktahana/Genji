        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「重い辞書を持ち歩くのは大変だけど、EBなら専用の端末一台で済むから助かるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "出版社は紙の書籍の発売と同時に、特典動画を付けたEBの予約販売も開始した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あら、その小説もうEB版が出てるの？ 私も後でダウンロードしてみるわ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＳＡＳＥＢＯＫＩＮもどこへやら、ここばかりは明るい光が窓に輝いている。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい夜の街、ＳＡＳＥＢＯも華やかに火花と輝いていますが、うごめいている人達は、なにか宿命のようなすてばちで、ただ暗い夜空をながめているようでならない。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＡＳＥＢＯは、朝鮮戦線の上り下りがまるで脈搏のようにはっきりひびいてくるのはなんとなく心細い様子である。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この形は犁が耨の進化したものであるというイー・ビー・テイラーの説を裏書している。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
