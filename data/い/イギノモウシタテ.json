    "definitions": [
      {
        "index": 1,
        "gloss": "formal complaint (regarding conduct of a criminal case)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
