        "examples": {
          "standard": [
            {
              "text": "「やった！合格だ！」受験生たちは、合格発表の掲示を見て一斉に色めき立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新製品の発表を知った開発チームは、期待と興奮で色めき立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、あの歌手が来るの？！」会場にいたファンたちは、ざわめきながら色めき立った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「市ちゃんも仲々腕が上つた」とか、「今の若い者は、春秋に富んで居る癖に惚れ方が性急だ」とか、「橘さんも隅に置けぬ」とか、一座は色めき立つて囂々と騷ので、市子は、『私｜此方の爲にしたんぢやなくて、皆さんが盃を欲しさうにして被居るから空けて上げたのですわ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「市ちやんも仲々腕が上つた」とか、「今の若い者は、春秋に富んで居る癖に惚れ方が性急だ」とか、「橘さんも隅には置けぬ」とか、一座は色めき立つて囂々と騒ぐので、市子は、『私｜此方の為にしたんぢやなくて、皆さんが盃を欲しさうにして被居るから、空けて上げたのですわ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、新劇の領域では、少くとも、作家並に劇団は、真剣に、それぞれの立場に於て自分の仕事の可能性といふことを考へ、或は転向を覚悟し、或は自粛自戒を心掛け、更にこの機会に、希望をもつて新しい道を拓いて行かうとするなど、こゝのところ、少しばかり色めき立つてゐることは事実である。",
              "citation": {
                "source": "新劇の行くべき途",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "児玉が姿をあらはすと、中年の男組はにはかに色めき立つて、彼の周囲へ押し寄せた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁は俄かに色めき立つ。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど重太郎が来たと、一同が色めき立つ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「船だっ」「追いついたぞ」　七名は色めき立つ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろめきたつ観客の、海のような底深い喧騒にかぶさり、またしても校歌の合唱がはじまる。",
              "citation": {
                "source": "昼の花火",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
