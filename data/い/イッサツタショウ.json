        "examples": {
          "standard": [
            {
              "text": "その任務は、一殺多生という倫理的なジレンマを抱えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "SF映画では、しばしば一殺多生的な選択が描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「一殺多生」の考え方には、賛否両論がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史上の大決断では、一殺多生を迫られる状況もあっただろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "然らずは一殺多生の理に任せ、御身を斬つて両段となし、唐津藩当面の不祥を除かむ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一殺多生一　月ハ瑞龍ノ雲ニ隠ルトイエドモ、光ハ暫ク西山ノ峰ニトドマル。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一殺多生、一山を焼いても、五山百峰の法を明らかに照らしめれば、わたくしたち武人の殺は、決して敢えなく無辜の命や文化を亡ぼすものでは、決してないはずと存じまする」「いかにも、その通りだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "（――一殺多生じゃ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "――万生万殺――一殺多生――いずれも天理の常でしょう。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
