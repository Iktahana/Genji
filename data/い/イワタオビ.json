        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "妊娠5ヶ月に入ったから、そろそろ岩田帯で腰を支えようと思ってるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "助産師さんに、岩田帯の正しい巻き方を教えてもらったわ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は岩田帯が一般的だったけど、今はもっと楽なサポーターもあるんだね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今まで黙っておいでになりましたお父様は、いよいよその年の八月に六月目の岩田帯をお母様がなさるようになりますと、胎教というのをお初めになりましたそうです。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だったかな……そう、岩田帯とかもするんだろう。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩田帯の代りに温湿布がぐるぐる巻いてあった。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月一日は、岩田帯の儀式があった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
